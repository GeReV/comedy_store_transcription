{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "static",
    "rootDir": "src",
    "noEmit": true
  },
  "include": ["src"]
}
