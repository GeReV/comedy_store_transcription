[{"start":9.09,"end":12.13,"text":"מאז שנולדתי אני רואה תוכניות בידור בטלוויזיה"},{"start":12.13,"end":13.9,"text":"וככה גם נראו החיים שלי"},{"start":13.9,"end":17.89,"text":"סתם"},{"start":17.89,"end":20.16,"text":"אבל מאז שאני רואה הקומדיסטור"},{"start":20.16,"end":21.9,"text":"השתנו החיים שלי לגמרי"},{"start":21.9,"end":23.6,"text":"וכעת הם נראים כך"},{"start":23.6,"end":26.82,"text":"סתם"},{"start":26.82,"end":29.92,"text":"מאז לאימא שלי קוראים ז'ז'וכה לאסטרה"},{"start":29.92,"end":31.82,"text":"לאבא שלי קוראים יפת"},{"start":31.82,"end":33.56,"text":"ולי קוראים יש לי יש לי"},{"start":33.56,"end":35.0,"text":"סתם"},{"start":35.0,"end":37.98,"text":"השם האמיתי שלי הוא מיסטר פיחס"},{"start":37.98,"end":39.72,"text":"רק דבר אחד אני לא מבין"},{"start":39.72,"end":41.76,"text":"למה הדביקו אותי לסולם הזה?"},{"start":41.76,"end":43.76,"text":"אחרי הפרסומות תשקום בקיסטור"},{"start":43.76,"end":45.71,"text":"מיסטר פיחס"},{"start":45.71,"end":47.71,"text":"איכס מוכן לשידור"},{"start":47.71,"end":53.41,"text":"תוכנית זהו מבוססת המקרים שהתרחשו במזיאות"},{"start":53.41,"end":59.17,"text":"עשר בין המציאות לדמיון הינו מקרי בהחלט"},{"start":59.17,"end":63.74,"text":"תמות האנשים והמקומות שונו לצורך העלילה"},{"start":63.74,"end":65.74,"text":"ומאתה הם ניקאים"},{"start":65.74,"end":108.53,"text":"תמצור לו את הכדור אני אומר לך"},{"start":108.53,"end":114.99,"text":"למי? למי למצור? למי? לא לא לבוטה שבילי"},{"start":114.99,"end":116.99,"text":"לבוטה שבילי מתור לבוטה?"},{"start":116.99,"end":118.99,"text":"כן כן כן כן"},{"start":118.99,"end":126.5,"text":"תמצור לו בהגח שמול"},{"start":126.5,"end":128.94,"text":"אתם בטוחים?"},{"start":128.94,"end":129.94,"text":"הוא פנוי"},{"start":129.94,"end":132.89,"text":"לא רגע, זה מה זה מדבר רגע"},{"start":132.89,"end":134.0,"text":"מה זה מדבר עצו?"},{"start":134.0,"end":135.05,"text":"אולה"},{"start":135.05,"end":136.44,"text":"תשאי לי מהגרעינים כמובן"},{"start":136.44,"end":137.44,"text":"אלא!"},{"start":137.44,"end":138.88,"text":"אהלו!"},{"start":138.88,"end":139.88,"text":"אהלו!"},{"start":139.88,"end":140.88,"text":"אהלו!"},{"start":140.88,"end":141.88,"text":"אהלו!"},{"start":141.88,"end":143.1,"text":"אהלו!"},{"start":143.1,"end":144.1,"text":"אהלו!"},{"start":144.1,"end":145.1,"text":"אהלו!"},{"start":145.1,"end":146.1,"text":"אהלו!"},{"start":146.1,"end":150.74,"text":"אהלו!"},{"start":150.74,"end":151.8,"text":"אהלו!"},{"start":151.8,"end":159.2,"text":"אהלו!"},{"start":159.2,"end":160.13,"text":"אהלו!"},{"start":160.13,"end":161.42,"text":"אהלו!"},{"start":161.42,"end":164.21,"text":"אהלו!"},{"start":164.21,"end":259.09,"text":"אהלו!"},{"start":259.09,"end":260.09,"text":"אהלו!"},{"start":260.09,"end":262.09,"text":"אהלו!"},{"start":262.09,"end":266.67,"text":"פקות גאים להציג את הפרק הרביעי"},{"start":266.67,"end":269.67,"text":"בסדרה הקומית הישראלית הגרועה ביותר!"},{"start":269.67,"end":307.86,"text":"משפחת ישראלית"},{"start":307.86,"end":309.86,"text":"יעלי להתרכז גם ככה זה בלי ניקון"},{"start":309.86,"end":312.92,"text":"אני בודק את כושר התעופה של המזוודה"},{"start":312.92,"end":315.92,"text":"הגעתי למסקנה שאם המזוודות יוכלו לעוף לבד"},{"start":315.92,"end":318.92,"text":"אז יהיה אפשר לבטר על טעם איתן במטוסים"},{"start":318.92,"end":321.92,"text":"וואו, אז זה אומר שיהיה אפשר להכניס במטוס מיטה זוגי"},{"start":321.92,"end":325.92,"text":"אין, ואת תוכלי לעשות מיליונים בטיסות טרנסטלנטיות"},{"start":325.92,"end":326.92,"text":"אוף, תגיד"},{"start":326.92,"end":328.92,"text":"אולי תזור לי ללמוד בעל פה אודי"},{"start":328.92,"end":330.92,"text":"יש לי היום מבחן בד לסרט גירושים פלוס"},{"start":330.92,"end":333.85,"text":"עם סטלונה שברצנגר ואיבגי"},{"start":333.85,"end":337.37,"text":"תגידי איזה סרט המשך של הנושא השמיני"},{"start":337.37,"end":338.37,"text":"לא למה?"},{"start":338.37,"end":343.49,"text":"חבל כי אז בטוח היית מקבלת את התפקיד של המפלצת"},{"start":343.49,"end":344.49,"text":"אני חוגר"},{"start":344.49,"end":347.49,"text":"קח את הנייר הזה ותעזור לי ללמוד בעל פה"},{"start":347.49,"end":348.49,"text":"תראה שאין לי טעויות"},{"start":348.49,"end":352.65,"text":"שלום"},{"start":352.65,"end":355.57,"text":"נמאס לי ממך"},{"start":355.57,"end":357.57,"text":"נמאס לי ממך ומחיה נישואים"},{"start":357.57,"end":360.83,"text":"כל מה שנותר לי זה רק לברוח"},{"start":360.83,"end":361.8,"text":"שלום"},{"start":361.8,"end":365.28,"text":"שלום ולא להתראות"},{"start":365.28,"end":367.59,"text":"אין לי טעויות אודי?"},{"start":367.59,"end":371.81,"text":"הטעות היחידה שלך זה שאת מנסה להיות שחקנית ולא דוגמנית פנים"},{"start":371.81,"end":374.81,"text":"מה אודי תחשב שאני יכולה להיות דוגמנית פנים?"},{"start":374.81,"end":376.77,"text":"כן, של מסכות ריתוך"},{"start":376.77,"end":392.44,"text":"ניכוש, אלפקה"},{"start":392.44,"end":395.44,"text":"דומה"},{"start":395.44,"end":396.84,"text":"הי תראי מה הבאתי לך"},{"start":396.84,"end":398.67,"text":"זה יפה"},{"start":398.67,"end":400.67,"text":"זה עלה לי כמעט חצי מזכורת"},{"start":400.67,"end":406.67,"text":"אבל כל פעם שאני מסתכל עלייך אני אומר צריך להכניס משהו יפה הביתה לשם שחילוי"},{"start":406.67,"end":409.25,"text":"ניכוש"},{"start":409.25,"end":412.39,"text":"מה זה?"},{"start":412.39,"end":417.08,"text":"שלום נמאס לי ממך"},{"start":417.08,"end":419.08,"text":"נמאס לי מחיי הנישואין"},{"start":419.08,"end":422.08,"text":"כל מה שנותר לי זה רק לברוח"},{"start":422.08,"end":425.26,"text":"אז שלום שלום ולא להתראות"},{"start":425.26,"end":427.86,"text":"יפה יפה"},{"start":427.86,"end":430.02,"text":"טוב והנה גם המזוודה"},{"start":430.02,"end":434.14,"text":"אני רואה שתפסתי את הממותה בדרך החוצה"},{"start":434.14,"end":438.65,"text":"אה? איך ידעתם מתי לצחוק מה אתם שומעים את המחשבות שלי?"},{"start":438.65,"end":440.65,"text":"טוב שתצה נראה אותה גיבורה גדולה"},{"start":440.65,"end":442.61,"text":"הרי זה ג'ונגל שם בחוץ"},{"start":442.61,"end":448.21,"text":"רגע מצד שני ג'ונגל זה סביבה עטיבית לגורילה כמוה"},{"start":448.21,"end":464.62,"text":"איץי איזה יופי של אהיל"},{"start":464.62,"end":468.68,"text":"איזה מתנה יפה הוא קנה לי החמוד הזה"},{"start":468.68,"end":471.71,"text":"אני חושבת שזה מתאים לעמוד בחדר השינה"},{"start":471.71,"end":474.71,"text":"באמת הגיע הזמן שמשהו יעמוד שם סוף סוף"},{"start":474.71,"end":478.71,"text":"אוו יש פה גם פתק"},{"start":478.71,"end":484.7,"text":"שלום נמאס לי שלום ולא להתראות"},{"start":484.7,"end":490.53,"text":"יופי יציק אז המנורה הזאת זה בעצם מתנת פרידה"},{"start":490.53,"end":494.84,"text":"חבל יציק באמת חבל דווקא רציתי סיר לקוסקוס"},{"start":494.84,"end":498.93,"text":"אוו הנה המזוודה של המנובל הזה"},{"start":498.93,"end":503.92,"text":"הוא בטח יגיע לקחת אותה ואז אני אבקש ממנו פתק החלפה"},{"start":503.92,"end":511.73,"text":"שלום לך אפשר לדעת מה אתה עושה פה"},{"start":511.73,"end":515.73,"text":"לא, מה אני עושה פה? מה עד לך פה?"},{"start":515.73,"end":518.73,"text":"מה אני עושה פה? מה אתה עושה פה?"},{"start":518.73,"end":521.73,"text":"מה אני עושה פה? מה הוא עושה פה?"},{"start":521.73,"end":530.42,"text":"לאלפרד פניטה קיבלת אסטייק בפיטה"},{"start":530.42,"end":532.42,"text":"לא, בצלוחי תמייל"},{"start":532.42,"end":534.42,"text":"איזה גנב הייתי כברי נהודים כברה"},{"start":534.42,"end":537.42,"text":"אלפרד חמודי, אלפרד מוטק שלי, אתה הגעת בדיוק בזמן"},{"start":537.42,"end":540.42,"text":"הלילה אני עוברת לישון אצלך"},{"start":540.42,"end":543.42,"text":"נכון שלא אכפת לך לקבל אחת כמוני"},{"start":543.42,"end":544.42,"text":"יש איזה בעיה קטנה"},{"start":544.42,"end":546.42,"text":"אתה יודעת שיש לי עדר ג'מוסים בבית"},{"start":546.42,"end":548.42,"text":"עכשיו מאז הרעידת אדמה"},{"start":548.42,"end":550.42,"text":"הם נבלו כל כך והתפזרו בכל חדרי הבית"},{"start":550.42,"end":553.42,"text":"כך שאין מקום עוד לאנטילופה כמוך"},{"start":553.42,"end":555.42,"text":"שתשגע אותם לגמרי ותביל אותם עוד יותר"},{"start":555.42,"end":557.54,"text":"אבל אם כבר מתעסקים באנטילופות"},{"start":557.54,"end":559.54,"text":"יש לי בדיחה שוס גדול, שימו לב"},{"start":559.54,"end":561.82,"text":"אתמול אני פוגש את חבר שלי"},{"start":561.82,"end":563.82,"text":"אלכסה קמצן"},{"start":563.82,"end":565.82,"text":"עכשיו איך שאני פוגש אותו אני כמובן שואל אותו"},{"start":565.82,"end":570.72,"text":"תגיד כשאתה מקיים יחסים, אתה מדבר עם אשתך"},{"start":570.72,"end":575.74,"text":"אז הוא אומר לי רק אם יש טלפון בסביבה"},{"start":575.74,"end":577.86,"text":"קוסוקטי"},{"start":577.86,"end":582.76,"text":"עכשיו מה מצחיק פה? מה מצחיק?"},{"start":582.76,"end":586.76,"text":"איך אלכס הקמצן יכול שיהיה לו טלפון בדירה"},{"start":586.76,"end":590.76,"text":"אם הוא לא שילם חשמל ארלונה וטלפון אולי שבע שנים"},{"start":590.76,"end":593.76,"text":"הוא כל כך קמצן שהוא לא מעיז לשלם בגלס"},{"start":593.76,"end":595.76,"text":"איזה קנה בקוסוקטי"},{"start":595.76,"end":597.76,"text":"אתה כל כך מוכשן"},{"start":597.76,"end":599.76,"text":"לא לא אתה מצחיק"},{"start":599.76,"end":600.76,"text":"אתה היסטריה"},{"start":600.76,"end":602.76,"text":"אם לא היה פה דרמה משפחתית"},{"start":602.76,"end":605.76,"text":"אני הייתי מצטרף לכל המפגרים האלה שפה צוחקים"},{"start":605.76,"end":607.76,"text":"אתה אל תצטח עליהם זה הם ידונים שלי"},{"start":607.76,"end":608.76,"text":"ואל תערב הורים"},{"start":608.76,"end":610.76,"text":"כן אתה יודע למה הם צוחקים?"},{"start":610.76,"end":611.76,"text":"למה?"},{"start":611.76,"end":612.76,"text":"כי אתה מצחיק"},{"start":612.76,"end":613.76,"text":"לא אתה יפה"},{"start":613.76,"end":615.76,"text":"אתה מצחיק כמו הנופלס מצונת"},{"start":615.76,"end":617.76,"text":"ואתה יפה כמו קבנוס חריזמטי"},{"start":617.76,"end":618.76,"text":"מאפרה מלוכלכת"},{"start":618.76,"end":619.76,"text":"טישום ממלכתי"},{"start":619.76,"end":620.76,"text":"צינור סטור"},{"start":620.76,"end":622.76,"text":"מזגן מפוצל ונדליסטי"},{"start":622.76,"end":623.76,"text":"מייאר צלופן שרות"},{"start":625.76,"end":626.76,"text":"אי חנית"},{"start":626.76,"end":627.76,"text":"כן?"},{"start":627.76,"end":628.76,"text":"כן, אתה יודע מה?"},{"start":628.76,"end":629.76,"text":"מה?"},{"start":629.76,"end":630.76,"text":"תקפוץ לטאקי על המרפסת ביום שישי"},{"start":630.76,"end":632.76,"text":"בסדר אני אבוא"},{"start":632.76,"end":633.94,"text":"להתראות"},{"start":633.94,"end":636.14,"text":"מצחיק כמו גמבה במשבל"},{"start":636.14,"end":638.14,"text":"רושיציק תעזוב עכשיו את זה"},{"start":638.14,"end":639.14,"text":"יש דברים יותר חשובים"},{"start":639.14,"end":641.14,"text":"למשל מה יהיה עם הילדים"},{"start":641.14,"end":642.14,"text":"מה יהיה עם הילדים?"},{"start":642.14,"end":643.14,"text":"נשלח אותם לספארי"},{"start":643.14,"end":646.29,"text":"יש שם עכשיו קורס לקופים בתנאי פלימייה"},{"start":646.29,"end":649.86,"text":"היי אמא, היי אבא"},{"start":649.86,"end":650.86,"text":"אוי אני לא מאמינה"},{"start":650.86,"end":652.86,"text":"הנה הטקסט שלי"},{"start":652.86,"end":653.86,"text":"אתם לא תאמינו"},{"start":653.86,"end":654.86,"text":"יש לבחינה חוזרת"},{"start":654.86,"end":655.86,"text":"אצל הבמים בבית"},{"start":656.86,"end":657.86,"text":"אני אחזור מוקדם"},{"start":657.86,"end":659.95,"text":"זאת אומרת מוקדם בבוקר"},{"start":659.95,"end":661.95,"text":"ביי"},{"start":661.95,"end":662.95,"text":"אוי איציק"},{"start":662.95,"end":664.01,"text":"איזו טעות"},{"start":664.01,"end":665.01,"text":"אני לא מאמינה"},{"start":665.01,"end":666.01,"text":"זה היה טקסט של זיווה"},{"start":666.01,"end":667.01,"text":"ואני חשבתי"},{"start":667.01,"end":668.01,"text":"שאתה כתבת את הפתק הזה"},{"start":668.01,"end":670.01,"text":"ואת רוצה לעזוב אותי"},{"start":670.01,"end":672.01,"text":"אני חשבתי שאת כתבת את הפתק הזה"},{"start":672.01,"end":673.01,"text":"ורוצה לעזוב אותי"},{"start":673.01,"end":674.01,"text":"אוי איציק"},{"start":674.01,"end":676.01,"text":"אני מרגישה כל כך מטומטמת"},{"start":676.01,"end":677.01,"text":"אוי תקווה"},{"start":677.01,"end":678.01,"text":"גם אני"},{"start":678.01,"end":680.04,"text":"מרגיש שאת כל כך מטומטמת"},{"start":680.04,"end":683.04,"text":"אך בואי בואי אינה"},{"start":683.04,"end":685.2,"text":"בואי מאפרה הסדוקה שלי"},{"start":685.2,"end":688.2,"text":"בואי אינה גזוסטרה מעוקמת"},{"start":688.2,"end":689.39,"text":"דומן"},{"start":689.39,"end":690.45,"t