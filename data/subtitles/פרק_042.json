[{"start":18.08,"end":32.65,"text":"תודה רבה."},{"start":61.51,"end":64.77,"text":"קומדיסטור אחרי הפרסמות. אלא לקה."},{"start":131.45,"end":148.13,"text":"תודה רבה לכם. בשבוע הבא אנחנו נהיה איתכם עם עורכים אחרים."},{"start":148.13,"end":152.33,"text":"יהיו איתנו כאן יואן סבסטיאן בח, תומאס אדיסון, יהושע בנון ונורית עירש."},{"start":152.33,"end":159.32,"text":"ואיתם לדון מה נושא האם ניסים ברדה מהופקים יכול לפתוח את חנות המקולת שלו לפני הגעת השוקו או לאחריו."},{"start":159.32,"end":161.57,"text":"יהיו איתנו. תודה ולהתראות."},{"start":166.14,"end":167.62,"text":"כולה מושבים."},{"start":167.62,"end":170.66,"text":"טוב."},{"start":170.66,"end":172.04,"text":"ההדיעה שהיא תהיה תהיה."},{"start":172.04,"end":173.64,"text":"מכה חדשה פה כולדת את זה."},{"start":173.64,"end":176.28,"text":"המזלמה המשוטטת של ג'ודי."},{"start":176.28,"end":183.26,"text":"ערב טוב."},{"start":183.26,"end":188.79,"text":"כאן ג'ודי לא צהרון עובר שית סוקניק ויקרא קרפין במדבר ודברים."},{"start":188.79,"end":194.19,"text":"וטיפול מכה חדשה על הדת ביני ישראל, התנך אומניה."},{"start":194.19,"end":200.28,"text":"ויעקום העם כאיש אחד ויינג בשגאון וידמלה שוב לימים רחוקים."},{"start":200.28,"end":205.9,"text":"ויבוא בקרב גיבורי התנך דוחי העוז וידבק במעשיהם הנשגבים."},{"start":205.9,"end":212.49,"text":"ותיקח ג'ודי את מצלמתה המשוטטת לטור הארץ ולראות הקצע הקטע."},{"start":212.49,"end":217.47,"text":"כאן עברה המצחק יעקב שרה סתירה, סדום והמורה."},{"start":217.47,"end":224.32,"text":"הלו צלב ראית פה איזה ג'ינג'י בורח?"},{"start":224.32,"end":227.58,"text":"בואי אני אומר לך, אני יושב לי ככה נעמתי תקלום."},{"start":227.58,"end":229.64,"text":"מתאום לך, אני מרוקקת רב."},{"start":229.64,"end":232.41,"text":"מתהפוק לי בין העיניים אוכל אמר כזה דבר."},{"start":232.41,"end":233.89,"text":"ראית לנו ברח, ראית?"},{"start":234.27,"end":236.99,"text":"בואי לדם ידחוק, אני בואי לך."},{"start":236.99,"end":238.67,"text":"תודה, הלאה, הלאה."},{"start":238.67,"end":243.07,"text":"הלאה, לך לך מארצך ומלדדך לך."},{"start":243.07,"end":246.02,"text":"למי אמרת לך לך מארצך ומלדדך?"},{"start":246.02,"end":247.08,"text":"לך."},{"start":247.08,"end":248.27,"text":"וולה."},{"start":248.27,"end":249.09,"text":"וולה."},{"start":249.09,"end":251.32,"text":"יא בן נעבת המרדות."},{"start":251.32,"end":252.66,"text":"בן נעבת המרדות."},{"start":252.66,"end":253.28,"text":"וולה."},{"start":253.28,"end":254.16,"text":"וולה."},{"start":254.16,"end":256.54,"text":"שטוק, יערל בן זדים."},{"start":256.54,"end":257.87,"text":"בן זדים?"},{"start":257.87,"end":259.67,"text":"כן, יא בלק בן אבינואם."},{"start":259.67,"end":260.45,"text":"וולה."},{"start":260.45,"end":264.77,"text":"בלק בן אבינואם, אימא שלך מסתובבת עם אשתך ואיר הכני."},{"start":264.77,"end":268.77,"text":"שעשירית מכל מקנחה היא כמול, יא בלעם בן בלק."},{"start":268.77,"end":269.56,"text":"כמול?"},{"start":269.56,"end":270.06,"text":"היא כמול."},{"start":270.06,"end":274.06,"text":"וולה, שר שלך כמו סנא בויר בעש בעינינו הוא קה."},{"start":274.06,"end":278.01,"text":"שיתפוס אותך לבייתן, יבלה אותך ויקח אותך תרשישה."},{"start":278.01,"end":280.06,"text":"תעשה לנבא, יעמלך."},{"start":280.06,"end":282.06,"text":"לחפש התונות."},{"start":282.06,"end":284.15,"text":"ראה על יד הבר."},{"start":284.15,"end":286.68,"text":"דבא."},{"start":286.68,"end":288.68,"text":"כה אמר זוזו לבני ישראלי אמור."},{"start":288.68,"end":290.75,"text":"מה הוא עבל אבל עם זה?"},{"start":290.75,"end":291.81,"text":"מה זה זה באמא שלי?"},{"start":291.81,"end":293.81,"text":"ותאגו, בכך יומם ולילה."},{"start":293.81,"end":295.81,"text":"בייר זוזו כי טוב."},{"start":295.81,"end":297.91,"text":"והיא גז זוזו לכם בסנג'ר."},{"start":297.91,"end":299.91,"text":"בייר זוזו כי עוד יותר טוב."},{"start":299.91,"end":301.91,"text":"בייר זוזו כי טוב את מראי,"},{"start":301.91,"end":303.91,"text":"טוב את מגעה וטוב את הציבור כולו."},{"start":303.91,"end":305.91,"text":"בייר זוזו פעמיים כי טוב."},{"start":305.91,"end":307.91,"text":"ותאגו בזה יומם ולילה, יומם ולילה,"},{"start":307.91,"end":309.91,"text":"יומם ולילה, יומם ולילה."},{"start":309.91,"end":311.91,"text":"ותאגו בכך."},{"start":311.91,"end":312.91,"text":"ניו."},{"start":312.91,"end":315.39,"text":"אכן תמונות קשות,"},{"start":315.39,"end":319.39,"text":"והיא ערב, והיא בוקר, יום שני."},{"start":319.39,"end":322.35,"text":"אחת, שתיים, שלוש."},{"start":322.35,"end":326.94,"text":"לא הפכתי לנציב מלח,"},{"start":326.94,"end":328.94,"text":"עבדתי עליי."},{"start":328.94,"end":334.39,"text":"הלו."},{"start":334.39,"end":335.64,"text":"הלו."},{"start":335.64,"end":337.27,"text":"כמה זה ב..."},{"start":337.27,"end":338.27,"text":"מה?"},{"start":338.27,"end":339.77,"text":"בשיחים, כמה?"},{"start":339.77,"end":341.73,"text":"תגיד לי, מה אתה חושב שאני?"},{"start":341.73,"end":344.3,"text":"מה, את לא..."},{"start":344.3,"end":346.3,"text":"אני כן, אני מוכרת מזונות."},{"start":346.3,"end":350.29,"text":"יש לך ניקייה, אמבורגר, שניצל, מה אתה רוצה לאכול?"},{"start":350.29,"end":353.51,"text":"רציתי, יוצאת לי את התאבון."},{"start":353.51,"end":355.93,"text":"לך, יס, סקס-מניאק!"},{"start":355.93,"end":359.41,"text":"אני חוזר ומדגיש לציבור, אין מה לדאוג."},{"start":359.41,"end":363.41,"text":"משטרת ישראל תטפל בבעיית התנוחומניה הזאת אחת ולתמיד."},{"start":363.41,"end":365.56,"text":"לא, תודה רבה, אדוני, אני עמוד שמח."},{"start":365.56,"end":367.56,"text":"אולי אתה יכול להגיד לי איפה יש פה קיוסק?"},{"start":367.56,"end":369.56,"text":"אדוני, בימינו לא צריך קיוסק."},{"start":369.56,"end":371.56,"text":"שים לב מה עושים כשצמאים."},{"start":371.56,"end":373.56,"text":"וופה!"},{"start":373.56,"end":378.56,"text":"משה ותחתברת ואיזה מימנו מהיית."},{"start":378.56,"end":380.56,"text":"משה!"},{"start":380.56,"end":383.49,"text":"אכן השתנו סדרי בראשית."},{"start":383.49,"end":389.65,"text":"בעולם של בו אין איש אשר יודע מה יום ומה עונה כי אין פרי ביתו."},{"start":389.65,"end":395.68,"text":"והתנח מושכנו בתנוך וההרגל אוכזנו ברגל."},{"start":395.68,"end":399.68,"text":"ואנו טועים כנער קטון בנתיב לא ידע או עית."},{"start":399.68,"end":404.83,"text":"כאן ג'ודי לא צהרון ובבישג השונמית, סוכניק בורה הנביאה."},{"start":404.83,"end":409.24,"text":"כאן אדם וחווה אלברשטיין, כאן עדן."},{"start":409.24,"end":415.17,"text":"ערב טוב, שוב אתם בתוכנית שלי שיחה קולחת."},{"start":415.17,"end":419.17,"text":"והפעם נמצאתי באולפן, הכוסם והפעלולן משה הודיני."},{"start":419.17,"end":426.49,"text":"ערב טוב משה, לפני כשנה במהלך קטע של בליית חרבות משה חתכת לשנו."},{"start":426.49,"end":428.03,"text":"זה כאב משה."},{"start":428.03,"end":432.72,"text":"חשבת באותו רגע שהסתיימו חייך המקצועיים?"},{"start":432.72,"end":436.35,"text":"משה זה סיפור עצוב באמת."},{"start":436.35,"end":442.38,"text":"אך אם אתם חושבים שכאן הסתיימו הצהרות, אתם טועים."},{"start":442.38,"end":445.73,"text":"בעקבות אותה פרשייה, אשתך עזבה אותך."},{"start":445.73,"end":450.91,"text":"גם נגרמה לך פגיעה מוטורית בעמוד השדרה שגורמת לך לחזור על אותה תנועה."},{"start":450.91,"end":454.32,"text":"אתה יכול להדגים לנו בבקשה?"},{"start":454.32,"end":456.25,"text":"הדגים?"},{"start":456.25,"end":465.43,"text":"משה, אתה מתכוון להמשיך לעבוד במקצוע?"},{"start":465.43,"end":467.19,"text":"לא."},{"start":467.19,"end":468.32,"text":"סליחה?"},{"start":468.32,"end":469.48,"text":"לא."},{"start":469.48,"end":470.48,"text":"אתה מדבר?"},{"start":470.48,"end":471.48,"text":"לא, מה פתאום? אני מסוגל רק להגיד את המילה \"לא\"."},{"start":471.48,"end":473.48,"text":"עם יתר המילים יש לי בעיה מאוד רצמית."},{"start":473.48,"end":475.4,"text":"כל כך עצוב."},{"start":475.4,"end":477.42,"text":"תודה רבה משה."},{"start":477.42,"end":483.31,"text":"מיד אחרי הפרסומות תהיה כאן יורה בחץ וקשת ללא ידיים שמנסה לעשות קאמבק."},{"start":483.31,"end":484.34,"text":"יהיו עמנו."},{"start":484.34,"end":499.09,"text":"אמא פולנייה יקרה, נלמד איך לקנות לילד נעליים."},{"start":499.09,"end":501.67,"text":"תפסיק ללעוס, אתה לא פרה."},{"start":501.67,"end":504.67,"text":"גם אבי החבר שלך לא אוס, ככה מסתיקים, נכון?"},{"start":504.67,"end":506.67,"text":"אני אמרתי לך לא להסתובב איתו, הוא פושטק."},{"start":506.67,"end":510.67,"text":"אתה יודע שהוא נוהג בלי רישיון, הוא פושטק, הוא פרח."},{"start":510.67,"end":511.67,"text":"שלום גבירתי."},{"start":511.67,"end":512.67,"text":"אווו, שלום לך."},{"start":512.67,"end":513.67,"text":"אפשר לעזור לך?"},{"start":513.67,"end":514.67,"text":"באיזה טוב שבוא אתה?"},{"start":514.67,"end":520.67,"text":"חמש דקות אני מחכה פה חצוף, חמש דקות ולא נראה לי שיש פה מי יודע מה הנשים."},{"start":520.67,"end":522.67,"text":"אוקיי, בייתי, אוקיי, אני מתמצל."},{"start":522.67,"end":523.64,"text":"אפשר לעזור לך במשהו?"},{"start":523.64,"end":527.64,"text":"בהחלט, אני צריכה נעל ליוגבי שלי, הוא נורא רוצה נעל,"},{"start":527.64,"end":529.64,"text":"והחלטתי לפונק אותו, מגיע לו."},{"start":529.64,"end":530.64,"text":"איזה נעל?"},{"start":530.64,"end":533.64,"text":"הוא קיבל 90 במולדת, בכל תספר לו."},{"start":533.64,"end":537.64,"text":"אני רוצה לקנות לו נעל, קודם כל שתהיה נעל חזקה."},{"start":537.64,"end":539.67,"text":"זה הכי חשוב, נעל חזקה."},{"start":539.67,"end":543.67,"text":"אני רוצה נעל שחורה גם כי אתה יודע יש לו כל מיני ברדים,"},{"start":543.67,"end":546.67,"text":"זה מתאים לכל וגד, ואתה יודע, אני לא צריכה לספר לך."},{"start":546.67,"end":548.67,"text":"ואני צריכה נעל מידה חמישים."},{"start":548.67,"end":550.67,"text":"אבל אמא, אני מידה ארבעים ושתיים."},{"start":550.67,"end":552.67,"text":"אתה מידה ארבעים ושתיים, אתה לא תגדל?"},{"start":552.67,"end":554.67,"text":"אתה לא תקחת, אתה תישאר כל החיים?"},{"start":554.67,"end":556.67,"text":"אבל אמא, אני רוצה נעלי ספורט."},{"start":556.67,"end":560.67,"text":"ואין לך נעלי ספורט, אתה רוצה!"},{"start":560.67,"end":562.67,"text":"לא קניתי לך אדידס."},{"start":562.67,"end":564.67,"text":"לא, לא, קניתי אדידוס."},{"start":564.67,"end":568.67,"text":"זה חיקוי, זה חיקוי, זה מדפיקים את זה ומחברים."},{"start":568.67,"end":572.67,"text":"אתה ביקש לך אולסר, קניתי לך סטופסר."},{"start":572.67,"end":574.67,"text":"אתה ביקש לך נאי, קניתי לך מי."},{"start":574.67,"end":575.67,"text":"אני רציתי דקטור מרטין."},{"start":575.67,"end":576.67,"text":"מה הבן נאי אבגבר?"},{"start":576.67,"end":577.67,"text":"מה הבסנדאי אבגבר?"},{"start":577.67,"end":579.67,"text":"כולם רוצים, דקטור מרטין?"},{"start":579.67,"end":581.67,"text":"כולם קופסים לגג, אז גם אתה תקפוץ."},{"start":581.67,"end":583.67,"text":"אז מה אם אני תקפוץ מהם?"},{"start":583.67,"end":585.76,"text":"שלום, בירתי, שלום."},{"start":585.76,"end":590.75,"text":"הבאתי לך, טנאי, בדיוק שאת רוצה שחורה, חזקה, בדיוק מתאימה לבן שלך."},{"start":590.75,"end":591.75,"text":"בבקשה."},{"start":591.75,"end":598.41,"text":"וואו, גם אני..."},{"start":598.41,"end":600.41,"text":"זה נורא יפה, נכון?"},{"start":600.41,"end":601.41,"text":"אין לי דרך."},{"start":601.41,"end":603.41,"text":"תשמע, זה ממש מדהים."},{"start":603.41,"end":605.41,"text":"תראה מה שעושים היום אנשים."},{"start":605.41,"end":607.41,"text":"דרך תולדים אגפיים."},{"start":607.41,"end":609.73,"text":"זה יופי."},{"start":609.73,"end":611.73,"text":"תגיד כמה זה התעלוג, נורא."},{"start":611.73,"end":613.73,"text":"630 שקלים לא כולל מאם."},{"start":613.73,"end":615.71,"text":"אבל בוא רגע."},{"start":615.71,"end":618.76,"text":"בכל זאת אתה יודע, בעלי הוא איש קבע."},{"start":618.76,"end":621.17,"text":"אם אפשר לעשות..."},{"start":621.17,"end":622.17,"text":"לא, נכון?"},{"start":622.17,"end":623.17,"text":"לא, לא, לא, אין הנחות."},{"start":623.17,"end":625.17,"text":"כי המחירים קבועים פה, גבירתי, אני מצטעיר."},{"start":625.17,"end":627.17,"text":"זאת חנות מכובדת."},{"start":627.17,"end":628.17,"text":"גבירתי, זה לא שוק."},{"start":628.17,"end":629.17,"text":"זה לא שוק באמת."},{"start":629.17,"end":631.17,"text":"וחבל מאוד בשבילך שזה לא שוק."},{"start":631.17,"end":632.17,"text":"חצוף כזה."},{"start":632.17,"end":634.17,"text":"אתם באמת צריכים לחזור לשוק."},{"start":634.17,"end":636.17,"text":"אתם משתלטים על הבדינה!"},{"start":636.17,"end":637.17,"text":"אתם משתלטים על הבדינה!"},{"start":637.17,"end":638.17,"text":"אתם משתלטים על הבדינה!"},{"start":638.17,"end":639.17,"text":"אמא, בואי!"},{"start":639.17,"end":640.17,"text":"אמא, בואי!"},{"start":640.17,"end":644.14,"text":"לא רק שזה עליי!"},{"start":644.14,"end":645.09,"text":"שמעון."},{"start":645.09,"end":653.08,"text":"מה?"},{"start":653.08,"end":655.84,"text":"עברה לי מחשבה, שמעון."},{"start":655.84,"end":657.32,"text":"איזה?"},{"start":657.32,"end":659.77,"text":"שמעת המחשבה זה החוש שלינג של מחשבה."},{"start":659.77,"end":660.83,"text":"נו."},{"start":660.83,"end":663.69,"text":"מה חשבנו אדם זה אהבה, נכון?"},{"start":663.69,"end":665.69,"text":"חשבנו אהבה זה אופר לוי."},{"start":665.69,"end":666.69,"text":"זה אופר לוי."},{"start":666.69,"end":667.69,"text":"זה רומנטיקה בחוף של הים."},{"start":667.69,"end":668.69,"text":"זה רומנטיקה בים."},{"start":668.69,"end":669.69,"text":"לא."},{"start":669.69,"end":671.01,"text":"מה זה?"},{"start":671.01,"end":672.48,"text":"אהבה זה יוגורט."},{"start":672.48,"end":676.93,"text":"מה קרה לי אמא שלך?"},{"start":676.93,"end":678.08,"text":"אל תערב את אמא שלי."},{"start":678.08,"end":679.47,"text":"האהבה זה יוגורט."},{"start":679.47,"end":681.59,"text":"אם תשמע טוב תראה יש לי דיבור."},{"start":681.59,"end":682.65,"text":"למה תראה?"},{"start":682.65,"end":684.25,"text":"זוכר שאתה צעיר,"},{"start":684.25,"end":685.25,"text":"בעים אומרים לך זה יוגורט?"},{"start":685.25,"end":686.4,"text":"כן."},{"start":686.4,"end":687.53,"text":"אתה אומר אחלה?"},{"start":687.53,"end":688.53,"text":"זוכר."},{"start":688.53,"end":689.53,"text":"טועם?"},{"start":689.53,"end":690.46,"text":"כן, טעמתי."},{"start":690.46,"end":691.5,"text":"טעים?"},{"start":691.5,"end":692.5,"text":"טעים."},{"start":692.5,"end":693.5,"text":"טעים."},{"start":693.5,"end":694.5,"text":"טעים?"},{"start":694.5,"end":695.5,"text":"טעים."},{"start":695.5,"end":696.5,"text":"יפה, סבבה?"},{"start":696.5,"end":697.5,"text":"כן."},{"start":697.5,"end":699.5,"text":"כך אחרי שבוע אתה הולך קונה את היוגורט לבד בסופר."},{"start":699.5,"end":700.65,"text":"בסדר."},{"start":700.65,"end":701.65,"text":"למה אתה זוכר שהוא טעים, נכון?"},{"start":701.65,"end":702.65,"text":"טעים."},{"start":706.65,"end":708.65,"text":"אתה זוכר את הטעם שלו מההתחלה, נכון?"},{"start":708.65,"end":709.65,"text":"שזה טעים."},{"start":709.65,"end":710.65,"text":"טעים, ואז עוברת שנה, נכון?"},{"start":710.65,"end":711.65,"text":"כן."},{"start":711.65,"end":713.72,"text":"ואתה כבר אוכל את היוגורט מההרגל."},{"start":713.72,"end":716.77,"text":"מההרגל אתה אוכל אותו, אבל אתה זוכר ביום הראשון איזה טעים היה, נכון?"},{"start":716.77,"end":717.73,"text":"כן."},{"start":717.73,"end":722.73,"text":"ואז פתאום ככה עוברים להם השנים, ואתה כבר לא מי יודע מה טעים לך היוגורט, אבל מה?"},{"start":722.73,"end":727.73,"text":"אם אמא שלך אומרת, בלך יפה היוגורט, היוגורט מסתדר, אז אתה נכנס לסיבוכי מלייסטור, נכון?"},{"start":727.73,"end":728.69,"text":"כן."},{"start":728.69,"end":730.71,"text":"אחרי שלוש שנים מה אתה רואה?"},{"start":730.71,"end":731.71,"text":"מה?"},{"start":731.71,"end":733.83,"text":"אתה רואה את התאריך של היוגורט בתחתית של הגביה?"},{"start":733.83,"end":734.83,"text":"כן."},{"start":734.83,"end":740.48,"text":"פג טוקה, אתה קולט את זה? מה אתה עושה? לוקח את הגבים, כמת אותו, זורק אותו?"},{"start":740.48,"end":743.84,"text":"לוקח עכמה, אם אתה משתחרר מהיוגורט, נכון או לא?"},{"start":743.84,"end":744.84,"text":"השתחררתי."},{"start":744.84,"end":748.32,"text":"יפה. עכשיו החבר שלך אומר לך, אללה, אללה, תכיר, זה אשל."},{"start":748.32,"end":749.6,"text":"נעים מאוד."},{"start":749.6,"end":750.6,"text":"נעים מאוד, זה אשל?"},{"start":750.6,"end":751.6,"text":"אשל."},{"start":751.6,"end":752.73,"text":"טועם?"},{"start":752.73,"end":753.73,"text":"טועם."},{"start":753.73,"end":754.76,"text":"יום למחרה טועם?"},{"start":754.76,"end":755.76,"text":"טועם."},{"start":755.76,"end":756.76,"text":"קונה לבד אחרי שבוע?"},{"start":756.76,"end":759.76,"text":"ככה שנה, שנתיים, חודש, חודשיים, שלוש שנים עברו?"},{"start":759.76,"end":760.76,"text":"כן."},{"start":760.76,"end":762.88,"text":"ככה אתה נכנס לסופר?"},{"start":762.88,"end":763.91,"text":"נכנס לסופר?"},{"start":763.91,"end":764.91,"text":"פתאום מה אתה רואה בסופר, שמעון?"},{"start":764.91,"end":765.91,"text":"מה?"},{"start":765.91,"end":767.91,"text":"אתה רואה את כל המדפים של היוגורטים."},{"start":767.91,"end":778.07,"text":"אתה יוגורט עם טוט, יוגורט עם אננס, יוגורט עם איש-מיש, יוגורט עם אמזיטים, יוגורט משולב, יוגורט עם אורבב, עם בי או בלי בי או דיאתתי, מבחר."},{"start":778.07,"end":779.61,"text":"כן."},{"start":779.61,"end":781.61,"text":"ואתה תקוע שלוש שנים עם אשל, שמעון."},{"start":781.61,"end":782.99,"text":"איזה בסה זה?"},{"start":782.99,"end":784.64,"text":"מה?"},{"start":784.64,"end":785.78,"text":"מה, לא קלטת הבאסה?"},{"start":785.78,"end":786.84,"text":"לא."},{"start":786.84,"end":787.84,"text":"זה כמו אהבה, בדיוק."},{"start":787.84,"end":790.79,"text":"מה קרה לך?"},{"start":790.79,"end":792.52,"text":"אה, איפה פה מצא מניסטרת?"},{"start":792.52,"end":794.52,"text":"מה זה, אלייאץפן? מה?"},{"start":794.52,"end":795.52,"text":"מה, לא קלטת את הדיבור שלי?"},{"start":795.52,"end":796.55,"text":"לא."},{"start":796.55,"end":798.55,"text":"הנה, יש לי עוד מחשבה, שמעון."},{"start":798.55,"end":801.12,"text":"החיים?"},{"start":801.12,"end":802.33,"text":"כן."},{"start":802.33,"end":805.34,"text":"זה כמו מג'דרה."},{"start":805.34,"end":806.4,"text":"יאללה, ביי."},{"start":806.4,"end":808.7,"text":"אבל למה, שמעון?"},{"start":808.7,"end":811.37,"text":"למה אתה הולך לי באמצע של המחשבה?"},{"start":811.37,"end":817.8,"text":"בייביסט."},{"start":817.8,"end":819.82,"text":"שמרתך."},{"start":819.82,"end":824.22,"text":"לכאורה עבודה קלה ופשוטה."},{"start":824.22,"end":827.7,"text":"דרך נעימה להרוויח דמי כיס."},{"start":827.7,"end":834.86,"text":"ואולי בפעם הבאה שתעשו בייביסט."},{"start":834.86,"end":837.43,"text":"וגלו שעשיתם אותו."},{"start":837.43,"end":840.43,"text":"באזור הדימדומים."},{"start":840.43,"end":846.31,"text":"תשמעי חמודה, אני בטוח שאת תסתדרים."},{"start":846.31,"end":848.31,"text":"אופר אופר הוא ילד מקסים."},{"start":848.31,"end":849.31,"text":"נכון? חמוד."},{"start":849.31,"end":853.27,"text":"שימי לב, מאוד חשוב, מאוד חשוב"},{"start":853.27,"end":855.27,"text":"לשמור על הסדר והניקיון בבית."},{"start":855.27,"end":857.27,"text":"מחר יש לנו עורכים מאוד חשובים מחול."},{"start":857.27,"end":858.21,"text":"זה ברור לך?"},{"start":858.21,"end":859.36,"text":"אני בטוחה שיהיה בסדר."},{"start":859.36,"end":861.36,"text":"רק את צריכה לזכור שבעשר"},{"start":861.36,"end":864.51,"text":"באים כמה מהחברים החמודים של האופר."},{"start":864.51,"end":866.51,"text":"הם לא יעשו שום דבר."},{"start":866.51,"end":868.51,"text":"את רק צריכה לדאוג"},{"start":868.51,"end":870.51,"text":"שמתנהגו יפה ולא יעשו בלגן."},{"start":870.51,"end":872.51,"text":"נכון חמודי?"},{"start":872.51,"end":874.51,"text":"אני כבר מתחילה לסבר, אוקיי?"},{"start":874.51,"end":876.51,"text":"תבלו בנעימים."},{"start":876.51,"end":877.51,"text":"דיר בלק, אה?"},{"start":877.51,"end":879.18,"text":"ביי."},{"start":879.18,"end":880.56,"text":"ביי ביי."},{"start":880.56,"end":883.0,"text":"וופסי."},{"start":883.0,"end":884.73,"text":"חמוד."},{"start":884.73,"end":886.72,"text":"לקים בדלת."},{"start":886.72,"end":887.72,"text":"מיד אני חוזרת."},{"start":887.72,"end":888.68,"text":"לא חמוד?"},{"start":888.68,"end":892.05,"text":"רגע."},{"start":892.05,"end":893.05,"text":"שלום."},{"start":893.05,"end":895.08,"text":"אופר בבית?"},{"start":895.08,"end":898.05,"text":"אופר!"},{"start":898.05,"end":900.18,"text":"אין שלך אופר."},{"start":905.63,"end":911.24,"text":"או! או! או! או! או! או!"},{"start":953.86,"end":965.89,"text":"אהבורי לב! אהבורי לב! אהבורי לב! אהב!"},{"start":1014.33,"end":1017.52,"text":"שלך? של המועדון? של הכבוד של המועדון?"},{"start":1017.52,"end":1020.56,"text":"כך את המכמצאים?"},{"start":1020.56,"end":1021.56,"text":"בבקשה, תהדד!"},{"start":1021.56,"end":1023.62,"text":"רגע, זה מהווה בעיה!"},{"start":1023.62,"end":1025.51,"text":"לא, לא, כנס!"},{"start":1025.51,"end":1026.48,"text":"לא מהווה!"},{"start":1026.48,"end":1029.48,"text":"למה בחונה על המועדון הזה, וואלה, אתם גדונים, אתם!"},{"start":1029.48,"end":1030.48,"text":"תבלד!"},{"start":1030.48,"end":1089.85,"text":"שמפו וקונדישנר לילדים עם שמן רוזמרין לסירוקל ולראש נקי."},{"start":1089.85,"end":1092.94,"text":"שרקל של ד\"ר פישר. זה בדוק."},{"start":1092.94,"end":1096.76,"text":"זה ההורים שלי."},{"start":1096.76,"end":1098.76,"text":"וזה המחשב שלי."},{"start":1098.76,"end":1101.82,"text":"אומנם אבא היסטוריון ואימא עורך הדין."},{"start":1101.82,"end":1104.82,"text":"אבל מול מחשב אני לא כל כך בטוח שהם ידעו מה לעשות."},{"start":1104.82,"end":1108.93,"text":"זה נראה לכם אולי הם נזר."},{"start":1108.93,"end":1113.71,"text":"אבל לא כולם נולדו עם אכבח ביד."},{"start":1113.71,"end":1114.7,"text":"בינינו."},{"start":1114.7,"end":1117.01,"text":"מתשהו זה עלול לקרות גם לכם."},{"start":1117.01,"end":1119.0,"text":"כי לכו תדעו מה יהיה מחר."},{"start":1119.0,"end":1121.19,"text":"לכו תדעו מה עוד ימציאו."},{"start":1121.19,"end":1122.19,"text":"לכו לאורט."},{"start":1122.19,"end":1124.19,"text":"קבלו היום את השכל של מחר."},{"start":1124.19,"end":1129.02,"text":"בזמן המטלחת מתחילה מתקפת חומציות על השיער."},{"start":1129.02,"end":1141.48,"text":"זה דעים."},{"start":1141.48,"end":1144.48,"text":"אני מתקף געגועים לבית הכי חם שאני מכיר."},{"start":1144.48,"end":1146.48,"text":"ככה זה מרק בוחרים?"},{"start":1146.48,"end":1147.48,"text":"משפחה לא."},{"start":1147.48,"end":1148.48,"text":"בית חם."},{"start":1148.48,"end":1149.48,"text":"גיכר שם בחוץ."},{"start":1149.48,"end":1151.21,"text":"אחלה מבצע."},{"start":1151.21,"end":1153.21,"text":"כך סלט אחלה של שטאוס."},{"start":1153.21,"end":1154.21,"text":"כך סלט נוסף."},{"start":1154.21,"end":1156.21,"text":"וקבל תחתית מעודרת במתנה."},{"start":1156.21,"end":1157.21,"text":"תפסת?"},{"start":1157.21,"end":1159.62,"text":"פאור ריינג'ר!"},{"start":1159.62,"end":1161.62,"text":"כך חטיב ועוד אחד."},{"start":1161.62,"end":1163.62,"text":"חטיב בוטנים מכור."},{"start":1163.62,"end":1164.62,"text":"מבצע חדש."},{"start":1164.62,"end":1166.62,"text":"מתנה בכל שקית גדולה של חטיב בוטנים פאור ריינג'ר."},{"start":1166.62,"end":1168.62,"text":"שני פליפים אמריקאים מקוריים"},{"start":1168.62,"end":1172.62,"text":"או מבצ אמריקאים מקורי של הפאור ריינג'ר."},{"start":1172.62,"end":1176.22,"text":"פאור ריינג'ר, חטיב בוטנים עם כוח מיוחד."},{"start":1176.22,"end":1181.98,"text":"קומדיסטור מיד בתום הפרסומות."},{"start":1181.98,"end":1183.98,"text":"השבוע בטוטו, שמונה עשר מיליון שקלים."},{"start":1183.98,"end":1185.98,"text":"מלא כסף."},{"start":1185.98,"end":1188.1,"text":"קצו מול רונן."},{"start":1188.1,"end":1194.99,"text":"קה, הרי כזה שברולט."},{"start":1194.99,"end":1198.99,"text":"היא בדרך לכאן והיא הדבר הטוב ביותר שתפגוש השנה."},{"start":1198.99,"end":1199.99,"text":"זה קורה בקרוב."},{"start":1199.99,"end":1202.99,"text":"שברולט מציגה עתיד חדש בישראל."},{"start":1202.99,"end":1205.72,"text":"תראו איזה מבצע מתוק יש לברד הגליל."},{"start":1205.72,"end":1208.72,"text":"אוספים את כרטיסי שוקולד הנזל מהחפיסות המשתתפות במבצע."},{"start":1208.72,"end":1210.72,"text":"ומחכים להגרלה."},{"start":1210.72,"end":1214.69,"text":"בכל שבוע יוגרל מגוון מוצרי חשמל של אי-גי גרמניה המעולים."},{"start":1214.69,"end":1218.69,"text":"את הפרס הגדול, מכונית הפאר האמריקאית פונג'ק גרן פרי."},{"start":1218.69,"end":1220.69,"text":"ההגרלה ביום ראשון ופספוסים."},{"start":1220.69,"end":1223.74,"text":"איך מעבירים סוף שבוע?"},{"start":1223.74,"end":1225.95,"text":"שקדיה?"},{"start":1225.95,"end":1227.58,"text":"שקדיה."},{"start":1227.58,"end":1228.62,"text":"פיצוחים ומתוקים."},{"start":1228.62,"end":1229.58,"text":"חגיגה."},{"start":1229.58,"end":1231.89,"text":"אני הולכת עם הזמן."},{"start":1231.89,"end":1233.89,"text":"אני דורשת יעילות ואיכות."},{"start":1233.89,"end":1237.89,"text":"עכשיו גיליתי את קרם מחדש לחוט פלניטוד עם פעולת לחוט מתמשכת."},{"start":1237.89,"end":1239.89,"text":"פריצת דרך אמיתית ממעבדות לוריאל פריז."},{"start":1239.89,"end":1243.89,"text":"קרם מחדש לחוט מספק מיד מנת לחוט מרוכזת לאור"},{"start":1243.89,"end":1247.89,"text":"ואחר כך ממשיך לשמור על רמת לחוט גבוהה במשך 12 שעות רצופות."},{"start":1247.89,"end":1252.89,"text":"עם פעולת לחוט מתמשכת האור שלי רח יותר, גמיש יותר ונראה צעיר יותר כל הזמן."},{"start":1252.89,"end":1255.89,"text":"קרם מחדש לחוט עובד יותר מקרמים אחרים."},{"start":1255.89,"end":1258.89,"text":"פלניטוד של לוריאל פריז מעכב את השפעות ההזדכנות."},{"start":1258.89,"end":1263.56,"text":"הילד שלך יעשה כל דבר כדי לקבל פוגי. מה?"},{"start":1263.56,"end":1265.56,"text":"25 שנותו לפרט."},{"start":1265.56,"end":1266.56,"text":"מלא? כן."},{"start":1266.56,"end":1269.56,"text":"ייכנס לסונול, לקח לילדים פוגי, חינם."},{"start":1269.56,"end":1272.56,"text":"סונול, ומבצע פצץ, סונול."},{"start":1272.56,"end":1279.17,"text":"אתה טס מחר לחול ואין לך מתח."},{"start":1279.17,"end":1281.17,"text":"תלצל עכשיו לאשור הראשון."},{"start":1281.17,"end":1284.17,"text":"הכסף יגיע בבוקר, אושליח."},{"start":1284.17,"end":1287.32,"text":"תחשבון בישיר הראשון."},{"start":1287.32,"end":1289.6,"text":"אין עוד בן כזה."},{"start":1289.6,"end":1294.32,"text":"שימו לב מבצע."},{"start":1294.32,"end":1296.31,"text":"שלחו אלינו קלטת ביתית."},{"start":1296.31,"end":1298.31,"text":"בנושא ובדמויות הקומן היסטורי."},{"start":1298.31,"end":1300.31,"text":"יש לי זו זו מי שאתם רוצים."},{"start":1300.31,"end":1302.31,"text":"שלחו את זה אלינו לטבע דואר 14463."},{"start":1302.31,"end":1304.31,"text":"אנחנו נבחר את הקלטת הטובה ביותר."},{"start":1304.31,"end":1306.31,"text":"ונשדר אותה כאן בפורים."},{"start":1306.31,"end":1308.31,"text":"רוצים להשתתם בתוכנית?"},{"start":1308.31,"end":1310.31,"text":"זה הזמן. תצטלמו את זה."},{"start":1310.31,"end":1315.38,"text":"הם אוהבים את המסך."},{"start":1315.38,"end":1317.76,"text":"הם רבים בגללו."},{"start":1317.76,"end":1319.76,"text":"אני אוהב את הטלוויזיה."},{"start":1319.76,"end":1321.98,"text":"אתם נכניס שאני חולה עליו."},{"start":1321.98,"end":1323.98,"text":"מה לעשות? אני לא עושה."},{"start":1323.98,"end":1325.98,"text":"הם לא יחמיצו עב תוכנית."},{"start":1325.98,"end":1328.45,"text":"נדמתי לטופז."},{"start":1328.45,"end":1330.45,"text":"ואחר כך הייתי עם מנטונלה."},{"start":1330.45,"end":1332.45,"text":"יום חמישי בתשע ערוץ 2 תלעד."},{"start":1332.45,"end":1334.99,"text":"להתראות."},{"start":1334.99,"end":1358.91,"text":"שוב אנחנו בחלסטה של זוזו."},{"start":1358.91,"end":1360.91,"text":"והפעם רציתי לדבר אתכם"},{"start":1360.91,"end":1362.91,"text":"על השיטפון של הפרסומות של המרקים."},{"start":1362.91,"end":1364.97,"text":"ואיבא שלי לא יום על כיסופן."},{"start":1364.97,"end":1366.97,"text":"כל כך הרבה פרסומות."},{"start":1366.97,"end":1368.97,"text":"מכל פינה קופצה עליך לוקש."},{"start":1368.97,"end":1370.9,"text":"והפרסומות הן מצוקתיות."},{"start":1370.9,"end":1373.03,"text":"הפרסומות מראות לנו את המשפחה."},{"start":1373.03,"end":1374.99,"text":"זו הטקטיקה שלהן."},{"start":1374.99,"end":1377.99,"text":"עוקף את העניין דרך הנוסטלגיות של המשפחה."},{"start":1377.99,"end":1380.99,"text":"והמשפחות ואמא שלי במצוקה קשה."},{"start":1380.99,"end":1383.99,"text":"דבר ראשון הפרסומות הראשונה, רואים את הילד הקטן."},{"start":1383.99,"end":1386.99,"text":"שהתחפש לטנין, לליגטור קטן, ללקוש."},{"start":1386.99,"end":1387.99,"text":"אללה, באמא שלי."},{"start":1387.99,"end":1388.99,"text":"רואים ילד הולך ברחוב."},{"start":1388.99,"end":1390.99,"text":"חשבתי באמא שלי חולצה ניידת."},{"start":1390.99,"end":1391.99,"text":"אללה."},{"start":1391.99,"end":1393.99,"text":"התחפש הילד לאמא שלי לדינוזאור."},{"start":1393.99,"end":1396.99,"text":"והוא מדוקא אלה מהסרט של פארק הג'ורה נגמר."},{"start":1396.99,"end":1398.99,"text":"ושפילבר וארגון עשה כבר, והוא לא פה."},{"start":1398.99,"end":1403.99,"text":"וילד מדחקי בדיכאון, הוא מגיע הביתה בוכה, דמעות נוזלות, נזלת גורפת."},{"start":1403.99,"end":1407.46,"text":"ומה אבא עושה לילד? נותן לו מרק."},{"start":1407.46,"end":1410.46,"text":"ובמקום שעבילו מרק, הוא מבילו מרק מאבקה."},{"start":1410.46,"end":1414.46,"text":"איזה מסכן הילד, באמא שלי? איזה ילד מסכן?"},{"start":1414.46,"end":1418.46,"text":"זה ילד מדוקא, הגדלו לו חד שקונים בגודל של כדור הארץ, הוא יגמגם כל החיים."},{"start":1418.46,"end":1422.46,"text":"הסרות שלו הגדלו מדובללות. באמא שלי, זה ילד מדוקא."},{"start":1422.46,"end":1426.46,"text":"לא מספיק זה, בא אפרסומת השנייה שמראים לנו חושמות."},{"start":1426.46,"end":1430.93,"text":"חושמות, באמא שלי, בא טבח עם באמא שלי כזה פומפה על הראש."},{"start":1430.93,"end":1434.93,"text":"והוא חותך עגבניות ופלפלים ולפלפונים וכישועים וגזרים."},{"start":1434.93,"end":1437.93,"text":"כל גזר באמא שלי נראה כמו היפופוטם נייד."},{"start":1437.93,"end":1440.93,"text":"ופתאום כל זה נכנס בתוך אבקה קטנה."},{"start":1440.93,"end":1444.93,"text":"חושמות, אבקה בצגר ביים ג'יפה, מה הם באים להראות לנו?"},{"start":1444.93,"end":1446.93,"text":"מה זה השטויות האלה באמא שלי?"},{"start":1446.93,"end":1451.93,"text":"אבל, האפרסומת המצוקתית מכולם היא האפרסומת של בית חם."},{"start":1451.93,"end":1456.93,"text":"שבא לא מספיק שהביאו משפחה, הביאו אותה משפחה של הקופי רייטר."},{"start":1456.93,"end":1458.93,"text":"זה אחד כזה באמא שלי עם משקפיים שלי גולדים."},{"start":1458.93,"end":1461.93,"text":"עם כזה שיער הוא נראה כמו פודל קטן."},{"start":1461.93,"end":1464.93,"text":"כמו הודי אלן, רק באמא שלי לאפלפון יותר."},{"start":1464.93,"end":1466.93,"text":"והוא יושב."},{"start":1466.93,"end":1469.02,"text":"והוא מספר על המשפחה לאפלפית שלו."},{"start":1469.02,"end":1470.02,"text":"זה כזאת משפחה."},{"start":1470.02,"end":1473.02,"text":"כולם נראה לי כזה עובדי הסתדרות, עם טיונים במרק."},{"start":1473.02,"end":1477.02,"text":"מדוקאים באמא שלי דופקים כרטיס אחרי שהם גורם לאכול את המרק."},{"start":1477.02,"end":1478.02,"text":"משפחה מדוקד כזאת."},{"start":1478.02,"end":1480.02,"text":"יש שם את הדודה הכי מפחידה."},{"start":1480.02,"end":1482.02,"text":"אני רוצה לשנות את העולם."},{"start":1482.02,"end":1484.02,"text":"באמא שלי עכשיו נראה את העולם משתנה בלי שתרצה."},{"start":1484.02,"end":1486.02,"text":"פשוט מצוקה."},{"start":1486.02,"end":1488.02,"text":"הבעיה היא ביטחונית, רבותיי."},{"start":1488.02,"end":1492.02,"text":"איך אנחנו מייצגים בעיני העולם את המשפחה הישראלית?"},{"start":1492.02,"end":1495.02,"text":"המשפחה הישראלית נראית ככה מה יחשבו אויבינו?"},{"start":1495.02,"end":1497.02,"text":"מה יחשבו אויבי העם היהודי?"},{"start":1497.02,"end":1499.05,"text":"אם ככה נראים ישראלים?"},{"start":1499.05,"end":1501.46,"text":"זו מצוקה ביטחונית."},{"start":1501.46,"end":1505.79,"text":"לכן, הצורך הביטחוני ענייה את צו\"זו ונבל\"ש"},{"start":1505.79,"end":1507.03,"text":"לצאת אל השטח."},{"start":1507.03,"end":1513.49,"text":"שימו לב, בית חם והם לא מובן המילה, שופופו."},{"start":1513.49,"end":1524.91,"text":"לכל חורף אני נתקף געגועים לבית הכי חם שאני מכיר."},{"start":1524.91,"end":1529.54,"text":"לאבא שלי שחושב שהוא יוריני הכוסם."},{"start":1529.54,"end":1537.54,"text":"כל הירח משהו לא הצליח לצאת מהפריגידה."},{"start":1537.54,"end":1539.54,"text":"לאח שלי שרוצה להיות דוגמן."},{"start":1539.54,"end":1543.11,"text":"תני להיות קצת מהגלידה אבל רק טיפ טיפה."},{"start":1543.11,"end":1547.13,"text":"לאחותי שכל כך רוצה כבר להתחתן."},{"start":1547.13,"end":1550.13,"text":"תכיו זה חזי החבר החדש שלי."},{"start":1550.13,"end":1551.42,"text":"חזי! חזי!"},{"start":1551.42,"end":1553.68,"text":"לדודה שלי שאח שלי פנט אותה."},{"start":1553.68,"end":1557.68,"text":"ומאז היא חושבת שהיא נסיכת הנילוס של ברום מזרח האנטרטיקה המשבנית."},{"start":1557.68,"end":1561.03,"text":"אני רוצה להביא כל רוח לעולם."},{"start":1561.03,"end":1566.62,"text":"ולאמא שלי שטבידה הייתה אומרת."},{"start":1566.62,"end":1568.09,"text":"ככה זה בחיים."},{"start":1568.09,"end":1570.31,"text":"איגלו בוחרים משפחה לא."},{"start":1570.31,"end":1571.29,"text":"איגלו."},{"start":1571.29,"end":1573.34,"text":"הבלוק הלבן שעמד במבחן."},{"start":1573.34,"end":1575.34,"text":"איגלו בית חם פי שלושה."},{"start":1575.34,"end":1579.01,"text":"מוסר אסכל המדינה נצלה."},{"start":1579.01,"end":1582.06,"text":"עכשיו סדאם חוסן יכוון את הטילים שלו."},{"start":1582.06,"end":1583.06,"text":"לאנטרטיקנט."},{"start":1583.06,"end":1584.06,"text":"אלא."},{"start":1584.06,"end":1585.06,"text":"לאנטרטיקנט, בלאקסה."},{"start":1585.06,"end":1587.06,"text":"שווה, אלא, אבא שלי."},{"start":1587.06,"end":1588.06,"text":"כל הפינגי פינגווינים."},{"start":1588.06,"end":1590.18,"text":"תיזהרו, מכוון עליכם הזה בבוסטש."},{"start":1590.18,"end":1591.18,"text":"אלא."},{"start":1591.18,"end":1593.18,"text":"ותחשבו על זה."},{"start":1593.18,"end":1601.0,"text":"מיד בתלעד, ילדה שראה את האבם."},{"start":1601.0,"end":1603.0,"text":"ואחד שמומחה לאבמים."}]