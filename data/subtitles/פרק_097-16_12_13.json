[{"start":5.76,"end":10.32,"text":"אני אגב את עתידות בגפילטפיש וקובה של הקומדי סטור"},{"start":10.32,"end":12.77,"text":"ואני רואה מה יהיה בתוכנית"},{"start":12.77,"end":14.58,"text":"אני רואה גפילטפיש"},{"start":14.58,"end":16.3,"text":"גפילטפיש זה פסח"},{"start":16.3,"end":17.78,"text":"פסח זה ניסים"},{"start":17.78,"end":20.11,"text":"ניסים זה ניס עם בוסקילה"},{"start":20.11,"end":22.66,"text":"גפילטפיש אוכלים עם חזרת"},{"start":22.66,"end":24.22,"text":"חזרת זה ורוד"},{"start":24.22,"end":25.82,"text":"ורוד זה רקפת"},{"start":25.82,"end":28.29,"text":"ורקפת זה מה זה בסיסי?"},{"start":28.29,"end":30.38,"text":"אני רואה קובה"},{"start":30.38,"end":32.1,"text":"קובה זה קריח"},{"start":32.1,"end":33.66,"text":"וקריח זה רובי"},{"start":33.66,"end":35.45,"text":"רובי הקריח"},{"start":35.45,"end":38.5,"text":"לגפילטיפיש יש גם ריח"},{"start":38.5,"end":39.34,"text":"ריח?"},{"start":39.34,"end":41.01,"text":"שחקן או ריח?"},{"start":41.01,"end":43.17,"text":"אני רואה שחקן או ריח"},{"start":43.17,"end":45.15,"text":"איתהי סגב"},{"start":45.15,"end":48.4,"text":"אל תזוזו מיד התחיל תוכנית הקומדיסטור"},{"start":48.4,"end":50.44,"text":"לא הקומדיסטור"},{"start":50.44,"end":53.04,"text":"קומדיסטור"},{"start":53.04,"end":58.29,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות"},{"start":58.29,"end":63.98,"text":"קשר בין המציאות לדמיון הינו מקרי בהחלק"},{"start":63.98,"end":68.26,"text":"שמות האנשים והמקומות שונו לצורך העלילה"},{"start":68.26,"end":69.78,"text":"ומאתה הם ניקאים"},{"start":69.78,"end":106.4,"text":"אימא חבקי לי חזק"},{"start":106.4,"end":108.4,"text":"בוא לעולה בליפרים"},{"start":108.4,"end":112.63,"text":"חזרתי אבו סקילה"},{"start":112.63,"end":114.81,"text":"אה? מה זה?"},{"start":114.81,"end":117.07,"text":"אה לא זה לא זה"},{"start":117.07,"end":119.35,"text":"חזרתי אבו סקילה"},{"start":119.35,"end":122.21,"text":"הלואו אבו סקילה"},{"start":122.21,"end":124.21,"text":"שלום נשימו שחומץ של אמא"},{"start":124.21,"end":126.21,"text":"בוא תתן לאמא חבוק בוק בוק בוק"},{"start":126.21,"end":128.21,"text":"בוק בוק בוק בוק"},{"start":128.21,"end":131.84,"text":"יש לי מסקילה חבי לאמא בסקילה"},{"start":131.84,"end":133.84,"text":"מתנה ליום האמא"},{"start":133.84,"end":135.84,"text":"עשרה סביס"},{"start":135.84,"end":137.84,"text":"לא לא עבלה עשרה סביס"},{"start":137.84,"end":139.84,"text":"הרגוסות, הלכות, הכביעות"},{"start":139.84,"end":141.84,"text":"אל תזכר, הנה בבקשה"},{"start":141.84,"end":144.15,"text":"אמא בסקילה"},{"start":144.15,"end":146.11,"text":"אל תדאג נשימו שזה בסדר"},{"start":146.11,"end":148.08,"text":"בונבון זה בסדר"},{"start":148.08,"end":150.08,"text":"זה בסדר זה אמא בסקילה"},{"start":150.08,"end":152.08,"text":"נשים את המתנה היפה שכל המתנות שלך בוסקי"},{"start":152.08,"end":154.1,"text":"בסדר?"},{"start":154.1,"end":156.1,"text":"נשימו שאתה רוצה משהו טעים?"},{"start":156.1,"end":158.1,"text":"בסדר אמא בסקילה בסדר"},{"start":158.1,"end":160.06,"text":"סדר אמא בסקילה"},{"start":160.06,"end":162.93,"text":"בסדר אמא בסקילה"},{"start":162.93,"end":164.93,"text":"בסדר אמא בסקילה"},{"start":164.93,"end":167.12,"text":"בסדר אמא בסקילה"},{"start":167.12,"end":169.44,"text":"בוא נראה מה אפשר לעשות אמא"},{"start":169.44,"end":171.44,"text":"יש לנו כאן אבוקדו"},{"start":171.44,"end":173.43,"text":"יש לנו כאן טירס"},{"start":173.43,"end":175.42,"text":"שומר וסנונית"},{"start":175.42,"end":177.63,"text":"ו..."},{"start":177.63,"end":181.89,"text":"איך היה?"},{"start":181.89,"end":183.89,"text":"לא טוב לקח הרבה זמן"},{"start":183.89,"end":185.89,"text":"גם לא שמה דבוד ודן"},{"start":185.89,"end":188.05,"text":"חבל חבל"},{"start":188.05,"end":190.05,"text":"איפה אמא בסקילה?"},{"start":190.05,"end":192.05,"text":"ניסי צריך ללכת אלוהים עבודה"},{"start":192.05,"end":194.05,"text":"רגע ניסי מושלגע אני אתן לך עוגה"},{"start":194.05,"end":196.33,"text":"עוגה? עוגה"},{"start":196.33,"end":198.55,"text":"מה קרה ניסי? מה זה הסערות האלה ככה מבוגלן?"},{"start":198.55,"end":200.55,"text":"למה זה מבוגלן?"},{"start":200.55,"end":202.58,"text":"מבוגלן?"},{"start":202.58,"end":204.58,"text":"צריך לסדר לך את הסערות"},{"start":204.58,"end":208.37,"text":"אי אי אי אי"},{"start":208.37,"end":211.09,"text":"איך היה?"},{"start":211.09,"end":215.1,"text":"ניסי צריך סבדר שאלו חם"},{"start":215.1,"end":217.09,"text":"סבדר"},{"start":217.09,"end":222.31,"text":"איך היה?"},{"start":222.31,"end":224.25,"text":"אה לא"},{"start":224.25,"end":226.66,"text":"מה זה אמא בסקילה זה גדול"},{"start":226.66,"end":228.66,"text":"אה אני אשם בסקילה יכול לצבוע בזה"},{"start":228.66,"end":230.66,"text":"אל תדאג אל תדאג ניסי מוש"},{"start":230.66,"end":232.66,"text":"העיקר שיחה ולא יתקרר"},{"start":232.66,"end":234.66,"text":"מה מקרר לא לא מקרר כבר"},{"start":234.66,"end":236.58,"text":"אני אשם בסקילה חלוגה הולך להקי"},{"start":236.58,"end":238.66,"text":"עשות סקי?"},{"start":238.66,"end":240.66,"text":"לא עשה סקי עלה בסקילה אף אחד לא שמעקל"},{"start":240.66,"end":242.66,"text":"הולך לעשות סקי צריך לבוש עוד דברים בונבון"},{"start":242.66,"end":244.66,"text":"חכי לגן סי מוש חכי לגן אבית"},{"start":244.66,"end":246.79,"text":"לא לא צריך לבוש עוד דברים שיהיה חם"},{"start":246.79,"end":252.55,"text":"אה אה אה"},{"start":252.55,"end":255.41,"text":"אה אה"},{"start":255.41,"end":257.41,"text":"אמא בוסקילה חבקי לי חזק"},{"start":257.41,"end":259.41,"text":"אין כמו בבית"},{"start":261.41,"end":263.41,"text":"להתראות נשימוש"},{"start":263.41,"end":265.41,"text":"להתראות"},{"start":265.41,"end":267.41,"text":"להתראות ולא לקחת עבודה מאנשים זרים"},{"start":267.41,"end":269.59,"text":"להתראות נשימוש"},{"start":269.59,"end":277.73,"text":"נשמע שאלה שהופיע במבחן הפסיכומטרי"},{"start":277.73,"end":279.73,"text":"שני פארסים"},{"start":279.73,"end":281.73,"text":"נוסעים ברכבת"},{"start":281.73,"end":285.09,"text":"אחד מצד... מה קרה?"},{"start":285.09,"end":287.33,"text":"תראית זה? מה? זה זה זה פה השתיים הזה"},{"start":287.33,"end":289.33,"text":"איזה שתיים? זה השתיים הקטנצ'י כזה פה"},{"start":289.33,"end":291.55,"text":"בפינה בפינה"},{"start":291.55,"end":293.96,"text":"מה זה? ממתי הוא כאן?"},{"start":293.96,"end":295.96,"text":"כל התוכלית ראית אבל הוא עכשיו שיזוז כלום"},{"start":295.96,"end":299.84,"text":"לא זה אז זה קטע"},{"start":299.84,"end":302.72,"text":"נעבוד עליו נעבוד עליו"},{"start":302.72,"end":306.23,"text":"וופה! מה זה?"},{"start":306.23,"end":309.89,"text":"לא זה"},{"start":309.89,"end":311.89,"text":"לא יורד כלום"},{"start":311.89,"end":314.72,"text":"מה נעשה?"},{"start":314.72,"end":316.94,"text":"יש פה חברים יעזרו לנו"},{"start":316.94,"end":318.94,"text":"תסתקן זה עוקב אחרינו"},{"start":318.94,"end":320.94,"text":"עלה על חבר'ס"},{"start":320.94,"end":322.94,"text":"טוב בסדר?"},{"start":322.94,"end":324.91,"text":"מה זה?"},{"start":324.91,"end":326.91,"text":"הם אלה שמעבירים את הפרסומות מהפרצוף הזה"},{"start":326.91,"end":328.91,"text":"לשתיים הגדול"},{"start":328.91,"end":330.91,"text":"בטח! מוכנים?"},{"start":330.91,"end":334.7,"text":"טו-טו טו טו טו טו טו טו טו טו"},{"start":334.7,"end":339.01,"text":"מה זה? עוד פעם אוקיי?"},{"start":339.01,"end":341.03,"text":"טו-טו טו טו טו טו טו טו טו"},{"start":341.03,"end":346.69,"text":"מה? חיים!"},{"start":346.69,"end":350.14,"text":"שימי את הקסטה של ההדרכה שיבינו איך לעשות את זה נכון"},{"start":350.14,"end":361.62,"text":"לא שיש לי אשליות בקשר ללונדון"},{"start":361.62,"end":363.93,"text":"לונדון לא ממתינה לי"},{"start":363.93,"end":366.2,"text":"גם שם יהיה בודדה"},{"start":366.2,"end":367.13,"text":"קלני!"},{"start":367.13,"end":369.67,"text":"מה כיפה!"},{"start":369.67,"end":375.29,"text":"אל תשאלי איזה חבילת יור הייתה לי עכשיו"},{"start":375.29,"end":377.29,"text":"איזה עשירה נשיחה דיינה"},{"start":377.29,"end":378.29,"text":"לא מכירה"},{"start":378.29,"end":380.45,"text":"איזה הרמון יש לי בקינגם פלס"},{"start":380.45,"end":381.48,"text":"לא מכירה"},{"start":381.48,"end":383.54,"text":"איזה שעון מדויק יש לי בינג בנג"},{"start":383.54,"end":384.85,"text":"לא מכירה"},{"start":384.85,"end":385.85,"text":"אז איך אני אדבר איתך על חוויות?"},{"start":385.85,"end":387.85,"text":"חזרתי עכשיו משבוע בחול"},{"start":387.85,"end":389.85,"text":"אז מה, ואני חזרתי עכשיו משבוע בארץ?"},{"start":389.85,"end":391.85,"text":"בטח בארץ, כי אין לך פספורט"},{"start":391.85,"end":392.85,"text":"אז מה, וגם את לא עושה ספורט?"},{"start":392.85,"end":393.85,"text":"אז מה?"},{"start":393.85,"end":396.35,"text":"אז מה?"},{"start":396.35,"end":398.6,"text":"תגידי, איפה זה בדיוק חול?"},{"start":398.6,"end":400.07,"text":"הכול זה בכל מיני מקומות"},{"start":400.07,"end":402.07,"text":"זה דושנוני, זה אי אפשר להמחיש"},{"start":402.07,"end":403.07,"text":"זה רשת תיבות"},{"start":403.07,"end":405.05,"text":"אז איפה את היית בעצם?"},{"start":405.05,"end":411.71,"text":"הייתי בכל מיני מקומות הייתי באנגליה, בלונדון, בבריטניה"},{"start":411.71,"end":412.83,"text":"גיוונתי"},{"start":412.83,"end":415.43,"text":"וואו, איזה כיף לך?"},{"start":415.43,"end":416.85,"text":"קלנית"},{"start":416.85,"end":417.85,"text":"מה רק כיףת?"},{"start":417.85,"end":419.85,"text":"תסתכלי מה הבאתי לך מלונדון"},{"start":419.85,"end":422.07,"text":"וואו, תודה"},{"start":422.07,"end":424.13,"text":"אלק תודה, את לא יודעת מה זה?"},{"start":424.13,"end":426.19,"text":"אלק אני לא יודעת מה זה"},{"start":426.19,"end":427.19,"text":"נו?"},{"start":427.19,"end":428.92,"text":"נו מה זה?"},{"start":428.92,"end":430.91,"text":"את איזו מפגרת, זה מה זה בסיסי?"},{"start":430.91,"end":433.39,"text":"זה מגדל אייפל טאוור"},{"start":433.39,"end":435.41,"text":"וואו"},{"start":435.41,"end":436.41,"text":"את יודעת מה בעיה איתך קלנית?"},{"start":436.41,"end":439.7,"text":"שאת לא יודעת להעריך מתנות מהתפוצות?"},{"start":439.7,"end":442.76,"text":"אתן לך ידיעה בכלל חורשת בנושא עולם וחוקו"},{"start":442.76,"end":446.14,"text":"את אפילו לא יודעת מה זה 1-2-3-4"},{"start":446.14,"end":449.14,"text":"אלא כאני לא יודעת מה זה 1-2-3-4"},{"start":449.14,"end":450.14,"text":"נו"},{"start":450.14,"end":451.14,"text":"אלא כאני לא יודעת מה זה"},{"start":451.14,"end":452.77,"text":"נו"},{"start":452.77,"end":454.95,"text":"נו מה זה?"},{"start":454.95,"end":456.95,"text":"את איזה מפגרת זה מה זה בסיסי?"},{"start":456.95,"end":459.42,"text":"1-2-3-4"},{"start":459.42,"end":461.42,"text":"זה נגיד את עולה במעלית בבריטניה"},{"start":461.42,"end":462.87,"text":"נו"},{"start":462.87,"end":465.87,"text":"ואת עושה תחרות עם עוד כמה אנשים היא מגיע ראשון לקומה 1-2-3"},{"start":465.87,"end":466.81,"text":"נו"},{"start":466.81,"end":469.32,"text":"והאנגלים מנומסים אז הם נותנים לך 4"},{"start":469.32,"end":469.42,"text":"נו"},{"start":469.32,"end":471.76,"text":"אז זה זה"},{"start":471.76,"end":473.21,"text":"וואו"},{"start":473.21,"end":474.46,"text":"וואו"},{"start":474.46,"end":475.46,"text":"מאיפה הולך על בריטניה?"},{"start":475.46,"end":476.42,"text":"מבריטניקה לנוער"},{"start":476.42,"end":477.6,"text":"וואו"},{"start":477.6,"end":479.14,"text":"רכפת"},{"start":479.14,"end":480.94,"text":"על מה את חושבת?"},{"start":480.94,"end":483.16,"text":"על שדה התעופה"},{"start":483.16,"end":484.7,"text":"על מה את?"},{"start":484.7,"end":486.69,"text":"על שדה בוקר"},{"start":486.69,"end":489.16,"text":"וואי"},{"start":489.16,"end":490.63,"text":"איזה טרמינל?"},{"start":490.63,"end":492.88,"text":"לא טרמינל פגרת"},{"start":492.88,"end":495.17,"text":"טלפתיה"},{"start":495.17,"end":496.61,"text":"וואו"},{"start":496.61,"end":500.51,"text":"אה יוחד שוחח איתך על ציוויון חובק עולם"},{"start":500.51,"end":501.51,"text":"יש לי ג'טלק"},{"start":501.51,"end":504.66,"text":"יש לי השעות טיסה בהפרשים מבריטניה"},{"start":504.66,"end":508.99,"text":"גם שם נהיה בודדה"},{"start":508.99,"end":543.19,"text":"מרח ברח מים"},{"start":543.19,"end":554.64,"text":"מרח מים"},{"start":554.64,"end":568.92,"text":"מרח מים"},{"start":568.92,"end":578.92,"text":"מרח מים"},{"start":578.92,"end":589.87,"text":"מרח מים"},{"start":589.87,"end":600.38,"text":"מרח מים"},{"start":600.38,"end":611.43,"text":"מרח מים"},{"start":611.43,"end":613.43,"text":"מרח מים"},{"start":613.43,"end":615.43,"text":"מרח מים"},{"start":615.43,"end":617.43,"text":"מרח מים"},{"start":617.43,"end":619.42,"text":"מרח מים"},{"start":619.42,"end":621.83,"text":"תרגום"},{"start":653.3,"end":655.65,"text":"תרגום"},{"start":695.85,"end":723.19,"text":"תגיד לי מה אתה חושב שאתה עושה"},{"start":723.19,"end":725.7,"text":"מה אני עושה?"},{"start":725.7,"end":727.7,"text":"אתה נוגע כאן עם הידיים?"},{"start":727.7,"end":729.7,"text":"כולם עוד ירצו לקנות כאן, לא?"},{"start":729.7,"end":731.7,"text":"מה אתה רוצה ממני זכותי? אני בודק"},{"start":731.7,"end":733.7,"text":"טוב לי קולה, לא טוב לא קולה"},{"start":733.7,"end":735.7,"text":"אפשר לשום התרוששור מזה"},{"start":735.7,"end":737.95,"text":"אלא, לך מפה, לך, לך, לך"},{"start":737.95,"end":739.9,"text":"יש לך קניות, לך"},{"start":739.9,"end":764.06,"text":"דוני, אתה חוצפן ממדרגה הראשונה"},{"start":764.06,"end":766.19,"text":"מה קרה? מה עשיתי? מה חוצפן?"},{"start":766.19,"end":768.19,"text":"אנשים עוד ירצו לקנות את זה"},{"start":768.19,"end":770.19,"text":"אדוני זכותי לבדוק"},{"start":770.19,"end":772.19,"text":"טוב לי קונה, לא טוב לי לא קונה"},{"start":772.19,"end":774.19,"text":"אפשר לחשוב שיתרושה שום מזה"},{"start":774.19,"end":776.19,"text":"יאללה אין לך קניות, לך, לך, לך"},{"start":776.19,"end":778.44,"text":"לך תגמור את הקניות שלך, לך"},{"start":778.44,"end":780.44,"text":"איזה חצוב, דוחף את האב שלו"},{"start":780.44,"end":785.15,"text":"מה קורה? איך החיים? מה, מה קורה?"},{"start":785.15,"end":788.15,"text":"בסדר, נחמד, אני רוצה מישהי"},{"start":788.15,"end":790.11,"text":"אני חייב מישהי, אחי..."},{"start":790.11,"end":792.11,"text":"נו אז בוא אליי, אני אכיר לך מישהי"},{"start":792.11,"end":793.11,"text":"אין מה, אני לא נעימי"},{"start":793.11,"end":795.11,"text":"יש לי מישהי להכיר לך"},{"start":795.11,"end":796.11,"text":"מי?"},{"start":796.11,"end":798.11,"text":"נחמדה מותק, תאמין לי"},{"start":798.11,"end":798.21,"text":"באמת?"},{"start":798.11,"end":799.04,"text":"כן, כן"},{"start":799.04,"end":801.07,"text":"אבל מה, אם היא לא נראית לי או משהו כזה"},{"start":801.07,"end":803.07,"text":"אני אכיר לך אותה טיפה כשהוא לא מוצא אתכן ביניך"},{"start":803.07,"end":805.07,"text":"תן לי איזה סימן אני מחפף אותה"},{"start":805.07,"end":806.07,"text":"מקסימום כן, אני אצל לך איזה פרצוף"},{"start":806.07,"end":807.07,"text":"ולא תראה אותה יותר"},{"start":807.07,"end":808.07,"text":"אני פשוט לוקח אותה הלאה, אוקיי?"},{"start":808.07,"end":809.07,"text":"אתה תקלוט"},{"start":809.07,"end":810.06,"text":"יאללה, בוא"},{"start":810.06,"end":811.06,"text":"תודה אחי, חבר שלי"},{"start":811.06,"end":813.06,"text":"בוא בוא בוא, בוא תראה אותה"},{"start":813.06,"end":817.28,"text":"בוא בוא"},{"start":817.28,"end":818.28,"text":"שלום, אלן שושנה"},{"start":818.28,"end":819.44,"text":"היי"},{"start":819.44,"end":820.38,"text":"תכירי, בני"},{"start":820.38,"end":821.5,"text":"בני שושנה"},{"start":821.5,"end":822.6,"text":"היי"},{"start":822.6,"end":824.6,"text":"אני מטוח שאתה עשו חיים יחד"},{"start":824.6,"end":825.6,"text":"נעים לי מאוד"},{"start":825.6,"end":826.92,"text":"שמעתי עליך הרבה"},{"start":826.92,"end":831.25,"text":"מה אתה עושה היום בערב?"},{"start":831.25,"end":832.51,"text":"אה, לא יודע"},{"start":832.51,"end":833.89,"text":"רוצה לבוא לסרט?"},{"start":833.89,"end":835.84,"text":"יש איזה סרט טוב ששמעתי עליו"},{"start":835.84,"end":837.33,"text":"אוקיי, אוקיי"},{"start":837.33,"end":838.3,"text":"אני רואה"},{"start":838.3,"end":839.3,"text":"אין לי שום כוונה לעמוד פה"},{"start":839.3,"end":840.3,"text":"להחזיק לכם את הנר"},{"start":840.3,"end":842.33,"text":"אני רואה שאתם מסתברים יפה"},{"start":842.33,"end":843.33,"text":"ביי ביי, תעשה חיים"},{"start":843.33,"end":844.33,"text":"תליפור"},{"start":844.33,"end":845.33,"text":"תודה"},{"start":845.33,"end":850.85,"text":"אולי כדאי שקודם נתנשק"},{"start":850.85,"end":852.85,"text":"זה ישבור את הקרח בינינו"},{"start":852.85,"end":853.85,"text":"לא חושב"},{"start":853.85,"end":886.88,"text":"תגיד לי מה הקרח משעמם לך"},{"start":886.88,"end":889.23,"text":"מה אתה ללך לכניות שלך נו"},{"start":889.23,"end":891.29,"text":"זכותי אני בודק"},{"start":891.29,"end":893.29,"text":"רוצה אקנה לא ארצה לא אקנה"},{"start":893.29,"end":895.29,"text":"יאללה ללך לכניות שלך כבר"},{"start":895.29,"end":897.29,"text":"ללך מה אתה עוקב אחריי"},{"start":897.29,"end":899.11,"text":"תגיד לי"},{"start":899.11,"end":901.43,"text":"אתה יודע איפה פה השמפוים פה"},{"start":901.43,"end":902.43,"text":"אה?"},{"start":902.43,"end":904.52,"text":"מה אתה עצבני אני לא אומר מה אתה לחוץ"},{"start":904.52,"end":906.52,"text":"מה אני לחוץ נכון אתה אידיוט"},{"start":906.52,"end":907.52,"text":"מה עשיתי לך?"},{"start":907.52,"end":909.52,"text":"מה עשית זהו שלא עשית"},{"start":909.52,"end":911.52,"text":"השארת אותי איתי עם הגועל הזה"},{"start":911.52,"end":912.52,"text":"אבל אמר אתה שצמנו לי"},{"start":912.52,"end":913.52,"text":"לא אבל לא סימנתי"},{"start":913.52,"end":914.52,"text":"אני לא ראיתי"},{"start":914.52,"end":915.52,"text":"לא זה לא היה מסתיק ברור"},{"start":915.52,"end":916.52,"text":"אלא לא היה מסתיק ברור"},{"start":916.52,"end":917.52,"text":"אני לא ראיתי שום דבר"},{"start":917.52,"end":918.52,"text":"מה אתה רוצה?"},{"start":918.52,"end":919.52,"text":"יו יו שעתיים"},{"start":919.52,"end":921.52,"text":"יו יו איזה גועל"},{"start":921.52,"end":922.52,"text":"בוא בוא בוא"},{"start":922.52,"end":923.52,"text":"אני אכי חמישי חיות"},{"start":923.52,"end":924.52,"text":"לא לא לא לא לא"},{"start":924.52,"end":925.52,"text":"מה קרה לך"},{"start":925.52,"end":926.52,"text":"אני אכי חמישי חיות"},{"start":926.52,"end":927.52,"text":"בומבון סוכריה"},{"start":927.52,"end":928.52,"text":"כן ואם היא לא תמצחן בעיניי"},{"start":928.52,"end":929.52,"text":"אז תן לי רמז ברור"},{"start":929.52,"end":930.52,"text":"אני מחפף אותה"},{"start":930.52,"end":931.52,"text":"בסדר אני אפעם נותן לך באמת רמז ברור"},{"start":931.52,"end":932.52,"text":"ואז אני מחפף אותה"},{"start":932.52,"end":933.52,"text":"אין בעיה בוא"},{"start":933.52,"end":934.52,"text":"חבר על הזמן"},{"start":934.52,"end":934.62,"text":"חבר שלי"},{"start":9