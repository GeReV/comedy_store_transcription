"text":"זה יחדל כשאתה ללכת פה"},{"start":995.62,"end":997.35,"text":"לא עוזר"},{"start":997.35,"end":1003.29,"text":"ארפדים"},{"start":1003.29,"end":1012.12,"text":"יצורים בני אל מוות"},{"start":1012.12,"end":1015.85,"text":"פוחדים רק מאור יום"},{"start":1015.85,"end":1017.2,"text":"שום"},{"start":1017.2,"end":1018.33,"text":"ובעיקר"},{"start":1018.33,"end":1019.78,"text":"מהצלב"},{"start":1019.78,"end":1023.24,"text":"ואולי בפעם הבאה"},{"start":1023.24,"end":1025.33,"text":"שאתה תהיה ארפד"},{"start":1025.33,"end":1027.55,"text":"תגלה שאתה ארפד"},{"start":1027.55,"end":1029.87,"text":"אבל באזור הדנדונים"},{"start":1029.87,"end":1112.97,"text":"יוווותא איש"},{"start":1112.97,"end":1114.06,"text":"יוווי"},{"start":1114.06,"end":1147.31,"text":"די בני די בחי חנו"},{"start":1147.31,"end":1148.31,"text":"בני נו"},{"start":1148.31,"end":1149.31,"text":"לא אתה חולה בראש"},{"start":1149.31,"end":1150.31,"text":"אתה פשוט חולה בראש"},{"start":1150.31,"end":1152.31,"text":"מה קרה לא מצחן בעיניך"},{"start":1152.31,"end":1154.31,"text":"לא לא לפח היא דווקא נהדרת"},{"start":1154.31,"end":1155.31,"text":"היא מקסימה"},{"start":1155.31,"end":1156.31,"text":"עוד באמת בני אל צחקות"},{"start":1156.31,"end":1157.31,"text":"אל צחקות אם לא מצחן בעיניך"},{"start":1157.31,"end":1158.31,"text":"הייתה מסמן לי"},{"start":1158.31,"end":1159.31,"text":"ולא סימנתי לך"},{"start":1159.31,"end":1160.31,"text":"לא סימנתי לך"},{"start":1160.31,"end":1162.31,"text":"תגיד לי לא סימנתי לך"},{"start":1162.31,"end":1163.31,"text":"מה יותר ברור מלהגיד"},{"start":1163.31,"end":1164.31,"text":"היא מחוערת"},{"start":1164.31,"end":1165.31,"text":"היא מגעילה"},{"start":1165.31,"end":1166.31,"text":"זה לא מספיק ברור"},{"start":1166.31,"end":1167.31,"text":"יש לי פריחה"},{"start":1167.31,"end":1168.31,"text":"אתה יודע את זה"},{"start":1168.31,"end":1169.31,"text":"בא לי להגיד"},{"start":1169.31,"end":1170.31,"text":"בני בני בני בני"},{"start":1170.31,"end":1171.31,"text":"בני תהרגע"},{"start":1171.31,"end":1172.31,"text":"בוא נקיחה מישהי"},{"start":1172.31,"end":1173.79,"text":"תרגיע אותך"},{"start":1173.79,"end":1174.79,"text":"יש לי מישהי בשבילך בומבון"},{"start":1174.79,"end":1175.79,"text":"בוא בוא"},{"start":1175.79,"end":1176.79,"text":"הפעם באמת תסמן לי"},{"start":1176.79,"end":1177.79,"text":"לא מוצא אתכם ביניך"},{"start":1177.79,"end":1178.79,"text":"תסמן לי אני מחפף אותך"},{"start":1178.79,"end":1179.79,"text":"יש לך מזל שאני רוצה מישהי"},{"start":1179.79,"end":1180.79,"text":"בוא בוא בוא"},{"start":1180.79,"end":1181.79,"text":"בוא נקיחה"},{"start":1181.79,"end":1182.78,"text":"בוא נקיחה"},{"start":1182.78,"end":1184.94,"text":"אלן זלפא"},{"start":1184.94,"end":1185.9,"text":"היי ימדם"},{"start":1185.9,"end":1186.9,"text":"יודה, מה נשמע?"},{"start":1186.9,"end":1188.9,"text":"תכירי זה בני, בני זו זלפא, תכירו?"},{"start":1188.9,"end":1189.9,"text":"שלום בני"},{"start":1189.9,"end":1190.88,"text":"מאוד מאוד"},{"start":1190.88,"end":1196.64,"text":"תשאל אותה משהו"},{"start":1196.64,"end":1199.95,"text":"מה, מה נשמע?"},{"start":1199.95,"end":1200.95,"text":"מה, מה שלומך?"},{"start":1200.95,"end":1201.95,"text":"בסדר, מה שלומך?"},{"start":1201.95,"end":1203.95,"text":"מאוד נחמד"},{"start":1203.95,"end":1204.95,"text":"יודה"},{"start":1204.95,"end":1206.95,"text":"אוקיי אוקיי אין לי פה שום כוון על להיות צלע שלישית"},{"start":1206.95,"end":1208.95,"text":"אני רואה שאתם מסתדרים טוב, תבלו יפה"},{"start":1208.95,"end":1209.95,"text":"ביי ביי"},{"start":1209.95,"end":1210.95,"text":"סרקו אותה חברה"},{"start":1210.95,"end":1211.95,"text":"יודה"},{"start":1211.95,"end":1212.95,"text":"יודה"},{"start":1212.95,"end":1213.95,"text":"יודה"},{"start":1213.95,"end":1215.95,"text":"היודה הזה לא מבין רמזים פעמיים"},{"start":1215.95,"end":1217.95,"text":"העיקר שמצאתי חברה שלך"},{"start":1217.95,"end":1218.95,"text":"יודה"},{"start":1218.95,"end":1220.95,"text":"את חברה שלי"},{"start":1220.95,"end":1221.95,"text":"יודה"},{"start":1221.95,"end":1223.08,"text":"חברה שלי"},{"start":1223.08,"end":1224.08,"text":"נאבירואן"},{"start":1224.08,"end":1225.08,"text":"יודה"},{"start":1225.08,"end":1230.08,"text":"אדוני"},{"start":1230.08,"end":1234.81,"text":"עוד פעם אתה תגיד החלטת להתלבש על היום"},{"start":1234.81,"end":1235.81,"text":"מה קרה לך?"},{"start":1235.81,"end":1236.81,"text":"יאללה"},{"start":1236.81,"end":1237.81,"text":"זאת אשתי"},{"start":1237.81,"end":1238.8,"text":"זאת אשתי"},{"start":1238.8,"end":1239.8,"text":"זאת אשתי"},{"start":1239.8,"end":1240.8,"text":"אז מה אני בודק"},{"start":1240.8,"end":1241.8,"text":"מתאים לי"},{"start":1241.8,"end":1242.8,"text":"קונה"},{"start":1242.8,"end":1243.8,"text":"לא מתאים לי"},{"start":1243.8,"end":1244.8,"text":"אללה אללה"},{"start":1244.8,"end":1245.8,"text":"לך לקופות"},{"start":1245.8,"end":1245.9,"text":"סוגרים אותם"},{"start":1245.8,"end":1246.8,"text":"אדוני"},{"start":1246.8,"end":1247.8,"text":"אין אדוני"},{"start":1247.8,"end":1255.04,"text":"אוקיי, אוקיי, אוקיי, אוקיי, אוקיי, אוקיי."}]