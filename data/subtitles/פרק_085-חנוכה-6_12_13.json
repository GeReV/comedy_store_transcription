[{"start":40.0,"end":42.0,"text":"חנוכה סוג!"},{"start":70.57,"end":72.57,"text":"אני רוצה להסתכל על ירקה סוג!"},{"start":72.57,"end":74.57,"text":"כן! כן! ירקה סוג!"},{"start":74.57,"end":76.57,"text":"הנוקי יאלי יש!"},{"start":76.57,"end":78.57,"text":"דורקת באה אש!"},{"start":78.57,"end":80.57,"text":"וסחא לי במעת!"},{"start":80.57,"end":82.63,"text":"זה ירקה סוג!"},{"start":82.63,"end":84.63,"text":"עכשיו, מר קול סוג!"},{"start":84.63,"end":86.66,"text":"נראה סוג!"},{"start":86.66,"end":88.66,"text":"כן! אהלים!"},{"start":88.66,"end":90.66,"text":"אהלים, שווי דהלים!"},{"start":90.66,"end":92.66,"text":"אהלים! אהלים! אהלים!"},{"start":92.66,"end":98.54,"text":"תכנית זו מבוססת המקרים שהתרחשו במציאות."},{"start":98.54,"end":104.59,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט."},{"start":104.59,"end":110.37,"text":"כמות האנשים והמקומות שונו לצורך העלילה."},{"start":110.37,"end":112.37,"text":"ומאתה הם נקראים..."},{"start":112.37,"end":148.73,"text":"עקומי!"},{"start":148.73,"end":149.73,"text":"שאול, אבז'ור!"},{"start":149.73,"end":151.78,"text":"ואלא, שאול, תביא שיר."},{"start":151.78,"end":152.87,"text":"עזוב אותך בנהי חנות."},{"start":152.87,"end":154.87,"text":"תביא שיר שאול, אלה."},{"start":154.87,"end":155.87,"text":"יאללה, זרוק נושא."},{"start":155.87,"end":158.87,"text":"תעשה לי שיר על חנוכה, ואללה."},{"start":158.87,"end":161.93,"text":"חנוכה הוא חג חביב, כמה אור פה מסביב,"},{"start":161.93,"end":165.93,"text":"כולם מדליקים נרות, אותי מדליק הגוף של הבחורות."},{"start":165.93,"end":174.89,"text":"אללה, אללה, אללה, אללה, אללה, אללה, אללה, אללה, איך עשית את זה, אללה?"},{"start":174.89,"end":181.98,"text":"לקחת הנושא תמים, עשית ממנו, פושע, אללה, אללה, אללה."},{"start":181.98,"end":183.98,"text":"תעזב אותך ברכה."},{"start":183.98,"end":184.93,"text":"שאול, תעשה עוד שיר."},{"start":184.93,"end":186.2,"text":"זרוק נושא."},{"start":186.2,"end":192.36,"text":"תעשה לי שיר על סביבונים וסופגניות, אתה יכול כזה דבר?"},{"start":192.36,"end":201.36,"text":"רנוכה, הוא חג מלבב, הסביבון סוף סוף מסתובב, יש סופגניות מלא הצלחת, כל סופגניה נראית כמו טעת."},{"start":201.36,"end":220.92,"text":"תעזב אותך ברכה."},{"start":220.92,"end":225.92,"text":"תעזב אותך ברכה."},{"start":225.92,"end":229.92,"text":"אני ככה שוכב על המיטה בחנוכה."},{"start":229.92,"end":234.92,"text":"והשוודיות מאכילות אותי סופגניה, סופגניה, לביבה, לביבה."},{"start":234.92,"end":237.92,"text":"תעשה לי אחד כזה."},{"start":237.92,"end":241.92,"text":"בחנוכה יש הרבה שוודיות חביבות, רכות חמות מתוקות כמו לביבות."},{"start":241.92,"end":247.98,"text":"אבל איזה שוודית אתה מסוגל להדליק עם הנח שלך כל כך דקי."},{"start":247.98,"end":251.78,"text":"שאול זה לא שר טוב."},{"start":251.78,"end":253.78,"text":"למה זה לא פושע?"},{"start":253.78,"end":256.38,"text":"כן אבל זה פשע בלי כבוד."},{"start":256.38,"end":259.95,"text":"בסדר בסדר קבל אחד אחר."},{"start":259.95,"end":263.95,"text":"איזה בחורה אני אדליק עם הנח שלי כל כך דקי."},{"start":263.95,"end":268.32,"text":"איזה יופי."},{"start":268.32,"end":273.32,"text":"תיקנת את עצמך וואלה את הנושא הטעמים בכל זאת עשית אותו."},{"start":273.32,"end":275.32,"text":"פושע."},{"start":275.32,"end":279.57,"text":"באמת יש לך אנר דקי?"},{"start":279.57,"end":283.68,"text":"שלום לכם."},{"start":283.68,"end":285.73,"text":"שוב אתם מפינתנו חיות ארצנו."},{"start":285.73,"end":289.77,"text":"והפעם הזמיננו לאולפן זבובי הנופלס בלתי נראים מעולפים."},{"start":289.77,"end":292.47,"text":"אבו נחזה בהם."},{"start":292.47,"end":293.47,"text":"היכנסו."},{"start":293.47,"end":294.59,"text":"עצה."},{"start":294.59,"end":295.95,"text":"לקפוץ."},{"start":295.95,"end":299.48,"text":"לקפוץ עם סלטה."},{"start":299.48,"end":301.34,"text":"החוצה."},{"start":301.34,"end":306.56,"text":"ועכשיו נכניס לאולפן זבובי הנופלס בלתי נראים שאינם מעולפים."},{"start":306.56,"end":314.5,"text":"נחזה!"},{"start":314.5,"end":316.53,"text":"נשוב על זבובי הנופלס המעולפים."},{"start":316.53,"end":321.59,"text":"ונחזה בהם רוקדים סטפס על משטח שיכננו ממאוד מועד."},{"start":321.59,"end":322.78,"text":"מייד."},{"start":322.78,"end":324.48,"text":"היכנסו."},{"start":324.48,"end":329.7,"text":"ניתן לעקוב אחרי זבובי הנופלס ואחר תמועתם בעזרת החץ שנראה על המסע."},{"start":329.7,"end":334.15,"text":"תודה לכם זבובים החוצה."},{"start":334.15,"end":336.96,"text":"שובו אלינו בהמשך."},{"start":336.96,"end":350.58,"text":"ערב טוב."},{"start":350.58,"end":351.58,"text":"והערב סקופ."},{"start":351.58,"end":355.64,"text":"בנאסא בקייפ קנברל נבחר סוף כל סוף האסטרונאוט הישראלי הראשון."},{"start":355.64,"end":356.74,"text":"איש חזק."},{"start":356.74,"end":357.73,"text":"איש אמיץ."},{"start":357.73,"end":358.73,"text":"גיבור לאומי."},{"start":358.73,"end":360.73,"text":"כתבנו יצא לשטח כדי לראיין אותו."},{"start":360.73,"end":365.73,"text":"תודה לך ז'ק ואנו נמצאים כאן במתקן האימונים הישראלי."},{"start":365.73,"end":371.73,"text":"ואיתי אכן נמצא כאן האסטרונאוט הישראלי הראשון, מייג'ר ניסים בוסקילה."},{"start":371.73,"end":372.82,"text":"שלום לך."},{"start":372.82,"end":374.78,"text":"שלום לך, אנס בוסקילה."},{"start":374.78,"end":376.78,"text":"ניסים, אתה מתרגש להיות אסטרונאוט?"},{"start":376.78,"end":377.78,"text":"אסטרונאוט?"},{"start":377.78,"end":380.13,"text":"אסטרונאוט, אסטרונאוט."},{"start":380.13,"end":383.76,"text":"אלוהים חמודה, אסטרונאוט, אסטרונאוט."},{"start":383.76,"end":391.82,"text":"כן, אנחנו נעבור כרגע לראות את ניסים בוסקילה באחד ממתקני האימון הצנטרפוגלים."},{"start":391.82,"end":401.1,"text":"וכן, כפי שאתם רואים כאן, ניתן לראות את מרבוסקילה מתאמן על מכשיר אלקטרוני מתקדם מאוד שאמור לבחון את שליטתו במהירויות עצומות."},{"start":401.1,"end":421.59,"text":"כעת, נעבור לראות את האסטרונאוטים מתמודדים עם כוח הג'י. ברגע שיורידו את המסכות נוכל לדעת מי שולט במצב."},{"start":421.59,"end":431.33,"text":"נפל, נפל."},{"start":431.33,"end":435.02,"text":"אם כן, הרגע הגדול הגיע. רגע השיגור."},{"start":435.02,"end":439.27,"text":"הנה אנחנו רואים את החללית של ניסים שתיקח אותו אל הירח."},{"start":439.27,"end":443.51,"text":"לניסים שלנו, או, הנה ניסים כבתא החללית."},{"start":486.5,"end":488.63,"text":"ארוחת סהריים"},{"start":517.48,"end":519.48,"text":"ארוחת סהריים"},{"start":519.48,"end":521.48,"text":"ארוחת סהריים"},{"start":521.48,"end":523.48,"text":"ארוחת סהריים"},{"start":523.48,"end":525.48,"text":"ארוחת סהריים"},{"start":525.48,"end":527.48,"text":"ארוחת סהריים"},{"start":527.48,"end":529.42,"text":"ארוחת סהריים"},{"start":529.42,"end":531.44,"text":"ארוחת סהריים"},{"start":531.44,"end":533.41,"text":"ארוחת סהריים"},{"start":533.41,"end":535.56,"text":"אם כן מגיעות אלינו התמונות הראשונות"},{"start":535.56,"end":537.56,"text":"מפני הירח"},{"start":537.56,"end":539.56,"text":"מי סימקה שלנו עמד לרדת מן החללית"},{"start":539.56,"end":541.56,"text":"בואו נעבור אל הירח"},{"start":541.56,"end":543.56,"text":"ארוחת סהריים"},{"start":543.56,"end":546.87,"text":"סהריים סהריים"},{"start":546.87,"end":549.02,"text":"נעבור אל הירח"},{"start":549.02,"end":551.31,"text":"נעבור אל הירח"},{"start":551.31,"end":554.2,"text":"סהריים"},{"start":554.2,"end":556.2,"text":"סהריים"},{"start":556.2,"end":558.32,"text":"סהריים"},{"start":558.32,"end":560.79,"text":"סהריים"},{"start":560.79,"end":560.89,"text":"סהריים"},{"start":560.79,"end":562.69,"text":"סהריים"},{"start":562.69,"end":562.79,"text":"סהריים"},{"start":562.69,"end":566.28,"text":"סהריים"},{"start":566.28,"end":568.28,"text":"סהריים"},{"start":568.28,"end":570.28,"text":"סהריים"},{"start":570.28,"end":572.28,"text":"סהריים"},{"start":572.28,"end":574.53,"text":"סהריים"},{"start":574.53,"end":580.56,"text":"סהריים"},{"start":580.56,"end":582.88,"text":"בפעם הראשונה על הירח"},{"start":582.88,"end":585.62,"text":"אין כן הירח"},{"start":585.62,"end":592.79,"text":"ביידן"},{"start":592.79,"end":595.52,"text":"ביידן"},{"start":595.52,"end":602.09,"text":"קלנית"},{"start":602.09,"end":604.09,"text":"מה רכפת"},{"start":604.09,"end":606.09,"text":"איזה דוחה נערת השנה"},{"start":606.09,"end":608.09,"text":"איך איזה גבוהה"},{"start":608.09,"end":610.09,"text":"איזה אף סולד"},{"start":610.09,"end":612.09,"text":"איזה טל יצרה"},{"start":612.09,"end":614.89,"text":"איזה יפה"},{"start":614.89,"end":616.89,"text":"וואו"},{"start":616.89,"end":618.89,"text":"איזה חתיך"},{"start":618.89,"end":620.89,"text":"וואי איזה שווה"},{"start":620.89,"end":624.04,"text":"איזה אליל"},{"start":624.04,"end":626.04,"text":"אני שמה תנס"},{"start":626.04,"end":628.01,"text":"אז מה אני כבר נרשמת"},{"start":628.01,"end":630.01,"text":"אלק נרשמת לא הבחרו אותך"},{"start":630.01,"end":632.42,"text":"אלק אז מה גם אותך לא"},{"start":632.42,"end":634.42,"text":"אז מה"},{"start":634.42,"end":636.42,"text":"אלק יפה אפילו בתל אביב לא היית"},{"start":636.42,"end":638.42,"text":"אז מה גם את לא"},{"start":638.42,"end":642.17,"text":"אני אסלבריטי"},{"start":642.17,"end":644.32,"text":"אז מה אז גם אני אסלבריטי"},{"start":644.32,"end":646.38,"text":"אלק את לא יודעת מה זה סלבריטי"},{"start":646.38,"end":648.54,"text":"אלק אני לא יודעת מה זה"},{"start":648.54,"end":651.55,"text":"אלק לא יודע"},{"start":651.55,"end":653.58,"text":"איזה מפגרת זה מה זה בסיסי"},{"start":653.58,"end":655.58,"text":"סלבריטי נגיד את הולך ברחוב"},{"start":655.58,"end":657.58,"text":"ופתאום הצלב בריטי"},{"start":657.58,"end":657.68,"text":"נו"},{"start":657.58,"end":659.4,"text":"אז זה זה"},{"start":659.4,"end":661.1,"text":"וואו"},{"start":661.1,"end":661.2,"text":"מאיפה הולך"},{"start":661.1,"end":662.1,"text":"מידע כללי"},{"start":662.1,"end":663.48,"text":"וואו"},{"start":663.48,"end":666.08,"text":"על מה את חושבת"},{"start":666.08,"end":667.26,"text":"על כלום"},{"start":667.26,"end":668.8,"text":"וואו"},{"start":668.8,"end":669.8,"text":"איזה טלפתיה"},{"start":669.8,"end":671.46,"text":"וואו"},{"start":671.46,"end":674.12,"text":"וואו"},{"start":674.12,"end":676.12,"text":"כל ההפקות גאים להציג פרק נוסף"},{"start":676.12,"end":679.12,"text":"בסדרה הקומית הישראלית הגרועה ביותר"},{"start":679.12,"end":681.12,"text":"משפחת ישראלי"},{"start":681.12,"end":717.52,"text":"מברצת קטנה שלי"},{"start":717.52,"end":719.64,"text":"תכיני לי בבקשה נס חנוכה קטן"},{"start":719.64,"end":721.64,"text":"עם שתי כפיות סוגה"},{"start":721.64,"end":723.64,"text":"בבקשה הנה הסופגניות שלך"},{"start":723.64,"end":724.64,"text":"מצטערת לגבי הנס"},{"start":724.64,"end":725.64,"text":"הוא נגמר"},{"start":725.64,"end":727.86,"text":"מה זה אומר יפנגמר?"},{"start":727.86,"end":729.86,"text":"לא קנינו לך קופסה חדשה לפני שבועיים"},{"start":729.86,"end":731.86,"text":"נכון וזה הספיק לשמונה ימים"},{"start":731.86,"end":738.23,"text":"מה נעשה שם עם כל הרעה על זה?"},{"start":738.23,"end":740.26,"text":"זה בסדר רבה זה בסדר גמור"},{"start":740.26,"end":741.26,"text":"זה בדיוק מה שאני צריך"},{"start":741.26,"end":743.26,"text":"תראה אני בונה כאן תותח סוגניות"},{"start":743.26,"end":744.26,"text":"משואב אבק"},{"start":744.26,"end":746.26,"text":"תראה כל מה צריך זה לשים כאן"},{"start":746.26,"end":748.26,"text":"את הסוגניות האלה בסלצילה הזאת"},{"start":748.26,"end":749.26,"text":"ואז לוחצים כאן על הכפתור הזה"},{"start":749.26,"end":750.26,"text":"ויש כמה נגינה כזאת"},{"start":750.26,"end":752.26,"text":"ואז הסוגניות אמורות לעוף מפה"},{"start":752.26,"end":754.26,"text":"אחרוצה כמו הזה כזה בום כזה של תותח"},{"start":754.26,"end":756.26,"text":"תסתכל בבקשה תסתכל"},{"start":756.26,"end":764.43,"text":"עוד פעם לא עובד אני לא מאמין"},{"start":764.43,"end":766.43,"text":"השואב הווה כזה"},{"start":766.43,"end":768.43,"text":"לא לא רק זה מה"},{"start":768.43,"end":770.39,"text":"תבין השואב הווה כזה"},{"start":770.39,"end":772.39,"text":"הפעם היחידה שהוא עבד"},{"start":772.39,"end":774.39,"text":"היה שהוא שאהב לך את המוח"},{"start":774.39,"end":785.96,"text":"פנית קיבלת סטייק"},{"start":785.96,"end":788.05,"text":"בטפה"},{"start":788.05,"end":790.05,"text":"אופרת יצוקה"},{"start":790.05,"end":792.21,"text":"איזה גנב איניו דינקים"},{"start":792.21,"end":794.21,"text":"שימו לב יש לי בדיחה אמיתית תגידו להם זה ימצקיק"},{"start":794.21,"end":797.04,"text":"כן? משפחה אחד"},{"start":797.04,"end":800.29,"text":"לא אין קוף בשמות, לא שילמה לבד הבית"},{"start":800.29,"end":802.29,"text":"אולי המון המון זמן"},{"start":802.29,"end":804.67,"text":"עכשיו בעד הבית"},{"start":804.67,"end":806.68,"text":"החליט כעונש"},{"start":806.68,"end":809.36,"text":"להטיל על המשפחה"},{"start":809.36,"end":812.39,"text":"המחזת מחזה של כנוכה"},{"start":812.39,"end":814.39,"text":"מסקת כנוכה לכל הדיירים"},{"start":814.39,"end":817.41,"text":"כן? איזה גנבה"},{"start":817.41,"end":820.56,"text":"עכשיו מה מתכים כמו"},{"start":820.56,"end":822.56,"text":"שהמשפחה הזאת"},{"start":822.56,"end":825.75,"text":"זה אתם משפחת ישראליה"},{"start":825.75,"end":827.75,"text":"אנטגנרטית האינפנטילית"},{"start":827.75,"end":829.75,"text":"אתם משפחת ישראליה"},{"start":829.75,"end":831.81,"text":"פוקה"},{"start":831.81,"end":836.27,"text":"אתה מצחיק"},{"start":836.27,"end":838.27,"text":"אתה מצחיק"},{"start":838.27,"end":840.27,"text":"יש הרבה מילים בעולם"},{"start":840.27,"end":842.27,"text":"יש משעשע, מוודר"},{"start":842.27,"end":844.24,"text":"אבל המילה המתאימה לך"},{"start":844.24,"end":846.3,"text":"בדיוק זה מצחיק"},{"start":846.3,"end":848.3,"text":"אתה, איך שאתה נולדת"},{"start":848.3,"end":850.3,"text":"אתה יצאת מאימא שלך"},{"start":850.3,"end":852.3,"text":"קפצת על המיטה וצעקת"},{"start":852.3,"end":854.49,"text":"אימא, אני מצחיק"},{"start":854.49,"end":856.81,"text":"לא נכון"},{"start":856.81,"end":858.87,"text":"אני קפצתי הכבוצה ממיטה"},{"start":858.87,"end":860.87,"text":"וצעקתי ימם הדרגה"},{"start":860.87,"end":862.87,"text":"ואנחנו התכבקנו והיה שמחה ססון"},{"start":862.87,"end":863.87,"text":"כן"},{"start":863.87,"end":864.87,"text":"כן"},{"start":864.87,"end":865.87,"text":"כן"},{"start":865.87,"end":867.87,"text":"אתה לביבה במשבר"},{"start":867.87,"end":868.87,"text":"סביבון אנטיפטי"},{"start":868.87,"end":869.87,"text":"סופגניה מנוזלת"},{"start":869.87,"end":871.87,"text":"מתיוון באופר תרצוכה"},{"start":871.87,"end":873.87,"text":"נר להורדת חום"},{"start":873.87,"end":874.87,"text":"חנוכיה אנקוליטית"},{"start":874.87,"end":875.87,"text":"כן"},{"start":875.87,"end":876.87,"text":"כן"},{"start":876.87,"end":877.87,"text":"כן"},{"start":877.87,"end":880.87,"text":"ותקפוץ לחזרות למופע חנוכה שאני מארגן"},{"start":880.87,"end":881.96,"text":"כן"},{"start":881.96,"end":883.05,"text":"כן"},{"start":883.05,"end":884.46,"text":"בחיים"},{"start":884.46,"end":885.59,"text":"אבל"},{"start":885.59,"end":886.53,"text":"בחיים"},{"start":886.53,"end":887.93,"text":"לא יתפסו אותי"},{"start":887.93,"end":891.18,"text":"משתתף במופע החנוכה"},{"start":891.18,"end":893.24,"text":"של הקיווי הסעיר הזה"},{"start":893.24,"end":898.24,"text":"סביבון סמצא"},{"start":898.24,"end":900.34,"text":"חנוכה"},{"start":900.34,"end":910.63,"text":"חג החנוכה"},{"start":910.63,"end":912.72,"text":"אנחנו חוגגים"},{"start":912.72,"end":915.72,"text":"לזכר הניצחון של המעטים"},{"start":915.72,"end":917.84,"text":"מול רבים"},{"start":917.84,"end":921.06,"text":"אני לביווח מהו מושכת"},{"start":921.06,"end":923.06,"text":"שעל שמר חלקלק מתהפכת"},{"start":923.06,"end":925.06,"text":"רגע רגע רגע"},{"start":925.06,"end":927.06,"text":"רגע רגע"},{"start":927.06,"end":929.53,"text":"מה זה האותיות המפגרות האלה לסביבון?"},{"start":929.53,"end":931.53,"text":"זה כף ג' א' ב'"},{"start":931.53,"end":934.0,"text":"ומה זה?"},{"start":934.0,"end":936.0,"text":"קושי גדול אצלי במבטיה"},{"start":936.0,"end":938.28,"text":"את עזבי הכל תתרכזי בעמדה"},{"start":938.28,"end":940.28,"text":"עוברים לעמדה"},{"start":940.28,"end":942.28,"text":"יש! זיווה אל תתלהבי כשהוא אומר"},{"start":942.28,"end":944.28,"text":"העמדה הוא מתכוון לצעדים של הריקוד"},{"start":944.28,"end":946.28,"text":"בדיוק"},{"start":946.28,"end":948.28,"text":"ורגע רגע איפה עק שלך"},{"start":948.28,"end":950.28,"text":"הטמפית הזה האודי הזה"},{"start":950.28,"end":952.28,"text":"אני מצטער על האיחור פשוט לא הצטחתי לסדר"},{"start":952.28,"end":954.28,"text":"את התותח סופגניות שלי"},{"start":954.28,"end":957.32,"text":"שמי המנגינה ולא יורד בכלל. הנה, הנה, תסתכלו, בבקשה."},{"start":957.32,"end":961.65,"text":"כלום, הוא לא עובד."},{"start":961.65,"end":967.79,"text":"אה, אה, וואו, יש לי צחר חורת, אני הולך ליפול מהכיסא."},{"start":967.79,"end":972.59,"text":"אל תדאג, אבא, אתה לא טיפול, אני מרחתי מלא דבק שם על הכיסא, דבק מיוחד."},{"start":972.59,"end":973.01,"text":"מה?"},{"start":973.01,"end":977.09,"text":"נו, אני רואה שיש אמירה טובה ושהמורל גבוהה."},{"start":977.09,"end":978.95,"text":"זה הזמן להתחיל במסכת."},{"start":978.95,"end":981.17,"text":"כל אחד מדקלם את התפקיד שלו."},{"start":981.17,"end":984.89,"text":"אני אנטיוגוס, יבני אכזר."},{"start":985.17,"end":988.85,"text":"אני מרקד כמו קואלה במנזר."},{"start":988.85,"end":991.81,"text":"אני השמונאית אמיצה כמו אנטילופה."},{"start":991.81,"end":995.31,"text":"למיטה של אנטיוגוס אני קופצת הופופה."},{"start":995.31,"end":999.88,"text":"ממש מצחיק כל הקטע הזה, ממש מצחיק."},{"start":999.88,"end":1000.69,"text":"רגע, רגע."},{"start":1000.69,"end":1003.3,"text":"אני לא סתמנר, אני שמש."},{"start":1003.3,"end":1005.86,"text":"אני מקפט כמו טבוע משומש."},{"start":1005.86,"end":1007.66,"text":"ולקפט כמו צבוע."},{"start":1007.66,"end":1011.26,"text":"דיגידי, דיגידי, דיגידי, דיגידי, דיגידי, שיר כולה."},{"start":1011.26,"end":1015.2,"text":"חנוכה, חנוכה, יפה כל כך."},{"start":1015.2,"end":1019.51,"text":"להסממית, לשואל, לזיקית ולתיבטק."},{"start":1019.51,"end":1023.65,"text":"חנוכה, חנוכה, סביבה מסרסות."},{"start":1023.65,"end":1027.11,"text":"להסנאי, לבונה, לקואלה ולפי הדור."},{"start":1027.11,"end":1032.56,"text":"אולי במקרה אני שרחתי לציין את העובדה הזאת קודם."},{"start":1032.56,"end":1034.36,"text":"אולי במקרה שרחתי, אבל..."},{"start":1034.36,"end":1036.26,"text":"אבל זה מצחיק!"},{"start":1036.26,"end":1038.5,"text":"זה ממש מצחיק כל העסק הזה."},{"start":1038.5,"end":1039.14,"text":"אין בעדמה."},{"start":1039.14,"end":1042.06,"text":"אבל אני רעב, אולי נעשה איזו הפסקה קצרה."},{"start":1042.06,"end":1043.8,"text":"כן, הפסקה, אלפרד."},{"start":1043.8,"end":1044.8,"text":"הפסקה!"},{"start":1044.8,"end":1048.5,"text":"רגע, רגע, איזנו, נעשה הפסקה קצרה."},{"start":1048.5,"end":1050.56,"text":"כולם עולים אליי בדירה למעלה."},{"start":1050.56,"end":1052.8,"text":"קפה טוב וסופגניות להיכתס מעשה."},{"start":1052.8,"end":1056.5,"text":"או! או! או! או! או! או! או! או! או! או! או! או! או! או! או! או! או!"},{"start":1056.5,"end":1058.26,"text":"זה קצת כבד לי לידה עליי."},{"start":1058.26,"end":1060.26,"text":"אה, אה, רק רגע."},{"start":1060.26,"end":1065.59,"text":"אה, אה, אה, אה, תיק בלן! אה, אה, שערתם אותי פה דבוק לכיסא!"},{"start":1065.59,"end":1072.15,"text":"טוב, נו, שחררו אותי פה. נו, יותר גרוע מזה לא יכול להיות."},{"start":1072.15,"end":1101.44,"text":"ערב טוב. בעקבות פרשת האזנות הסתר לפלאפונים, נחשפה תופעה חדשה. מדהימה, לא פחות."},{"start":1101.44,"end":1105.59,"text":"שלום לכם! ברוכים הבאים לפלאפון של אלי סביך."},{"start":1105.59,"end":1108.59,"text":"כאן זה התחנה הפירטית שמשדרת ישירות לאוזניים שלכם."},{"start":1108.59,"end":1113.57,"text":"רדיו אלי סביך, הפלאפון שלנו מאזינים למאזינים."},{"start":1113.57,"end":1116.22,"text":"אופה, שנייה אחד יש לי במתינה."},{"start":1116.22,"end":1118.4,"text":"אלו? כן דינה, שלום לך דינה."},{"start":1118.4,"end":1122.46,"text":"כן, מאשקלון לדינה, אוקיי? ברוכים הבאים כל מאזינינו מאשקלון,"},{"start":1122.46,"end":1129.46,"text":"באשר אתם. אנחנו שמחים לרגל הצטרפותכם עינינו לתחנה פירטית של רדיו פלאפון אלי סביך."},{"start":1129.46,"end":1136.37,"text":"שנייה אחד, זה אתה נתבשרנו על טבר חדש, כולם נעבור לכוכבית 42."},{"start":1136.37,"end":1139.81,"text":"ונעבור לשמוע ג'ינגל."},{"start":1139.81,"end":1144.77,"text":"רדיו אלי סביך משדר עליכם, אלי רדיו פלאפון."},{"start":1144.77,"end":1152.04,"text":"יאה."},{"start":1152.04,"end":1153.04,"text":"הלו בוקר טוב."},{"start":1153.04,"end":1154.04,"text":"הלו אדוני בוקרור אדוני."},{"start":1154.04,"end":1155.04,"text":"כמה עולם מנה?"},{"start":1155.04,"end":1156.04,"text":"כתוב אדוני."},{"start":1156.04,"end":1157.61,"text":"14 שקל?"},{"start":1157.61,"end":1158.61,"text":"כן אדוני."},{"start":1158.61,"end":1159.61,"text":"מנה פלאבל ב-14 שקל?"},{"start":1159.61,"end":1160.51,"text":"כתוב."},{"start":1160.51,"end":1161.77,"text":"סדמה תן לי חצי מנה."},{"start":1161.77,"end":1164.4,"text":"אין בעיה אדוני, חצי מנה."},{"start":1164.4,"end":1165.34,"text":"13 שקל."},{"start":1165.34,"end":1166.37,"text":"כמה?"},{"start":1166.37,"end":1167.46,"text":"13 שקל אדוני."},{"start":1167.46,"end":1168.46,"text":"איך 13 שקל?"},{"start":1168.46,"end":1170.43,"text":"חצי מנה של 14 זה שבע לא?"},{"start":1170.43,"end":1173.58,"text":"אדוני מסתכל הפוך על כל האירוע."},{"start":1173.58,"end":1176.58,"text":"שים לב, אלוהים, חצי מנה הולך 13 שקל."},{"start":1176.58,"end":1177.58,"text":"כן."},{"start":1177.58,"end":1178.58,"text":"דהיינו, אני בא לקראת הקליאנט,"},{"start":1178.58,"end":1180.58,"text":"מוסיף לו שקל אחד בלבד,"},{"start":1180.58,"end":1182.58,"text":"ונותן לו מנה ב-14 שקל."},{"start":1182.58,"end":1184.58,"text":"אני לרג' עם הקליאנטים הולך לקראת,"},{"start":1184.58,"end":1186.99,"text":"בא לקראת הציבור."},{"start":1186.99,"end":1187.99,"text":"הבנתי, אם זה ההבדלים במחיר,"},{"start":1187.99,"end":1188.99,"text":"אז תן לי מנה, נו?"},{"start":1188.99,"end":1189.99,"text":"אין בעיה, אדוני."},{"start":1189.99,"end":1191.63,"text":"26 שקלים."},{"start":1191.63,"end":1193.08,"text":"כמה?"},{"start":1193.08,"end":1194.56,"text":"26 שקלים, אדוני."},{"start":1194.56,"end":1196.8,"text":"איך הקטל 26?"},{"start":1196.8,"end":1198.36,"text":"מה זאת אומרת?"},{"start":1198.36,"end":1199.36,"text":"איך? כתוב 14, לא?"},{"start":1199.36,"end":1201.45,"text":"אדוני מתייחס למנה הזאת."},{"start":1201.45,"end":1204.45,"text":"אלוהים אדוני ביקש מנה שהחצי שלה הוא 13 שקלים."},{"start":1204.45,"end":1206.45,"text":"דהיינו שני החצאים מחדב, כמה הם?"},{"start":1206.45,"end":1207.45,"text":"26."},{"start":1207.45,"end":1208.45,"text":"הבין אדוני."},{"start":1208.45,"end":1209.45,"text":"אבל כתוב 14."},{"start":1209.45,"end":1211.45,"text":"אדוני אם היית בא מראש ואומר לי, תן לי מנה,"},{"start":1211.45,"end":1214.45,"text":"היית מקבל ב-14 שקל, אבל אדוני ביקש מנה"},{"start":1214.45,"end":1217.45,"text":"שמורכבת משני החצאים של ה-13 שקל."},{"start":1217.45,"end":1218.45,"text":"דהיינו זה, כמה?"},{"start":1218.45,"end":1219.45,"text":"26."},{"start":1219.45,"end":1220.45,"text":"בבקשה אדוני."},{"start":1220.45,"end":1221.45,"text":"בוא אני אבוא עוד פעם."},{"start":1221.45,"end":1223.45,"text":"אין בעיה אדוני, אדוני רוצה לבוא פעם."},{"start":1223.45,"end":1225.45,"text":"אין בעיה אדוני."},{"start":1225.45,"end":1226.99,"text":"בסדר."},{"start":1226.99,"end":1229.63,"text":"שלום, בוקר טוב."},{"start":1229.63,"end":1230.63,"text":"אלן."},{"start":1230.63,"end":1232.07,"text":"תן לי בבקשה מנה."},{"start":1232.07,"end":1234.9,"text":"אדוני מוכר לי, היית פה קודם."},{"start":1234.9,"end":1236.22,"text":"מה?"},{"start":1236.22,"end":1237.28,"text":"26 שקלים אדוני."},{"start":1237.28,"end":1239.28,"text":"עזוב, די נשבר לי, תבין לי חצי מנה וזהו."},{"start":1239.28,"end":1244.73,"text":"בסדר אדוני, 25 שקלים בבקשה אדוני."},{"start":1244.73,"end":1249.5,"text":"פלאפל סאסון, באתי בגלל המחיר, נשארתי בגלל השירות."}]