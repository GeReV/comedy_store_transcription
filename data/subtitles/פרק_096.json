[{"start":18.91,"end":21.05,"text":"תזמה מופלע נחמן"},{"start":49.19,"end":55.75,"text":"בואו בואו בואו לקום דסטור בואו בואו בואו לקום דסטור"},{"start":55.75,"end":59.71,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות"},{"start":59.71,"end":65.12,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט"},{"start":65.12,"end":71.02,"text":"שמות האנשים והמקומות שונו לצורך העלילה"},{"start":71.02,"end":72.54,"text":"ומאתה הם ניקאים"},{"start":72.54,"end":101.25,"text":"הקום דסטור"},{"start":101.25,"end":105.09,"text":"מצוירים מצוירים"},{"start":105.09,"end":106.33,"text":"אג ראשון"},{"start":106.33,"end":107.25,"text":"יוטם"},{"start":107.25,"end":108.5,"text":"אקשן"},{"start":108.5,"end":109.91,"text":"אה איזה מצויר"},{"start":109.91,"end":112.6,"text":"מה קורה יוטם?"},{"start":112.6,"end":113.6,"text":"סליחה זה הגרון"},{"start":113.6,"end":117.6,"text":"יוטם יש לנו לעשות 20 תמויות ב20 דקות באמת"},{"start":117.6,"end":119.6,"text":"סליחה סליחה מעט חלה ימיסה"},{"start":119.6,"end":120.6,"text":"ומערים לירושלים"},{"start":120.6,"end":121.6,"text":"מעט חלה"},{"start":121.6,"end":122.6,"text":"תרוץ לו עם הסרט"},{"start":122.6,"end":124.6,"text":"טייקשני חברים מצוירים יוטם"},{"start":124.6,"end":125.6,"text":"אקשן"},{"start":125.6,"end":128.08,"text":"אה אה אה שלום לך"},{"start":128.08,"end":130.08,"text":"תראו מה קרה לי"},{"start":130.08,"end":133.08,"text":"יוטם"},{"start":133.08,"end":134.24,"text":"יוטם"},{"start":134.24,"end":135.24,"text":"יוטם"},{"start":135.24,"end":137.24,"text":"מה קורה עם הגרון שלך"},{"start":137.24,"end":139.24,"text":"באמת אנחנו נמערים לירושלים"},{"start":139.24,"end":140.24,"text":"מצטרר זה היה לי כל הלילה"},{"start":140.24,"end":141.24,"text":"חשבתי זה יעבור לי"},{"start":141.24,"end":143.52,"text":"מוכן בבקשה לא להפריע?"},{"start":143.52,"end":145.9,"text":"לא, לא עם חבודה, אין ניקיון"},{"start":145.9,"end":147.9,"text":"בסדר ניקיון אבל אל תפריע"},{"start":147.9,"end":149.96,"text":"יוטם אנחנו ממארים לירושלים"},{"start":149.96,"end":152.12,"text":"ירושלים"},{"start":152.12,"end":153.12,"text":"רוץ לו עם הסרט"},{"start":153.12,"end":154.12,"text":"רוץ לי מבציירן"},{"start":154.12,"end":155.15,"text":"יוטם"},{"start":155.15,"end":156.15,"text":"יוטם"},{"start":156.15,"end":157.15,"text":"אקשן"},{"start":157.15,"end":159.15,"text":"רוץ לו עם הסרטים"},{"start":159.15,"end":161.15,"text":"יוטם"},{"start":161.15,"end":162.21,"text":"יוטם"},{"start":162.21,"end":164.28,"text":"לא באמת מה יהיה יוטם?"},{"start":164.28,"end":166.28,"text":"אני מאוד מצטער הגרון"},{"start":166.28,"end":167.28,"text":"מצטער הגרון"},{"start":167.28,"end":170.28,"text":"אבל אני יודע שאגב אנחנו ממארים לירושלים צריך לעשות את זה"},{"start":170.28,"end":172.28,"text":"אורם מירושלים צריך לעשות את זה"},{"start":172.28,"end":175.28,"text":"לא מה זה תלוי בי אני חולה זה נפל עליי מה אני יכול לעשות"},{"start":175.28,"end":177.28,"text":"נפל עליי אני יכול לעשות"},{"start":177.28,"end":178.24,"text":"תגיד מי אתה?"},{"start":178.24,"end":179.24,"text":"באמת מי אתה?"},{"start":179.24,"end":181.24,"text":"אתה אני אצליץ לך מי אתה"},{"start":181.24,"end":183.43,"text":"אל תפריע"},{"start":183.43,"end":184.43,"text":"אקשן"},{"start":184.43,"end":220.76,"text":"אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה,"},{"start":220.76,"end":222.76,"text":"רק תיזהר מה נדבר עליו!"},{"start":222.76,"end":224.82,"text":"שלום לך בוסקרו!"},{"start":224.82,"end":227.82,"text":"ילד מתוק אתה!"},{"start":227.82,"end":229.82,"text":"אפשר לטעום?"},{"start":229.82,"end":231.82,"text":"אה חייה, סדר! אלו!"},{"start":231.82,"end":232.82,"text":"יופי!"},{"start":232.82,"end":233.82,"text":"יופי!"},{"start":233.82,"end":235.92,"text":"תסתכל על המוניטור!"},{"start":235.92,"end":237.21,"text":"מה?"},{"start":237.21,"end":238.21,"text":"מוניטור! מוניטור!"},{"start":238.21,"end":240.21,"text":"לא, אין טוב! אין טוב! אלו, אין פה טוב!"},{"start":240.21,"end":241.21,"text":"אני מבטאו, מסכיל!"},{"start":241.21,"end":242.21,"text":"אין לא איזה טוב!"},{"start":242.21,"end":243.21,"text":"תגור אחרי זה!"},{"start":243.21,"end":244.21,"text":"לא משנה, זה ממשיך!"},{"start":244.21,"end":245.21,"text":"תוכל להיות בשקט, אתה מפריע!"},{"start":245.21,"end":246.21,"text":"לא, בשקט המפריע!"},{"start":246.21,"end":248.04,"text":"תמשיך!"},{"start":248.04,"end":249.04,"text":"תמשיך!"},{"start":249.04,"end":250.04,"text":"אקשן!"},{"start":250.04,"end":251.04,"text":"אשל!"},{"start":251.04,"end":252.08,"text":"דקו איפה"},{"start":252.08,"end":254.24,"text":"בוסקו בצרה! בוסקו בצרה!"},{"start":254.24,"end":255.92,"text":"אם כן צריך לעזור לו!"},{"start":255.92,"end":257.12,"text":"היי ביותה!"},{"start":257.12,"end":259.29,"text":"אני בולי העביר!"},{"start":259.29,"end":261.18,"text":"בולי עביר הנסח!"},{"start":261.18,"end":263.85,"text":"איך היה? סדר כלה בולי בולבולי העביר!"},{"start":263.85,"end":265.37,"text":"בוסקו צרה עוסקו צרה, סדר!"},{"start":265.37,"end":268.57,"text":"יופי! בפלע! תמשיך! תמשיך! תמשיך, תמשיך!"},{"start":268.57,"end":269.57,"text":"תמשיך, תמשיך! מה קרה!"},{"start":269.57,"end":270.97,"text":"היי נגניבא! היי נגניבא!"},{"start":270.97,"end":305.24,"text":"הוווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":305.24,"end":308.5,"text":"לא, לא, אני שבשקיל עבן, לא, לא, לא יפה."},{"start":308.5,"end":313.95,"text":"מה זה תחשבי, בי..."},{"start":313.95,"end":317.53,"text":"שמא, התפנתה בדיוק משרה של מנקפה באולפן, אתה יכול להתחיל לעבוד מהיום."},{"start":317.53,"end":323.53,"text":"לא, לא, לא, אלו, סליחה רגע, לא, לא, לא, זה משרה מקיון, אלא, שבשקיל, אלו, לא, ככה, ככה, ככה, לא, לא."},{"start":323.53,"end":328.89,"text":"הוא בסליחה, גם מקיון, גם עשור, מקלופלו, ככה, כל עשור, מקלופלו, יכול לעשות גם זה וגם זה."},{"start":328.89,"end":331.33,"text":"בסדר שלך, אגמרנו להיום, נגמר הסרט."},{"start":331.33,"end":368.37,"text":"אגמר, לא נגמר הסרט, אגמר, אגמר, אגמר, אגמר בלבולי. צריך להציל אותו, כל האנדיאנים שבאים החללי, צריך להציל. תעזור, ערוץ לו. ערוץ לו, ערוץ לו. גופי, עזור הבוסקיל, הגופי. איך היה? רגע, שנייה. שלום. שלום, ליפ שיצליהו? כן. אנחנו מערוץ הקניות, באנו להתקין את מדליק הבוילר האוטומטי. או, או, יופי, חיכיתי לכם. בואו, כלסו. אלמב, בוא אחריי. איפה פה הבוילר? פה פה, כאן. אה. בבקשה."},{"start":368.77,"end":371.4,"text":"אדוני, מקשה."},{"start":371.4,"end":378.38,"text":"לא מתקינים את זה?"},{"start":378.38,"end":380.82,"text":"אדוני, מדליק הבוילר האוטומטי מותקן."},{"start":380.82,"end":383.56,"text":"מה זאת אומרת? אתם עוד לא חיברתם כלום."},{"start":383.56,"end":385.56,"text":"אדוני, זה מחובר. חתיכה אחת, קומפלט."},{"start":385.56,"end":386.56,"text":"הוא?"},{"start":386.56,"end":391.2,"text":"כן. אדוני, שים לב איך הוא עובד. פשוט, קל ובטוח."},{"start":391.2,"end":393.2,"text":"אלברט, תדליק בוילר."},{"start":393.2,"end":397.66,"text":"אלברט, קבע בוילר."},{"start":397.66,"end":400.88,"text":"קל, פשוט ונוח."},{"start":400.88,"end":402.88,"text":"מה זאת אומרת? את זה אני יכול לעשות לבד, אני לא צריך אותו."},{"start":402.88,"end":405.88,"text":"אדוני, אבל הוא אוטומטי, אדוני."},{"start":405.88,"end":410.88,"text":"אתה יכול פשוט להגיד לו והוא מדליק, אדוני, יש פה גם פונקציה נוספת של טיימר."},{"start":410.88,"end":412.07,"text":"טיימר?"},{"start":412.07,"end":416.07,"text":"כן, אתה יכול לתכנת את אלברט להדליק את הבוילר מתי שאתה רוצה והוא כבר עושה את זה לבד, אדוני."},{"start":416.07,"end":417.07,"text":"מה זאת אומרת?"},{"start":417.07,"end":419.07,"text":"לדוגמה, מחר, מתי אתה חוזר מהעבודה?"},{"start":419.07,"end":420.07,"text":"חמש."},{"start":420.07,"end":421.07,"text":"חמש, אתה רוצה שהבוילר יעבוד משעה?"},{"start":421.07,"end":422.07,"text":"ארבע."},{"start":422.07,"end":423.07,"text":"ארבע."},{"start":423.07,"end":425.07,"text":"אלברט, מחר תדליק בוילר בארבע."},{"start":425.07,"end":429.33,"text":"מתוכנת."},{"start":429.33,"end":439.74,"text":"טוב, אבל אתה לא מביא, יכול להיות פה בכל מיני בעיות, אני קם באמצע הלילה, רוצה ללכת למטפח לקחת משהו, אז אני עובר בתחתונים או לפעמים, אני בלי דרך, ערום?"},{"start":439.74,"end":442.12,"text":"מה אני עושה איתו בבית?"},{"start":442.12,"end":449.12,"text":"אדוני, אל תדאג, הוא צנוע בישן מנומס, הוא לא הסתכל, לא אין לו שיניים, תאמין לצמוך עליי, אני אפילו אדגים לך, בסדר?"},{"start":449.12,"end":450.12,"text":"אלברט!"},{"start":450.12,"end":454.74,"text":"אוקיי, אוקיי."},{"start":454.74,"end":455.74,"text":"אלברט, אלברט, תסתכל!"},{"start":455.74,"end":456.74,"text":"אופה, אופה!"},{"start":456.74,"end":458.74,"text":"אני מרגש, אני לא מעוניין."},{"start":458.74,"end":461.74,"text":"אני לא מעוניין בו, אני לא מעוניין בו."},{"start":461.74,"end":462.86,"text":"אני לא רוצה אותו."},{"start":462.86,"end":464.85,"text":"אתם יכולים לבקשה לצאת מהבית שלי?"},{"start":464.85,"end":467.97,"text":"אדוני, זה לא בסדר, תדע לך שזה יכול להיות גם פטיליה."},{"start":467.97,"end":470.97,"text":"אדוני, מקרר, מיקר, פוד פרוססור, אדוני, להפתיע אותה."},{"start":470.97,"end":471.97,"text":"מה פוד פרוססור?"},{"start":471.97,"end":472.97,"text":"איך הוא יכול להיות פוד פרוססור?"},{"start":472.97,"end":473.97,"text":"בקשה, בקשה."},{"start":473.97,"end":476.86,"text":"אלברט, הנה, קוטש את המזון דק-דק."},{"start":476.86,"end":478.24,"text":"חבל שאתם..."},{"start":478.24,"end":479.24,"text":"אתם יכולים לצאת מבקשה מהבית שלי?"},{"start":479.24,"end":481.24,"text":"כערית, אדוני, כערית זה עובד יופי."},{"start":481.24,"end":486.24,"text":"שדה קטנה, אגרתיו!"},{"start":486.24,"end":488.24,"text":"אדוני, אגרתיו, ארון חשמל, יש לך!"},{"start":488.24,"end":490.24,"text":"יש לי מבית, תודה!"},{"start":490.24,"end":494.25,"text":"גזייה, גזייה אדוני!"},{"start":494.25,"end":499.72,"text":"חולה ודלה, תקין את זה פיראטי!"},{"start":499.72,"end":502.27,"text":"אדוני, אולי מסתור לה כביסה?"},{"start":502.27,"end":505.99,"text":"זה ימרה מותק!"},{"start":505.99,"end":509.04,"text":"בואי, בואי תעמדי פה מתחת לבוילר איזה חצי שעה."},{"start":509.04,"end":511.17,"text":"סרטי בגל המציגים."},{"start":511.17,"end":512.17,"text":"הוא היה גנב."},{"start":512.17,"end":514.35,"text":"הלו!"},{"start":514.35,"end":515.31,"text":"קרוזיני."},{"start":515.31,"end":517.75,"text":"אין מוכנע בישו מה קרה, מה צועק, מה קרה?"},{"start":517.75,"end":518.75,"text":"מה קרה?"},{"start":518.75,"end":523.02,"text":"מה קרה?"},{"start":523.02,"end":525.02,"text":"עד שיום אחד עצר אותו שוטר."},{"start":525.02,"end":526.82,"text":"תימני."},{"start":526.82,"end":532.09,"text":"אין מוכנע בישו מה קרה?"},{"start":532.09,"end":534.17,"text":"מה קרה?"},{"start":534.17,"end":535.17,"text":"מה קרה?"},{"start":535.17,"end":538.06,"text":"הוא נשלח לכלא."},{"start":538.06,"end":540.06,"text":"מה קרה בישו שאין מוכנע?"},{"start":540.06,"end":541.06,"text":"למה ביצור, למה?"},{"start":541.06,"end":545.18,"text":"עם שכנול אתה התורכי."},{"start":545.18,"end":550.0,"text":"אבל ילד אחד חלם להציל אותו."},{"start":550.0,"end":553.83,"text":"אל תדאג בבא שבילי, אני אציל אותך בישו."},{"start":553.83,"end":557.62,"text":"זה שחרר את שבילי."},{"start":557.62,"end":564.6,"text":"עכשיו, בקולנוע של ציון."},{"start":564.6,"end":568.6,"text":"עצק ביצק עקביש על החלוא על הכביש."},{"start":568.6,"end":572.6,"text":"פתאום ירד הגש שמשתף אותו בביש."},{"start":572.6,"end":576.78,"text":"באה שמשיבשה את הטיפות."},{"start":576.78,"end":581.93,"text":"ועצק ביצק עקביש משחלוא שוב לצעוד."},{"start":581.93,"end":586.03,"text":"עצק מיציק בוא הבא איתה, עצק מיציק בוא מהר!"},{"start":586.03,"end":588.99,"text":"עצק מיציק בוא הבא איתה, עצק מי..."},{"start":588.99,"end":636.54,"text":"תודה רבה."},{"start":636.56,"end":673.06,"text":"תודה רבה."},{"start":673.08,"end":739.4,"text":"תודה רבה."},{"start":739.4,"end":742.22,"text":"אני חולה על שייקספיר, אני חולה על שייקספיר."},{"start":742.22,"end":743.08,"text":"יופי, יופי, יופי."},{"start":743.08,"end":744.46,"text":"האמת, אני גם מאוד אוהבת אותו."},{"start":744.46,"end":745.02,"text":"כן."},{"start":745.02,"end":745.34,"text":"כן."},{"start":745.34,"end":747.28,"text":"את נראית לי אחד שמבינה."},{"start":747.28,"end":748.04,"text":"נכון, אני מבינה."},{"start":748.04,"end":753.28,"text":"תגידי, נכון, קלאודיוס, הדות של אמלט יצא מניאק."},{"start":753.28,"end":756.1,"text":"איך הרגת אבא של אמלט סמלורן."},{"start":756.1,"end":760.1,"text":"אתם יודעים מה, האמת בקטע זה כל כך התרגשתי, אני פשוט בכיתי."},{"start":760.1,"end":761.4,"text":"שולה, צריך לזול."},{"start":761.4,"end":764.7,"text":"רגע, מוטי, אני יכול לשאול אותך שאלה אישית."},{"start":764.7,"end":765.9,"text":"זה ודאי, בטח."},{"start":765.9,"end":767.6,"text":"רום, בכה."},{"start":767.6,"end":768.62,"text":"מי, מוטי?"},{"start":768.62,"end":769.27,"text":"אה?"},{"start":769.27,"end":771.47,"text":"מה פתאום, מוטי בכלל לא נוגע לו הדברים האלה."},{"start":771.47,"end":774.17,"text":"כל כך לא רגישים הגברים האלה."},{"start":774.17,"end":774.77,"text":"כדורגל."},{"start":774.77,"end":776.93,"text":"אין להם שאר רוח."},{"start":776.93,"end":778.86,"text":"כדורגל, זה מה שמעניין."},{"start":778.86,"end":781.16,"text":"נכון, כדורגל, יש עכשיו משחק, שולה, קדימה."},{"start":781.16,"end":784.46,"text":"אמרתי רגע, אלו מתחילת הערב זה ככה, די!"},{"start":784.46,"end":787.94,"text":"רגע, רגע, אני לא רוצה להיכנס ביניכם שלא תעריב..."},{"start":787.94,"end":791.02,"text":"אתה לא נכנס, תאמין לי, זה כבר ככה כל הזמן."},{"start":791.02,"end":793.02,"text":"זה פשוט זה לא טוב לו וזה לא טוב לו."},{"start":793.02,"end":793.32,"text":"כן."},{"start":793.32,"end":794.14,"text":"זה בסדר."},{"start":794.14,"end":797.4,"text":"את רוצה לבוא אליי לראות רפרודוקציות של דלי?"},{"start":797.4,"end":798.98,"text":"סלוודור דלי?"},{"start":798.98,"end":799.48,"text":"כן."},{"start":799.48,"end":801.18,"text":"אני לא מאמינה בוודאי."},{"start":801.18,"end":804.84,"text":"נכון שהסוריאליזם זה לא זרם שמיצה את עצמו."},{"start":804.84,"end":805.32,"text":"שולה."},{"start":805.32,"end":806.33,"text":"ממש אני חושב."},{"start":806.33,"end":806.97,"text":"שולה."},{"start":806.97,"end":807.92,"text":"שולה!"},{"start":808.55,"end":810.21,"text":"שולה, אני קורא אלה, שולה!"},{"start":810.21,"end":815.68,"text":"שלום לכם."},{"start":815.68,"end":818.31,"text":"שוב אתם מפינתנו חיות ארצנו."},{"start":818.31,"end":822.58,"text":"אני ברוך, ועם הדין נמצא ג'וני שואלי."},{"start":822.58,"end":823.7,"text":"שלום ג'וני."},{"start":823.7,"end":829.82,"text":"והפעם הזמיננו לאולפן עז שיודעת להכין מטוס נייר."},{"start":829.82,"end":833.01,"text":"תודה ג'טה."},{"start":833.01,"end":837.15,"text":"ונעבור אל העז שאין לה מושג בהכנת מטוסי נייר."},{"start":837.15,"end":841.02,"text":"תודה מרסל."},{"start":841.02,"end":844.09,"text":"והפעם יש לנו אורך נוסף."},{"start":844.09,"end":847.96,"text":"נמצא איתנו כאן צבוע שאוהב לאכול קרמבו."},{"start":848.97,"end":851.81,"text":"פליקס?"},{"start":851.81,"end":857.33,"text":"יערב לך."},{"start":857.33,"end":861.18,"text":"ונעבור אל הצבוע ששונא לאכול קרמבו."},{"start":861.18,"end":868.43,"text":"נמרוד יערב גם לך."},{"start":868.43,"end":871.32,"text":"יעמי."},{"start":871.32,"end":874.11,"text":"עד כאן פינתנו חיות ארצנו."},{"start":874.11,"end":875.72,"text":"שובו..."},{"start":875.72,"end":876.56,"text":"לא!"},{"start":876.56,"end":879.1,"text":"מי שחר את החיידק לטורף מהכלום שלו?"},{"start":879.1,"end":881.32,"text":"נא!"},{"start":881.32,"end":884.58,"text":"בער, מזריק את האנטיבירוס."},{"start":884.58,"end":886.49,"text":"נא!"},{"start":886.49,"end":890.86,"text":"עד כאן פינתנו חיות ארצנו."},{"start":890.86,"end":892.54,"text":"שובו אלינו בהמשך."},{"start":892.54,"end":897.61,"text":"אה! לא! מי יזריק את הנשיאו בניסיוני? אה!"},{"start":897.61,"end":924.48,"text":"עצק ביצק עקביש על החלוא על הכביש. פתאום ירד הגשם שתפותו בוויש. באה שמשיבשה את הטיפות. ועצק ביצק עקביש משיכלו שוב לצעוד."},{"start":924.48,"end":935.89,"text":"*עזק ועזק ועזק ועזק*"},{"start":935.89,"end":948.61,"text":"שלום. אתה יוצא?"},{"start":948.61,"end":949.79,"text":"לאן יוצא?"},{"start":949.79,"end":952.39,"text":"אדוני, אתה עולה או יורד?"},{"start":952.39,"end":954.17,"text":"סליחה, לא מביא לי, מה אתה מחפש?"},{"start":954.17,"end":957.12,"text":"אדוני, המעלית. עולה או יורדת?"},{"start":957.12,"end":959.42,"text":"אין פה שום מעלית, אתה כנראה היית אדוני, אני מצטער."},{"start":959.42,"end":961.53,"text":"מה אתה היית אדוני, אני צריך למעלה, הלו?"},{"start":961.53,"end":964.7,"text":"כן."},{"start":964.7,"end":967.5,"text":"אדוני, אתה עולה או יורד, אני צריך להגיע למעלה, אני נורא ממהר."},{"start":967.5,"end":972.3,"text":"אדוני, אני אמרתי לך, אין פה שום מה זה, לא מעלית, אני מצטער, אני גר פה, זה לא מעלית, יש פה מדרגות, תעלה לשם."},{"start":972.3,"end":975.1,"text":"איזה מדרגות אדוני, אני צריך לקומה שבע, אתה רוצה צחוק מהבן אדם? אני צריך..."},{"start":975.1,"end":975.7,"text":"אני לא אתם מחפש."},{"start":975.7,"end":979.1,"text":"אדוני, אני מחפש את משה אייפשיץ, גר למעלה, אני צריך לעלות למעלה."},{"start":979.1,"end":980.7,"text":"אז תעלה למעלה, יש פה מדרגות."},{"start":980.7,"end":984.3,"text":"איזה מדרגות, זה קומה שבע, תגיד לי, אתה יש תגעת, תן לי, כנס למעלית, מה אתה עושה צחוק?"},{"start":984.3,"end":987.23,"text":"-אדוני, אני לא יודע מה אתה רוצה, מצטרס. -אדוני, זה חוצפה מדרגה ש..."},{"start":987.23,"end":993.34,"text":"זה פשוט חוצפה לשמה, אתה אנטיפט, אדוני, תן לי בקשה לעלות למעלה, בסדר?"},{"start":993.34,"end":998.34,"text":"-על מה אתה מדבר? זה בית, אתה רואה את זה בית, יש פה מטבח, יש פה סלון חדש, על מה אתה מדבר? זה לא מעלית."},{"start":998.34,"end":1000.34,"text":"-אתה הגע לך. -אתה גר פה, כן?"},{"start":1000.34,"end":1003.34,"text":"-כן, אני גר פה. -התנחלת פה במעלית, למה לא?"},{"start":1003.34,"end":1007.34,"text":"הוא גר פה, יש פה עוד אנשים, אדוני, אנחנו יכולים לעלות, להרדל מתי שנרצה."},{"start":1007.34,"end":1010.34,"text":"תעוף לי מהעיניים כשאני קורא לה משטרה, בסדר?"},{"start":1010.34,"end":1012.34,"text":"אני אקרא לה, אני אקרא לה משטרה, אני אכתיקה את הדברת!"},{"start":1012.34,"end":1017.21,"text":"אדוני, אני אמרתי לך דבר!"},{"start":1017.21,"end":1018.66,"text":"מי, מי אתם?"},{"start":1018.66,"end":1020.17,"text":"מחבאש."},{"start":1020.17,"end":1021.23,"text":"מה מחבאש?"},{"start":1021.23,"end":1024.35,"text":"ואנו נחלץ אותך, אתה לא נתקעת פה במעלית."},{"start":1024.35,"end":1028.35,"text":"איזה מעלית? אני כבר אמרתי לבן אדם הזה, אתה מוני, אין פה שום מעלית, אני גר פה לבד הדירה!"},{"start":1028.35,"end":1030.35,"text":"רגע, באיזה קומה אתה גר, אדוני?"},{"start":1030.35,"end":1031.35,"text":"שנייה!"},{"start":1031.35,"end":1033.35,"text":"אז למה אתה תקוע בין קומה שנייה לשלישית?"},{"start":1033.35,"end":1035.51,"text":"אני לא תקוע בין קומה שנייה לשלישית!"},{"start":1035.51,"end":1037.51,"text":"אדוני, אתה רוצה לצאת מהמעלית או לא?"},{"start":1037.51,"end":1039.51,"text":"לא! לא! אני רוצה לגור פה!"},{"start":1039.51,"end":1041.51,"text":"אז אולי תיתן לכל אלה שנתקעו איתך שייצאו?"},{"start":1041.51,"end":1043.51,"text":"מי מתקעת פה? אף אחד אני גר פה לבד!"},{"start":1043.51,"end":1045.51,"text":"אתם לא מבינים, אני גר פה לבד!"},{"start":1045.51,"end":1047.51,"text":"טוב, כל אלה שנתקעו ולאנחנו לצאת, בואו!"},{"start":1047.51,"end":1049.51,"text":"צורח רוצה!"},{"start":1049.51,"end":1051.51,"text":"בואו, בזהירות, בזהירות..."},{"start":1051.51,"end":1053.57,"text":"מה? מה? מה? מה?"},{"start":1053.57,"end":1056.14,"text":"מבוק..."},{"start":1056.14,"end":1059.19,"text":"אלו, מה זה... מה?"},{"start":1059.19,"end":1061.19,"text":"טוב, אתה רוצה לצאת עם כולם או שאתה נשאר פה?"},{"start":1061.19,"end":1069.11,"text":"מה? אני... אני צריך לחשב על זה. מ... מאיפה?"},{"start":1069.11,"end":1076.89,"text":"ולסיום קבלו שוב את הזמר המופלא נחמן והפעם בסגנון הקאמטרי"},{"start":1076.89,"end":1091.95,"text":"אסטור קומדי מבסולסי נגמרה עוד תוכנית כמונה השרסי בגינה ישיונה מבערכת המדינה"},{"start":1091.95,"end":1117.95,"text":"נגמרה עוד תוכנית כמונה שרסי בגינה ישיונה מברכת המדינה"},{"start":1117.95,"end":1121.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1121.95,"end":1127.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1127.95,"end":1128.05,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1127.95,"end":1128.05,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1127.95,"end":1131.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1131.95,"end":1139.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1139.95,"end":1141.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1141.95,"end":1146.95,"text":"נגמרה עוד תוכנית כמונה שפרסי"},{"start":1146.95,"end":1148.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1148.95,"end":1150.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1150.95,"end":1152.95,"text":"נגמרה עוד תוכנית כמונה שרסי"},{"start":1152.95,"end":1154.95,"text":"נגמרה עוד תוכנית כמונה עוד תוכנית כמונה עש פרסי"},{"start":1154.95,"end":1162.04,"text":"נגמרה עוד תוכנית כמונה עש פרסי"},{"start":1162.04,"end":1166.52,"text":"נגמרה עוד תוכנית כמונה עש פרסי"},{"start":1166.52,"end":1169.12,"text":"נגמרה עוד תוכנית כמונה עש פרסי"}]