[{"start":24.93,"end":28.43,"text":"חמודה רגבו"},{"start":28.43,"end":34.74,"text":"אני לא הבחרת חמודה רגבו"},{"start":34.74,"end":35.74,"text":"אני חמודה רגבו"},{"start":35.74,"end":162.3,"text":"אני רואה פרפגרת"},{"start":162.3,"end":163.3,"text":"רק נראה ככה"},{"start":163.3,"end":167.85,"text":"גידי, בוטה"},{"start":167.85,"end":169.23,"text":"תעוד מער"},{"start":169.23,"end":189.94,"text":"אני לא מביא שם"},{"start":189.94,"end":194.97,"text":"שואל מקום של ברגבים"},{"start":194.97,"end":195.97,"text":"אני לא מביא שם"},{"start":195.97,"end":199.95,"text":"אז למה לי יש להם בלפה במכנסה"},{"start":199.95,"end":202.07,"text":"היא רוב לי פרפגרת"},{"start":202.07,"end":204.07,"text":"ומחפשו לקרנסים"},{"start":204.07,"end":205.61,"text":"וואו"},{"start":205.61,"end":209.52,"text":"כל זאת"},{"start":209.52,"end":210.52,"text":"זאת"},{"start":210.52,"end":211.52,"text":"סביבית הגחמינית"},{"start":211.52,"end":213.77,"text":"היא נכנסת התפקית שלה זה לעיר"},{"start":213.77,"end":214.77,"text":"את הקרנסים של השונות"},{"start":214.77,"end":223.58,"text":"וגם אני יכולה לעשות מילים"},{"start":223.58,"end":226.78,"text":"לא לעשות מילים"},{"start":226.78,"end":237.02,"text":"אלכס"},{"start":237.02,"end":242.28,"text":"לא יודעת מה זה בלי"},{"start":242.28,"end":244.36,"text":"מה זה?"},{"start":244.36,"end":245.77,"text":"את נפגיד את זה"},{"start":245.77,"end":247.07,"text":"מה זה פסיסים?"},{"start":247.07,"end":251.22,"text":"אלכס"},{"start":251.22,"end":255.04,"text":"ונביא דקי אבוני עולה במעלית אצלך בביליון"},{"start":255.04,"end":257.84,"text":"את חושבת שהוא בא אליי"},{"start":257.84,"end":258.83,"text":"אבל הוא בא לרינה"},{"start":258.83,"end":271.47,"text":"הוא מריחוד מושך"},{"start":271.47,"end":273.47,"text":"אתה לא יכולה לצפות איתך בפורוגרפיה מוחזת"},{"start":273.47,"end":275.47,"text":"שמוסיקה קלאסית ופסידה"},{"start":275.47,"end":278.33,"text":"אני נלך לסרט"},{"start":278.33,"end":279.33,"text":"ריחה אהפה"},{"start":279.33,"end":281.33,"text":"תזמה אני נשארת פה"},{"start"