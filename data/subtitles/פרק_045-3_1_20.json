[{"start":38.91,"end":40.97,"text":"ארסת את הבדינה, בוג'רס אחד גדול."},{"start":40.97,"end":43.12,"text":"יש תוכנית אחת שהיא טובה היום,"},{"start":43.12,"end":45.12,"text":"ואוהב אותה גדול כקטן, משפחה כאוכלוסייה,"},{"start":45.12,"end":47.12,"text":"אוכלוסייה כגמבה ושסק כמנגו."},{"start":47.12,"end":50.12,"text":"אם יש תוכנית אחת שהיא טובה עדיין ומדברת אל כל העם,"},{"start":50.12,"end":51.37,"text":"זה נקודת חן עם אורי דביר."},{"start":51.37,"end":53.43,"text":"מיד אחרי הקומדיסטור."},{"start":53.43,"end":58.01,"text":"אה! לך דבר לשסק."},{"start":58.01,"end":99.81,"text":"שלום."},{"start":99.81,"end":101.81,"text":"הגעתם לביתם של משפחת נתן,"},{"start":101.81,"end":103.81,"text":"אין באפשרותנו להגיע כרגע לאינדרקום."},{"start":103.81,"end":107.81,"text":"הנה, נשאירו הודעתכם ואנו נענה בקדם. תודה."},{"start":107.81,"end":113.39,"text":"ערב טוב, הרי ידיעה שפורסמה באחד מיתוני הצהריים."},{"start":113.39,"end":117.93,"text":"פסק הלכה: אסור להתחפש לז'וז'ו ולדנה אינטרנשונל."},{"start":117.93,"end":122.15,"text":"הרב אפרים זלמנוביץ' אסר על ילדים להתחפש לז'וז'ו חלסטרה"},{"start":122.15,"end":123.15,"text":"כי הוא מנבל את הפה."},{"start":123.15,"end":126.46,"text":"לשם קבלת תגובה הזמנו לאולפן את כבוד הרב בריח."},{"start":126.46,"end":127.46,"text":"ערב טוב, כבודו."},{"start":127.46,"end":128.45,"text":"ערב טוב, שלום רב."},{"start":128.45,"end":130.45,"text":"מדוע אסור להתחפש לז'וז'ו?"},{"start":130.45,"end":139.41,"text":"אני, אני, אני, השאלה שחתמוהה, ודאי שאסור להתחפש לז'וז'ו, אנחנו יצאנו כרגע מחדרו של ערב את המשליטה, ואנחנו המומים וכואבים."},{"start":139.41,"end":149.41,"text":"אין ספק שאסור להתחפש לדמות שהסמל המסחרי שלה הוא צחוק שכזה, אוי, אוי, אוי, דבר שמזכיר חזיר, וכפי שאתה יודע, חזיר הוא חיה תמאה ועשורה על פי הדת היהודית."},{"start":149.41,"end":156.53,"text":"מה עוד שהוא לובש עליו נמר, ונמר הוא לא דג שמפריז קסקסים, לכן אסור להתחפש לז'וז'ו, זה ברור."},{"start":156.53,"end":164.53,"text":"אנחנו גם הוצאנו פסק עליך הרבה יותר חמור שאוסר להתחפש תחפושות אחרות, הרבה יותר קשה מהרב של זלמנוביץ'."},{"start":164.53,"end":166.53,"text":"ראה, אסור להתחפש לקובוי."},{"start":166.53,"end":167.53,"text":"למה?"},{"start":167.53,"end":174.53,"text":"ראה, קובוי זה תחפוש את מוקצה, כולם יודעים שבשרטי הקובוי עם הנבל הוא אומר לשודד \"הנדזאפ אירו מדרפאקר\"."},{"start":174.53,"end":178.53,"text":"ומדרפאקר כמובן, אסור להגיד, זה זוות, זה גועל נפץ ואסור לנבל את הפה."},{"start":178.53,"end":179.53,"text":"איזו תחפשות עשרת?"},{"start":179.53,"end":181.53,"text":"אסור כמובן להתחפש לליצן."},{"start":181.53,"end":183.53,"text":"מדוע ליצן? דמות ממה?"},{"start":183.53,"end":185.5,"text":"דמות ממה? איך אומר השיר?"},{"start":185.5,"end":187.88,"text":"ליצן קטן נחמד."},{"start":187.88,"end":190.88,"text":"ליצן קטן נחמד, קודם יודעים מה זה קטן."},{"start":190.88,"end":192.88,"text":"הקטן הוא לא תמיד נחמד."},{"start":192.88,"end":194.88,"text":"הקטן עלול לעשות דברים ואפילו לגדול."},{"start":194.88,"end":199.88,"text":"לכן אנחנו החלטנו להפסיק לאלתר את כל התחפושות של הליצנים לאלתר."},{"start":199.88,"end":202.88,"text":"בכלל אנחנו החלטנו לאסור את כל התחפושות השנה"},{"start":202.88,"end":206.88,"text":"כי כולם איכשהו מחללים את חג הפורים"},{"start":206.88,"end":208.88,"text":"ולכן אנחנו נאסור על הפצת התחפושות"},{"start":208.88,"end":212.88,"text":"ועבור זה שתרום לנו כמובן המנחה הישקלים"},{"start":212.88,"end":214.88,"text":"אז למה כן מותר להתחפש?"},{"start":214.88,"end":217.88,"text":"כמובן התחפושת היחידה אותה אנחנו נאשר"},{"start":217.88,"end":219.88,"text":"היא התחפושת של הרב זלמנוביץ'"},{"start":219.88,"end":222.88,"text":"הרב זלמנוביץ' היא דמות מצחיקה, דמות חינוכית"},{"start":222.88,"end":224.88,"text":"הילדים אוהבים אותה, הבנות קרועות עליו"},{"start":224.88,"end":227.88,"text":"לכן אין ספק הרב זלמנוביץ' היא התחפושת בפורים"},{"start":227.88,"end":231.88,"text":"ואם הדברים האלה לא התקיימו אנחנו נפרק את הקואליציה"},{"start":231.88,"end":233.88,"text":"תודה רבה לך"},{"start":233.88,"end":235.88,"text":"זה הכל להפעם כאן במבזק של ז'ק"},{"start":235.88,"end":244.73,"text":"לילה טוב והמשך צפייה נעימה"},{"start":244.73,"end":260.81,"text":"חבר'ה תזיזו טיפה את הספוטים ימינה"},{"start":260.81,"end":262.94,"text":"להוריד מצלמות כן"},{"start":262.94,"end":263.94,"text":"כל המצלמות לשם"},{"start":263.94,"end":265.94,"text":"אלן אלן אוקיי גמרתי מהבן אדם"},{"start":265.94,"end":266.94,"text":"מה קורה עכשיו?"},{"start":266.94,"end":267.94,"text":"סיימת ג'ודי לא צריכה להתאפר"},{"start":267.94,"end":268.94,"text":"להוריד!"},{"start":268.94,"end":269.94,"text":"רגע רגע שנייה לא דעתי"},{"start":269.94,"end":271.94,"text":"ג'ודי לא צריכה להתאפר או ג'ודי לא צריכה להתאפר"},{"start":271.94,"end":273.94,"text":"בסדר חבר'ה עוד טיפה"},{"start":273.94,"end":274.94,"text":"שנייה שנייה לא ברור לי רגע"},{"start":274.94,"end":277.94,"text":"ג'ודי לא צריכה להתאפר או ג'ודי לא צריכה להתאפר"},{"start":277.94,"end":279.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":279.97,"end":281.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":281.97,"end":284.97,"text":"ג'ודי לא צריכה להתאפר או ג'ודי לא צריכה להתאפר"},{"start":284.97,"end":285.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":285.97,"end":287.97,"text":"מה הבעיה שאתה לא מבין?"},{"start":287.97,"end":289.97,"text":"אני לא מבין את זה"},{"start":289.97,"end":291.97,"text":"יש ג'ודי לא צריכה להתאפר"},{"start":291.97,"end":293.97,"text":"ויש ג'ודי לא צריכה להתאפר"},{"start":293.97,"end":295.97,"text":"למה אתה לא מבין?"},{"start":295.97,"end":297.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":297.97,"end":299.97,"text":"אבל אתה לא מבין, אתה לא ברור, יש שני דברים"},{"start":299.97,"end":301.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":301.97,"end":303.97,"text":"מה הבעיה שאתה?"},{"start":303.97,"end":305.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":305.97,"end":307.97,"text":"יש ג'ודי לא"},{"start":307.97,"end":309.97,"text":"ג'ודי לא צריכה להתאפר"},{"start":309.97,"end":313.97,"text":"במיטות אני צריכה להתאפר או לא צריכה"},{"start":313.97,"end":316.64,"text":"לא"},{"start":316.64,"end":319.69,"text":"מה שאלתי"},{"start":319.69,"end":325.49,"text":"כמה ברמי ג'ה סעודיה"},{"start":325.49,"end":327.49,"text":"מנתרפסונה לאסרעילי מנעור של מלחוץ"},{"start":327.49,"end":358.32,"text":"תודה רבה."},{"start":358.34,"end":395.47,"text":"תודה רבה."},{"start":395.49,"end":397.49,"text":"תודה רבה."},{"start":397.49,"end":399.49,"text":"תודה רבה."},{"start":399.49,"end":407.36,"text":"תודה רבה."},{"start":407.36,"end":409.36,"text":"תודה רבה."},{"start":409.36,"end":411.36,"text":"תודה רבה."},{"start":411.36,"end":413.36,"text":"תודה רבה."},{"start":413.36,"end":415.32,"text":"תודה רבה."},{"start":415.32,"end":418.18,"text":"תודה רבה."},{"start":418.18,"end":420.18,"text":"תודה רבה."},{"start":420.18,"end":422.18,"text":"תודה רבה."},{"start":422.18,"end":425.3,"text":"תודה רבה."},{"start":455.13,"end":457.13,"text":"תודה רבה."},{"start":495.55,"end":540.8,"text":"תודה רבה."},{"start":540.8,"end":543.03,"text":"שנות השבעים המוקדמות,"},{"start":543.03,"end":545.09,"text":"להקת בוני ים בסייה"},{"start":545.09,"end":547.18,"text":"וכאן בארץ תוכניתך"},{"start":547.18,"end":549.16,"text":"מה פתאום שוברת סיים."},{"start":549.16,"end":551.37,"text":"לאן נעלמת, קשקשת"},{"start":551.37,"end":553.56,"text":"ומה אתה עושה היום?"},{"start":553.56,"end":555.56,"text":"לצערי, למרות שהיה לנו אחלה רייטינג,"},{"start":555.56,"end":557.62,"text":"התוכנית ירדה"},{"start":557.62,"end":559.84,"text":"ואיך שהיא ירדה, נכנסתי לדיכאון,"},{"start":559.84,"end":561.86,"text":"התמכרתי לסמים,"},{"start":561.86,"end":563.83,"text":"ירדתי לאלת, התנקרתי לחברה."},{"start":563.83,"end":567.98,"text":"אבל עכשיו אני שמח לומר שאני נקי,"},{"start":567.98,"end":571.06,"text":"כיום אני עורך דין מצליח בחברה מאוד גדולה."},{"start":571.06,"end":573.14,"text":"תרשה לי לחזור לאותם שנות ה-70."},{"start":573.14,"end":577.61,"text":"בעולם הבי-ג'יז הולכים מחי לחייל,"},{"start":577.61,"end":580.61,"text":"כאן בארץ אוזי פוקס והסגנונות הצ'רצ'ילים,"},{"start":580.61,"end":583.64,"text":"ובטלוויזיות אנשים אוהבים את קשקשתה."},{"start":583.64,"end":585.64,"text":"הייתה כוכב מאוד מאוד מפורסם."},{"start":585.64,"end":588.64,"text":"ספר לנו איזושהי חוויה מאותה תקופה."},{"start":588.64,"end":592.64,"text":"תשמע, התוכנית הזאת הייתה התקופה הכי קשה בחיי."},{"start":592.64,"end":596.76,"text":"מה אתה חושב, שרציתי להשתתף בתוכנית מטומטמת של ילדים?"},{"start":596.76,"end":597.76,"text":"סניתי כל רגע."},{"start":597.76,"end":600.89,"text":"אה, בכלל היו לי חלומות אחרים."},{"start":600.89,"end":601.95,"text":"אילו חלומות היו לך?"},{"start":601.95,"end":603.95,"text":"אה, אז אני גדול לך זקופ היסטרי."},{"start":603.95,"end":605.91,"text":"בעצם הייתה לי להקת רור כבד."},{"start":605.91,"end":606.88,"text":"קשקשתה ובתולות."},{"start":606.88,"end":609.88,"text":"אה, רצינו לכבוש את העולם, אבל אתה יודע,"},{"start":609.88,"end":611.88,"text":"בארץ אי אפשר להתפרנס מאומנות."},{"start":611.88,"end":613.88,"text":"כסמק."},{"start":613.88,"end":621.18,"text":"אם אפשר את הקוסמק להוריד בעריכה כדי שזה לא ייכנס לשידור,"},{"start":621.18,"end":624.18,"text":"והפעם ברשותך גשקשת נעשה התנחת הקלה,"},{"start":624.18,"end":627.5,"text":"מה מזכיר לך הכל הבא."},{"start":627.5,"end":630.5,"text":"כולכם שחקו נאיתי."},{"start":630.5,"end":633.72,"text":"לא לא לא לא."},{"start":633.72,"end":638.94,"text":"אתה לא זוכר את נירא, גשקשת."},{"start":638.94,"end":640.94,"text":"בטע שאני זוכר, בטע."},{"start":640.94,"end":642.94,"text":"זה הרוח השובה."},{"start":642.94,"end":643.94,"text":"אתה אורבי מפה, אתה אורבי מפה."},{"start":643.94,"end":644.94,"text":"מטומטמת."},{"start":644.94,"end":647.94,"text":"נירא רבינוביץ' כוכבת תוכנית הילדים הפתאום."},{"start":647.94,"end":649.94,"text":"לא השתנה, לא השתנה,"},{"start":649.94,"end":651.94,"text":"עם אותם לא ריצע."},{"start":651.94,"end":653.94,"text":"לך מפה!"},{"start":653.94,"end":655.94,"text":"אין ספק שהתרגשות רבה."},{"start":655.94,"end":658.93,"text":"נירא רבינוביץ' בכל העולם כולו"},{"start":658.93,"end":661.93,"text":"רוקדים ג'ולי אנדריוז לצלילי המוזיקה."},{"start":661.93,"end":664.96,"text":"ואילו כאן בארץ, נירא רבינוביץ'"},{"start":664.96,"end":667.03,"text":"שחקנית תיאטרון מפורסמת, כוכבת,"},{"start":667.03,"end":669.05,"text":"ועושה חלטורות בתוכניות ילדים,"},{"start":669.05,"end":671.05,"text":"בעיקר בקשקשתה."},{"start":671.05,"end":672.05,"text":"ערב טוב לך, נירא."},{"start":672.05,"end":676.05,"text":"ערב טוב גם לך."},{"start":676.05,"end":678.05,"text":"ובכן, כשקשתה, אתה לא זוכר את נירא?"},{"start":678.05,"end":681.05,"text":"מה שאני זוכר, שאני הייתי מת לשיר רוק כבד,"},{"start":681.05,"end":682.05,"text":"לקסך עם הגיטרה,"},{"start":682.05,"end":684.05,"text":"כל פעמי נכנסת לי משאיר עם הדבילים שלה."},{"start":684.05,"end":692.05,"text":"אני רציתי להיות זמה רוק!"},{"start":692.05,"end":694.05,"text":"וואן, טו, טריף!"},{"start":694.05,"end":697.05,"text":"קוראים לי כשקשתה, כשקשתה זה שני!"},{"start":697.05,"end":700.99,"text":"טיימך ושחק ושלום!"},{"start":700.99,"end":702.24,"text":"נשאר לי, אוקיי!"},{"start":702.24,"end":703.24,"text":"נשאר לי, אוקיי!"},{"start":703.24,"end":705.24,"text":"כן, אוקיי! בקצב הנפלא הזה."},{"start":705.24,"end":709.33,"text":"אנחנו נסיים את תכניתנו להיום חיים שכאלה."},{"start":709.33,"end":712.36,"text":"אין ספק, אני מקווה שנהניתם לנו את החוויה מאוד מרגשת."},{"start":712.36,"end":718.49,"text":"בשבוע הבא יתארכו אצלנו צ'ומפי ואין שם לילה טוב."},{"start":718.49,"end":724.83,"text":"שמעון!"},{"start":724.83,"end":725.99,"text":"אה?"},{"start":725.99,"end":728.1,"text":"באה לי מחשבה."},{"start":728.1,"end":730.45,"text":"אני מקווה לא על אוכל, למה אני לא רעב."},{"start":730.45,"end":732.45,"text":"לא, אל תדע."},{"start":732.45,"end":736.81,"text":"החיים זה כמו בקרוב."},{"start":736.81,"end":740.28,"text":"איזה סמי טרלר על העלימה שלך?"},{"start":740.28,"end":742.28,"text":"לא על הכלוב, אחי."},{"start":742.28,"end":744.28,"text":"זה כמו הבקרוב של הסטרטיב"},{"start":744.28,"end":746.28,"text":"שבטלוויזיה מראים לך את הבקרוב."},{"start":746.28,"end":747.24,"text":"כן."},{"start":747.24,"end":749.34,"text":"תראה, בוא תעקוב אחרי במחשבה."},{"start":749.34,"end":750.34,"text":"אוקיי."},{"start":750.34,"end":752.34,"text":"הנה אתה פותח טלוויזיה, אתה רואה את הבקרוב של הסרט."},{"start":752.34,"end":753.3,"text":"כן."},{"start":753.3,"end":755.3,"text":"מראים לך תפעורה ושחקנים"},{"start":755.3,"end":757.3,"text":"אתה רואה את שרון סטון."},{"start":757.3,"end":759.71,"text":"מה זה חייך תליה, אה?"},{"start":759.71,"end":760.71,"text":"עם איבגי."},{"start":760.71,"end":761.71,"text":"איבגי."},{"start":761.71,"end":762.71,"text":"לא מגולח ככה, בשר כתוב."},{"start":762.71,"end":763.71,"text":"גבר."},{"start":763.71,"end":764.71,"text":"וואלה, אתה רואה אותם בקרוב, אה?"},{"start":764.71,"end":765.71,"text":"כן."},{"start":765.71,"end":766.71,"text":"משכנע אותך?"},{"start":766.71,"end":767.71,"text":"משכנע."},{"start":767.71,"end":768.71,"text":"משתכנע."},{"start":768.71,"end":769.71,"text":"משתכנע."},{"start":769.71,"end":770.63,"text":"הולך, לקחת אשתך לסרט?"},{"start":770.63,"end":771.74,"text":"הולך."},{"start":771.74,"end":772.74,"text":"קונה כרטיס?"},{"start":772.74,"end":773.74,"text":"משקיע."},{"start":773.74,"end":773.84,"text":"מתיישב?"},{"start":773.74,"end":774.74,"text":"יושב."},{"start":774.74,"end":775.74,"text":"משקעת בפופקורן?"},{"start":775.74,"end":776.74,"text":"פופקורן."},{"start":776.74,"end":777.74,"text":"וואלה, ישבת לראות את הסרט, אה?"},{"start":777.74,"end":778.9,"text":"כן."},{"start":778.9,"end":782.03,"text":"אתה מתחיל להסתכל בסרט, אתה מצפה לראות את שרון סטון,"},{"start":782.03,"end":784.03,"text":"אשתך מצפה לראות את איבגי, אה?"},{"start":784.03,"end":785.13,"text":"כן."},{"start":785.13,"end":786.72,"text":"יושב."},{"start":786.72,"end":788.61,"text":"מה אתה רואה?"},{"start":788.61,"end":789.61,"text":"מה?"},{"start":789.61,"end":792.08,"text":"שרון סטון, שרון סטון."},{"start":792.08,"end":794.33,"text":"איבגי זה איבגי."},{"start":794.33,"end":797.58,"text":"שום דבר, שום מפגש, שום פיצוץ, יבש."},{"start":797.58,"end":798.76,"text":"אז?"},{"start":798.76,"end":800.72,"text":"נו אז זה כמו בחיים."},{"start":800.72,"end":802.72,"text":"אתה בחיים, אתה רצית לקבל את שרון סטון,"},{"start":802.72,"end":803.72,"text":"אשתך רוצה לקבל את איבגי."},{"start":803.72,"end":804.72,"text":"מה קיבלנו?"},{"start":804.72,"end":805.72,"text":"כלום."},{"start":805.72,"end":806.72,"text":"כמו בחיים, אתה מחכה."},{"start":806.72,"end":808.72,"text":"יהיה משהו בחיים יהיה."},{"start":808.72,"end":809.91,"text":"בסוף הכל בשמם."},{"start":809.91,"end":810.93,"text":"כמו בקרוב."},{"start":810.93,"end":813.25,"text":"מה קרה להימשך, מה זה?"},{"start":813.25,"end":814.21,"text":"נו קרה לה כלום."},{"start":814.21,"end":816.61,"text":"למה?"},{"start":816.61,"end":818.61,"text":"רגע, רגע, פתאום עברה לי מחשבה בראש."},{"start":818.61,"end":819.61,"text":"נו."},{"start":819.61,"end":822.08,"text":"בונה, החיים זה לא כמו בקרוב של סרט."},{"start":822.08,"end":826.27,"text":"החיים זה בדיוק כמו אופרה צבון."},{"start":826.27,"end":829.64,"text":"תגיד לי, אתה מדבר איתי במישור הפילוסופי?"},{"start":829.64,"end":834.41,"text":"אופרה צבון, אנטונלה, טופה, סלסטה."},{"start":834.41,"end":837.4,"text":"אה, אז תגיד תלנובלות."},{"start":837.4,"end":838.4,"text":"תלנובלות."},{"start":838.4,"end":839.4,"text":"תלנובלות."},{"start":839.4,"end":840.4,"text":"אה, אם זה בדיוק כמו תלנובלות."},{"start":840.4,"end":841.4,"text":"שמה זה כמו בחיים."},{"start":841.4,"end":842.4,"text":"ואללה, צודק."},{"start":842.4,"end":843.88,"text":"תגיד, אחי."},{"start":843.88,"end":845.13,"text":"כן."},{"start":845.13,"end":846.13,"text":"בא לך שיפוד."},{"start":846.13,"end":847.19,"text":"אופה, זה מחשבה."},{"start":847.19,"end":848.19,"text":"זה המחשבה."},{"start":848.19,"end":849.19,"text":"זה המחשבה."},{"start":849.19,"end":852.29,"text":"זה המחשבה."},{"start":852.29,"end":853.29,"text":"זה המחשבה."},{"start":853.29,"end":854.29,"text":"זה המחשבה."},{"start":854.29,"end":856.56,"text":"זה המחשבה."},{"start":856.56,"end":857.62,"text":"שלום תלמידים."},{"start":857.62,"end":858.62,"text":"שלום."},{"start":858.62,"end":862.58,"text":"ובכן, תימו לב, לאחר שבסיעור שעבר למדנו כיצד נכתוב שיר של שלמה ארצי."},{"start":862.58,"end":867.64,"text":"השיעור נעסוק בכתיבת שיר של להכת אתניקס."},{"start":867.64,"end":874.32,"text":"זאב, אני מבקשת אותך להירגע פן יבולה לך."},{"start":874.32,"end":879.08,"text":"עכשיו תלמידים, על מנת לכתוב שיר של להכת אתניקס,"},{"start":879.08,"end":885.09,"text":"אנו זקוקים למילים שמזכירות לנו אדמה, אפר, פלחה, רגבים."},{"start":885.09,"end":887.09,"text":"מי יכול לתת לי דוגמה?"},{"start":887.09,"end":888.22,"text":"בבקשה רובי."},{"start":888.22,"end":889.22,"text":"חיטה."},{"start":889.22,"end":891.22,"text":"יפה, חיטה זה לא רק כן בבקשה אסף."},{"start":891.22,"end":893.22,"text":"ערבות צייה."},{"start":893.22,"end":896.28,"text":"חבורה של פוסטקים ופריים תיזהרו ממני."},{"start":896.28,"end":898.24,"text":"אני מבקשת לשמור לדבר אחד אחד."},{"start":898.24,"end":900.62,"text":"כן, מי יכול לתת לי עוד דוגמה?"},{"start":900.62,"end":902.81,"text":"בבקשה גיל."},{"start":902.81,"end":905.81,"text":"המורה, שיבולת זהובה וכמלה יחד עם זאת."},{"start":905.81,"end":908.78,"text":"יפה, יחד עם זאת היא עלולה לכמול."},{"start":908.78,"end":909.78,"text":"יפה לי."},{"start":909.78,"end":911.78,"text":"כן, גל, ניתן לך גם לך הזדמנות, כן?"},{"start":911.78,"end":912.73,"text":"אולי..."},{"start":912.73,"end":915.75,"text":"טוטים, טוטים, בואי נקנה לך טוטים?"},{"start":915.75,"end":916.75,"text":"עלה."},{"start":916.75,"end":919.34,"text":"לי תקנה טוטים?"},{"start":919.34,"end":920.34,"text":"חתיכת דביל."},{"start":920.34,"end":922.3,"text":"אנו לא משחקים בך, צומח דומם."},{"start":922.3,"end":924.3,"text":"אנו עוסקים בשירה!"},{"start":924.3,"end":926.3,"text":"מדובר בשיר של אתניס,"},{"start":926.3,"end":927.3,"text":"ביטוי מן האדמה, מן האפרל..."},{"start":927.3,"end":929.3,"text":"טוטים, טוט..."},{"start":929.3,"end":930.32,"text":"בבקשה, רובי."},{"start":930.32,"end":931.32,"text":"חשבנו..."},{"start":931.32,"end":932.32,"text":"ביחד."},{"start":932.32,"end":934.32,"text":"שאם אפשר לקחת מילים מהתנ\"ך,"},{"start":934.32,"end":936.32,"text":"שלא קשורות אחת לשנייה,"},{"start":936.32,"end":938.48,"text":"לחבר אותם ביחד"},{"start":938.48,"end":940.48,"text":"וליצור ביחד איזה שיר חדש."},{"start":940.48,"end":941.48,"text":"משהו שולה לגמרי."},{"start":941.48,"end":942.7,"text":"מקסי, תה לי דוגמה."},{"start":942.7,"end":943.7,"text":"בוא תנסו לחשוב לדוגמה."},{"start":943.7,"end":946.7,"text":"בני מואב הלכו במדבר,"},{"start":946.7,"end":949.79,"text":"חזור נרסיני חלף לו גם עבר."},{"start":949.79,"end":950.79,"text":"קיטצה אמורה!"},{"start":950.79,"end":952.79,"text":"המאדרים קיטצה אפשר להוסיף."},{"start":952.79,"end":953.85,"text":"מקסי..."},{"start":953.85,"end":955.85,"text":"אתם מעוררים בירדת פסוד, מקסי."},{"start":955.85,"end":957.85,"text":"אמורה, יש לי רעיון לשיר אדיר."},{"start":957.85,"end":958.85,"text":"כן, זאב?"},{"start":958.85,"end":959.85,"text":"ג'סי ג'סי."},{"start":959.85,"end":961.84,"text":"ג'סי ג'סיקה."},{"start":961.84,"end":963.81,"text":"וואלה, טוב."},{"start":963.81,"end":964.83,"text":"זאב, מה עובר עליך?"},{"start":964.83,"end":966.83,"text":"לא ישנת בליילה שלנו כמלחן."},{"start":966.83,"end":969.02,"text":"ג'סי ג'סי."},{"start":969.02,"end":971.08,"text":"ג'סי ג'סיקה."},{"start":971.08,"end":975.48,"text":"אני מבקשת להשיג את זה."},{"start":975.48,"end":978.09,"text":"מה זו הברבריות זו?"},{"start":978.09,"end":980.47,"text":"מדובר כאן בשיר של להקה."},{"start":980.47,"end":982.56,"text":"תצאו החוצה כולה, בבקשה."},{"start":982.56,"end":983.56,"text":"זאב, לא יצאי לך כלום."},{"start":983.56,"end":984.56,"text":"אתה גרותאה."},{"start":984.56,"end":985.56,"text":"אתה לא יודע לשיר."},{"start":985.56,"end":987.56,"text":"אתה לא יודע לכתוב מילים."},{"start":987.56,"end":988.56,"text":"תצא החוצה."},{"start":988.56,"end":989.56,"text":"מכיתה דלת כל הזמן."},{"start":989.56,"end":991.56,"text":"אני בא בזה כסוף שנה."},{"start":991.56,"end":992.56,"text":"הוא מנפח לי את הפופה."},{"start":992.56,"end":993.56,"text":"זה שירה?"},{"start":993.56,"end":994.56,"text":"תצאו החוצה בבקשה."},{"start":994.56,"end":997.97,"text":"חבורה של פושטלקים."},{"start":997.97,"end":999.35,"text":"להכות בארץ."},{"start":999.35,"end":1001.11,"text":"אין."},{"start":1001.11,"end":1003.11,"text":"אני אוהב את רוק אלטרנטיבי."},{"start":1003.11,"end":1012.37,"text":"ארם צחר אבזח."},{"start":1012.37,"end":1013.37,"text":"שוב אנחנו באלסטרה."},{"start":1013.37,"end":1015.37,"text":"והפאג ונוטב רבותיי."},{"start":1015.37,"end":1017.37,"text":"רציתי לדבר איתכם על להכות ישראליות."},{"start":1017.37,"end":1019.37,"text":"ואמא שלי המצוקה היא קשה."},{"start":1019.37,"end":1021.37,"text":"אנחנו הגענו לנקודת העל חזור."},{"start":1021.37,"end":1023.37,"text":"נקודת העל חזור זה אתה הולך להופעה."},{"start":1023.37,"end":1025.37,"text":"לא רוצה לחזור לשם בחיים אמא שלי."},{"start":1025.37,"end":1027.37,"text":"פעם הייתה תקופה יפה באמא שלי."},{"start":1027.37,"end":1029.37,"text":"הייתה תקופה נאיבטית."},{"start":1029.37,"end":1031.37,"text":"היו להקות עם אופטימיות ואמא שלי."},{"start":1031.37,"end":1033.37,"text":"היה להקת החלונות הגבוהים."},{"start":1033.37,"end":1036.37,"text":"השלושרים, אוזי פיקס והסגנוניות."},{"start":1036.37,"end":1038.37,"text":"ואמא שלי זה להקות עם אופטימיות."},{"start":1038.37,"end":1039.37,"text":"מה יש לנו היום?"},{"start":1039.37,"end":1041.37,"text":"יש לנו להקות מלא אלימות ואמא שלי."},{"start":1041.37,"end":1042.37,"text":"איזה פחד."},{"start":1042.37,"end":1044.37,"text":"נקמת הטרקטור."},{"start":1044.37,"end":1045.37,"text":"איזה פחד."},{"start":1045.37,"end":1046.37,"text":"המחשפות."},{"start":1046.37,"end":1047.37,"text":"מפלצות כולם."},{"start":1047.37,"end":1048.37,"text":"מה זה ההרת הזה?"},{"start":1048.37,"end":1051.37,"text":"יש לנו עכשיו להקת באמא שלי לא יומן כיסופר."},{"start":1051.37,"end":1052.37,"text":"אבטיפוס."},{"start":1052.37,"end":1053.37,"text":"אבא שלי."},{"start":1053.37,"end":1055.37,"text":"יש לה מחלה קשה."},{"start":1055.37,"end":1056.37,"text":"ויש להם גם שיר."},{"start":1056.37,"end":1057.37,"text":"האומור שלי זה לא משהו."},{"start":1059.37,"end":1061.37,"text":"יש גם להקה קוראים לה ריר."},{"start":1061.37,"end":1063.78,"text":"מה זה לא קראו לה להקת מוכתה."},{"start":1063.78,"end":1065.78,"text":"באמא שלי לא יודע מה זה החרט הזה."},{"start":1065.78,"end":1067.78,"text":"יש להקה קוראים לה קרמלה גרוז וגנר."},{"start":1067.78,"end":1069.78,"text":"עוד מעט תקראו להם ג'ודי לוץ."},{"start":1069.78,"end":1070.78,"text":"ארולוב קרפן קלאוויד."},{"start":1070.78,"end":1071.78,"text":"מה זה הביצוקה?"},{"start":1071.78,"end":1075.78,"text":"הלהקה הכי גדולה שציפיתי להופעה שלה בחיליון אוזניים."},{"start":1075.78,"end":1077.78,"text":"זה להקת מוניקה סקס."},{"start":1077.78,"end":1080.13,"text":"באם אמא שלי חשבתי את אבו מוניקה."},{"start":1080.13,"end":1083.25,"text":"תתאי לנו איזה הופעת סקס אחוז הקשוק פתאום."},{"start":1083.25,"end":1087.25,"text":"בואו לי חבורה של מכוערים עם גיטר, מה זה הביצוקה הזאת?"},{"start":1087.25,"end":1092.88,"text":"לכן, צוות הצילום של זוזו ונבלש סיפה עליו את להקת אתניקס."},{"start":1092.88,"end":1096.88,"text":"להקה גדולה, ידועה, עם כבוד החושק שוקי שהוציאה כבר 19 אלף תקניטים."},{"start":1096.88,"end":1099.88,"text":"עם שוויון אלף ועם מיליון אלף עותקים."},{"start":1099.88,"end":1102.88,"text":"ולכן החלטנו לשיר איתם את שיר הטרטה."},{"start":1102.88,"end":1107.91,"text":"ככה שיר צריך להיות מבוצע, גם במקצב, גם בביצוע וגם במראה החיצוני."},{"start":1107.91,"end":1113.72,"text":"שימו לב, שיר הטרטה, מופעה בחורה עולמי, שופופו."},{"start":1170.53,"end":1187.18,"text":"שעותי גם בפיפר, תורטעל קלודיה שיפר"},{"start":1187.18,"end":1187.77,"text":"עכשיו"},{"start":1187.77,"end":1287.1,"text":"יון אל אסראייל"},{"start":1287.1,"end":1290.05,"text":"שלים אל כוריס"},{"start":1290.05,"end":1290.15,"text":"יזנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנבא, זנ"},{"start":1290.05,"end":1322.11,"text":"תודה רבה"}]