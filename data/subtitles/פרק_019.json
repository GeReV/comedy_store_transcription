[{"start":29.76,"end":34.95,"text":"גבירותיי ורבותיי, ברוכים הבאים לכל המסתור!"},{"start":68.19,"end":72.19,"text":"מה זה אחת הזה? אני עובר על הדף של העיתונים של הבורסה, אני לא מבין מילה!"},{"start":72.19,"end":78.19,"text":"שובו, באמא שלי, דולר יציג, מדד המשתנים, פרנק שוויצרי, מה זה פרנק? או שהוא פרנק או שהוא שוויצרי!"},{"start":78.19,"end":84.19,"text":"לא יכול להיות ביחד, שובו! אני פותח אתם לא מאמינים! שימו לב, בכותרת! האופציות, הבולטות!"},{"start":84.19,"end":90.54,"text":"מה זה האופציות? באמא שלי יש שתי אופציות! אופציה אחת לקחת הכסף, אופציה שנייה לקבל את הקפה!"},{"start":90.54,"end":94.54,"text":"מה זה אחת הזה? זה לא יומן! שובו, אני קורא לכם רישימה של קרנות!"},{"start":94.54,"end":101.54,"text":"קרן רימון, קרן אילנות, קרן תמר, קרן דקל, קרן גפן, מה זה אחת הזה? מה אנחנו ביתו בצבן?"},{"start":101.54,"end":106.5,"text":"מה זה זה? עוד מעט באמא שלי, משרד האוצר יהיה עם שחח! מה זה אחת הזה? לא יומן!"},{"start":106.5,"end":115.0,"text":"ואתם ממשיכים? שובו! קרן פי! מה זה פי! דרבבי! מה זה אחת הזה פי? אמא, מה זה פי את הבעת?"},{"start":115.0,"end":120.0,"text":"מה זה אחת הוות הזה? לא מבין! לא מבין! מרוב קרנות, אני חשבתי שלוש קרנות פנדל!"},{"start":120.0,"end":125.0,"text":"מה זה אחת הזה רבותיי? תעזבו את כל הבורסה, תעזבו את כל החרטה, שימו לב איפה להשקיע!"},{"start":125.0,"end":131.06,"text":"מהיום ועל לגבירותיי ורבותיי, תשקיעו בבורסת התכשיטים, הנה, תחדוקי!"},{"start":131.06,"end":137.06,"text":"התכשיט נמצא עליך רבותיי, השרשר מונח עליך, והשטפות בידיך!"},{"start":137.06,"end":140.05,"text":"ותעשבו על זה!"},{"start":140.05,"end":143.67,"text":"ערב טוב! הרי די השיקי הזה עקה!"},{"start":143.67,"end":148.67,"text":"מכה חדשה פוקדת את אלפים! המצלמה המשוטטת של ג'ודי!"},{"start":148.67,"end":161.55,"text":"ג'ודי לא צהרונוב קרפינסטממה ויצטום סוכניק טוקר אלימלך רמנבר קלופטטר וילימוס קוללרמן פורט שובל רובי"},{"start":161.55,"end":165.55,"text":"מכה חדשה נוחתת על קהיליית משתמשי הטלפון בארץ"},{"start":165.55,"end":172.7,"text":"אלפי אנשים ויש שסוברים אף עשרות מוצאים עצמם מדי יום מחורים לאותו מכשיר פלאפון על חוטי"},{"start":172.7,"end":180.07,"text":"הפסיכולוגים הגדירו אותם חולי נפש, מסוכנים, אנשים אלוקים במחלת הפלאפומניה"},{"start":180.07,"end":185.19,"text":"ולפאמניה דחב חולני לדבר בכל מכשיר על חוטי"},{"start":185.19,"end":190.59,"text":"לקחנו את המצלמה המשוטטת ויצאנו לבדוק הקצע הקטע"},{"start":190.59,"end":194.23,"text":"כאן ראום האלדר, אזור חיוג 0-3"},{"start":201.09,"end":213.96,"text":"רגע, אלו אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו, אלו."},{"start":213.96,"end":221.52,"text":"יום ראשון, פוקר. אנחנו נמצאים באחת מתוך אלפי נקודות המפגש החביבות על המשתמשים."},{"start":221.52,"end":222.46,"text":"צלם אותי כך."},{"start":223.11,"end":234.06,"text":"אני לא שווה. אין בטריה. אלו. אני לא שווה. אל צלם אותי כך."},{"start":234.06,"end":240.57,"text":"כאן נפגשנו במוטי רולה. מוטי, איך הכל התחיל?"},{"start":240.57,"end":246.12,"text":"התחיל הכל בגיל שבע. התחלתי להתמכר בתור ילד לווקי-טוקי."},{"start":246.12,"end":249.53,"text":"אחר כך רגע יש לי ממתינה."},{"start":249.53,"end":252.7,"text":"אמא, זה את? אה לא, זה מטוס."},{"start":253.85,"end":263.17,"text":"ואז יותר מאוחר עברתי לביפר והתגייסתי, הייתי בחיל קשר."},{"start":263.17,"end":266.07,"text":"הייתי צמוד לממקוף שבעים ושבע כל היום."},{"start":266.07,"end":269.66,"text":"חתמתי שנתיים, לא יכולתי לעזוב את האנטנה."},{"start":269.66,"end":278.07,"text":"השתחררתי מהצמא וקניתי את הסולולוי, הפלאפון הסולולוי, בהתחלה גדול, אחר כך קטן."},{"start":278.07,"end":284.86,"text":"אני לא יכול, אני היום צולך 1,500 שקל על שיחה."},{"start":284.86,"end":289.34,"text":"את התמונות הבאות צילמנו בעזרת מצלמה נסתרת."},{"start":289.34,"end":294.92,"text":"שימו לב, הילד שבתמונה הוא אליית פן בטחפוסת."},{"start":294.92,"end":297.47,"text":"עולנה, בואו כך משהו טוב."},{"start":297.47,"end":300.03,"text":"אמא לא מרשה."},{"start":300.03,"end":303.88,"text":"מה לא מרשה? קח שיחה אחת, תראה איזה יופי, אתה מתקשר לחבר, עולן לך."},{"start":303.88,"end":304.95,"text":"כמה זה עולה?"},{"start":304.95,"end":308.45,"text":"שיחה ראשונה עליי, פעם ראשונה עליי, המתוק, חינם."},{"start":308.45,"end":309.41,"text":"לא רצה."},{"start":309.41,"end":311.87,"text":"נכנסה זה טוב."},{"start":311.87,"end":312.59,"text":"לא רצה."},{"start":312.59,"end":313.87,"text":"לא רצה."},{"start":313.87,"end":314.84,"text":"לא רצה."},{"start":314.84,"end":319.85,"text":"דיברנו עם אחת האימהות, שבנה נפל קורבן לטלפון ההלכותי."},{"start":319.85,"end":323.16,"text":"מסיבות מובנות, היבטנו את קולה."},{"start":323.16,"end":327.52,"text":"היבטנו את פרצופה, וגילחנו את צערושה."},{"start":327.52,"end":333.93,"text":"היה לנו ילד מלאף, ואז יום אחד הוא בא, הוא ביקש אסימות."},{"start":333.93,"end":339.31,"text":"נתנו לו, אחרי זה הוא ביקש כרטיס של טלקאר, אז אנחנו הבאנו לו."},{"start":339.31,"end":342.92,"text":"ואחרי זה, נו, כל המחלה הזאת היא גמרה אותנו."},{"start":342.92,"end":356.47,"text":"אותו ואת האבא שלו גמרה גם כן, הוא לקח מאיתנו הכל, הוא לקח מאיתנו את האוטו, את הטלוויזיה, לא נשאר לנו כלום, ואפילו ילד אין לנו עכשיו."},{"start":356.47,"end":359.43,"text":"וכך מתפשטת לה המחלה בחוצות העיר."},{"start":359.43,"end":360.39,"text":"אה, גדול."},{"start":360.39,"end":363.39,"text":"בויש! אלן! בויש!"},{"start":363.39,"end":364.66,"text":"כן, כן."},{"start":364.66,"end":367.73,"text":"טוב, אלן, צ'או. צ'או, ביי."},{"start":367.73,"end":372.57,"text":"כן, אלו."},{"start":372.57,"end":375.09,"text":"יראה, אפשר ללכת להופעה של הקולובי חביבי, אני פלאב."},{"start":375.09,"end":376.09,"text":"בויש! בויש!"},{"start":376.09,"end":380.03,"text":"בויש! מה אני עדים, אחי? בויש! בויש!"},{"start":380.03,"end":385.4,"text":"ואני... רגע, לא, אני מחכה..."},{"start":385.4,"end":387.45,"text":"*ערק*"},{"start":387.45,"end":388.09,"text":"אלו!"},{"start":388.09,"end":390.8,"text":"לא, אתה לא... אני מדבר עם מה!"},{"start":390.8,"end":392.62,"text":"תגיד לי, אתה לא מתעכל על הקביס!"},{"start":392.62,"end":393.62,"text":"אתה לא מרבע לי, אתה לא מרבע לי!"},{"start":393.62,"end":395.72,"text":"אני עובד את זה, אתה לא מרבע אותי!"},{"start":395.72,"end":397.26,"text":"תגיד, אתה לא מתעכל!"},{"start":397.26,"end":399.62,"text":"אני מתעכל! אני מתעכל! אני מתעכל! אני מתעכל!"},{"start":399.62,"end":405.94,"text":"בעקבות ההתמכרות, צאצו גם מוסדות כמילה כפטריות בין האצבעות של הרגליים."},{"start":405.94,"end":409.92,"text":"במוסד אחד כזה, אנחנו ביקרנו."},{"start":409.92,"end":416.35,"text":"אנחנו חזקים, אנחנו חזקים, אנחנו חזקים."},{"start":416.35,"end":418.35,"text":"אני עומד לעשות לזה, תהיו מוכנים."},{"start":418.35,"end":420.82,"text":"אנחנו לא כל כך חזקים."},{"start":420.82,"end":422.84,"text":"תרגע וגו."},{"start":422.84,"end":426.96,"text":"לא, אתם חזקים, אתם חזקים."},{"start":426.96,"end":428.86,"text":"אני אוהב, אמא!"},{"start":428.86,"end":430.99,"text":"אמא!"},{"start":430.99,"end":432.99,"text":"אמא!"},{"start":432.99,"end":435.53,"text":"כולם לתמוך בשמשון."},{"start":435.53,"end":437.52,"text":"לדת לו חיזותים חיוביים."},{"start":437.52,"end":439.53,"text":"כולם לתמוך בו, לתמוך."},{"start":439.53,"end":441.53,"text":"אנחנו אוהבים אותך שמשון."},{"start":441.53,"end":443.62,"text":"איך אתה עושה את זה? ספר לנו."},{"start":443.62,"end":445.68,"text":"האמת היא שגם אני הייתי מחור."},{"start":445.68,"end":447.68,"text":"מחור לעניין חזק, ולכן אני יודע איך לעזור להם."},{"start":447.68,"end":451.71,"text":"ובדיוק כפי שהמצאו את התחליף לסאם, את האדולן,"},{"start":451.71,"end":453.71,"text":"ככה אני המצאתי את התחליף לטלפון ההלכותי,"},{"start":453.71,"end":455.71,"text":"את האשלפון, המצאה שלי."},{"start":455.71,"end":458.38,"text":"הלו?"},{"start":458.38,"end":460.82,"text":"הלו, ציון?"},{"start":460.82,"end":463.65,"text":"הלו?"},{"start":463.65,"end":465.78,"text":"הלו, אני שומר אותך מצוין!"},{"start":465.78,"end":467.87,"text":"ציון, מה העניינים?"},{"start":467.87,"end":470.12,"text":"בסדר, מה העניינים איתך עמוס?"},{"start":470.12,"end":472.12,"text":"בסדר, שומעים טוב, נכון?"},{"start":472.12,"end":474.12,"text":"מצוין, אני שומע מצוין!"},{"start":474.12,"end":476.14,"text":"רק רגע יש לי שיחה ממתינה!"},{"start":476.14,"end":478.11,"text":"מאה אחוז, אני שם אותך בינתיים הלוכזנית!"},{"start":478.11,"end":485.66,"text":"האש אלפון אומנם פתר חלק מהבעיה"},{"start":485.66,"end":487.78,"text":"אולם ברמיד אך גיסה"},{"start":487.78,"end":491.68,"text":"אז נוצרה הבעיה הלכתית"},{"start":491.68,"end":494.06,"text":"שלום לכם עיתונאים ציבור יקר"},{"start":494.06,"end":496.06,"text":"זה אתה יצאתי מחדרו שלה, רב יצא משליטאי"},{"start":496.06,"end":496.16,"text":"שאתה בחשמו?"},{"start":496.06,"end":498.16,"text":"וההחלטה היא פה אחד"},{"start":498.16,"end":500.16,"text":"רבותיי שימו לב, אין לאכול בשר"},{"start":500.16,"end":502.16,"text":"אם הם משתמשים באש אלפון"},{"start":502.16,"end":504.16,"text":"או שיעברו לפחות ששעות"},{"start":504.16,"end":506.16,"text":"על כך אין ויכוח"},{"start":506.16,"end":508.16,"text":"אוכלט כך על ידי ערב"},{"start":508.16,"end":510.16,"text":"והכוונה היא לכל עם ישראל"},{"start":510.16,"end":512.16,"text":"וכל החיילים וכל המחבש"},{"start":512.16,"end":514.16,"text":"וכל הצלם והמקליט והאוזם"},{"start":514.16,"end":516.16,"text":"ויש תהבה שם עובדים תקני צעד"},{"start":516.16,"end":518.16,"text":"חי שקלים"},{"start":518.16,"end":520.16,"text":"חי שקלים"},{"start":520.16,"end":522.16,"text":"חי שקלים תרשום אצלך"},{"start":522.16,"end":524.16,"text":"ולכן רבותיי"},{"start":524.16,"end":526.16,"text":"אם הממשלה לא תוותל"},{"start":526.16,"end":528.15,"text":"ממחר את חוק"},{"start":528.15,"end":530.15,"text":"האש אלפון הנוראי"},{"start":530.15,"end":532.15,"text":"שקלים לחילול נוראי בציבור"},{"start":532.15,"end":534.15,"text":"אנחנו נעזוב את הקואליציה לאלטר"},{"start":534.15,"end":536.76,"text":"תודה רבה לכם"},{"start":536.76,"end":538.76,"text":"אם כן הממשלה שוב בסכנה"},{"start":538.76,"end":540.98,"text":"ועם תמונת מצב קשה זו"},{"start":540.98,"end":542.98,"text":"כדאי מאוד שניפרד"},{"start":542.98,"end":545.3,"text":"כאן ג'ודי ללצהרונוב"},{"start":545.3,"end":547.3,"text":"קרפינסם אמה ויצטום"},{"start":547.3,"end":549.3,"text":"נוקיה בי פריטורית מוטורול"},{"start":549.3,"end":551.65,"text":"יורוקום"},{"start":551.65,"end":603.68,"text":"יואב ווקי-טוקר פריז"},{"start":603.68,"end":618.38,"text":"קובוי דוס דוס"},{"start":618.38,"end":620.56,"text":"אך הנה נומעז"},{"start":620.56,"end":622.53,"text":"עז עז עז"},{"start":622.53,"end":630.94,"text":"תחרות הרודאו"},{"start":630.94,"end":632.94,"text":"מה מנסה הקאובוי לתפוס ולקשור?"},{"start":632.94,"end":637.41,"text":"שור שור שור"},{"start":637.41,"end":645.32,"text":"יש לי יש לי יש לי יש לי"},{"start":645.32,"end":647.72,"text":"ובדוק חב"},{"start":647.72,"end":649.72,"text":"איך הקאובוי יורה"},{"start":649.72,"end":652.32,"text":"בום בום בום"},{"start":652.32,"end":655.06,"text":"בום"},{"start":655.06,"end":657.07,"text":"יש גם מנגיאנים"},{"start":665.04,"end":668.63,"text":"ערב צח ערב זך"},{"start":668.63,"end":670.69,"text":"ושוב אנחנו בחלסטרה של זוזו"},{"start":670.69,"end":672.61,"text":"והפעם חזרנו לפרסומות"},{"start":672.61,"end":674.91,"text":"רציתי להזכיר לכם קהל לכבד"},{"start":674.91,"end":676.91,"text":"על פרסומת לפלפית שמביאה לי את החלסטרה בהפוכה"},{"start":676.91,"end":679.0,"text":"רואים איזה גבר לפלפ כזה"},{"start":679.0,"end":681.0,"text":"הוא מחזיק בידיים שלו שנפון"},{"start":681.0,"end":685.51,"text":"ומהסנפה של השנפון שהוא מריח אותה"},{"start":685.51,"end":687.54,"text":"הוא נזכר בחברה שלו"},{"start":687.54,"end":689.54,"text":"שהם היו מאוהבים"},{"start":689.54,"end":691.79,"text":"מה זה אחרת הזה?"},{"start":691.79,"end":693.79,"text":"אני באיממה שלי"},{"start":693.79,"end":695.79,"text":"אני בשביל זה זה אני יכול לעשות את הפרסומת הזאת הרבה יותר טוב"},{"start":695.79,"end":698.78,"text":"הנה, מספיק שאני לוקח זוג ארבעים של חברה שלי"},{"start":698.78,"end":700.67,"text":"ובא לי הסנפה"},{"start":700.67,"end":702.92,"text":"שימו לב, זוזו והסנפה"},{"start":702.92,"end":745.63,"text":"נהנתם?"},{"start":745.63,"end":748.71,"text":"ובכן, זהו תוצר של משרד הפרסום החדש"},{"start":748.71,"end":751.81,"text":"חלאסטרה, הבוקסיס ובנב על העש"},{"start":751.81,"end":753.79,"text":"ותחשבו על זה"},{"start":753.79,"end":764.51,"text":"טוב, יצאנו אל השטח לשאול את האזרח הקטן מה דעתו"},{"start":764.51,"end":766.02,"text":"סליחה אדוני"},{"start":766.02,"end":767.02,"text":"כן"},{"start":767.02,"end":768.02,"text":"אפשר לשאול אותך מה דעתך?"},{"start":768.02,"end":769.09,"text":"כן"},{"start":769.09,"end":772.4,"text":"אתה מודע למצב הסורר בארץ"},{"start":772.4,"end":773.81,"text":"כן"},{"start":773.81,"end":774.81,"text":"ואתה מחזיק עםך דעה"},{"start":774.81,"end":776.38,"text":"כן"},{"start":776.38,"end":781.49,"text":"אולי תוכל להגיד לי ולעם ישראל מה דעתך?"},{"start":781.49,"end":784.34,"text":"כן"},{"start":784.34,"end":787.34,"text":"אתה יודע לענות עוד דברים חוץ מכן?"},{"start":787.34,"end":788.85,"text":"כן"},{"start":788.85,"end":789.85,"text":"תגיד לי אתה בסדר?"},{"start":789.85,"end":790.85,"text":"כן"},{"start":790.85,"end":791.85,"text":"יכול להגיד לי למה אתה עושה לי את זה?"},{"start":791.85,"end":792.95,"text":"כן"},{"start":792.95,"end":793.95,"text":"אני בעצם לא צריך את זה"},{"start":793.95,"end":794.95,"text":"אתה יודע את זה?"},{"start":794.95,"end":795.87,"text":"כן"},{"start":795.87,"end":797.94,"text":"סליחה אדוני"},{"start":797.94,"end":798.94,"text":"כן"},{"start":798.94,"end":800.04,"text":"אפשר לשאול אותך כמה שאלות?"},{"start":800.04,"end":801.13,"text":"כן"},{"start":801.13,"end":802.13,"text":"אני שאלתי אותו אתה מודע לעניין?"},{"start":802.13,"end":803.13,"text":"כן"},{"start":803.13,"end":804.03,"text":"ובכל זאת אתה עונה לי?"},{"start":804.03,"end":805.83,"text":"כן"},{"start":805.83,"end":805.93,"text":"גם אתה עונה לי?"},{"start":805.83,"end":806.95,"text":"כן"},{"start":806.95,"end":807.95,"text":"אתם משוגעים שלכם?"},{"start":807.95,"end":809.11,"text":"כן"},{"start":809.11,"end":810.11,"text":"סליחה אדוני"},{"start":810.11,"end":811.11,"text":"כן"},{"start":811.11,"end":812.11,"text":"אפשר לשאול אותך כמה שאלות?"},{"start":812.11,"end":814.0,"text":"כן"},{"start":814.0,"end":815.0,"text":"החלטתם לשגע אותי שלו שלכם?"},{"start":815.0,"end":816.73,"text":"כן"},{"start":816.73,"end":819.73,"text":"מה קורה לכם? תגידו כל השאלה שאני אשאל אותכם אתם טענו בכן?"},{"start":819.73,"end":820.98,"text":"כן"},{"start":820.98,"end":821.98,"text":"אתם שונאים אותי או משהו כזה?"},{"start":821.98,"end":822.98,"text":"כן"},{"start":822.98,"end":823.98,"text":"אתם שונאים את התוכנית שלי?"},{"start":823.98,"end":824.98,"text":"כן"},{"start":824.98,"end":825.98,"text":"אתם חושבים שאני מנחה גרוע?"},{"start":825.98,"end":826.98,"text":"כן"},{"start":826.98,"end":827.98,"text":"אתם חושבים שאתם יותר חכמים ממני?"},{"start":827.98,"end":828.98,"text":"כן"},{"start":828.98,"end":829.98,"text":"ויש לכם דעה יותר טובה משלי?"},{"start":829.98,"end":830.98,"text":"כן"},{"start":830.98,"end":833.98,"text":"כן, אז תגידו לי מה דעתכם בקשר למצב בארץ"},{"start":833.98,"end":835.36,"text":"תראה"},{"start":835.36,"end":836.49,"text":"אני חושב"},{"start":836.49,"end":838.49,"text":"לפי דעתי האישית בלבד"},{"start":838.49,"end":842.65,"text":"שהמצב בארץ הוא לא מהמשובחים"},{"start":842.65,"end":845.0,"text":"ויפה שעה אחת קודם"},{"start":845.0,"end":847.56,"text":"אתם בטוחים?"},{"start":847.56,"end":851.0,"text":"כן!"},{"start":851.0,"end":856.7,"text":"אוקיי"},{"start":856.7,"end":858.7,"text":"קק קטן שכח לסגור הדלת"},{"start":858.7,"end":862.7,"text":"הצטנן המשכן וקיבל נזלת"},{"start":862.7,"end":864.85,"text":"שלום"},{"start":864.85,"end":867.85,"text":"גם היום הייתה לי יום הולדת וגם היום הייתי חולה"},{"start":867.85,"end":872.73,"text":"ונשארתי לבד בבית ועכשיו אני הולך לפאב"},{"start":872.73,"end":875.76,"text":"כאל לצפוק בירות להקפיט תקילות"},{"start":875.76,"end":878.76,"text":"אני מה אני חנון אני חופשי שוטה"},{"start":878.76,"end":881.76,"text":"מה אני חננה סטוק כדור הארץ"},{"start":881.76,"end":883.94,"text":"לא לא לא לא לא לא לאן זה?"},{"start":883.94,"end":886.01,"text":"אני הולך לפעם לצפוק בירות"},{"start":886.01,"end":887.45,"text":"למה בין כמה אתה?"},{"start":887.45,"end":889.66,"text":"בין ארבעים ושתיים"},{"start":889.66,"end":891.74,"text":"בנס"},{"start":891.74,"end":906.62,"text":"מה אתה מצלם?"},{"start":906.62,"end":909.0,"text":"מה אתה מצלם? אתה רוצה פוסטר?"},{"start":909.0,"end":913.0,"text":"סע סע מפויבן זולל הבטיחים זורחת השם"},{"start":913.0,"end":917.0,"text":"זו נה נה נה נה נה שתבלה מתריע ותפתח לך אמן בפנים"},{"start":917.0,"end":920.47,"text":"נלצר תבי תבי בירה תבי"},{"start":920.47,"end":925.77,"text":"תאר אסור למכור משקעות מתחת דגל 18"},{"start":925.77,"end":926.86,"text":"למה בין כמה אתה?"},{"start":926.86,"end":930.37,"text":"בין ושש למה?"},{"start":930.37,"end":932.48,"text":"אז מותר לך תבי תבי"},{"start":932.48,"end":934.85,"text":"אבל לא חושבתי על זה ככה"},{"start":934.85,"end":944.16,"text":"אישה כהה!"},{"start":944.16,"end":955.61,"text":"אוקיי."},{"start":955.61,"end":958.29,"text":"האם כדאי להתפיין?"},{"start":958.29,"end":961.48,"text":"יאס! יאס! יאס! יאס!"},{"start":961.48,"end":966.99,"text":"אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה!"},{"start":966.99,"end":970.05,"text":"יש לי! יש לי! יש לי! אבל טענו לי בספרנית!"},{"start":970.05,"end":973.18,"text":"נו! האם גודל הוא דבר יחסי?"},{"start":973.18,"end":977.3,"text":"שי, שי, שי, שי, שי!"},{"start":977.3,"end":981.8,"text":"יש לי, יש לי, יש לי, יש לי!"},{"start":981.8,"end":984.25,"text":"אבל הפעם טענו לי ברוסית."},{"start":984.25,"end":987.72,"text":"האם אשתי חמודה?"},{"start":987.72,"end":992.19,"text":"דה, דה, דה, דה, דה!"},{"start":992.19,"end":996.37,"text":"יש לי, יש לי, יש לי, יש לי, יש לי."},{"start":996.37,"end":998.37,"text":"טענו לי בעברי."},{"start":998.37,"end":1001.47,"text":"האם כדאי להסתכן?"},{"start":1001.47,"end":1005.25,"text":"לא כדאי, לא כדאי, לא כדאי!"},{"start":1005.49,"end":1009.76,"text":"לא, בשביל מה, להסתכן, לא כדאי בכלל."},{"start":1009.76,"end":1023.71,"text":"לבין נראה?"},{"start":1023.71,"end":1025.6,"text":"צבי כאדם!"},{"start":1025.6,"end":1032.8,"text":"כאדם, לא, כומדי סתום!"},{"start":1032.8,"end":1034.17,"text":"הלא!"},{"start":1034.17,"end":1038.14,"text":"הלא, הלא."},{"start":1038.14,"end":1044.24,"text":"הלא, הלא, הלא, הלא, הלא, הלא, הלא, הלא, הלא, הלא, הלא, הלא!"},{"start":1044.24,"end":1046.93,"text":"אלי, אלי, בוא תראה מבוא!"},{"start":1046.93,"end":1052.45,"text":"לא, לא, חלשתה, הלא, חלא לך."},{"start":1052.45,"end":1055.3,"text":"אחי אתה! אחי! אחי! אחי!"},{"start":1055.3,"end":1056.56,"text":"לא היו מאמינים בשכונה!"},{"start":1056.56,"end":1057.56,"text":"לא! לא! תעשה!"},{"start":1057.56,"end":1057.66,"text":"אהההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":1057.56,"end":1088.3,"text":"אהההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":1088.3,"end":1093.52,"text":"ויחד כולם את רשות הבידור עם דודו תופלס."},{"start":1093.52,"end":1095.11,"text":"סחר, עכשיו תעשה..."},{"start":1095.11,"end":1096.49,"text":"לא, לא, ותחשבו על זה!"},{"start":1096.49,"end":1096.99,"text":"עכשיו!"},{"start":1096.99,"end":1097.92,"text":"יותר טוב, יותר טוב."},{"start":1097.92,"end":1099.91,"text":"ותחשבו על זה!"},{"start":1099.91,"end":1101.99,"text":"סחר!"},{"start":1101.99,"end":1104.59,"text":"גדול אתה, גדול, גדול, אחי אתה..."},{"start":1104.59,"end":1106.81,"text":"מה נשאר לעשות?"},{"start":1106.81,"end":1107.57,"text":"מה נשאר לעשות?"},{"start":1107.57,"end":1108.93,"text":"תראה, מה שנשאר לנו רק זה..."},{"start":1108.93,"end":1113.75,"text":"יודי טראביץ, על עץ תמר ושלמה ארצי מאחורי גדר בטון."},{"start":1113.75,"end":1114.65,"text":"סחר!"},{"start":1114.65,"end":1116.65,"text":"האופוע שלנו, יאללה, בוא!"},{"start":1116.65,"end":1118.27,"text":"יאללה, סחר, תודה."},{"start":1118.27,"end":1124.37,"text":"ואני תפוס את דודו, אני אחתוך אותו, נשבע לכם."},{"start":1124.37,"end":1125.55,"text":"מה זה אחר אותה?"},{"start":1125.55,"end":1131.06,"text":"איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה."},{"start":1131.06,"end":1135.33,"text":"טוב, חבר'ה, מה העניינים? שוב כאן אני אלפרד והצפצפת שלי איז'ו."},{"start":1135.33,"end":1138.27,"text":"איזה גנבה, הנה על דין כי יפו שרמו אותי."},{"start":1138.27,"end":1141.27,"text":"ערב טוב באמת לא צריך חבר'ה, רלקס, קאן-דאון, קאן-דאון."},{"start":1141.27,"end":1143.27,"text":"שוב כאן אלפרד, אומן הבדיחות הגרועות, הציסבטים הידועים."},{"start":1143.27,"end":1147.27,"text":"הבדיחות שנס לחם, הבדיחות שלא נס לחם, חידות מוכרות, הרבה כיתה, שוארמה ושסק."},{"start":1147.27,"end":1149.27,"text":"איזה גנבה, שקט!"},{"start":1149.27,"end":1151.27,"text":"אני גם עושה בר מצוות, חתונות, חלטורות ובת ינה."},{"start":1151.27,"end":1152.27,"text":"שקט! לא לזרוק פוספטים."},{"start":1152.27,"end":1154.27,"text":"אוקיי חבר'ה, ריכוז קל ומתחילים."},{"start":1154.27,"end":1155.27,"text":"נתחיל בחידה."},{"start":1155.27,"end":1158.27,"text":"מה זה ירוק, קטן, מסתובה וצועק."},{"start":1158.27,"end":1161.27,"text":"אני צפרדיה בבלנדר, אני צפרדיה בבלנדר."},{"start":1161.27,"end":1162.27,"text":"זה צפרדיה בבלנדר."},{"start":1162.27,"end":1164.27,"text":"איזה גנבה, אינה דינקית."},{"start":1164.27,"end":1168.65,"text":"אוקיי, נעבור לאן משהו אחר. שימו לב, קטעים מסרטים."},{"start":1168.65,"end":1171.65,"text":"קטע ראשון מתוך הסרט כשהרי פגש את סלי."},{"start":1171.65,"end":1174.78,"text":"הרי, סלי, איזה גנבה? אינה דינקית."},{"start":1174.78,"end":1179.44,"text":"קוס אוכטי, איזה גנבה הייתי? שימו לב, עוברים לקטע אחר."},{"start":1179.44,"end":1181.44,"text":"קטע מהסרט שובו של מרטין גר."},{"start":1181.44,"end":1184.85,"text":"מרטין, חזרת, איזה גנבה?"},{"start":1184.85,"end":1188.45,"text":"שוסטערי, תאמינו לי, קטע מהסרט ספיד."},{"start":1188.45,"end":1190.89,"text":"איזה גנבה?"},{"start":1190.89,"end":1193.46,"text":"קטע מהסרט ספר נשים."},{"start":1193.46,"end":1194.46,"text":"אחת, שתיים, שלוש, ארבע."},{"start":1194.46,"end":1196.55,"text":"ארבע, ארבע נשים ספרנו את כולם."},{"start":1196.55,"end":1198.61,"text":"איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה, איזה גנבה."},{"start":1198.61,"end":1199.61,"text":"סיימטי, אחו שרמותי, אני לא מאמין."},{"start":1199.61,"end":1202.78,"text":"לא הוציא את הבתייני החוצה, מי הכניס שסק לאולפן."},{"start":1202.78,"end":1205.22,"text":"קבר'ה, שימו לב, כי פה תרצי לסיום, שימו לב."},{"start":1205.22,"end":1210.71,"text":"לאיש עושה טפטפת ולאלפרד פניטה, קיבלת הסטק וניילון."},{"start":1210.71,"end":1212.71,"text":"איזה גנבה, איזה גנבה, איזה גנבה."},{"start":1212.71,"end":1214.77,"text":"קבר'ה, לא לגדל אבוקדו, שאני מדבר."},{"start":1214.77,"end":1223.65,"text":"זה לא יומן, אני אומר לזה אסון."},{"start":1223.65,"end":1225.65,"text":"בבקשה, הגיע הקפה."},{"start":1225.65,"end":1229.02,"text":"סוכר זית, שלא סוכר וכלום."},{"start":1229.02,"end":1230.02,"text":"בלי כלום."},{"start":1230.02,"end":1231.02,"text":"זכרתי."},{"start":1231.02,"end":1233.97,"text":"תדמת, זה מה אתה?"},{"start":1233.97,"end":1234.97,"text":"סוכר, שנייה אחת."},{"start":1234.97,"end":1240.03,"text":"רגע."},{"start":1240.03,"end":1244.64,"text":"אוקיי."},{"start":1244.64,"end":1245.64,"text":"בבקשה."},{"start":1245.64,"end":1246.64,"text":"סוכר זית."},{"start":1246.64,"end":1247.6,"text":"אופה."},{"start":1247.6,"end":1248.86,"text":"סוכר."},{"start":1248.86,"end":1249.86,"text":"סוכר, זה בלי."},{"start":1249.86,"end":1250.86,"text":"כן, זה זה."},{"start":1250.86,"end":1252.4,"text":"בבקשה."},{"start":1252.4,"end":1253.4,"text":"תודה רבה."},{"start":1253.4,"end":1254.4,"text":"תודה לך."},{"start":1254.4,"end":1255.4,"text":"זה יהיה בריא אדוני."},{"start":1255.4,"end":1257.85,"text":"לא מסוגל לשתות סוכר אני."},{"start":1257.85,"end":1260.13,"text":"בקרה."},{"start":1260.13,"end":1261.13,"text":"זה בלי כלום."},{"start":1261.13,"end":1263.41,"text":"בזל, אני לא יכול לסבול את זה."},{"start":1263.41,"end":1268.78,"text":"אני מצטער."},{"start":1268.78,"end":1269.87,"text":"זה עם הסוכר זית."},{"start":1269.87,"end":1272.31,"text":"אה?"},{"start":1272.31,"end":1277.32,"text":"זה."},{"start":1277.32,"end":1278.28,"text":"יופי."},{"start":1278.28,"end":1279.28,"text":"תסלח לי אדוני."},{"start":1279.28,"end":1280.24,"text":"מה דעתך על הקפה שלנו?"},{"start":1280.24,"end":1281.24,"text":"מצוין."},{"start":1281.24,"end":1284.78,"text":"נו, איזה קפה תעדיף."},{"start":1284.78,"end":1289.0,"text":"קפה של פעם או קפה של טעם?"},{"start":1289.0,"end":1291.09,"text":"קפה ג'יפה."},{"start":1291.09,"end":1293.67,"text":"נדמה לך שכבר טעמת אותו."},{"start":1293.67,"end":1295.4,"text":"וואו."},{"start":1295.4,"end":1301.66,"text":"היי, נו."},{"start":1301.66,"end":1306.31,"text":"איזה היה כל כך גדולה שאי אפשר להפיל?"},{"start":1306.31,"end":1309.98,"text":"מי? מי? מי? מי?"},{"start":1309.98,"end":1313.6,"text":"יש לי, יש לי, יש לי, יש לי."},{"start":1313.6,"end":1317.73,"text":"מי כל הלילה אילל ולישון לא נתן?"},{"start":1317.73,"end":1321.45,"text":"תן, תן, תן."},{"start":1321.45,"end":1326.04,"text":"יש לי גם, יש לי גם, יש לי, יש לי, יש לי, יש לי."},{"start":1326.04,"end":1329.66,"text":"נו, איזה חיה מתנדמדת על המשקוף?"},{"start":1329.66,"end":1334.36,"text":"קוף, קוף, קוף, קוף."},{"start":1334.36,"end":1338.11,"text":"יש לי, יש לי, יש לי, יש לי, יש לי."},{"start":1338.11,"end":1341.95,"text":"איזה חיה הכי גדולה ומפחידה."},{"start":1341.95,"end":1346.31,"text":"דינוזאור, דינוזאור, דינוזאור."},{"start":1346.31,"end":1350.53,"text":"יו, יו, דינוזאור, פרקה יורה."},{"start":1350.53,"end":1351.81,"text":"יש לי שאת מפחיד."},{"start":1351.81,"end":1354.07,"text":"נו, נו."},{"start":1354.07,"end":1366.84,"text":"ערב זך, ערב זך, ושוב אנחנו ממשיכים בפרסומות"},{"start":1366.84,"end":1368.48,"text":"על שמפונים וסבונים."},{"start":1368.48,"end":1370.5,"text":"באמא שלי יש תופעה."},{"start":1370.5,"end":1372.9,"text":"גם בפרסומת של בלנננדה ידרה,"},{"start":1372.9,"end":1375.18,"text":"וגם בפלמולי, וכולם מתפשטות."},{"start":1375.18,"end":1377.58,"text":"לא משנה מה קורה עם הסבון, הן מתפשטות."},{"start":1377.58,"end":1378.94,"text":"הן לא יכולות להתאפק."},{"start":1378.94,"end":1381.94,"text":"החלטו להביא קונטרה בישראלית."},{"start":1381.94,"end":1384.34,"text":"הפרסומת על נקע שבע."},{"start":1384.34,"end":1387.22,"text":"ואם אמא שלי הביאו את כל הסלאברטין,"},{"start":1387.22,"end":1388.95,"text":"את כל הסלאברטין של המדינה,"},{"start":1388.95,"end":1392.35,"text":"מה זה סלאברטין? זה יעני כאלה שכדאי להתחכך איתם."},{"start":1392.35,"end":1394.33,"text":"יש שם משהו שלא מי יודע מה הייתי מתחכך,"},{"start":1394.33,"end":1396.09,"text":"אבל רובם בסדר."},{"start":1396.09,"end":1399.63,"text":"הביאו את דנה ברגר, את יאיר ניץניץ,"},{"start":1399.63,"end":1401.27,"text":"את שלומי שבץ."},{"start":1401.27,"end":1403.11,"text":"כל הזאמרים באמא שלי, שלומי שבץ,"},{"start":1403.11,"end":1407.11,"text":"כמה שבחואר, הכניסו אותו גם, מה יש ישיר, יודע לשיר, סבבה."},{"start":1407.11,"end":1410.75,"text":"יושבים כולם במקלחד, בג'קוזי, עם אל ישראלי,"},{"start":1410.75,"end":1413.47,"text":"ועם כולם, והם מתקלחים ומשתבנים."},{"start":1413.47,"end":1416.85,"text":"אבל את מי רואים פתאום באמצע או שקשוקה?"},{"start":1416.85,"end":1419.77,"text":"מי אם לא? את יעל הבוקסיס."},{"start":1419.77,"end":1423.87,"text":"אווו, באמא שלי, אם אני הייתי במקומו בפרשומת,"},{"start":1423.87,"end":1426.55,"text":"פה הייתה נגמרת, רבותיי, באמא שלי."},{"start":1426.55,"end":1429.05,"text":"הייתי נכנס למקלחד ומוציא את המים."},{"start":1429.05,"end":1431.31,"text":"מה זה, אחרת הזה? אבל מה הם עושים?"},{"start":1431.31,"end":1437.88,"text":"הם שרים, הלפלפים שרים, לילה לילה לילה לילה לילה פופופופ"},{"start":1437.88,"end":1441.79,"text":"מה זה חרט הזה? מה זה שירים? יש לנו זמן לשירים, באמא שלי זה לא יומן"},{"start":1441.79,"end":1441.89,"text":"והיהיה לה בוקסיס, לא אכפת לה וכייכת, אהההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":1441.79,"end":1444.35,"text":"ויהיה לה בוקסיס, לא אכפת לה וכייכת"},{"start":1444.35,"end":1446.59,"text":"איך היה לה בוקסיס התקדמה באמא שלכם?"},{"start":1446.59,"end":1449.27,"text":"בהתחלה, כולה היה לה פרסומת של מעיל"},{"start":1449.27,"end":1451.51,"text":"עלך פתחה גמרנו"},{"start":1451.51,"end":1456.31,"text":"עכשיו החושי לי כבר רואים אותלה בבקלעת, עד פה בטוח"},{"start":1456.31,"end":1459.19,"text":"איך אני מחכה לפרסומת הבאה באמא שלי?"},{"start":1459.19,"end":1463.11,"text":"בפרסומת הבאה אני לא אקבל נקע, אני אקבל נקע שבע באמא שלי"},{"start":1463.11,"end":1468.2,"text":"מוסרסקין, בפרסומת הבאה שלי היה לה בוקסיס, גברותיי ורבותיי, יהיו מוכנים"},{"start":1468.2,"end":1471.15,"text":"סבון ביד ימין, ואני מזמין את כולם"},{"start":1471.15,"end":1474.88,"text":"-למי שובים! -הההההההההההההההה!"}]