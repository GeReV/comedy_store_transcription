[{"start":9.76,"end":32.54,"text":"וככה, הכל התחיל לפני איזה שנתיים בערך, החבר'ה אמרו לי בוא בוא תנסה, אז התחלתי בהתחלה עם מילים בודדות, יש לי, יש לי, אחרי זה, אחרי זה העסק התפתח, עברתי כבר למשפטים, כמו שלום לבושבת, מכה חדשה נפלה על המדינה."},{"start":32.54,"end":48.47,"text":"מי שם העסק כבר מדרדר בקלות, אתה ישר עובר למערכונים, לשירים, ואז נפלתי לגמרי, כאילו היום, היום בלי לפתוח טלוויזיה ביום השלישי בשבע וחצי, לא, לא, לא, לא עובר שבוע."},{"start":48.47,"end":57.11,"text":"בהתחלה עוד אני חשבתי, אני שולט על זה, אני יכול להפסיק מתי שאני רוצה, לא, אני פשוט לא יכול, הנה, אפילו קרחת עשיתי."},{"start":57.11,"end":62.53,"text":"הקרומדיסטור, רצית רק לדפוק את הראש, דפקת את החיים."},{"start":62.53,"end":66.46,"text":"מה זה החושך הזה? אה, זה אתה."},{"start":66.46,"end":71.02,"text":"מה? רצית רק לדפוק את הראש, דפקת את החיים?"},{"start":71.02,"end":73.65,"text":"הקרומדיסטור, מיד אחרי הפרסומות."},{"start":73.65,"end":78.13,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות."},{"start":78.13,"end":83.57,"text":"קשר בין המציאות לדמיון הינו מקרי בהחלק."},{"start":83.57,"end":89.49,"text":"כמות האנשים והמקומות שונו לצורך העלילה."},{"start":89.49,"end":90.89,"text":"ומאתה הם ניקאים."},{"start":90.89,"end":122.92,"text":"הקרומדיסטור, סירסי בקל המציגים."},{"start":122.92,"end":127.07,"text":"אם אהבתם את שון קונרי, אם אהבתם את רוג'ר מור,"},{"start":127.07,"end":129.48,"text":"תמותו על ג'יימס בונד החדש."},{"start":134.11,"end":151.05,"text":"ניסים בוסקילה הוא סוכן חשי אפס אפס."},{"start":151.05,"end":152.57,"text":"שירותים מיוחדים."},{"start":152.57,"end":163.88,"text":"סדר, נסבון, סדר."},{"start":163.88,"end":165.1,"text":"מתח."},{"start":165.1,"end":166.49,"text":"תצילו!"},{"start":166.49,"end":176.81,"text":"תציל אותנו, ג'יימס בונד."},{"start":176.81,"end":178.99,"text":"בואו, מה, תפרק תפצצה."},{"start":178.99,"end":179.75,"text":"פרק תפצצה."},{"start":179.75,"end":181.05,"text":"תפצח תחבלים, תחבלים."},{"start":181.05,"end":181.81,"text":"תחבלים, חבלים."},{"start":181.81,"end":183.47,"text":"זה באמת, זה פצצה גרירים, איתן זמן."},{"start":183.47,"end":185.69,"text":"גרירים, יופי, פיתוחים, איתן."},{"start":185.69,"end":187.33,"text":"תורל כל העולם בידיך."},{"start":187.33,"end":188.43,"text":"תוקחה בידיך."},{"start":188.43,"end":190.03,"text":"אין זמן, חמש שניות, נו."},{"start":190.11,"end":191.51,"text":"ויש לי עוד נור, מה?"},{"start":191.51,"end":193.19,"text":"ארבע! שלום!"},{"start":193.19,"end":194.69,"text":"יפה ירוק הזה, לא יפה!"},{"start":194.69,"end":196.87,"text":"לא חדום וירוק לא יפה!"},{"start":196.87,"end":199.43,"text":"אה חייאא, סדר, סידר, אתם באים יפה!"},{"start":199.43,"end":200.43,"text":"תודה רבה!"},{"start":200.43,"end":201.09,"text":"תודה!"},{"start":201.09,"end":202.43,"text":"אולי הוא כן ירוק יפה!"},{"start":202.43,"end":202.53,"text":"לאווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":202.43,"end":203.43,"text":"לא!"},{"start":203.43,"end":204.43,"text":"לא!"},{"start":204.43,"end":205.43,"text":"לא!"},{"start":205.43,"end":206.43,"text":"לא!"},{"start":206.43,"end":210.25,"text":"ברוע!"},{"start":210.25,"end":214.32,"text":"מה?"},{"start":214.32,"end":215.95,"text":"בנות!"},{"start":215.95,"end":217.36,"text":"מה?"},{"start":217.36,"end":218.36,"text":"עוד סיבור!"},{"start":218.36,"end":219.32,"text":"לא עוד סיבור!"},{"start":219.32,"end":220.32,"text":"לא עוד סיבור!"},{"start":220.32,"end":221.32,"text":"לא עוד סיבור ניסים!"},{"start":221.32,"end":223.32,"text":"חבל! ניסים רוצה עוד סיבור! חבל!"},{"start":223.32,"end":224.41,"text":"חבל, יחול!"},{"start":224.41,"end":225.41,"text":"מעולות נועזות!"},{"start":225.41,"end":232.21,"text":"חבודה!"},{"start":232.21,"end":233.31,"text":"ניסים!"},{"start":233.31,"end":234.24,"text":"ניסים תהיה בשקט!"},{"start":234.24,"end":235.32,"text":"בשקט!"},{"start":235.32,"end":236.32,"text":"ניסים עברתי לחקיה בשקט!"},{"start":236.32,"end":237.32,"text":"או בשקט!"},{"start":237.32,"end":238.32,"text":"ניסים אני באמצע מערב!"},{"start":238.32,"end":239.32,"text":"מערב!"},{"start":239.32,"end":241.61,"text":"ניסים תשתוק האויב מעזין!"},{"start":241.61,"end":243.61,"text":"מערב מועדין על ההוגבר!"},{"start":243.61,"end":245.61,"text":"ניסים אתה לא יכול לשתוק רגע אחד!"},{"start":245.61,"end":247.96,"text":"זה יכול לזה חשוב!"},{"start":247.96,"end":248.96,"text":"שש!"},{"start":248.96,"end":253.8,"text":"אה!"},{"start":253.8,"end":254.76,"text":"ניסים תשתוק!"},{"start":254.76,"end":259.83,"text":"אה!"},{"start":259.83,"end":261.83,"text":"חומו עדין שחלו את המכירש!"},{"start":261.83,"end":262.83,"text":"אה!"},{"start":262.83,"end":263.98,"text":"אה!"},{"start":263.98,"end":264.98,"text":"טכנולוגיה מתקדמת!"},{"start":264.98,"end":279.36,"text":"נחשי ניסים בוסקילה אפס אפס!"},{"start":279.36,"end":281.36,"text":"האם אתה שומע אותי?"},{"start":281.36,"end":282.42,"text":"שומע אותי?"},{"start":282.42,"end":286.4,"text":"האם אתה שומע אותי ניסים בוסקילה אני מדבר אליך מהעטיפה של הקרמבו?"},{"start":286.4,"end":288.05,"text":"הקרמבו?"},{"start":288.05,"end":290.14,"text":"כן ניסים מהעטיפה של הקרמבו!"},{"start":290.14,"end":291.04,"text":"ניסים לב ניסים"},{"start":291.04,"end":294.33,"text":"העט שאתה נושא בחיסך הוא אקדח ארוך טווח"},{"start":294.33,"end":295.33,"text":"ארוך טווח"},{"start":295.33,"end":298.33,"text":"הניבט הפפיון שלך היא פצצה רבת עוצמה"},{"start":298.33,"end":299.33,"text":"ארוך טווח"},{"start":299.33,"end":303.23,"text":"והמיקרופילם השווה מיליון עם היחידי בעולם תמון בתוך הקרמבו"},{"start":303.23,"end":305.32,"text":"קרמבו?"},{"start":305.32,"end":307.32,"text":"כן כן ניסים הבנת נכון בתוך הקרמבו"},{"start":307.32,"end":308.34,"text":"מה הקרמבו?"},{"start":308.34,"end":310.34,"text":"שמור עליו מכל משמר ניסים"},{"start":310.34,"end":313.46,"text":"אה לא אכלתי אכלתי קרמבו ניסים בשקילה אחתה"},{"start":313.46,"end":315.46,"text":"האם אני מבין שאתה שומר על המיקרופילם?"},{"start":315.46,"end":322.49,"text":"מיקרופילם בפנים אחתה אני אוהב אנטי ניסים מה עשיתם המיקרופיל?"},{"start":322.49,"end":325.49,"text":"אני לא מבין ניסים תסביר את עצמך"},{"start":325.49,"end":330.65,"text":"ניסים ניסים תראה דה ותסביר את עצמך"},{"start":330.65,"end":332.65,"text":"ניסים הלו מה אתה עושה?"},{"start":332.65,"end":334.65,"text":"מה ישראל לאן אתה הולך?"},{"start":334.65,"end":341.65,"text":"ניסים ניסים תוציא אותי מפה ניסים אדיוט מה אתה עושה לאן אתה הולך ניסים תחזור אליו מיד ניסים הלו"},{"start":341.65,"end":345.03,"text":"עכשיו בקולנוע של ציון בואו במונאיכם"},{"start":345.03,"end":350.31,"text":"הוא בבקשה קנוק ארטיס ציון מסכן ציון איך היה למחבודה ציון"},{"start":350.31,"end":355.38,"text":"איזה דיכאון יא הלה"},{"start":355.38,"end":365.71,"text":"אופה אדוני סליחה יש לך אולי קבל אם אני פשוט תקוע פה כבר כמה שעות"},{"start":365.71,"end":366.71,"text":"אין בעיה"},{"start":366.71,"end":369.48,"text":"יש לך? ואללה גדול אתה תאמין לי"},{"start":369.48,"end":372.86,"text":"פשוט אני תקוע פה תאמין לי אני עומד פה אני לא יודע מה לעשות ממש"},{"start":372.86,"end":374.86,"text":"אין בעיה תרגע הכל יהיה בסדר"},{"start":374.86,"end":377.85,"text":"תודה רבה לך איך אומרים ממש הצלת אותי"},{"start":377.85,"end":378.91,"text":"חבר אצלך"},{"start":378.91,"end":380.91,"text":"בסדר אני מחבר רק תגיד לי מתי"},{"start":380.91,"end":381.91,"text":"אתה מוכן?"},{"start":381.91,"end":382.91,"text":"כן"},{"start":382.91,"end":383.91,"text":"אני מתחבר"},{"start":383.91,"end":384.88,"text":"יופי"},{"start":384.88,"end":385.88,"text":"גדול"},{"start":385.88,"end":385.98,"text":"גדול"},{"start":385.88,"end":386.88,"text":"גדול"},{"start":386.88,"end":387.88,"text":"גדול"},{"start":387.88,"end":388.88,"text":"גדול"},{"start":388.88,"end":389.88,"text":"עצר"},{"start":389.88,"end":405.53,"text":"גדול"},{"start":405.53,"end":406.53,"text":"אני הגעתי להוראה"},{"start":406.53,"end":408.72,"text":"ועבר לחינוך"},{"start":408.72,"end":412.03,"text":"מברג בזווית שלושים מעלות"},{"start":412.03,"end":413.34,"text":"כמו שלמדנו"},{"start":413.34,"end":415.34,"text":"אני מלמד אותם שיעורים טכנולוגיים"},{"start":415.34,"end":417.34,"text":"אוקיי, אז אתה מפרק את האלטרנטור"},{"start":417.34,"end":418.34,"text":"מה?"},{"start":418.34,"end":419.34,"text":"אני מוריד את המצבר"},{"start":419.34,"end":420.34,"text":"את המצבר"},{"start":420.34,"end":421.34,"text":"את המצבר"},{"start":421.34,"end":422.34,"text":"המצבר זה זה"},{"start":422.34,"end":423.33,"text":"לא נכון"},{"start":423.33,"end":424.33,"text":"המורה יש בו שאלה על המצבר"},{"start":424.33,"end":427.35,"text":"אני מלמד אותם יחסי אנוש"},{"start":427.35,"end":429.47,"text":"מה שיקו הכל בסדר?"},{"start":429.47,"end":430.47,"text":"כן המורה"},{"start":430.47,"end":432.47,"text":"הסתדרת מבחינה כלכלית?"},{"start":432.47,"end":433.47,"text":"כן המורה"},{"start":433.47,"end":434.47,"text":"אלה על הכפק"},{"start":434.47,"end":435.47,"text":"אתה התקדמת"},{"start":435.47,"end":437.43,"text":"להסיר את הענק המורה"},{"start":437.43,"end":438.74,"text":"בורסול"},{"start":438.74,"end":439.74,"text":"עכשיו אני יודע"},{"start":439.74,"end":441.74,"text":"שאנחנו ניפגש גם מחוץ לשאות הלימודים"},{"start":441.74,"end":443.74,"text":"חכה חכה המורה"},{"start":443.74,"end":445.74,"text":"ניפגש אחרי בית ספר"},{"start":445.74,"end":448.12,"text":"והיום אני מתמלא גאווה"},{"start":448.12,"end":449.12,"text":"מתי שאני יודע"},{"start":449.12,"end":450.12,"text":"שגם לי"},{"start":450.12,"end":452.44,"text":"יש חלק בעיצוב של העתיד שלהם"},{"start":452.44,"end":455.41,"text":"אלא סליחה מורה לא שמעתי לך"},{"start":455.41,"end":457.41,"text":"סליחה מורה אלא"},{"start":457.41,"end":459.59,"text":"מורה"},{"start":459.59,"end":461.67,"text":"נפר לי פאולי יותר בשקט"},{"start":461.67,"end":463.64,"text":"מורה טוב"},{"start":463.64,"end":465.93,"text":"מורה לחיים"},{"start":465.93,"end":470.61,"text":"תגיד מתי היום הולדת של חברה שלך"},{"start":470.61,"end":472.92,"text":"אני אומר את חברה שלך שלך שעה אתמול"},{"start":472.92,"end":473.92,"text":"אתמול?"},{"start":473.92,"end":474.92,"text":"אני לא זוכר אני"},{"start":474.92,"end":477.11,"text":"אני חושבת לשלח לך משברך לא נעים לי