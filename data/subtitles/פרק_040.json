[{"start":30.4,"end":34.61,"text":"תלוכים הבאים, לקומדיסטור!"},{"start":34.61,"end":41.04,"text":"ערב טוב, בא לך להיות ג'ודי לא צהרונוב החדשה?"},{"start":41.04,"end":43.93,"text":"יש לך את החיוך של ג'ודי?"},{"start":43.93,"end":46.6,"text":"יש לך את החן של ג'ודי?"},{"start":46.6,"end":49.66,"text":"יש לך את השערות של ג'ודי?"},{"start":49.66,"end":53.37,"text":"מיד אחרי הפרסומות, בקומדיסטור,"},{"start":53.37,"end":57.83,"text":"תוכלי לבדוק אם את מתאימה ולראות הקצע הקטע."},{"start":57.83,"end":62.38,"text":"כאן ג'ודי לא צהר, אוראה כפולה, שני קוני למל,"},{"start":62.38,"end":65.48,"text":"מגדלי התאומים, מנהטן."},{"start":65.48,"end":117.34,"text":"בדיחה חכה עם חיים בלוף."},{"start":117.34,"end":119.99,"text":"ערב טוב לכולם, שלום רב,"},{"start":119.99,"end":122.85,"text":"שוב אנחנו בבדיחה חכה עם חיים בלוף."},{"start":122.85,"end":126.31,"text":"והפעם, במיוחד, לכבוד ראש השנה לילנות,"},{"start":126.31,"end":128.17,"text":"החלטנו להקדיש מתיחה."},{"start":128.17,"end":129.99,"text":"נמצא איתי כאן איגור."},{"start":129.99,"end":134.13,"text":"ואנחנו הולכים לשלוח את איגור,"},{"start":134.37,"end":137.67,"text":"למכור סאברסים לא מחולפים בבסטה."},{"start":137.67,"end":139.27,"text":"איגור, בהצלחה!"},{"start":139.27,"end":140.35,"text":"להתראות."},{"start":140.35,"end":142.71,"text":"נמצא איתי כאן מושון."},{"start":142.71,"end":146.71,"text":"זה הפעם אנחנו הולכים לחפור בור ענק באמצע הדרך."},{"start":146.71,"end":153.31,"text":"ושימו לב, כי איצד איפול לשם אדם תמים שלא יודע שתמנו לא מלכונת."},{"start":153.31,"end":157.73,"text":"שובו אלינו בהמשך."},{"start":157.73,"end":163.86,"text":"ברוכים הבאים לבדיחיחיחי עם אלי מתחן."},{"start":165.12,"end":169.94,"text":"שוב אתם בתוכנית בדיחיחיחי עם אלי מתחן."},{"start":169.94,"end":173.04,"text":"נמצאתי כאן העוזר שלי, עברי מלא."},{"start":173.04,"end":178.6,"text":"ואנחנו עומדים להתמין על השביל."},{"start":178.6,"end":185.56,"text":"לולעת חבל בה התאפס הקורבן ברגלה והתעלה כשראשון נוטה למטה."},{"start":185.56,"end":188.98,"text":"חזרו אלינו אחר כך."},{"start":189.98,"end":200.12,"text":"ובכן, חזרו אלינו בדיוק כאשר הקורבן שלנו הולך ליפול לתוך הבורש שאנחנו קרינו."},{"start":200.12,"end":201.44,"text":"שימו לב, אינו."},{"start":201.44,"end":208.54,"text":"והנה אנחנו רואים את הקורבן התאמים מתקרב."},{"start":208.54,"end":211.54,"text":"שתי רגליו על הקרקע, אבל לא לאורך זמן."},{"start":211.54,"end":213.68,"text":"הוא לא יודע מה הולך לקראפ."},{"start":213.68,"end":215.96,"text":"או, אני רואה שיש לנו בעיה מסוימת."},{"start":215.96,"end":218.52,"text":"הקורבן הלך לשבת על הספסל."},{"start":218.52,"end":220.74,"text":"אוי, אני רואה שיש לנו כאן בעיה."},{"start":220.96,"end":225.32,"text":"הבן אדם התעקש לשבת על הספסל ולא הולך להתאפס במלכודת."},{"start":225.32,"end":227.43,"text":"מושון!"},{"start":227.43,"end":233.35,"text":"אתה תיגש אל הספסל ותשכנע אותו ללכת בשביל שלנו."},{"start":233.35,"end":234.55,"text":"קדימה מושון."},{"start":234.55,"end":235.19,"text":"אל תדעי."},{"start":235.19,"end":236.39,"text":"בהצלחה מושון."},{"start":236.39,"end":239.94,"text":"קדימה. בהצלחה."},{"start":239.94,"end":243.31,"text":"שלום אדוני."},{"start":243.31,"end":244.32,"text":"שלום."},{"start":244.32,"end":245.96,"text":"תגיד לי, ארנק שם בפינה."},{"start":245.96,"end":248.61,"text":"זה לא שלך עם כל הכסף שם."},{"start":248.61,"end":253.48,"text":"יש פה אחת מתה להכיר אותך."},{"start":253.48,"end":254.72,"text":"הנה זאת שיושבת שם."},{"start":254.72,"end":257.6,"text":"אופה, בחוצ'יק, מישהו מתעסק לך באוטו שם מאחורי הבור, לא?"},{"start":257.6,"end":259.04,"text":"בעזוב את האוטוגנב!"},{"start":259.04,"end":264.16,"text":"מושון משכנה האוטו לבוא ליפול בתוך..."},{"start":264.16,"end":267.17,"text":"בוא נה בוא נה, תראי, ארומה לגמרי, רוצה שתעייך."},{"start":267.17,"end":272.05,"text":"עברי מלא שלנו, פשוט עושה עבודה מצוינת."},{"start":272.05,"end":275.17,"text":"בוא נה בוא נה, אדוני, אדוני, אתה לא רואה שעושים פה קטע."},{"start":275.17,"end":277.57,"text":"מה קטע, שאתה אוקיי, היא בחקה, ארומה לגמרי."},{"start":277.57,"end":279.89,"text":"מה אתה מלבל תמוך, אנחנו עובדים פה על קטע, נכון?"},{"start":279.89,"end":281.89,"text":"מה אתה נתחף, עושים פה קטע."},{"start":281.89,"end":284.89,"text":"ימר, ימר, בוא נרגע עם זה."},{"start":284.89,"end":290.89,"text":"שלום לך אדוני, אני חיים בלוף, ואתה במצלמה, אני אסתרת, שאני בדיחה עליך."},{"start":290.89,"end":294.89,"text":"שלום לך אדוני, אתה במצלמה, אני אסתרת, שאני בדיחה עליך."},{"start":294.89,"end":296.89,"text":"אני מדיחה עליך."},{"start":296.89,"end":298.89,"text":"אני מדיחה עליך."},{"start":298.89,"end":299.89,"text":"אני מדיחה."},{"start":299.89,"end":303.89,"text":"תרשו לי רגע לעזור, אתם כולכם מצטלמים להלצה צה צה."},{"start":303.89,"end":308.89,"text":"אני בני ספליט, ואתם הייתי בתוכנית, עבדתי על כולכם."},{"start":308.89,"end":313.89,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":313.89,"end":319.33,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":319.33,"end":321.64,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":321.64,"end":333.12,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":333.12,"end":335.12,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":335.12,"end":337.12,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":337.12,"end":339.12,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":339.12,"end":341.12,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":341.12,"end":343.08,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":343.08,"end":345.08,"text":"תרשו לי רגע לעזור, אתם כולכם."},{"start":345.08,"end":349.07,"text":"והייתי רוצה להתייעץ איתך ז'ז'ו, איזה הודעה להקליט?"},{"start":349.07,"end":351.08,"text":"לטיפולך המסור, רוטי."},{"start":351.08,"end":354.08,"text":"ובכן רוטי, מכירתי, אין ספק שאת נוגעת בבעיה חיובה."},{"start":354.08,"end":357.17,"text":"המזכירות האלקטרונית השתלטו על המדינה באמא שלי."},{"start":357.17,"end":360.17,"text":"אין בית שלא רואים בתוכו מזכירה אלקטרונית."},{"start":360.17,"end":362.17,"text":"וההודעות באמא שלי לפלפיות מחלוטין."},{"start":362.17,"end":364.17,"text":"לכן את שכה לדגם את ההודעה שלך."},{"start":364.17,"end":367.29,"text":"א', כול, במקום להגיד להשאיר הודעה אחרי הביפ,"},{"start":367.29,"end":371.48,"text":"רצוי לומר: \"השאיר הודעה אחריה\"."},{"start":371.48,"end":374.51,"text":"הרבה יותר רגיוני, אנשים יסביכו להשאיר את ההודעה."},{"start":374.51,"end":376.51,"text":"דבר שני, ההודעות הם גדליק למען."},{"start":376.51,"end":381.51,"text":"הודעה אחת יכולה להיות: \"שלום, זאת רותם, אני כרגע לא בבית, אני במקלחת\"."},{"start":381.51,"end":383.51,"text":"תשאיר הודעה אחריה."},{"start":383.51,"end":384.51,"text":"זאת הודעה הראשונה."},{"start":384.51,"end":387.51,"text":"הודעה שנייה יכולה להיות הרבה יותר אופטימית:"},{"start":387.51,"end":394.54,"text":"\"שלום, זאת רותם, אני נמצאת עם חבר שלי כרגע במקלחת ותחשבו על זה\"."},{"start":394.54,"end":397.63,"text":"הודעה שלישית: \"שלום, זאת רותם\"."},{"start":397.63,"end":405.66,"text":"חבר שלי לא בבית, אני נמצאת עם זו זו עכשיו במקלחת ותחשבו על זה ואל תשאירו הודעות בכלל."},{"start":405.66,"end":410.72,"text":"מוסר עזקל: עזבו אתכם מזכירות אלקטרוניות, עזבו אתכם בטאריות."},{"start":410.72,"end":412.72,"text":"חור מזכירה כמו שלי יש באמא שלי."},{"start":412.72,"end":415.78,"text":"הנה זאת המזכירה, תוכלו לדור את המזכירה שלי האישית."},{"start":415.78,"end":417.78,"text":"כימא חושק שוקה."},{"start":417.78,"end":420.78,"text":"גם סימפטית, גם עונה באנגלית, גם בעברית."},{"start":420.78,"end":424.78,"text":"ואמא שלי הכי חשוב: שווה פעימת מונה."},{"start":424.78,"end":427.58,"text":"ותחייגו את זה."},{"start":432.96,"end":436.18,"text":"ערב טוב. שוב אתם במדריך כיצד נתנהג הנכון,"},{"start":436.18,"end":439.18,"text":"והפעם, כיצד תבלא עם בת זוגתך במסעדה."},{"start":439.18,"end":442.42,"text":"ראשית, עליך להזמין מקומות מראש."},{"start":442.42,"end":444.42,"text":"אם לא עשית זאת, תמתן בסבלנות."},{"start":444.42,"end":445.48,"text":"ערב טוב."},{"start":445.48,"end":447.48,"text":"שולחן לזוג, בבקשה?"},{"start":447.48,"end":450.48,"text":"אני מצטער לנו כרגע, מקום פנוי, תאלצו להמתין חמש דקות."},{"start":450.48,"end":453.48,"text":"מה זאת אומרת, ומה זה? אלו, אלו, זו, זו, זו, זו, שולחן לאר, במעט המשפים שניים."},{"start":453.48,"end":455.48,"text":"זו, זו, תן מקום, זו!"},{"start":455.48,"end":456.48,"text":"קח את הקפוא."},{"start":456.48,"end":460.51,"text":"זכור, בכל מסעדה ישנו אדם שתפקידו לשמור על הסדר."},{"start":460.51,"end":461.47,"text":"פרוספי!"},{"start":461.47,"end":465.53,"text":"חייף, אתה עוז מפה, קדימה, יש פה מקום לכולן."},{"start":465.53,"end":468.93,"text":"סדר תשארו, אין מה יחד?"},{"start":468.93,"end":473.15,"text":"סוף סוף הגעתם אל השולחן המיוחל."},{"start":473.15,"end":475.27,"text":"דאג לנוכיות בת זוגתך."},{"start":475.27,"end":476.77,"text":"שבים עותק."},{"start":476.77,"end":483.3,"text":"אך, אל תגזים."},{"start":483.3,"end":484.3,"text":"ועכשיו, נוח לך עמודה?"},{"start":484.3,"end":487.45,"text":"הכיסא קצת גבוה, אבל חוץ מזה הכל בסדר."},{"start":487.45,"end":490.4,"text":"גבוה, יאללה, זוזי, זוזי, נסדר, זוזי, קדימה, הופה."},{"start":490.4,"end":495.32,"text":"סדר את זה בשניות!"},{"start":495.32,"end":502.82,"text":"תת לך קונטרה?"},{"start":502.82,"end":504.82,"text":"בשלב זה יביא המלצר את התפריט."},{"start":504.82,"end":508.03,"text":"אל תפגין בורות בשמות המאכלים."},{"start":508.03,"end":510.09,"text":"מה זה? אוף ברוטב בריגנצי? מה זה השטויות הנה?"},{"start":510.09,"end":511.09,"text":"תבין לבקשה, איך קוראים לזה?"},{"start":511.09,"end":515.09,"text":"זה עם התפוח הדמה שחתוך דק-דק-דק עם חום בשמן, בשמן."},{"start":515.09,"end":516.09,"text":"את הדבר הזה, נו?"},{"start":516.09,"end":517.25,"text":"צ'יפס."},{"start":517.25,"end":518.88,"text":"הופה."},{"start":518.88,"end":519.87,"text":"כן?"},{"start":519.87,"end":522.94,"text":"את זה בבקשה, וגם את הנוזל הזה בתוך כוס, נו, שיש בפנים דגים."},{"start":522.94,"end":523.94,"text":"שקוף, שקוף, גלום."},{"start":523.94,"end":524.94,"text":"מים."},{"start":524.94,"end":526.19,"text":"מים."},{"start":526.19,"end":528.44,"text":"היית פה פעם, אה?"},{"start":528.44,"end":532.66,"text":"משכילה. פעמיים, מים וצ'יפס, תבי, יאללה, יאללה, טוס, טוס, טוס, תבי."},{"start":532.66,"end":536.08,"text":"מצד שני, אל תנסה להפגין ידע מוגזם."},{"start":536.08,"end":542.78,"text":"יש. אני הייתי רוצה בקשהגול השהודי עם קארי ברוטה וז'מבו בבר על הז'אם פול ז'ימריס ז'אנקלוד ון דם"},{"start":542.78,"end":546.78,"text":"עם שני סוגי טירס, אורז, שסק, חסה ועננס קטן בצד, בסדר?"},{"start":546.78,"end":551.78,"text":"זה בא מחבל שעטוב, ריאור, שם ז'אנקלוד ון דם ושישה סוסים שחורים, קודשים לבד"},{"start":551.78,"end":556.78,"text":"על מצב פוספט עם חווית, את כל הענבים לבד בכוחות עצמם ועונת האיכום של הסנאים"},{"start":556.78,"end":563.88,"text":"ובשבילה שועית, חולה עלייך"},{"start":563.88,"end":570.66,"text":"אם המחירים גבוהים מדי, אל תנסה להבריח אוכל למסעדה"},{"start":570.66,"end":588.81,"text":"רצוי ליצור אווירה רומנטית, הצעה האפשרית, הדלק נר"},{"start":588.81,"end":595.73,"text":"עינייך נוצצות כמו עדר תיאור"},{"start":595.73,"end":597.76,"text":"אך גם כאן רצוי לא להגזים"},{"start":611.36,"end":617.66,"text":"ייתכן שבשלב מסוים תצטרך להתפנות"},{"start":617.66,"end":620.0,"text":"עשה זאת בדיסקרטיות"},{"start":620.0,"end":624.1,"text":"כן בבקשה"},{"start":624.1,"end":625.1,"text":"איפה פה אפשר לה..."},{"start":625.1,"end":626.96,"text":"לא מבין"},{"start":626.96,"end":628.08,"text":"איפה פה ה..."},{"start":628.08,"end":632.05,"text":"אני מצטער למושג למה אתה מתכוון"},{"start":632.05,"end":633.05,"text":"מלצר?"},{"start":633.05,"end":634.05,"text":"עם ה..."},{"start":634.05,"end":637.14,"text":"אם לא תדבר ברור תשכח מימד יד ומי"},{"start":637.14,"end":640.14,"text":"בסוף הארוחה יגיע המלצר עם החשבון"},{"start":640.14,"end":641.23,"text":"לעולם"},{"start":641.23,"end":643.26,"text":"אבל לעולם"},{"start":643.26,"end":644.44,"text":"אל תיראה מופתע"},{"start":644.44,"end":645.75,"text":"חשבון"},{"start":645.75,"end":648.39,"text":"אתה רוצה להגיד לי שהארוחה פקוחה בתשלום?"},{"start":648.39,"end":650.58,"text":"למה לא כתוב גלום הכניסה?"},{"start":650.58,"end":651.58,"text":"אתה מושים צחוק"},{"start":651.58,"end":652.54,"text":"למה לא מיידים את האנשים?"},{"start":652.54,"end":657.58,"text":"מה קורה?"},{"start":657.58,"end":658.58,"text":"פרוספר אני בא!"},{"start":658.58,"end":659.84,"text":"יש על מי לא מותק"},{"start":659.84,"end":660.93,"text":"פרוספר!"},{"start":660.93,"end":666.55,"text":"ולסיכום"},{"start":666.55,"end":669.47,"text":"בפעם הבאה כשתרצה לצאת עם בת זוגתך למסעדה"},{"start":669.47,"end":670.64,"text":"קח אותה לאכול פלאפל"},{"start":670.64,"end":673.69,"text":"זה הכל, לילה טוב, המשך צפייה"},{"start":673.69,"end":680.85,"text":"הרדיעה שהגיעה זה הכל"},{"start":680.85,"end":682.85,"text":"מכה חדשה פוקדת את הלפים"},{"start":682.85,"end":684.85,"text":"המזלמה המשוטטת של ג'ודי"},{"start":684.85,"end":686.97,"text":"ערב טוב"},{"start":686.97,"end":688.94,"text":"כאן ג'ודי לא צהרונוב"},{"start":688.94,"end":689.94,"text":"קרפינסמה"},{"start":689.94,"end":690.94,"text":"דודו דודותן סוכניק"},{"start":690.94,"end":692.94,"text":"עקיפי שרמנון אבני"},{"start":692.94,"end":693.94,"text":"ודני רופ"},{"start":693.94,"end":695.94,"text":"יותר נתן מדאטנר"},{"start":695.94,"end":698.91,"text":"מכה חדשה נוחתת על המדינה"},{"start":698.91,"end":700.91,"text":"השעשוומניה"},{"start":700.91,"end":702.97,"text":"איי שעשוומניה"},{"start":702.97,"end":704.97,"text":"מחלת נפש קשה"},{"start":704.97,"end":706.97,"text":"שמקורה בשעשווני הטלוויזיה"},{"start":706.97,"end":708.97,"text":"המשודרים ללא ערב"},{"start":708.97,"end":710.97,"text":"וחודרים למוחו חסר הישע"},{"start":710.97,"end":712.97,"text":"של האזרח התמים"},{"start":712.97,"end":715.03,"text":"לקחנו את המצלמה המשטעשת"},{"start":715.03,"end":719.03,"text":"ויצאנו לבדוק הקצע הקטע"},{"start":719.03,"end":720.99,"text":"כאן אורי זוהר"},{"start":720.99,"end":722.99,"text":"מהשערים של בדידות"},{"start":722.99,"end":725.11,"text":"הראת לי בוס"},{"start":725.11,"end":727.11,"text":"כן הנה הגיע הזמן קבלת הווסקורת"},{"start":727.11,"end":727.21,"text":"או תודה רבה"},{"start":727.11,"end":729.11,"text":"אבל לפני שאתה פותח"},{"start":729.11,"end":731.1,"text":"אתה יכול לקבל את הווסקורת הזאת"},{"start":731.1,"end":733.1,"text":"פלוס כל חבילת השאי שנמצאת כאן בארגז"},{"start":733.1,"end":734.16,"text":"או"},{"start":734.16,"end":736.51,"text":"להמר על מה שיש כאן מאחורי הווילון"},{"start":736.51,"end":738.28,"text":"ווילון"},{"start":738.28,"end":739.28,"text":"עוד אלף דולר"},{"start":739.28,"end":741.28,"text":"תיקח את מה שנתת לך ולא תיקח את הווילון"},{"start":741.28,"end":743.28,"text":"לא לא לא אני רוצה את מה שמחה הווילון"},{"start":743.28,"end":745.28,"text":"ווילון"},{"start":745.28,"end":746.28,"text":"פלוס סוף שבוע זוגי בטורקיה"},{"start":746.28,"end":747.66,"text":"וילון"},{"start":747.66,"end":748.66,"text":"אוקיי וילון"},{"start":748.66,"end":749.66,"text":"נפסד אתה את כל זה"},{"start":749.66,"end":750.66,"text":"שים לב מה קיבלת"},{"start":750.66,"end":753.82,"text":"עוד מזכורת עלך"},{"start":753.82,"end":754.82,"text":"עוד מזכורת"},{"start":754.82,"end":755.82,"text":"יופי"},{"start":755.82,"end":756.82,"text":"טוב נתראה בחודש הבא"},{"start":756.82,"end":757.82,"text":"אולי תסליח"},{"start":757.82,"end":758.82,"text":"אני מקווה"},{"start":758.82,"end":759.82,"text":"כן יופי"},{"start":759.82,"end":760.82,"text":"תודה בכל אופן"},{"start":760.82,"end":763.16,"text":"ביחוס תקרא לעובד הבא"},{"start":763.16,"end":767.33,"text":"מה קורה?"},{"start":767.33,"end":768.45,"text":"אחר?"},{"start":768.45,"end":769.76,"text":"מה?"},{"start":769.76,"end":770.76,"text":"אפשר לקנות אותה יביא?"},{"start":770.76,"end":775.37,"text":"ששש"},{"start":775.37,"end":776.62,"text":"אלי פגשם"},{"start":776.62,"end":781.34,"text":"או סליחה אדוני"},{"start":781.34,"end":785.09,"text":"אתה יודע איפה זה רחוב אלמבי?"},{"start":785.09,"end":786.89,"text":"פוסקי וון"},{"start":786.89,"end":787.89,"text":"אתה יודע איפה זה רחוב אלמבי?"},{"start":787.89,"end":789.91,"text":"פוסקי וון"},{"start":789.91,"end":790.97,"text":"אתה יודע?"},{"start":790.97,"end":792.38,"text":"סימנו"},{"start":792.38,"end":794.38,"text":"עשרים שניות כמה שיותר פושאפס"},{"start":794.38,"end":795.38,"text":"וון וון וון"},{"start":795.38,"end":796.38,"text":"פוסקי"},{"start":796.38,"end":801.02,"text":"וון"},{"start":801.02,"end":802.98,"text":"אני מבין שאדוני מרוצה מהתופעה"},{"start":802.98,"end":804.01,"text":"נו בוודאי שאני מרוצה"},{"start":804.01,"end":806.01,"text":"זה הדבר הכי טוב שאני יכול לקרוא אותי אי פעם"},{"start":806.01,"end":807.01,"text":"תראה כל מקום שאני הולך"},{"start":807.01,"end":808.01,"text":"תרח מדביקים לי פרס"},{"start":808.01,"end":810.01,"text":"המזל רודפתי לכל מקום"},{"start":810.01,"end":811.01,"text":"כבר מיליתי את הבית שלי"},{"start":811.01,"end":812.01,"text":"ממש נדר"},{"start":812.01,"end":814.01,"text":"תראה לי חייב להיכנס פה לרופא שנייה"},{"start":814.01,"end":826.9,"text":"לכורה אין מקום לדאגה"},{"start":826.9,"end":829.9,"text":"אולם ברמי דך גיסה תרתי משמע"},{"start":829.9,"end":832.9,"text":"מה שהחל כפר פרה משעשת"},{"start":832.9,"end":836.9,"text":"הפך בי מרה למטרד גדול ומעצבן"},{"start":836.9,"end":839.9,"text":"אה צלם בוא נשתעשע"},{"start":839.9,"end":840.9,"text":"אה בוא אתה"},{"start":840.9,"end":850.89,"text":"אה אה אני חוזר ומדגיש לציבור אין מה לדאוג משטרת ישראל תטפל בבעיית השעשורומניה הזאת ותעשה הכל על מנת להשיב את הסדר על קנו"},{"start":850.89,"end":851.89,"text":"זה שקר"},{"start":851.89,"end":853.89,"text":"נכון מאוד"},{"start":853.89,"end":860.24,"text":"ויש לנו כאן רצב על הסוני של איקסים"},{"start":860.24,"end":861.21,"text":"אחורה אחרי"},{"start":861.21,"end":863.4,"text":"בוא יש לי משאיל להכיר לך שים לב"},{"start":863.4,"end":864.46,"text":"בוא אלנה דנה"},{"start":864.46,"end":866.46,"text":"שים לב איזה נסיכה יש לנו כאן"},{"start":866.46,"end":868.46,"text":"איזה נסיכה דנה תכירי זה איתהי"},{"start":868.46,"end":871.46,"text":"איתהי דנה ויש לנו כאן אורח נוסף"},{"start":871.46,"end":875.46,"text":"עשי"},{"start":875.46,"end":877.46,"text":"תכיר זו דנה"},{"start":877.46,"end":879.46,"text":"דנה איך את רוצה את הגבר שלה"},{"start":879.46,"end":882.46,"text":"כמו קפה שחור קצר וחזק"},{"start":882.46,"end":886.18,"text":"ונראה לי שיש לנו כאן"},{"start":886.18,"end":889.18,"text":"קונס"},{"start":889.18,"end":893.43,"text":"זה קונס ללא ספר"},{"start":893.43,"end":895.43,"text":"קונס או שחבל על הזם"},{"start":895.43,"end":898.43,"text":"העיר איתנו בואו התוכנית של קונס או שחבל על הזם"},{"start":898.43,"end":900.43,"text":"של התראות"},{"start":900.43,"end":904.43,"text":"עוד ארבעה תפוחים"},{"start":904.43,"end":911.3,"text":"רק היום"},{"start":911.3,"end":914.3,"text":"בוא נראה את זה רק היום"},{"start":914.3,"end":919.33,"text":"בוא נראה את זה עושה תפוחים אלא איכן הוא יוציא תפוח תחף"},{"start":919.33,"end":921.33,"text":"יש! יש!"},{"start":921.33,"end":924.81,"text":"עוד תפוח תחף"},{"start":924.81,"end":926.81,"text":"קונטור אדוני"},{"start":926.81,"end":930.85,"text":"לא! לא!"},{"start":930.85,"end":933.63,"text":"סליחה אדוני"},{"start":933.63,"end":935.73,"text":"תגיד אולי אתה מבין משהו באופניים"},{"start":935.73,"end":938.85,"text":"שנייה אתה, אופה, הנה יש לך פאנצ'ר, תעושה צחוק"},{"start":938.85,"end":940.94,"text":"נראה, שנייה אחת אני אשר לך פה את זה"},{"start":940.94,"end":943.09,"text":"מו חדש, בבקשה"},{"start":943.09,"end":945.09,"text":"איזה יופי, תגיד כמה אני חייבך?"},{"start":945.09,"end":948.11,"text":"שנייה אחת אני מסובב את הגלגל"},{"start":948.11,"end":949.36,"text":"ו..."},{"start":949.36,"end":951.83,"text":"איי-איי-איי-איי, שיטת רגל"},{"start":951.83,"end":953.83,"text":"יש לנו שיטת רגל, לא נורא, מה לעשות אדוני"},{"start":953.83,"end":955.83,"text":"קורא, בא מהמבטחות של הבית?"},{"start":955.83,"end":958.21,"text":"כן, במובן, סליחה"},{"start":958.21,"end":960.84,"text":"אה-אה-אה, שיטת רגל או לא פשיטת רגל?"},{"start":960.84,"end":961.75,"text":"סודק"},{"start":961.75,"end":964.01,"text":"אכן תמונות קשות"},{"start":964.01,"end":969.23,"text":"במגפה עוד אינה סובבת כשעות עלי שעון"},{"start":969.23,"end":973.23,"text":"והשעה שוונים עדיין מענישים ואין ישועה"},{"start":973.23,"end":976.23,"text":"עדיין מענים ואין מענה"},{"start":976.23,"end":981.23,"text":"ועולים כאשן עוין לעיניים ואין משען"},{"start":981.23,"end":986.71,"text":"כאן שוש אתרים פיצוחים, אפולה"},{"start":986.71,"end":1001.11,"text":"ערב טוב, ערב טוב, הרי תקציר החדשות כאן במבזק של ז'אק בערוץ הקהילתי שלכם"},{"start":1001.11,"end":1004.11,"text":"אז המער האמריקני מייקל ג'קסון עבר ניתוח פלסטי נוסף"},{"start":1004.11,"end":1007.1,"text":"הוא שוב צולם כשהוא מטריד ילד"},{"start":1007.1,"end":1008.1,"text":"הווה ונצפה בקטע"},{"start":1008.1,"end":1016.1,"text":"ולנושא שונה לגמרי"},{"start":1016.1,"end":1019.28,"text":"הרי ידיעה שפורסמה באחד מעיתוני הצהריים"},{"start":1019.28,"end":1023.42,"text":"מדען צרפתי \"גיליתי שם נאורים\""},{"start":1023.42,"end":1025.8,"text":"נמצא איתנו כאן אותו מדען"},{"start":1025.8,"end":1027.8,"text":"ערב טוב מרעמית ילד"},{"start":1035.86,"end":1044.33,"text":"ערב טוב מרעמית"},{"start":1044.33,"end":1046.33,"text":"ערב טוב עמית"},{"start":1046.33,"end":1048.33,"text":"אתה המצאת כאן \"שם נאורים\" נכון?"},{"start":1048.33,"end":1049.33,"text":"כן"},{"start":1049.33,"end":1050.61,"text":"זה המצאה שלך?"},{"start":1050.61,"end":1054.87,"text":"זה... אני החלפתי את זה עם חבר שלי תמורת המכונת גרטה גרטה טנטה"},{"start":1054.87,"end":1055.87,"text":"אה כן?"},{"start":1055.87,"end":1056.79,"text":"כן"},{"start":1056.79,"end":1058.84,"text":"אפשר לנסות את \"שם הנאורים\" הזה?"},{"start":1058.84,"end":1060.84,"text":"בלי חיפודים בלי חיפודים"},{"start":1060.84,"end":1061.84,"text":"בבקשה"},{"start":1061.84,"end":1065.35,"text":"יאללה בלי חרטות"},{"start":1065.35,"end":1069.07,"text":"אני יכול למשרדה שלי מיכל ינאי?"},{"start":1069.07,"end":1070.07,"text":"לא"},{"start":1070.07,"end":1072.93,"text":"אלא מה?"},{"start":1072.93,"end":1076.53,"text":"אז זה הכל ואתה מסכיחו לראות את התוכנית"},{"start":1076.53,"end":1079.53,"text":"אתה מבעתי אליך זה בכלל עושה מני הורים אני גבר נאה"},{"start":1079.53,"end":1081.53,"text":"גרישה בוא כך תמוצץ האינפנטיליה זה"},{"start":1081.53,"end":1085.32,"text":"כי ביני צ'ורט"},{"start":1085.32,"end":1089.09,"text":"זה הכל לילה טוב והמשך צפייה נעימה"},{"start":1089.09,"end":1127.62,"text":"שוב אנחנו בחלסטרה של זוזו"},{"start":1127.62,"end":1130.62,"text":"והפעם רציתי לספר לכם על הפחדים שלי"},{"start":1130.62,"end":1133.68,"text":"בים אמא שלי כמה שאתם רואים אותי פטיש למר אחושה שוגה"},{"start":1133.68,"end":1136.68,"text":"הדבר שאני מפחד ממנו אחר הרבה בעולם"},{"start":1136.68,"end":1137.64,"text":"זה רופא שיניים"},{"start":1137.64,"end":1141.64,"text":"מלח מי מלח מי מלח מי זה פח זה מלח של הרופא שיניים"},{"start":1141.64,"end":1143.64,"text":"הכיסא שלו זה כמו כיסא של חללית"},{"start":1143.64,"end":1146.64,"text":"עם מכשירים אני אך שאני מתקרן לו ראשי שומעת"},{"start":1146.64,"end":1148.64,"text":"אני בורע ביבה שלי"},{"start":1148.64,"end":1150.64,"text":"הדבר היחיד שאני מסמפת אצל הרופא שיניים"},{"start":1150.64,"end":1152.64,"text":"זה הסייעת שלו"},{"start":1152.64,"end":1154.64,"text":"או כמו שקוראים לה השינה נינטית"},{"start":1154.64,"end":1156.64,"text":"ביבה שלי"},{"start":1156.64,"end":1158.64,"text":"אני בא פותח את הפי ובכוונה זו זכורה"},{"start":1158.64,"end":1159.64,"text":"והיא מתקדמת"},{"start":1159.64,"end":1162.64,"text":"ונוצר מפגש ואופטימיות של הפחדים שלי"},{"start":1162.64,"end":1164.64,"text":"ואז אנחנו מסתדרים"},{"start":1164.64,"end":1167.64,"text":"אבל האפסורד התחיל להיות גדול"},{"start":1167.64,"end":1170.64,"text":"בפרסומות שהתחילו להיות לאחרונה בטלוויזיה"},{"start":1170.64,"end":1172.64,"text":"למשחות שיניים ולרופאי שיניים"},{"start":1172.64,"end":1174.64,"text":"באמא שלי מה זה החרטה זה?"},{"start":1174.64,"end":1176.64,"text":"זה פשוט לא יאומן כי סופיר"},{"start":1176.64,"end":1177.64,"text":"לא יאומן רואים ילד?"},{"start":1177.64,"end":1179.64,"text":"קטן מגאל, קטן כזה"},{"start":1179.64,"end":1180.64,"text":"הוא קופץ לאופי שיניים"},{"start":1180.64,"end":1182.64,"text":"הוא עושה לו, נו!"},{"start":1182.64,"end":1184.6,"text":"יעני, בוא תקדח!"},{"start":1184.6,"end":1186.6,"text":"אם אני הייתי רפא שיניי,"},{"start":1186.6,"end":1188.6,"text":"הייתי מביא לו מקדח שבע צהול,"},{"start":1188.6,"end":1190.6,"text":"הייתי רואה אותו, אומר נו!"},{"start":1190.6,"end":1192.6,"text":"איזה פחד! זה מביא לך מוביל ארצי בתוך הפה!"},{"start":1192.6,"end":1194.6,"text":"מה זה אחרת הזה באמא שלי?"},{"start":1194.6,"end":1196.6,"text":"ועכשיו המשחות שיניים!"},{"start":1196.6,"end":1198.6,"text":"יש משחות של כל בלט,"},{"start":1198.6,"end":1200.6,"text":"יש X-X-F, X-X-F, לא יודע מה זה X-X הזה,"},{"start":1200.6,"end":1202.6,"text":"בגרשים חתולים, לא יודע מה זה ביוסי לי עליו!"},{"start":1202.6,"end":1204.6,"text":"אבל, האפסורד הגדול ביותר,"},{"start":1204.6,"end":1206.6,"text":"זה באמת הפרסומת של X-X-F,"},{"start":1206.6,"end":1208.66,"text":"שבו רואים את דנה דבורדין,"},{"start":1208.66,"end":1210.66,"text":"ידועה מצהירי תל אביב,"},{"start":1210.66,"end":1212.66,"text":"שעכשיו היא בקשישי עפולה,"},{"start":1212.66,"end":1214.66,"text":"היא הייתה בלעקה,"},{"start":1214.66,"end":1216.66,"text":"ואם סקנה גנבו לה את התיק,"},{"start":1216.66,"end":1218.78,"text":"אנחנו שקשוקה נבהלנו,"},{"start":1218.78,"end":1220.78,"text":"עושים מסדר זיהוי,"},{"start":1220.78,"end":1222.78,"text":"זורקים את התיק,"},{"start":1222.78,"end":1224.78,"text":"יש לה ערנק וטבעות ועלומים,"},{"start":1224.78,"end":1226.78,"text":"וכסף זר ובנקים בשוויץ והכל,"},{"start":1226.78,"end":1230.78,"text":"וגנבו לה את X-X-F את המשחת שיניים!"},{"start":1230.78,"end":1235.1,"text":"מה זה החרט הזה ואמא שלי מכל התיק הזה משחת שיניים?"},{"start":1235.1,"end":1238.1,"text":"מה זה פורץ לפלף על אביבא שלי?"},{"start":1238.1,"end":1241.1,"text":"ובמסדר זהוי כל אחד יש לו שיניים יותר עקומות לחבר שלו"},{"start":1241.1,"end":1244.1,"text":"ואחד פתאום ניהיה לו יעלום בשן, הלאה!"},{"start":1244.1,"end":1246.1,"text":"תגיד גנב את הטבעת יעלום, מה זה החרט הזה?"},{"start":1246.1,"end":1249.38,"text":"פשוט המצוקה רבה, היא לך אחו והתאם לזאתי."},{"start":1249.38,"end":1251.41,"text":"צוות הצילום של זוזו ונב על האש,"},{"start":1251.41,"end":1254.37,"text":"יצא להראות לכם פרצומת, מהי?"},{"start":1254.37,"end":1256.62,"text":"מסדר זהוי, שופופו."},{"start":1256.62,"end":1257.77,"text":"מהי?"},{"start":1257.77,"end":1261.9,"text":"אדוני השיקוצניק, אתה מזהה את זאת שגנבה לך את הכלי עבודה?"},{"start":1261.9,"end":1269.31,"text":"תסתובבנה ימינה."},{"start":1269.31,"end":1278.24,"text":"מה היה לך בדלי?"},{"start":1278.24,"end":1280.16,"text":"פופרת סיליקון."},{"start":1280.16,"end":1281.84,"text":"זה המלא."},{"start":1281.84,"end":1284.01,"text":"אוקיי."},{"start":1284.01,"end":1286.42,"text":"כולן לפתוח מאלים בבקשה."},{"start":1286.42,"end":1298.55,"text":"סיליקון מוסיף לך המון, סיליקון תכשיר עם חזון."},{"start":1298.55,"end":1304.93,"text":"מוסר אסכל, רופא השיניים איננו מפחיד, בשבילנו הוא ידיד."},{"start":1304.93,"end":1307.88,"text":"מה זה חרוץים? מה זה חד הזה מבשילי?"},{"start":1307.88,"end":1312.88,"text":"מוסר אסכל, לא צריך להגיע למסדר זהוי בשביל צחצח שיניים."},{"start":1312.88,"end":1316.88,"text":"למרות שהבעיה היא במשחוד, בקלגלד, בקסלף,"},{"start":1316.88,"end":1320.88,"text":"שיבות המוזריות האלה ובטח זהו ראי זה משחה."},{"start":1320.88,"end":1322.91,"text":"ג'וזו מוציא משחה עדה של השעוק."},{"start":1322.91,"end":1325.9,"text":"טייגר, מהיום לא תבחד מרפא השיניים."},{"start":1325.9,"end":1329.37,"text":"טייגר, משחה לגבר שאוהב לנשוך."},{"start":1329.37,"end":1333.46,"text":"ותחשבו על זה."},{"start":1333.46,"end":1371.81,"text":"תבוא אלינו לפיינת היעוץ לגוצלי של ג'וזו."},{"start":1371.81,"end":1374.9,"text":"תיבדו עריכת ארבע ארבע ארבע של שלוש תל אביב."},{"start":1374.9,"end":1375.9,"text":"ותרשמו את זה."},{"start":1375.9,"end":1377.21,"text":"תודה רבה."}]