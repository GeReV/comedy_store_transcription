[{"start":52.71,"end":55.37,"text":"הרחובות בריקים."},{"start":91.18,"end":98.18,"text":"אם כן, לסיכום, הלף-לף הינו חכם, ואילו הפטיש הינו טיפש גמור."},{"start":98.18,"end":105.16,"text":"ובכן, יכול להיות שאני לגמרי טועה ואינני צודק בכלל."},{"start":105.16,"end":109.16,"text":"ובכן, תשכחו מכל מה שאמרתי, היו גם בשבוע הבא בפינה שלנו."},{"start":109.16,"end":112.25,"text":"לילה טוב, המשך תביע מענה!"},{"start":112.25,"end":115.46,"text":"מי תחשבו על זה?"},{"start":115.46,"end":176.43,"text":"ושוב אתם איתנו במדור הפרסומי, כדאי, אימם חוערת."},{"start":176.43,"end":184.86,"text":"יש פתרון, מהיום לכל כאב ראש, אאו, קחי כדור הכמו לאו."},{"start":184.86,"end":194.21,"text":"ואז במהירות של טיל לאו, תרגישי מיד, או כמה כואב לי הראש."},{"start":194.21,"end":196.3,"text":"אקח כדור בזה הרגע."},{"start":196.3,"end":206.3,"text":"הייתם צריכים לראות אותי קודם."},{"start":206.3,"end":210.9,"text":"תראו את הכדורים, נאו, ומיד תרגישו. וואו."},{"start":210.9,"end":250.41,"text":"ניתנו אנשים שלא רואים כל יום."},{"start":250.41,"end":252.76,"text":"ניתה איתנו כאן גוף."},{"start":252.76,"end":256.04,"text":"גוף מבוקש מזה שנים רבות על ידי העולם התחתון,"},{"start":256.04,"end":259.03,"text":"ולכן מסיבות מובנות ומחשש לחייו,"},{"start":259.03,"end":261.03,"text":"החלטנו להצוות את פרצופו."},{"start":261.03,"end":263.57,"text":"כמו... רק רגע?"},{"start":263.57,"end":265.73,"text":"מוסרים לי פשוט משהו בזניה?"},{"start":265.73,"end":268.88,"text":"וואו, כנראה שהחלפנו במקומות."},{"start":268.88,"end":270.97,"text":"מייד נתקן זאת."},{"start":270.97,"end":274.78,"text":"תהינו במקומות, תהינו במקומות."},{"start":274.78,"end":282.15,"text":"בשבוע הבא נראיין כאן את ראש השבק,"},{"start":282.15,"end":286.64,"text":"וכמובן מיד אחרי הפרסומות קומדיסטור."},{"start":286.64,"end":288.64,"text":"עוד פעם פרסומות!"},{"start":288.64,"end":290.64,"text":"אלא, עוד פעם צריך לצייר את השתיים האלה."},{"start":290.64,"end":292.64,"text":"רגע, איזה מסלול אתה היום?"},{"start":292.64,"end":293.64,"text":"אתה פנימי לוקח או את החיצו