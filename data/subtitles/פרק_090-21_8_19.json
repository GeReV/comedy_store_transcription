[{"start":5.99,"end":7.99,"text":"שירבה מוקדש ל\"איך יהיה היאש\""},{"start":7.99,"end":14.97,"text":"קבק, קבק את זה"},{"start":14.97,"end":18.53,"text":"מי עשה את זה?"},{"start":18.53,"end":19.72,"text":"את מה?"},{"start":19.72,"end":20.97,"text":"את מה, את החיסול?"},{"start":20.97,"end":21.95,"text":"החדש"},{"start":21.95,"end":23.05,"text":"גימל?"},{"start":23.05,"end":24.11,"text":"לא לא לא"},{"start":24.11,"end":25.1,"text":"נון ב'"},{"start":25.1,"end":27.1,"text":"זה שאנחנו מבטיחים אותו פה באוטו, החדש"},{"start":27.1,"end":28.1,"text":"נון ב'"},{"start":28.1,"end":29.1,"text":"כן כן"},{"start":29.1,"end":30.1,"text":"שבק שלום"},{"start":30.1,"end":31.1,"text":"שבק שלום"},{"start":31.1,"end":32.1,"text":"איך היאש?"},{"start":32.1,"end":34.15,"text":"אתה עשית את זה?"},{"start":34.15,"end":35.15,"text":"מה אתה עשית את זה?"},{"start":35.15,"end":36.15,"text":"אתה נון ב'"},{"start":36.15,"end":38.15,"text":"ניסי משכיל לך נון ב'"},{"start":38.15,"end":39.15,"text":"כן"},{"start":39.15,"end":40.15,"text":"איך היאש?"},{"start":40.15,"end":41.15,"text":"סדר? בום"},{"start":41.15,"end":42.15,"text":"הוא כבר לא מרנדס יותר"},{"start":42.15,"end":43.15,"text":"כן כן"},{"start":43.15,"end":44.15,"text":"יופי יופי"},{"start":44.15,"end":45.05,"text":"כן בטח"},{"start":45.05,"end":47.59,"text":"קח, בשבילך!"},{"start":47.59,"end":49.16,"text":"פלת לוב."},{"start":49.16,"end":51.16,"text":"רגע, רגע, יש לי הרגע תחושה שזה בשבילך."},{"start":51.16,"end":52.16,"text":"תחושה שזה בשבילך."},{"start":52.16,"end":53.16,"text":"מה פתאה שלי זה בשבילך?"},{"start":53.16,"end":54.16,"text":"זה בשבילך."},{"start":54.16,"end":55.1,"text":"תוחה."},{"start":55.1,"end":57.22,"text":"לא, לא, לא, באמת, זה אתה, אתה, תענה."},{"start":57.22,"end":58.22,"text":"בטוח לך אני יודע."},{"start":58.22,"end":59.22,"text":"בטוח לך, הוא בטוח לך."},{"start":59.22,"end":60.22,"text":"תענה אתה, נו."},{"start":60.22,"end":61.22,"text":"מה אני זה בשבילך?"},{"start":61.22,"end":62.22,"text":"תענה!"},{"start":62.22,"end":64.22,"text":"חור, בוא רואה שחצת הבותקילה, אולי זה אבא של בותקילה."},{"start":64.22,"end":66.18,"text":"רגע."},{"start":66.18,"end":67.13,"text":"הלו!"},{"start":67.13,"end":70.41,"text":"רואה, מה זה טוק-טוק אומר? מה אומר טוק-טוק?"},{"start":70.41,"end":71.41,"text":"בשבילך!"},{"start":71.41,"end":72.41,"text":"בשבילך..."},{"start":72.41,"end":75.58,"text":"א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א-א"},{"start":75.58,"end":80.11,"text":"תוכנית זו מבוססת המקרים שהתרחשו במציאות."},{"start":80.11,"end":85.59,"text":"כל קשר בין המציאות לדמיון, הינו מקרי בהחלק."},{"start":85.59,"end":91.19,"text":"כמות האנשים והמקומות שונו, לצורך העלילה."},{"start":91.19,"end":171.76,"text":"ומטה הם נקראים."},{"start":171.78,"end":177.0,"text":"ומטה זה סיכול, שובר סים שיפס לטור ולשתת העבודה."},{"start":177.0,"end":178.12,"text":"איך היה?"},{"start":178.12,"end":185.92,"text":"זאת לא יגע."},{"start":185.92,"end":198.69,"text":"שלו יופי נספר ומשגע את הבנות."},{"start":198.69,"end":200.6,"text":"זה ישתם, צלפים כוונות."},{"start":200.6,"end":202.26,"text":"הוא עצרי מהר, הוא האיש הרי חזק."},{"start":202.26,"end":203.22,"text":"הוא עלוף בקר הטבע."},{"start":203.22,"end":204.18,"text":"איך הוא פתק?"},{"start":204.18,"end":206.12,"text":"גאליסטו!"},{"start":206.12,"end":227.18,"text":"גם אני רוצה לשיר, גם אני רוצה ללכות, גם אני יכול לעשות את זה בשביל לעבוד."},{"start":227.18,"end":230.56,"text":"רוצה לעבוד בטיקס, רוצה לעבוד חיה, בצוב ההופעה, אני רוצה לישום גם לחיה."},{"start":230.84,"end":236.84,"text":"רוצה להיות גנן, רוצה להיות טבח, אני יכול להביא להוב אותך, רוצה לשדר ברד, רוצה להיות מכנן, יכול להביא לעשות את זה בשביל לפולי קר."},{"start":236.84,"end":291.96,"text":"אני סנטיבי, חיה, תלה בום בום בום, סקילה."},{"start":291.96,"end":300.23,"text":"לגברת, לאדון, פיצוחים וגם העיתון, יאללה יאללה, רק באזון."},{"start":300.23,"end":308.06,"text":"הכיאבני, הכיאבני, בוא לך גדול, אני חולה עליך, בוא לך על הכיפה, כל המשברת לאהובים אותך."},{"start":308.06,"end":313.02,"text":"כל יום שישי יושמים רואים את הוילונות שלך, חום אמיצים, אף תוכנית, אין להפרעות או יותר."},{"start":313.02,"end":315.93,"text":"אין להפרעות או יותר, מה אני יכול לחזורך אקי?"},{"start":315.93,"end":319.17,"text":"עודד, ספר לו מה אני רוצה!"},{"start":319.17,"end":325.17,"text":"אקי רוצה 100 גרם גרעינים שחורים, 50 גרם פיסטוק חלבי ו150 גרם אגוזי קשיו."},{"start":325.17,"end":326.87,"text":"אה, עודד!"},{"start":326.87,"end":330.87,"text":"אה, כן, וגם 70 גרם פעירות יבשים לאימא של אקי."},{"start":330.87,"end":334.93,"text":"סך כל הקנייה 47 שקלים ו24 גאות."},{"start":334.93,"end":340.22,"text":"אלא זה עודד הזה יכול להלווש לו כל, כל ארגול, גדול זה, גדול."},{"start":340.22,"end":341.27,"text":"עודד, משהו בשביך עמוד!"},{"start":341.27,"end":344.24,"text":"לא תודה, אני בדיאטה, תודה ששאלת!"},{"start":344.24,"end":345.62,"text":"אפשר?"},{"start":345.62,"end":346.93,"text":"אקשן!"},{"start":346.93,"end":352.58,"text":"יפת בני, למה יחרת לי ואת הכנסת?"},{"start":352.58,"end":355.58,"text":"אמא, אבא, הייתי צל הספר והוא סיפר אותי באף,"},{"start":355.58,"end":358.57,"text":"ואפן לא נכנס לו פנימה לייבש לי את כל השערות,"},{"start":358.57,"end":360.54,"text":"אז זה לקח הרבה זמן ברוח."},{"start":360.54,"end":364.81,"text":"בלי תירוצים, קידוש, לך תתפלל."},{"start":364.81,"end":370.52,"text":"שטוק, ראית הכפסה שחורה קטנה?"},{"start":370.52,"end":377.27,"text":"סרטי \"בקלה\" מציגים, סרטו המזרח-אירופאי של אבימיי,"},{"start":377.27,"end":379.26,"text":"אמיל כישלונובסקי."},{"start":379.26,"end":386.15,"text":"הוא אהב אותה."},{"start":386.15,"end":401.25,"text":"היא חלמה עליו עד שיום אחד הגיע זר לאיירה."},{"start":401.25,"end":406.46,"text":"הם נבהלו, הם הופתעו."},{"start":406.46,"end":410.39,"text":"אך הוא לא ויתר."},{"start":410.39,"end":418.15,"text":"שבע שעות של דיאלוגים נפלאים."},{"start":418.15,"end":419.93,"text":"רישקה!"},{"start":419.93,"end":421.24,"text":"מישקה!"},{"start":421.24,"end":422.17,"text":"תרישקה!"},{"start":422.17,"end":423.24,"text":"מישקה!"},{"start":423.24,"end":424.24,"text":"רישקה!"},{"start":424.24,"end":425.24,"text":"חדרישקה!"},{"start":425.24,"end":427.24,"text":"מישקה בחיית דינק, מישקה!"},{"start":427.24,"end":430.58,"text":"אז הרע, כל מי שצופה בסרט זה,"},{"start":430.58,"end":433.58,"text":"עלול להחמיץ את האוטובוס האחרון הביתה."},{"start":433.58,"end":437.9,"text":"רייל טריינז, או בעברית, החבר'ה של גרישקה."},{"start":437.9,"end":441.11,"text":"עכשיו בקולנוע של ז'דק."},{"start":441.11,"end":452.09,"text":"אבמי?"},{"start":452.09,"end":453.95,"text":"הלו מוטה?"},{"start":453.95,"end":454.05,"text":"אההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":453.95,"end":454.95,"text":"אההה!"},{"start":454.95,"end":457.97,"text":"שו, אני לא מאמינה, אני רואה אותך מרחוק, אני רצתי רצימר."},{"start":457.97,"end":458.97,"text":"יו, אני באלם, החבר'ה שלא ימי לו."},{"start":458.97,"end":460.97,"text":"איך קורם לך, בובה? איך קורם לך?"},{"start":460.97,"end":461.97,"text":"דנה."},{"start":461.97,"end":465.66,"text":"דנה, תעשי סיבוב."},{"start":465.66,"end":467.23,"text":"הופה."},{"start":467.23,"end":468.77,"text":"אוקיי."},{"start":468.77,"end":472.51,"text":"עודד, תספר לה ומה היא זוכה."},{"start":472.51,"end":475.47,"text":"דנה, את זוכה בלל תענוגות עם אקי."},{"start":475.47,"end":479.65,"text":"כן, כן, את זוכה בסטוץ עם אקי אבני."},{"start":479.65,"end":480.65,"text":"יש, אני לא מאמינה!"},{"start":480.65,"end":483.64,"text":"יו, החבר'ות שלו יאמינו לי ואני אגיד להם,"},{"start":483.64,"end":485.64,"text":"יא, איזה גף אני מתה לך!"},{"start":485.64,"end":486.64,"text":"תודה רבה!"},{"start":486.64,"end":488.28,"text":"בבקשה, אקי."},{"start":488.28,"end":490.28,"text":"יש לי, יש לי, יש לי, יש לי!"},{"start":490.28,"end":492.28,"text":"אני אחרתי כי ירד שמש!"},{"start":492.28,"end":494.28,"text":"לא! כי ירד גשם!"},{"start":494.28,"end":499.91,"text":"בלי תרוצים, טמטום!"},{"start":499.91,"end":504.78,"text":"לך תשתפר!"},{"start":504.78,"end":507.71,"text":"אלה, אינגה!"},{"start":507.71,"end":509.63,"text":"אלה, you want me a song sing for you?"},{"start":509.63,"end":512.63,"text":"you know I have a friend,"},{"start":512.63,"end":514.63,"text":"his name is Shaol the Songer."},{"start":514.63,"end":516.63,"text":"he'll do a song for you,"},{"start":516.63,"end":518.63,"text":"you die on the floor."},{"start":518.63,"end":520.63,"text":"here is you,"},{"start":520.63,"end":522.63,"text":"here is Shaol the Songer."},{"start":522.63,"end":524.78,"text":"Shaol sit."},{"start":524.78,"end":527.32,"text":"Shaol, שב אמרתי."},{"start":527.32,"end":529.32,"text":"אלה, אלה, Shaol, הבאתי שבדי, תביא לשיר."},{"start":529.32,"end":531.28,"text":"אלה, אלה, תעזוב אתך בה."},{"start":531.28,"end":533.28,"text":"Shaol, הבאתי שבדי, אל תתפוג אותי, תביא שיר."},{"start":533.28,"end":535.28,"text":"אלה, אז רק נושא."},{"start":535.28,"end":537.41,"text":"תביא שיר על אהבה."},{"start":537.41,"end":539.41,"text":"he'll now do a song on love for you."},{"start":539.41,"end":541.41,"text":"love, oh great."},{"start":541.41,"end":543.41,"text":"אהבה זה דבר מאוד מרגש."},{"start":543.41,"end":545.44,"text":"אהבה חמה, לוהטת כמו אש."},{"start":545.44,"end":547.44,"text":"אם נרדמת אהבה,"},{"start":547.44,"end":551.4,"text":"אני אגדם תאהבה, אני כיץי, ולה יש לה ועד זיץי."},{"start":551.4,"end":556.04,"text":"מה די נשאה? מה די נשאה, פליז?"},{"start":556.04,"end":558.04,"text":"תודה רבה."},{"start":558.04,"end":561.31,"text":"תודה רבה."},{"start":561.31,"end":563.63,"text":"אין אינסן סבגקט."},{"start":563.63,"end":565.99,"text":"מיידי קרימינל."},{"start":565.99,"end":566.99,"text":"קרימינל."},{"start":566.99,"end":570.3,"text":"אמרתי לה לה כך תרוסית אביבה סידה וטובושי."},{"start":570.3,"end":576.61,"text":"תודה רבה."},{"start":576.61,"end":577.61,"text":"תודה רבה."},{"start":578.41,"end":597.75,"text":"יש לך עיניים ממש יפות, עיניים מחשפות, עיניים מטרפות, יש לך עיניים זוגיונים, אבל למה אני רוצה לראות לך את התחתונים."},{"start":609.8,"end":614.68,"text":"תביא... אלא, אלא, אלא, אלא. תביא לו עוד שיר, חמה, חמה, זאתי."},{"start":614.68,"end":615.76,"text":"מעזוב אותך, חמה, חמה."},{"start":615.76,"end":616.96,"text":"עוד שיר אמרתי."},{"start":616.96,"end":617.96,"text":"אלא זרוק נושא."},{"start":617.96,"end":626.37,"text":"תביא שיר, אני ואה, עולים אליי לדירה, מלטפת אותי, עושה לי נעימויות בכל הגוף, מחזיקה אותי ככה."},{"start":626.37,"end":627.07,"text":"מה?"},{"start":627.07,"end":643.91,"text":"אני אגב את רחמים שלנו רוצה שתקחי אותו בכיף, אותו בכל הגוף תתחילי ללטף, אבל למה לך את רחמים עכשיו?"},{"start":643.91,"end":645.96,"text":"קמתו מהירום, ולצמכלאב."},{"start":645.96,"end":660.63,"text":"הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, הלאה, שאול."},{"start":660.63,"end":664.68,"text":"לא, אני, זה, נו, אני, אני חנפתי את הקוסמטיקאית."},{"start":664.68,"end":669.1,"text":"בלי תירוצים, כיעור, לך תשתפץ."},{"start":669.1,"end":675.62,"text":"אח, אקי, אתה היית נפלא."},{"start":675.62,"end":682.55,"text":"תודה, דנה. עודד, ספר לה מה היא קיבלה."},{"start":682.55,"end":688.55,"text":"דנה, את קיבלת הרפס, מתנת אקי אבני, ושבועיים השפוז חינם על חשבוננו."},{"start":688.55,"end":690.52,"text":"סך כל הזכייה, חי שקלים."},{"start":690.52,"end":693.19,"text":"יש שבועיים חינם?"},{"start":693.19,"end":695.66,"text":"פחות או יותר."},{"start":695.66,"end":698.14,"text":"יאללה, סעיס, סעי."},{"start":698.14,"end":699.32,"text":"מה?"},{"start":699.32,"end":700.32,"text":"המתחרה הבאה, סעי."},{"start":700.32,"end":702.94,"text":"אקי, תסדר גם לי משהו."},{"start":702.94,"end":705.54,"text":"עודד, קיבלת אותה."},{"start":705.54,"end":707.54,"text":"תודה, אחי."},{"start":707.54,"end":713.24,"text":"לא יודע, הלכתי ברחוב, פתאום הרגשתי מכה בראש."},{"start":713.24,"end":717.94,"text":"בלי תירוצים, כיפ-קוף, לך תסתפר."},{"start":717.94,"end":727.97,"text":"שומע, אז אני לוקח את מול, ככה לוקח אותה לסרט,"},{"start":727.97,"end":730.94,"text":"יושב איתה בסרט, מתחילים לדבר על כל מיני דברים,"},{"start":730.94,"end":733.9,"text":"פתאום הגיע קטע המוטח, ליצ'י המוטח,"},{"start":733.9,"end":736.28,"text":"ושנינו מסתכלים, אתה יודע, ממש..."},{"start":736.28,"end":737.28,"text":"רגע, רגע, רגע, שני, שני, רגע,"},{"start":737.28,"end":741.44,"text":"אתה אמרת לי משפט נורמלי, ואת פתאום אמרת, אני חושב כמו שכמו ליצ'י,"},{"start":741.44,"end":743.75,"text":"יכול להיות ליצ'י באמצע המשפט אמרת לי?"},{"start":743.75,"end":746.41,"text":"מה אתה מדבר? אני לא מבין אותך."},{"start":746.41,"end":749.41,"text":"אתה רומס שאני עכשיו אמרתי איזשהו משפט,"},{"start":749.41,"end":753.51,"text":"פתאום אמרתי ליצ'י והמשכתי פינצטת המשפט כאילו כלום לא קרה?"},{"start":753.51,"end":755.51,"text":"בידיוק, עכשיו הרגע עשתה זה עוד פעם אותו דבר."},{"start":755.51,"end":757.51,"text":"אמרת המשפט נורמלי, אמרת ליצ'י בסדר כבר,"},{"start":757.51,"end":759.51,"text":"ואני חסרה פתאום פינצטה למשפט."},{"start":759.51,"end":761.51,"text":"איך זה יכול להיות פינצטה למשפט?"},{"start":761.51,"end":763.51,"text":"מה אתה מדבר איתם? אני אומר סתם דברים לא קשורים."},{"start":763.51,"end":765.51,"text":"לא, לא, לא, אני יודע מה זה, אני חושב שאני יודע מה זה,"},{"start":765.51,"end":767.7,"text":"אני קראתי איזה מחקר בעניין הזה."},{"start":767.7,"end":770.7,"text":"יכול להיות שבתת תמודה שלך אתה חושב על הדברים האלה"},{"start":770.7,"end":773.7,"text":"אתה רוצה לעשות, למשל, לאכול ליצ'י, או אני יודע מה, לתעסק עם פינצטה,"},{"start":773.7,"end":777.05,"text":"וזה יוצא לך תוך כדי המשפט, יכול להיות שזה זה, יכול להיות."},{"start":777.05,"end":779.05,"text":"מה זה שטויות האלה? מה זה שטויות האלה?"},{"start":779.05,"end":784.05,"text":"נראה לך שסתם אני אומר דברים בו ליצ'י, פינצטה, כל מיני דברים ששוכבים אצלי"},{"start":784.05,"end":786.97,"text":"בתוך התמודה שאחבתי משתך אתמול, וסתם אני אומר דברים?"},{"start":786.97,"end":788.16,"text":"גם עם אחותך?"},{"start":788.16,"end":797.46,"text":"אני לא רוצה לפרט את המניעים שלי."},{"start":797.46,"end":799.76,"text":"עזבתי את התפקיד, וזהו."},{"start":799.76,"end":802.75,"text":"בלי תירוצים, שבק, לאיך תתפטר."},{"start":802.75,"end":807.01,"text":"יש לי רישיון לבספא, מישהו רוצה שאני הביא לו איזה פיצה או משהו."},{"start":807.01,"end":809.82,"text":"יש ננבנות, יש ננבנות..."},{"start":809.82,"end":812.34,"text":"אימא, ג'ורנל."},{"start":812.34,"end":815.42,"text":"אבל אני איני כזאת."},{"start":815.42,"end":817.26,"text":"אז מה, אבל גם אני איני כזאת."},{"start":817.26,"end":819.42,"text":"אלי כן, איך כזאת, כולם יודעים שאת כזאת."},{"start":819.42,"end":821.1,"text":"אז מה, גם כולם יודעים שאת כזאת."},{"start":821.1,"end":822.33,"text":"אז מה? -אז מה?"},{"start":822.33,"end":825.05,"text":"איזה בינלאומי דנה אינטרנשיונל."},{"start":825.05,"end":826.59,"text":"וואו, איזה זמרת."},{"start":826.59,"end":827.55,"text":"איזה זמר."},{"start":827.55,"end":828.43,"text":"איזה גדולה."},{"start":828.43,"end":829.15,"text":"איזה גדול."},{"start":829.15,"end":830.03,"text":"איזה מוכשרת."},{"start":830.03,"end":830.99,"text":"איזה מוכשר."},{"start":830.99,"end":832.03,"text":"איזה פיגורה."},{"start":832.03,"end":833.05,"text":"איזה פיגור."},{"start":833.05,"end":836.58,"text":"לא מפגרת, מה פיגורה בא לי רעב."},{"start":836.58,"end":838.23,"text":"איך בא לי? סושי?"},{"start":838.23,"end":839.93,"text":"אז מה, ולי בפטוצ'יני."},{"start":839.93,"end":842.23,"text":"אלק פטוצ'יני, את לא צמחונית."},{"start":842.23,"end":843.35,"text":"אז מה, ואת לא טבעוני?"},{"start":843.35,"end":843.91,"text":"אז מה?"},{"start":843.91,"end":844.94,"text":"אז מה?"},{"start":844.94,"end":846.81,"text":"סושי הולך עם יעין לבן."},{"start":846.81,"end":848.89,"text":"אז מה, ופטוצ'יני הולך עם יעין אדום?"},{"start":848.89,"end":850.57,"text":"אלק האדום, את שותה פטל."},{"start":850.57,"end":851.93,"text":"אז מה, ואת שותה מהברז."},{"start":851.93,"end":852.41,"text":"אז מה?"},{"start":852.41,"end":853.06,"text":"אז מה?"},{"start":853.06,"end":856.79,"text":"אית אפשר לדבר איתך בכלל על מסעדות."},{"start":856.79,"end":858.31,"text":"יש לך טעם לוואי."},{"start":858.31,"end":859.99,"text":"אז מה, לנו יש את אותו טעם."},{"start":859.99,"end":863.2,"text":"הלק אותו טעם, את אפילו לא יודעת מה זה לוואי."},{"start":863.2,"end":865.41,"text":"הלק אני לא יודעת מה זה."},{"start":865.41,"end":866.1,"text":"נו."},{"start":866.1,"end":867.7,"text":"הלק לא יודע."},{"start":867.7,"end":868.76,"text":"נו."},{"start":868.76,"end":870.4,"text":"נו, מה זה?"},{"start":870.4,"end":873.78,"text":"איזה פגרת, זה מה זה בסיסי?"},{"start":873.78,"end":876.67,"text":"לוואי זה נגיד..."},{"start":876.67,"end":878.24,"text":"נגיד, את עולה במעלית?"},{"start":878.24,"end":878.8,"text":"נו."},{"start":878.8,"end":880.11,"text":"עם בונג'ובי?"},{"start":880.11,"end":880.97,"text":"נו."},{"start":880.97,"end":882.6,"text":"ואת אומרת לוואי, אני התעקה?"},{"start":882.6,"end":883.12,"text":"נו."},{"start":883.12,"end":885.41,"text":"אז זה זה."},{"start":885.41,"end":887.76,"text":"וואו, מאיפה הולך?"},{"start":887.76,"end":891.38,"text":"מישראל להרוני וחברים פותחים שולחן."},{"start":891.38,"end":895.39,"text":"וואו, על מה את חושבת רכפת?"},{"start":895.39,"end":897.46,"text":"על מנה פלאפל."},{"start":897.46,"end":900.96,"text":"על מה את? -על חצי מנה פלאפל."},{"start":900.96,"end":906.85,"text":"וואו, כמעט טלפתיה. וואו."},{"start":906.85,"end":914.08,"text":"רע, אקי! -הלו דוקטור. -רגיש טוב."},{"start":914.08,"end":917.21,"text":"פחות או יותר. -ספר מה הבעיה."},{"start":917.21,"end":920.38,"text":"עודד, ספר לו מה יש לי."},{"start":920.38,"end":926.52,"text":"אתה רואה, דוקטור? אני לא יכול לתקשר עם אנשים."},{"start":926.52,"end":928.78,"text":"מה, אתה לא יכול להגיד לבד מה הבעיה?"},{"start":928.78,"end":929.63,"text":"לא."},{"start":929.63,"end":934.94,"text":"עודד, עודד, עודד, ספר לי, ספר לי מה הבעיה."},{"start":934.94,"end":941.95,"text":"דוקטור, יש לי שתי מצקות בגרון וגם שפט שקיבלתי מתנה מדנה שקיבלתי מאקי אבני."},{"start":941.95,"end":946.53,"text":"עודד עם יו, עודד, פגדול אהה."},{"start":946.53,"end":954.97,"text":"ככה, תשמע, תיתן לו אנטיביוטיקה פעמיים ביום ואני רוצה אתכם פה לבדיקת מעקב."},{"start":954.97,"end":959.74,"text":"תודה, דוקטור, ולהתראות בשבוע הבא."},{"start":959.74,"end":964.84,"text":"אנחנו עוד נחזור אליכם עם פחות או יותר."},{"start":964.84,"end":977.35,"text":"עוד פרק מעלילות חסמבה, חסמבה בשירות השבק."},{"start":977.35,"end":980.88,"text":"חסמבהים, עוקבים אחריי."},{"start":980.88,"end":983.23,"text":"אמר ירון זהבי באומץ לב."},{"start":983.23,"end":987.05,"text":"מי, אלימלך זורקין הרשע? מה פתאום מי המלאפפון רבי?"},{"start":987.05,"end":990.53,"text":"החבר'ה צחקו מן הבדיחה המוצלחת."},{"start":990.53,"end":995.37,"text":"הוא התכווה לשירות הכווח הרי בטלפון, מה לא ראית את הפרסומך?"},{"start":995.37,"end":999.42,"text":"שוב צחקו החבר'ה צחוק מוגזם ובמשחק גרוע."},{"start":999.42,"end":1004.42,"text":"לא חסמבהים, הפעם אל עובנו אכזרים."},{"start":1004.42,"end":1007.45,"text":"החל דאגה, מצאתי שיטה חדשה למגר אותה."},{"start":1007.45,"end":1009.79,"text":"מה עם מפקדי היקר והאהוב?"},{"start":1009.79,"end":1010.97,"text":"נא!"},{"start":1010.97,"end":1015.84,"text":"לוקחים פלאפון, שולפים את הנצרה ומחייגים."},{"start":1015.84,"end":1019.83,"text":"כוכבית 21, 22, 23."},{"start":1019.83,"end":1023.52,"text":"צאץ!"},{"start":1023.52,"end":1026.43,"text":"הלכה המערה החשמלית."},{"start":1026.43,"end":1028.61,"text":"חסמבהים, תדרוך!"},{"start":1028.61,"end":1035.89,"text":"חייגו 21, חכו לצליל של כלום, חייגו את המספר ותשמעו את הבום."},{"start":1035.89,"end":1046.82,"text":"חייגו 21, חכו לצליל של כלום, חייגו את המספר ותשמעו את הבום."},{"start":1046.82,"end":1051.3,"text":"חייגו 21, חכו לצליל של כלום, חייגו את המספר ותשמעו את הבום."},{"start":1051.3,"end":1053.12,"text":"הלו, יחיה?"},{"start":1053.12,"end":1059.84,"text":"המנוי אינו זמין קייץ, המנסנו שוב ורוחה יותר. תודה."},{"start":1059.84,"end":1064.06,"text":"יו, ברו, what is your name, Mann?"},{"start":1064.06,"end":1067.37,"text":"What is your name, Mann? I ain't a name, Mann, I see a skill."},{"start":1067.37,"end":1072.22,"text":"Now tell me, you wanna work in the MTV? You wanna work in the MTV? Tell me about yourself, Mann!"},{"start":1072.22,"end":1087.42,"text":"אני מתחסי כל, שובר סים שקים, הסמימה הבעיה."},{"start":1087.42,"end":1090.78,"text":"אני מתחסי כל בין השקת העבודה. איך היה?"},{"start":1090.78,"end":1104.88,"text":"תסותו ליקה."},{"start":1104.88,"end":1116.45,"text":"טויופי נסבור ומשגע את הבנות, יוצא חכם האשטיין צלפים כוונות, הוא עצר עם ההר, הוא האיש הכי חזק, הוא עלו בקרדבר, איך הוא במשחד?"},{"start":1116.45,"end":1118.27,"text":"אז כה גארסטו!"},{"start":1118.27,"end":1149.38,"text":"לא מנים עוד שיר, גם אני רוצה ללכות, גם אני יכול לעשות את זה בשביליו, רוצה לעבוד בטיקס, רוצה לעלת חיה, בצוב ההופע, אני רוצה לשום גם מחיה, רוצה להיות גנן, רוצה להיות טבח, אני יכול להביא לאורותיו, רוצה לשדר ברד, רוצה להיות מכיני, יכול להביא לעשות פליטוי, לפוליקר."},{"start":1151.77,"end":1202.43,"text":"תודה רבה."}]