[{"start":31.87,"end":34.45,"text":"לסטור!"},{"start":113.48,"end":117.45,"text":"איך קוראים לתרנגולת שיודעת לשיר ולרקוד? -נו!"},{"start":117.45,"end":119.57,"text":"אוף מוחשר! יאללה!"},{"start":119.57,"end":122.08,"text":"אוף מוחשר! -נו!"},{"start":122.08,"end":126.2,"text":"איך קוראים לבצק שיודע להרביץ? -נו!"},{"start":126.2,"end":128.2,"text":"בצק אלים!"},{"start":128.2,"end":130.2,"text":"הוא אלים!"},{"start":130.2,"end":132.2,"text":"היי טובים!"},{"start":132.2,"end":134.2,"text":"יש לי, יש לי, יש לי!"},{"start":134.2,"end":138.2,"text":"איך קוראים לדג שמבושל ברוטב עגווניות?"},{"start":138.2,"end":140.2,"text":"איך? -חריים!"},{"start":140.2,"end":152.31,"text":"ערב טוב! שוב אתם במדריך כיצד נתנהג הנכון,"},{"start":152.31,"end":155.41,"text":"והפעם, עצות לספר המתחיל."},{"start":155.41,"end":157.52,"text":"ראשית, הגיע הלקוח."},{"start":157.52,"end":159.52,"text":"נסה להנעים את זמן המתנתו."},{"start":159.52,"end":161.47,"text":"שלום. -שלום."},{"start":161.47,"end":163.47,"text":"אדוני זמן טוב. -וודאי."},{"start":163.47,"end":166.01,"text":"מת על הקו הזה. -תודה."},{"start":166.01,"end":167.01,"text":"הסתפרת פה? -לא."},{"start":167.01,"end":170.1,"text":"ובכן, עיין בינתיים בז'ורנל הזה, בסדר?"},{"start":170.1,"end":171.1,"text":"מיד נתפלא עיניך."},{"start":171.1,"end":173.13,"text":"אלברט, תרים את הכיסא."},{"start":173.13,"end":177.13,"text":"היה עדיב ונסה לתת ללקוח הרגשה שמיד יגיע תורו."},{"start":177.13,"end":179.13,"text":"זה ייקח דקה או שתיים, בסדר?"},{"start":179.13,"end":181.13,"text":"אולי תון או שניים ככה לפני שאתה מסתפר."},{"start":181.13,"end":183.31,"text":"כך תקרה משמרת."},{"start":183.31,"end":185.34,"text":"עמוד."},{"start":185.34,"end":187.01,"text":"אלבר!"},{"start":187.01,"end":189.98,"text":"כדאי לגוון את שעות העבודה האפרוריות במעט שמחת חיים."},{"start":189.98,"end":192.2,"text":"אך, אל תגזים."},{"start":192.2,"end":193.2,"text":"שבבקשה, אדוני."},{"start":193.2,"end":195.2,"text":"אצלנו תרגיש בניחותה."},{"start":195.2,"end":196.2,"text":"הופלה!"},{"start":196.2,"end":198.17,"text":"אדוני, שתקרה, מה אתה עושה?"},{"start":198.17,"end":200.39,"text":"סתם צחוק עם ידיים, אדוני."},{"start":200.39,"end":201.48,"text":"בבקשה."},{"start":201.48,"end":202.67,"text":"הופלה!"},{"start":202.67,"end":203.67,"text":"סופרמר!"},{"start":203.67,"end":209.66,"text":"השתדל להתאים ללקוח, תספורת שתהלום אותו."},{"start":209.66,"end":212.77,"text":"יש לי בדיוק את הקו שיתאים למבנה הפנים שלך."},{"start":212.77,"end":214.72,"text":"בבקשה."},{"start":214.72,"end":218.64,"text":"אדוני למבסות? מה את התחל זה?"},{"start":218.64,"end":220.61,"text":"אופה, אדוני! אדוני, את אלה לא ראית, אדוני!"},{"start":220.61,"end":222.95,"text":"רצוי להשתמש בכלי עבודה מקובלים."},{"start":222.95,"end":224.95,"text":"אדוני, הוא רוצה אולי רולים בשיער?"},{"start":224.95,"end":226.98,"text":"לא לא לא, אני מעדיף קצוץ."},{"start":226.98,"end":228.98,"text":"קצוץ! אין בעיה."},{"start":228.98,"end":234.92,"text":"חשוב להכיר את כלי העבודה שלך ודרך תפעולם."},{"start":234.92,"end":242.22,"text":"הריכוז בעבודה חשוב מאוד."},{"start":242.22,"end":245.22,"text":"אל תיתן לדבר להשיח את דעתך."},{"start":245.22,"end":247.34,"text":"אלברט, מה עם הקפה שלך?"},{"start":247.34,"end":255.13,"text":"אלו, כן אלי, איתך כל הזמן אלי, כן."},{"start":255.13,"end":257.21,"text":"מה אתה אומר? אז בא אותך?"},{"start":257.21,"end":259.13,"text":"נו אז תחתוך, מה הבעיה? תחתוך אלי."},{"start":259.13,"end":263.97,"text":"אה, אתה לא רוצה. טוב, לא נורא. אלי, תשמע, אני פידוק באמצע עבודה."},{"start":263.97,"end":266.99,"text":"בסדר? מה אתה אומרת? מה עם הכסף שאתה חייב לי? אלי!"},{"start":266.99,"end":269.98,"text":"אלי, זה פעם אחרונה שאני מנפה לך משהו אלי!"},{"start":269.98,"end":275.05,"text":"במידה ואתה משתמש בחומרי טיפוח קוסמטיים, בדוק אותם שמפג תוקפם."},{"start":275.05,"end":277.05,"text":"יהיה בסדר אדוני, אתה תרגיש ממש..."},{"start":277.05,"end":280.39,"text":"קצת אזריים אתה יכול..."},{"start":280.39,"end":283.75,"text":"יופה!"},{"start":283.75,"end":285.67,"text":"תודה אדוני"},{"start":285.67,"end":286.76,"text":"וואו"},{"start":286.76,"end":290.1,"text":"תעמי לי אגל לזה החזיק לך כל החיים"},{"start":290.1,"end":291.1,"text":"תודה רבה"},{"start":291.1,"end":294.86,"text":"בשעה טובה סיימת את עבודתך"},{"start":294.86,"end":298.88,"text":"נסה לתת ללקוח הרגשה שזוהתי ספורת הטובה ביותר בשבילו"},{"start":298.88,"end":303.44,"text":"בבקשה, מבסות אדוני"},{"start":303.44,"end":305.91,"text":"בוא תראה מאחורה"},{"start":305.91,"end":308.54,"text":"איזה יופי"},{"start":308.54,"end":311.13,"text":"ממש כמו כוכב קולנוע"},{"start":311.13,"end":313.41,"text":"תוצאה שלא היית מביישת אף אחד"},{"start":313.41,"end":317.07,"text":"זכור, מתן טיפ הוא רשות ולא חובה"},{"start":317.07,"end":318.71,"text":"חמישים שקלים בבקשה"},{"start":318.71,"end":321.71,"text":"בבקשה אדוני אני אמליץ לכל החברים שלי על המספרה הזאת"},{"start":321.71,"end":323.71,"text":"פשוט מעולה, תודה רבה"},{"start":323.71,"end":325.71,"text":"אדוני לא שכח משהו?"},{"start":325.71,"end":328.06,"text":"מה שכחתי?"},{"start":328.06,"end":329.92,"text":"מה?"},{"start":329.92,"end":330.92,"text":"אולי"},{"start":330.92,"end":332.11,"text":"אני לא מבין מה"},{"start":332.11,"end":333.11,"text":"אני לא מבין"},{"start":333.11,"end":335.4,"text":"דבר ברור, אני לא מבין"},{"start":335.4,"end":337.4,"text":"כמה שקלים, כמה שולים לזפה"},{"start":337.4,"end":339.56,"text":"קח משהו לגרון אדוני"},{"start":339.56,"end":343.13,"text":"ולסיכום, בפעם הבאה כשתרצה להיות ספר"},{"start":343.13,"end":345.21,"text":"עדיף שתהיה גנן"},{"start":345.21,"end":348.53,"text":"זה הכל, לילה טוב והמשך צפייה"},{"start":348.53,"end":363.68,"text":"תודה רבה"},{"start":363.68,"end":381.68,"text":"תודה רבה"},{"start":381.68,"end":387.68,"text":"תודה רבה"},{"start":387.68,"end":389.68,"text":"תודה רבה"},{"start":389.68,"end":390.68,"text":"תודה רבה"},{"start":390.68,"end":393.68,"text":"תודה רבה"},{"start":393.68,"end":394.68,"text":"תודה רבה"},{"start":394.68,"end":395.68,"text":"תודה רבה"},{"start":395.68,"end":396.68,"text":"תודה רבה"},{"start":396.68,"end":398.68,"text":"תודה רבה"},{"start":398.68,"end":400.65,"text":"תודה רבה"},{"start":400.65,"end":401.64,"text":"תודה רבה"},{"start":401.64,"end":403.64,"text":"תודה רבה"},{"start":403.64,"end":404.64,"text":"תודה רבה"},{"start":404.64,"end":405.64,"text":"תודה רבה"},{"start":405.64,"end":407.27,"text":"תודה רבה"},{"start":407.27,"end":408.45,"text":"תודה רבה"},{"start":408.45,"end":412.25,"text":"נורי, איך נכנע ילו פתתרשاקו מביל וסבאסיה?"},{"start":412.25,"end":414.31,"text":"על עיין וענגעסי תפדלי."},{"start":414.31,"end":418.47,"text":"נורי, מן ברامج הסעודיה מן תלפייסיון אלה ישראלי"},{"start":418.47,"end":420.89,"text":"פתאسעה ונוש דקיקה פל מסלסל אלף?"},{"start":420.89,"end":422.81,"text":"מוש פהים."},{"start":422.81,"end":426.39,"text":"בעד נקליל פתאים ונוש פתתרשاקו לינגו גיללון."},{"start":426.39,"end":427.59,"text":"שו בידה?"},{"start":427.59,"end":432.64,"text":"ובעד נקליל פתתרשاקו מן ברامج הסעודיה מן תלפייסיון אלה כפל תעסע ונוש"},{"start":432.64,"end":433.72,"text":"פל מסלסל מגייבר."},{"start":433.96,"end":434.96,"text":"זה מהבולה הבא."},{"start":434.96,"end":436.2,"text":"שוקרן."},{"start":436.2,"end":437.5,"text":"אני מגנונה כבירי."},{"start":437.5,"end":438.56,"text":"שוקרן."},{"start":438.56,"end":440.53,"text":"אדיבי סכינון."},{"start":440.53,"end":442.83,"text":"ביר בלעקבו גמיל על התלפייסיון."},{"start":442.83,"end":446.31,"text":"פתמניה עונוס דקיקה בעדן כליל אלה לקה."},{"start":446.31,"end":448.49,"text":"אלה לקה."},{"start":448.49,"end":451.7,"text":"איזה מגנונה הזה, אה?"},{"start":451.7,"end":453.09,"text":"אלה לקה."},{"start":453.09,"end":457.38,"text":"שמעון."},{"start":457.38,"end":457.94,"text":"מה?"},{"start":457.94,"end":459.18,"text":"אל תשאר."},{"start":459.18,"end":460.1,"text":"מה קרה?"},{"start":460.1,"end":461.32,"text":"בעלי מחשבה."},{"start":461.32,"end":462.38,"text":"עוד פעם?"},{"start":462.38,"end":464.66,"text":"כן, אבל הפעם אחו שלך של מחשבה שימו."},{"start":464.66,"end":465.16,"text":"מה עכשיו?"},{"start":465.16,"end":467.15,"text":"מה היינו חושבים עד היום זה בחורה?"},{"start":467.15,"end":467.65,"text":"מה?"},{"start":467.65,"end":469.43,"text":"בחורה זה כמו פרח."},{"start":469.61,"end":470.22,"text":"כמו פרח."},{"start":470.22,"end":471.74,"text":"זה כמו ירח בלילה."},{"start":471.74,"end":472.44,"text":"כמו ירח."},{"start":472.44,"end":473.68,"text":"כמו שושנה בליקוצים."},{"start":473.68,"end":474.38,"text":"זה יפה."},{"start":474.38,"end":474.8,"text":"לא."},{"start":474.8,"end":475.33,"text":"מה?"},{"start":475.33,"end":477.07,"text":"בחורה זה כמו סלט חצילים."},{"start":477.07,"end":478.81,"text":"מה קרה לי עם אשך?"},{"start":478.81,"end":485.83,"text":"לא קרה לה כלום, תזהר ממני וחוץ מזה שלא קרה לה כלום זה לא כמו סלט חצילים אצל ג'ינו, אלא סלט חצילים אצל חיימון בסטקייה."},{"start":485.83,"end":489.74,"text":"מה? אבל ב... לא ישיבים אצלו הבחורות."},{"start":489.74,"end":490.3,"text":"אצל מי?"},{"start":490.3,"end":491.08,"text":"אצל חיימון."},{"start":491.08,"end":493.78,"text":"אבל אני מדבר איתך במישור הפילוסופי, אני מדבר איתך קטן."},{"start":493.88,"end":496.38,"text":"אה, תתגלגל איתי במחשבה הפילוסופי."},{"start":496.38,"end":496.94,"text":"בסדר, מתגלגל."},{"start":496.94,"end":497.84,"text":"והנה אנחנו הולכים."},{"start":497.84,"end":499.62,"text":"הנה אנחנו במחשבה הולכים, נכון?"},{"start":499.62,"end":500.12,"text":"הולכים."},{"start":500.12,"end":502.84,"text":"פתאום בא לך לאכול סלט חצילים."},{"start":502.84,"end":503.86,"text":"מתיישב לך עם ההיגיון?"},{"start":503.86,"end":504.34,"text":"יושב."},{"start":504.34,"end":504.9,"text":"יושבים?"},{"start":504.9,"end":505.78,"text":"יושבנו."},{"start":505.78,"end":506.18,"text":"יושבת?"},{"start":506.18,"end":506.88,"text":"אכלתי."},{"start":506.88,"end":507.4,"text":"יושבתי."},{"start":507.4,"end":507.82,"text":"בסדר."},{"start":507.82,"end":509.31,"text":"מה אתה עושה? מזמין."},{"start":509.31,"end":510.31,"text":"מזמין."},{"start":510.31,"end":510.99,"text":"מה אתה מזמין?"},{"start":510.99,"end":511.77,"text":"סלט חצילים."},{"start":511.77,"end":513.09,"text":"יפה. ומה אתה עושה?"},{"start":513.09,"end":514.16,"text":"אוכל אותו."},{"start":514.16,"end":514.7,"text":"לא."},{"start":514.7,"end":516.64,"text":"פה הטעות."},{"start":525.4,"end":526.58,"text":"אצל ז'ינו למשל,"},{"start":526.58,"end":528.72,"text":"אתה יכול לשבת אצלו ויש אחלה סלט."},{"start":528.72,"end":533.92,"text":"אתה מקבל סלט חצילים מסודר יפה עם כל מיני פתיטים של פטרוזיליה, נכון?"},{"start":533.92,"end":534.38,"text":"כן."},{"start":534.38,"end":536.41,"text":"זה נראה לך טוב בצורה חיצונית?"},{"start":536.41,"end":537.59,"text":"חיצונית כן."},{"start":537.59,"end":540.15,"text":"אבל כשאתה טועם את הסלט זה חרה של סלט."},{"start":540.15,"end":547.11,"text":"ואז היא מתיישב לך עם הנקודת מבט הפילוסופי."},{"start":547.11,"end":549.93,"text":"שבחורה זה בדיוק כמו סלט חצילים."},{"start":549.93,"end":551.89,"text":"אצל ז'ינו ולא אצל חיימון."},{"start":551.89,"end":553.53,"text":"לא אצל חיימון אבל לא אצל ז'ינו."},{"start":553.53,"end":554.13,"text":"בדיוק."},{"start":554.13,"end":555.59,"text":"הבנתי."},{"start":555.67,"end":557.71,"text":"אני יכול לשאול אותך שאלה במישור הפילוסופי."},{"start":557.71,"end":558.27,"text":"כל הזמן."},{"start":558.27,"end":562.2,"text":"נניח שאתה יושב אצל חיימון ואוכל סלט חצילים."},{"start":562.2,"end":563.05,"text":"יושב."},{"start":563.05,"end":563.72,"text":"שבים."},{"start":563.72,"end":564.48,"text":"ישבנו."},{"start":564.48,"end":565.16,"text":"ישבתי."},{"start":565.16,"end":567.33,"text":"הזמנו סלט חצילים, אכלנו אותו טעים."},{"start":567.33,"end":567.93,"text":"טעים."},{"start":567.93,"end":568.61,"text":"טעים מאוד."},{"start":568.61,"end":569.01,"text":"יפה."},{"start":569.01,"end":572.99,"text":"אבל הסלט חצילים לא רוצה אותך."},{"start":572.99,"end":577.82,"text":"תגיד, מה קרה לי עם אשך, שמעון?"},{"start":577.82,"end":581.33,"text":"לא קרה לה כלום, אני מדבר במישור הפילוסופי."},{"start":581.33,"end":586.68,"text":"אה, זה סוגיה שלא חשבתי עליה."},{"start":586.68,"end":587.46,"text":"אתה רואה?"},{"start":587.46,"end":597.8,"text":"אבל רגע, שמעון, עכשיו אני יודע, בחורה זה לא כמו סלט חצילים אצל חיימון גם, כי הסלט חצילים יכול גם לא לרצות אותך במישור הפילוסופי."},{"start":597.8,"end":598.32,"text":"בדיוק."},{"start":598.32,"end":600.24,"text":"בחורה זה כמו חיימון."},{"start":600.24,"end":601.27,"text":"מה?"},{"start":601.27,"end":603.29,"text":"חיימון תמיד רוצה אותך."},{"start":603.29,"end":607.87,"text":"אה, נכון, בחורה זה בדיוק כמו חיימון."},{"start":607.87,"end":608.89,"text":"בדיוק כמו חיימון."},{"start":608.89,"end":609.31,"text":"יפה."},{"start":609.31,"end":611.35,"text":"אה, לנושה, עכשיו זה ברור."},{"start":611.35,"end":611.84,"text":"כן."},{"start":611.84,"end":617.84,"text":"וואלה, שמעון, שאני ככה מביט, בא לי עוד מחשבה."},{"start":617.84,"end":619.1,"text":"מה?"},{"start":619.1,"end":625.85,"text":"ידידות, זה כמו סלטה בטבוחה."},{"start":625.85,"end":628.67,"text":"יאללה, ביי."},{"start":628.67,"end":631.22,"text":"לאן אתה הולך, שמעון?"},{"start":631.22,"end":635.31,"text":"אני הזהרתי אותך, מה התחלתי ללכת לי בחיים באמצע של המחשבה?"},{"start":635.31,"end":645.22,"text":"יש לי, מי יודע מה זה?"},{"start":645.22,"end":646.31,"text":"מה זה?"},{"start":646.31,"end":648.31,"text":"לא יודע, אבל הנה בא עוד אחד."},{"start":648.31,"end":652.73,"text":"יש לי גם כן, יש לי גם כן."},{"start":652.73,"end":654.69,"text":"מי יודע מה זה?"},{"start":654.69,"end":655.83,"text":"לא."},{"start":655.83,"end":657.27,"text":"זה כזה ברוורס."},{"start":657.27,"end":661.81,"text":"יש לי, יש לי."},{"start":661.81,"end":663.09,"text":"יאללה, שימו לב."},{"start":663.09,"end":663.91,"text":"מה זה?"},{"start":664.61,"end":667.07,"text":"זה לך שיקור."},{"start":667.07,"end":669.11,"text":"אם לא היה שיקור, היום שיקחה."},{"start":669.11,"end":674.65,"text":"יש לי, יש לי, יש לי, יש לי."},{"start":674.65,"end":676.55,"text":"מי יודע מה זה?"},{"start":676.55,"end":677.45,"text":"מה זה?"},{"start":677.45,"end":680.63,"text":"שלום, שלום, מה נשמע?"},{"start":680.63,"end":684.79,"text":"להתראות, הלוא, אני פה, הלוא."},{"start":684.79,"end":688.41,"text":"ערב טוב."},{"start":688.41,"end":689.85,"text":"הרי די אשיגי הזה עקה."},{"start":689.85,"end":691.59,"text":"מכח חדשה פוקדת את הלפים."},{"start":691.59,"end":694.07,"text":"המסלמה המשוטטת של ג'ודי."},{"start":694.86,"end":696.09,"text":"ערב טוב."},{"start":696.09,"end":701.59,"text":"כאן ג'ודי לא צהרונוב, נפוליון בונה פרטס וכן נקצה חינוי גבינה לבנה."},{"start":701.59,"end":705.27,"text":"אה, הרמתי עליכם, חשבתם נכון?"},{"start":705.27,"end":706.81,"text":"ערב טוב."},{"start":706.81,"end":711.58,"text":"כאן ג'ודי לא צהרונוב, קרפין בני עקיבא והנוער העובד והלומד."},{"start":711.58,"end":715.9,"text":"צופים בשומר הצעיר ובר'ה לקצנלסון צער חוצה."},{"start":715.9,"end":718.78,"text":"אבא ואמא התנו לך עוגה."},{"start":718.78,"end":723.36,"text":"מכח חדשה נוחתת על המדינה התנועת נוער רומניה."},{"start":723.36,"end":731.16,"text":"כל התקסים, חיי החברה, הווי היום יומי והפולקלור המיוחד שהיו עד כה נחלתם של תנועת הנוער,"},{"start":731.16,"end":738.88,"text":"חלחלו עד למעמקי החברה הישראלית והפכו למנעת חלקם של כלל הציבור התמים."},{"start":738.88,"end":744.45,"text":"לקחנו את המצלמה המשוטטת ויצאנו לבדוק הכתנועתה."},{"start":744.45,"end":748.13,"text":"כאן א' ד' גורדון, פינה דיזינגוף."},{"start":748.13,"end":751.49,"text":"קופץ אליי, באתי לראות סצרטים, אני גר פה לא רחוק."},{"start":751.49,"end":753.93,"text":"הלב ההגשם, הלא נעלה!"},{"start":753.93,"end":757.69,"text":"סלין, אבינו, ברוסיה עימנו!"},{"start":757.69,"end":764.36,"text":"רבר'ה, חמוד, אוקיי, שימו לב."},{"start":764.36,"end":766.8,"text":"דבר ראשון לפני שמתחיל בלאכול: ברכת המזון!"},{"start":766.8,"end":771.08,"text":"ג'ימליה! ג'ימ! ג'ימליה! ג'ימ! ג'ימליה!"},{"start":771.08,"end":776.78,"text":"אנחנו עוד לא אכלו שום דבר, ושום דבר רדושתנו!"},{"start":776.78,"end":781.95,"text":"פלח לי מה שעה, אני גאה להדליק את השעה."},{"start":781.95,"end":784.57,"text":"שמונה ושלושים!"},{"start":784.57,"end":792.35,"text":"בעוד כדקה יגיעו הנה האופרים משבט עציר להדליק את השעה, שמונה שלושים ואחת!"},{"start":792.35,"end":795.32,"text":"נה, בבקשה!"},{"start":795.32,"end":797.89,"text":"אדוני המציל, אני מבין שנפגעת מהמגפה."},{"start":797.89,"end":801.47,"text":"נפגעתי מאוד, הפרנסה שלי עלך, אני עבדתי בכבוד, עשרים שנה."},{"start":801.47,"end":803.79,"text":"הייתי שם בסוכה שלי, ממעין סוכה הייתי,"},{"start":803.79,"end":806.83,"text":"הייתי תדגלים בסוכה, דגל הדוד, דגל שחרות, דרגל חול,"},{"start":806.83,"end":810.35,"text":"עד שהתחיל המשוגעים האלה, עם התנועות נוערים, המשחק שלהם שתי דגלים."},{"start":810.35,"end":813.63,"text":"זה משחק שהם כולבים תדגלים, המחנות שלהם, הם כולבים..."},{"start":813.63,"end":821.13,"text":"המצילים, הפוצים, מהתחת הם יוצאים, הנה לא איתו, בוא לפה, בוא לפה."},{"start":821.13,"end":833.16,"text":"חופשי יקשב, חופשי יקשב, לקברת הרשגדית, ג'ודי, הגדוד יעבור להקשב, בזצת, דרגור."},{"start":833.16,"end":837.41,"text":"סליחה, אשן מפריע לי, תחברו, מבקשה, את הסיגריה."},{"start":837.41,"end":841.51,"text":"טוב, יאללה, טיבוי צופים. טיבוי צופים, קדימה."},{"start":841.51,"end":843.74,"text":"רוצה לבוא לעזור? בוא."},{"start":843.74,"end":850.69,"text":"הלו, רחוב ארץ, אלא איך אני מגיע?"},{"start":850.69,"end":875.38,"text":"רואו שבו ואני אגלה לכם. אתם הולכים ישר, ישר, ישר. ממשיכים ללכת בכיוון הזה עד שאתם מגיעים לכיכר הגולה. שם אתם פונים ימינה. ממשיכים ללכת עד שפתאום אתם מגיעים ל... רמזון! יאו, וואי, וואי, חבילי אותה מהפתוחה. יאללה, רמזון, רמזון, רמזון, רמזון, תשפת גדול, תשפת גדול."},{"start":875.38,"end":877.76,"text":"לא תהבתם? כן. תנו לי דלת."},{"start":877.76,"end":882.17,"text":"תנו לי שין. תנו לי א'."},{"start":882.17,"end":892.7,"text":"ומה קיבלנו? נא, לא לדרוך על הדשת! יותר חזק! נא, לא לדרוך על הדשת! הכי חזק!"},{"start":892.7,"end":899.83,"text":"אני חוזר ומדגיש לציבור בארץ, אין מה לדאוג. משטרת ישראל תטפל בבעיית התנועת רומניה הזאת אחת ולתמיד."},{"start":899.83,"end":906.83,"text":"בזה הרגע אני שוקד על הקמת מתה מיוחד שיתפל במגפה הזאת ויחסל אותה מן העולם. תודה רבה לכם."},{"start":906.83,"end":913.27,"text":"הלו! מישהו יודע פה קשר מאוד משהו הלו! בפיצת עוגם, קשר סבתא הלו!"},{"start":913.27,"end":916.22,"text":"נה לא לדרוך על הדשא!"},{"start":916.22,"end":919.12,"text":"נה לא לדרוך על הדשא!"},{"start":919.12,"end":922.64,"text":"נה נה לדרוך על הדשא!"},{"start":922.64,"end":923.64,"text":"לא, לא נכון."},{"start":923.64,"end":924.64,"text":"סוף סוף, אתמול יצאתי מחד."},{"start":924.64,"end":926.64,"text":"לא מאמין לי, לא יתייחסה אליך בטח."},{"start":926.64,"end":927.64,"text":"בטח בעיניים שלי, אתה לא מאמין להגדון."},{"start":927.64,"end":928.64,"text":"אתה צבמך, אני לא מאמין לך."},{"start":928.64,"end":929.64,"text":"נשבע לך!"},{"start":929.64,"end":930.64,"text":"לא מאמין!"},{"start":930.64,"end":931.64,"text":"נשבע!"},{"start":931.64,"end":932.64,"text":"נשבע!"},{"start":932.64,"end":933.64,"text":"לא, שבע אבל!"},{"start":933.64,"end":937.56,"text":"צופי יקר, צופי חביב,"},{"start":937.56,"end":941.56,"text":"כל חוקתי חשמור לזולת תמיד תעזור!"},{"start":941.56,"end":942.56,"text":"זכור תזכור!"},{"start":942.56,"end":943.56,"text":"צופי יקר!"},{"start":943.56,"end":944.56,"text":"צופי יקר!"},{"start":944.56,"end":945.56,"text":"צופי יקר!"},{"start":945.56,"end":946.56,"text":"צופי יקר!"},{"start":946.56,"end":948.62,"text":"צופי יקר!"},{"start":948.62,"end":951.09,"text":"אתה מאמין לי?"},{"start":951.09,"end":952.03,"text":"הוא היה!"},{"start":952.03,"end":954.91,"text":"ואח הוא היה!"},{"start":954.91,"end":960.15,"text":"אכן תמונות קשות ומושיעים"},{"start":960.15,"end":964.15,"text":"במצב החמור כחמור זועק השמימה"},{"start":964.15,"end":968.21,"text":"מכת תנועות הנוער כעתונות נוערות ישמע"},{"start":968.21,"end":973.21,"text":"ובאה אל הבנים שמלוכ לך כל הימים וזבובים לאלפים"},{"start":973.21,"end":978.27,"text":"ורק הטבך יושב בין הסירים ובשל את הביצים"},{"start":978.27,"end":983.65,"text":"כאן הי היונה היונה פעמונה גן הפעמון"},{"start":983.65,"end":993.06,"text":"ערב צח ערב זח שוב אתם ביתי"},{"start":993.06,"end":996.06,"text":"והפעם רציתי להחגוג איתכם ביחד את יום העם"},{"start":996.06,"end":998.06,"text":"שנחגג לפני ימים ספורים"},{"start":998.06,"end":1000.06,"text":"ובכן סביחה גדולה יום העם באימא שלי"},{"start":1000.06,"end":1002.06,"text":"קוראים לזה בעצם יום המשפחה"},{"start":1002.06,"end":1004.06,"text":"אבל אף אחד לא יודע מזה"},{"start":1004.06,"end":1006.06,"text":"אבא סמרטוט, הילדים בגד"},{"start":1006.06,"end":1008.06,"text":"אמא חוגגת"},{"start":1008.06,"end":1010.06,"text":"אני בכלל מציע להרחיב את יום העם"},{"start":1010.06,"end":1012.06,"text":"ושיהיה גם בצבא יום העם 16"},{"start":1012.06,"end":1014.06,"text":"בטלוויזיה יום העם TV"},{"start":1014.06,"end":1016.06,"text":"בכלל שיהיה יום העם, יו דו וווי אר"},{"start":1016.06,"end":1018.06,"text":"אבריבדי כלאוי וכדומה"},{"start":1018.06,"end":1020.12,"text":"באמא שלי זה יהיה יום חג לאומי"},{"start":1020.12,"end":1022.12,"text":"אבל המצוקה היא קשה ביום העם"},{"start":1022.12,"end":1024.12,"text":"באמא שלי, זה לא יום על מה שקורה ביום העם"},{"start":1024.12,"end":1026.02,"text":"קודם כל"},{"start":1026.02,"end":1028.09,"text":"שימו לב מה שקורה במשתלות"},{"start":1028.09,"end":1030.09,"text":"מלחמה באמא שלי"},{"start":1030.09,"end":1032.09,"text":"אנשים עומדים בתור כאילו חלקים לחם"},{"start":1032.09,"end":1034.09,"text":"לא יומן"},{"start":1034.09,"end":1036.09,"text":"באמא שלי חשבתי רעב לארץ עלי וחלקים לאורז"},{"start":1036.09,"end":1038.09,"text":"לא יומן עומדים כולם ממש תלות"},{"start":1038.09,"end":1040.09,"text":"ויש טילים נחטפים"},{"start":1040.09,"end":1042.09,"text":"אחריזנתמות רבות עם הדליות"},{"start":1042.09,"end":1044.09,"text":"הדליות רבות עם הפתוניות"},{"start":1044.09,"end":1046.09,"text":"יש רסיות, פוטוסינתזה עולה לשמיים"},{"start":1046.09,"end":1048.09,"text":"באמא שלי הפיוניות עובדות פול טיים ג'וב"},{"start":1048.09,"end":1050.09,"text":"לא יומן, הקוטנועיים משתובבים בעיר"},{"start":1050.09,"end":1052.09,"text":"לא הם פיצות, הם עציצים"},{"start":1052.09,"end":1054.09,"text":"לא יומן, בן אדם אוכל עציץ בערב, לא יודע מה לעשות"},{"start":1054.09,"end":1056.09,"text":"השתגעו כולם, השתגעו כולם"},{"start":1056.09,"end":1058.09,"text":"לא יומן, לא יומן כיסופן"},{"start":1058.09,"end":1060.09,"text":"וזה עוד כלום, זה רק ההתחלה"},{"start":1060.09,"end":1062.09,"text":"מה שיותר מפחיד זה הליצן המזמר"},{"start":1062.09,"end":1064.09,"text":"או אבא שלי"},{"start":1064.09,"end":1066.09,"text":"יש ילדים להפלפים כאלה ששולחים לאמא שלהם"},{"start":1066.09,"end":1068.09,"text":"ליצן מזמר, להפלף כאיזו צבוע בקומי צבעים"},{"start":1068.09,"end":1070.09,"text":"חשבתי אינדיאני"},{"start":1070.09,"end":1072.09,"text":"והוא שר להם כל מיני שירים"},{"start":1072.09,"end":1074.09,"text":"אמא יקרה לי יקרה, תביא לי כפה"},{"start":1074.09,"end":1076.09,"text":"ואמא זה החרטה זה"},{"start":1076.09,"end":1078.09,"text":"בא ליצן, אמא בבית מתגן את המטבוכה"},{"start":1078.09,"end":1080.09,"text":"פתאום הוא דופק בדלת"},{"start":1080.09,"end":1082.09,"text":"אולי גלבים, אולי מחבלים"},{"start":1082.09,"end":1084.09,"text":"אולי דודו דופז, היא לא יודעת"},{"start":1084.09,"end":1086.09,"text":"לחס, באמא שלי, פתאום רואה לי צלף"},{"start":1086.09,"end":1088.09,"text":"לב כזה קטן, הוא שאלה, אמא היא קרה לי"},{"start":1088.09,"end":1090.09,"text":"במקום יש לה משהו של אופר לב"},{"start":1090.09,"end":1092.28,"text":"המצוקה היא קשה"},{"start":1092.28,"end":1094.25,"text":"לכן צוות ז'וזו בנה ולאש"},{"start":1094.25,"end":1096.31,"text":"החליט להתייחס ליום המשפחה"},{"start":1096.31,"end":1098.31,"text":"ולא רק ליום המשפחה, אלא ליום המשפחם"},{"start":1098.31,"end":1100.33,"text":"לקחנו את משפחת חם ויפת"},{"start":1100.33,"end":1102.42,"text":"החלטנו להביא שיר גזעי"},{"start":1102.42,"end":1104.42,"text":"עסיסי, שעיר"},{"start":1104.42,"end":1106.39,"text":"כמו שצריך ליום המשפחה"},{"start":1106.39,"end":1118.24,"text":"שופופו"},{"start":1118.24,"end":1120.7,"text":"נהי, תפוסת בתוכך"},{"start":1120.7,"end":1125.85,"text":"חזק, חזק"},{"start":1125.85,"end":1127.85,"text":"שלום שמי חם זהו בני יפת"},{"start":1127.85,"end":1132.85,"text":"יפת"},{"start":1132.85,"end":1171.75,"text":"שכולם חושבים שזה מוקסם"},{"start":1171.75,"end":1189.11,"text":"אני אבא שלו אני מכיר אותו"},{"start":1189.11,"end":1191.11,"text":"קוראים לי חמי חמי חמי חמי"},{"start":1191.11,"end":1193.4,"text":"אני שומר עליו מוזר כזה"},{"start":1193.4,"end":1195.4,"text":"אפילו שבוקם"},{"start":1195.4,"end":1197.78,"text":"תשמור על ילד עם שערות בעב"},{"start":1197.78,"end":1199.78,"text":"וקיפה, זה מה שיש"},{"start":1199.78,"end":1201.78,"text":"שלא ייפול עליי, שלא ייפול על עצמו"},{"start":1201.78,"end":1203.78,"text":"שלא ייגמר לי"},{"start":1203.78,"end":1208.86,"text":"שלא ייגמר לי עולה"},{"start":1208.86,"end":1214.12,"text":"שווה אנשים בעולם"},{"start":1214.12,"end":1233.63,"text":"ובחורם"}]