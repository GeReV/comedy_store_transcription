[{"start":0.67,"end":3.33,"text":"כל קשר בין המציאות לדמיון, הינו מקרי בהחלט."},{"start":3.33,"end":9.19,"text":"תמות האנשים והמקומות שונו, לצורך העלילה."},{"start":9.19,"end":10.59,"text":"ומאתה הם נקראים."},{"start":10.59,"end":52.53,"text":"איזה אותי?"},{"start":52.53,"end":62.95,"text":"סטיף, אין לך, זה שוקולד, אה?"},{"start":62.95,"end":68.77,"text":"אמא בוסקילה תמיד אמרה לי, בוסקילה, שהחיים זה כמו קופסת שוקולד."},{"start":68.77,"end":71.68,"text":"אז אף פעם לא יודע איזה קוביית שוקולד מקלוקלת."},{"start":71.68,"end":73.98,"text":"אז בוסקילה מנסה את כולם, לא פרהר."},{"start":73.98,"end":78.63,"text":"עורים לי בוסקילה, ניסים בוסקילה."},{"start":78.63,"end":81.22,"text":"לא עבודה?"},{"start":82.38,"end":86.11,"text":"בוסקילה תמיד היה פעם הרבה, מלפלא הרבה שעלים רבות."},{"start":86.11,"end":89.8,"text":"היה לו עבודה פעם, אפילו אמרו את זה בחדשות אפילו."},{"start":89.8,"end":93.57,"text":"שהיה להם כזה, קול כזה של טאמבל כזה, שאומר ככה..."},{"start":93.57,"end":97.72,"text":"ולמעט פרפרעות, נשיא אוגנדה ביקר בכל נימוסין את נשיאינו."},{"start":97.72,"end":98.69,"text":"איך היה?"},{"start":98.69,"end":100.1,"text":"עדר?"},{"start":100.1,"end":106.87,"text":"אז היה איזה איש אחד זקן גם, שהוא כל הזמן דיבר, ואף אחד לא שמע לו מה שהוא אומר, אז אני..."},{"start":106.87,"end":112.51,"text":"הבוסקילה הייתי לעזור לו, והוא אמר לכולם שקט, שקט, שקט ככה, ואף אחד לא שמע לו מה הוא אומר."},{"start":112.51,"end":123.8,"text":"ראש הממשלה שחר בימים אלה שירותיו של עוזר פרלמנטרי חדש. הנה קטע מנאומו של ראש הממשלה."},{"start":140.2,"end":142.58,"text":"יושב ראש הכנסת."},{"start":142.58,"end":146.58,"text":"ואחורי זה כל הזמן כולם יתווכחו ועשו רעש ועצה הכל."},{"start":146.58,"end":148.58,"text":"אז הבוסקילה אמר להם שהוא בשקט."},{"start":148.58,"end":151.54,"text":"כי כבר כואב לדווד הזקין הזה הראש ועצה הכל שלהם."},{"start":151.54,"end":173.69,"text":"תמונות ראשונות מאתר הנופש של מר בן גוריון ורעייתו עם מדידם המשותף בוסקילה."},{"start":173.69,"end":202.75,"text":"תכנס דויד תכנס למים אל תפחד מהמים הקרים תראה הנה פולה תראה יופי נכנס חופשי פולה יאללה יופי שכה שכה דויד שכה פתוח עגליים יסגור על ידיים ופתוח יסגור יופי תראה איך פולה עושה תראה איך עושה ככה צוחק מוקריש חופשי במים יופי ועכשיו שכות גב ועל הצוף על המים סבבה על הצוף ככה רגליים בחוץ ככה עושה ככה באצבעות ככה דויד זה קסט אחרי זה פעם בעת הציפורניים לא יפה ככה מה זהו העיר פתח."},{"start":202.75,"end":205.76,"text":"טוב היה לצא, צא עם המים, היה לצא."},{"start":205.76,"end":207.47,"text":"אה?"},{"start":207.47,"end":211.47,"text":"איזה גופה, דוד, כל הכבוד, גוף משושש לך, כל הכבוד."},{"start":211.47,"end":212.56,"text":"השחקת אותה?"},{"start":212.56,"end":213.82,"text":"הלאה, התראות!"},{"start":213.82,"end":218.94,"text":"קבענו מחר ב-4 שעשה על זה חתירה וכל זה, סדר?"},{"start":218.94,"end":219.87,"text":"התראות!"},{"start":219.87,"end":222.32,"text":"אחרי זה גם הרבה..."},{"start":222.32,"end":225.1,"text":"אה?"},{"start":225.1,"end":229.1,"text":"מיקודם היה פה מישהו אחרת, איפה הלך זה עם שקפה, עם שקפה, איפה?"},{"start":229.1,"end":230.1,"text":"לא משנה, תמשיך, תמשיך."},{"start":230.1,"end":231.1,"text":"זה מרתק."},{"start":231.1,"end":232.1,"text":"זה מרתק."},{"start":232.1,"end":233.1,"text":"זה ידיר."},{"start":233.1,"end":239.32,"text":"עד אחורה זה גם הבוצקילה אוהב גם לשיר, אז הלך עם כל החברים שלו לשיר, גם כן הייתי אוהב לשיר."},{"start":239.32,"end":244.38,"text":"אז הרי פעם לא היה להם ריקודים, רק עומדים ככה, מסתכלים למעלה ככה, וזהו."},{"start":244.38,"end":249.57,"text":"שלישיית גשר הירקון התרחבה בימים אלו והפכה לרביעייה."},{"start":249.57,"end":266.0,"text":"יורם, תשאיר סלולה, סיר."},{"start":266.0,"end":270.33,"text":"זה יורם גאון, הוא רוצה להיות ראש הריית ירושלים, חמוד."},{"start":270.33,"end":281.23,"text":"ודימי אלה, זה באם צאריק אנשטיין, וזה פה מלפנים, זה בני עמדורצקי, וזה שם בצד ימין, זה יורם גאון."},{"start":281.23,"end":293.72,"text":"ודימי אלה, זה עושר ועושר, מחפש אלו עם חבודה דצם היום הזה."},{"start":293.72,"end":301.62,"text":"עלו, לצא, נפלה לך הציפור, עלו, הציפור נפלה."},{"start":301.62,"end":304.61,"text":"הייתי חבל הציפור הזה, הייתי חבל לציפור הזה."},{"start":304.61,"end":305.61,"text":"חבל לדיר."},{"start":305.61,"end":329.74,"text":"שוב אנחנו במדריך כיצד נתנהג הנכון, והפעם כיצד נתנהג וכיצד נחוג את יום העצמאות."},{"start":329.74,"end":333.74,"text":"ראשית, את החג יש לך גוג במקום המתאים לכאן."},{"start":333.74,"end":361.91,"text":"כדי להבטיח את הענאה, רצוי להתרחק מהמקומות הצפופים, אך אל תגזים."},{"start":361.91,"end":388.0,"text":"רצוי כמובן להויג אפרורים."},{"start":388.0,"end":393.82,"text":"זיקוקים דינור אין שעשוע פופולרי, אך מסוכן."},{"start":393.82,"end":395.82,"text":"זכור לשמור על כללי הבטיחות."},{"start":395.82,"end":398.91,"text":"כן, חיליק, אני אהיה בפיקניק מחרה, אל תדאג."},{"start":398.91,"end":401.93,"text":"בוא עכשיו על איזה גג, עושה חלטור, הזיקוקים, על ערב."},{"start":401.93,"end":402.93,"text":"שנייה!"},{"start":402.93,"end":404.99,"text":"אל, אני אהיה!"},{"start":404.99,"end":413.16,"text":"לא תיכלו להתקשר עם אמצע עבודה לכל חיליק!"},{"start":413.16,"end":417.29,"text":"צד שני, אין כל טעם להגזים מאמצעי הבטיחות."},{"start":417.29,"end":431.98,"text":"יום העצמאות מתאפיין בצעצועים רבים."},{"start":431.98,"end":435.0,"text":"אל תהסס להצטרף לשמחה הכללית."},{"start":435.0,"end":458.5,"text":"יום העצמאות הוא יום שמחה לאומית."},{"start":458.5,"end":462.56,"text":"אך רצוי לחוג אותו בסביבה המתאימה."},{"start":462.56,"end":478.32,"text":"זה הכל להפעם, לילה טוב, חג שמח והמשך צפייה."},{"start":478.32,"end":482.32,"text":"חבצלת, את רוצה קבע בו נקליקייה?"},{"start":482.32,"end":486.72,"text":"חם ויפת שתיים צריך משהו חדש."},{"start":486.72,"end":487.72,"text":"משהו מקורי."},{"start":487.72,"end":488.72,"text":"משהו שאף אחד לא חשב עליו."},{"start":488.72,"end":491.72,"text":"יש לך רעיון?"},{"start":491.72,"end":493.58,"text":"יש לי."},{"start":493.58,"end":497.12,"text":"חם ויפת שתיים מערב פרוע."},{"start":497.12,"end":530.89,"text":"הוא יזהה אותו בלונדיני."},{"start":530.89,"end":531.85,"text":"כן, אתה צודק."},{"start":531.85,"end":534.94,"text":"אבל תגיד לי, מה המזכירה הג'ינג'ית הזאת קשורה לפרסומת?"},{"start":534.94,"end":538.19,"text":"לא חשוב, בוא נחזור לענייננו."},{"start":538.19,"end":539.19,"text":"כן, אתה צודק."},{"start":539.19,"end":553.46,"text":"טוב, הערב במפזק של ז'ק נמצא איתנו,"},{"start":553.46,"end":555.46,"text":"המדען הצרפתי והממציא הישראלי מרמח."},{"start":555.46,"end":558.46,"text":"אתה יכול לקרוא לי בשמי הפרטי ושמחת בחגיך והיית אחסה."},{"start":558.46,"end":561.46,"text":"אם כן ערב טוב לך מר ושמחת בחגיך והיית אחסה."},{"start":561.46,"end":564.46,"text":"מרח, מרח, חבל לבזבז את כל הזמל על השם הזה."},{"start":564.46,"end":565.46,"text":"ערב טוב לך מרמח."},{"start":565.46,"end":567.46,"text":"צאתה שם רלגרם השם לא סתטו פרטנאו."},{"start":567.46,"end":569.46,"text":"עזאסאפ, עזאסאפ לזום אתה לרולג."},{"start":569.46,"end":574.46,"text":"איזה מדינה, איזה מדינה, איזה מדינה."},{"start":574.46,"end":576.46,"text":"ז'עדת עודה, יאה."},{"start":576.46,"end":578.46,"text":"ערב טוב לך מה אתה המצאת על לכבוד יום העצמאות?"},{"start":578.46,"end":583.46,"text":"וכן אני המצאתי המצאה גרנדיו זיק, שים לב, זהו הפטיש."},{"start":583.46,"end":586.84,"text":"יש כבר המצאה כזאת, יש פטיש מיוחד ליום העצמאות."},{"start":586.84,"end":591.87,"text":"יצחתיתי, אוללה, מורידיה, זה פטיש גרנדיו זיק, עוד לא קם כזה פטיש."},{"start":591.87,"end":593.87,"text":"זה פטיש מפרגן."},{"start":593.87,"end":595.87,"text":"הוא, מה הוא עושה?"},{"start":595.87,"end":598.87,"text":"וכן זהו פטיש, כשמו כאילו מפרגן לזולת."},{"start":598.87,"end":602.87,"text":"זאת אומרת אתה פוגש חבר שלך ביום עצמאות באווירה המפרגנת שלך,"},{"start":602.87,"end":606.87,"text":"אתה רוצה לפרגן לו ולדבר איתו, הפטיש עושה בשבילך את העבודה,"},{"start":606.87,"end":608.87,"text":"אתה לא צריך להוציא מילה."},{"start":608.87,"end":609.82,"text":"אתה יכול להדגים?"},{"start":609.82,"end":612.16,"text":"בבקשה, מה שלומך? אתה נראה טוב, אתה דובל לקובה,"},{"start":612.16,"end":614.16,"text":"איזה יופי, איזה מדינה, לתפארת מדינה את ישראל,"},{"start":614.16,"end":616.16,"text":"מה שלא משתך, חולה עליה."},{"start":616.16,"end":621.59,"text":"הפטיש מדבר, איזה עוד סוג של פטישים יש לך?"},{"start":621.59,"end":624.59,"text":"ובכן, שיב לב, זהו יוד המצא הגרנדיו זיק,"},{"start":624.59,"end":626.59,"text":"זהו הפטיש הנדחף."},{"start":626.59,"end":627.59,"text":"נדחף?"},{"start":627.59,"end":628.59,"text":"כן."},{"start":628.59,"end":629.59,"text":"מה הוא עושה?"},{"start":629.59,"end":631.59,"text":"אוקי שמוק, אינו, זהו פטיש נדחף."},{"start":631.59,"end":634.59,"text":"אתה יודע שביום עצמאות כמובן יש הרבה הופעות,"},{"start":634.59,"end":638.59,"text":"הרבה אירועים, הרבה אנשים רוצים להידחס פנימה להיכנס לתוך האירוע,"},{"start":638.59,"end":640.59,"text":"וזהו פטיש שעושה בשלך את העבודה."},{"start":640.59,"end":641.59,"text":"אתה יכול להדגים?"},{"start":641.59,"end":643.59,"text":"בבקשה, נניח, אתה עכשיו,"},{"start":643.59,"end":645.59,"text":"בהופעה גדולה של ישרים אל הסופים,"},{"start":645.59,"end":648.69,"text":"של הזמר הידוע נניח גפן."},{"start":648.69,"end":649.69,"text":"אביו."},{"start":649.69,"end":652.69,"text":"הגיע פסח באה, ואתה רוצה להיכנס פנימה לתוך ההופעה."},{"start":652.69,"end":653.69,"text":"מה שאתה עושה זה פשוט מאוד."},{"start":653.69,"end":657.72,"text":"הפטיש, אתה מניח לא לדבר, הוא עושה בשלך את כל העבודה."},{"start":657.72,"end":659.01,"text":"תדגים."},{"start":659.01,"end":666.48,"text":"בבקשה, זוזה צידה, גם אני רוצה לראות, לכי המניק, למה אתה מפריע, אל תטיז עליי, אל תירק עליי, זוז, אני מכיר את אביב אישית, אתה מניק."},{"start":666.48,"end":672.36,"text":"אהה, אתה יודע שאתה משמיע את הקולות, לא הפטיש."},{"start":672.36,"end":679.34,"text":"נכון, ואם יותר ללמסור דעש, רק לא, איש בידי המקר שלי, אביו מדינה."},{"start":679.34,"end":681.34,"text":"לא, בשום פנים ואופן לא."},{"start":681.34,"end":682.34,"text":"שטוק דביל."},{"start":682.34,"end":684.91,"text":"כמה עולה פטיש כזה?"},{"start":684.91,"end":686.0,"text":"זה 15 שקלים."},{"start":686.0,"end":689.09,"text":"שמה, יש לי רק שטר של 200, אתה יכול להחזיר לי עודף בבקשה?"},{"start":689.09,"end":691.09,"text":"כן, לא נורא, אין שום בעיה."},{"start":693.72,"end":696.16,"text":"את העודף בבקשה."},{"start":696.16,"end":699.16,"text":"אהה, שכחתי להציג לך את הארנק החדש שלי,"},{"start":699.16,"end":702.16,"text":"זה המצאה אקטראורדינר, שים להם, הארנק התחמן."},{"start":702.16,"end":705.35,"text":"לך, פסט החדנים שלך, אין עודף, זבל."},{"start":705.35,"end":708.4,"text":"אם כן, זה הכל..."},{"start":708.4,"end":711.4,"text":"רק אם אני יכול להראות לך עוד פטיש, לדוגמה פטיש לכלב."},{"start":711.4,"end":714.4,"text":"רגלי, רגלי, צא החוצה, אל תשתית בבית, אל תשתית בבית."},{"start":714.4,"end":716.39,"text":"או פטיש שונה לטלפון, אלו."},{"start":716.39,"end":719.35,"text":"זה הכל הפעם כאן במבזק של ז'אנ..."},{"start":719.35,"end":725.2,"text":"תגיד לי, זה אמבורגן הנשיא או שזה פשוט משמלו?"},{"start":725.2,"end":727.65,"text":"משמלו, מה שחשבתי?"},{"start":727.65,"end":729.65,"text":"חם ויפת שטיין, צריך משהו חדש."},{"start":729.65,"end":730.65,"text":"משהו מקורי."},{"start":730.65,"end":733.65,"text":"אפילו אתה פותחינה, הצליחו לגרד איזה סרט המשך להולנדית שלהם."},{"start":733.65,"end":735.65,"text":"יש לך רעיון?"},{"start":735.65,"end":736.61,"text":"יש לי!"},{"start":736.61,"end":739.53,"text":"חם ויפת, האחים בלוז!"},{"start":739.53,"end":777.58,"text":"זה לא מסחרי מספיק."},{"start":777.58,"end":781.58,"text":"אני עדיין לא מבין מה המסקירה ג'ינג'ית הדוד סבא פרסומת שלנו!"},{"start":781.58,"end":784.58,"text":"לא חשוב, בוא נחזור לענייננו."},{"start":784.58,"end":785.64,"text":"תודק."},{"start":785.64,"end":797.11,"text":"הופ הופ, הלו הלו הלו!"},{"start":797.11,"end":798.42,"text":"הלו!"},{"start":798.42,"end":802.43,"text":"בוא להן השנייה, אני רוצה לסוג את הקליפה."},{"start":802.43,"end":805.56,"text":"אין בעיה, אדוני, חג שמח לך."},{"start":805.56,"end":809.56,"text":"אתה באמת אזרח לדוגמה, לבי כולם היו כמוך."},{"start":809.56,"end":814.81,"text":"כי כל ישראל לכים אבל מלכלכים וכשיש חגיגות צריך לנקות."},{"start":814.81,"end":816.19,"text":"כל הכבוד."},{"start":816.19,"end":818.25,"text":"יני, רק סיימת בנלה וזורג בסדר?"},{"start":818.25,"end":819.25,"text":"לקליפה של הקליפה הזה."},{"start":819.25,"end":821.6,"text":"אתה יודע למה, למה?"},{"start":821.6,"end":823.63,"text":"למה נחלכת ביאסטא?"},{"start":823.63,"end":825.62,"text":"סגורת באסטא."},{"start":825.62,"end":828.62,"text":"הלאה, לתראות לך, כשיש חגיגות אני הולך לנקות."},{"start":828.62,"end":829.62,"text":"הלאה."},{"start":829.62,"end":832.96,"text":"הופ, שנייה בחוץ'י, שנייה."},{"start":832.96,"end":836.01,"text":"רק שנייה בסדר, אין אתה כבר פה."},{"start":836.01,"end":837.04,"text":"שנייה קטנה בסדר?"},{"start":837.04,"end":839.04,"text":"הלאה, אתה באמת אזרח לדוגמה."},{"start":839.04,"end":840.04,"text":"לבי כולם היו לומדים ממך."},{"start":840.04,"end":842.04,"text":"חג שמח לך ולכל עם ישראל."},{"start":842.04,"end":844.04,"text":"הלאה, שיחקת אותה אחונה, אה?"},{"start":844.04,"end":845.04,"text":"אני חבל לי לך לך."},{"start":845.04,"end":846.04,"text":"אתה יודע איך זה למה?"},{"start":846.04,"end":849.04,"text":"לכלכת, בעסת, סגורת הבסת."},{"start":849.04,"end":851.04,"text":"רק תסתעשה את זה מהר למה."},{"start":851.04,"end":853.04,"text":"כשיש חגיגות אני הולך לנקות."},{"start":853.04,"end":854.04,"text":"אתה מבין את זה."},{"start":854.04,"end":856.04,"text":"אין בעיה, תאמין לי."},{"start":856.04,"end":858.04,"text":"אני החשיבות של הנקיון של המדינה"},{"start":858.04,"end":860.04,"text":"זה חשיבות גם בשביל חומרים."},{"start":860.04,"end":861.04,"text":"אחונה, אתה אזרח לדוגמה באמת."},{"start":861.04,"end":862.17,"text":"תודה."},{"start":862.17,"end":863.94,"text":"תודה."},{"start":863.94,"end":865.09,"text":"להתראות."},{"start":865.09,"end":867.55,"text":"תודה רבה לך."},{"start":867.55,"end":868.51,"text":"אלו, אלו, אלו!"},{"start":868.51,"end":873.63,"text":"תחונה, פנק את עצמנו וגרעינים קצן, לא?"},{"start":873.63,"end":878.65,"text":"רק מהר, למה כשיש חגיגות אני צריך לנקות."},{"start":878.65,"end":880.65,"text":"אין בעיה, חבל לזרוק על הרספה, למה?"},{"start":880.65,"end":883.68,"text":"לכלכתה, ביאזתה, סגורתה, בסגורתה, בסגורתה, בסגורתה."},{"start":883.68,"end":897.26,"text":"חבי, זה אם אני מפזר פה מסביב,"},{"start":897.26,"end":900.41,"text":"למה צברו אחורי לסך, תבין זה?"},{"start":900.41,"end":904.69,"text":"לכלחתה, בעסתה, גולטה בעסתה."},{"start":904.69,"end":906.59,"text":"חם ויפת 2, מה עושים?"},{"start":906.59,"end":908.75,"text":"יש לי רעיון!"},{"start":908.75,"end":913.8,"text":"יום עצמאוץ, שיר פטריוטי למדינה!"},{"start":913.8,"end":914.8,"text":"נפי את צבבן!"},{"start":914.8,"end":917.98,"text":"יש! חם ויפת 2!"},{"start":917.98,"end":929.23,"text":"חם ויפת, כלום לא השתנה,"},{"start":929.23,"end":931.23,"text":"רוצים לשיר כרשיר, לכבוד המדינה."},{"start":931.23,"end":936.67,"text":"כי בימים קרה לי, כל מה שחשוב, זה להסקנקו."},{"start":936.67,"end":940.45,"text":"תומך יבא, אור שלום."},{"start":940.45,"end":1000.25,"text":"שנפלה, אחד אלוהינו, יושב שמי למעלה."},{"start":1000.25,"end":1002.69,"text":"ושם כולנו יחד, בארץ ה..."},{"start":1002.69,"end":1016.23,"text":"ותבש בנה נמוקה, ירושלים, תל אביב, כמו בלמדה מיורקה."},{"start":1016.23,"end":1019.44,"text":"בלמדה, וואה!"},{"start":1019.44,"end":1084.29,"text":"את אימא ותשמר את הפיצ'ה בעל, את קפיים, וכל החיים בכאן ואת יופי."},{"start":1084.29,"end":1091.08,"text":"הנה, רק עוד חתיכה קטנה של הפומלה, וזהו, וואלה."},{"start":1091.08,"end":1095.08,"text":"מזל שאתה פה, תאמין לי, חבל, הייתי מלך לחפות כל האזור הזה."},{"start":1095.08,"end":1097.08,"text":"לכלכת, בעזת?"},{"start":1097.08,"end":1102.08,"text":"סגור את הבאסתה, אבל תראה, אני אין לי זמן, יש חגיגות, אני צריך..."},{"start":1102.08,"end":1104.06,"text":"נקות, הלאה, אתה יודע."},{"start":1104.06,"end":1108.48,"text":"רוצה קטן? למה לא?"},{"start":1108.48,"end":1111.27,"text":"לא, לא, לא צריך שרם."},{"start":1111.27,"end":1113.3,"text":"אלא, יש חגיגות, אני הולך נקות."},{"start":1113.3,"end":1117.29,"text":"רגע, לא! שם, שם!"},{"start":1117.29,"end":1118.65,"text":"מה עם קינוע?"},{"start":1118.65,"end":1121.66,"text":"תביא תביא פותחן."},{"start":1121.66,"end":1123.84,"text":"לא הבאתי, אין לי פותחן."},{"start":1123.84,"end":1126.08,"text":"מזל שלא שמחתי עליך."},{"start":1126.08,"end":1134.89,"text":"הלאה, תאמין לי, אם הייתי את כל הדבר הזה,"},{"start":1134.89,"end":1139.89,"text":"אין דבר הזה, פה בוטח, עם המטכת הזה מלחלך פה, זה ללחלך דאב!"},{"start":1139.89,"end":1141.89,"text":"בלחלך, בלחלך, בלחלך, בלחלך!"},{"start":1166.58,"end":1173.46,"text":"And food commercials are making a lot of money, which is good for their pocket, but not really good for our diet, as they say."},{"start":1173.46,"end":1175.06,"text":"Well, we run MTV has, have, has, have, has, wished, have, has, have, would, has, has, wish, has, has, has, spin, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has, has"},{"start":1175.06,"end":1186.97,"text":"Well, we run MTV has, have, have, has, have, has wished, have, has, have wood, has, has, has, has been, has, has, has, has been, has, has, has, has been, has, has, has, has, has been, has, has, has, has, has, has been, has, has, has, has been, has, has, has, has, has been, has, has, has, has, has, has, has, has prepared our own food commercials."},{"start":1186.97,"end":1188.59,"text":"We call it Marzey Maurice."},{"start":1188.59,"end":1194.43,"text":"Aden, what is this spray you have in your hand? Is it an Israeli deodorant or what? Can I smell it?"},{"start":1194.43,"end":1201.08,"text":"Well, thank you."},{"start":1201.08,"end":1207.5,"text":"Marzey Maurice with our own special smashing guests are Marzey Maurice."},{"start":1212.27,"end":1221.61,"text":"Arb-tobu, ברוכים הבאים למרזה מוריס, המכון היחידי שמבטיח לכם הצלחה מהירה ובאחריות."},{"start":1221.61,"end":1225.18,"text":"שלושת האורחים שלנו עלו ביותר מ-490 קילוגרמים."},{"start":1225.18,"end":1227.62,"text":"סוזי, את נראית צבעה."},{"start":1227.62,"end":1233.14,"text":"תודה רבה. היום, בזכות הדיאטה של מרזה מוריס, אני משמשת כמשקולת ומעלית של בניין מפואר."},{"start":1233.14,"end":1239.75,"text":"אברהם, אתה איתה גנב חתיך והיום אתה עשיר דוחה."},{"start":1239.75,"end":1248.82,"text":"בזכות מרזה מוריס, אני נתקעתי בחלון של וילה באפקה באמצע פריצה, וככה גם נתפסתי על ידי המשטרה."},{"start":1248.82,"end":1256.25,"text":"שושנה, בעקבות מרזה מוריס חייך השתנו מן הקצה לקצה."},{"start":1256.25,"end":1258.57,"text":"אני לא יודעת, אני לא רואה שום הבדל."},{"start":1258.57,"end":1261.44,"text":"אתה יודע מה אימא שלי היית אומרת?"},{"start":1261.44,"end":1263.75,"text":"בוק רפל מישמיש."},{"start":1263.75,"end":1271.54,"text":"ובכן, אם הם יכולים להצליח, גם אתם יכולים להצליח."},{"start":1271.54,"end":1274.24,"text":"פה ונראה את השיטה הסודית של מרזה מוריס."},{"start":1278.65,"end":1280.65,"text":"שוקולד חלב ושוקולד מריר."},{"start":1280.65,"end":1282.95,"text":"נגורג עסים כצפת מהפסטה שממול."},{"start":1282.95,"end":1285.85,"text":"כמישה עלים של חסה ושני קילו מעמול מול."},{"start":1285.85,"end":1289.73,"text":"בפיטא עוזבות, בנה תשירות מול."},{"start":1289.73,"end":1293.36,"text":"אחלה דייט, דייט אחלה."},{"start":1293.36,"end":1298.01,"text":"ועכשיו, עם קולסטרול, עצמיגים עוד יותר אחלה."},{"start":1298.01,"end":1300.18,"text":"דייט אחלה."},{"start":1300.18,"end":1305.5,"text":"מרשה עם מוריסט, רואים טוב צעות יום."},{"start":1305.5,"end":1316.73,"text":"עבר לא יעצור את השפן של יפת, ששר ושר ושר."},{"start":1319.15,"end":1322.46,"text":"פסטן פוטר דספיר."},{"start":1322.46,"end":1324.6,"text":"פטן פוטר דספיר."},{"start":1324.6,"end":1326.6,"text":"פטן פוטר דספיר."},{"start":1326.6,"end":1328.79,"text":"פטן פוטר דספיר."},{"start":1328.79,"end":1330.81,"text":"פטן פוטר דספיר."},{"start":1330.81,"end":1332.81,"text":"פטן פוטר דספיר."},{"start":1332.81,"end":1336.63,"text":"פטן פוטר דספיר."},{"start":1336.63,"end":1340.05,"text":"פטן פוטר דספיר."},{"start":1340.05,"end":1341.15,"