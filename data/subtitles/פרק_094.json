[{"start":18.43,"end":19.77,"text":"קהל ההפקות גאים להציג."},{"start":19.77,"end":22.12,"text":"תוכנית רעיונות מהפכנית."},{"start":22.12,"end":24.27,"text":"אחרי בילי בדרכים."},{"start":24.27,"end":26.17,"text":"אחרי בילי באוויר,"},{"start":26.17,"end":27.47,"text":"אנו מגישים לכם את"},{"start":27.47,"end":29.12,"text":"בילי באמבטיה."},{"start":29.12,"end":30.57,"text":"דיברת איתו?"},{"start":30.57,"end":32.73,"text":"שכבת איתו?"},{"start":32.73,"end":35.88,"text":"התקלחתם ביחד?"},{"start":35.88,"end":40.11,"text":"אתם סיבנתם זה לזה את הגב?"},{"start":40.11,"end":42.36,"text":"שקרן."},{"start":42.36,"end":48.06,"text":"תוכנית זו מבוססת המקרים שהתרחשו במציאות."},{"start":49.94,"end":53.53,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט."},{"start":53.53,"end":59.41,"text":"כמות האנשים והמקומות שונו לצורך העלילה."},{"start":59.41,"end":60.81,"text":"ומאתה הם נקראים."},{"start":60.81,"end":95.13,"text":"מה באים לסדרת הזוהר של עולם האופנה הישראלי?"},{"start":95.13,"end":96.78,"text":"רמת אביב ג'"},{"start":96.78,"end":111.0,"text":"היי, דין."},{"start":111.0,"end":114.27,"text":"דין, דין, תקראי את הטקסט פעם אחת."},{"start":114.27,"end":116.81,"text":"תני לי סיבה אחת למה לקחו אותך לסדרה הזאת."},{"start":116.81,"end":118.97,"text":"אני יכולה לתת לך שתי סיבות."},{"start":118.97,"end":126.21,"text":"אתה בכלל שמעת על הבחינות לדוגמנים שנערכות עכשיו?"},{"start":126.21,"end":126.83,"text":"לא?"},{"start":126.83,"end":131.68,"text":"אז בואו נעבור לסצנה שבה מתוארת הבחינה לדוגמנים שנערכת עכשיו."},{"start":131.68,"end":139.45,"text":"אז מה גילת? נראה לך של הדוגמן שזה אתר העינו יש את הלוק המתאים?"},{"start":139.45,"end":141.86,"text":"אני הייתי מעדיפה לראות עוד דוגמנים."},{"start":141.86,"end":144.04,"text":"תקרא לדוגמן הבא."},{"start":144.04,"end":146.68,"text":"אגב, שמעתי שום מה הטובים ביותר."},{"start":146.68,"end":148.49,"text":"הדוגמן הבא?"},{"start":148.49,"end":149.85,"text":"הדוגמן הבא, בבקשה."},{"start":153.71,"end":156.93,"text":"הלם לכם? פה זה רמת אביו גפל"},{"start":156.93,"end":158.47,"text":"רמת אביו ג'"},{"start":158.47,"end":162.92,"text":"אה, אביו גפל, חבל, תחתה אהו אילנה, לא מזוזל, חבל"},{"start":162.92,"end":164.4,"text":"איך קורים לך בבקשה?"},{"start":164.4,"end":166.43,"text":"תחום לך בבקשה, אסמסקילה"},{"start":166.43,"end":172.38,"text":"אה, תראה ניסים, כאן בסוכנות הדוגמנות שלנו, דאמג'"},{"start":172.38,"end":172.8,"text":"דאמג'"},{"start":172.8,"end":175.12,"text":"אנחנו מחפשים אנשים יפים"},{"start":175.12,"end":175.94,"text":"יפים"},{"start":175.94,"end":177.43,"text":"שנראים טוב"},{"start":177.43,"end":180.0,"text":"דוגמנים"},{"start":180.0,"end":180.86,"text":"רומנים"},{"start":180.86,"end":182.07,"text":"רומנים?"},{"start":182.07,"end":183.37,"text":"דוגמנים, דוגמנים"},{"start":183.37,"end":184.59,"text":"רומנים, רומנים"},{"start":184.59,"end":187.69,"text":"טוב, תראה ניסים, אנחנו מחפשים דוגמנ צילום"},{"start":187.69,"end":188.73,"text":"מה נצילום?"},{"start":188.73,"end":190.83,"text":"בוא תראה לנו מה אתה שווה"},{"start":190.83,"end":191.82,"text":"מה זה שווה?"},{"start":191.82,"end":193.92,"text":"חול, חול בזכירה, אתה שווה החול"},{"start":193.92,"end":221.15,"text":"היה, סדר זה, כל הנשקויות, סדר, אה?"},{"start":221.15,"end":222.47,"text":"תראה, אה..."},{"start":222.47,"end":224.21,"text":"היה נפלא, ניסים, נפלא"},{"start":224.21,"end":226.2,"text":"התקבלת, ניסים"},{"start":226.2,"end":227.22,"text":"תקבלת, ניסים"},{"start":227.22,"end":228.76,"text":"אתה לא עם עבודה"},{"start":228.76,"end":231.9,"text":"תגיע אליי מחר בבוקר למשרד, ניסים"},{"start":231.9,"end":234.28,"text":"בבחר במשרד, סדר, יופי, יופי"},{"start":234.28,"end":235.52,"text":"גילה אנקורי, יופי"},{"start":235.52,"end":237.78,"text":"אבא תסקיל לך גילה אנקורי במשרד, יופי"},{"start":237.78,"end":238.52,"text":"לבד"},{"start":238.52,"end":246.39,"text":"אתה בטח שואל את עצמך ניסים"},{"start":246.39,"end":249.9,"text":"למה קראתי לך אליי למשרד?"},{"start":249.9,"end":252.16,"text":"לא, לא שואל אותי עצמך ניסים"},{"start":252.16,"end":254.88,"text":"לא, לא שואל אותי לך, למה, מה, בית ספר אנקורי"},{"start":254.88,"end":255.82,"text":"למה, מה?"},{"start":255.82,"end":259.38,"text":"אתה כל כך סקסי"},{"start":259.38,"end":262.49,"text":"אה? טקסי, לא, לא, גבר, לא טקסי"},{"start":262.49,"end":264.37,"text":"אה, לא, אבא, אין שם תסקיל לך ברגל"},{"start":264.37,"end":266.75,"text":"ברגל, אין כסף, לא עם עבודה, אה טקסי, מה?"},{"start":266.75,"end":268.23,"text":"אתה כזה טיפשון"},{"start":268.23,"end":271.03,"text":"אה, לא, לא, לא שימשון, אה, לא, לא שימשון"},{"start":271.03,"end":274.45,"text":"אי, סים, אי, סים, סקיל, אה, לא, אי, סים, סקיל"},{"start":274.45,"end":276.23,"text":"אהלה, חרשנת, לא שומעתו טבלה"},{"start":276.23,"end":276.98,"text":"אהלה"},{"start":276.98,"end":278.74,"text":"אתה כל כך מגרר"},{"start":278.74,"end":279.93,"text":"אה?"},{"start":279.93,"end":281.39,"text":"מגרר"},{"start":281.39,"end":282.43,"text":"אה"},{"start":282.43,"end":295.0,"text":"וואו, דיק"},{"start":295.0,"end":297.41,"text":"דין, לא זין ולא דיק"},{"start":297.41,"end":298.13,"text":"דין"},{"start":298.13,"end":302.63,"text":"איזה מהר עברו ארבעה חודשים מאז הצן האחרונה בצפינו זה אתה?"},{"start":302.63,"end":305.33,"text":"תגידי יאהלי למה אמרת עכשיו את המשפט הזה?"},{"start":305.33,"end":309.03,"text":"כי אני מיודדת אם אתה סריטאי והייתה לו בעיה להעביר את האינפורמציה"},{"start":309.03,"end":312.06,"text":"וואו, רואים שיש לך פלפל"},{"start":312.06,"end":316.73,"text":"וואו, רואים שיש לך בננה"},{"start":316.73,"end":325.28,"text":"ניסים, זה לא יכול להיות"},{"start":325.28,"end":329.49,"text":"אתה משקר ניסים, אתה רוצה את הכסף שלי"},{"start":329.49,"end":334.85,"text":"זה לא יכול להיות שאתה... בהיריון"},{"start":334.85,"end":338.46,"text":"בהיריון, בוסקילה בהיריון, תינוק בבית נראה בוסקילה"},{"start":338.46,"end":341.21,"text":"בוסקילה אבא, אימא"},{"start":341.21,"end":345.01,"text":"אה... או..."},{"start":345.01,"end":347.88,"text":"ניסים, זה בטח לא ממני"},{"start":347.88,"end":350.23,"text":"אה, לא ממני עמא פה, מה לא?"},{"start":350.23,"end":352.8,"text":"אתה רוצה את הכסף שלי ניסים?"},{"start":352.8,"end":354.75,"text":"די, נמאס לי, אתה מפותח!"},{"start":354.75,"end":365.25,"text":"לא טוב לגדול פה רמה את אביב גפת מלא אתך חויות"},{"start":365.25,"end":367.25,"text":"בוא בוסקילה ג'וניור, בוא"},{"start":367.25,"end":369.22,"text":"כי אני לא יודעים העבודה?"},{"start":369.22,"end":370.51,"text":"איך היה?"},{"start":370.51,"end":371.51,"text":"אה, בוא ג'וניור, בוא"},{"start":371.51,"end":389.5,"text":"אמר לי אדוני, אני צריך להגיע לרחוב ויצמן, אבל אתה יודע איפה זה?"},{"start":389.5,"end":390.56,"text":"ויצמן"},{"start":390.56,"end":393.56,"text":"אמרו לי שזה פה קרוב, אני רק לא יודע בגלל"},{"start":393.56,"end":397.56,"text":"ויצמן, אז תגיד אין בעיה, בוא אחריי, אני אקר אותך, סמוך עליי"},{"start":397.56,"end":402.19,"text":"אדוני, אמרו לי שזה פה קרוב, מאיפה אתה הולך?"},{"start":402.19,"end":405.19,"text":"בוא בוא, בוא אחריי, זה דרך קיצור, סמוך עליי"},{"start":405.19,"end":408.19,"text":"דווקא פה דרך השיחים, אני לא מבין את זה אדוני"},{"start":408.19,"end":410.19,"text":"בוא אדוני אחריי, יהיה בסדר, סמוך עליי"},{"start":410.19,"end":412.19,"text":"תגיד לי, זה הכרחי לעבור פה"},{"start":412.19,"end":414.19,"text":"זה דרך קיצור, סמוך עליי"},{"start":414.19,"end":417.19,"text":"אני לא יודע, אני דווקא הייתי פתוח שויצמן זה קרוב"},{"start":417.19,"end":419.19,"text":"אתה פתוח שזה הכרחי פה"},{"start":419.19,"end":422.19,"text":"זה הכרחי, הכרחי, זה דרך קיצור, תסמוך עליי"},{"start":422.19,"end":425.19,"text":"אני נדכר פה מכל כיוון, זה הכרחי"},{"start":425.19,"end":428.19,"text":"זה הכרחי, רק תיזהר פה על הבור עם הקוברות"},{"start":428.19,"end":430.5,"text":"זה הכרחי, רק תיזהר פה על הבור עם הקוברות"},{"start":430.5,"end":443.86,"text":"זה עמי רע, מה מה עמי רע"},{"start":443.86,"end":445.86,"text":"כאול המשורר"},{"start":445.86,"end":447.49,"text":"שאול אבי שיר"},{"start":447.49,"end":448.49,"text":"אני לא עזוב לך בעייך אני"},{"start":448.49,"end":450.49,"text":"שאול כל החבר'ה פה, תבי שיר"},{"start":450.49,"end":451.49,"text":"לזרוק נושא"},{"start":451.49,"end":454.49,"text":"תבי שיר כל החבר'ה, יושבים שערים שירים ביחד"},{"start":454.49,"end":456.8,"text":"בוא נשיר כולם בצבתא"},{"start":456.8,"end":458.8,"text":"גם הסבא, גם הסבתא"},{"start":458.8,"end":460.8,"text":"בוא נשיר כולם בריכוז"},{"start":460.8,"end":462.8,"text":"רק שלא יצא לנו צלילים מעכוז"},{"start":462.8,"end":464.8,"text":"אלה"},{"start":464.8,"end":468.02,"text":"אלה"},{"start":468.02,"end":470.49,"text":"אלה אותו אלה"},{"start":470.49,"end":472.51,"text":"הוא נוקח נושא תעמים עושה אותו בושיה"},{"start":472.51,"end":474.48,"text":"תעזבו אותו בער"},{"start":474.48,"end":476.48,"text":"אלה שיר שיר שיר"},{"start":476.48,"end":478.45,"text":"נכון איזה"},{"start":478.45,"end":480.45,"text":"מה מה מה"},{"start":480.45,"end":482.45,"text":"מה גב"},{"start":482.45,"end":485.63,"text":"וואן טו"},{"start":485.63,"end":487.63,"text":"גבוה"},{"start":487.63,"end":490.59,"text":"מעל העיר בני"},{"start":490.59,"end":495.93,"text":"עיונה פורס את קנף"},{"start":495.93,"end":498.28,"text":"ועיני הקלו"},{"start":498.28,"end":524.66,"text":"עדוני"},{"start":524.66,"end":527.19,"text":"הנה עוד שנייה"},{"start":527.19,"end":529.41,"text":"בוא אחריו עדוני דרך קיצור"},{"start":529.41,"end":531.41,"text":"אתה בטוח שזה הכרחי"},{"start":531.41,"end":533.41,"text":"סמוך עליי עדוני זה הכרחי"},{"start":533.41,"end":535.41,"text":"אתה בטוח שזה... זה קצת מסוכן"},{"start":535.41,"end":537.41,"text":"לא עדוני זה דרך קיצור"},{"start":537.41,"end":539.47,"text":"תאמין לי"},{"start":539.47,"end":541.47,"text":"אתה בטוח שזה הכרחי"},{"start":541.47,"end":543.47,"text":"סמוך עליי עדוני זה הכרחי"},{"start":543.47,"end":544.47,"text":"סמוך עליי"},{"start":544.47,"end":546.47,"text":"נפס לי הגבה אתה בטוח זה הכרחי"},{"start":546.47,"end":548.49,"text":"סמוך עליי"},{"start":548.49,"end":550.49,"text":"בטוח שזה הכרחי"},{"start":550.49,"end":552.49,"text":"לעשות את זה עוד פעם"},{"start":552.49,"end":554.49,"text":"אגב שלי"},{"start":554.49,"end":556.49,"text":"בטוח אדוני"},{"start":556.49,"end":558.49,"text":"הנה עוד כמה בלוקים אנחנו מגיעים"},{"start":558.49,"end":560.49,"text":"לדרך קיצור"},{"start":560.49,"end":562.49,"text":"אבל כל הגום שלי כואב"},{"start":562.49,"end":564.49,"text":"אתה בטוח שזה הכרחי"},{"start":564.49,"end":566.49,"text":"אדוני זה הכרחי זה דרך קיצור לביצמן"},{"start":566.49,"end":569.19,"text":"זה הכרחי"},{"start":569.19,"end":571.28,"text":"אחרי כישלון בילי באמבטיה"},{"start":571.28,"end":573.28,"text":"קל ההפקות גאים להציג את בילי על האש"},{"start":573.28,"end":575.2,"text":"דיברת איתו?"},{"start":575.2,"end":577.47,"text":"ניסיתי לדבר איתו"},{"start":577.47,"end":579.47,"text":"ראית אותו?"},{"start":579.47,"end":581.47,"text":"מה הוא אמר לך?"},{"start":581.47,"end":583.47,"text":"שכבת איתו?"},{"start":583.47,"end":586.01,"text":"שקרן"},{"start":586.01,"end":601.91,"text":"יש כל לי תלויה עדיין"},{"start":601.91,"end":603.91,"text":"בין החורף"},{"start":603.91,"end":605.91,"text":"ורק העצבה"},{"start":605.91,"end":607.91,"text":"אני"},{"start":607.91,"end":609.91,"text":"כמותה"},{"start":609.91,"end":611.91,"text":"עוד אני"},{"start":611.91,"end":613.91,"text":"פושיה"},{"start":613.91,"end":615.91,"text":"מחפש תשוודי"},{"start":615.91,"end":617.91,"text":"עבוד אתכם פרסבות הבעיה"},{"start":617.91,"end":619.91,"text":"היי"},{"start":619.91,"end":621.91,"text":"היי"},{"start":621.91,"end":623.91,"text":"את פעם הלכו"},{"start":623.91,"end":629.32,"text":"תגיד לי בבקשה"},{"start":629.32,"end":631.32,"text":"לאן הגענו?"},{"start":631.32,"end":633.32,"text":"זה אחרחי"},{"start":633.32,"end":635.41,"text":"שנייה אני עוקה בקיצור"},{"start":635.41,"end":637.41,"text":"ומגיעים בדיוק לביצמן"},{"start":637.41,"end":639.41,"text":"אני לא יודע זה מאוד קר פה"},{"start":639.41,"end":641.41,"text":"זה אחרחי"},{"start":641.41,"end":643.41,"text":"תאמין לי אני מקומי"},{"start":643.41,"end":645.44,"text":"סמוך עליי אתה רואה את המסחרת שם"},{"start":645.44,"end":647.44,"text":"ימינה שני בלוקים זה בדיוק"},{"start":647.44,"end":649.44,"text":"אתה מזחרת זה רחוק"},{"start":649.44,"end":651.44,"text":"זה זכח"},{"start":651.44,"end":654.4,"text":"זכחי בוא אחריים"},{"start":654.4,"end":656.37,"text":"היא נכשלה באוויר"},{"start":656.37,"end":658.37,"text":"באמבטיה ועל האש"},{"start":658.37,"end":660.46,"text":"אך היא לא תתייאש"},{"start":660.46,"end":662.46,"text":"בילי אין ספייס"},{"start":662.46,"end":664.46,"text":"נחתת איתו"},{"start":664.46,"end":667.06,"text":"אמרת איתו"},{"start":667.06,"end":670.4,"text":"התרוממת איתו"},{"start":670.4,"end":673.45,"text":"שקרן"},{"start":673.45,"end":675.45,"text":"קל ההפקות גאים להציג פרק נוסף"},{"start":675.45,"end":679.59,"text":"בסדרה הקומית הישראלית"},{"start":679.59,"end":681.59,"text":"הגרועה ויותר"},{"start":681.59,"end":685.57,"text":"משפחת ישראלי"},{"start":685.57,"end":719.55,"text":"את המכתב ששלח לנו המורה של אודי?"},{"start":719.55,"end":721.51,"text":"קשה מאוד להקל את זה"},{"start":721.51,"end":723.51,"text":"את מה קשה להקל? את מה שהוא רשם במכתב?"},{"start":723.51,"end":725.51,"text":"לא, את מה שהכנת קודם לאורחת זוהריים"},{"start":725.51,"end":731.19,"text":"תרשיבי למכתב"},{"start":731.19,"end":733.28,"text":"להורי אודי ישראלי שלום"},{"start":733.28,"end":735.28,"text":"אני מגיע אליכם לביקור בית החוף"},{"start":735.28,"end":737.28,"text":"הבן שלכם הורד בכיתה"},{"start":737.28,"end":739.76,"text":"ציון אפס"},{"start":739.76,"end":742.11,"text":"אפס אחד גדול"},{"start":742.11,"end":744.02,"text":"ועבוי לי אודי"},{"start":744.02,"end":746.17,"text":"אפס אחד גדול"},{"start":746.17,"end":748.17,"text":"אבל הבטחת לי שלא תצא דומה לאבא שלך"},{"start":748.17,"end":750.17,"text":"טוב"},{"start":750.17,"end":752.45,"text":"סטרפטוקוקוס"},{"start":752.45,"end":754.45,"text":"יותר טוב תדאגי מה קורה עם הבת שלך"},{"start":754.45,"end":755.83,"text":"זיבה"},{"start":755.83,"end":757.83,"text":"לפי דעתי היא לא הכינה שיעורי בית"},{"start":757.83,"end":759.83,"text":"תקופה ארוכה מאוד והיא זקוקה לריפוי בעיסוק"},{"start":759.83,"end":761.95,"text":"יותר מתאים לריפוי בפיצוך"},{"start":761.95,"end":767.31,"text":"עוז לבית החמורה"},{"start":767.31,"end":772.31,"text":"בית לפרנס"},{"start":772.31,"end":774.94,"text":"ערב טוב"},{"start":774.94,"end":776.94,"text":"עוז לספת מו"},{"start":776.94,"end":777.94,"text":"עוז לספת מו"},{"start":777.94,"end":778.94,"text":"עוז לספת מו"},{"start":778.94,"end":779.94,"text":"עוז לספת מו"},{"start":779.94,"end":780.94,"text":"עוז לספת מו"},{"start":780.94,"end":781.94,"text":"עוז לספת מו"},{"start":781.94,"end":782.94,"text":"עוז לספת מו"},{"start":782.94,"end":783.94,"text":"עוז לספת מו"},{"start":783.94,"end":785.94,"text":"עוז לספת מו"},{"start":785.94,"end":786.94,"text":"סלימון מוניו"},{"start":786.94,"end":787.94,"text":"מון דייר"},{"start":787.94,"end":789.94,"text":"אני מתנצל על האיכור פשוט אני"},{"start":789.94,"end":791.94,"text":"נדקעתי במעלית איזה שעה"},{"start":791.94,"end":793.94,"text":"לחצתי על שלוש וזה לא עלה בכלל"},{"start":793.94,"end":794.94,"text":"רגע רגע איזה מעלית?"},{"start":794.94,"end":797.0,"text":"הדלת האדומה משמאל"},{"start":797.0,"end":798.15,"text":"מהפלדה"},{"start":798.15,"end":799.15,"text":"כן?"},{"start":799.15,"end":801.33,"text":"זה המקלט"},{"start":801.33,"end":808.32,"text":"אם ככה נראה מורה טוב מורה לחיים אני רוצה למות"},{"start":808.32,"end":811.32,"text":"אני לא מבין איך יצא לבן כזה גאון"},{"start":811.32,"end":813.29,"text":"אבא כזה דביל"},{"start":813.29,"end":815.29,"text":"רגע אני לא מבינה, מה זאת אומרת גאון?"},{"start":815.29,"end":819.28,"text":"אתה כתבת בפירוש שאודי שלנו הורד בכיתה"},{"start":819.28,"end":820.24,"text":"מה זה?"},{"start":820.24,"end":821.21,"text":"תבידי רוצה את זה?"},{"start":821.21,"end":823.59,"text":"מה פתאום?"},{"start":823.59,"end":825.59,"text":"מנה מנה מנה לא הבנת"},{"start":825.59,"end":827.59,"text":"שימי לב, כתוב כאן בפירוש"},{"start":827.59,"end":829.59,"text":"הבן שלכם, הוורד שבכיתה"},{"start":829.59,"end":831.59,"text":"לא הבנת כיתה, הוא הוורד שבכיתה"},{"start":831.59,"end":833.59,"text":"הוא פשוט שושן, הוא גרון"},{"start":833.59,"end":835.59,"text":"אסטראורדינר במבס, סביב לפרנס"},{"start":835.59,"end":837.59,"text":"כן, אז למה אתה כתבת ציון אפס"},{"start":837.59,"end":839.59,"text":"אפס אחד גדול"},{"start":839.59,"end":841.74,"text":"מה זה? תביאי לראות את זה"},{"start":841.74,"end":843.74,"text":"הפתאום"},{"start":843.74,"end":845.74,"text":"זה ציון אפס"},{"start":845.74,"end":847.74,"text":"מנה, ציון לוי אפס"},{"start":847.74,"end":849.74,"text":"ציון לוי את הכיתה של אודי, הוא אס אחד גדול"},{"start":849.74,"end":851.74,"text":"אבל אודי, הוא גרנד יוזיק"},{"start":851.74,"end":853.74,"text":"הוא גדול, הוא אסטראורדינר, הוא במבס"},{"start":853.74,"end":855.74,"text":"לא, לא, לא, לא, הרגע זה נמציא עלול"},{"start":855.74,"end":858.74,"text":"אולי אני נציתי להסביר להם אבל הם לא רצו לשמוע"},{"start":858.74,"end":861.74,"text":"עזב אותך אודי, אם הטמטום היה ברזל"},{"start":861.74,"end":863.74,"text":"ההורים שלך היו מגדל אייפל"},{"start":863.74,"end":868.31,"text":"או, או, יש פה עוד מצחיק"},{"start":868.31,"end":870.37,"text":"מה אמרת לי שהעולם אין בו מורים מצחיקים?"},{"start":870.37,"end":873.37,"text":"יש מורים מחנכים, יש מורים מלמדים"},{"start":873.37,"end":876.5,"text":"והנה, מורה מצחיק"},{"start":876.5,"end":879.0,"text":"מצחיק כמו בננה מזוקקת"},{"start":879.0,"end":880.0,"text":"ז'חנו נדראו לי"},{"start":880.0,"end":882.0,"text":"צבח שמחומצן"},{"start":882.0,"end":883.0,"text":"ערובת חדר המשתהלן"},{"start":883.0,"end":885.0,"text":"מלאו החידראולים"},{"start":885.0,"end":886.0,"text":"מימן מוגלתי"},{"start":886.0,"end":887.0,"text":"כן"},{"start":887.0,"end":888.0,"text":"כן"},{"start":888.0,"end":889.0,"text":"כן"},{"start":889.0,"end":890.0,"text":"ואתם מוזמנים עכשיו לצפות"},{"start":890.0,"end":892.0,"text":"בפרויקט הגמר של הבן הגאון שלכם"},{"start":892.0,"end":894.0,"text":"איזה המצאות הוא הכין"},{"start":894.0,"end":895.0,"text":"זה פשוט מלך הכיתה"},{"start":895.0,"end":896.0,"text":"היעלום שבקטר"},{"start":896.0,"end":898.0,"text":"התינוק שבא מבחנה"},{"start":898.0,"end":899.0,"text":"זה העתידות שבא בזוקה"},{"start":899.0,"end":901.0,"text":"השחור שמתאחת לתקורנאי"},{"start":901.0,"end":903.0,"text":"הנה הפרויקט ציום שלי בבקשה"},{"start":903.0,"end":904.0,"text":"זה מכונה רב שימושית"},{"start":904.0,"end":906.0,"text":"זה גרנדיאז"},{"start":906.0,"end":907.0,"text":"מה היא עושה?"},{"start":907.0,"end":907.99,"text":"אז תראה תראה את הכפתור הזה כאן"},{"start":907.99,"end":908.99,"text":"התסובבים אותו"},{"start":908.99,"end":913.99,"text":"וזה מחלקת עיתונים"},{"start":913.99,"end":916.21,"text":"והכפתור הזה מחלקים"},{"start":916.21,"end":921.55,"text":"וזה זה מחצבת אסלעים"},{"start":921.55,"end":923.55,"text":"תראה"},{"start":923.55,"end":929.27,"text":"וזה כפתור שמביא באחורות"},{"start":929.27,"end":931.71,"text":"האסלע"},{"start":931.71,"end":934.99,"text":"מה את עושה פה?"},{"start":934.99,"end":936.99,"text":"אני יוצאת עם המורה של עודי"},{"start":936.99,"end":939.99,"text":"מה חשבתם שהוא יהיה כאן ואני פוסס נשיקה צורפתית אמיתית?"},{"start":939.99,"end":941.99,"text":"מה אשר מה אשר חושנית שלי"},{"start":941.99,"end":943.99,"text":"זיבא זיבא זיבא זיבא זיבא זיבא"},{"start":943.99,"end":945.99,"text":"הכי חפוץ בעיר"},{"start":945.99,"end":946.99,"text":"בוניה"},{"start":946.99,"end":947.99,"text":"זיבא לילי"},{"start":947.99,"end":949.99,"text":"אני לא מבין איך אתה צריכי לנשק את הצרפתית"},{"start":949.99,"end":952.99,"text":"עם כל היערות הגשם שצומחים לו כאן"},{"start":952.99,"end":955.99,"text":"על מה אכפת לי תתמשקי אפילו עם דינוזאום מצונן"},{"start":955.99,"end":957.99,"text":"רק לו עם אלפרד השכר"},{"start":957.99,"end":959.24,"text":"כן!"},{"start":959.24,"end":960.21,"text":"כן!"},{"start":960.21,"end":961.21,"text":"כן!"},{"start":961.21,"end":963.21,"text":"עכשיו מה משקי"},{"start":963.21,"end":968.5,"text":"סתתארי"},{"start":968.5,"end":972.55,"text":"זיבא אני עכשיו לוקחותה לפיול רומנטי מול השקיעה"},{"start":972.55,"end":974.55,"text":"אני ואת על סוסים"},{"start":974.55,"end":975.51,"text":"סוסים?"},{"start":975.51,"end":977.64,"text":"מאיפה תביא סוסים אלפרד?"},{"start":977.64,"end":979.29,"text":"הודי!"},{"start":979.29,"end":981.5,"text":"תלחץ על הכפתול שמביא סוסים"},{"start":981.5,"end":982.5,"text":"נתן לי רבורי אלפרד"},{"start":982.5,"end":1001.43,"text":"הנה פה ישר, אתה רואה, אנחנו מבשיכים פה ישר ומגיעים, זה שנייה אחת"},{"start":1001.43,"end":1004.43,"text":"דווקא בחרת לעבור מפה, אתה תגיד לי, זה הכרחי"},{"start":1004.43,"end":1007.43,"text":"שמור עליי, זה דרך קיצור, זה הכרחי הכרחי, אני מקומי"},{"start":1007.43,"end":1016.03,"text":"תגיד לי, שני אלה פה, זה הכרחי"},{"start":1016.03,"end":1019.85,"text":"הרחי, הרחי"},{"start":1019.85,"end":1023.29,"text":"מה זה הכיתור, זה שנייה, אנחנו מגיע"},{"start":1023.29,"end":1027.07,"text":"אני שערו אותך, זה הכרחי"},{"start":1027.07,"end":1029.95,"text":"אנו הולכות ברגל, אופה"},{"start":1029.95,"end":1030.95,"text":"היי"},{"start":1030.95,"end":1031.95,"text":"אופה"},{"start":1031.95,"end":1033.95,"text":"אנו הולכות ברגל, אופה"},{"start":1033.95,"end":1035.33,"text":"היי"},{"start":1035.33,"end":1036.33,"text":"קלנית"},{"start":1036.33,"end":1037.33,"text":"מה, רכפת"},{"start":1037.33,"end":1038.33,"text":"הסתכלי, איזה יפה ארץ ישראל"},{"start":1038.33,"end":1040.33,"text":"וואי, איזה פורחת"},{"start":1040.33,"end":1041.33,"text":"איזה את יושבה בה"},{"start":1041.33,"end":1042.33,"text":"איזה עצופה בה"},{"start":1042.33,"end":1043.33,"text":"איזה וזורחת"},{"start":1043.33,"end":1044.32,"text":"וואו"},{"start":1044.32,"end":1046.3,"text":"וואי"},{"start":1046.3,"end":1049.73,"text":"מתחת לסלע צומחת לפה לרכפת נחמדת מאוד"},{"start":1049.73,"end":1052.73,"text":"אז מה ולטיול יצאנו קלנית מצאנו על גבעת הדשא במערב"},{"start":1052.73,"end":1054.73,"text":"אילק במערב אין לך מצפן"},{"start":1054.73,"end":1055.73,"text":"אז מה ולכן משקפה"},{"start":1055.73,"end":1056.73,"text":"אז מה"},{"start":1056.73,"end":1057.69,"text":"אז מה"},{"start":1057.69,"end":1059.85,"text":"וואי וואי וואי הסתכלי"},{"start":1059.85,"end":1061.82,"text":"הנה שנונית במעופה"},{"start":1061.82,"end":1064.26,"text":"אז מה אני ראיתי קודם חצב בתפרחתו"},{"start":1064.26,"end":1066.26,"text":"אילק בתפרחתו חצב"},{"start":1066.26,"end":1067.32,"text":"את לא יודעת מה המצב"},{"start":1067.32,"end":1068.32,"text":"אז מה ואת לא יודעת מה נשמע"},{"start":1068.32,"end":1069.32,"text":"אז מה"},{"start":1069.32,"end":1070.32,"text":"אז מה"},{"start":1070.32,"end":1072.29,"text":"אני לא יכולה תהיה להתכבחי כתב"},{"start":1072.29,"end":1073.29,"text":"את לא מתיבת לכת"},{"start":1073.29,"end":1075.67,"text":"את אפילו לא יודעת איפה זה חומות אקו העתיקה"},{"start":1075.67,"end":1078.62,"text":"אילק אני לא יודעת איפה זה"},{"start":1078.62,"end":1079.56,"text":"איפה זה?"},{"start":1079.56,"end":1080.87,"text":"נו"},{"start":1080.87,"end":1081.87,"text":"אני כאן לא יודע"},{"start":1081.87,"end":1083.38,"text":"נו"},{"start":1083.38,"end":1085.91,"text":"נו איפה זה?"},{"start":1085.91,"end":1086.91,"text":"פגרת"},{"start":1086.91,"end":1088.04,"text":"זה מה זה בסיסי?"},{"start":1088.04,"end":1090.39,"text":"חומות אקו עתיקה"},{"start":1090.39,"end":1091.68,"text":"זה נגיד"},{"start":1091.68,"end":1093.83,"text":"נגיד אתה עולה לשם?"},{"start":1093.83,"end":1094.95,"text":"ומעלית?"},{"start":1094.95,"end":1095.95,"text":"לא במעלית פגרת"},{"start":1095.95,"end":1096.95,"text":"זה ימים עבר"},{"start":1096.95,"end":1097.95,"text":"הוא לא היה מעליות"},{"start":1097.95,"end":1099.58,"text":"נו"},{"start":1099.58,"end":1100.8,"text":"בהליקופטר"},{"start":1100.8,"end":1102.38,"text":"וואו"},{"start":1102.38,"end":1104.38,"text":"ואת נוחתת בבית שען?"},{"start":1104.38,"end":1105.25,"text":"נו"},{"start":1105.25,"end":1107.52,"text":"אז זה"},{"start":1107.52,"end":1108.52,"text":"וואו מאיפה עולך?"},{"start":1108.52,"end":1109.52,"text":"מכל מקום ואתר"},{"start":1109.52,"end":1111.03,"text":"וואו"},{"start":1111.03,"end":1113.53,"text":"אוי חיק אתם עשו אותי רעבה"},{"start":1113.53,"end":1114.53,"text":"אבל אני בדייטה"},{"start":1114.53,"end":1116.85,"text":"אז מה גם אני בדייטה"},{"start":1116.85,"end":1118.85,"text":"אלכ בדייטה עכשיו אכלת חצי לכם"},{"start":1118.85,"end":1120.85,"text":"אז מה ועכשיו את אכלת חצי השני"},{"start":1120.85,"end":1121.85,"text":"אז מה?"},{"start":1121.85,"end":1123.23,"text":"אז מה?"},{"start":1123.23,"end":1124.58,"text":"וואו"},{"start":1124.58,"end":1125.58,"text":"איזה טלקארט"},{"start":1125.58,"end":1127.55,"text":"לא טלקארט פאגרת"},{"start":1127.55,"end":1128.8,"text":"טלפאטיה"},{"start":1128.8,"end":1130.88,"text":"וואו"},{"start":1130.88,"end":1131.88,"text":"יאללה בואי נלך"},{"start":1131.88,"end":1132.88,"text":"אנחנו צריכות להגיע לחיר בית בג'אן"},{"start":1132.88,"end":1133.88,"text":"לפני שקיעת הזריחה"},{"start":1133.88,"end":1135.88,"text":"תיזהרי פה מהכיפוד הים"},{"start":1135.88,"end":1137.75,"text":"וואו"},{"start":1137.75,"end":1153.24,"text":"תודה רבה"},{"start":1153.24,"end":1162.44,"text":"תודה רבה"},{"start":1162.44,"end":1176.37,"text":"תודה רבה"},{"start":1179.37,"end":1216.53,"text":"תודה רבה"}]