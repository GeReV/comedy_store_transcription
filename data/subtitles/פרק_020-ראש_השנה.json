[{"start":30.05,"end":32.05,"text":"ברוכים הבאים"},{"start":32.05,"end":34.05,"text":"לקום ומסתול"},{"start":34.05,"end":37.1,"text":"הלן"},{"start":37.1,"end":39.12,"text":"הוו הלן הלן"},{"start":39.12,"end":41.12,"text":"בסדר גמור, אל תשאל איזה תמונות יש בעיתון"},{"start":41.12,"end":43.12,"text":"תמונות קשות העיתון של היום"},{"start":43.12,"end":46.29,"text":"מה אתה אומר, אתה ראה לי?"},{"start":46.29,"end":48.29,"text":"בואה, באמת תמונות קשות"},{"start":48.29,"end":50.29,"text":"טוב, בוא נעזוב את זה בצד"},{"start":50.29,"end":52.32,"text":"הבאתי עותק של החוזה"},{"start":52.32,"end":52.42,"text":"ערב טוב"},{"start":52.32,"end":54.76,"text":"מה תשתו?"},{"start":54.76,"end":54.86,"text":"קפה"},{"start":54.76,"end":56.89,"text":"איך אתם שותים את הקפה שלכם?"},{"start":56.89,"end":56.99,"text":"ככה"},{"start":56.89,"end":61.61,"text":"הבנתי, אין בעיה"},{"start":61.61,"end":63.64,"text":"אתה מכבד כרטיס האשראי?"},{"start":63.64,"end":63.74,"text":"בבקשה"},{"start":63.64,"end":67.46,"text":"בבקשה"},{"start":67.46,"end":70.0,"text":"בבקשה"},{"start":70.0,"end":72.0,"text":"תהנו חבר'ה"},{"start":72.0,"end":74.47,"text":"באיזה עמוד אתה?"},{"start":74.47,"end":78.1,"text":"אני בעמוד הזה"},{"start":78.1,"end":82.49,"text":"יש טעם לסעיף הזה?"},{"start":82.49,"end":84.65,"text":"אם כך זה מקובל עליי"},{"start":84.65,"end":89.36,"text":"יש לך העת?"},{"start":89.36,"end":92.75,"text":"טוב, נסיים בתקיעת קף"},{"start":92.75,"end":103.51,"text":"למה לא?"},{"start":103.51,"end":110.88,"text":"ושוב הלכנו בהלסטרה של ז'וז'ו"},{"start":110.88,"end":112.98,"text":"והפעם גבירותיי ורבותיי"},{"start":112.98,"end":114.98,"text":"החגים בפתח וז'וז'ו במתח"},{"start":114.98,"end":117.17,"text":"ואמא שלי מה זה חרט הזה?"},{"start":117.17,"end":119.17,"text":"החגים שלנו זה דבר נורא"},{"start":119.17,"end":121.17,"text":"מה זה חרט הזה?"},{"start":121.17,"end":123.17,"text":"יש לנו חגים של אפלפים"},{"start":123.17,"end":125.17,"text":"תראו דוגמת החגים של הגויים"},{"start":125.17,"end":127.17,"text":"באמא שלי שם כל חג זה חג"},{"start":127.17,"end":129.26,"text":"הנה אתם לכם דוגמת"},{"start":129.26,"end":131.42,"text":"יש להם את החג הזה שלהם שנקרא"},{"start":131.42,"end":133.42,"text":"זה חג ההודעה"},{"start":133.42,"end":135.42,"text":"באמא שלי זה חג זה"},{"start":135.42,"end":137.42,"text":"קודם כל כל אמרים תודה תודה"},{"start":137.42,"end":139.42,"text":"שבבי שבבי ואללה זה חג"},{"start":139.42,"end":141.42,"text":"יש שם מגישים באוכל באמא שלי"},{"start":141.42,"end":143.67,"text":"תרנגול הודו"},{"start":143.67,"end":145.67,"text":"זה חזיר בר באמא שלי כזה גודל"},{"start":145.67,"end":147.67,"text":"על השולחן עכשיו זה הם קוראים לו"},{"start":147.67,"end":149.67,"text":"טורקי טורקי אני טורקי"},{"start":149.67,"end":151.67,"text":"אתרנגול לא יודע אם הוא טורקי או הודו"},{"start":151.67,"end":153.67,"text":"לא מבין אבל אתרנגול"},{"start":153.67,"end":155.67,"text":"ממעלים אותו באורז"},{"start":155.67,"end":157.67,"text":"ומגישים אותו לשולחן באמא שלי"},{"start":157.67,"end":159.67,"text":"אני כבר בולש אותו"},{"start":159.67,"end":161.77,"text":"מה יש בארץ? גפיל טיפיש"},{"start":161.77,"end":163.77,"text":"מה זה אחרת הזה עם כל הרועדים"},{"start":163.77,"end":165.77,"text":"והצירים ואת אדמה והגזרים"},{"start":165.77,"end":167.77,"text":"שמחייכים אליך ועושים לך"},{"start":167.77,"end":169.77,"text":"מה זה אחרת הזה באמא שלי"},{"start":169.77,"end":171.77,"text":"זה חזרת? מה זה הלפלפיה הזאת באמא שלי"},{"start":171.77,"end":173.77,"text":"את עושה שמעת אנקסט גיבין"},{"start":173.77,"end":174.77,"text":"יש להם את החג השני"},{"start":174.77,"end":175.77,"text":"הקריסטמנט"},{"start":175.77,"end":176.77,"text":"אללה איזה חג זה הקריסטמנט"},{"start":176.77,"end":177.77,"text":"ואמא שלי"},{"start":177.77,"end":179.77,"text":"זה הראש השבה שלהם"},{"start":179.77,"end":181.77,"text":"הם קונים עץ קשוח"},{"start":181.77,"end":182.69,"text":"ואמא שלי"},{"start":182.69,"end":184.79,"text":"עץ בגודל שבע מטר בבפנים של הבית"},{"start":184.79,"end":186.79,"text":"ושמים עליו כיסותים"},{"start":18