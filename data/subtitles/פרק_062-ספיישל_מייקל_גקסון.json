[{"start":31.39,"end":35.13,"text":"הלוחים, הלוואים, נקו ובסתול!"},{"start":35.13,"end":40.78,"text":"לך בלהע, עבור מוליקוס שלך, שפתיי משקו."},{"start":40.78,"end":42.87,"text":"תודה רבה לך, אישי היקה, תודה."},{"start":42.87,"end":44.45,"text":"יש אתך אל מימצא."},{"start":44.45,"end":47.03,"text":"עכשיו, איפה הילד הזה שלך יפת?"},{"start":47.03,"end":49.63,"text":"הוא בוודאי מתרואה ברחוב, הוא יחזור עוד מעט הבית."},{"start":49.63,"end":51.12,"text":"מה זאת אומרת ברחוב?"},{"start":51.12,"end":52.72,"text":"אני מאמינה שהוא עוד מעט מגיע, הוא ילד טוב."},{"start":52.72,"end":56.12,"text":"השעה שבע בערב, אמרתי בשעה שבע בערב, אני רוצה אותו בבית."},{"start":56.12,"end":59.12,"text":"כאן בשדה שלנו יודעים שיפת הוא ילד, טוב וממושמע."},{"start":59.12,"end":66.64,"text":"מה זה? יפת! יפת! בוא הנה! בוא הנה מיד!"},{"start":66.64,"end":72.8,"text":"מה זה? נכנסים הביתה לא אומרים שלום? שלום למול שבאל! בוא הנה!"},{"start":72.8,"end":77.55,"text":"מה זה? איך אתה נראה? מה זה? מה זה צריך להביע?"},{"start":77.55,"end":83.01,"text":"זה הבגדים של חבר שלי, מייקל ג'קסון. אני מאריץ אותו, הוא חבר שלי."},{"start":83.01,"end":85.01,"text":"מה זאת אומרת חבר של... תסתכל!"},{"start":85.01,"end":88.01,"text":"מה עשית על הסערות באף של חייפת? צבעת אותם?"},{"start":88.01,"end":92.51,"text":"לא, אני... קבלתי לתוך הדלי של החזרת של אמא..."},{"start":92.51,"end":93.51,"text":"יפת, יפת, יפת, אתה נראה בבילי."},{"start":93.51,"end":96.51,"text":"בילי ג'י, לך מה..."},{"start":96.51,"end":103.42,"text":"תראי, תראי איך גידלת אותו את הביטי!"},{"start":103.42,"end":106.51,"text":"ביטי, ביטי, ביטי, ביטי..."},{"start":106.51,"end":108.6,"text":"די וואלי כל מי, וואלי ממוריין..."},{"start":108.6,"end":111.6,"text":"יפת, יפת, יפת, יפת, יפת, יפת, רגע!"},{"start":111.6,"end":113.6,"text":"למה אתה עושה לנו את זה?"},{"start":113.6,"end":119.6,"text":"יפת, יפת, יפת, יפת, יפת, יפת!"},{"start":119.6,"end":125.81,"text":"אם אתה לא תפסיק עם השטויות האלה, אני זורק עליך העיל!"},{"start":125.81,"end":136.15,"text":"בנים גידלתי, בנים גידלתי, תראי, לובש את התחתונים על המכנסה!"},{"start":136.15,"end":138.15,"text":"תרקה, תרקה, תרקה, תרקה, יפת!"},{"start":138.15,"end":140.15,"text":"אתה אולי רוצה קוס מים?"},{"start":140.15,"end":152.14,"text":"יפת, יפת! לא, לא יעזור ככה, צריך לדבר איתו בפסיכולוגיה!"},{"start":152.14,"end":159.72,"text":"יפת, תקשיב טוב, מייקל ג'קסון לא יכול להיות חבר שלך!"},{"start":159.72,"end":162.38,"text":"לא יכול! הוא כן יכול!"},{"start":162.38,"end":167.66,"text":"הוא לא יכול, הוא זמר גוי, הוא גר בגולה, הוא לא פה!"},{"start":167.66,"end":169.66,"text":"הוא חבר שלי! הוא לא!"},{"start":169.66,"end":171.66,"text":"הוא לא! הוא חבר שלי! הוא לא!"},{"start":171.66,"end":173.66,"text":"הוא כן חבר שלי! הוא לא חבר שלך!"},{"start":173.66,"end":175.94,"text":"אתם יודעים מה? הנה תראו!"},{"start":175.94,"end":178.45,"text":"מייקל!"},{"start":178.45,"end":180.72,"text":"מייקל! מה עניינים!"},{"start":180.72,"end":182.72,"text":"מה זה?"},{"start":182.72,"end":187.43,"text":"אורי יפת!"},{"start":187.43,"end":189.43,"text":"מייקל! שלום לבושבת מייקל!"},{"start":189.43,"end":191.43,"text":"שלום לבושבת יפת!"},{"start":191.43,"end":193.43,"text":"הם נערים טוב ביחד!"},{"start":193.43,"end":195.43,"text":"תראה איזה יופי של מושלמות!"},{"start":195.43,"end":197.42,"text":"שחור ולבן!"},{"start":197.42,"end":220.85,"text":"נאו, לסדאנס מייקל!"},{"start":220.85,"end":223.03,"text":"איך אבל אל תחזור מאוחר!"},{"start":223.03,"end":225.44,"text":"לסדאנס!"},{"start":225.44,"end":231.72,"text":"אתה עורי בלדים, נכון?"},{"start":231.72,"end":233.72,"text":"ברוכים הבאים להצטדיון הפועל מזכרת בטיה!"},{"start":233.72,"end":235.72,"text":"כאן עומד להיפתח ברגעים אלה"},{"start":235.72,"end":237.72,"text":"כינוס הפועל עם הופעת הזמר האורח"},{"start":237.72,"end":239.72,"text":"הישר מלאס וגאס"},{"start":239.72,"end":241.72,"text":"ניל סדאקה!"},{"start":241.72,"end":243.84,"text":"קבלו אותו הישר מהנפטלין"},{"start":243.84,"end":245.84,"text":"אוי, סטי ביי מי"},{"start":245.84,"end":248.99,"text":"אילנה"},{"start":248.99,"end":251.27,"text":"אוי, אילנה"},{"start":251.27,"end":253.53,"text":"ובכן, ההופעה"},{"start":253.53,"end":255.53,"text":"הנפלאה הזאת של ניל סדאקה"},{"start":255.53,"end":257.53,"text":"ששר בפלייבק מלאקי בגילו הוא כבר לא יכול לשיר"},{"start":257.53,"end":259.53,"text":"עלתה לנו למרכז הפועל כשמונה מאות אלף דולר"},{"start":259.53,"end":261.53,"text":"ולכן כל המשחקים כולם"},{"start":261.53,"end":263.53,"text":"התקיימו ביצדיון הנטוש"},{"start":263.53,"end":265.53,"text":"בטל חורפשה בועחה בית מעלול"},{"start":265.53,"end":267.53,"text":"בוא נעבור לשם מיד"},{"start":267.53,"end":269.53,"text":"לראות את מהרות השליחים"},{"start":269.53,"end":282.41,"text":"שקלים אדוני"},{"start":282.41,"end":283.95,"text":"נחל אותה אדוני בחמש דקות"},{"start":283.95,"end":285.65,"text":"מצטערנו עשרים שקל לסגור עניין"},{"start":285.65,"end":287.63,"text":"אוקיי תתאמנו עולה תשתפרו"},{"start":287.63,"end":289.63,"text":"אחלה פיצה אחלה אחלה פיצה אני אוהב אתכם"},{"start":289.63,"end":291.13,"text":"תודה להתראות ביי"},{"start":291.13,"end":338.37,"text":"בחגיגות כינוס הפועל"},{"start":338.37,"end":341.45,"text":"ולפני שנראה את ההופעה המרהיבה של ציפית פוט"},{"start":341.45,"end":342.89,"text":"בליווי קשקשת על הקלידים"},{"start":342.89,"end":344.97,"text":"נעבור לריצת המתיים מטרים"},{"start":344.97,"end":346.53,"text":"בטל חורשפים בבקשה"},{"start":346.53,"end":366.81,"text":"בוא נחם מה אתם גדולים יותר"},{"start":366.81,"end":368.75,"text":"אחלה כיפה"},{"start":368.75,"end":371.05,"text":"אני אשלח לכם את התמונות הביתה"},{"start":371.05,"end":374.0,"text":"ובכן גבירותיי ורבותיי"},{"start":374.0,"end":376.08,"text":"כרגע קיבלנו הודעה דרמטית"},{"start":376.08,"end":378.32,"text":"דונה סאמר לא תוכל להגיע"},{"start":378.32,"end":380.38,"text":"להופיע בשל גילה המופלג"},{"start":380.38,"end":381.8,"text":"ההליכון של השבור"},{"start":381.8,"end":383.08,"text":"ולכן היא לא תוכל להגיע"},{"start":383.08,"end":385.22,"text":"לכן יופיעו כאן במקומה"},{"start":385.22,"end":387.02,"text":"אפי בין ישראל ודודו זר"},{"start":387.02,"end":389.04,"text":"בלקת שירים מתוך פרפר נחמד"},{"start":389.04,"end":390.86,"text":"אבל עד אז אנו עוברים"},{"start":390.86,"end":393.36,"text":"לידוי פטיש"},{"start":393.36,"end":394.06,"text":"בבקשה"},{"start":406.29,"end":416.19,"text":"ובכן כבירותיי לפני נעילת הכינוס"},{"start":416.19,"end":417.63,"text":"סקופ מתרחש"},{"start":417.63,"end":419.23,"text":"מסע ומתן סודי"},{"start":419.23,"end":421.97,"text":"בין ניל סדקה, דונה סמר"},{"start":421.97,"end":423.35,"text":"ופול אנקה"},{"start":423.35,"end":425.73,"text":"על רכישת קבוצת הפועל תל אביב"},{"start":425.73,"end":427.33,"text":"מדובר כרגע על סכום של"},{"start":427.33,"end":429.99,"text":"שבעים ושלושה דולרים ושני סנט"},{"start":429.99,"end":431.59,"text":"והשתייה עליהם"},{"start":431.59,"end":433.11,"text":"רבותיי סקופ"},{"start":433.11,"end":435.63,"text":"אנו מקווים שסוף סוף יחלצו את הפועל"},{"start":435.63,"end":437.09,"text":"מהמשבר הנורא שהם נמצאים פה"},{"start":437.09,"end":439.15,"text":"יום שחור לספורט הישראלי"},{"start":439.15,"end":440.91,"text":"בתקווה לימים טובים יותר"},{"start":440.91,"end":441.84,"text":"עד כאן"},{"start":473.53,"end":475.53,"text":"מייקל יחלצו את הפועל"},{"start":475.53,"end":477.53,"text":"מייקל"},{"start":477.53,"end":479.53,"text":"מייקל"},{"start":479.53,"end":481.61,"text":"דבר שמלווה אותי עד היום"},{"start":481.61,"end":485.72,"text":"האימהות מתלוננות שאתה אוכל במבושך בזמן הריקוד"},{"start":486.28,"end":488.8,"text":"ובכן איתכם הסליחה עם האות יקרות"},{"start":488.8,"end":489.9,"text":"אך אין מה לומר"},{"start":489.9,"end":491.98,"text":"הרב יצא משליטה"},{"start":491.98,"end":493.68,"text":"יצא מאוד משליטה באותו יום"},{"start":493.68,"end":495.78,"text":"והוא חתך עמוק בבשר החייקח"},{"start":495.78,"end":496.74,"text":"שעד היום כואב לי"},{"start":496.74,"end":499.66,"text":"כואב לי בעיקר בקולות הגבוהים ובריקודים"},{"start":499.66,"end":502.02,"text":"בעיקר בסיבובים ובפליה שענה ושעשה"},{"start":502.02,"end":503.96,"text":"מייקל"},{"start":503.96,"end":505.38,"text":"מהם תוכניותיך להתיד?"},{"start":505.38,"end":508.06,"text":"התוכניות שלי להתיד הם להוציא תקליט"},{"start":508.06,"end":509.3,"text":"ומחזמר"},{"start":509.3,"end":510.22,"text":"בידיש"},{"start":510.22,"end":512.84,"text":"המחזמר יקרא אל תקרא לי לבן"},{"start":512.84,"end":515.23,"text":"אני מקווה שזה יהיה להיט היסטרי"},{"start":515.23,"end":520.18,"text":"יצאו לנגדך גם שמועות שאתה עומד לפרק את הקואליציה"},{"start":520.18,"end":521.9,"text":"אני עומד לפרק את הקואליציה"},{"start":521.9,"end":524.2,"text":"זה חלק מהקליפ הבא שאני עומד להפיק"},{"start":524.2,"end":526.06,"text":"הקליפ יקרא תירוק הקואליציה"},{"start":526.06,"end":527.54,"text":"יש שם מוטיבים יהודיים רבים"},{"start":527.54,"end":530.56,"text":"שם אני הופך מנמר לגפיל תפיש"},{"start":530.56,"end":532.68,"text":"מגפיל תפיש לשלח ציבור"},{"start":532.68,"end":533.86,"text":"וחוזר חלילה"},{"start":533.86,"end":536.78,"text":"עם מוטיבים של הליקופטרים, פוצצויות וכדומה"},{"start":536.78,"end":539.24,"text":"הקליפ יעלה כעשרה מיליוני דולרים"},{"start":539.24,"end":542.22,"text":"ולכן גם אתה צריך לתת יד ולתרום לצורך העניין"},{"start":542.22,"end":542.96,"text":"אתה תורם לנו"},{"start":542.96,"end":563.14,"text":"יופי תודה רבה לך זה הכל הפעם כאן במבזק של ז'ק"},{"start":563.14,"end":564.82,"text":"לילה טוב והמשך צפייה מענה"},{"start":564.82,"end":574.61,"text":"ערב צחר הפזק"},{"start":574.61,"end":578.62,"text":"עכשיו אנחנו בחלנסטרה של ז'זו והפעם חגיגה אמיתית"},{"start":578.62,"end":580.06,"text":"סקוף עולמי"},{"start":580.06,"end":585.64,"text":"הפעם במסגרת הקומנדיסטור תוכלו לראות בו את שניות מעטות את הקליף של מייקל ג'קסאונט"},{"start":585.64,"end":587.37,"text":"את השיר הנפלא של אוס קרימת"},{"start":587.37,"end":590.7,"text":"ובכן השיר הזה הוא שיר בעל היסטוריה העמוקה"},{"start":590.7,"end":594.52,"text":"השיר הושקו בו עשרה מיליונים של טבינות כלים של דולריה"},{"start":594.52,"end":599.34,"text":"ולכן אתם בטח שקרנים לדעת איך קליפ כל כך זול ועממי"},{"start":599.34,"end":602.02,"text":"הגיע דווקא לתוכנית היוקרתית כמו הקובי דיסטור"},{"start":602.02,"end":605.08,"text":"ובכן שימו לב כל הפרשייה החלה כדלק למן"},{"start":605.08,"end":608.96,"text":"קיבלנו מחתב למדור שלנו זוזו ונבל אש"},{"start":608.96,"end":612.18,"text":"קיבלנו מחתב מבחור קושי מיוניטד סטייטס"},{"start":612.18,"end":615.12,"text":"בחור קושי עם שער אפרו"},{"start":615.12,"end":619.98,"text":"ראיתי אותו בתמונה חשבתי זה פרצומת לספוג שמנקה כלים"},{"start":619.98,"end":622.04,"text":"אבל הוא אמר לנו כדלק למן שופופו"},{"start":622.04,"end":628.72,"text":"אני אקריא לכם את המכתב, המכתב נרשם לנו באנגליתית, אבל אנחנו תרגמנו אותו לעברית שיחה על מנת שיבינו צופנו."},{"start":628.72,"end":629.22,"text":"שוב ובו."},{"start":629.22,"end":635.63,"text":"דיר מיסטר חלאסטרה, אני שחתן עליך זוזו, מה העניינים אחרי יש לך אחלה פינה."},{"start":635.63,"end":642.23,"text":"אני זמר אמריקאי שכום האור בתחילת הקריירה שלי, ואני מאוד מעריץ את התוכנית הקומדיסטור."},{"start":642.23,"end":645.9,"text":"אני שר, אני רוקד, ואני יודע את המילים של חם ויפד בעל פה."},{"start":645.9,"end":648.87,"text":"אני הייתי מאוד רוצה לקבל הזדמנות להופיע בתוכניתכם."},{"start":649.75,"end":654.33,"text":"אני מאמין שהופעה אחת שלי בתוכניתכם המכובדת תוכל להזניק את הקריירה שלי."},{"start":654.33,"end":657.61,"text":"חוץ מזה לדוד שלי ג'ייקוב, יש לו חנות וידאו בברוקלין,"},{"start":657.61,"end":661.85,"text":"והוא צילם אותי ואת אחותי החמודה ז'נט, כבר שם של פתישה ז'נט,"},{"start":661.85,"end":665.51,"text":"הלאה, הוא צילם אותנו בשיר שגם אני כתבתי וגם הנחנתי,"},{"start":665.51,"end":667.25,"text":"קוראים לשיר הזה סקרים."},{"start":667.25,"end":669.88,"text":"אני, אהה, משהו כזה."},{"start":669.88,"end":674.86,"text":"עשינו קליף קטן, ואומנם זה לא דומה לשיר התרתה שעשיתם,"},{"start":674.86,"end":678.8,"text":"אבל יש לו את הכבוד שלו, ואני מאמין שעשיר הוא בעל פוטנציאל."},{"start":678.8,"end":682.8,"text":"אני מקווה ג'וזו פטיש יקר, שהיא תסכים לשדר את הקליפ שלי."},{"start":682.8,"end":685.46,"text":"באנגלית הוא כתב, ג'וזו, דבסט המר."},{"start":685.46,"end":687.32,"text":"אני, אהה, חושק שוקה."},{"start":687.32,"end":690.26,"text":"בכבוד רב ובתודה וראש, מייקל ג'קסון."},{"start":690.26,"end":693.52,"text":"נונבט, ג'וזו, אם תוכל לשלוח לי את הטלפון של אורן הקטן."},{"start":693.52,"end":700.04,"text":"ובכן, מתוך התחשבות ואהבה לתת הזדמנות גם לזמרים שכומי אור,"},{"start":700.04,"end":702.7,"text":"וגם לזמרים בעלי תספורות מוזרות,"},{"start":702.88,"end":704.68,"text":"החלטנו לתת כאן הזדמנות נדירה."},{"start":704.68,"end":707.21,"text":"ולמייקל ג'קסון ולאחותו ז'נת,"},{"start":707.21,"end":708.65,"text":"בעיקר בגלל החודר, אגב,"},{"start":708.65,"end":710.43,"text":"החלטנו לתת הזדמנות נדירה."},{"start":710.43,"end":712.21,"text":"והפעם, בהופעה היה,"},{"start":712.21,"end":714.6,"text":"הקליף סקרימפ."},{"start":714.6,"end":715.93,"text":"שוב, שוב, שוב."},{"start":715.93,"end":1003.24,"text":"ובכן, לדיסן ג'נטלמנט,"},{"start":1003.24,"end":1006.31,"text":"זה היה הקליף סקרימפ של מייקל ג'קסון,"},{"start":1006.31,"end":1007.87,"text":"ותרשלי מייקל, ידידי הצעיר,"},{"start":1008.11,"end":1010.31,"text":"אני כבר שלחתי עליי מכתב לעוצלי ג'וץלי,"},{"start":1010.31,"end":1012.64,"text":"תן לי לתנת לך הערה הדבונה."},{"start":1012.64,"end":1015.39,"text":"מה זה החרט הזה מייקל?"},{"start":1015.39,"end":1017.65,"text":"באמא שלי אני מוכזב עד קשות."},{"start":1017.65,"end":1018.93,"text":"מה זה החרט הזה?"},{"start":1018.93,"end":1020.63,"text":"החללית, באמא שלי,"},{"start":1020.63,"end":1023.03,"text":"עשר מיליון דולר ולא הביאו לך צבע בכליף,"},{"start":1023.03,"end":1024.23,"text":"שחון לבד."},{"start":1024.23,"end":1025.23,"text":"זה מזמר היה עושים,"},{"start":1025.23,"end":1027.19,"text":"עכשיו יש צבעוני, לא שמעיית על זה."},{"start":1027.19,"end":1029.46,"text":"ממש מוזר, עבדו עליך אחי."},{"start":1029.46,"end":1031.06,"text":"וכזה קליפ משוכלל,"},{"start":1031.06,"end":1032.96,"text":"ואתה לא יכול לשחק יותר ממשחק טלוויזיה,"},{"start":1032.96,"end":1033.86,"text":"מעבל שחק."},{"start":1033.86,"end":1037.46,"text":"ולא מבדילים מ-מייקל, מי ג'קסון, מי ג'אנד, לא יודעים."},{"start":1037.46,"end":1039.96,"text":"כולם, אתם שתיכם נראים אותו דבר, ממה שלי."},{"start":1039.96,"end":1042.96,"text":"שתיכם שחיפים, הרזים רק אחד יותר כהי מהשני, אלא."},{"start":1042.96,"end":1045.96,"text":"לא יומנים, היה צבע, היינו יכולים להבחין, אלא."},{"start":1045.96,"end":1047.96,"text":"פתאום ראו ציצים, לא ידענו."},{"start":1047.96,"end":1051.16,"text":"זה העף שלך, זה המרפק שלך, זה הנחיר נפל, לא ידענו."},{"start":1051.16,"end":1052.26,"text":"ממש מצוקה."},{"start":1052.26,"end":1055.46,"text":"למרות שבקליפים הקודמים שלך, מייקל, לשחר ההיסטוריה,"},{"start":1055.46,"end":1057.56,"text":"הייתה דווקא הבנה טובה בקליפים."},{"start":1057.56,"end":1060.36,"text":"למשל, בקליפ הנפלא שלך, I'm black, I'm white."},{"start":1060.36,"end":1061.86,"text":"הייתה יופי של עבודה."},{"start":1061.86,"end":1064.06,"text":"שם מה שהייפה זה הפרצופים המתחלפים."},{"start":1064.06,"end":1067.56,"text":"באמא שלי, פתאום אתה מייקל, פתאום אתה מתהפכת להיות בחורך בלונדינית."},{"start":1067.56,"end":1071.26,"text":"אתה חוזר להיות אינדיאני, אתה חוזר כבית, פתאום אתה חן בני, פתאום אתה מוכר בגלה."},{"start":1071.26,"end":1073.36,"text":"באמא שלי, זה היה פרצומת."},{"start":1073.36,"end":1077.06,"text":"למה? למה הבנו את כל התהליך שעברת בניתוחים פלסטיים שלך."},{"start":1077.06,"end":1078.46,"text":"זה מה שהייפה."},{"start":1078.46,"end":1079.96,"text":"ובסוף גם הפכת לנמר."},{"start":1079.96,"end":1085.02,"text":"אני היה מוסר אסכל מג'קסון לזוזו, שניים מתחיל בג\"ל."},{"start":1085.02,"end":1087.02,"text":"לא יהיו מרקי סופר."},{"start":1087.02,"end":1088.02,"text":"זה היה אחלה קליפ."},{"start":1088.02,"end":1089.02,"text":"גם אין לך את הקליפ טרילר."},{"start":1089.02,"end":1092.02,"text":"טרילר, זה היה קליפ שיש לנו ובסם בטרילר ביחד וחשבנו עליו."},{"start":1092.02,"end":1093.02,"text":"זה גם אחלה קליפ."},{"start":1093.02,"end":1096.02,"text":"שאתה נהיה מייקל, פתאום אתה נהיה מפלצת ירוקה."},{"start":1096.02,"end":1098.02,"text":"באמא שלי נזלת ניידת."},{"start":1098.02,"end":1099.02,"text":"לא יהיו מרקי סופר."},{"start":1099.02,"end":1101.02,"text":"איזה פעד, הבחורת שחקת."},{"start":1101.02,"end":1103.02,"text":"זה גם היה ספחה גדולה."},{"start":1103.02,"end":1105.02,"text":"זה סבירה את תהליך ההפיכת שלך."},{"start":1105.02,"end":1107.02,"text":"ממייקל השחר והחביב מהשכונה."},{"start":1107.02,"end":1110.02,"text":"למייקל הבהיר והשלגון מהשירים הבאים."},{"start":1110.02,"end":1112.02,"text":"באמא שלי זה פשוט מהפך שלם."},{"start":1112.02,"end":1113.02,"text":"זה היה ברור."},{"start":1113.02,"end":1115.02,"text":"אבל מה שקורה עכשיו זה מצוקה."},{"start":1115.02,"end":1117.02,"text":"מייקל למה לא לעשות קליפ כמו שצריך?"},{"start":1117.02,"end":1119.02,"text":"תביא לעקה מזרחית."},{"start":1119.02,"end":1121.02,"text":"במקום הסנתסטייזרים וכל הגיטרה."},{"start":1121.02,"end":1123.02,"text":"וכמה מנדולינות ועוד."},{"start":1123.02,"end":1126.02,"text":"תביא את זוזו מוסיקה עם המשקפי שמש שלו ירוקלוק."},{"start":1126.02,"end":1129.02,"text":"ככה לעקה עם יחיות כפיים איזה מעוול טוב."},{"start":1129.02,"end":1133.02,"text":"אתם יכולים לעשות מעוול ובסופה כמו שאתה אוהב, למה לא? למה לא לנצל?"},{"start":1133.02,"end":1138.98,"text":"וז'אנט יכולה לרקוט בטן. יש לך כישורים לז'אנט, גם שם ז'אנט וגם חזון, ואללה."},{"start":1138.98,"end":1143.98,"text":"תן לה לרקוט בטן, תן 20 דולר. זה יקליפ 20 מיליון דולר ואנשים יסמחו, ואללה."},{"start":1143.98,"end":1145.98,"text":"לכן, מייקל, המוסר רז כאלו מאוד פשוט."},{"start":1145.98,"end":1149.94,"text":"פעם הבאה שאתה בא להוציא 10 מיליון דולר, תחשוב, תחשוב."},{"start":1149.94,"end":1153.94,"text":"אם לז'נת משעמם ואתה עושה את השולם, לא צריך לעשות 10 מיליון."},{"start":1153.94,"end":1159.94,"text":"שלח את ז'נת אליי. אצלי תהיה, כמו שאומר הפתגם, בין הפתיש לסדין."},{"start":1159.94,"end":1161.94,"text":"וואו, וואו, וואו, תחשוב על זה, מייקל."},{"start":1161.94,"end":1164.93,"text":"וואו, וואו, וואו."},{"start":1164.93,"end":1179.72,"text":"חשמל, קדימה."},{"start":1179.72,"end":1180.72,"text":"מכת חשמל, התרחק."},{"start":1180.72,"end":1182.69,"text":"קדימה, תלו את זה."},{"start":1182.69,"end":1183.69,"text":"תלו, תלו עוד לך, תלו עוד לך."},{"start":1183.69,"end":1184.69,"text":"הוא לא נגיד, הוא לא נגיד לי."},{"start":1184.69,"end":1187.69,"text":"מקסימום, מקסימום להתרחק."},{"start":1187.69,"end":1189.94,"text":"תלו עוד לך, תלו עוד לך, תלו עוד לך, תלו עוד לך."},{"start":1189.94,"end":1191.94,"text":"מקסימום להתרחק!"},{"start":1191.94,"end":1199.93,"text":"ניבדנו אותו."},{"start":1199.93,"end":1207.07,"text":"סניטארים, תשלחו לי מטה ריקה."},{"start":1207.07,"end":1210.54,"text":"כן, ניבדנו אותו, ביי."},{"start":1210.54,"end":1211.54,"text":"חבל, חבל, חבל."},{"start":1211.54,"end":1213.54,"text":"היה איש גדול, היה איש גדול."},{"start":1213.54,"end":1214.54,"text":"היה מפיק ענק."},{"start":1214.54,"end":1215.64,"text":"מפיק?"},{"start":1215.64,"end":1216.76,"text":"מה, אתה לא הכר אותה אותו?"},{"start":1216.76,"end":1217.66,"text":"לא."},{"start":1217.66,"end":1220.89,"text":"מה אחד הגדולים, אתה יודע מה, בלוס אנג'לס היה לו קשרים."},{"start":1220.89,"end":1223.11,"text":"מה אתה אומר, תראה, אתה בא לפרו אנונימי בשבילך ואתה..."},{"start":1223.11,"end":1229.11,"text":"את מי הוא לא יכיר, ג'וליה רוברט, שרון סטון, כולם היו אצלו, מל גיבסון, מלני גריפיט."},{"start":1229.11,"end":1230.11,"text":"מה אתה אומר?"},{"start":1230.11,"end":1231.11,"text":"הגיר אותם אישית."},{"start":1231.11,"end":1236.11,"text":"עכשיו חבר שלי חזר מפסטיבל כאן, ראה אותו שותה קפה עם מל, אוכל צהריה ממלני."},{"start":1236.11,"end":1237.11,"text":"ממש, אתה יודע, חברי..."},{"start":1237.11,"end":1238.11,"text":"האיש הזה?"},{"start":1238.11,"end":1240.39,"text":"מה אתה אומר, תראה מה זה."},{"start":1240.39,"end":1241.61,"text":"יאללה."},{"start":1241.61,"end":1244.66,"text":"אוזז, אוזז, אוזז!"},{"start":1244.66,"end":1246.66,"text":"לא יודע, תביא את הרשמל!"},{"start":1246.66,"end":1247.66,"text":"תן לי את הרשמל!"},{"start":1247.66,"end":1249.72,"text":"הרשמל, רגע! רגע שנייה!"},{"start":1249.72,"end":1251.42,"text":"מה אתה אומר?"},{"start":1251.42,"end":1253.31,"text":"מה אתה אומר?"},{"start":1253.31,"end":1254.49,"text":"מה אתה אומר?"},{"start":1254.49,"end":1256.64,"text":"שאני שתיתי קפה עם מל?"},{"start":1256.64,"end":1258.64,"text":"או שאני שתיתי קפה עם אל?"},{"start":1258.64,"end":1260.63,"text":"אמרתי שאתה שתיתי קפה עם אל?"},{"start":1260.63,"end":1261.63,"text":"לא, אתה לא..."},{"start":1261.63,"end":1262.63,"text":"הוא לא הבין אותי."},{"start":1262.63,"end":1263.63,"text":"זה שני דברים שונים לגמרי."},{"start":1263.63,"end":1264.63,"text":"אתה כשתסביר לו."},{"start":1264.63,"end":1266.63,"text":"יש קפה עם מל!"},{"start":1266.63,"end":1267.63,"text":"זה עם מל!"},{"start":1267.63,"end":1268.63,"text":"אתה כאן!"},{"start":1268.63,"end":1269.63,"text":"זה אחד!"},{"start":1269.63,"end":1271.63,"text":"יש קפה עם אל!"},{"start":1271.63,"end":1272.63,"text":"זה שני דברים שונים לגמרי!"},{"start":1272.63,"end":1273.63,"text":"זה שחקר!"},{"start":1273.63,"end":1274.63,"text":"זה טבלין!"},{"start":1274.63,"end":1275.63,"text":"מה אמרת לי?"},{"start":1275.63,"end":1278.68,"text":"אבל הוא לא מבין אותי!"},{"start":1278.68,"end":1279.68,"text":"לא, הוא אמר את זה קפה עם אל!"},{"start":1279.68,"end":1281.68,"text":"יש קפה עם אל!"},{"start":1281.68,"end":1282.68,"text":"זה אחד!"},{"start":1282.68,"end":1314.37,"text":"רעיון המלא עם מייקל ג'קסון ואשתו ישודר הערב בשעה העשרה לעשר לאחר פרק בסדרה \"זהב של שוטים\""}]