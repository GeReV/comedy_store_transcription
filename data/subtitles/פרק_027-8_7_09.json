[{"start":30.27,"end":34.78,"text":"ברוכים הבאים לקום ומסתור!"},{"start":34.78,"end":75.16,"text":"הבאים לבדיחה חכה עם חיים בלוף"},{"start":75.16,"end":79.53,"text":"שלום לכולם, שלום חגל בדיחה חכה עם חיים בלוף"},{"start":79.53,"end":81.59,"text":"שוב אנחנו גן איתכם כבידי שבוע"},{"start":81.59,"end":86.83,"text":"והשבוע שלחנו את דנוני הנפלאה שלנו לשוויצריה לעשות סקי"},{"start":86.83,"end":89.61,"text":"את איגור המקסים שלחנו לכלא הטורקי"},{"start":89.61,"end":94.98,"text":"והפעם המצלבה שלנו"},{"start":94.98,"end":102.91,"text":"מתלבה למושון הכנסנו את מושון לתוך פח זבל"},{"start":102.91,"end":106.47,"text":"איך אומרים החיים בזבל התלבנו למושון"},{"start":106.47,"end":108.21,"text":"ובואו ונראה מה ככה"},{"start":108.21,"end":113.69,"text":"ובכן גבירותיי ורבותיי זהו פח ההשפעה וזהו מושון על המושון"},{"start":113.69,"end":118.53,"text":"ובכן הציעו לב אנחנו מטמינים את מושון היטב בתוך הפח"},{"start":118.53,"end":122.63,"text":"ואנחנו מחכים לקורבן הראשון"},{"start":132.54,"end":137.58,"text":"מה זה מקרה? אתה עובר? אני יוצא לך מהפח! מה זה מקרה לך?"},{"start":137.58,"end":140.38,"text":"ו? מה?"},{"start":140.38,"end":142.47,"text":"בטומטר"},{"start":142.47,"end":146.49,"text":"חיים שיחקנו אותה!"},{"start":146.49,"end":153.47,"text":"מושון הוא פתח אנחנו נחזור אליך מושון"},{"start":153.47,"end":159.97,"text":"שימו לב הקורבן הבא הולך לשרוג זבל בתוך הפח והזבל הולך לפעול על מושון והוא לא יודעת"},{"start":159.97,"end":166.61,"text":"אה! חייש לנו את זה!"},{"start":166.61,"end":169.23,"text":"שלום לך"},{"start":169.23,"end":169.79,"text":"שלום"},{"start":169.79,"end":172.2,"text":"טוב זהר אותי לא"},{"start":172.2,"end":174.49,"text":"חייך למצלבה"},{"start":174.49,"end":177.29,"text":"וחיים לא"},{"start":177.29,"end":179.29,"text":"חיים תראה מה הוא זרק"},{"start":179.29,"end":182.29,"text":"נו אתה מסכים שתשודר את הקטע"},{"start":182.29,"end":184.29,"text":"שדרו תעשור מה שאתם רוצים ואתה אכפת"},{"start":184.29,"end":187.28,"text":"סרטון"},{"start":187.28,"end":189.28,"text":"סרטון"},{"start":189.28,"end":192.28,"text":"הוא פשוט קרוע"},{"start":192.28,"end":193.28,"text":"שדרו"},{"start":193.28,"end":196.08,"text":"ובכן"},{"start":196.08,"end":197.98,"text":"אנחנו עוד נחזור למושון"},{"start":197.98,"end":200.08,"text":"אני פה חיים"},{"start":200.08,"end":201.08,"text":"שדרו"},{"start":201.08,"end":219.63,"text":"חרב זך, שוב אנחנו בהלסטר של זוזו, והפאנק ורותיי ורבותיי, רציתי לדבר איתכם על שער אוריה, מי הדחי לדחקי, פינות היעוץ."},{"start":219.63,"end":227.41,"text":"מה זה החרטיטותתי הזה? כל עיתון באמא שלי שיש לו יותר מארבע דפים, מביא זה יועץ שעונה לשאלות הקהל."},{"start":227.41,"end":238.09,"text":"מה זה שטויות האלה? רות וסטיימנט ודוקטור עמי פיסטוק שעונה לנו בענייני שחלות ועלבנים ועלבנות ויש לנו, כל אחד יש לו מכתב סודי."},{"start":238.09,"end":241.39,"text":"מי יש לו מכתב סודי? מה זה שטויות האלה? זה פשוט שער אוריה."},{"start":241.39,"end":248.35,"text":"לכן החלטנו להביא ענה לאולפן מומחה שיענה לכם הצופים בבית על כל מיני בעיות שיש לכם בחיים."},{"start":248.35,"end":254.75,"text":"במקרה נמצא איתי אני ואני אענה לכם על כל שאלה שתרצו ותחפיצו לנעת."},{"start":254.75,"end":264.23,"text":"מתוך אלפי המכתבים שקיבלנו שימו לב רבותיי שק עמוס, החלטנו לבחור אולי כמה מכתבים שנתייחס אליהם בשידור."},{"start":264.23,"end":269.14,"text":"כן, הנה ובחרנו שלושה, כן. ובכן בואו נתחיל גבירותיי ורבותיי."},{"start":269.48,"end":274.27,"text":"המכתב הראשון כתוב לי ככה: \"שלום לאט ג'ו-ג'ו\"."},{"start":274.27,"end":278.13,"text":"ג'ו-ג'ו כבר בן אדם אהבל, לא כותבים עם ג'ימל אלא עם ז'יין."},{"start":278.13,"end":280.47,"text":"ג'ו-ג'ו, לא ג'ו אלא ג'ו."},{"start":280.47,"end":286.32,"text":"שמי רחמיל קרמבו, לפלפ במקצועי הוא בין 27, ואני נראה כך."},{"start":286.32,"end":289.88,"text":"אני נשוי שלוש שנים לאישה מדהימה שנראית כך."},{"start":289.88,"end":292.21,"text":"ג'ו-ג'ו, אשתי בוגדת בלי לא הפסק."},{"start":292.21,"end":295.44,"text":"זה פוגם בגבריות שלי, איך אשכם את עצמי."},{"start":295.44,"end":299.48,"text":"שים לב, רחמי אל יקרי. קודם כל תשנה מרחמי לרחמות."},{"start":299.48,"end":303.76,"text":"דבר שני, אתה צריך שיפוץ בפנים, צריך לעבור נגריה, אין מה לעשות."},{"start":303.76,"end":306.76,"text":"תגדל זקן, תגדל שער, תסתיר את המראה."},{"start":306.76,"end":310.03,"text":"דבר שלישי, דחוף את הכתובת של אשתך."},{"start":310.03,"end":312.4,"text":"תעביר לי כי הבעיה היא אצלה."},{"start":312.4,"end":317.27,"text":"אני אסביר לה את הנושא מקרוב, אני אעמיד אותה על הדברים ותחשוב על זה."},{"start":317.27,"end":320.63,"text":"כן, ונעבור למכתב הבא שלנו, יש לנו כאן עוד מכתב מעוד בן אדם."},{"start":320.63,"end":322.03,"text":"בוא נראה מה הוא כותב לנו."},{"start":322.03,"end":327.06,"text":"ובכן, הבן אדם הזה כותב לי כה: \"שלום, זו זו החינו\" כבר בן אדם חביב."},{"start":327.06,"end":329.64,"text":"קוראים לי שמעון, אני פטיש ואני נראה כך."},{"start":329.64,"end":334.62,"text":"מצפוני מציק לי כבר שלוש שנים כי אני מנהל רומן סוער עם אשתו של חברי הטוב ביותר."},{"start":334.62,"end":337.06,"text":"אשתו נראית כך."},{"start":337.06,"end":340.69,"text":"בזמן האחרון נראה לי שהיא אוהבת בבחור שלישי נוסף."},{"start":340.69,"end":344.24,"text":"זו זו הלפ מי, I love her very much."},{"start":344.24,"end":346.04,"text":"אני, אני אוהב שיער הרבה מאוד."},{"start":346.04,"end":348.2,"text":"הר, הוא כנראה ספר במקצוע."},{"start":348.2,"end":358.73,"text":"ובכן, שמעון ידידי, לא יפה לפגוד עם אשת חבר, לכן דחוף, תעביר לי את הטלפון שלה שאני אעמיד אותה על הבעיה שלה בעצמי."},{"start":358.73,"end":370.57,"text":"ובכן, נעבור למכתב האחרון, שי נשאל לנו, המכתב האחרון, ובכן כך כתוב, זו זו יקר, שמי שולמית הר נבוא, והרי תמונתי, אני נראית כך."},{"start":370.57,"end":379.52,"text":"אני קרועה בין אהבתי לשני גברים, האחד בעלי והשני חברו הטוב, בזמן האחרון נדלקתי עליך."},{"start":379.52,"end":410.14,"text":"מחכה לך. כתובתי ומספר הטלפון, הם קטליק למעניים. רחובה אצל... חיים! תשמין ליבונית! חבריה, תחשיבו על משהו, אני הולך לתת כמה עצות היום. איך אומרים? ושבו בנות לקבולה, ובנים ישובו על לקבותיו. מהי? אני תראות. בוא אמא, אני מגיע! אני נהוא! ערב טוב. הרי די השיגי הזה אתה. מה ככה את השפוקדת את הלבים? המצלמה המשוטטת של ג'ודי."},{"start":410.14,"end":419.91,"text":"ערב טוב. כאן ג'ודי לאוצה ארונוב, קרפינסוף, מעשה במחשבה תחילה המתחיל במצווה, אומרים לו גמור."},{"start":419.91,"end":424.67,"text":"מגה חדשה נוחתת על המדינה, חיידק האמצע פוס."},{"start":424.67,"end":430.75,"text":"אמצע פוס, חיידק אכזריה לוקח את האמצע ומשאיר את הסוף והתחלה בלבד."},{"start":430.75,"end":438.45,"text":"בבת אחת, נעלם האמצע מחיי היום יום, ותושבים רבים מצאו עצמם ללא אמצע."},{"start":438.45,"end":444.31,"text":"לקחנו את המצלמה המשוטטת ויצאנו לבדוק הכאמצעתה."},{"start":444.31,"end":449.34,"text":"כאן סופיה לורן לרנקה, רוץ סוף עבור."},{"start":449.34,"end":452.19,"text":"הלו?"},{"start":452.19,"end":453.8,"text":"הלו, זה גיל?"},{"start":453.8,"end":455.08,"text":"כן, מי זה? דווד?"},{"start":455.08,"end":456.66,"text":"כן, ביי, להתראות."},{"start":456.66,"end":458.04,"text":"ביי ביי, להתראות."},{"start":458.04,"end":464.38,"text":"למקומות, היקון."},{"start":464.38,"end":485.33,"text":"מה הבחורה יפה כמוך, עושה כאן לבד, אה?"},{"start":485.33,"end":488.8,"text":"משה."},{"start":488.8,"end":490.04,"text":"אורנה."},{"start":490.04,"end":496.85,"text":"לילי, לילי, לילי, לילי, לילי."},{"start":496.85,"end":500.35,"text":"אה, אה, תשכח ירושלים, תשכח ימידי, שבור את הכל."},{"start":500.35,"end":504.03,"text":"ביי, לילי, לילי, לילי."},{"start":504.03,"end":508.85,"text":"מזל טוב וסימה טוב, מזל טוב וסימה טוב, מזל טוב ומזל טוב."},{"start":508.85,"end":511.87,"text":"אה, אה, אה, אה."},{"start":511.87,"end":515.46,"text":"ערב צח, ערב זח, ושוב אנחנו בחלסטרה של ג'וזו."},{"start":515.46,"end":516.78,"text":"ותחשבו על זה."},{"start":516.78,"end":517.96,"text":"מווו."},{"start":517.96,"end":521.16,"text":"נגמר מהר, לא?"},{"start":521.16,"end":522.71,"text":"אוי."},{"start":522.71,"end":536.49,"text":"אני מבין שאדוני חייל, איך זה קרה לך?"},{"start":537.35,"end":539.91,"text":"כן, נכמר גם עתקתא א'."},{"start":539.91,"end":541.68,"text":"ועכשיו אתה כבר חייל?"},{"start":541.68,"end":544.6,"text":"כן, כל הסיים בצנחנים."},{"start":544.6,"end":549.82,"text":"אך מה שהחל כפרפרה משעשד,"},{"start":549.82,"end":553.5,"text":"הפך במירה למטרד שאין גדול ממנו,"},{"start":553.5,"end":555.56,"text":"יאה, שברתי סי."},{"start":555.56,"end":558.85,"text":"וזו היא רק התחלה, ללא, ללא, ללא."},{"start":558.85,"end":564.63,"text":"וא' פועל באיזה בית, שין שלום ותו תודה, ניצחתי."},{"start":564.63,"end":569.63,"text":"אני חושב שאני אחד הקורבנות היותר גדולים של המחלה הזאת."},{"start":570.1,"end":575.26,"text":"הרופאים אומרים שהטיפול עולה הרבה כסף, אבל מה לעשות? אני חסר אמצעים."},{"start":575.26,"end":579.52,"text":"אה, איפה המצע הזה? אני מת מראה."},{"start":579.52,"end":581.02,"text":"תגיד, אפשר לקבל סגריה?"},{"start":581.02,"end":581.56,"text":"תופשי."},{"start":581.56,"end":584.12,"text":"תודה רבה לך, אחי. אני מוכרח להפסיק, אני לא מסוכר."},{"start":584.12,"end":589.29,"text":"שלום, פעם ראשונה שלכם כאן."},{"start":589.29,"end":590.13,"text":"כן."},{"start":590.13,"end":591.52,"text":"מה אתם רוצים להזמין?"},{"start":591.52,"end":592.93,"text":"את החשבון, בבקשה."},{"start":592.93,"end":594.0,"text":"אין בעיה."},{"start":594.0,"end":597.21,"text":"תני רובס, אני מבין שגם אתה קורבן של מגפת האמצע."},{"start":597.21,"end":602.08,"text":"כן זה קשה מאוד, הייתה לי הופעה של ארבע שעות, נשאר מנה שלוש וחצי דקות, זה באמת מאוד קשה."},{"start":602.08,"end":603.36,"text":"אתה יכול לדגים לנו?"},{"start":603.36,"end":604.35,"text":"בוודאי."},{"start":604.35,"end":615.69,"text":"זה היה קשה. גם בהופעה של הביטלס זה פגע, אני מבין."},{"start":615.69,"end":617.61,"text":"כן, בהופעה של הביטלס זה פגע קשות."},{"start":617.61,"end":624.73,"text":"זה לא רק הביטלס, זה אומות שלמות נפגעו מהעניין הזה, אומות שלמות."},{"start":624.73,"end":629.29,"text":"ארצות הברית למשל, בסופרבול אחרון, האמנון האמריקאי עלתה הזמרת."},{"start":631.45,"end":634.45,"text":"תא תא תא תא תא תא תא."},{"start":634.45,"end":639.13,"text":"בפונדק? מעץ. קשה קשה קשה מאוד."},{"start":639.13,"end":642.13,"text":"לא ידעתי שזאת הייתה הפעם הראשונה שלך."},{"start":642.13,"end":644.1,"text":"אני נורא נורא נהנתי."},{"start":644.1,"end":653.71,"text":"תודה. תודה לך."},{"start":653.71,"end":655.99,"text":"יו זה חמוד יו תודה."},{"start":655.99,"end":663.63,"text":"אכן תמונות קשות, אולם ברמיד אך גיסה חולפים להם הימים ותרופה עין."},{"start":663.63,"end":667.69,"text":"ואין אישה שיודע אם זהו קצת התחילה או תחילת הקט."},{"start":667.69,"end":674.71,"text":"והנה כך הפכו אורם סדרי בראשית ורק הרוח מייבבת מעל קני הסוף."},{"start":674.71,"end":679.18,"text":"כאן ג'ודי וושינגטון."},{"start":679.18,"end":680.15,"text":"אה..."},{"start":680.15,"end":686.76,"text":"חזרתם אלינו אלה בדיחה רכה עם חיים בלוף."},{"start":686.76,"end":691.82,"text":"ובכן, את המתיחה הבעת שלנו החלטנו לעשות ברחוב."},{"start":691.82,"end":697.94,"text":"לקחנו את מושון וחיפשנו אותו לעץ."},{"start":697.94,"end":700.86,"text":"עמדנו אותו באמצע הסדרה."},{"start":700.86,"end":703.94,"text":"בוא נראה מה יקרה. בהצלחה מושון."},{"start":703.94,"end":727.86,"text":"שימו לב לקרבן הבא שלנו."},{"start":727.86,"end":731.86,"text":"הוא לא מבחין שהעץ למעשה הוא מושון."},{"start":731.86,"end":741.1,"text":"דנו אתה תחליף."},{"start":741.1,"end":743.9,"text":"והנה עוד קרבן."},{"start":743.9,"end":750.42,"text":"עובד העירייה שמטפל בעצים בסדרה."},{"start":750.42,"end":755.37,"text":"הוא לא שם לב שמושון הוא בעצם העץ."},{"start":755.37,"end":761.65,"text":"זה בורב לקרבן עבר שלנו."},{"start":761.65,"end":764.65,"text":"הוא עדיין לא קולט שמושון הוא עץ."},{"start":764.65,"end":794.76,"text":"חייב לופו, עוד קאמרה."},{"start":794.76,"end":796.92,"text":"עובד לי קייב."},{"start":796.92,"end":808.74,"text":"ערב טוב, הרי תקציר החדשות."},{"start":808.74,"end":811.74,"text":"כאן במבזק של ז'ק בערוץ הקהילתי שלכם."},{"start":811.74,"end":814.74,"text":"עבר ברית מילה בשיטת \"עשה זאת בעצמך\"."},{"start":814.74,"end":818.41,"text":"בעקבות אותו אדם יצאה לשוק קלטת הדרכה"},{"start":818.41,"end":821.41,"text":"של כהנת מלאכת היד הגדולה, עתיה בוזיאל."},{"start":821.41,"end":825.04,"text":"אבו ונצפה בקטע מהקלטת."},{"start":825.04,"end":826.04,"text":"שלום לכם."},{"start":826.04,"end":829.38,"text":"שוב אני כאן איתכם עתיה בוזיאל"},{"start":829.38,"end":831.3,"text":"בקלטת למלאכת יד"},{"start":831.3,"end":836.38,"text":"והיום נלמד כיצד למול את עצמנו לבד לבד"},{"start":836.38,"end":839.38,"text":"ובכן המצרכים והכלים הדרושים הם:"},{"start":839.38,"end":846.21,"text":"מבאר חשמלי, חרב, גרזנים, מסוריות,"},{"start":846.21,"end":852.21,"text":"מסור עדין, שופין קל, קטר ומסור חשמלי זריז"},{"start":852.21,"end":855.68,"text":"ומקדחה מסתובבת."},{"start":855.68,"end":857.68,"text":"כאשר החשוב ביותר הוא לסיום,"},{"start":857.68,"end":860.67,"text":"אפטר שייף מרוכז 90% אלכואוי."},{"start":860.67,"end":862.79,"text":"וכעת נעבור למלאכה,"},{"start":862.79,"end":866.79,"text":"מגלל שאין לנו זמן, החינון הוא מבעוד מועד מתנדם."},{"start":866.79,"end":870.69,"text":"זהו האסיסטנט שלנו, אסי סטנט, בבקשה."},{"start":870.69,"end":874.83,"text":"ובכן, זהו אסי ולמלאכה."},{"start":874.83,"end":883.1,"text":"כאן אנחנו נאלצים לקטוע את הכתבה."},{"start":883.1,"end":885.41,"text":"הזמר האמריקני מייקל ג'קסון,"},{"start":885.41,"end":887.41,"text":"מי שקונה האיש בעל אלף הפרצופים,"},{"start":887.41,"end":889.41,"text":"עבר ניתוח פלסטי נוסף,"},{"start":889.41,"end":894.4,"text":"רופאו עשר עליו להתגלח וכרגע הוא נראה כך."},{"start":894.4,"end":898.22,"text":"לסוהה שלום."},{"start":898.22,"end":900.34,"text":"ולנושא אחר לגמרי."},{"start":900.34,"end":903.34,"text":"נמצאתי כאן באולפן הממציא הישראלי יושפת טרם."},{"start":903.34,"end":904.34,"text":"ערב טוב יושפת."},{"start":904.34,"end":920.34,"text":"יושי, ספר לנו על המצאתך החדשה."},{"start":920.34,"end":923.44,"text":"ובכן הוות, זו היא מכונה מיוחדת אקסטראורדינר."},{"start":923.44,"end":926.44,"text":"מה שקורה כאן, ברגע שאתה שם אוזניות אלו על אוזניך,"},{"start":926.44,"end":929.44,"text":"אתה שומע שאלות שתשאלנה בעתיד."},{"start":929.44,"end":933.74,"text":"אני אתן לך דוגמה קלה. שבע שנים."},{"start":933.74,"end":935.74,"text":"כמה זמן עבדת על ההמצאה הזו?"},{"start":935.74,"end":938.74,"text":"מברגים, כל מיני שבבים חשמליים שהיו לי בבית."},{"start":938.74,"end":939.74,"text":"ממים רוכבת?"},{"start":939.74,"end":941.74,"text":"אני גרוש, מצטער."},{"start":941.74,"end":943.69,"text":"מה חושבת על ההמצאה אשתך?"},{"start":943.69,"end":945.7,"text":"או, איזה עולנדי ואיזה בטיח. זו שעוריה."},{"start":945.7,"end":947.7,"text":"אתם תמיד מחפשים מתחת לקותרות."},{"start":947.7,"end":949.7,"text":"אנדר ליליינז. אתם צהובים כולכם."},{"start":949.7,"end":950.7,"text":"חוצפה."},{"start":950.7,"end":952.7,"text":"האם זה נכון שאת ההמצאה הזאת המציאה"},{"start":952.7,"end":954.7,"text":"הממציאה הולנדי ונצטיחלנד ואתה גנבת אותה ממנו?"},{"start":954.7,"end":957.7,"text":"בוודאי, אין שום בעיה. נסה ותבחח בעצמך."},{"start":957.7,"end":960.76,"text":"האם אני יכול לנסות בעצמי את המכונה?"},{"start":960.76,"end":962.88,"text":"אה, תחדוי, תחדוי, סמב פרזן."},{"start":962.88,"end":964.84,"text":"אוללה, ותרוע ללם טיסן."},{"start":964.84,"end":965.84,"text":"מרסים, מרסים בקו."},{"start":965.84,"end":967.97,"text":"סביב לפרנס, סביב לפרנס, סביב לפרנס."},{"start":967.97,"end":969.77,"text":"לא."},{"start":969.77,"end":971.77,"text":"רק אם מיותר לי למסורדש למיקי גורדוס."},{"start":971.77,"end":972.77,"text":"תודה רבה."},{"start":972.77,"end":974.96,"text":"אז שכח מזה, מיקי."},{"start":974.96,"end":976.96,"text":"זה הכל בינתיים, כאן במשזק של ז'אק,"},{"start":976.96,"end":978.96,"text":"לילה טוב והמשך צפייה נעימה."},{"start":978.96,"end":980.09,"text":"לבריאות."},{"start":980.09,"end":982.09,"text":"אה, תחו!"},{"start":982.09,"end":1011.99,"text":"היינו לברכת הקרישים,"},{"start":1011.99,"end":1015.02,"text":"והפעם הלבשנו את מושון כמו קריש,"},{"start":1015.02,"end":1019.02,"text":"והחלטנו לעבוד על הקריש שמושון הוא אוכל צמחוני."},{"start":1019.02,"end":1024.02,"text":"שימו לב, הקרישים אורעבו במיוחד לצורך הצילומים שלנו"},{"start":1024.02,"end":1026.02,"text":"במשך שבועיים."},{"start":1026.02,"end":1029.02,"text":"מושון מוכן למסיבה. מושון, למים."},{"start":1029.02,"end":1035.02,"text":"שימו לב איך מושון עובד על הקרישים הרעבים."},{"start":1035.02,"end":1043.84,"text":"רק אצלנו שום תעלול או לא מבוים, הכל בזמן אמת."},{"start":1043.84,"end":1061.24,"text":"יש לי, יש לי, יש לי. אני אשחק עם עצמי חי צומח דומהם."},{"start":1064.16,"end":1065.5,"text":"עצור!"},{"start":1065.5,"end":1067.85,"text":"מם! חי מדוזה, צומח מלפפון."},{"start":1067.85,"end":1068.85,"text":"דומה מנוע."},{"start":1068.85,"end":1069.85,"text":"דומה מנוע?"},{"start":1069.85,"end":1070.85,"text":"דומה מנוע?"},{"start":1070.85,"end":1072.85,"text":"עכשיו אני צריך ארץ עיר ילד ילדיו."},{"start":1072.85,"end":1073.85,"text":"תחבא מנוע אמרתי לך."},{"start":1073.85,"end":1074.85,"text":"אז תגיד תחבא את..."},{"start":1074.85,"end":1075.85,"text":"מה את תחבא את..."},{"start":1075.85,"end":1077.85,"text":"אז תגיד... אני אחבא את המנוע."},{"start":1077.85,"end":1078.88,"text":"מה רבי?"},{"start":1078.88,"end":1083.57,"text":"תגיד לי אתה עושה צחוק ממני."},{"start":1083.57,"end":1085.69,"text":"אני עושה בדיקה שגרדית לך עורף, אתה מוכן?"},{"start":1085.69,"end":1086.69,"text":"בבטח שאני מוכן."},{"start":1086.69,"end":1088.69,"text":"בבקשה, יש לי משהו דוי."},{"start":1088.69,"end":1090.69,"text":"לא אתה, המכונית דביל."},{"start":1090.69,"end":1092.69,"text":"המכונית בסדר?"},{"start":1092.69,"end":1093.69,"text":"הנה, מאה אחוז."},{"start":1093.69,"end":1094.69,"text":"תראה לי בבקשה אורות."},{"start":1094.69,"end":1095.69,"text":"יש לי איזה..."},{"start":1095.69,"end":1098.69,"text":"יש לי אורות מצוינים, זה מטורקיה."},{"start":1098.69,"end":1099.69,"text":"לא אורות, פנסים, תראה לי."},{"start":1099.69,"end":1102.69,"text":"פנסים, בבקשה, יש לי פנסים."},{"start":1102.69,"end":1103.66,"text":"פנה..."},{"start":1103.66,"end":1105.69,"text":"מגבים, תראה לי עכשיו."},{"start":1105.69,"end":1107.69,"text":"יש לי פה... הנה, בבקשה."},{"start":1107.69,"end":1109.69,"text":"אתה עושה ממין לצחוק, מה המצב של הצמיגים שלך?"},{"start":1109.69,"end":1114.69,"text":"הצמיגים שלי, יש לי קצה צמיגים, אבל אני עושה דיאטה, זה בסדר, אני... אני עושה ספור."},{"start":1114.69,"end":1118.69,"text":"אתה עושה ממין, אתה יכול לקבל כנסה להצחצפות לשוטר, אתה תראה לי ניירות."},{"start":1118.69,"end":1120.69,"text":"בבקשה, הנה, יש לי פה ניירות."},{"start":1120.69,"end":1122.68,"text":"לא, תראה לי תעודות שלך."},{"start":1122.68,"end":1123.71,"text":"של איזה כיתה?"},{"start":1123.71,"end":1126.37,"text":"אתה עצור, אתה שמע, אתה עצור."},{"start":1126.37,"end":1132.75,"text":"כן, אני יודע שאני עצור, אני... קשה לי לדבר על הבעיות שיש לי, אני... אני מאוד עצור."},{"start":1132.75,"end":1140.14,"text":"את זה תספר בתחנה, בוא איתי. בוא, מה הבעיה?"},{"start":1140.14,"end":1146.31,"text":"הבעיה היא שכל פעם שאני, שאני מנסה לצחיק משהו, הוא מתעצבל."},{"start":1146.31,"end":1148.88,"text":"אני לא יודע מה אני עושה."},{"start":1148.88,"end":1151.3,"text":"אתה רוצה איזה עזרה במשהו?"},{"start":1151.3,"end":1153.3,"text":"אני רק רוצה שתשחרר אותי."},{"start":1153.3,"end":1154.75,"text":"תסתובב."},{"start":1154.75,"end":1159.05,"text":"תשתחרר, תשתחרר חמודי, תשתחרר."},{"start":1159.05,"end":1160.05,"text":"תשתחרר."},{"start":1160.05,"end":1162.05,"text":"אל תהיה מתוך, תשתחרר."},{"start":1162.05,"end":1170.71,"text":"שוב אנחנו בחלסט רעילה, מה?"},{"start":1170.71,"end":1172.71,"text":"והפאנק, גבירותיי ורבותיי,"},{"start":1172.71,"end":1175.67,"text":"רציתי לדבר איתכם על מחלה קשה של הילדים."},{"start":1175.67,"end":1177.08,"text":"פוגים!"},{"start":1177.08,"end":1179.23,"text":"באמא שלי מחלה מדבקת, תשתחררו כולם!"},{"start":1179.23,"end":1181.23,"text":"רוצים פוגים, פוגים!"},{"start":1181.23,"end":1183.23,"text":"מה זה הקלעווין הזה? מה זה זה?"},{"start":1183.23,"end":1184.23,"text":"לא יודעים מה זה, מאיפה זה בא?"},{"start":1184.23,"end":1186.23,"text":"ואיפה זה בא? ואיזה פרשומת מפחידה?"},{"start":1186.23,"end":1187.23,"text":"באמא שלי"},{"start":1187.23,"end":1189.23,"text":"רואים אותם הולכים ברחוב, מה לגרף איתן?"},{"start":1189.23,"end":1190.23,"text":"מה לגרף איתן?"},{"start":1190.23,"end":1191.23,"text":"והם כמו קושים בהרלם?"},{"start":1191.23,"end":1192.23,"text":"באמא שלי"},{"start":1192.23,"end":1193.23,"text":"אבל מה הם לא קושים?"},{"start":1193.23,"end":1194.23,"text":"הם לאפלפים"},{"start":1194.23,"end":1197.23,"text":"רואים אותם כאלה, לאפלפים קטנים, בלונדינדינדים"},{"start":1197.23,"end":1199.23,"text":"והם שרים באלימות את הרפ שלהם"},{"start":1199.23,"end":1201.23,"text":"באלימות? מה זה הרפ הזה?"},{"start":1201.23,"end":1202.23,"text":"פוגים!"},{"start":1202.23,"end":1203.23,"text":"וזה רפ, פשוט"},{"start":1203.23,"end":1205.23,"text":"מי זה? איזה פעד?"},{"start":1205.23,"end":1206.23,"text":"מה אני לא יודע על השירפ אני?"},{"start":1206.23,"end":1207.23,"text":"הנה גם אני יכול"},{"start":1207.23,"end":1209.23,"text":"ילד בו מהר, איפה נמצאת אמא שלך"},{"start":1209.23,"end":1211.23,"text":"תזזער לך כי זוזו יחפש"},{"start":1211.23,"end":1212.23,"text":"מי נענע גם אותך"},{"start":1212.23,"end":1213.23,"text":"אלה לא יצא אבל"},{"start":1213.23,"end":1214.23,"text":"זה הכיוון"},{"start":1214.23,"end":1215.23,"text":"לא יומן"},{"start":1215.23,"end":1217.23,"text":"איזה פחדים שרים ברב"},{"start":1217.23,"end":1218.23,"text":"וזה לא הילדים של פעם"},{"start":1218.23,"end":1220.26,"text":"תראו פעם ילדים היו נחמדים"},{"start":1220.26,"end":1222.26,"text":"פעם ילדים היה להם"},{"start":1222.26,"end":1224.26,"text":"היה להם נחמד אם היו ילדותיים"},{"start":1224.26,"end":1226.26,"text":"היינו משחקים של ילדים"},{"start":1226.26,"end":1228.26,"text":"ושירים של ילדים נגיד"},{"start":1228.26,"end":1230.26,"text":"האוטו שלנו גדול וירוק"},{"start":1230.26,"end":1231.26,"text":"האוטו שלנו עובר על החוק"},{"start":1231.26,"end":1233.26,"text":"יונה תנק אלפן"},{"start":1233.26,"end":1235.26,"text":"היה להם משחקים שלוש מקלות"},{"start":1235.26,"end":1237.26,"text":"חמש אבנים שבע כפות"},{"start":1237.26,"end":1239.26,"text":"כל מיני חסקלח"},{"start":1239.26,"end":1241.26,"text":"זה המשחקים"},{"start":1241.26,"end":1243.26,"text":"אגב המשחק ארצל אמר"},{"start":1243.26,"end":1244.26,"text":"איזה משחק"},{"start":1244.26,"end":1246.26,"text":"זה המציא אותו חבר שלי ארצל אמר"},{"start":1246.26,"end":1248.26,"text":"זה על שמו זה נקרא"},{"start":1248.26,"end":1250.26,"text":"והם ככה היום משחקים"},{"start":1250.26,"end":1252.26,"text":"ארצל אמר להביא כפה כל בשביל השאר בלונדיני"},{"start":1252.26,"end":1254.26,"text":"ישר היינו בין המשחק אחר"},{"start":1254.26,"end":1256.26,"text":"ושארצל אמר לבוא למורות"},{"start":1256.26,"end":1258.26,"text":"ולא הוריד להם תחצא איתה"},{"start":1258.26,"end":1259.26,"text":"היינו מורידים תחצא איתה"},{"start":1259.26,"end":1260.26,"text":"הייתה תמימות"},{"start":1260.26,"end":1262.26,"text":"היינו משחקים בתמימות"},{"start":1262.26,"end":1263.26,"text":"הייתה נאיבתיות"},{"start":1263.26,"end":1265.26,"text":"היום הכל ראפ"},{"start":1265.26,"end":1266.26,"text":"הכל בא לגן"},{"start":1266.26,"end":1267.26,"text":"בימא שלון מתי עשו בר מצווה בראפ"},{"start":1267.26,"end":1268.26,"text":"התו ראפי עם ספרי תורה"},{"start":1268.26,"end":1269.26,"text":"רוקד עם דאב דאבל קסית"},{"start":1269.26,"end":1270.26,"text":"מה זה?"},{"start":1270.26,"end":1271.26,"text":"ואיזה פעד"},{"start":1271.26,"end":1272.26,"text":"הסדרות שלהם פעם אלינו"},{"start":1272.26,"end":1273.26,"text":"מכימה עוז"},{"start":1273.26,"end":1274.26,"text":"ודונלד דיק"},{"start":1274.26,"end":1275.26,"text":"אין זה היה נחמד"},{"start":1275.26,"end":1276.16,"text":"היום"},{"start":1276.16,"end":1277.35,"text":"פאוור הריינג'רס"},{"start":1277.35,"end":1278.44,"text":"איזה פעד"},{"start":1278.44,"end":1280.44,"text":"עם אבי פלצת זורבעת ימני"},{"start":1280.44,"end":1282.44,"text":"יוצא לו ג'כנול מפה וקוצים מפה"},{"start":1282.44,"end":1283.44,"text":"איזה פעד הילדים"},{"start":1283.44,"end":1284.44,"text":"כולם מרטיבים מהפעד"},{"start":1284.44,"end":1286.44,"text":"מה זה בימא שלי"},{"start":1286.44,"end":1287.44,"text":"והפוגים"},{"start":1294.07,"end":1297.07,"text":"ולדים עם לפלפים צריך לדעת להתעים את הפרסומת"},{"start":1297.07,"end":1299.07,"text":"שיהיה קצת יותר ילדותי"},{"start":1299.07,"end":1301.16,"text":"לכן צוות הצילום"},{"start":1301.16,"end":1302.16,"text":"של זו זו ונבל האש"},{"start":1302.16,"end":1305.15,"text":"יצא לשטח יחד עם צוות הלפלפייה"},{"start":1305.15,"end":1307.24,"text":"שימו לב מה הם העלו בחקתים"},{"start":1307.24,"end":1309.42,"text":"חקתים, חקתם, לא משנה"},{"start":1309.42,"end":1310.58,"text":"שימו לב"},{"start":1310.58,"end":1313.18,"text":"חבר'ה, דוקים!"},{"start":1313.18,"end":1321.99,"text":"שלום חבריה, כולנו פה החוקים"},{"start":1321.99,"end":1323.99,"text":"אז הבא נתיישבא ונשחק בדוקים"},{"start":1323.99,"end":1325.99,"text":"בדוקים גם מרגיש חכם וגם שלון"},{"start":1325.99,"end":1328.99,"text":"אפילו לא אכפת לאן כולם קוראים לחנון"},{"start":1328.99,"end":1331.25,"text":"זה משחק מרהיב"},{"start":1331.25,"end":1333.54,"text":"דוקים"},{"start":1333.54,"end":1335.54,"text":"דוקים בקידה בבית ממחשב"},{"start":1335.54,"end":1337.54,"text":"דוקים עם ילדה שאותה תאוהב"},{"start":1337.54,"end":1340.54,"text":"אז זה סחק כולנו עכשיו לפי הטוב"},{"start":1340.54,"end":1343.54,"text":"ויש לך בונוס עם תוצי את השחור"},{"start":1343.54,"end":1344.54,"text":"דוקים"},{"start":1344.54,"end":1345.53,"text":"זה משחק מרהיב"},{"start":1345.53,"end":1346.53,"text":"דוקים"},{"start":1346.53,"end":1347.78,"text":"דוקים"},{"start":1347.78,"end":1348.7,"text":"דוקים"},{"start":1348.7,"end":1350.55,"text":"וזיהקס"},{"start":1350.55,"end":1351.55,"text":"דוקים"},{"start":1351.55,"end":1352.9,"text":"אבנים לפלף"},{"start":1352.9,"end":1366.98,"text":"דוקו זוהי מניה"},{"start":1366.98,"end":1369.88,"text":"משחק של מניה ורומניה"},{"start":1369.88,"end":1386.39,"text":"דוקים מרומניה השגאון הישן שכובש את לפלפי ישראל"}]