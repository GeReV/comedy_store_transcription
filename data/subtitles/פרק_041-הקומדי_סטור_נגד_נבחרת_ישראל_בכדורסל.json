[{"start":1.73,"end":40.01,"text":"שוב אנו בתוכניתנו אנשים שלא רואים כל יום"},{"start":40.01,"end":41.71,"text":"נמצא איתנו כאן קוף"},{"start":41.71,"end":45.19,"text":"קוף מבוקש מזה שנים רבות על ידי העולם התחתון"},{"start":45.19,"end":48.35,"text":"ולכן מסיבות מובנות ומחשש לחייו"},{"start":48.35,"end":50.33,"text":"החלטנו להסוות את פרצופו"},{"start":50.33,"end":55.16,"text":"כמו רק רגע מוסרים לי פשוט משהו מוזניה"},{"start":55.16,"end":59.28,"text":"וואה כנראה שהחלפנו במקומות"},{"start":59.28,"end":60.77,"text":"מיד נתקן זאת"},{"start":60.77,"end":63.68,"text":"קוף קוף תהינו במקומות"},{"start":63.68,"end":65.67,"text":"קוף תהינו במקומות"},{"start":65.67,"end":71.16,"text":"בשבוע הבא נראיין כאן את ראש השבק"},{"start":71.16,"end":74.08,"text":"וכמובן מיד אחרי הפרסומות"},{"start":74.08,"end":74.96,"text":"קומדיסו"},{"start":74.96,"end":97.98,"text":"עכשיו מצאתי אותו"},{"start":97.98,"end":99.48,"text":"קסטינג של אוריאל פריז"},{"start":99.48,"end":102.16,"text":"צבע החפיפה החדש בשיטת גוון על גוון"},{"start":102.16,"end":104.22,"text":"רק סובבי את האפליקולור וצבעי"},{"start":104.22,"end":105.74,"text":"כל כך קל לשימוש"},{"start":105.74,"end":108.12,"text":"קסטינג כהדין וללא אמוניה"},{"start":108.12,"end":109.64,"text":"קסטינג בלא ריאל פריז"},{"start":109.64,"end":112.44,"text":"הצבע החדש עם הברק העמוק שנשאר"},{"start":112.44,"end":114.56,"text":"קסטינג הופך את צבע שערי הטבעי"},{"start":114.56,"end":116.5,"text":"ליפה מתמיד והוא נשאר"},{"start":116.5,"end":121.46,"text":"קסטינג צבע שער החדש עם הברק העמוק בשיטת גוון על גוון מלא ריאל פריז"},{"start":121.46,"end":169.68,"text":"חיצת מתנהג הנכון והפעם מה תעשה וחיצת תתנהג במועדון ריקודי"},{"start":169.68,"end":173.52,"text":"ראשית, עליך לבדוק לאיזה סוג מועדון הגעת"},{"start":173.52,"end":189.82,"text":"סיבת פנויים פנויים, אה?"},{"start":189.82,"end":191.06,"text":"מדי, בא לך איזה ריקוד?"},{"start":191.06,"end":193.47,"text":"לא, אני... סר, אני מאחר"},{"start":193.47,"end":194.63,"text":"למה? ריקוד קטן?"},{"start":194.63,"end":195.43,"text":"אהב ללכת"},{"start":195.43,"end":198.88,"text":"כבל, כזה חפיץ"},{"start":198.88,"end":200.48,"text":"אי, גם אתה חמוד"},{"start":201.08,"end":203.5,"text":"הקפד להתלבש בהתאם לאופי האירוע"},{"start":203.5,"end":213.84,"text":"אהב ללכת למחר"},{"start":213.84,"end":215.68,"text":"יום טכנו, אה?"},{"start":215.68,"end":217.52,"text":"אהב ללכת שיין"},{"start":217.52,"end":219.2,"text":"יום של חבר'ה"},{"start":219.2,"end":223.58,"text":"בבוחה לרקוד, נסה להשתלב ברחבה"},{"start":223.58,"end":225.36,"text":"ולהתאים את תנועות גופך"},{"start":225.36,"end":226.92,"text":"לשאר הרוקדים"},{"start":226.92,"end":230.41,"text":"חבר'ה, הגעתי!"},{"start":230.41,"end":247.52,"text":"השליטה ברזה הריקוד"},{"start":247.52,"end":249.7,"text":"עשויה להרשים את בנות המין היפה"},{"start":249.7,"end":251.89,"text":"השתמש בה בחוכמה"},{"start":251.89,"end":257.31,"text":"וואו! וואו!"},{"start":257.31,"end":267.85,"text":"אל תנסה להפגין בקיאות"},{"start":267.85,"end":269.15,"text":"במילות השירים"},{"start":269.15,"end":270.59,"text":"וואו!"},{"start":270.59,"end":285.69,"text":"בבורכה לנהל דו שיח"},{"start":285.69,"end":287.65,"text":"התחשב ברעש הכללי"},{"start":287.65,"end":289.41,"text":"את נראה טוב!"},{"start":289.41,"end":305.48,"text":"זכור!"},{"start":305.48,"end":307.77,"text":"באת לדיסקוטקט כדי לבלות"},{"start":307.77,"end":311.38,"text":"היא מנע מאימותים מיותרים"},{"start":311.38,"end":313.71,"text":"יופו! יופו! יופו!"},{"start":313.71,"end":316.99,"text":"אתה רוקד עם חברה שלי שאני לא פה, אה?"},{"start":316.99,"end":319.01,"text":"אתה יודע מה יכול לקרוא אותך?"},{"start":319.01,"end":321.71,"text":"מה? חומשית, תרקוד איתה כמה שאתה רוצה"},{"start":321.71,"end":331.88,"text":"ולסיכום, בפעם הבאה כשתרצה לצאת לדיסקוטקט"},{"start":331.88,"end":333.66,"text":"עדיף שאתה ללך לריקודי עם"},{"start":333.66,"end":336.87,"text":"זה הכל, לילה טוב, המשך צפייה"},{"start":336.87,"end":345.57,"text":"על מה קרה לי?"},{"start":345.57,"end":347.84,"text":"הבוקר גנבו לי את הארנק"},{"start":347.84,"end":350.85,"text":"חמישים אלף שקל הלכו ככה"},{"start":350.85,"end":353.73,"text":"היה החיים שלי, אני..."},{"start":353.73,"end":356.37,"text":"לא יודע מה אני אעשה, יש איזה בן אדם שמחפש אותי"},{"start":356.37,"end":358.97,"text":"אומר אם אני לא אחזיר לו את הכסף הוא יהרוג אותי"},{"start":358.97,"end":362.79,"text":"את זה חיים מחורבנים"},{"start":362.79,"end":365.61,"text":"איזה איש מוזר"},{"start":365.61,"end":367.71,"text":"כל מה שאני אומר לו הוא צוחק"},{"start":367.71,"end":369.7,"text":"מזל שלא סיפרתי לו שהכלב שלו נדרס"},{"start":369.7,"end":372.88,"text":"הכלב שלו נדרס"},{"start":372.88,"end":385.82,"text":"מכר חדשה פוקדת את ערבי"},{"start":385.82,"end":388.82,"text":"המצלמה המשוטטת של ג'ודי"},{"start":388.82,"end":396.06,"text":"ג'ודי לא צהרו נובטן חום כהן מין צלוס סילבר הרואסטי"},{"start":396.06,"end":400.21,"text":"מכר חדשה נוחתת על נבחרת ישראל בחדורסל"},{"start":400.21,"end":402.21,"text":"נבחרת הקומדיסטור"},{"start":402.21,"end":404.3,"text":"לקחנו את המצלמה המשוטטת"},{"start":404.3,"end":408.27,"text":"ויצאנו לבדוק הקצע הקטע"},{"start":408.27,"end":413.33,"text":"והוא המכרה צסקה אכלה אותה"},{"start":413.33,"end":442.04,"text":"כאן בחולון האורות דולקים"},{"start":442.04,"end":444.04,"text":"אבל לנבחרת ישראל עושה ראשן"},{"start":444.04,"end":446.04,"text":"אפשר לחבות את האורות"},{"start":446.04,"end":448.04,"text":"תזמין סיני, סיני"},{"start":448.04,"end":450.04,"text":"סיני תזמין"},{"start":450.04,"end":452.04,"text":"מישהו ייתן לי ביש?"},{"start":452.04,"end":459.14,"text":"מיקי מאוס לא מיקי מרקובי"},{"start":459.14,"end":461.14,"text":"לא, יש לי, יש לי"},{"start":461.14,"end":464.14,"text":"קובי ברפת לא, קובי בלול"},{"start":466.14,"end":468.33,"text":"יש לי, יש לי, יש לי, יש לי"},{"start":468.33,"end":469.33,"text":"סיקה, מזמר?"},{"start":469.33,"end":471.67,"text":"לא, סיקה שר"},{"start":471.67,"end":474.67,"text":"יש לי, יש לי, יש לי"},{"start":474.67,"end":476.63,"text":"רפאת, דור"},{"start":476.63,"end":478.63,"text":"לא, הוא בכלל משחק כדורגל"},{"start":478.63,"end":481.94,"text":"יו, אני בכלל התבלפלתי"},{"start":481.94,"end":483.94,"text":"זה כדורגל ואנחנו פה משחק כדורגל"},{"start":483.94,"end":485.96,"text":"זה לא כדורגל"},{"start":485.96,"end":488.15,"text":"תראו להם מה זה"},{"start":488.15,"end":490.24,"text":"מפגרים אבל לא פטימים"},{"start":490.24,"end":493.54,"text":"מה, מה קורה?"},{"start":493.54,"end":494.54,"text":"מדהים, אה?"},{"start":494.54,"end":495.54,"text":"לא, אני בלואה ישר"},{"start":495.54,"end":496.54,"text":"לא, לא עשים, בולעים, קדימה"},{"start":496.54,"end":499.54,"text":"מה קרה צ'לצ'ל תפחד בו גמר, בוא"},{"start":499.54,"end":500.54,"text":"רגע לשכות, רגע"},{"start":500.54,"end":502.37,"text":"קדימה"},{"start":502.37,"end":504.4,"text":"קדימה"},{"start":504.4,"end":515.32,"text":"קדו, תתקדו"},{"start":515.32,"end":520.6,"text":"קדימה"},{"start":520.6,"end":531.8,"text":"מה סטטיסטי?"},{"start":531.8,"end":533.73,"text":"מה סטטיסטי כאן?"},{"start":533.73,"end":535.76,"text":"סטע שעמרי לגרם השם לסטרפתמר"},{"start":535.76,"end":536.76,"text":"ובייסי תודה מהבירו אלא"},{"start":536.76,"end":537.76,"text":"אוזו ספ, אוזו ספ"},{"start":537.76,"end":538.76,"text":"כל כיסא כיסא מהקד"},{"start":538.76,"end":540.76,"text":"ברגו מיברזי אנג'לוטי דונדוןי"},{"start":540.76,"end":542.76,"text":"כניגבורות שעגה בעסו על דמר אדונה"},{"start":542.76,"end":543.76,"text":"לא, אוטובוס נכנסת"},{"start":543.76,"end":544.76,"text":"וראת עם סלים"},{"start":544.76,"end":553.49,"text":"זה הכל הפעם כאן במבזק של ז'ק"},{"start":553.49,"end":555.39,"text":"נחזור אל משחק הקדוסה"},{"start":555.39,"end":564.65,"text":"שנים לפרנס"},{"start":564.65,"end":571.2,"text":"אמר לו שאני מניאק"},{"start":571.2,"end":573.57,"text":"אמר לו שאני מניאק"},{"start":573.57,"end":600.17,"text":"טוב, אני אשים לי"},{"start":600.17,"end":602.17,"text":"כן, וגם"},{"start":602.17,"end":604.17,"text":"מסתכל שנדה ונפלד הוא כל הזמן מקלל אותי"},{"start":604.17,"end":606.17,"text":"אוקיי"},{"start":606.17,"end":608.17,"text":"כן, הוא אמר חמני, אגבי אמא שלי"},{"start":608.17,"end":610.17,"text":"תראה פה, אלו, מה בא לגן?"},{"start":610.17,"end":611.17,"text":"אני באתי סתם, באתי לכדרך סתם"},{"start":611.17,"end":612.17,"text":"פתאום כינוס סתם"},{"start":612.17,"end":614.17,"text":"פתאום דורון ג'מתי באה שלי"},{"start":614.17,"end":615.17,"text":"לך ימניה, ככה הוא אמר לי"},{"start":615.17,"end":616.17,"text":"סתם, לא עציתי לו"},{"start":616.17,"end":617.17,"text":"לך ימניה"},{"start":617.17,"end":622.14,"text":"לך ימניה"},{"start":622.14,"end":623.68,"text":"סתם, סייך, לוס"},{"start":623.68,"end":628.87,"text":"ארבע, חבש, ששש, שבע, שמונה, דשע, עשר"},{"start":628.87,"end":632.87,"text":"כן, תזכר לשנה הבא"},{"start":632.87,"end":634.87,"text":"כן, תזכר לשנה הבא"},{"start":642.43,"end":649.11,"text":"את הדאטה של ארבעה שחקנים מתוך הנבחרת יש רכב אוטומטי"},{"start":649.11,"end":653.14,"text":"לעומת זאת, לשני שחקנים יש רכב עם גירגיל"},{"start":653.14,"end":678.46,"text":"טוב לדעת, נחזור למשחק"},{"start":678.46,"end":680.46,"text":"קום, קום, יאללה"},{"start":680.46,"end":683.46,"text":"אתה שומר שלישי"},{"start":683.46,"end":686.45,"text":"אתה שומר שלישי"},{"start":686.45,"end":706.49,"text":"שג'יודי נמצאת בעמדת הרעיונות, אבא נעבור לג'יודי"},{"start":706.49,"end":710.64,"text":"המקומה מסורג שרירי מובנוי לטלפיות"},{"start":710.64,"end":714.76,"text":"דורון ג'מצ'י, שלום דורון"},{"start":714.76,"end":718.76,"text":"כיצד אתה מסביר את חוסר המוטיבציה של נבחרת ישראל?"},{"start":718.76,"end":721.76,"text":"טוב, יש לנו בעיה, בלי שום ספק, אין לנו מנהיגות"},{"start":721.76,"end":726.95,"text":"חסר לנו מישהו בעל קומה שיכול לתת מילה במקום הנכון, בעל סמכות"},{"start":726.95,"end":732.32,"text":"דורון, ערעף עליי מגבריותך המתפרצת"},{"start":732.32,"end":735.31,"text":"נבחרת ישראל וכולנו יודעים את זה מצבה בכירה"},{"start":735.31,"end":739.97,"text":"מוטיבציה נמוכה, בעיות של שחקנים, של התאמה על המגרש"},{"start":739.97,"end":745.09,"text":"וכרגיל כשאנחנו במצבים כאלה אנחנו פונים לרלף קליין"},{"start":745.09,"end":746.01,"text":"רלף ערב טוב"},{"start":746.01,"end":748.28,"text":"מה שראיתי זה לא מסמך אותי"},{"start":748.28,"end":750.28,"text":"אני חושב שבאמת יש בעיה של רצינות"},{"start":750.28,"end":753.56,"text":"אין גיבוש, אין רוצה לעשות משהו אני יודע"},{"start":753.56,"end":755.55,"text":"זה בעיה רצינית מאוד"},{"start":755.55,"end":759.55,"text":"אתה חושב שלמשל פונקציה כמו מנהל מקצועי יכולה לעזור כאן?"},{"start":759.55,"end":762.55,"text":"תעזוב את הפונקציה, תשמע לי, תעזוב את הפונקציה הזו"},{"start":762.55,"end":767.18,"text":"צלבי יועץ, כשמבין את המשחק בזה ישפר את המצב"},{"start":767.18,"end":796.51,"text":"מה שקורה זה ככה מה הרגע הזה? אני מאמן, אני קובע מה אתם אוכלים, מה אתם שותים, מה אתם זוללים"},{"start":796.51,"end":800.47,"text":"מה דבר אני? מה איסות שותות אתכם? אני קובע הכל, דרבלכו"},{"start":800.47,"end":804.47,"text":"מעכשיו לא תוכלו יותר את הכולויה ויטמינים והמסאגים"},{"start":804.47,"end":806.57,"text":"כל אחד אוכל ארוחת צהריים כבס ולאפה"},{"start":806.57,"end":808.69,"text":"הם דחינה ועמבה דרבלכו"},{"start":808.69,"end":810.85,"text":"שאני לא אראה משוכת דברים לא טובים"},{"start":810.85,"end":812.85,"text":"כי גאון כל מיני"},{"start":812.85,"end":814.85,"text":"דבר שני"},{"start":814.85,"end":816.85,"text":"דבר שני"},{"start":816.85,"end":818.85,"text":"הנה עדי יודע על מה הוא מדבר"},{"start":818.85,"end":820.85,"text":"חנקותו שנים עם קרמבו"},{"start":820.85,"end":823.16,"text":"באמא שלי מה זה עתה זה"},{"start":823.16,"end":825.16,"text":"דבר שני אל תצחק את נציני עדי תאמין לי"},{"start":825.16,"end":827.57,"text":"בליף דמין"},{"start":827.57,"end":829.76,"text":"דבר שני שתנעור"},{"start":829.76,"end":832.11,"text":"מה הרגע הזה אתם מורידים פרופילת"},{"start":832.11,"end":834.55,"text":"מורידים פרופילת"},{"start":834.55,"end":836.74,"text":"אני נותן לכם תלבושות חדשות"},{"start":836.74,"end":839.25,"text":"אני משיג חברה מעמצת חדשה"},{"start":839.25,"end":841.21,"text":"אתם עולים למגרש באמא שלי"},{"start":841.21,"end":843.6,"text":"כמו חיות בה"},{"start":843.6,"end":845.85,"text":"רצח בעיניי"},{"start":845.85,"end":847.85,"text":"זה הבנתם את זה? זה ברור?"},{"start":847.85,"end":849.85,"text":"קדימה סחקותה"},{"start":849.85,"end":851.85,"text":"קדימה"},{"start":851.85,"end":853.85,"text":"יאללה, כולה בייחד עושים"},{"start":853.85,"end":855.85,"text":"מיני מיני מיני"},{"start":855.85,"end":857.85,"text":"יאללה חברה קדימה, תרואו לי מיאת"},{"start":857.85,"end":860.07,"text":"לי מיש איש"},{"start":860.07,"end":862.07,"text":"יאללה חברה קדימה, אני רוצה"},{"start":862.07,"end":864.07,"text":"נשחק ותחמות, אה?"},{"start":864.07,"end":866.07,"text":"יאללה, יאללה, שחקותה"},{"start":866.07,"end":868.07,"text":"ישחץ אחי"},{"start":868.07,"end":870.07,"text":"יופי ברקומית, יאללה חברה"},{"start":870.07,"end":872.07,"text":"שחקותה, אופה"},{"start":872.07,"end":874.09,"text":"יאללה, נשחק"},{"start":874.09,"end":876.09,"text":"קדימה יאללה, גות, כולה"},{"start":876.09,"end":878.09,"text":"דניאל, זה קבוצה, חושק שוקי"},{"start":878.09,"end":884.73,"text":"אז כולם, לזכור דבר ראשון"},{"start":884.73,"end":886.73,"text":"אומרים לכם, בוקר צח אתם עונים?"},{"start":886.73,"end":888.73,"text":"בוקר דע"},{"start":888.73,"end":890.89,"text":"לפני כליית תונשין עושים?"},{"start":890.89,"end":892.98,"text":"קפה וכשרוצים למשות הכדור אומרים?"},{"start":892.98,"end":895.81,"text":"פסות הכדור"},{"start":895.81,"end":898.48,"text":"קופה, אל תשכח מביא לך את השרשר של המשרוקית"},{"start":898.48,"end":900.48,"text":"כדור מנאמר, ככה טוב הבית אחרז"},{"start":900.48,"end":902.48,"text":"בסדר? יאללה אחי"},{"start":902.48,"end":904.99,"text":"גדר גדר אתה"},{"start":904.99,"end":909.92,"text":"אני אמא מתפרצנת, מתפרצנת"},{"start":909.92,"end":912.05,"text":"חבר'ל, להתלחם, אה?"},{"start":912.05,"end":914.05,"text":"תה, גמצי, גמצי"},{"start":914.05,"end":916.05,"text":"יאללה שתבכתו זדנו, תשמע את התרגיל"},{"start":916.05,"end":918.05,"text":"יאללה, יאללה"},{"start":918.05,"end":920.23,"text":"גוץ, גוץ, תמועוק לחיוך גוץ"},{"start":920.23,"end":922.23,"text":"יאללה, גורדי, יאללה, אלפלפלד"},{"start":922.23,"end":924.23,"text":"לפלפון, אה? תתחיל לגבי"},{"start":924.23,"end":926.23,"text":"יאללה, זה קבוצה, זה קבוצה"},{"start":926.23,"end":928.36,"text":"יפה, עדי, יאללה, אופה, יפה"},{"start":928.36,"end":930.36,"text":"זהו, זה המשחק"},{"start":930.36,"end":933.31,"text":"יאללה, קבוצה"},{"start":933.31,"end":935.28,"text":"אלפלפלד, בוא, יפה"},{"start":935.28,"end":937.28,"text":"אלפלפלד, תראה, דבר ראשון"},{"start":937.28,"end":939.28,"text":"אתה עומד מול הודשין, עכשיו יש לך אחוז"},{"start":939.28,"end":941.27,"text":"יש לך את היד, אין לך את הביצוע"},{"start":941.27,"end":943.3,"text":"נתקה, שים לב, אתה עומד, מסתכל לסל"},{"start":943.3,"end":945.68,"text":"עכשיו, תמיד אתה עושה מן משהו מטופש כמו"},{"start":945.68,"end":947.93,"text":"נזורק"},{"start":947.93,"end":949.94,"text":"מה זה נפיחה? מה זה החרט הזה?"},{"start":949.94,"end":951.99,"text":"צריך לעשות כזה דבר, נדוי"},{"start":951.99,"end":954.08,"text":"כדרור, שתי כדרורים"},{"start":954.08,"end":956.08,"text":"לוקח, עביר, ואז תעושה"},{"start":956.08,"end":958.08,"text":"נזורק"},{"start":958.08,"end":960.08,"text":"ראית איך זה נכנס?"},{"start":960.08,"end":962.48,"text":"עכשיו, נדוי, שים לב, עמידת מוצא"},{"start":962.48,"end":964.89,"text":"פיסוק קל, שחרור תושבת ההשך"},{"start":964.89,"end":966.95,"text":"בסדר? קדימה, let's do it"},{"start":966.95,"end":969.61,"text":"It's not America, it's you know Israel"},{"start":969.61,"end":971.61,"text":"I want, they are"},{"start":971.61,"end":973.67,"text":"זה שחקה, יופי, הנה נדה"},{"start":973.67,"end":979.73,"text":"זה לא נדלים, זה לא"},{"start":979.73,"end":982.14,"text":"זה שחקנים, זה נמוצא"},{"start":982.14,"end":984.09,"text":"זה יופי"},{"start":984.09,"end":986.17,"text":"יפה, שתי נקודו, תוקלה פעביים"},{"start":986.17,"end":988.48,"text":"יופי, כל המקרש, ביפש"},{"start":988.48,"end":990.48,"text":"לערים ידיים לחלוק אותנו עליה, קדימה"},{"start":990.48,"end":992.45,"text":"תורידו, תורידו לך מה"},{"start":992.45,"end":994.82,"text":"הלו, הגנה, גנה"},{"start":994.82,"end":997.1,"text":"איתה, לכי, הגנה"},{"start":997.1,"end":999.1,"text":"והנה הכדור שלנו, יפה, צמשי, קדימה, יפה, צמשי"},{"start":999.1,"end":1001.23,"text":"צור, צור את הכדור"},{"start":1001.23,"end":1003.23,"text":"היימה, הנה שלנו"},{"start":1003.23,"end":1005.23,"text":"בוא בוא ימה, בוא ימה"},{"start":1005.23,"end":1033.51,"text":"קודם כל לנוח, לזכור שאנחנו משחקים כדור שגית"},{"start":1033.51,"end":1035.51,"text":"אנחנו משחקים כדור שגית"},{"start":1035.51,"end":1037.51,"text":"עדי, אתה תפקם פה, גורדון פה, גורדון פה"},{"start":1037.51,"end":1039.51,"text":"שטיין אהור פה, עכשיו"},{"start":1039.51,"end":1041.51,"text":"איזה שם זה? אתה רואה או לא רואה? מה זה אהור?"},{"start":1041.51,"end":1043.51,"text":"עכשיו, שים לי"},{"start":1043.51,"end":1045.51,"text":"אתה עומד לפני הזרקת אונשין, ג'מצ'י"},{"start":1045.51,"end":1047.51,"text":"אתה מתנשם כמו איזה לפלפ, מה זה?"},{"start":1047.51,"end":1049.51,"text":"אתה מבין? עם תנועה, בוא ננסה, ו"},{"start":1049.51,"end":1051.51,"text":"יפה, קדימה, קדימה, סטיין מאורר, לא נטרו!"},{"start":1051.51,"end":1053.51,"text":"זה עבוד הרתילית, אתם לא מבינים!"},{"start":1053.51,"end":1054.43,"text":"זה נטרו!"},{"start":1054.43,"end":1055.67,"text":"יש שאלות עוד עוד עוד שם?"},{"start":1055.67,"end":1056.67,"text":"לא. -הכול ברור?"},{"start":1056.67,"end":1059.67,"text":"אז יאללה, קדימה, להמשיך לזרק ותרו להם על זה."},{"start":1059.67,"end":1070.49,"text":"תזרוק לו את הכתוב!"},{"start":1070.49,"end":1073.49,"text":"אה, הוא עמד לי כמה, תזרוק לו את הכתוב!"},{"start":1073.49,"end":1076.61,"text":"יאיו, הגודי גודי!"},{"start":1076.61,"end":1078.86,"text":"זה שלב לבו, שכן שכן, היו!"},{"start":1078.86,"end":1080.86,"text":"תרגיל מספר כמה!"},{"start":1080.86,"end":1083.56,"text":"וסטיין מאורר, יפה!"},{"start":1083.56,"end":1085.62,"text":"הנה, רק רכז גם קולה!"},{"start":1085.62,"end":1087.62,"text":"אין למילדה!"},{"start":1087.62,"end":1089.62,"text":"בוא לאבא, בוא לאבא!"},{"start":1089.62,"end":1091.8,"text":"בוא לאבא!"},{"start":1091.8,"end":1093.8,"text":"כיפק!"},{"start":1093.8,"end":1095.8,"text":"כיפק!"},{"start":1095.8,"end":1097.8,"text":"כיפק!"},{"start":1097.8,"end":1101.23,"text":"מוסר עזקה לכל המנאמנים"},{"start":1101.23,"end":1103.36,"text":"זכרו שאתם באים לאמן כדורסל"},{"start":1103.36,"end":1105.36,"text":"אתם חייבים לזכור את הפתגים הידוע"},{"start":1105.36,"end":1107.49,"text":"כדורסל משחקים תשעים דקות"},{"start":1107.49,"end":1109.65,"text":"אנחנו המטרה שלנו לשחק"},{"start":1109.65,"end":1111.65,"text":"משבת לשבת"},{"start":1111.65,"end":1113.65,"text":"וכמו שאומרים"},{"start":1113.65,"end":1115.74,"text":"אני אוהב את הפתגים"},{"start":1115.74,"end":1117.74,"text":"ותתקע על זה"},{"start":1117.74,"end":1120.06,"text":"ותתקע על זה"},{"start":1120.06,"end":1139.17,"text":"שלום לך"},{"start":1139.17,"end":1141.17,"text":"אני מסתכל כבר ותפריט המון זמן"},{"start":1141.17,"end":1143.2,"text":"אני פשוט פעם ראשונה"},{"start":1143.2,"end":1145.2,"text":"אולי אתה יכול להמליץ לי על משהו כאן"},{"start":1145.2,"end":1147.17,"text":"תרשה לי להמליץ לך על רגלי צפרדיה"},{"start":1147.17,"end":1149.42,"text":"מה אתה אומר זה לא קצת מסוכן בשביל פעם ראשונה?"},{"start":1149.42,"end":1153.93,"text":"לא לא לא לא לא לא יש לזה טעם שמזכיר אוף"},{"start":1153.93,"end":1155.93,"text":"אז רגע אם זה טעם שמזכיר אוף אני לא אתנגד לאוף"},{"start":1155.93,"end":1157.93,"text":"בוא נזמין אוף"},{"start":1157.93,"end":1159.93,"text":"בחירה מצוינת אז תרשה לי להמליץ לך על"},{"start":1159.93,"end":1162.93,"text":"על מנת האוף נורמנדי מבושל בקונייק"},{"start":1162.93,"end":1164.93,"text":"האוף מקבל איכויות של בקר"},{"start":1164.93,"end":1167.15,"text":"אז רגע בי איכויות של בקר"},{"start":1167.15,"end":1170.15,"text":"אז למה לא ניקח בקר נזמין בקר לקבל את האיכויות עצמן"},{"start":1170.15,"end":1172.15,"text":"אוקיי אוקיי אז תרשה לי להמליץ לך על"},{"start":1172.15,"end":1174.15,"text":"סטייק בקר בטפוחים"},{"start":1174.15,"end":1176.6,"text":"טפוחים? נו ואיך זה?"},{"start":1176.6,"end":1178.6,"text":"אוללה זה כמו שירה"},{"start":1178.6,"end":1180.6,"text":"כמו שירה כמו"},{"start":1180.6,"end":1182.6,"text":"למה לא ללכת על הדבר האמיתי"},{"start":1182.6,"end":1184.6,"text":"בוא אני אקום ואני אשיר"},{"start":1184.6,"end":1186.6,"text":"אז במקרה הזה תרשה לי להמליץ לך על"},{"start":1186.6,"end":1188.6,"text":"מכשיר הקריורקי החדש שלנו"},{"start":1188.6,"end":1190.6,"text":"לעלות על הבמה לשיר כמה שאתה רוצה"},{"start":1190.6,"end":1192.6,"text":"אתה תרגיש כאילו שתית בקבוק"},{"start":1192.6,"end":1194.6,"text":"שלם של יין"},{"start":1194.6,"end":1196.6,"text":"כאילו שתיתי בקבוק"},{"start":1196.6,"end":1198.6,"text":"למה שלא נשתה"},{"start":1198.6,"end":1200.6,"text":"איזה יין אתה יכול להמליץ למה כאילו"},{"start":1200.6,"end":1202.6,"text":"אני ממליץ לך על יין שאתה עשו בניו"},{"start":1202.6,"end":1204.6,"text":"בציר שבעים ושבע"},{"start":1204.6,"end":1206.6,"text":"מתוק אדום סמיך"},{"start":1206.6,"end":1209.34,"text":"כמו מוס"},{"start":1209.34,"end":1211.34,"text":"כמו מוס"},{"start":1211.34,"end":1213.34,"text":"לא כן זה כמו מוס"},{"start":1213.34,"end":1215.34,"text":"אם לא תגיד לי מה אתה רוצה"},{"start":1215.34,"end":1217.34,"text":"אני לא יכול להמליץ לך"},{"start":1217.34,"end":1219.34,"text":"אני רוצה שאני נכף במסעדה"},{"start":1219.34,"end":1221.34,"text":"שאני מקבל את הצלחת"},{"start":1221.34,"end":1223.34,"text":"אני רואה את האוכל בפנים"},{"start":1223.34,"end":1225.34,"text":"אני רוצה להריח את העדים"},{"start":1225.34,"end":1227.34,"text":"אני רוצה להרגיש כמו גן עדן"},{"start":1227.34,"end":1229.34,"text":"אז למה כמו? למה כמו גן עדן?"},{"start":1229.34,"end":1231.34,"text":"אני יכול לשלוח אותך לגן עדן"},{"start":1231.34,"end":1233.34,"text":"לא לא לא אני אוכל צלמיץ בבית"},{"start":1233.34,"end":1235.34,"text":"יופי של מצעדה"},{"start":1235.34,"end":1237.28,"text":"יופי ינחק"},{"start":1237.28,"end":1241.09,"text":"יופי תודה לך"},{"start":1241.09,"end":1243.09,"text":"עוד מישהו רוצה פה כמו"},{"start":1247.53,"end":1278.4,"text":"תודה רבה"},{"start":1278.4,"end":1281.17,"text":"אני עובדת עצות"},{"start":1281.17,"end":1283.17,"text":"אם את עובדת עצות יש לך שבולת"},{"start":1283.17,"end":1285.17,"text":"אז לא צריך יותר גרוב"},{"start":1285.17,"end":1287.17,"text":"למרות מה שאני נותנת לה לאכול"},{"start":1287.17,"end":1289.17,"text":"הילדה לא אוכלת, הילדה מסתרבת לאכול"},{"start":1289.17,"end":1291.17,"text":"והגרוע מכל ניסיתי את כל שוגי החיתונים"},{"start":1291.17,"end":1293.17,"text":"אבל שום דבר לא עוזר"},{"start":1293.17,"end":1295.17,"text":"תמיד יש רטיבות"},{"start":1295.17,"end":1297.17,"text":"וכן אמא של שבולת"},{"start":1297.17,"end":1301.17,"text":"שבולת תגדל יותר גדול תהיה לחם שחור"},{"start":1301.17,"end":1303.17,"text":"לכן שואלת אמא של שבולת"},{"start":1303.17,"end":1305.2,"text":"אם תוכל לייעץ לנו נסמך"},{"start":1305.2,"end":1307.2,"text":"וכן אמא של שבולת ערב צח נעים להכיר אותך"},{"start":1307.2,"end":1309.2,"text":"תראה אין ספק שיש כאן בעיה כשה"},{"start":1309.2,"end":1311.2,"text":"עם אמא של שבולת הנושא של החיתולים"},{"start":1311.2,"end":1313.2,"text":"הוא בדמנו יותר נכון בנוזלנו"},{"start":1313.2,"end":1315.2,"text":"וכן איך אומר הילדים במצוקה"},{"start":1315.2,"end":1317.2,"text":"מה נותנים להם לאכול"},{"start":1317.2,"end":1319.16,"text":"כל מיני גמדים"},{"start":1319.16,"end":1321.16,"text":"וצורסיקים ולוקלוקים"},{"start":1321.16,"end":1323.16,"text":"למה לא מביאים להם שיש לקים החוסף שהוא גם בקטנים"},{"start":1323.16,"end":1325.16,"text":"בגלל הזה יש להם בעיה ביציאה"},{"start":1327.16,"end":1329.16,"text":"מגיע חיתול"},{"start":1329.16,"end":1331.16,"text":"איזה מצוקה באמא שלי"},{"start":1331.16,"end":1333.16,"text":"כל מיני כאלה חיתולים"},{"start":1333.16,"end":1335.16,"text":"עם ציורים של ברבזים"},{"start":1335.16,"end":1337.16,"text":"מכוערים כאלה קלימי רוחתנים"},{"start":1337.16,"end":1339.16,"text":"מה זה אחרת הזה?"},{"start":1339.16,"end":1341.16,"text":"למה לא מצהרים להם עוף בגרילה?"},{"start":1341.16,"end":1343.16,"text":"חסידה עם פה של גורילה?"},{"start":1343.16,"end":1345.16,"text":"שיהיה להם חשק להציע"},{"start":1345.16,"end":1347.32,"text":"לכן צוות הצילום של זוזו בנבלש"},{"start":1347.32,"end":1349.47,"text":"החליט לשים קץ לכל העניין"},{"start":1349.47,"end":1351.46,"text":"שימו לב איך צריך להיראות חיתול"},{"start":1351.46,"end":1353.78,"text":"צוות הצילום בפעולה"},{"start":1353.78,"end":1356.21,"text":"צופופו"},{"start":1356.21,"end":1358.46,"text":"עובדיה היה ילד בעייתי"},{"start":1358.46,"end":1360.46,"text":"מדובחה תמיד הוא היה עצבנו"},{"start":1360.46,"end":1362.46,"text":"עד שגילינו את הסיבה"},{"start":1362.46,"end":1364.46,"text":"עובדיה שלנו פשוט היה רטוב כל הזמן"},{"start":1364.46,"end":1367.42,"text":"ניסינו את כל החיתולים שבעולם"},{"start":1367.42,"end":1369.42,"text":"עד שמצאנו פתרון"},{"start":1369.42,"end":1371.55,"text":"חיתולי סבבי בייבי"},{"start":1371.55,"end":1375.11,"text":"החיתולים המנומרים"},{"start":1375.11,"end":1377.02,"text":"זה סיפור הטובה"},{"start":1377.02,"end":1378.24,"text":"תוכם בצורה"},{"start":1378.24,"end":1380.67,"text":"צורה"},{"start":1380.67,"end":1386.78,"text":"שזוריה"},{"start":1386.78,"end":1416.27,"text":"אני"},{"start":1416.27,"end":1417.39,"text":"מוסר אסכל"},{"start":1417.39,"end":1419.39,"text":"הילד שלך זקוק לחיתול מנומר"},{"start":1419.39,"end":1421.39,"text":"חיתול החוסק סוקה"},{"start":1421.39,"end":1423.39,"text":"זה חיתול מצמר פלדה מצופה בפרווס של נמר"},{"start":1423.39,"end":1426.39,"text":"בא בפנוח שלו יש צמר צלעים"},{"start":1426.39,"end":1428.39,"text":"עם ברגים תעופתיים נשלפים"},{"start":1428.39,"end":1429.39,"text":"עם פינים קופצים"},{"start":1429.39,"end":1432.39,"text":"עם אסבס תחוש הקשוקה בילט אין"},{"start":1432.39,"end":1433.48,"text":"כמו שאומרים"},{"start":1433.48,"end":1434.48,"text":"סבבי בייבי"},{"start":1434.48,"end":1436.48,"text":"ולבייבי סבבי"},{"start":1436.48,"end":1437.58,"text":"כמו שאומר חז\"ל"},{"start":1437.58,"end":1438.8,"text":"סבבה"},{"start":1438.8,"end":1439.76,"text":"אבא בא"},{"start":1439.76,"end":1441.91,"text":"אריה מכפר סבא בא"},{"start":1441.91,"end":1444.19,"text":"ותחשיבו על זה"},{"start":1444.19,"end":1460.54,"text":"יעד נעבור בשידור חי ללילה גוב עם גידי גוב"},{"start":1460.54,"end":1463.54,"text":"המבצע מערכון משותף עם יאורם גאון"},{"start":1463.54,"end":1464.54,"text":"לאחר לילה גוב"},{"start":1464.54,"end":1465.54,"text":"החל מהערב"},{"start":1465.54,"end":1469.54,"text":"ובכל יום שני פרק בסדרת המתח תיקים באפלה"},{"start":1469.54,"end":1471.53,"text":"והערב החוליה המובילה"},{"start":1471.53,"end":1489.89,"text":"שימו להם הודעה חשובה"},{"start":1489.89,"end":1491.89,"text":"רוצים להשתתף בתוכנית הקומדיסטור?"},{"start":1491.89,"end":1493.89,"text":"בא לכם לקחת חלק פעיל בתוכנית?"},{"start":1493.89,"end":1496.86,"text":"שימו להם, מבצע מיוחד לפורים"},{"start":1496.86,"end":1498.86,"text":"שירחו לנו עכשיו, קלטת ביתית"},{"start":1498.86,"end":1500.86,"text":"לא יותר מחמש דקות"},{"start":1500.86,"end":1503.86,"text":"ואתם מגלמים, מבצעים, עושים כל מיני קטעים על הקומנדיסטור"},{"start":1503.86,"end":1504.86,"text":"לא אכפת לנו"},{"start":1504.86,"end":1505.86,"text":"תפתיעו אותנו"},{"start":1505.86,"end":1507.86,"text":"שירחו לנו את זה לצבע דואר"},{"start":1507.86,"end":1509.86,"text":"1-4463 בתל אביב"},{"start":1509.86,"end":1511.86,"text":"אנחנו נקבל תקלטות"},{"start":1511.86,"end":1512.82,"text":"נעבור עליהם"},{"start":1512.82,"end":1514.82,"text":"והזוכה המאושר השתתף איתנו"},{"start":1514.82,"end":1516.82,"text":"והתארח כאן בתוכנית של פורים"},{"start":1516.82,"end":1518.82,"text":"רבותיי, למה אתם מחכים?"},{"start":1518.82,"end":1519.82,"text":"לכו תתחילו לעבוד"},{"start":1519.82,"end":1521.82,"text":"ותצלמו את זה"}]