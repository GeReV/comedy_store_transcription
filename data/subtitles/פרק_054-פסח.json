[{"start":31.33,"end":34.59,"text":"תמוכים הבאים, לקורא נסתון!"},{"start":61.78,"end":64.06,"text":"זהו סי אמיתי, בשידור חי!"},{"start":64.06,"end":71.73,"text":"אוי רבותה, אני לא מאמין, אולי 20 סנטימטרים מפרידים"},{"start":71.73,"end":75.71,"text":"בין אדון קפיץ לי לבין המרכז, מה תגובתך?"},{"start":75.71,"end":79.53,"text":"הייתי צריך לקחת תנופה מעקה בה, איזה שטוט!"},{"start":79.53,"end":82.14,"text":"ובכן, הייתי אומר, טקטיקה שגויה!"},{"start":82.14,"end":86.86,"text":"שוב יום שחור לספורט הישראלי, שוב התרחקנו מאירופה!"},{"start":86.86,"end":90.39,"text":"עוד צעים ישברו כאן, מיד אחרי הפרסומות!"},{"start":90.39,"end":99.48,"text":"אוקיי, עכשיו ספרי לי, מה את רואה כאן?"},{"start":99.48,"end":104.35,"text":"טוב, אני רואה אישה שוכבת על החוף"},{"start":104.35,"end":105.01,"text":"מעניין"},{"start":105.01,"end":109.7,"text":"העיניים של העצומות והיא נהנית מכל רגע"},{"start":109.7,"end":110.72,"text":"מאוד, מאוד"},{"start":110.72,"end":112.48,"text":"כן, היא שותה דייט קוקה קולה"},{"start":112.48,"end":113.29,"text":"איפה?"},{"start":113.29,"end":113.97,"text":"כאן"},{"start":113.97,"end":117.15,"text":"מה פתאום, בקבוק דייט קוקה קולה לא נראה כך"},{"start":117.15,"end":117.85,"text":"הוא כן"},{"start":117.85,"end":118.33,"text":"הוא לא"},{"start":118.33,"end":118.93,"text":"הוא כן"},{"start":118.93,"end":119.43,"text":"הוא לא"},{"start":119.43,"end":121.51,"text":"הוא כן ועוד איך נראה ככה"},{"start":121.51,"end":126.04,"text":"דייט קוקה קולה, זה מרענן, גם בבקבוק חצי ליטר"},{"start":126.04,"end":128.55,"text":"חטיף פאור רינג'ר זה מחלק משחק סמים!"},{"start":128.55,"end":132.55,"text":"גם הוא בא לשים על איתו יפרון, גם משחק בוות סבון וגם חותמת!"},{"start":132.55,"end":136.55,"text":"ומה הכי נפלא במשחק הקסמים? מקבלים אותו מתנה מחטיף בוטנים פאור רינג'ר!"},{"start":136.55,"end":137.55,"text":"אוכלים חטיף בוטנים פאור רינג'ר!"},{"start":137.55,"end":140.55,"text":"עוסקים חמש עקיות גולות, מביאים אותה לסניף הדואר הקרוב אליכם"},{"start":140.55,"end":143.55,"text":"ומקבלים במקום את משחק הקסמים במתנה בלי הגרלה!"},{"start":143.55,"end":148.55,"text":"משחק הקסמים, גם בובה, גם בוות, גם חותמת וגם בחינם!"},{"start":148.55,"end":151.63,"text":"פאור רינג'ר, חטיף בוטנים עם כוח מיוחד!"},{"start":151.63,"end":188.94,"text":"פאור רינג'ר, המשימה: לתדלק פס!"},{"start":188.94,"end":190.26,"text":"הפס הגדול!"},{"start":190.26,"end":193.26,"text":"פיסה לאמריקה, לאתר הצילומים!"},{"start":193.26,"end":198.26,"text":"מתנה בכל תתלוק מחמישים שקלים ומעלה, וגם חוספים מבקות ומשתתפים בהקרלות!"},{"start":198.26,"end":199.26,"text":"רוצים מתנות של הפאור רינג'ר?"},{"start":199.26,"end":201.26,"text":"פאור רינג'ר!"},{"start":201.26,"end":203.26,"text":"חפשו את השילות בתחלות המבצע!"},{"start":203.26,"end":205.44,"text":"מסע אל גבולות הזמן והחלל."},{"start":205.44,"end":209.44,"text":"גיבורי הדור החדש יקחו את חמל מעבר לגבול האחרון."},{"start":209.44,"end":213.44,"text":"מסע בין כוכבים דורות, עכשיו בבתי הקולנוע."},{"start":213.44,"end":219.15,"text":"וואו, ביסלי. ביסלי. ביסלי. איך איתו ביסלי? ביסלי, רוצה גם?"},{"start":219.15,"end":221.15,"text":"ירי, יש לו ביסלי. תן לי קצת."},{"start":221.15,"end":226.22,"text":"יו, ביסלי. ביסלי."},{"start":226.22,"end":234.21,"text":"ביסלי. עכשיו חדש. ביסלי קשר לפסח. איזה חדוף."},{"start":234.21,"end":236.21,"text":"איזה חדוף."},{"start":236.21,"end":243.19,"text":"יש לך כסתם, דבר ראש טוב, דבר ראש טוב."},{"start":243.19,"end":248.75,"text":"אהלו דברים שהם לא שיעו."},{"start":248.75,"end":251.75,"text":"סבא, כמה זמניים עובדים במצרים?"},{"start":251.75,"end":253.75,"text":"זה לא היה בזמני."},{"start":253.75,"end":257.44,"text":"אפס, אפס."},{"start":257.44,"end":258.3,"text":"הלואו?"},{"start":258.41,"end":260.49,"text":"דורן, זה לך!"},{"start":260.49,"end":262.49,"text":"אבא, כמה זמניים עובדים במצרים?"},{"start":262.49,"end":263.49,"text":"מה זה?"},{"start":263.49,"end":265.49,"text":"בשביל זה אתה מתקשר לניו יורק?"},{"start":265.49,"end":267.49,"text":"אני אמרת שזה שטן של שם שטן מתחת במצל."},{"start":267.49,"end":269.52,"text":"על זה דודה דורה הייתה אומרת,"},{"start":269.52,"end":271.52,"text":"כמה זמניים עובדים במצרים הם לא יודעים,"},{"start":271.52,"end":273.52,"text":"אבל להתקשר לניו יורק זה כן!"},{"start":273.52,"end":277.38,"text":"אפס, אפס, ארץ, עיר, מספר."},{"start":277.38,"end":278.38,"text":"אפס, אפס, מה?"},{"start":278.38,"end":280.66,"text":"אפס, אפס, ארץ, עיר, מספר."},{"start":280.66,"end":282.66,"text":"לא צריך להיות איינשטיין בשביל זה."},{"start":282.66,"end":284.66,"text":"מה גון?"},{"start":284.66,"end":291.29,"text":"מה גון?"},{"start":291.29,"end":307.23,"text":"לילד שלך לא בדיוק משנה על איזה ספת נוער הוא ישן."},{"start":307.23,"end":309.89,"text":"העיקר שזה יהיה מגניב."},{"start":309.89,"end":320.69,"text":"במקום שתפקירי את הגב שלו, תמי לו ספה של המנח עם המרכז הבריאותי."},{"start":320.69,"end":322.69,"text":"ותוכלי נשון בשקט."},{"start":322.69,"end":327.01,"text":"ספה, ספה, ספה של ארץ."},{"start":327.01,"end":336.37,"text":"כשהרועה שוב עומד להשתלט על העולם,"},{"start":336.37,"end":339.37,"text":"ואין מי שיעצור את הייצואים המשתוללים ברחבי העיר."},{"start":339.37,"end":342.37,"text":"הוכשה הכל כבר נראה אבות."},{"start":342.37,"end":345.39,"text":"אין מי שאין מי גוסט פוסט."},{"start":345.39,"end":349.87,"text":"בכסכי השדים שתיים, יום חמישי, רבע לתשע."},{"start":349.87,"end":352.87,"text":"אבות שתיים, תלעד."},{"start":352.87,"end":405.03,"text":"ערב טוב, שוב אתם בתוכנית כדאי לקנות,"},{"start":405.03,"end":408.15,"text":"והפעם חידושים והמצאות ללא תחרות,"},{"start":408.15,"end":411.27,"text":"לכבוד חג הפסח, חג החירות."},{"start":411.27,"end":418.54,"text":"אם אתם מרגישים נורא, בגלל שהמצא כל כך שבירה,"},{"start":418.54,"end":423.84,"text":"נע להכיר בבקשה את המצא הגמישה."},{"start":423.84,"end":429.42,"text":"אלסטית כמו גומי, חזקה כמו קפה,"},{"start":429.42,"end":433.48,"text":"מתאימה לכליחים לרולדה ולפה."},{"start":433.48,"end":437.21,"text":"הנה הגיע לו ליל הסדר הגדול,"},{"start":437.21,"end":440.26,"text":"וכל המשפחה רוצים כבר לאכול."},{"start":440.26,"end":444.25,"text":"אך אבוי, ההגדה של פסח ארוכה היא להכאיס,"},{"start":444.25,"end":448.25,"text":"וחולפות להם שעות עד שנותנים את הביס."},{"start":448.25,"end":455.87,"text":"נא, יש פתרון, המצאה נהדרת, נא להכיר, הגדה מקוצרת."},{"start":455.87,"end":462.75,"text":"עכשיו כבר לא צריך לכאוס, הסדר מתחיל וכבר אפשר ללעוס."},{"start":462.75,"end":468.06,"text":"אתה מחפש אפיקומן, זה לוקח לך המון זמן,"},{"start":468.06,"end":474.54,"text":"והיום יש פטן סימפטי, הזעקה עם שלט טלפטי."},{"start":474.54,"end":478.79,"text":"מתחבר לכל אפיקומן ובלחיצה אחת בדיוק,"},{"start":478.79,"end":481.88,"text":"אתה מיד מוצא ומקבל מתנה."},{"start":481.88,"end":485.95,"text":"עד כאן להפעם."},{"start":485.95,"end":494.97,"text":"וכדאי לכם לקנות כילל הסדר מיהו, מהו, שיהיה לכם חג וואו."},{"start":494.97,"end":518.3,"text":"חג שמח, חג שמח."},{"start":518.3,"end":521.97,"text":"קום בני, קום בני, נשאתה אפיקומן."},{"start":521.97,"end":522.97,"text":"וואו."},{"start":522.97,"end":525.16,"text":"זה כמון, זה כמון."},{"start":525.16,"end":528.21,"text":"שמע, אני רוצה לומר לך, כן?"},{"start":528.21,"end":529.56,"text":"יפת."},{"start":529.56,"end":531.53,"text":"בזמן האחרון קצת מוזר."},{"start":531.53,"end":534.53,"text":"נו, התרגלנו. כזה הוא תמיד היה."},{"start":534.53,"end":536.53,"text":"שלושה, תמיד היה."},{"start":536.53,"end":537.47,"text":"כן."},{"start":537.47,"end":540.62,"text":"תגידו, למה נוח לא פה? נשאר שבת בשבטה?"},{"start":540.62,"end":542.62,"text":"שני מזר, שבטהיה."},{"start":542.62,"end":546.62,"text":"תמיד שאנחנו באים לפה, מרוב שהוא שער כואב לי הראש, אני רואה כוכבים."},{"start":546.62,"end":548.62,"text":"אחת מזר, כוכביה."},{"start":548.62,"end":550.62,"text":"הוא לא מבשיק לדבר."},{"start":550.62,"end":552.62,"text":"עשרה, נמריה."},{"start":552.62,"end":554.77,"text":"ירידי לי, מתי ילדה?"},{"start":554.77,"end":556.8,"text":"תישאר חלדה."},{"start":556.8,"end":558.8,"text":"בונה, אי אפשר להוציא פה מילה."},{"start":558.8,"end":559.8,"text":"שמונה ימי מילה."},{"start":559.8,"end":562.8,"text":"בואו נמשיך לקרוא, רק נקרא לסבתא."},{"start":562.8,"end":563.8,"text":"סבתא!"},{"start":563.8,"end":564.8,"text":"שיבה ימי סבתא!"},{"start":564.8,"end":567.77,"text":"רגע, רגע, עכשיו תורי לקרוא שהסדר לא משנה."},{"start":567.77,"end":569.77,"text":"שיבה ימי מילה."},{"start":569.77,"end":572.73,"text":"אז כן משנה, עכשיו במקרה איזה תורה?"},{"start":572.73,"end":574.99,"text":"חמישה חומשה תורה."},{"start":574.99,"end":576.99,"text":"רק תגיד לי באיזה עוד להתחיל."},{"start":576.99,"end":578.89,"text":"ארבעים עוד."},{"start":578.89,"end":579.98,"text":"לא משנה, תקרא אתה."},{"start":579.98,"end":582.98,"text":"אני לא קורא עכשיו, וחוץ מזה יש לי משקפיים אבות."},{"start":582.98,"end":584.98,"text":"שלושה עבות."},{"start":584.98,"end":587.98,"text":"אמין לי זה ילד שגיע לי, אתם בפעם אחרונה שראינו אותו זה היה בברית."},{"start":587.98,"end":622.17,"text":"שלום."},{"start":622.17,"end":623.32,"text":"אלון."},{"start":623.32,"end":624.64,"text":"ערב טוב."},{"start":624.64,"end":627.75,"text":"ידוע לך כמובן שזאת איננה מכוניתך."},{"start":627.75,"end":628.92,"text":"מי זה?"},{"start":628.92,"end":631.92,"text":"זאת ההזקה הפסיכוסומטית החדשה של חברת אנקונדה."},{"start":631.92,"end":633.92,"text":"איך ייבלת אותי המכונית?"},{"start":633.92,"end":636.92,"text":"לפני שנמשיך בשיחה עליי לשאול אותך האם ברצונך להמשיך ולפרוץ למכונית."},{"start":636.92,"end":638.88,"text":"מה נראה לך אני משחק לגו אני?"},{"start":638.88,"end":643.88,"text":"אם כך עליי להזירך כי מה שאתה עתיד לשמוע עלול לגרום לך לנזק בלתי יפיך."},{"start":643.88,"end":644.88,"text":"זה איך להתחפשי מן הענה אותה?"},{"start":644.88,"end":647.81,"text":"אני מתוכננת לגרום לך להשתעמם אדמוות."},{"start":647.81,"end":653.97,"text":"אתה עומד לשמוע את הרב שיח בין הפילוסוף ישוע בר יעקב, הפסיכולוג יוסף בן גיק וירון לונדון,"},{"start":653.97,"end":657.97,"text":"בנושא אי סדירות של מערכת העיכול והשפעתה על הקיום בארץ ישראל."},{"start":657.97,"end":660.54,"text":"אם כך נתחיל ברב שיח."},{"start":660.54,"end":666.54,"text":"וכן, לפי דעתי הכל קשור בכרומוזומים שבניש המים לתוך האותיו."},{"start":666.54,"end":668.54,"text":"מה נכון להכים את זה? חלה, שכן, מה ברב?"},{"start":668.54,"end":670.54,"text":"שכן, מה ברב? הלו?"},{"start":670.54,"end":682.51,"text":"אתה מעוניין להפסיק?"},{"start":682.51,"end":689.51,"text":"אם כך נעבור לשמוע את הגבעת רון בשירם \"מלאו עסמי נובר\"."},{"start":693.51,"end":696.51,"text":"להכי, קחי טעות בקליבני קילוב של לעבוד ורצנה עליי!"},{"start":696.51,"end":698.51,"text":"נשתקעת הבטא, בוא הנקה!"},{"start":698.51,"end":702.51,"text":"ותודה שהפעלת את ההזקה הפסיכוסומטית החדשה של חברת אנקונדה."},{"start":702.51,"end":705.51,"text":"להכי, יש בלב חוניות בכביש, אנקונדן קלאוי."},{"start":705.51,"end":706.51,"text":"שלום ולהתראות."},{"start":706.51,"end":707.51,"text":"להכי!"},{"start":707.51,"end":724.08,"text":"כל הלכורות כבר ריקים"},{"start":724.08,"end":727.08,"text":"הסרטן!"},{"start":727.08,"end":733.62,"text":"נדבר"},{"start":733.62,"end":737.54,"text":"נדבר ישעני יהודים טובים"},{"start":737.54,"end":738.54,"text":"נדבר"},{"start":738.54,"end":741.82,"text":"נדבר ישעני המשיח בה נדבר"},{"start":741.82,"end":743.91,"text":"תודה רבה לך אדוני"},{"start":743.91,"end":744.91,"text":"תודה רבה לך אדוני"},{"start":744.91,"end":746.91,"text":"תזכה לכל ביקור תורה אדוני"},{"start":746.91,"end":748.91,"text":"תודה רבה לך אדוני"},{"start":748.91,"end":750.91,"text":"תודה רבה לך אדוני"},{"start":750.91,"end":752.91,"text":"תזכה אתם לחיים טובים וארוכים"},{"start":752.91,"end":754.91,"text":"אתה ובנך ובני בנך"},{"start":754.91,"end":756.91,"text":"וכולם חדים וכל המינים וכולם"},{"start":756.91,"end":758.91,"text":"תזכה ואתה ואשתך"},{"start":758.91,"end":760.91,"text":"תודה רבה אדוני"},{"start":760.91,"end":762.91,"text":"תזכה לחיים טובים"},{"start":762.91,"end":764.91,"text":"אדוני בנך ובני בנך"},{"start":764.91,"end":766.91,"text":"תודה רבה לך אדוני"},{"start":766.91,"end":768.91,"text":"כנגד שני בנים"},{"start":768.91,"end":773.79,"text":"דיברה תורה"},{"start":773.79,"end":787.27,"text":"שמעון"},{"start":787.27,"end":789.72,"text":"עברה לי מחשבה בראש"},{"start":789.72,"end":791.72,"text":"שדר"},{"start":791.72,"end":791.82,"text":"תגיד"},{"start":791.72,"end":801.59,"text":"איך זה יכול להיות"},{"start":801.59,"end":803.59,"text":"שאנחנו בסדר פה לבד"},{"start":803.59,"end":805.59,"text":"לאיפה נעלמו כולם?"},{"start":805.59,"end":809.91,"text":"אולי קרה משהו"},{"start":809.91,"end":815.39,"text":"לאמא שמה עוד"},{"start":815.39,"end":817.93,"text":"עברה לי מחשבה בראש"},{"start":817.93,"end":820.41,"text":"שדר"},{"start":820.41,"end":822.73,"text":"תגיד איך זה יכול להיות"},{"start":822.73,"end":824.76,"text":"שאנחנו בסדר פה לבד"},{"start":824.76,"end":831.14,"text":"אולי קרה משהו לאמא שלהם"},{"start":831.14,"end":834.35,"text":"זה רעיון"},{"start":834.35,"end":841.49,"text":"זה אפשרי"},{"start":841.49,"end":843.71,"text":"שמה עון"},{"start":843.71,"end":846.66,"text":"בא לי עוד מחשבה"},{"start":846.66,"end":850.27,"text":"שדר"},{"start":850.27,"end":853.52,"text":"החיים זה כמו מצב"},{"start":853.52,"end":855.52,"text":"מרובעים קשים ומלא גפשושיות"},{"start":855.52,"end":858.11,"text":"רשע"},{"start":858.11,"end":860.65,"text":"מה הוא אומר"},{"start":860.65,"end":862.65,"text":"איזה בני ישראל עברו על אמא שלך במדבר 40 שנה"},{"start":862.65,"end":866.12,"text":"מה הוא אומר"},{"start":866.12,"end":869.2,"text":"לא יודע"},{"start":869.2,"end":872.28,"text":"ושאינו יודע לשאול"},{"start":872.28,"end":876.6,"text":"במישור? במישור הפילוסופי או במישור של התכלס?"},{"start":876.6,"end":878.88,"text":"במישור של הסדר כמובן"},{"start":878.88,"end":880.94,"text":"תגיד לי מי זה מדבר? מי זה הלו?"},{"start":880.94,"end":883.01,"text":"מי אתה?"},{"start":883.01,"end":888.9,"text":"אני אליהו"},{"start":888.9,"end":893.64,"text":"תגיד איזה מרכבות אש שרפו לי עם משחת הגבות?"},{"start":893.64,"end":899.5,"text":"אני לא יודע אבל אם אנחנו כבר מדברים גם לי עברה המחשבה בראש"},{"start":899.5,"end":902.24,"text":"שדר שדר"},{"start":902.24,"end":904.56,"text":"החיים זה כמו חרוסת"},{"start":904.56,"end":906.52,"text":"מתוקים אבל דביקים"},{"start":906.52,"end":907.61,"text":"יאללה בית"},{"start":907.61,"end":909.67,"text":"הלו, חבר'ה, רגע!"},{"start":909.67,"end":911.8,"text":"היי, אל תלכו לי באמצע הסדר!"},{"start":911.8,"end":912.93,"text":"הלו!"},{"start":912.93,"end":917.64,"text":"היי!"},{"start":917.64,"end":970.25,"text":"הלו?"},{"start":970.25,"end":971.25,"text":"תגיד, אתה יודע מתי מצלמים היום?"},{"start":971.25,"end":972.25,"text":"עוד מעט."},{"start":972.25,"end":974.56,"text":"ו... יש לך מושג מה יהיה בתוכנית היום?"},{"start":974.56,"end":976.16,"text":"כן."},{"start":976.16,"end":977.7,"text":"מה?"},{"start":977.7,"end":979.7,"text":"יהיו כמה אנשים שידעו לנו בענייני היום."},{"start":979.7,"end":983.98,"text":"יהיה כתאים אמנותיים, יהיה רקדנים, זמר, קוסם."},{"start":983.98,"end":984.98,"text":"אה, הבנתי. לא."},{"start":984.98,"end":985.98,"text":"למה אני שואל?"},{"start":985.98,"end":987.98,"text":"כי קודם ראיתי ברשמה של המשתתפים: \"אתה אחים כהן\"."},{"start":987.98,"end":991.1,"text":"אז רציתי לדעת מה התפקיד שלהם, מה הם עושים?"},{"start":991.1,"end":992.1,"text":"אה, הם רקדנים."},{"start":992.1,"end":994.28,"text":"אה, תודה."},{"start":994.28,"end":995.28,"text":"רגע, רגע, לא הבנתי."},{"start":995.28,"end":996.34,"text":"מה הם עושים בדיוק?"},{"start":996.34,"end":999.39,"text":"הם רקדנים או שהם רק דנים?"},{"start":999.39,"end":1002.48,"text":"הם רקדנים, מה זאת אומרת?"},{"start":1002.48,"end":1004.48,"text":"לא הבנת אותי, יש פשוט הבדל בין הדברים."},{"start":1004.48,"end":1007.45,"text":"יש רק דנים ויש רק דנים."},{"start":1007.45,"end":1008.45,"text":"שני דברים שונים לגמרי."},{"start":1008.45,"end":1010.45,"text":"הם שונים לגמרי. -אה, הם רק דנים."},{"start":1010.45,"end":1012.45,"text":"לא, אבל אתה עדיין לא מסביר את עצמך."},{"start":1012.45,"end":1016.42,"text":"יש רק דנים. זה אחד. בצד מעצוב אותו."},{"start":1016.42,"end":1020.48,"text":"ויש רק דנים. הם רק דנים. זה דבר שני."},{"start":1020.48,"end":1022.48,"text":"עכשיו, מה הם רוצים? תגידי."},{"start":1022.48,"end":1024.48,"text":"תשמע, אני עובד, אתה מפריע לי, הם רק דנים וזהו."},{"start":1024.48,"end":1027.48,"text":"אבל אתה עדיין, עדיין רוצה את אותה טעות."},{"start":1027.48,"end":1029.48,"text":"אתה לא אומר לי, הם רק דנים."},{"start":1029.48,"end":1030.48,"text":"הם רק דנים, מה?"},{"start":1030.48,"end":1033.79,"text":"אבל יש רק דנים ורק דנים."},{"start":1033.79,"end":1036.79,"text":"הם רק דנים ורק דנים ורק דנים."},{"start":1036.79,"end":1041.21,"text":"שלום לכם, אני מושה מהאכים כהן, אולי אני תגיד לנו מה אנחנו צריכים לעשות?"},{"start":1041.21,"end":1041.31,"text":"נאוווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":1041.21,"end":1082.81,"text":"נעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעעע"},{"start":1082.81,"end":1084.6,"text":"כל יום. והפעם"},{"start":1084.6,"end":1087.14,"text":"תופעה חמורה בחברה הישראלית"},{"start":1087.14,"end":1088.96,"text":"אנשים שעמדו אל מול"},{"start":1088.96,"end":1091.25,"text":"פני הדלת. נמצא איתנו"},{"start":1091.25,"end":1093.27,"text":"כאן יוד כסיף. שלום יוד"},{"start":1093.27,"end":1094.85,"text":"אולי לפני שנמשיך"},{"start":1094.85,"end":1096.86,"text":"בואו נראה קטע מתוך אותו"},{"start":1096.86,"end":1098.94,"text":"מעורת טראומטי שאתה עברת"},{"start":1098.94,"end":1101.79,"text":"בבקשה. אולי בקצרה"},{"start":1101.79,"end":1103.55,"text":"תתאר לנו מה אנו רואים?"},{"start":1103.55,"end":1106.32,"text":"טוב פה בעצם"},{"start":1106.32,"end":1108.83,"text":"רואים אותי עומד"},{"start":1108.83,"end":1112.0,"text":"אל מול פני הדלת"},{"start":1112.0,"end":1115.38,"text":"לא, לא קל, לא קל"},{"start":1115.38,"end":1117.75,"text":"איך הכל התחיל בעצם?"},{"start":1119.56,"end":1120.8,"text":"אני זוכר את אותו יום"},{"start":1120.8,"end":1122.63,"text":"ממש כאילו זה היה אתמול"},{"start":1122.63,"end":1125.39,"text":"אני הלכתי לתומי ברחוב"},{"start":1125.39,"end":1127.59,"text":"לפתע מצאתי את עצמי בפני בניין"},{"start":1127.59,"end":1130.86,"text":"בין קומה או שתיים"},{"start":1130.86,"end":1131.56,"text":"אני כבר לא זוכר"},{"start":1131.56,"end":1133.22,"text":"אני זוכר את עצמי מטפס למעלה"},{"start":1133.22,"end":1138.63,"text":"פתאום עמדתי שם"},{"start":1138.63,"end":1144.21,"text":"ולמה הסכמת בעצם לחשף"},{"start":1144.21,"end":1145.87,"text":"אם אפשר לשאול?"},{"start":1145.87,"end":1149.13,"text":"אני הסכמתי מהסיבה"},{"start":1149.13,"end":1151.13,"text":"שאני חושב שיש הרבה אנשים"},{"start":1151.13,"end":1152.49,"text":"ואני גם יודע על הרבה כאלה"},{"start":1152.49,"end":1156.1,"text":"אנשים שנמצאים עכשיו בבית"},{"start":1156.1,"end":1157.38,"text":"ואני מקווה שהוא ראים אותנו"},{"start":1157.38,"end":1168.33,"text":"באיזושהי סיבה, הם פשוט מסרבים להודות להכיר בעובדה הזאת שהם גם, גם הם עמדו בפני הדלת."},{"start":1168.33,"end":1178.27,"text":"יש לי חבר למשל דני, ודני, אני יודע שאתה רואה אותנו עכשיו דני, ודני עבודתו, הוא ניצב יום, יום, בפני הדלת."},{"start":1178.27,"end":1188.75,"text":"הוא במקצוע שלו שליח, ודני ניצב עשרות פעמים בפני הדלת, כמו אלפי אנשים שמסרבים להכיר בעובדה, ואני הסכמתי כאן."},{"start":1188.75,"end":1198.51,"text":"די, די, די, די, די, די, יהיה בסדר, זה בסדר. זה הזמן לציין שמחר יום הדלת הבינלאומי, אל תתרקו את הדלת."},{"start":1198.51,"end":1200.12,"text":"אתה רוצה להוסיף משהו?"},{"start":1200.12,"end":1204.52,"text":"פשוט תתרמו, תתרמו, יש הרבה אנשים שסובלים."},{"start":1204.52,"end":1210.2,"text":"הם יתרמו, הרבה. די, יהיה בסדר. לא לשכוח, לא לשכוח."},{"start":1210.2,"end":1218.42,"text":"שבוע הבא נערך כאן אנשים ששוכחים לסגור את הפקק של משחת השיניים. תודה רבה לכם, די, די."},{"start":1224.01,"end":1230.61,"text":"מקווה מאוד שיהיה לנו סדר בומבסטי!"},{"start":1230.61,"end":1231.61,"text":"מבה!"},{"start":1231.61,"end":1237.01,"text":"ואיף שעמדה ואיף עמדה!"},{"start":1237.01,"end":1239.0,"text":"איזה סף או כיסא כיסא מקק!"},{"start":1239.0,"end":1242.0,"text":"די די ינו, די די ינו!"},{"start":1242.0,"end":1245.0,"text":"די די ינו, די ינו, די ינו!"},{"start":1245.0,"end":1247.0,"text":"עוז! זרדת עודה!"},{"start":1247.0,"end":1249.22,"text":"בוא הסבר לכולם, אני מבקש"},{"start":1249.22,"end":1251.22,"text":"לפתוח את ההגדון!"},{"start":1251.22,"end":1253.22,"text":"אה, יש פה הגדה!"},{"start":1253.22,"end":1255.22,"text":"זה משהו אקסטרארדינר!"},{"start":1255.22,"end":1257.22,"text":"זה משהו אקסטרארדינר!"},{"start":1257.22,"end":1261.22,"text":"זה משהו פריטסטי!"},{"start":1261.22,"end":1263.26,"text":"צילד! צילד!"},{"start":1263.26,"end":1265.94,"text":"תודה, תודה!"},{"start":1265.94,"end":1267.91,"text":"המכונות האלה, זה תופעה אקסטרארדינר!"},{"start":1267.91,"end":1269.91,"text":"המכונות האלה קוראות לבד את ההגדה!"},{"start":1269.91,"end":1271.91,"text":"כל שנותר הוא רק לאכול!"},{"start":1271.91,"end":1273.91,"text":"המכונה כבר עושה את כל אבושי!"},{"start":1273.91,"end":1275.91,"text":"אקסטרארדינר!"},{"start":1275.91,"end":1277.94,"text":"אז קדימה, לאכול, רק לפני כן!"},{"start":1277.94,"end":1280.77,"text":"מי רוצה לשאול את הקושיות?"},{"start":1280.77,"end":1283.09,"text":"אתה תשכח מזה!"},{"start":1283.09,"end":1287.09,"text":"לך תתנייק ותכפש מי נענה אותך עם השיקומן!"},{"start":1287.09,"end":1329.85,"text":"בטח תשמח לשמוע שההורים שלה פתחו לתוכנית חיס אחרון"},{"start":1329.85,"end":1332.85,"text":"ואפשר לעשות את זה אפילו עכשיו, בפועלים ישיר"},{"start":1332.85,"end":1336.26,"text":"ובעניין ההשקעות שלכם זה לא לטלפון"},{"start":1336.26,"end":1337.26,"text":"בואו אליי לסליב"},{"start":1337.26,"end":1341.09,"text":"בינינו, השקעות זה לא משחק ילדים"},{"start":1341.09,"end":1343.09,"text":"בנק הפועלים, גם אישי, גם ישיר"},{"start":1343.09,"end":1362.51,"text":"אם ככה את בוחרת את הגבינה הלבנה שלך"},{"start":1362.51,"end":1365.12,"text":"תנו ורוצה לעזור לך קצת"},{"start":1365.12,"end":1369.59,"text":"בבחני טעימה העדיפו שלושה מתוך ארבעה אנשים"},{"start":1369.59,"end":1371.59,"text":"את מעודנת חצי אחוז של תנובה"},{"start":1371.59,"end":1375.77,"text":"מעודנת גבינה לבנה במרקם קטיפתי"},{"start":1375.77,"end":1381.31,"text":"קצה הדיסקים המדהים של היד ארצי"},{"start":1381.31,"end":1383.31,"text":"דירשו את המחיר הירוק"},{"start":1383.31,"end":1385.31,"text":"רק 49 שקלים לדיסק"},{"start":1385.31,"end":1391.7,"text":"איפה קונים ירקות משומות שלי?"},{"start":1391.7,"end":1395.15,"text":"מחנות ירקות, נכון"},{"start":1395.15,"end":1398.95,"text":"איפה קונים נעליים גוזל?"},{"start":1398.95,"end":1401.52,"text":"מחנות נעליים"},{"start":1401.52,"end":1407.52,"text":"ואיפה קונים מעטפות?"},{"start":1407.52,"end":1409.87,"text":"לא"},{"start":1409.87,"end":1414.15,"text":"מעטפות קונים בדועה"},{"start":1414.15,"end":1418.23,"text":"מעטפות קונים בדועה"},{"start":1418.23,"end":1420.23,"text":"ועכשיו חדש מעטפות מבוילות"},{"start":1420.23,"end":1422.23,"text":"הבול כבר מודפס עליהם"},{"start":1422.23,"end":1424.77,"text":"איפה קונים מעטפות?"},{"start":1424.77,"end":1428.36,"text":"ילד נחמד"},{"start":1428.36,"end":1430.16,"text":"לא שלי"},{"start":1430.16,"end":1434.21,"text":"כארכיטקט המכונית משמשת אותי"},{"start":1434.21,"end":1436.21,"text":"ככלי עבודה ממדרגה הראשונה"},{"start":1436.21,"end":1438.21,"text":"אתה יוצא מעוט אחרי יום נהיגה שלם"},{"start":1438.21,"end":1440.21,"text":"ואתה לא מרגיש שנהגת בכלל"},{"start":1440.21,"end":1442.21,"text":"אני עושה 4,000 קילומטר לחודש"},{"start":1442.21,"end":1444.21,"text":"ויש לי אפס תקלות"},{"start":1444.21,"end":1447.21,"text":"זה אוטו אמין, ספורטיבי ובטוח"},{"start":1447.21,"end":1450.49,"text":"לכמה הגעתי? עד כאן"},{"start":1450.49,"end":1459.27,"text":"סיטרואן ZX, זה בדיוק זה"},{"start":1459.27,"end":1462.97,"text":"ועכשיו מבצע סיטרואן, אשראי בלי ריבית"},{"start":1462.97,"end":1465.97,"text":"וטלפון נוקיה עם קו מתנה, פרטים בסוכנויות"},{"start":1465.97,"end":1475.54,"text":"אלקטרמייסטר, מדיח כלים עם שבע תוכניות עד אחת"},{"start":1475.54,"end":1477.5,"text":"אלקטרמייסטר"},{"start":1477.5,"end":1510.72,"text":"אלקטרמייסטר"},{"start":1510.72,"end":1512.72