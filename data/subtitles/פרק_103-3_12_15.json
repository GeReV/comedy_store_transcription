[{"start":0.64,"end":1.1400000000000001,"text":"זהו!"},{"start":74.88,"end":79.88,"text":"ספרי כבר עבלה יאללה, פו פו פו פו. יאללה עבלה ספרי כבר סדר."},{"start":79.88,"end":82.01,"text":"אלוהים עודם."},{"start":82.01,"end":87.96,"text":"נסיםו שבונבון שלי אני ספלך היום את העגדן על בוסקילה הוד."},{"start":87.96,"end":90.66,"text":"לפני שנים רבות רבות."},{"start":90.66,"end":93.79,"text":"בארץ רחוקה רחוקה."},{"start":93.79,"end":94.79,"text":"חוקה."},{"start":94.79,"end":97.17,"text":"הלו, בוסקילה הוד."},{"start":97.17,"end":100.17,"text":"מלח עצודת וגיבור חם."},{"start":100.17,"end":105.53,"text":"מי? מי? מי?"},{"start":105.53,"end":106.74,"text":"מי זה פה?"},{"start":106.74,"end":108.45,"text":"חלה."},{"start":108.45,"end":109.45,"text":"עם תעיהו, בוסקילה, מה זה?"},{"start":109.45,"end":113.57,"text":"בוסקילה בין עצים ובכלו שלוש ביתים."},{"start":113.57,"end":115.56,"text":"הלו, מה זה המכנסים האלה, אה?"},{"start":115.56,"end":117.84,"text":"הלו, מה אתה הסיעה, חלה?"},{"start":117.84,"end":120.93,"text":"אתה הייתה חרון שלכם."},{"start":120.93,"end":121.93,"text":"מרגישים הראשון."},{"start":121.93,"end":122.93,"text":"יאללה, רבי."},{"start":122.93,"end":123.93,"text":"יאללה, רבי."},{"start":123.93,"end":124.93,"text":"הייתי מריאם."},{"start":124.93,"end":126.99,"text":"עצי אשתי."},{"start":126.99,"end":128.99,"text":"יאללה, עשתיו."},{"start":128.99,"end":131.14,"text":"יחב בשביל כולם."},{"start":131.14,"end":133.14,"text":"בוסקילה בשביל עצמו."},{"start":133.14,"end":134.14,"text":"אוף ראייו."},{"start":134.14,"end":137.04,"text":"בוסקילה הוד חש לעזרתה של הנצחה מריאם."},{"start":137.04,"end":138.04,"text":"ויצא לדוק רב עמית."},{"start":138.04,"end":140.04,"text":"עם השריפ הרעמי רמת גן."},{"start":140.04,"end":141.01,"text":"אונגאר."},{"start":141.01,"end":143.36,"text":"הייתי ממליץ לך להיכנח."},{"start":143.36,"end":145.64,"text":"אלה התחלה לתחנף אלה תחק תחק."},{"start":145.64,"end":147.64,"text":"אונגאר בן בליאל."},{"start":147.64,"end":150.24,"text":"אונגאר בן בליאל."},{"start":150.24,"end":154.3,"text":"אונגאר."},{"start":154.3,"end":168.17,"text":"ישברים תכוחת ריאה."},{"start":168.17,"end":170.17,"text":"עוד לא בקיפור הלו."},{"start":170.17,"end":172.17,"text":"השריפ מרמת גן חטף רופעה."},{"start":172.17,"end":174.17,"text":"מכישלונו בדוק רב."},{"start":174.17,"end":177.27,"text":"קרה לשני חבר'ה שלו למה לא עשו אותו בעדבא."},{"start":184.75,"end":188.12,"text":"שריפה."},{"start":188.12,"end":212.84,"text":"שריפה."},{"start":212.84,"end":215.28,"text":"שריפה."},{"start":215.28,"end":222.5,"text":"בוסקיל הוא די זיהר."},{"start":222.5,"end":224.89,"text":"ביקח."},{"start":224.89,"end":226.98,"text":"ללקד בוסקילה עוד בידי בניעב ליעל."},{"start":226.98,"end":229.04,"text":"שיעלותו על מוקים."},{"start":229.04,"end":231.04,"text":"בוסקילה מדיום ריר."},{"start":231.04,"end":235.17,"text":"מייסי לי בוסקילה בוסקיל."},{"start":235.17,"end":238.24,"text":"מה נאםית אימה בוסקילה."},{"start":238.24,"end":240.73,"text":"יואו נתו כל מה נסיםוش."},{"start":240.73,"end":246.94,"text":"פריפרתו די נמי עשו לכבל נקרא לך את הצורה."},{"start":246.94,"end":253.91,"text":"נחלון חביב שבין נסיםוش يا בונבון."},{"start":253.91,"end":256.55,"text":"נחלון חביב שבין נסיםוش يا בונבון."},{"start":256.55,"end":258.96,"text":"נחלון חביב שבין נסיםוش يا בונבון."},{"start":258.96,"end":261.02,"text":"נחלון חביב שבין נסיםוش."},{"start":261.02,"end":264.94,"text":"נחלון חביב שבין נסיםוش يا בונבון."},{"start":264.94,"end":266.94,"text":"נחלון חביב שבין נסיםוش يا בונבון."},{"start":266.94,"end":267.94,"text":"נסיםוش."},{"start":267.94,"end":269.97,"text":"נסיםוش."},{"start":269.97,"end":271.97,"text":"נסיםוش."},{"start":271.97,"end":273.03,"text":"בונבון."},{"start":273.03,"end":274.38,"text":"נעקבל לך."},{"start":274.38,"end":275.38,"text":"אה."},{"start":275.38,"end":277.38,"text":"כולה بتروزيل وتعرض فوق הרי ח."},{"start":277.38,"end":278.38,"text":"בונבון."},{"start":278.38,"end":279.38,"text":"בונבון."},{"start":279.38,"end":280.38,"text":"נסיםוش."},{"start":280.38,"end":281.57,"text":"אי אודיה?"},{"start":281.57,"end":282.54,"text":"עודיה, עודיה!"},{"start":282.54,"end":284.76,"text":"אבל אייק מורימה?"},{"start":284.76,"end":286.21,"text":"איימה?"},{"start":286.21,"end":289.97,"text":"אייק מורימה, אייק מורימה?"},{"start":289.97,"end":290.97,"text":"אייק מורימה, אייק מורימה?"},{"start":290.97,"end":291.97,"text":"לילה טוב, נתיםו."},{"start":291.97,"end":292.97,"text":"לילה טוב, נתיםו."},{"start":292.97,"end":293.97,"text":"לילה טוב, נתיםו."},{"start":293.97,"end":296.18,"text":"לילה טוב, בונבון."},{"start":296.18,"end":298.18,"text":"תחלום, חלומות פסגד."},{"start":298.18,"end":299.34,"text":"שובי גובי."},{"start":299.34,"end":301.34,"text":"עבוד כיל עבוד, ורק בלער."},{"start":301.34,"end":302.34,"text":"מה די תירו."},{"start":302.34,"end":304.33,"text":"חיילה המעבודה."},{"start":304.33,"end":305.33,"text":"ביתר חשדו."},{"start":305.33,"end":314.3,"text":"בילון עבור."},{"start":314.3,"end":316.3,"text":"לא קצר במיוחד."},{"start":316.3,"end":318.21,"text":"לא היה לו מוסד."},{"start":318.21,"end":320.25,"text":"כיצד לפסוע."},{"start":320.25,"end":324.44,"text":"רק אתמול הוא בא לאוויר העולם."},{"start":324.44,"end":327.44,"text":"ולפסוע לא היה לו שום ניסיון."},{"start":327.44,"end":328.78,"text":"ביל ביל."},{"start":328.78,"end":331.94,"text":"קלה נתאר את הזמרה שלך כזאת דושנונית,"},{"start":331.94,"end":334.2,"text":"את יכולה לשחק במחזמר."},{"start":334.2,"end":335.55,"text":"וואו."},{"start":335.55,"end":336.55,"text":"מה זאת אומרת מחזמר?"},{"start":336.55,"end":338.8,"text":"זה אי אפשר להמחיש, זה דושנוני."},{"start":338.8,"end":340.77,"text":"זה גם מחזבל וגם אותו זמר."},{"start":340.77,"end":343.04,"text":"וואו."},{"start":343.04,"end":344.04,"text":"רכפת, אולי תבוא אליי."},{"start":344.04,"end":347.2,"text":"אני לא יכולה, אני צריכה לעשות כביסה בהרתחה."},{"start":347.2,"end":349.88,"text":"אז מה, אבל אני צריכה לעשות כביסה באשריה"},{"start":349.88,"end":350.4,"text":"אז מה?"},{"start":350.4,"end":350.96,"text":"אז מה?"},{"start":350.96,"end":354.97,"text":"אפרופו כביסה, חשבתי לפתוח מכבסה"},{"start":354.97,"end":356.38,"text":"וואו"},{"start":356.38,"end":359.06,"text":"אלכו, ואת לא יודעת מה זה אפרופו מכבסה?"},{"start":359.06,"end":360.86,"text":"נו, מה זה?"},{"start":360.86,"end":364.7,"text":"הכזאת פגרת, אפילו חשבתי על פרסומת למכבסה שלנו"},{"start":364.7,"end":366.17,"text":"וואו"},{"start":366.17,"end":369.11,"text":"הנה, סתכלי, יש לי ויז'ן"},{"start":369.11,"end":370.46,"text":"וזה"},{"start":370.46,"end":376.24,"text":"ללא ספק, הנתונים שלך ממש מרשימים ואני חושבת שבאמת מגיעה לך עליו"},{"start":376.24,"end":378.07,"text":"אבל קודם תסתובבי"},{"start":378.07,"end":380.91,"text":"סתובבי, סתובבי"},{"start":380.91,"end":385.49,"text":"אני לא מפגרת כנגד כיוון השעון"},{"start":385.49,"end":387.55,"text":"אבל יש לי שעון אלקטרוני"},{"start":387.55,"end":390.65,"text":"אלקרוני, את אפילו לא יודעת מה זה דיגיטלי"},{"start":390.65,"end":392.93,"text":"אלקני לא יודעת מה זה דיגיטלי?"},{"start":392.93,"end":393.49,"text":"נו"},{"start":393.49,"end":394.9,"text":"אלקני לא יודע"},{"start":394.9,"end":395.62,"text":"נו"},{"start":395.62,"end":396.63,"text":"נו מה זה?"},{"start":396.63,"end":398.69,"text":"את מפגרת זה, מה זה בסיסי?"},{"start":398.69,"end":402.22,"text":"דיגיטלי, זה נגיד את עולה במהלית עם חברה שלך טלי?"},{"start":402.22,"end":402.62,"text":"נו"},{"start":402.62,"end":404.52,"text":"ואת נורא ממהרת, אז את אומרת לה"},{"start":404.52,"end":406.27,"text":"מה שעה, תגידי טלי"},{"start":406.27,"end":408.08,"text":"אז זה זה"},{"start":408.08,"end":410.5,"text":"נכבשת קלנית ורקפת, זה זה"},{"start":410.5,"end":412.33,"text":"וואי, מאיפה הולך?"},{"start":412.41,"end":415.45,"text":"מטוב השעה, עכשיו תעבדי, תעבדי, תעבדי"},{"start":415.45,"end":416.5,"text":"נו תעבדי"},{"start":416.5,"end":418.6,"text":"נכבשת קלנית ורקפת"},{"start":418.6,"end":420.16,"text":"נגיד את הנולות ומעלית"},{"start":420.16,"end":422.35,"text":"קומה שנייה, אז הזה"},{"start":422.35,"end":425.29,"text":"פגרת, פגרת"},{"start":425.29,"end":427.0,"text":"אצלנו קפצי"},{"start":427.0,"end":429.15,"text":"זה מה זה פציסי?"},{"start":429.15,"end":430.45,"text":"וואי"},{"start":430.45,"end":433.25,"text":"לאחר שחיבר את מילות האמנון הלאומי"},{"start":433.25,"end":435.81,"text":"ישב נפתלי הרץ אימבר מול הפסנתר"},{"start":435.81,"end":438.05,"text":"וניסה למצוא לחן מתאים"},{"start":438.05,"end":441.89,"text":"קולות בלבב פנימה"},{"start":441.89,"end":445.93,"text":"לא, לא, לא, לא, לא, זה לא טוב, זה לא טוב"},{"start":445.93,"end":457.91,"text":"קולות בלבב פנימה"},{"start":457.91,"end":464.99,"text":"ילדים, שקס, יש לדרכס פה, קדימה, תסתלקו לי כאן, תסתלקו לי גינה אחרת"},{"start":464.99,"end":469.69,"text":"בוקשה וחייפה באמצע צורה, תצאו לי פה מהר"},{"start":469.69,"end":472.25,"text":"לאחר שהשתתקו הפרחכים הפושתקים"},{"start":472.25,"end":474.33,"text":"התיישב נפתלי אלמון הפסנתר"},{"start":474.33,"end":476.81,"text":"חדור גאווה לאומית ותחושת שליחות"},{"start":476.81,"end":480.77,"text":"והנה עלה במוחו רעיון נוסף"},{"start":480.77,"end":487.02,"text":"קולות בלבי בנימה, קולות בלבי בנימה."},{"start":512.26,"end":534.27,"text":"נפנייה!"},{"start":534.27,"end":553.05,"text":"יום שישי הגיע, יצאנו לחופשה. מתי נהיה בבית, רק אל ידע. ואי לי הבדה, ואי לי אני חרבד, ואי לי..."},{"start":553.05,"end":566.59,"text":"שקת מחלקה 2. זה מה שקשי מאוד באימונים. היה בסך הכל על הקפק. הם יוצאים הביתה עכשיו. שובעת שלום מחלקה 2."},{"start":567.59,"end":574.9,"text":"רגע, רגע, מחלקה 2. אף אחד לא זז, רגע. הממפה רוצה להגיד משהו. הממפה, בבקשה."},{"start":574.9,"end":578.21,"text":"אוקיי, מחלקה 2. לפני שאתם יוצאים, שימו לב."},{"start":578.21,"end":590.23,"text":"חם, אתם בטח תלכו לים. כל השבת יבלו בים. אני לא רוצה שתחזרו לי צרופים. אני מבקש לדאוג לכובע, משקפי שמש ושמן שיזוף."},{"start":590.23,"end":593.32,"text":"אוקיי, תהנו, זה מגיע לכם. שבת שלום."},{"start":593.32,"end":595.32,"text":"שבת שלום! רגע!"},{"start":595.32,"end":599.39,"text":"לאט, לאט, עצו שבת. סמך, יש לך מה להגיד."},{"start":600.51,"end":604.37,"text":"רק נזכיר! אתם יוצאים? מבלים!"},{"start":604.37,"end":606.78,"text":"מי פוגש בחורה? מי פוגש חבר'ה?"},{"start":606.78,"end":609.13,"text":"לא לשכוח, אמצעי זהירות."},{"start":609.13,"end":611.6,"text":"הכרתם מישהי? אתם עוד לא יודעים מי היא בדיוק?"},{"start":611.6,"end":616.95,"text":"קונדום! קונדום תמיד שמות בכיס מחלקה 2."},{"start":616.95,"end":619.85,"text":"בטיחות! שבת שלום מחלקה 2."},{"start":619.85,"end":620.85,"text":"שבת שלום, הפקד!"},{"start":620.85,"end":623.85,"text":"אופה, רגע, רגע, לאן אתם קמים?"},{"start":623.85,"end":629.35,"text":"לאט, לאט, עצו שבת. הממפה רוצה להגיד לכם משהו."},{"start":629.35,"end":633.35,"text":"לא! האמת שאין לי מה להגיד לכם, רק באמת לפני שאתם יוצאים דבר קטן."},{"start":633.35,"end":638.57,"text":"אז תפתח מגיעים הביתה עם כל האבק והזעה, תיכנסו לאיזה מקלח הטובה."},{"start":638.57,"end":644.6,"text":"מיד אחר כך תלכו לסלון, תתרווחו לכם בנחת באיזה קורצה, תשימו רגליים על השולחן מול הטלוויזיה,"},{"start":644.6,"end":647.57,"text":"מיד תיקחו תפוח ליד ותקלפו אותו."},{"start":647.57,"end":653.01,"text":"חבר'ה, זירות עם הסכין. זה מסוכן, אני לא רוצה שתחתכו את העצבות, תחזרו אליי פצועים, אה?"},{"start":653.01,"end":660.19,"text":"אז שיהיה לכם שבת שלום באמת, תיהנו. רגע, רגע, לאט, לאט, תצאו שבת."},{"start":660.19,"end":663.42,"text":"תמי, יש לך מה להגיד להם."},{"start":663.42,"end":672.54,"text":"מדרגות, מחלקה שתיים, הם עולים במדרגות הביתה."},{"start":672.54,"end":675.71,"text":"מי שגר ברב קומות, מי שגר בבית פרטי."},{"start":675.71,"end":678.93,"text":"להיזהר, מדרגות זה לא צחוק מחלקה שתיים."},{"start":678.93,"end":683.75,"text":"מי שלוקח מעלית, הלכת כמה וכמה. זהירות מחלקה שתיים."},{"start":683.75,"end":686.62,"text":"שבת שלום."},{"start":686.62,"end":690.85,"text":"רגע, רגע, רגע, מה בוער?"},{"start":690.85,"end":696.54,"text":"לאט לאט נצא שבת. הממפי, הם שלך כולם."},{"start":696.54,"end":702.06,"text":"אוקיי, מחלקה שתיים. אתם כבר יוצאים הבית, יש לכם שבת שלום, אבל לפני זה מחלקה שתיים."},{"start":702.06,"end":709.8,"text":"צבע טרי. הרבה בתים עושים עכשיו שיפוצים, אתם עלולים להתעכל באיזה קיר צבוע ולנחלכת המדים."},{"start":709.8,"end":715.07,"text":"התרחקו מקירות בעלי צבע טרי. שבת שלום לכם, מחלקה שתיים. רגע!"},{"start":715.07,"end":718.15,"text":"מחלקה שתיים, לאט לאט תצאו שבת. סמך."},{"start":718.15,"end":728.42,"text":"מחלקה שתיים, לגו. מי שבחר לשחק בלגו במהלך השבת, הוא טוב, וזה יפה."},{"start":728.42,"end":732.21,"text":"לא רוצה לראות אף אחד, לא רוצה לשמוע על אף אחד."},{"start":732.21,"end":738.65,"text":"נופזר חלקים, גונב חלקים מאחר קטן, לא שם הכל במקום, בדיוק איפה שזה היה קודם."},{"start":738.65,"end":741.77,"text":"דיר בלג בחלקה השתיים, דיר בלג."},{"start":741.77,"end":745.28,"text":"לאט, לאט, לצור שבת."},{"start":745.28,"end":756.28,"text":"שיתוף פעולה בין תוכנית החרצופים לקומדיסטור, לראשונה בטלוויזיה, בובות החרצופים בקטע קלאסי של הקומדיסטור."},{"start":756.28,"end":760.34,"text":"חיים טובים, חיים טובים!"},{"start":760.34,"end":771.34,"text":"יש לי, יש לי, יש לי! אנחנו עושים צחוק מהצחוקרות! לא! אנחנו עושים צחוק מהבכירות!"},{"start":771.34,"end":785.37,"text":"יש לי, יש לי, יש לי, יש לי, יש לי! אנחנו עושים צחוק מהפריים גבה! לא! אנחנו עושים צחוק מהפריים הריס!"},{"start":785.37,"end":794.37,"text":"יש לי, יש לי, יש לי, יש לי! אנחנו עושים צחוק מהבובה של הרב אובדיה!"},{"start":794.37,"end":805.61,"text":"יש לי, יש לי, יש לי, יש לי! אני כל צף! לא! אני חרצף!"},{"start":805.61,"end":813.5,"text":"יו, יו, חרצף, חרצף, חרצף, חרצף, חרצף!"},{"start":813.5,"end":825.01,"text":"רגע, רגע, לאט לאט, תרצו שבא!"},{"start":825.01,"end":827.64,"text":"תמך, יש לך מה להוסיף!"},{"start":827.64,"end":830.98,"text":"מחלקה שתיים!"},{"start":830.98,"end":832.2,"text":"היגואנה!"},{"start":832.2,"end":838.16,"text":"למי שיש היגואנה בבית ושמגדל חיית מחמד שכזו, להיזהר!"},{"start":838.16,"end":840.88,"text":"אומנם היא חיה נחמדה, חיה שקטה!"},{"start":840.88,"end":843.2,"text":"אבל מחלקה שתיים!"},{"start":843.2,"end":845.96,"text":"היגואנה עלולה להיות מסוכנת!"},{"start":845.96,"end":850.5,"text":"לא שמעתי על חייל מפלוגה אחרת שקיבל מכה מהזנף שלה!"},{"start":850.5,"end":855.12,"text":"לא מזמן ביקרנו בי חילוב, חייל שקיבל ביס מהיגואנה!"},{"start":855.12,"end":857.89,"text":"מי שיש לו היגואנה, להיזהר!"},{"start":857.89,"end":860.46,"text":"לבת שלום מחלקה שתיים!"},{"start":860.46,"end":862.43,"text":"מחלקה שתיים!"},{"start":862.43,"end":865.1,"text":"רגע! רגע!"},{"start":865.1,"end":867.65,"text":"מה קרה? לאט לאט עשו שבת!"},{"start":867.65,"end":870.68,"text":"הממפה עם הקשיים שלך!"},{"start":870.68,"end":873.48,"text":"מחלקה שתיים!"},{"start":873.48,"end":875.95,"text":"קלטות וידאו!"},{"start":875.95,"end":878.08,"text":"אתם באים להקליט בוידאו שימו לב!"},{"start":878.08,"end":880.46,"text":"יש את הלשונית הזאת על הקלטת!"},{"start":880.46,"end":882.52,"text":"אם אתם רוצים להקליט אתם חייבים לבדוק שהיא קיימת!"},{"start":882.52,"end":884.67,"text":"אחרת אי אפשר להקליט על הקלטת שום דבר!"},{"start":884.67,"end":887.15,"text":"אם אין לשונית פשוט לשים צלוטייפ על החור!"},{"start":887.15,"end":891.43,"text":"אוקיי, רק ככה תוכלו להקליט בוידאו הביתי שלכם!"},{"start":891.43,"end":893.84,"text":"שיהיה לכם שבת שלום החלקה!"},{"start":893.84,"end":894.97,"text":"רגע!"},{"start":894.97,"end":896.97,"text":"לאט לאט עטו שבת!"},{"start":896.97,"end":905.73,"text":"אתם הבאים לקליניקה של ד\"ר אריך פון שמוק!"},{"start":905.73,"end":908.01,"text":"מטפל מיני מוצמך!"},{"start":908.01,"end":909.01,"text":"משמוק!"},{"start":909.01,"end":910.0,"text":"קליני..."},{"start":910.0,"end":911.0,"text":"תחזוב אותו בעצם!"},{"start":911.0,"end":913.45,"text":"מה הבעיה של הפציינט?"},{"start":913.45,"end":915.45,"text":"הוא תזן טובה, תשחרר אותו מהשבדיות!"},{"start":915.45,"end":918.45,"text":"יש לו כל הזמן ברור שבדיות שבדיה!"},{"start":918.45,"end":919.45,"text":"שבדיות שבדיות!"},{"start":919.45,"end":921.45,"text":"שבדיות גדולות!"},{"start":921.45,"end":922.45,"text":"אתה רואה מה צריך תחזוב אותו בעיה?"},{"start":922.45,"end":923.45,"text":"אני מבין בהחד, אני מבין את."},{"start":923.45,"end":925.45,"text":"אתה שער בשרו?"},{"start":925.45,"end":927.41,"text":"איזה שער בשרו זה תחזוב אותו בעיה."},{"start":927.41,"end":929.57,"text":"אם כן, מה קרבטך לאדון?"},{"start":929.57,"end":931.57,"text":"אני... אני משורר שלי."},{"start":931.57,"end":933.57,"text":"זה שעול המשורר."},{"start":933.57,"end":935.57,"text":"אני מבין, אכן."},{"start":935.57,"end":937.57,"text":"אוקיי, שים לב אדון רחמים."},{"start":937.57,"end":940.6,"text":"האם הייתה לך בנעוריך איזושהי בעיה עם אבא?"},{"start":940.6,"end":941.89,"text":"אבא?"},{"start":941.89,"end":943.89,"text":"להקת אבא משוודיה."},{"start":943.89,"end":946.11,"text":"עם הבלונדי מיטינגה."},{"start":946.11,"end":948.13,"text":"מה את זה בקרי אבות זה?"},{"start":948.13,"end":950.13,"text":"אבא היה אכן אכן גרועה כמו שחשבתי."},{"start":950.13,"end":951.13,"text":"שים לב אדון רחמים."},{"start":951.13,"end":953.13,"text":"אני הולך להשתמש כאן במכשיר ההפנתה שלי."},{"start":953.13,"end":954.13,"text":"שים לב, כן?"},{"start":954.13,"end":955.48,"text":"שים לב."},{"start":955.48,"end":957.48,"text":"זהו שרשר ההפנוז."},{"start":957.48,"end":958.48,"text":"כן."},{"start":958.48,"end":960.48,"text":"אני הולך להוציא ממך את כל הפשיעות."},{"start":960.48,"end":961.48,"text":"כן."},{"start":961.48,"end":962.48,"text":"פושע תמים."},{"start":962.48,"end":964.48,"text":"פושע תמים."},{"start":964.48,"end":966.48,"text":"כשאני אומר לך סטוקולם אתה נרדם."},{"start":966.48,"end":967.48,"text":"סטוקולם פעזוב אותך."},{"start":967.48,"end":968.48,"text":"סטוקולם."},{"start":968.48,"end":971.4,"text":"פעם הרחמים יפה מאוד."},{"start":971.4,"end":972.46,"text":"שים לב."},{"start":972.46,"end":973.46,"text":"עכשיו שאתה תחת השפעה."},{"start":973.46,"end":974.46,"text":"תחת."},{"start":974.46,"end":975.46,"text":"שקט."},{"start":975.46,"end":977.55,"text":"תחת השפעת ההפנוזת."},{"start":977.55,"end":979.73,"text":"אתה שוכח מכל השווידיות שראית."},{"start":979.73,"end":981.8,"text":"מכל הדברים שחשבת עליהם בקרבת סטוקולם."},{"start":981.8,"end":985.02,"text":"אין יותר שווידיה אם היא מחכה מעל המפית."},{"start":985.02,"end":986.02,"text":"אין יותר שום דבר, אוקיי?"},{"start":986.02,"end":988.02,"text":"כשאני ספור שלוש, אתה מתעורר."},{"start":988.02,"end":989.18,"text":"שלוש."},{"start":989.18,"end":990.18,"text":"אלה."},{"start":990.18,"end":991.27,"text":"בבקשה, אדוני."},{"start":991.27,"end":994.03,"text":"אדון רחמים,"},{"start":994.03,"end":995.03,"text":"על מה אתה חושב עכשיו?"},{"start":995.03,"end":997.03,"text":"הולנדיות."},{"start":997.03,"end":999.57,"text":"הולנדיות גדולות."},{"start":999.57,"end":1000.89,"text":"אסיסיות."},{"start":1000.89,"end":1003.98,"text":"כן, אדון משורר, אז כשאתה רואה,"},{"start":1003.98,"end":1004.98,"text":"הניתוח הצליח."},{"start":1004.98,"end":1006.04,"text":"החולה אידיוט."},{"start":1006.04,"end":1008.63,"text":"תחזוק אותך בך."},{"start":1008.63,"end":1022.59,"text":"סליחה."},{"start":1022.59,"end":1024.93,"text":"יש לכם אולי פה,"},{"start":1024.93,"end":1027.02,"text":"הדבר הזה שבא ככה."},{"start":1027.02,"end":1030.37,"text":"אגול, אגול מאורח טיפה עם..."},{"start":1030.37,"end":1032.55,"text":"עיגול בקצה, עיגול בקצה."},{"start":1032.55,"end":1033.8,"text":"כזה? רבס כזה?"},{"start":1033.8,"end":1034.8,"text":"לא, לא, לא, לא."},{"start":1034.8,"end":1037.92,"text":"ארוך, ארוך, עיגול בקצה עם פסים."},{"start":1037.92,"end":1038.92,"text":"פסים ירוק בפנים, ירוק."},{"start":1038.92,"end":1040.67,"text":"ירוק."},{"start":1040.67,"end":1042.19,"text":"איזה, אתה מדבר על כזה דבר?"},{"start":1042.19,"end":1044.31,"text":"לא, מה פתאום, זה בא ככה."},{"start":1044.31,"end":1046.31,"text":"הופ, הופ, אליפטי בקצה עם זרבודלים."},{"start":1046.31,"end":1049.31,"text":"זרבודלים קטנים, הופ, פס, פס, פס, ירופ."},{"start":1049.31,"end":1050.31,"text":"הופה, הופה, הם כאלה, פומים."},{"start":1050.31,"end":1054.74,"text":"סגע, זה עם הזרבודלים."},{"start":1054.74,"end":1057.74,"text":"לא, זה שרבודלים אקספיילס, אני לבד לך לקטנים."},{"start":1057.74,"end":1059.74,"text":"לא, לא, הקצה יותר, אקספיילס, יותר בא לך."},{"start":1059.74,"end":1063.01,"text":"גול, גול, פסים, פסים, נמשים."},{"start":1063.01,"end":1067.52,"text":"הבנתי, הבנתי, הנה, בבקשה."},{"start":1067.52,"end":1070.81,"text":"זה בן את אקספיילס, זה אקספיילס קטרים, נו."},{"start":1070.81,"end":1072.81,"text":"הבן שלי אוכל את זה, לא כזה, תימלם טוב."},{"start":1072.81,"end":1077.79,"text":"בא לך, הופ, שבוט, נמשים, עזק, עזק, הוא עולה לך למעלה, למעלה."},{"start":1077.79,"end":1079.79,"text":"אלה, עם הקטנים, נמשים."},{"start":1079.79,"end":1082.79,"text":"לא, זה, תגיד לי אתה איש מקצוע."},{"start":1082.79,"end":1084.79,"text":"איש מקצוע, לא מבין אותך, מה קרה?"},{"start":1084.79,"end":1086.79,"text":"לא כזה, אין פה מישהו שיודע בהם, הם מגניבים לדבר, לא?"},{"start":1086.79,"end":1090.72,"text":"שנייה, שנייה, שנייה, אתה יכול להיות, יכול להיות שהוא מנסה בעצם להגיד לך שהוא רוצה"},{"start":1090.72,"end":1092.98,"text":"צ'וע, צ'וע, צ'וע."},{"start":1092.98,"end":1095.98,"text":"אז למה הוא לא אומר, אתה רוצה את האלה עם הצ'וע, צ'וע."},{"start":1095.98,"end":1097.98,"text":"לא רוצה צ'וע, צ'וע, צ'וע, לא, לא."},{"start":1097.98,"end":1099.98,"text":"לא צ'וע, אמרתי, אופ, אופ, גם עוד אימט."},{"start":1099.98,"end":1101.07,"text":"זה, זה, זה."},{"start":1101.07,"end":1104.07,"text":"לא מבין אותך, אדוני, לא מבין, יש פה קליאנטים, רגע."},{"start":1104.07,"end":1106.07,"text":"אה, אין פה שקליאנטים קבועים."},{"start":1106.07,"end":1108.07,"text":"מה בעיה, אבלר, מה אתה צריך?"},{"start":1108.07,"end":1109.07,"text":"יש לך אולי כמה חתיכות של..."},{"start":1109.07,"end":1114.07,"text":"יש לך כמה חתיכות כאלה?"},{"start":1114.07,"end":1116.07,"text":"במקרה נשאר לי אחרון מתוק."},{"start":1116.07,"end":1117.51,"text":"תודה רבה."},{"start":1117.51,"end":1119.47,"text":"נרשום לך."},{"start":1119.47,"end":1122.11,"text":"תודה רבה."},{"start":1122.11,"end":1123.45,"text":"כן."},{"start":1123.45,"end":1125.41,"text":"ספציפית, מה אתה מחפה?"},{"start":1125.41,"end":1126.41,"text":"שים לב טוב עכשיו."},{"start":1126.41,"end":1127.46,"text":"כן, כן."},{"start":1127.46,"end":1128.5,"text":"זה בא כזה?"},{"start":1128.5,"end":1130.63,"text":"מין מעוגל, מעוגל."},{"start":1130.63,"end":1132.63,"text":"עם זאת פה, זאת, זאת."},{"start":1132.63,"end":1134.65,"text":"הולך, עם על הרשוט, כשחבודלים, ומשקפיים."},{"start":1134.65,"end":1139.46,"text":"רח, כזה."},{"start":1139.46,"end":1140.46,"text":"זה אני צריך."},{"start":1140.46,"end":1142.09,"text":"בא לך למעלה?"},{"start":1142.09,"end":1143.09,"text":"שחבודלים?"},{"start":1143.09,"end":1144.39,"text":"זאת, זאת, מושקפיים?"},{"start":1144.39,"end":1145.79,"text":"אה, צריך כזה."},{"start":1145.79,"end":1146.76,"text":"כזה, הנה, זה אני צריך, תודה."},{"start":1146.76,"end":1148.76,"text":"רגע, רגע, רגע, זה נגמר."},{"start":1148.76,"end":1149.76,"text":"זה נגמר, אדוני, זה נגמר."},{"start":1149.76,"end":1150.76,"text":"זה אחרון שיש."},{"start":1150.76,"end":1153.97,"text":"דינו-זאורים."},{"start":1153.97,"end":1160.04,"text":"הם יוצאים לבלות, שבת, בוקר, חק הטבע, תמורות טבע."},{"start":1160.04,"end":1163.77,"text":"אתם פוגשים דינו-זאור, לא רוצה לשמוע על אף אחד"},{"start":1163.77,"end":1165.77,"text":"שמעיז להתנקל לחיה הזאת."},{"start":1165.77,"end":1169.49,"text":"זאת חיה מוגנת, תנו צ'אנס לחיה הזאת."},{"start":1169.49,"end":1171.49,"text":"שבת שלום, מחלקה שתיים."},{"start":1171.49,"end":1172.41,"text":"רגע!"},{"start":1172.41,"end":1174.9,"text":"לסיכור, מחלקה שתיים."},{"start":1174.9,"end":1178.65,"text":"שאלות."},{"start":1178.65,"end":1180.28,"text":"שאלות."},{"start":1180.28,"end":1181.91,"text":"אין שאלות."},{"start":1181.91,"end":1186.19,"text":"או שהכל ברור, או שהכל לא ברור, מחלקה שתיים."},{"start":1186.19,"end":1188.19,"text":"מי ראה לי שהכל ברור לכם."},{"start":1188.19,"end":1192.76,"text":"סימן שהכל לא ברור לכם, מחלקה שתיים."},{"start":1192.76,"end":1196.73,"text":"בוא נממפה, ואם הכל לא ברור לכם, מחלקה שתיים,"},{"start":1196.73,"end":1201.61,"text":"אז הממפה, אולי כדאי שנתחיל הכל מההתחלה."},{"start":1201.61,"end":1203.05,"text":"אין לי בעיה."},{"start":1203.05,"end":1205.46,"text":"שימו לב, מחלקה שתיים."},{"start":1205.46,"end":1210.47,"text":"לאט לאט תשו שבת"}]