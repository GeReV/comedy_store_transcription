[{"start":29.22,"end":34.41,"text":"רבותיי, ברוכים הבאים לקום ומסתור!"},{"start":34.41,"end":44.8,"text":"אתה בקיר כעס?"},{"start":44.8,"end":46.02,"text":"מה ההטרקציה שלך?"},{"start":46.02,"end":49.02,"text":"אני פשוט לוקח את הלבנה הזאת, שם על הראש,"},{"start":49.02,"end":53.17,"text":"ועם הפטיש אני מנפצ את הלבנה על הראש שלי."},{"start":53.17,"end":54.17,"text":"הידר!"},{"start":54.17,"end":55.16,"text":"מה יש לך בתיק?"},{"start":55.16,"end":56.8,"text":"אספירין."},{"start":56.8,"end":86.34,"text":"תלמידים, סליחה!"},{"start":86.34,"end":90.14,"text":"בוקר טוב, תלמידים!"},{"start":90.14,"end":91.17,"text":"בוקר!"},{"start":91.17,"end":96.22,"text":"שימו לב, מה שנעשה היום,"},{"start":96.22,"end":99.22,"text":"אנחנו נלמד לשנן משפטים חשובים"},{"start":99.22,"end":102.41,"text":"עד שתדעו אותם בעל פה"},{"start":102.41,"end":103.41,"text":"אני אומרת משפט"},{"start":103.41,"end":104.41,"text":"ואתם חוזרים אחריי"},{"start":104.41,"end":105.47,"text":"ברור?"},{"start":105.47,"end":108.29,"text":"ברור!"},{"start":108.29,"end":109.77,"text":"ובכן, נתחיל"},{"start":109.77,"end":111.77,"text":"סכום הזוויות במשולש"},{"start":111.77,"end":113.8,"text":"הוא 180 מעלות"},{"start":113.8,"end":114.8,"text":"בבקשה"},{"start":114.8,"end":117.02,"text":"סכום הזוויות במשולש"},{"start":117.02,"end":119.34,"text":"הוא 180 מעלות"},{"start":119.34,"end":122.95,"text":"שטח מעגל הוא פי ארבע ריבוע"},{"start":122.95,"end":125.95,"text":"שטח מעגל הוא פי ארבע ריבוע"},{"start":125.95,"end":129.92,"text":"אם תרצו, אין זו אגדה"},{"start":129.92,"end":132.99,"text":"אם תרצו, אין זו אגדה"},{"start":132.99,"end":135.09,"text":"אם אין קמח, אין תורה"},{"start":135.09,"end":138.09,"text":"אם אין קמח, אין תורה"},{"start":138.09,"end":143.3,"text":"מי שאוכל לבד, יעמות לבד"},{"start":143.3,"end":146.67,"text":"מי שאוכל לבד, יעמות"},{"start":146.67,"end":157.2,"text":"בגדי בגדי קטן"},{"start":157.2,"end":159.2,"text":"אל המיין"},{"start":159.2,"end":165.02,"text":"ליברפול באנגליה, ברשבה בישראל"},{"start":165.02,"end":171.38,"text":"ליברפול באנגליה, ברשבה בישראל"},{"start":171.38,"end":207.24,"text":"בובי נאמר, בוקר טוב למנהיל"},{"start":207.24,"end":210.09,"text":"בוקר טוב"},{"start":210.09,"end":212.86,"text":"מה קורה פה? כיתה חץ 2"},{"start":212.86,"end":217.01,"text":"את יכולה להסביר לי מה קורה פה? המורה נחמה"},{"start":217.01,"end":220.01,"text":"אנחנו משתעשיים סיום חברה"},{"start":220.01,"end":224.01,"text":"תמי לי את הכדור בבקשה, המורה נחמה"},{"start":224.01,"end":226.71,"text":"לא ככה, לראש"},{"start":226.71,"end":229.38,"text":"יופי, עוד פעם"},{"start":229.38,"end":241.48,"text":"עוד פעם"},{"start":242.48,"end":251.32,"text":"תגידו"},{"start":251.32,"end":253.32,"text":"תגידו"},{"start":253.32,"end":255.32,"text":"תגידו"},{"start":255.32,"end":285.44,"text":"תגידו"},{"start":285.44,"end":287.44,"text":"תגידו"},{"start":287.44,"end":289.5,"text":"תגידו"},{"start":289.5,"end":291.72,"text":"תגידו"},{"start":291.72,"end":293.72,"text":"תגידו"},{"start":293.72,"end":299.84,"text":"תגידו"},{"start":299.84,"end":305.41,"text":"ואל קומדיה? לא, ואל דראמה. דראמה, דראמה."},{"start":305.41,"end":307.41,"text":"לא, דראמה, דראמה."},{"start":307.41,"end":311.75,"text":"יש לי, יש לי, יש לי, יש לי. תגידו."},{"start":311.75,"end":315.3,"text":"ציצי זראטה? לא, זופי זראטה."},{"start":315.3,"end":317.3,"text":"זופי זראטה."},{"start":317.3,"end":318.24,"text":"זופי זראטה."},{"start":318.24,"end":324.54,"text":"יש לי, יש לי, יש לי, יש."},{"start":324.54,"end":329.36,"text":"הלו, זה בלוםפילד. לא, זה בלוםשטיין."},{"start":329.36,"end":340.1,"text":"קח, קח, תעלי על אזרחי, אולי זה יעזור לך."},{"start":340.1,"end":342.1,"text":"קח, קח, קח, תתלבש."},{"start":342.1,"end":351.11,"text":"ערב צח ושלום לכולם."},{"start":351.11,"end":356.26,"text":"והפעם רציתי להתייחס לנקודה הכואבת, משחקי המונדיל."},{"start":356.26,"end":363.14,"text":"למה נבחרת ישראל, הצולה תמזרובה והלפלפית, לא הגיעה למשחקים?"},{"start":363.14,"end":365.45,"text":"בגלל חוסר מחשבה."},{"start":365.45,"end":369.61,"text":"ורותיי ורבותיי, אני פונה לכל ראשי ההתאחדות, בושו."},{"start":369.61,"end":373.2,"text":"מה שצריך לעשות, רבותיי, זה מאוד פשוט."},{"start":373.2,"end":375.26,"text":"חייבים לעבוד לפי תקטיקה."},{"start":375.26,"end":378.75,"text":"התקטיקה היא לקלמן, שימו לב."},{"start":378.75,"end":380.66,"text":"להוריד את הרמה באירופה."},{"start":380.66,"end":381.84,"text":"איך נעשה את זה?"},{"start":381.84,"end":383.93,"text":"נשלח שחקנים שיסחקו שם."},{"start":383.93,"end":385.93,"text":"כולם שיסחקו באירופה."},{"start":385.93,"end":388.93,"text":"ולא רק טלבנין וגוזי גוזנטל."},{"start":388.93,"end":389.93,"text":"לא, עוד."},{"start":389.93,"end":391.93,"text":"כולם שירחו, כל המכוערים."},{"start":391.93,"end":392.96,"text":"כולם ביחד שיסחו."},{"start":392.96,"end":395.96,"text":"בוני גינסבורג, גלפלפון, שיסה."},{"start":395.96,"end":397.96,"text":"שלא ימרח קרמים וייסה."},{"start":397.96,"end":398.96,"text":"אוי, תוקעו לי גול."},{"start":398.96,"end":399.96,"text":"שיסה."},{"start":399.96,"end":401.96,"text":"שיתעמנ בחול."},{"start":401.96,"end":402.96,"text":"שזוהבייסה."},{"start":402.96,"end":404.96,"text":"שביטו ניסה."},{"start":404.96,"end":406.96,"text":"אור שדריקססן שנמנים."},{"start":406.96,"end":407.96,"text":"שכולם יסחו."},{"start":407.96,"end":409.96,"text":"ילמדו ויורידו את הרבה באירופה."},{"start":409.96,"end":411.87,"text":"ואז שהרבה תרד."},{"start":411.87,"end":412.99,"text":"אנחנו נבשלים."},{"start":412.99,"end":415.15,"text":"אנחנו שגדלנו על קוסקוס."},{"start":415.15,"end":416.31,"text":"על מופלטה."},{"start":416.31,"end":418.43,"text":"על מטורנה."},{"start":418.43,"end":420.43,"text":"כל תינוק אצלנו מקבל מטורנה."},{"start":420.43,"end":422.49,"text":"ואז נהיה בריאים וחזקים."},{"start":422.49,"end":425.61,"text":"נבוא למונדי לחוש הקשוקה."},{"start":425.61,"end":426.61,"text":"עם כבוד."},{"start":426.61,"end":427.61,"text":"עם גאווה."},{"start":427.61,"end":429.61,"text":"עם דגל ישראל מתנפנף."},{"start":429.61,"end":431.92,"text":"ואז שאנחנו נכנסים למגרש."},{"start":431.92,"end":434.24,"text":"אימא נראה שם בטעות."},{"start":434.24,"end":436.71,"text":"אימא נראה שם בטעות."},{"start":436.71,"end":438.71,"text":"ועם אימא שלי את אבי רצון."},{"start":438.71,"end":441.41,"text":"או את גרטל הלפלף."},{"start":441.41,"end":445.44,"text":"או את יהודה סנפירי הקוקיה."},{"start":445.44,"end":449.44,"text":"או כל אחד זוהר בעלול יוסי תעלול ויוסי בקלאווה."},{"start":449.44,"end":451.44,"text":"אם אני ראה אחד מהשדרנים האלה באימא שלי,"},{"start":451.44,"end":455.44,"text":"כרטיס אדום, רסיה בפנים וכף הכפולה."},{"start":455.44,"end":460.19,"text":"ערב טוב לכם."},{"start":460.19,"end":462.19,"text":"ושוב אני בתוכניתנו זהה את המומחה."},{"start":462.19,"end":466.19,"text":"והפעם על המומחה לזהות חפת שנמצא בידי."},{"start":466.19,"end":472.09,"text":"השם של החפת מופיע לפניכם."},{"start":472.09,"end":480.42,"text":"אנו ניגש למומחה שלנו מר שרלוק הומלס ונבקש ממנו לזהות מהו החפת."},{"start":480.42,"end":482.83,"text":"שלום לך מר הומלס."},{"start":482.83,"end":489.25,"text":"בידי נמצא חפת וכבי שידוע לך כללי המשחק הם שעליך לזהות את החפת מבלי לראותו."},{"start":489.25,"end":490.78,"text":"מהו החפת?"},{"start":490.78,"end":501.97,"text":"ובכן לפי הננוחות שאתה קופץ בה את ידך אני מניח שמדובר בחפת עגול."},{"start":501.97,"end":503.22,"text":"האם הוא מדהים?"},{"start":503.22,"end":514.77,"text":"לפי השקערוית הכלילה באצבעך האמצעית אני מניח שהחפץ הוא בעל חור באמצעיתו זאת אומרת בעל מבנה הדומה לטבעת."},{"start":514.77,"end":519.24,"text":"הוא עולה על זה."},{"start":519.24,"end":529.06,"text":"לפי מידת ההידוק של קצות אצבעותיך אל פרק כף ידך אני מניח שמדובר בחפץ העשוי מחומרך הייתי מהמר על אילו."},{"start":529.06,"end":532.61,"text":"לא סתם קראו לו בלש."},{"start":532.61,"end":545.01,"text":"לפי הברק המוזר שבישוני עיניך אני מניח שלחפץ יש צבע כהה הייתי אומר שחור."},{"start":545.01,"end":553.68,"text":"ובכן החפץ הוא בעל מבנית הבעתי העשוי מיג ומשחור."},{"start":553.68,"end":561.71,"text":"אין ספק שמדובר בסמיג של מסעית."},{"start":561.71,"end":616.1,"text":"השפן הקטן שכח לסגור הדלת."},{"start":616.1,"end":620.1,"text":"הצטנן המסכן וקיבל נזלת."},{"start":620.1,"end":621.1,"text":"דה-לה-לה."},{"start":621.1,"end":626.74,"text":"היום הייתה לי יום הולדת והייתי חולה"},{"start":626.74,"end":631.98,"text":"ונשארתי לבד בבית ושמעתי אביו גפן."},{"start":631.98,"end":633.68,"text":"ואני לא מבין."},{"start":633.68,"end":636.64,"text":"כולם אוהבים את אביו גפן, אוהבים, אוהבים, אוהבים."},{"start":636.64,"end":638.64,"text":"אבל הוא מכוער."},{"start":638.64,"end":640.64,"text":"הוא מכוער גדול."},{"start":640.64,"end":642.64,"text":"יש לו רווח בשיניים עם שיער ירוק"},{"start":642.64,"end":644.64,"text":"ואנשים מתאבדים בכללו."},{"start":644.64,"end":646.64,"text":"זה אני ממש לא מבין."},{"start":646.64,"end":648.64,"text":"איך אפשר להתאבד בגלל אביו גפן?"},{"start":648.64,"end":653.64,"text":"אפילו הסולן של נרוונה הוא התאבד כי הוא שמע אביו גפן, כן?"},{"start":653.64,"end":654.64,"text":"ולי לא אכפת."},{"start":654.64,"end":657.64,"text":"אני גם ניסיתי כמה פעמים להתאבד."},{"start":657.64,"end":658.64,"text":"עובדה זכותי."},{"start":658.64,"end":660.64,"text":"אבל לא בגלל אביו גפן."},{"start":660.64,"end":662.12,"text":"בגלל רוני אדידיה."},{"start":662.12,"end":664.25,"text":"בגלל הקולובר חביבי."},{"start":664.25,"end":666.25,"text":"בגלל אם ניסיתי להתאבד."},{"start":666.25,"end":667.25,"text":"וחמי רודנר."},{"start":667.25,"end":669.25,"text":"איזה פה גדול יש לו."},{"start":669.25,"end":671.24,"text":"פה גדול גדול."},{"start":671.24,"end":672.2,"text":"ואתם יודעים איפה הילד?"},{"start":672.2,"end":673.2,"text":"אני גיליתי."},{"start":673.2,"end":674.2,"text":"חמי רודנר."},{"start":674.2,"end":676.2,"text":"הוא בלה אותו עם המפה שלו."},{"start":676.2,"end":678.2,"text":"והוא מופיע בפסטיבל הרד."},{"start":678.2,"end":681.2,"text":"ואל הרד וזה מסוכן שאתם הולכים לפסטיבל."},{"start":681.2,"end":684.45,"text":"תיזהרו שהוא לא הבלה אתכם."},{"start":684.45,"end":686.45,"text":"אמא, אני לא רוצה לדבר יותר."},{"start":686.45,"end":689.7,"text":"זה מפחיד אותי והפה שלי ברשותי."},{"start":689.7,"end":691.7,"text":"סטופ כדור הארץ, נגעתי באדום יבן,"},{"start":691.7,"end":692.7,"text":"זולל אבטיחים, זורחת השמש."},{"start":692.7,"end":694.7,"text":"עניין לניין לניין, היא בוכה משתך."},{"start":694.7,"end":696.7,"text":"גזגזגז, מתרגשת עמות הבן מהקבר שנעצר."},{"start":696.7,"end":698.7,"text":"אה, רואה לך דמה נעליים, נפל לך השכל,"},{"start":698.7,"end":701.7,"text":"שתבלה מטריה ותפתח לך אמן בפנים."},{"start":701.7,"end":704.51,"text":"לא, לך!"},{"start":704.51,"end":707.42,"text":"אופשי! אופשי! אופשי!"},{"start":707.42,"end":707.52,"text":"אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופשי! אופ"},{"start":707.42,"end":709.42,"text":"אני מרחל נבדל!"},{"start":709.42,"end":712.0,"text":"אני מרחל נבדל!"},{"start":712.0,"end":714.8,"text":"מה יאפסד ברור!"},{"start":714.8,"end":716.83,"text":"מה יאפסד ברור!"},{"start":716.83,"end":719.85,"text":"מה יאפסד ברור!"},{"start":719.85,"end":721.85,"text":"לא יאפסד ברור!"},{"start":721.85,"end":723.85,"text":"נבדל!"},{"start":723.85,"end":726.1,"text":"רוני רוזנגשם!"},{"start":726.1,"end":727.35,"text":"לא!"},{"start":727.35,"end":728.35,"text":"רוני רוזנטל!"},{"start":728.35,"end":730.35,"text":"רוזנטל!"},{"start":730.35,"end":732.35,"text":"חלילי!"},{"start":732.35,"end":733.35,"text":"חלילי!"},{"start":733.35,"end":734.35,"text":"יש לי!"},{"start":734.35,"end":735.35,"text":"גבר, יש לי!"},{"start":735.35,"end":737.45,"text":"תשמע, תשמע!"},{"start":737.45,"end":785.73,"text":"אורי מלעני, לא אורי מלמליאן - אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! א"},{"start":785.73,"end":790.82,"text":"הם חתיכים. אמרתי חתיכים, איזה שובבה אני."},{"start":790.82,"end":794.82,"text":"אבל תראי, זה לא... אני אוהבת את הניגרים."},{"start":794.82,"end":798.97,"text":"אז נכון שהם שוורצה, אבל אני לא צריכה להתחתן איתם."},{"start":798.97,"end":802.97,"text":"אני בסך הכל אוהבת את המערך משחק שלהם, שתיים, שתיים, ארבע."},{"start":802.97,"end":804.87,"text":"נורא נחמד. זה הכל."},{"start":804.87,"end":809.94,"text":"אבל במחשבה שנייה, למה בעצם נבחרת פולין לא משחקת השנה?"},{"start":809.94,"end":812.19,"text":"אני אוהבת את פולין."},{"start":812.19,"end":813.16,"text":"אהה, פולין."},{"start":815.39,"end":820.04,"text":"אני מקווה שנהנתם, ויש לי אבטה קטנה."},{"start":820.04,"end":823.96,"text":"איתי רוצה להזמין כישרון מקומי של מועדון הזמר את יעקב פינקוס."},{"start":823.96,"end":825.12,"text":"רבה."},{"start":825.12,"end":828.43,"text":"יעקב, יעקב, כן."},{"start":828.43,"end":829.43,"text":"רבה רבה."},{"start":829.43,"end":833.43,"text":"יעקב, תשים לב שיש לנו כאן ילדים, אז טיפה, תצנזר את העניינים."},{"start":833.43,"end":834.43,"text":"אין בעיה."},{"start":834.43,"end":835.43,"text":"סומך עליך."},{"start":835.43,"end":838.81,"text":"יעקב, יעקב, יעקב, יעקב."},{"start":838.81,"end":842.84,"text":"למה טו לזיינטו?"},{"start":842.84,"end":845.8,"text":"למה טו לקוסטו?"},{"start":845.8,"end":848.87,"text":"למה יש לשד נפוח?"},{"start":848.87,"end":852.87,"text":"וגם טו טו אדמדם."},{"start":852.87,"end":855.84,"text":"כשהטו טו טו צופרת,"},{"start":855.84,"end":859.84,"text":"זה סימן שמפליטו."},{"start":859.84,"end":863.19,"text":"כשהבטן טו טו טו טו,"},{"start":863.19,"end":867.29,"text":"זה סיתו שמי זה די, אני מבטח."},{"start":867.29,"end":874.64,"text":"ילבינטו! ילבינטו!"},{"start":874.64,"end":876.9,"text":"אדרן!"},{"start":876.9,"end":879.19,"text":"תודה רבה, תודה רבה."},{"start":879.19,"end":894.19,"text":"תודה רבה, תודה רבה."},{"start":894.19,"end":897.57,"text":"גדול, גדול, גדול."},{"start":897.57,"end":903.2,"text":"עיריית תל אביב יפו מגישה קייטנה בכל פינה."},{"start":903.2,"end":904.83,"text":"מי אנחנו?"},{"start":904.83,"end":907.83,"text":"קייטנה תרלו זורו פינה דבן."},{"start":907.83,"end":908.83,"text":"לא שומעים."},{"start":908.83,"end":910.83,"text":"קייטנה תרלו זורו פינה דבן."},{"start":910.83,"end":914.83,"text":"לא שומעים."},{"start":914.83,"end":915.83,"text":"קייטנה תרלו זורו פינה דבן."},{"start":915.83,"end":918.83,"text":"מי הכי הכי טוב?"},{"start":918.83,"end":921.83,"text":"קייטנה תרלו זורו פינה דבן."},{"start":921.83,"end":925.83,"text":"מי שעולה תמיד ברחוב?"},{"start":925.83,"end":927.83,"text":"קייטנה דבן."},{"start":927.83,"end":929.83,"text":"פינה דבן."},{"start":929.83,"end":931.83,"text":"מי הכי הכי מקביץ?"},{"start":931.83,"end":935.83,"text":"קייטנה תיהודה מקביב פינה דבן כתוביץ."},{"start":935.83,"end":937.83,"text":"הכל עובר יהיה חביבי."},{"start":937.83,"end":939.83,"text":"קייטנה דבן כתוביץ."},{"start":939.83,"end":941.83,"text":"פינת יהודה מקביב."},{"start":941.83,"end":945.83,"text":"ילדי קייטנת יהודה מקביב פינת וידת כתוביץ."},{"start":945.83,"end":950.83,"text":"מי שרוצה לחמניה ושוקו שישב יפה."},{"start":950.83,"end":954.83,"text":"ילדי קייטנת ויצמן פינת זיכרון יעקב."},{"start":954.83,"end":957.82,"text":"לקום על הרגליים ולהסתדר בזוגות."},{"start":957.82,"end":960.91,"text":"אנחנו יוצאים לטיול."},{"start":960.91,"end":963.0,"text":"קדימה אחריי."},{"start":963.0,"end":972.49,"text":"הגבייה הוא שלנו, הגבייה הוא שלנו, הגבייה הוא שלנו."},{"start":972.49,"end":991.94,"text":"אבי, חטאתי. אבי, חטאתי. אבי, למה אתה לא מדבר אליי?"},{"start":991.94,"end":1005.68,"text":"וואו, אבי. יו. גדול אבי, יו. לא ידעתי."},{"start":1005.68,"end":1009.8,"text":"וואו, וואו. אבי, ברך אותי עכשיו."},{"start":1009.8,"end":1052.92,"text":"שלום. כן. אתה מנהל הקרקס. במה די? אני רוצה לעבוד אצלכם להופיע בקרקס. זה אפשרי. אפשרי אבל מה האטרקציה שלך? אז ככה אני תראה אני יודע כרוך טוב בחמש שפות לפחות. זה גם אני יודע. תראה אני גם יודע."},{"start":1052.92,"end":1056.3,"text":"אה, תראה, אני גם יודע להתפיס במכונת כתיבה, אני למדתי קצרנות."},{"start":1056.3,"end":1057.12,"text":"זה גם אשתי יודעת."},{"start":1057.12,"end":1060.06,"text":"אה, תראה, יש לי ניסיון לא מבוטל במחשבים וכן."},{"start":1060.06,"end":1061.12,"text":"זה גם הבן שלי יודע."},{"start":1061.12,"end":1063.5,"text":"תראה, יש לי רישיון ניגל מסעית, זה יתרון, אני חושב."},{"start":1063.5,"end":1065.34,"text":"זה לא מעניין, מה האטרקציה שלך, אדוני, אין לי זמן."},{"start":1065.34,"end":1067.38,"text":"תראה, אני יודע לדקלם גם את שייקספיר מלטר."},{"start":1067.38,"end":1068.96,"text":"זה לא מעניין, מה האטרקציה?"},{"start":1068.96,"end":1070.36,"text":"אני יודע להשיר את השירים שלום משמר."},{"start":1070.36,"end":1071.72,"text":"וחייח, זה גם אני יודע."},{"start":1071.72,"end":1075.14,"text":"אני יודע לרקוד בחמישים סגנונות שונים, זרוק סגנון אני רוקד אותו."},{"start":1075.14,"end":1076.64,"text":"זה גם דף הירקון יודעת, כן?"},{"start":1076.64,"end":1079.22,"text":"תראה, אני יודע לפשל משהו מצוין."},{"start":1079.22,"end":1081.15,"text":"זה לא מעניין, עוד נאה לי זמן להתראות."},{"start":1081.15,"end":1083.04,"text":"שלום, שלום, אדוני."},{"start":1083.04,"end":1087.82,"text":"יאללה, בן אדם, תן לי גמור לדבר."},{"start":1087.82,"end":1099.73,"text":"ערב צח, ואני חייב עוד כמה מילים קטנות בקשר למונדל הזה שמשגע אותנו."},{"start":1099.73,"end":1102.33,"text":"ובכן, החלסטרה שלי היא לא על המונדל."},{"start":1102.33,"end":1104.93,"text":"היא למד דווקא עשוי את המונדל באמריקה."},{"start":1105.04,"end":1108.16,"text":"בשביל מה? כולם לאפלפים שם. הם לא מבינים."},{"start":1108.16,"end":1112.12,"text":"זה כאלה לאפלפים כאלה שואבים לקחת נקניקיות ולאכול המבורגנד."},{"start":1112.12,"end":1113.76,"text":"זה כאלה לאפלפים כאלה, אה?"},{"start":1113.76,"end":1116.71,"text":"הם באים למשחק: \"היי, אסופט שגע!"},{"start":1116.71,"end":1119.04,"text":"היי, היי, אסופט טועה!\""},{"start":1119.04,"end":1120.84,"text":"מה זה, אחרת זה?"},{"start":1120.84,"end":1124.1,"text":"במשחק כדורגל חייב לפצח גרעינים."},{"start":1124.1,"end":1127.55,"text":"חייב לתפוס את הגרעין בעדינות, להביא לו..."},{"start":1127.55,"end":1131.24,"text":"ופי! שבע קומות למטה, ושבבה!"},{"start":1131.24,"end":1133.6,"text":"כולם נהלים כל העורף של כולם מלא עם גרעינים."},{"start":1133.6,"end":1135.24,"text":"רק ככה אתה מוולה במשחק."},{"start":1135.24,"end":1137.44,"text":"אחרת מטה נהנה מהמשחק, אין מה לראות."},{"start":1137.44,"end":1139.56,"text":"התביס לראות שם, כולם בכוערים, באמא שלי."},{"start":1139.56,"end":1142.76,"text":"מה יש לך לראות? את ולדרמה? ראיתם את הצפורת שלו?"},{"start":1142.76,"end":1144.36,"text":"באמא שלי, זה פרסומת לליפה."},{"start":1144.36,"end":1146.4,"text":"מה זה הדבר הזה? בקזה דבר."},{"start":1146.4,"end":1149.12,"text":"השער שלו עולה, באמא שלי זה שמש. זה לא שער."},{"start":1149.12,"end":1151.84,"text":"באמא שלי, יש לו חור באוזום. מה זה החרט הזה?"},{"start":1151.84,"end":1154.04,"text":"זה פרסומת של בנק מזרחי, יש לו כזה שמש."},{"start":1154.04,"end":1156.84,"text":"מעניין אם זה הראש שלו, מה יש לו בבית שחי באמא שלי?"},{"start":1156.84,"end":1158.76,"text":"בטח נופלים לא עציתים."},{"start":1158.76,"end":1162.89,"text":"ולשיום, ורותיי ורבותיי, עזקיתו ושמעו."},{"start":1162.89,"end":1167.49,"text":"אם אישה בא אליך ומתחילה לעשות לך, אני רוצה לראות אנטונאללה,"},{"start":1167.49,"end":1170.71,"text":"אני רוצה לראות כל מיני חרטוותי, שים לב."},{"start":1170.71,"end":1173.86,"text":"תגיד לה, זה לא מונדל, זה צ'יפנדל."},{"start":1173.86,"end":1176.58,"text":"במקום יהיו שבעות שעות עם פיצוכים איתך,"},{"start":1176.58,"end":1179.58,"text":"שבע שעות עם אהבת יאם, חכה שבי שוב המשחק הם יורידו טוב גדים."},{"start":1179.58,"end":1182.82,"text":"בנתיים, תם עלי? לא חשבתם על זה, אה?"},{"start":1182.82,"end":1184.62,"text":"להתראות בסמחות, ג'וזו."},{"start":1184.62,"end":1202.7,"text":"יש לי! יש לי! יש לי! יש לי! יש לי! שבע! שבע!"},{"start":1202.7,"end":1206.68,"text":"מיג עשיר? לא! מיג רעש!"},{"start":1206.68,"end":1210.79,"text":"מיג רעש! מיג רעש!"},{"start":1210.79,"end":1213.27,"text":"יש לי! יש לי! יש לי!"},{"start":1213.27,"end":1215.24,"text":"אני אמרה!"},{"start":1215.24,"end":1216.77,"text":"לא!"},{"start":1216.78,"end":1220.18,"text":"טק סייד? לא! אוף סייד!"},{"start":1220.18,"end":1222.74,"text":"אוף סייד! אוף סייד!"},{"start":1222.74,"end":1225.31,"text":"יש לי! יש לי! יש לי!"},{"start":1225.31,"end":1226.86,"text":"לא בעצמי! לא!"},{"start":1226.86,"end":1230.44,"text":"שו ישן? לא! שואר?"},{"start":1230.44,"end":1232.44,"text":"שואר!"},{"start":1232.44,"end":1238.33,"text":"יש לי! יש לי! יש לי! יש לי! יש לי!"},{"start":1238.33,"end":1241.3,"text":"בלם? לא!"},{"start":1241.3,"end":1248.6,"text":"הטברקס! הטברקס!"},{"start":1248.6,"end":1252.96,"text":"מה? לך לחדר השני, תראה, אנטונאללה, לך!"},{"start":1252.96,"end":1296.84,"text":"לך עכשיו! לך, תראה לך! הוא משוגע!"}]