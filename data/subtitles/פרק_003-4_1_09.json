[{"start":0.13,"end":1.29,"text":"בקליפ ההסברה"},{"start":105.11,"end":108.09,"text":"לפעם אחת על מהירות, הלך הרישיון"},{"start":108.09,"end":109.51,"text":"מה אתה אומר?"},{"start":109.51,"end":110.78,"text":"וואו"},{"start":110.78,"end":112.45,"text":"מה זה על עניין לי רישיון?"},{"start":112.45,"end":113.98,"text":"אז תקנה אוטו"},{"start":113.98,"end":114.9,"text":"שלום לך"},{"start":114.9,"end":115.54,"text":"שלום"},{"start":115.54,"end":117.18,"text":"בקשנו לגוע צבי, נעים מאוד"},{"start":117.18,"end":117.94,"text":"נעים ערובי"},{"start":117.94,"end":118.66,"text":"מתעניין?"},{"start":118.66,"end":119.38,"text":"כן"},{"start":119.38,"end":120.58,"text":"אתה יכול לספר לי קצת פרטים על האוטו?"},{"start":120.58,"end":122.14,"text":"אין ספק, זאת הבחירה הנכונה"},{"start":122.14,"end":123.3,"text":"שמה זאת המילה האחרונה"},{"start":123.3,"end":124.22,"text":"אוטו שנות ה-2000"},{"start":124.22,"end":127.26,"text":"גג חשמלי, דלתות מיגון פלדה לכל אורך האוטו"},{"start":127.26,"end":129.02,"text":"גלגלי מגנזיום, גלגלים רכבים"},{"start":129.02,"end":131.02,"text":"יש ספוילר על חשבוננו"},{"start":131.02,"end":132.96,"text":"תאמר לי, לאוטו זה יש טסט?"},{"start":132.96,"end":136.24,"text":"מה? בוודאי, זה אוטו שעולה על הכביש לך שנתיים טסט אוטומטית"},{"start":136.24,"end":137.24,"text":"אה, שנתיים טסט"},{"start":137.24,"end":139.24,"text":"אוטו חדש, צבע מקורי נגד חלודה"},{"start":139.24,"end":140.24,"text":"מנוע מיוחד במינו"},{"start":140.24,"end":142.24,"text":"שים לב, מנוע עם 24 שסטומים"},{"start":142.24,"end":144.24,"text":"מ-0 ל-100 ב-78 שניות"},{"start":144.24,"end":146.24,"text":"תאמר לי, מראות חשמליות"},{"start":146.24,"end":148.78,"text":"זה יד ראשונה אוטו זה?"},{"start":148.78,"end":150.78,"text":"אתה ודאי מתלצת, זה אוטו שיצא את זה מהחברה"},{"start":150.78,"end":152.78,"text":"אוטו פשוט חדש חדש"},{"start":152.78,"end":154.78,"text":"הוא הגיע לפועל מסעית, לא נגענו בו"},{"start":154.78,"end":156.78,"text":"אוטו מדהים פשוט"},{"start":156.78,"end":158.74,"text":"אני יכול לקח את