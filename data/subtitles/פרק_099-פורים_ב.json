[{"start":6.5600000000000005,"end":7.32,"text":"אתה ירוק את ש..."},{"start":7.32,"end":9.08,"text":"והשאלה היא,"},{"start":9.08,"end":15.72,"text":"מה עוד, מה עוד אוכלים מגורים של המרמיתות מלבד עסף ותחווים?"},{"start":15.72,"end":17.06,"text":"אני רק אתם לכם רמז,"},{"start":17.06,"end":20.11,"text":"אני לא הייתי מחבר את השאלה ואת התשובה הזאת."},{"start":20.11,"end":23.66,"text":"מה עוד אוכלים מגורים מלבד..."},{"start":23.66,"end":24.12,"text":"נוח."},{"start":24.12,"end":28.7,"text":"באותו רגע ממש את לא מוכנה לבקר על רביבו?"},{"start":28.7,"end":33.11,"text":"ואל מציע לכם פתרון בחינם."},{"start":33.11,"end":34.17,"text":"מנויים תבל."},{"start":34.17,"end":36.15,"text":"תתקשו עכשיו אל מוקד שירות הלקוחות,"},{"start":36.15,"end":38.15,"text":"תסמינו חיבור נקודת כבלים נוספת,"},{"start":38.27,"end":40.85,"text":"ובמשך חדסי שנה לא תשלמו עלי אדמי מלאי,"},{"start":40.85,"end":42.21,"text":"וגם ההתקנה בחינה."},{"start":76.83,"end":79.09,"text":"תסמינו חדסי שנה לא תסמינו,"},{"start":79.09,"end":81.09,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":81.09,"end":83.09,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":83.09,"end":85.09,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":85.09,"end":87.11,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":87.11,"end":89.11,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":89.11,"end":91.11,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":91.11,"end":95.38,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":95.38,"end":97.38,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":97.38,"end":101.55,"text":"ובמשך חדסי שנה לא תסמינו,"},{"start":101.55,"end":103.55,"text":"והמשים והמקומות שונו לצורך העלילה."},{"start":103.55,"end":110.13,"text":"ומאתה הם ניקאים."},{"start":110.13,"end":154.94,"text":"את הכסף או את החיים?"},{"start":154.94,"end":155.94,"text":"חיים? בטח חיים, מה?"},{"start":155.94,"end":156.94,"text":"חיים!"},{"start":156.94,"end":157.94,"text":"אדוני, אתה בטוח שאתה בוחר את החיים?"},{"start":157.94,"end":158.94,"text":"כן."},{"start":158.94,"end":160.48,"text":"אתה בטוח, אדוני?"},{"start":160.48,"end":161.45,"text":"כן!"},{"start":161.45,"end":164.35,"text":"כי אני יכול להציע לך פה את וילון מספר אחת, אדוני."},{"start":164.35,"end":166.47,"text":"וילון מספר אחת."},{"start":166.47,"end":169.47,"text":"מה אתה בוחר את הכסף, החיים או וילון מספר אחת?"},{"start":169.47,"end":171.75,"text":"חיים, מה? בטח חיים, מה אתה... מה?"},{"start":171.75,"end":172.75,"text":"חיים!"},{"start":172.75,"end":173.75,"text":"בטח!"},{"start":173.75,"end":173.85,"text":"אתה בטוח?"},{"start":173.75,"end":174.75,"text":"כן!"},{"start":174.75,"end":176.35,"text":"חבל."},{"start":176.35,"end":179.35,"text":"אליהו, בוא נראה מה מסתתר מאחורי וילון מספר אחת!"},{"start":179.35,"end":181.44,"text":"ספר לו מה הוא יבציא!"},{"start":181.44,"end":186.44,"text":"אתה לא זכית הבא מבחר לחמים ולחמניות של מיטב המאפיות בארץ!"},{"start":186.44,"end":194.69,"text":"סך שווי העסקה 475 שקלים מתנת מכולת יעקב שבהנהלת יעקב!"},{"start":194.69,"end":196.91,"text":"חבל יעקב, חבל, אח!"},{"start":196.91,"end":199.91,"text":"אבל לא הכל עבוד, שים להם, אני אתן לך עכשיו עוד שנס,"},{"start":199.91,"end":202.91,"text":"יעקב, אני אצא לרצ' איתך ואני מציע לך, אם תוותר על החיים,"},{"start":202.91,"end":207.48,"text":"את וילון מספר שתיים!"},{"start":207.48,"end":208.5,"text":"ומה אתה מוכר?"},{"start":208.5,"end":209.49,"text":"חיים, חיים."},{"start":209.49,"end":210.49,"text":"חיים?"},{"start":210.49,"end":211.49,"text":"כן, אני אשאר עם החיים."},{"start":211.49,"end":216.49,"text":"יעקב, אני אגדיל את האתגר, אני אהיה איתך ואני אוסיף לך לוילון מספר שתיים את..."},{"start":216.49,"end":220.42,"text":"אלפיים שמונה מאות וחמישים שקלים!"},{"start":220.42,"end":223.91,"text":"כל זה כמובן מתנת מקולת יעקב!"},{"start":223.91,"end":224.91,"text":"ומה אתה מוכר יעקב?"},{"start":224.91,"end":226.88,"text":"וילון פלוס הסכום הזה או חיים!"},{"start":226.88,"end":227.97,"text":"וילון!"},{"start":227.97,"end":229.97,"text":"ממש מפטע, לא דבר לנסות."},{"start":229.97,"end":231.35,"text":"כמובן!"},{"start":231.35,"end":233.35,"text":"חיים, חיים, אני אשאר עם החיים."},{"start":233.35,"end":235.35,"text":"אמן לחיים, הגעתי על פה, אני אשאר עם החיים."},{"start":235.35,"end":236.35,"text":"חיים! -כן, כן."},{"start":236.35,"end":238.35,"text":"אני ניסיתי, אני הייתי איתך, יעקב, חבל."},{"start":238.35,"end":242.35,"text":"אליהו, ספר לו מה מסתתר מאחוריו, אילון מספר 2."},{"start":242.35,"end":243.35,"text":"מה הוא הפסיד? הווא נראה."},{"start":243.35,"end":245.35,"text":"אך יעקב, אתה לא זכית, הבא."},{"start":245.35,"end":249.35,"text":"שלל מוצרי חלב, חלב, גבינות, יוגורט ומעדני חלב."},{"start":249.35,"end":254.35,"text":"שים לב, יעקב, סך שווי העסקה, 4353 שקלים,"},{"start":254.35,"end":256.35,"text":"מתנת המכולת של יעקב."},{"start":256.35,"end":258.35,"text":"מכולת יעקב, זול, זול, זול!"},{"start":258.35,"end":263.86,"text":"אתה יודע מה יעקב? שם לב, שן סחרון, אני אהיה ממש לארג'יתך."},{"start":263.86,"end":268.83,"text":"אתה יכול לוותר על החיים תמורת וילון מספר 3,"},{"start":268.83,"end":274.35,"text":"פלוס שבוע משלוחים חינם מתנת, מכולת יעקב."},{"start":274.35,"end":276.35,"text":"אני לא מאמין, אני לא מאמין."},{"start":276.35,"end":277.35,"text":"מה קורה פה אדוני?"},{"start":277.35,"end":281.02,"text":"ברוכים הבאים המצטרפים אלינו זה אתה."},{"start":281.02,"end":284.02,"text":"יש כאן התלבטות בין חיים לבין וילון."},{"start":284.02,"end":286.56,"text":"אני יכול להתאר באשתי?"},{"start":286.56,"end":287.56,"text":"לא, לא, קח את הוילון לזה אשתך."},{"start":287.56,"end":289.56,"text":"אין לנו זמן לזה אם אפשר להתדרד."},{"start":289.56,"end":291.56,"text":"אני לא יודע, אני לא יודע."},{"start":291.56,"end":293.56,"text":"הוילון?"},{"start":293.56,"end":294.56,"text":"בילון?"},{"start":294.56,"end":295.56,"text":"אני לא יודע מה לעשות."},{"start":295.56,"end":299.56,"text":"נו, בילון, בילון, בילון, בילון, בילון, בילון, בילון, בילון."},{"start":299.56,"end":300.56,"text":"בסדר, בסדר, בסדר."},{"start":300.56,"end":302.56,"text":"אני מבטר על החיים, אני לוקח את הוילון."},{"start":302.56,"end":305.56,"text":"יש כאן החלטה."},{"start":305.56,"end":307.56,"text":"תימו לב, הוילון הוא הנבחר."},{"start":307.56,"end":309.56,"text":"בואו נעבור לראות מה מסתתר מאחור הוילון."},{"start":309.56,"end":311.56,"text":"אליך הענייה."},{"start":311.56,"end":314.56,"text":"הוא ספר לנו מה מסתתר מאחור הוילון מספר 3."},{"start":320.98,"end":326.88,"text":"אך יעקב יעקב יעקב חבל שלא נשארת עם החיים יעקב."},{"start":326.88,"end":329.42,"text":"אבל מה לעשות ככה זה."},{"start":329.42,"end":331.95,"text":"אתה ויתה אתה לחיים."},{"start":331.95,"end":334.87,"text":"אלה ואני אמרתי לו לווילון."},{"start":334.87,"end":336.51,"text":"לא נועה."},{"start":336.51,"end":341.51,"text":"אוקיי ואני אתן עשרים שקלים למי שיוכיח שהוא שוטר אמיתי."},{"start":341.51,"end":342.51,"text":"לא אני."},{"start":342.51,"end":343.51,"text":"אלה ואה."},{"start":343.51,"end":344.51,"text":"אלה ואה."},{"start":344.51,"end":345.51,"text":"אלה ואה."},{"start":345.51,"end":357.55,"text":"אלה ואה."},{"start":357.55,"end":359.34,"text":"שלום."},{"start":359.34,"end":360.47,"text":"שלום."},{"start":360.47,"end":361.47,"text":"יש לך איזה עבודה בשבילי?"},{"start":361.47,"end":362.72,"text":"שם."},{"start":362.72,"end":363.85,"text":"אלה."},{"start":363.85,"end":365.03,"text":"שם משפחה."},{"start":365.03,"end":366.34,"text":"דרכת."},{"start":366.34,"end":367.34,"text":"מקום עבודה קודם."},{"start":367.34,"end":371.64,"text":"אני לא נראה לך מוכר?"},{"start":371.64,"end":372.7,"text":"לא."},{"start":372.7,"end":375.7,"text":"טוב אני הייתי אחד מהאלים האלה שהעבירו לפרסומות בערוץ 2."},{"start":375.7,"end":377.7,"text":"אהההה כן כן."},{"start":377.7,"end":379.43,"text":"סיבת הפיתורים?"},{"start":379.43,"end":381.55,"text":"אמרו שאני אלים מדי."},{"start":381.55,"end":384.55,"text":"נועה אז הביאו את הפרצוף הזמניה גנב לנו את העבודה."},{"start":384.55,"end":387.03,"text":"יש לך איזה משהו בשבילי בחיית?"},{"start":387.03,"end":390.99,"text":"אין תאמין לי השוק יבש, עכשיו תבוא בסתיו אולי יהיה לנו משהו."},{"start":390.99,"end":396.02,"text":"לא אכפת לי כל דבר תאמין לי להיות אלים בקוסטי נאנה, אוריגן או בפיצה."},{"start":396.02,"end":398.02,"text":"הלו מה העניינים?"},{"start":398.02,"end":399.02,"text":"אהלן משי."},{"start":399.02,"end":401.02,"text":"יש איזה משהו בשבילי אני הרבה זמן פה."},{"start":401.02,"end":404.17,"text":"אין כלום תאמין לי השוק ריק, ריק."},{"start":404.17,"end":405.87,"text":"זה אתה!"},{"start":405.87,"end":407.09,"text":"מה אני?"},{"start":407.09,"end":409.09,"text":"אתה בחברים שלך לקחתם לי ולחבר שלי את העבודה."},{"start":409.09,"end":412.18,"text":"אנחנו לפניהם היינו מעבירים לפרסומות."},{"start":412.18,"end":413.18,"text":"מי לקחת את העבודה?"},{"start":413.18,"end":415.18,"text":"תשתוק יא גולם."},{"start":415.18,"end":417.18,"text":"אני גולם הבן שלך גולם."},{"start":417.18,"end":418.53,"text":"משהו נכון נכון."},{"start":418.53,"end":420.53,"text":"חבר'ה, חבר'ה, לא נעריב."},{"start":420.53,"end":422.53,"text":"אולי אפשר עוד למצוא משהו."},{"start":422.53,"end":423.56,"text":"איך אתם בשירה?"},{"start":423.56,"end":425.08,"text":"ככה."},{"start":425.08,"end":427.67,"text":"שמיעה מוזיקלית יש?"},{"start":427.67,"end":428.63,"text":"ככה."},{"start":428.63,"end":430.59,"text":"אולי אפשר למצוא משהו."},{"start":430.59,"end":434.59,"text":"אנחנו מחפשים חבר'ה שישאירו את העברה לפרסומות."},{"start":434.59,"end":436.42,"text":"איך זה הולך?"},{"start":436.42,"end":438.38,"text":"זה הולך בערך ככה."},{"start":438.38,"end":441.57,"text":"*ערבית*"},{"start":441.57,"end":443.98,"text":"אולי יותר ספציפי?"},{"start":443.98,"end":445.98,"text":"אז בואו אני אשמיע לכם את האורגינל."},{"start":445.98,"end":523.64,"text":"מה עושים?"},{"start":523.64,"end":525.91,"text":"מה עמם?"},{"start":525.91,"end":527.16,"text":"תיכו."},{"start":527.16,"end":529.79,"text":"מה נעשה?"},{"start":529.79,"end":533.35,"text":"אצל דויד."},{"start":533.35,"end":535.28,"text":"יאללה, בוא."},{"start":535.28,"end":543.11,"text":"תדיקה."},{"start":543.11,"end":544.72,"text":"ספרדיה הולכת ביער."},{"start":544.72,"end":545.91,"text":"ספרדיה הולכת ביער."},{"start":545.91,"end":547.91,"text":"בא לצ'יטא אומרת לה:"},{"start":547.91,"end":548.91,"text":"שלם!"},{"start":548.91,"end":550.35,"text":"מה אתה עושה?"},{"start":550.35,"end":551.98,"text":"מה זה?"},{"start":551.98,"end":552.93,"text":"צ'יטא אומרת לה:"},{"start":552.93,"end":553.98,"text":"אני משחררת לציד."},{"start":553.98,"end":554.98,"text":"היא יוצאת לצוד."},{"start":554.98,"end":556.05,"text":"הולכת..."},{"start":556.05,"end":558.83,"text":"אה."},{"start":558.83,"end":559.83,"text":"טוב. מה לעשות?"},{"start":559.83,"end":560.83,"text":"אז אני אפשר."},{"start":560.83,"end":561.83,"text":"אה אתה מכיר את זה?"},{"start":561.83,"end":562.79,"text":"אתה תראה."},{"start":562.79,"end":563.79,"text":"עכשיו היא עוזבת את הצ'יטא הצ'פארדה הזו."},{"start":563.79,"end":564.79,"text":"היא המשיכה, אלו המשיכה."},{"start":564.79,"end":565.79,"text":"היא המשיכה ואתה מורלת את זה..."},{"start":565.79,"end":566.79,"text":"איזה ג'ירף הגבוהה."},{"start":566.79,"end":567.79,"text":"כן, אומרת לה:"},{"start":567.79,"end":569.29,"text":"שלא! מה אתה עושה?"},{"start":569.29,"end":570.42,"text":"אז היא אומרת:"},{"start":570.42,"end":572.42,"text":"אני, אני, הג'ירף אומרת:"},{"start":572.42,"end":573.42,"text":"אני, אני עם הענפים,"},{"start":573.42,"end":574.42,"text":"אוכל לי קצת אסבים..."},{"start":574.42,"end":575.42,"text":"רטח."},{"start":575.42,"end":576.42,"text":"שנייה, אריה, סליחה, אריה."},{"start":576.42,"end":578.49,"text":"אלו?"},{"start":578.49,"end":579.66,"text":"אני אמשיך."},{"start":579.66,"end":580.66,"text":"אתה מכיר את זה?"},{"start":580.66,"end":581.66,"text":"מכיר את זה, ישן."},{"start":581.66,"end":582.75,"text":"מה קרה לך?"},{"start":582.75,"end":584.75,"text":"אני מנסה לתרוב צפרדי הקטן עם פה גדול."},{"start":584.75,"end":585.93,"text":"אני מנסה לתרוב צפרדי הקטן עם פה גדול."},{"start":585.93,"end":587.93,"text":"מה אתה אומר?"},{"start":587.93,"end":589.93,"text":"זה קטן קטנים פה כזה, כן?"},{"start":589.93,"end":591.93,"text":"אז היא אומרת לו:"},{"start":591.93,"end":594.08,"text":"מה אתה עושה?"},{"start":594.08,"end":596.03,"text":"אז הוא אומר לה: אוכל דגים?"},{"start":596.03,"end":598.37,"text":"מייחד, בסדר?"},{"start":598.37,"end":599.97,"text":"חבל, דווקא עכשיו."},{"start":599.97,"end":604.97,"text":"אלו, רגע, רגע, רגע, זאת לא בדיחה הזאת שאחרי שיוזב את היפופותם היא מגיעה לנהר ורואה את הנים."},{"start":604.97,"end":606.97,"text":"ושואלת, אתה מבין:"},{"start":606.97,"end":608.97,"text":"שלב, מה אתה עושה?"},{"start":608.97,"end":611.97,"text":"אז הוא אומר לה: אני מנסה לתרוב צפרדי הקטן עם פה גדול."},{"start":611.97,"end":614.97,"text":"אז הוא אומר: מה אתה אומר?"},{"start":614.97,"end":618.97,"text":"לא, לא, לא, אני לא יכול בתאריך הזה."},{"start":618.97,"end":629.88,"text":"זה לא עסק, זה לא עסק."},{"start":629.88,"end":632.88,"text":"שגרנו שעם על הרגז בוטני מחד."},{"start":632.88,"end":640.54,"text":"אתה צריך להביא כל הרגזים האלה לבניין..."},{"start":640.54,"end":650.58,"text":"מה עושים?"},{"start":650.58,"end":651.86,"text":"שעמם."},{"start":651.86,"end":654.15,"text":"שעמם, שעמם."},{"start":654.15,"end":655.31,"text":"תיכו."},{"start":655.31,"end":659.22,"text":"בואו נרביץ לדוד."},{"start":659.22,"end":662.33,"text":"הרבסנו לו."},{"start":662.33,"end":667.3,"text":"בואו נרביץ לו עוד פעם."},{"start":667.3,"end":673.15,"text":"יאללה יאללה"},{"start":673.15,"end":676.88,"text":"תקלה תגמרי את המשחקים חוזרים הביתנו"},{"start":676.88,"end":677.88,"text":"לא רוצה"},{"start":677.88,"end":679.44,"text":"אמא מחכה ברוכת צהריים"},{"start":679.44,"end":679.54,"text":"לאווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":679.44,"end":680.83,"text":"לא!"},{"start":680.83,"end":680.93,"text":"לא, לא, לא, לא, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו, בו,"},{"start":680.83,"end":685.45,"text":"הלו הלו הלו הלו בו בו בו בו בו הלל הלל"},{"start":685.45,"end":689.28,"text":"אתה לא זה מהחלסטרות מהזו זו זו הלל"},{"start":689.28,"end":691.28,"text":"מכירה אותו מהטלוויזיה? לא"},{"start":691.28,"end":693.28,"text":"מת עליך הבת שלי תעשה לה איך היה"},{"start":693.28,"end":694.66,"text":"לא לא"},{"start":694.66,"end":697.66,"text":"תעשה לה איך היהנו יש לה מחר עם הולדת 8 תעשה לה איך היה"},{"start":697.66,"end":698.98,"text":"זלתם"},{"start":698.98,"end":701.71,"text":"איך היה?"},{"start":701.71,"end":705.75,"text":"מה זה? למה אתה לא עושה את זה מצחיק?"},{"start":705.75,"end":706.75,"text":"זה לא אני עושה את זה"},{"start":706.75,"end":711.75,"text":"תעשה את זה מצחיק כמו בטלוויזיה איך היהנו תעשה לה יש לה עם הולדת 8 נו מחר תעשה לטיור"},{"start":711.75,"end":713.75,"text":"לא אני עושה את זה בטלוויזיה"},{"start":713.75,"end":717.75,"text":"אמרתי תעשה איך היה אז תעשה לה איך היה תצחק להיות הסופרסטר עכשיו"},{"start":717.75,"end":718.84,"text":"איך היה"},{"start":718.84,"end":720.84,"text":"תעשה לה תעשה לה תהיה מבסודית מו"},{"start":720.84,"end":722.06,"text":"איך היה"},{"start":722.06,"end":725.18,"text":"תגיד לי מה זה בגלל שאני בא מרחוב ואתה משחק להיות המשחקים"},{"start":725.18,"end":728.18,"text":"תעשה את זה כמו שצריך תחזיק את הקובע"},{"start":728.18,"end":732.18,"text":"תעשה שיער פרוח כמו בטלוויזיה או לבטלוויזיה תמירה יותר גבוה"},{"start":732.18,"end":734.18,"text":"תעשה ככה ותגיד איך היה"},{"start":734.18,"end":737.18,"text":"איי איי איי עיניים פה זלות גריים הפה"},{"start":737.18,"end":739.18,"text":"תצחיק אותה מתה על הבוסקילה שלך"},{"start":739.18,"end":740.18,"text":"תעשה איך היהנו"},{"start":740.18,"end":741.18,"text":"איך היה"},{"start":741.18,"end":743.18,"text":"תעשה לך ינו תעשה לטיון"},{"start":743.18,"end":745.15,"text":"בסדר אני אעשה לך"},{"start":745.15,"end":750.08,"text":"איך היה"},{"start":750.08,"end":751.23,"text":"אה"},{"start":751.23,"end":752.67,"text":"תדר זה"},{"start":752.67,"end":754.67,"text":"עולה כשאתה רוצה את היכול"},{"start":754.67,"end":755.67,"text":"איך היה"},{"start":755.67,"end":757.7,"text":"אדים אדיק לארוחת צהריים"},{"start":757.7,"end":759.7,"text":"אדים אדיק לארוחת צהריים הלכי"},{"start":759.7,"end":760.7,"text":"הלכי"},{"start":760.7,"end":763.7,"text":"הלכי איזה עבלים אנשים היותים הלכת ברכו בלבד בשקט"},{"start":763.7,"end":768.29,"text":"הל"},{"start":768.29,"end":770.07,"text":"הלן חבר'ה"},{"start":770.07,"end":772.64,"text":"הלן דווי"},{"start":772.64,"end":774.78,"text":"מה קורה?"},{"start":774.78,"end":776.24,"text":"שעמם"},{"start":776.24,"end":778.68,"text":"שעמם שעמם"},{"start":778.68,"end":780.79,"text":"תיכו"},{"start":780.79,"end":781.79,"text":"הוציא ושחק סנוקר?"},{"start":781.79,"end":783.84,"text":"שענו"},{"start":783.84,"end":787.02,"text":"אז בואו לשקיפה על בחורות"},{"start":787.02,"end":788.49,"text":"שרפנו"},{"start":788.49,"end":790.47,"text":"טוב?"},{"start":790.47,"end":794.41,"text":"אז בואו תרביצו לי עוד פעם"},{"start":794.41,"end":797.1,"text":"יאללה"},{"start":797.1,"end":801.13,"text":"אוהו!"},{"start":801.13,"end":804.19,"text":"היום טוב מנטלית שונה לגמרי אתה לא יכול לקחת דבר שאלה כמו משנה"},{"start":804.19,"end":805.19,"text":"בסדר וטיים"},{"start":805.19,"end":807.35,"text":"אתה יודע שמגיע לי מזל טוב?"},{"start":807.35,"end":808.44,"text":"באמת על מה?"},{"start":808.44,"end":811.52,"text":"על מה זכיתי בתואר מנתח השנה אצלנו במחור"},{"start":811.52,"end":812.57,"text":"מה טוב מנתח השנה?"},{"start":812.57,"end":813.57,"text":"אהההה"},{"start":813.57,"end":814.57,"text":"כי אנשים מגיע גם לי איזשהו מזל טוב קטן"},{"start":814.57,"end":815.57,"text":"למה?"},{"start":815.57,"end":817.63,"text":"המנתח הזריז של מצרד הבריאות"},{"start":817.63,"end":818.63,"text":"מה זאת אומרת הזריז?"},{"start":818.63,"end":820.63,"text":"מה זאת אומרת זה אומר שהכל רק יותר מהר"},{"start":820.63,"end":822.84,"text":"כמה זמן אתה עושה מעקפים?"},{"start":822.84,"end":823.84,"text":"שלוש שעות 19 דקות"},{"start":823.84,"end":825.86,"text":"אני עשיתי שלוש חמש עשרה"},{"start":825.86,"end":827.83,"text":"תלוש חמש עשרה עשיתי"},{"start":827.83,"end":830.71,"text":"כמה רק אתה עושה קריטת תעונה קדמית?"},{"start":830.71,"end":831.89,"text":"קדמית"},{"start":831.89,"end":833.92,"text":"קדמית אני עשיתי את זה בארבע שתיים"},{"start":833.92,"end":834.92,"text":"ארבע"},{"start":834.92,"end":836.97,"text":"ארבע"},{"start":836.97,"end":837.97,"text":"ארבע"},{"start":837.97,"end":838.97,"text":"עגול"},{"start":838.97,"end":839.97,"text":"לא מאמין לך"},{"start":839.97,"end":840.97,"text":"אני לא מאמין לך"},{"start":840.97,"end":841.97,"text":"מה הדבר הכי זריז שאתה עושה?"},{"start":841.97,"end":844.09,"text":"תוספתן דקה וחצי"},{"start":844.09,"end":845.53,"text":"אני עושה את זה בדקה"},{"start":845.53,"end":846.53,"text":"דקה"},{"start":846.53,"end":847.72,"text":"דקה"},{"start":847.72,"end":849.72,"text":"אם אני אתמצם את הארדמה ואת התפרים"},{"start":849.72,"end":851.72,"text":"נטו יישאר לי פחות מדקה אפילו"},{"start":851.72,"end":852.72,"text":"אתה לא יורד מדקה"},{"start":852.72,"end":853.72,"text":"פחות מדקה אני אומר לך"},{"start":853.72,"end":855.72,"text":"אתה לא יורד מדקה אני"},{"start":855.72,"end":857.72,"text":"אני לא מאמין לך שאתה יורד מדקה"},{"start":857.72,"end":859.84,"text":"דוקטר פחות מדקה אני אומר לך"},{"start":859.84,"end":861.84,"text":"אתה יודע מה אני אוכל להתערף שאני עושה את זה יותר מהר ממך"},{"start":861.84,"end":861.94,"text":"יותר מה ממני"},{"start":861.84,"end":862.84,"text":"יותר מהר ממך"},{"start":862.84,"end":863.84,"text":"כמה זמן שאתה עושה אני אעשה את עומד"},{"start":863.84,"end":864.84,"text":"המנתה החזרי זה אומר לך משהו"},{"start":864.84,"end":865.84,"text":"אני עושה את זה יותר מהר"},{"start":865.84,"end":866.84,"text":"מתערבים?"},{"start":866.84,"end":867.96,"text":"מתערבים"},{"start":867.96,"end":869.89,"text":"מלצר!"},{"start":869.89,"end":872.33,"text":"מה? מה?"},{"start":872.33,"end":873.33,"text":"מה אתה עושה?"},{"start":873.33,"end":875.33,"text":"מה אתה משתגלתם או מה?"},{"start":875.33,"end":876.33,"text":"מה אתה?"},{"start":876.33,"end":877.33,"text":"סליחה רגע"},{"start":877.33,"end":879.33,"text":"סליחה רגע"},{"start":879.33,"end":880.45,"text":"אוקיי"},{"start":880.45,"end":882.51,"text":"מה קורה פה?"},{"start":882.51,"end":884.89,"text":"מה אתה משתגלת?"},{"start":884.89,"end":886.89,"text":"אני מבין"},{"start":886.89,"end":904.31,"text":"תרושים"},{"start":904.31,"end":906.33,"text":"זה לא זה"},{"start":906.33,"end":909.92,"text":"ארבעים וחמש"},{"start":909.92,"end":912.07,"text":"טראם"},{"start":912.07,"end":913.07,"text":"שששש"},{"start":913.07,"end":915.97,"text":"לינג לינג לינג"},{"start":915.97,"end":917.97,"text":"יאללה, קינוח עליי"},{"start":917.97,"end":922.65,"text":"קפה דבז מישהו?"},{"start":922.65,"end":924.65,"text":"ערב טוב, ערב טוב, איפה קפיים?"},{"start":924.65,"end":926.65,"text":"איפה, איפה קפיים?"},{"start":926.65,"end":928.74,"text":"ערב טוב"},{"start":928.74,"end":930.74,"text":"שוב ברוכים הבאים לחיידון נוסף"},{"start":930.74,"end":934.74,"text":"וחיידון הפופולרי, החיידון השכונתי שלנו"},{"start":934.74,"end":936.74,"text":"אבו גפיים"},{"start":936.74,"end":938.74,"text":"והגענו כמובן לשלב הגמר"},{"start":938.74,"end":940.74,"text":"ואיתנו יש מתמודד"},{"start":940.74,"end":943.74,"text":"האחד והחיד התציח לפצח את הקוד ולהגיע לשלב הזה"},{"start":943.74,"end":945.89,"text":"רחמי"},{"start":945.89,"end":946.89,"text":"אבו גפיים"},{"start":946.89,"end":948.77,"text":"שצבר עד כה"},{"start":948.77,"end":950.64,"text":"אבס נקודות"},{"start":950.64,"end":953.12,"text":"אבו גפיים"},{"start":953.12,"end":956.12,"text":"ולימיני, האחד והיחיד, הוגה השאלון"},{"start":956.12,"end":958.12,"text":"ויושב ראש כבוד חבר השופטים"},{"start":958.12,"end":961.4,"text":"שאול המשורי"},{"start":961.4,"end":964.71,"text":"שאול, שאלה באה"},{"start":964.71,"end":966.71,"text":"ונעבור לשלב הראשון של המשחקון"},{"start":966.71,"end":968.7,"text":"שלב השאלה"},{"start":968.7,"end":969.74,"text":"רגשה שאלה"},{"start":969.74,"en