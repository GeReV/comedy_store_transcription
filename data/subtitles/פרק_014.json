5.29,"end":896.29,"text":"באמת איך אתה עשית את זה"},{"start":896.29,"end":897.29,"text":"בכל כך מקלות"},{"start":897.29,"end":898.29,"text":"יכולה להניע וליסון"},{"start":898.29,"end":899.29,"text":"פרופסור ממש"},{"start":899.29,"end":900.29,"text":"זה פשוט נפלא"},{"start":900.29,"end":901.29,"text":"איך אני יודע לך?"},{"start":901.29,"end":902.29,"text":"אני חייבת להודות לך"},{"start":902.29,"end":903.29,"text":"זה היה פשוט נפלא"},{"start":903.29,"end":904.29,"text":"אין בעיה לא"},{"start":904.29,"end":905.29,"text":"לא לא לא לא אני חייבת להודות לך"},{"start":905.29,"end":906.26,"text":"אתה רוצה את זה פה בשיחים?"},{"start":906.26,"end":907.64,"text":"מה?"},{"start":907.64,"end":908.64,"text":"רוצה את זה פה בשיחים?"},{"start":908.64,"end":910.64,"text":"אני פשוט חייבת להודות לך"},{"start":910.64,"end":911.64,"text":"מה שאת אומרת פה בשיחים?"},{"start":911.64,"end":913.7,"text":"רוצה שנעשה את זה פה בשיחים?"},{"start":913.7,"end":915.98,"text":"מה? כאילו"},{"start":915.98,"end":918.48,"text":"די איפה? מה זה בצלבד הסתרת?"},{"start":918.48,"end":919.48,"text":"איפה? איפה? איפה?"},{"start":919.48,"end":922.02,"text":"איפה שנעשה את זה עכשיו? בשיחים?"},{"start":922.02,"end":923.4,"text":"מה? את רצינית?"},{"start":923.4,"end":924.55,"text":"אה"},{"start":924.55,"end":925.62,"text":"את לא צוחקת אליי"},{"start":925.62,"end":926.75,"text":"לא לא"},{"start":926.75,"end":927.75,"text":"אז מה? את רוצה להודות?"},{"start":927.75,"end":928.75,"text":"אז רגע למה בשיחים? בואי נעלה אליי הבית"},{"start":928.75,"end":929.75,"text":"אני גר פה ממש שתי מטר"},{"start":929.75,"end":930.75,"text":"עזוב אותך לך בבית"},{"start":930.75,"end":931.75,"text":"בואי נעשה את זה פה עכשיו"},{"start":931.75,"end":933.75,"text":"מה את נורמלי? תגידי לי בואי נעשה את זה בבית"},{"start":933.75,"end":935.81,"text":"בואי פה אני גר ממש שתי דקות קומה ראשונה"},{"start":935.81,"end":937.81,"text":"לא, אני שואל אותך שתי דקות"},{"start":937.81,"end":938.81,"text":"עזוב אותך בוא עכשיו לשיחים"},{"start":938.81,"end":939.81,"text":"בואי שתי דקות קומה ראשונה"},{"start":939.81,"end":941.81,"text":"תאמיני לי בית, מזגן, שתייה, יין"},{"start":941.81,"end":942.81,"text":"יהיה סבבה תאמיני לי"},{"start":942.81,"end":945.81,"text":"אם כבר להודות אז בואי נודה אחד לשני אה?"},{"start":945.81,"end":946.9,"text":"מה את אומרת?"},{"start":946.9,"end":947.9,"text":"טוב, קראתי בבית"},{"start":947.9,"end":948.9,"text":"אני אקח אותך מותק"},{"start":948.9,"end":951.04,"text":"אופלה"},{"start":951.04,"end":953.27,"text":"סבתא שלי"},{"start":953.27,"end":956.27,"text":"תראה"},{"start":956.27,"end":957.24,"text":"תראה"},{"start":957.24,"end":958.24,"text":"תראה"},{"start":958.24,"end":959.24,"text":"תראה"},{"start":959.24,"end":960.24,"text":"תראה"},{"start":960.24,"end":961.24,"text":"תראה"},{"start":961.24,"end":962.27,"text":"תראה"},{"start":962.27,"end":963.23,"text":"תראה"},{"start":963.23,"end":964.23,"text":"תראה"},{"start":964.23,"end":965.23,"text":"תראה"},{"start":965.23,"end":966.2,"text":"תראה"},{"start":966.2,"end":967.2,"text":"תראה"},{"start":967.2,"end":968.2,"text":"תראה"},{"start":968.2,"end":969.2,"text":"תראה"},{"start":969.2,"end":970.2,"text":"תראה"},{"start":970.2,"end":972.2,"text":"אוי מוצרלה שלי"},{"start":972.2,"end":974.2,"text":"אוי קורכיוון שלי"},{"start":974.2,"end":977.17,"text":"אוי שובי שלי אני אוכל אותך"},{"start":977.17,"end":980.17,"text":"בואי לובסטר אני רוצה שתקצי אותי"},{"start":980.17,"end":982.17,"text":"הוא אליי"},{"start":982.17,"end":984.97,"text":"או אני לא מאמין"},{"start":984.97,"end":988.15,"text":"אני בא סוכריה שלי"},{"start":988.15,"end":990.15,"text":"אני בא את לא תאמין מה ש..."},{"start":990.15,"end":994.58,"text":"אני בא"},{"start":994.58,"end":996.96,"text":"אני בא מוטק שלי אני בא"},{"start":996.96,"end":998.92,"text":"אני בא"},{"start":998.92,"end":1001.17,"text":"אני בא"},{"start":1001.17,"end":1003.83,"text":"אני בא"},{"start":1003.83,"end":1006.2,"text":"אני בא"},{"start":1006.2,"end":1008.74,"text":"אני בא"},{"start":1008.74,"end":1010.73,"text":"אני בא"},{"start":1010.73,"end":1012.64,"text":"גבי"},{"start":1012.64,"end":1014.82,"text":"גבי לאן אתה בא"},{"start":1014.82,"end":1016.82,"text":"גבי קום"},{"start":1016.82,"end":1017.82,"text":"לן אתה בא תגיד לי"},{"start":1017.82,"end":1018.82,"text":"לן אתה בא ללך לעבוד"},{"start":1018.82,"end":1019.82,"text":"ללך לעבוד"},{"start":1019.82,"end":1020.82,"text":"נמאש לי"},{"start":1020.82,"end":1022.82,"text":"נמאש לי מה ההתנהגות שלך"},{"start":1022.82,"end":1023.82,"text":"תראה אני לא מוכנה"},{"start":1023.82,"end":1025.82,"text":"לי נמאש להפנים כל הזמן"},{"start":1025.82,"end":1027.82,"text":"אתה תלך לעבוד נבלה"},{"start":1027.82,"end":1028.82,"text":"ואתה תאיר אותי שאתה תחזור"},{"start":1028.82,"end":1029.82,"text":"אתה שומע"},{"start":1029.82,"end":1030.82,"text":"אתה תאיר אותי שאתה תחזור"},{"start":1030.82,"end":1031.82,"text":"ונמאש לי ממך"},{"start":1031.82,"end":1032.82,"text":"ואתה סתום מטפה"},{"start":1032.82,"end":1033.82,"text":"ואל תענה לי"},{"start":1033.82,"end":1043.14,"text":"הייתי צריך לדקור אותה בשיחי"},{"start":1043.14,"end":1051.63,"text":"השפן הקטן שכח לסגור הדלת"},{"start":1051.63,"end":1054.63,"text":"הצטנן המשכן וקיבל נזלת"},{"start":1054.63,"end":1058.63,"text":"שלום, היום גם הייתה לי יום הולדת"},{"start":1058.63,"end":1059.63,"text":"והייתי חולה"},{"start":1059.63,"end":1064.43,"text":"ונשארתי לבד בבית"},{"start":1064.43,"end":1066.43,"text":"ובגלל שהורים שלי לא היו בבית"},{"start":1066.43,"end":1068.43,"text":"אז דפקתי סיגרי"},{"start":1068.43,"end":1070.43,"text":"כן, אני מאשן חופשי"},{"start":1070.43,"end":1072.43,"text":"אין לי אלוהים בקטעים של סיגריות"},{"start":1072.43,"end":1073.43,"text":"אני גם מכניס לרעות"},{"start":1073.43,"end":1076.49,"text":"כן, מי שלא מאשן הוא לא גבר"},{"start":1076.49,"end":1078.49,"text":"ואני גם בכלל הישנתי נובלס"},{"start":1078.49,"end":1079.49,"text":"כי אני פריק"},{"start":1079.49,"end":1081.49,"text":"כן, יש לי סנדלי טבע"},{"start":1081.49,"end":1083.49,"text":"אני תופס טראמפים לאלת"},{"start":1083.49,"end":1084.49,"text":"אני בנוער מרץ"},{"start":1084.49,"end":1085.49,"text":"בגלל שאני פריק"},{"start":1085.49,"end":1087.49,"text":"אז אני גם מאשן נובלס"},{"start":1087.49,"end":1089.84,"text":"ועכשיו"},{"start":1089.84,"end":1091.84,"text":"נורא בא לי סיגריה"},{"start":1091.84,"end":1093.84,"text":"אז אני אתקשר לבחורה"},{"start":1093.84,"end":1095.84,"text":"כי אני מאשן רק אחרי שאני מזדבג"},{"start":1095.84,"end":1097.79,"text":"אז אני אתקשר לבחורה"},{"start":1097.79,"end":1101.79,"text":"אני אתקשר לדנה מהממת"},{"start":1101.79,"end":1104.91,"text":"שנייה"},{"start":1104.91,"end":1107.67,"text":"דנה"},{"start":1107.67,"end":1112.02,"text":"נו"},{"start":1112.02,"end":1114.02,"text":"תבדקי אם יש לך"},{"start":1114.02,"end":1119.31,"text":"מים בברז"},{"start":1119.31,"end":1122.65,"text":"היא בודקת עכשיו?"},{"start":1122.65,"end":1124.65,"text":"תבדקי אם יש לך קולה"},{"start":1124.65,"end":1128.35,"text":"ראיתם איך הכנסתי לה?"},{"start":1128.35,"end":1130.38,"text":"עכשיו אני רוצה סיגרה"},{"start":1130.38,"end":1132.38,"text":"כי זהו הכנסתי לה"},{"start":1132.38,"end":1149.63,"text":"ערב צח ושוב הדיאטות"},{"start":1149.63,"end":1151.94,"text":"מחלסטרות לי את המוח"},{"start":1151.94,"end":1153.94,"text":"מה זה אחרת הזה?"},{"start":1153.94,"end":1155.94,"text":"בימא שלי תלכו תראו היום איזה דיאטות"},{"start":1155.94,"end":1157.94,"text":"ישתי כך כדורים? כדורי סובין? כדורי חיטין?"},{"start":1157.94,"end":1159.94,"text":"כדורי כפה? מה זה אחרת הזה בימא שלי"},{"start":1159.94,"end":1161.94,"text":"אני פתחתי קופסה של כדורים איזה יפי"},{"start":1161.94,"end":1163.94,"text":"צבעוני, סגוני בימא שלי חשבתי אקסטזי"},{"start":1163.94,"end":1165.94,"text":"שבתי מוזיקה בליטי של שלתי שבועיים"},{"start":1165.94,"end":1167.94,"text":"מה זה אחרת הזה בימא שלי"},{"start":1167.94,"end":1169.94,"text":"ויש כל מיני כאלה בתמונות"},{"start":1169.94,"end":1172.0,"text":"לפני ואחרי"},{"start":1172.0,"end":1174.09,"text":"לפני התורה בחורה"},{"start":1174.09,"end":1176.09,"text":"מה זה מכוערת בימא שלי"},{"start":1176.09,"end":1178.09,"text":"עם חצקונים בגודל של כדורסל"},{"start":1178.09,"end":1178.19,"text":"היא חייכת ככה"},{"start":1178.09,"end":1180.09,"text":"אחרי היא לא רזה"},{"start":1180.09,"end":1182.09,"text":"גם שמינה אבל היא בעודים"},{"start":1182.09,"end":1184.03,"text":"ובזווית רחוקה 80 מטר מתחבה מאחורי צריף"},{"start":1184.03,"end":1186.05,"text":"הבנתם את זה? מה זה אחרת הזה בימא שלי"},{"start":1186.05,"end":1190.02,"text":"ודודו תופז דיית דודו דיית נעליים"},{"start":1190.02,"end":1192.02,"text":"אני יש לי דיית זו זו רבותיי"},{"start":1192.02,"end":1194.02,"text":"זו הדיית הכי מדליקה בעולם"},{"start":1194.02,"end":1195.99,"text":"ערוכת בוקר דיית קוסקוס"},{"start":1195.99,"end":1197.99,"text":"ערוכת שהריים דיית מופלטה"},{"start":1197.99,"end":1199.99,"text":"וערוכת ערב דיית דיית דיית"},{"start":1199.99,"end":1201.99,"text":"דיית זה ירוצה לאכול"},{"start":1201.99,"end":1203.99,"text":"ותחשבו על זה העיקר הבריאות"},{"start":1203.99,"end":1205.99,"text":"העיקר החיים איך פתלו דייתה?"},{"start":1205.99,"end":1207.19,"text":"מתעבוד"}]