[{"start":29.73,"end":33.83,"text":"ברוכים הבאים, לקום המסתור!"},{"start":33.83,"end":56.2,"text":"כן, מה?"},{"start":56.2,"end":57.2,"text":"אתה נקרח אותו 100 שקל"},{"start":57.2,"end":59.2,"text":"לא פי טוב, 30 שקל, זה מכולקל זה"},{"start":59.2,"end":60.2,"text":"90 שקל"},{"start":60.2,"end":62.2,"text":"30 שקל לא יכול למכור אותו בכלל"},{"start":62.2,"end":63.2,"text":"70 שקל הוא שלך, אנו"},{"start":63.2,"end":64.2,"text":"זה דפוק 30 רוצה?"},{"start":64.2,"end":67.2,"text":"אדוני, אדוני, 50 שעה!"},{"start":100.04,"end":103.0,"text":"הורדות על תל אביב ועשות בתל אביב כי ושלאין"},{"start":103.0,"end":107.0,"text":"הופעתן הפתאום התגרמה לבעיות תנועה ופקקים רבים"},{"start":107.0,"end":108.96,"text":"שבלווחי היו עד כה בתל אביב"},{"start":108.96,"end":114.35,"text":"לקחנו את המצלמה המשוטטת ויצאנו לשטח לראות מה קורה בדיוק"},{"start":114.35,"end":118.3,"text":"כאן הנס קריסטיאן אנדרסן, וושינגטון"},{"start":118.3,"end":151.38,"text":"המשטרה והעירייה לשים קץ לפרשה"},{"start":151.38,"end":153.38,"text":"עולים בתוהו"},{"start":153.38,"end":186.32,"text":"תושבים בתל אביב הפכו לגהנום"},{"start":186.32,"end":191.45,"text":"תושבים לא מעטים ותמימים הפכו לקורבן לציפורני המחשפות הללו"},{"start":191.45,"end":194.45,"text":"ואלה אינן יודות רכב"},{"start":194.45,"end":197.83,"text":"כאן, האנס קריאן סממה אנדרסן, יפו"},{"start":197.83,"end":203.17,"text":"היה לי קוטט, קוטט שלי שמניתי בבוא ידי, קוטט שדו מפלסי"},{"start":203.17,"end":206.17,"text":"הם קבצו את והם התאכזרו, תראו מה נהיה"},{"start":206.17,"end":211.08,"text":"עולה תשמע, זה מס, זה ריל מס"},{"start":211.08,"end":214.04,"text":"אני, אני יוסטובי אחלה דוגמנית צמרת"},{"start":214.04,"end":217.04,"text":"עכשיו תראה מה הם עשו לי, אני הייתי יפה שעה אחת קודם"},{"start":217.04,"end":219.04,"text":"תסתכל עליי, תסתכל"},{"start":219.04,"end":224.04,"text":"שלום אדוני, גם אדוני קורבן של המחשפות"},{"start":224.04,"end":226.0,"text":"כן, אבל אני דווקא מרוזה, תשמע, זה לא רע"},{"start":226.0,"end":229.0,"text":"היה לי כלב פודל, טי מכוח כזה, קאגי, פי, פי, שתי, שתגע"},{"start":229.0,"end":232.0,"text":"לא ידעתי מה לעשות איתו, תראה, הפכו לי אותו לטלוויזיה"},{"start":232.0,"end":235.0,"text":"טלוויזיה, ממש טלוויזיה אמיתית"},{"start":235.0,"end":237.0,"text":"רק, מה הבעיה, אם כבר הם עושים עבודה"},{"start":237.0,"end":239.0,"text":"שעשו עד הסוף, למה הפכו את זה לשחור לבן"},{"start":239.0,"end":242.0,"text":"כי בין אם את היו עושים צבעונים, חיבור לכבלים"},{"start":242.0,"end":246.32,"text":"מה?"},{"start":246.32,"end":260.3,"text":"צריך לקרוא לה כסף, 250 אלף דולר, ארחו ככה סתם"},{"start":260.3,"end":262.3,"text":"בופ, הלכו, נעלמו כל הכסף"},{"start":262.3,"end":264.65,"text":"גם אדוני קורבן של המחשפות"},{"start":264.65,"end":267.96,"text":"איזה מחשפות? הבורסה?"},{"start":267.96,"end":274.38,"text":"והרי הדייה שהגיעה זה עתה"},{"start":274.38,"end":276.63,"text":"על פי השמועות שהגיעו למערכת"},{"start":276.63,"end":279.63,"text":"מסתבר שהמחשפות חטפו בין הרובה"},{"start":279.63,"end":282.82,"text":"אותו בין הרובה מסכן וחסר עונים"},{"start":282.82,"end":285.82,"text":"הינו אישיות ידועה ומוכרת לציבור המקומי"},{"start":285.82,"end":289.0,"text":"אך זהותו האמיתית, תרם נחשפה"},{"start":289.0,"end":295.15,"text":"נחשפה"},{"start":295.15,"end":297.15,"text":"נבשל אותו"},{"start":297.15,"end":299.15,"text":"הוא ברדו"},{"start":299.15,"end":301.15,"text":"יש לי"},{"start":301.15,"end":303.15,"text":"יש לי"},{"start":303.15,"end":305.15,"text":"עסקיטו"},{"start":305.15,"end":307.15,"text":"עסקיטו"},{"start":307.15,"end":309.15,"text":"יפנדרלה"},{"start":309.15,"end":311.27,"text":"לא"},{"start":311.27,"end":313.27,"text":"סינדרלה"},{"start":313.27,"end":315.27,"text":"יש לי גם"},{"start":315.27,"end":317.27,"text":"תקשיבו"},{"start":317.27,"end":319.49,"text":"תקשיבו"},{"start":319.49,"end":321.41,"text":"היפיפייה הנרשת"},{"start":321.41,"end":323.83,"text":"היפיפייה הנרדמת"},{"start":323.83,"end":325.83,"text":"נרדמת"},{"start":325.83,"end":327.83,"text":"נרדמת"},{"start":327.83,"end":329.83,"text":"נרדמת"},{"start":329.83,"end":331.89,"text":"יש לי גם משהו נהדר"},{"start":331.89,"end":333.89,"text":"שלגיית ושיבת הגה"},{"start":333.89,"end":335.89,"text":"קומתה? לא"},{"start":335.89,"end":337.89,"text":"שלגייה ושיבת הגמדים"},{"start":337.89,"end":339.89,"text":"הגמדים"},{"start":339.89,"end":341.89,"text":"הגמדים"},{"start":341.89,"end":343.89,"text":"נרדמת"},{"start":343.89,"end":345.89,"text":"נרדמת"},{"start":345.89,"end":347.89,"text":"מה יש לו?"},{"start":347.89,"end":350.4,"text":"הקלברי פין"},{"start":350.4,"end":352.7,"text":"דני שווה ואני"},{"start":352.7,"end":358.0,"text":"תחבר והשתרק"},{"start":358.0,"end":360.0,"text":"נה"},{"start":360.0,"end":369.54,"text":"ערם צח ערב זך"},{"start":369.54,"end":371.57,"text":"שוב אנחנו בחלסטר של ז'וז'ו"},{"start":371.57,"end":373.47,"text":"והפעם, סוף השנה בבתי הספר"},{"start":373.47,"end":375.76,"text":"כל התלמידים המלאונים והלפלפים"},{"start":375.76,"end":377.76,"text":"הגיעו לבית עם תעודות"},{"start":377.76,"end":379.86,"text":"הבן שלי געבה"},{"start":379.86,"end":381.86,"text":"ואמא שלי שיחייה בדיל שיינים ארוכות"},{"start":381.86,"end":383.86,"text":"אש תבח שמו חמצה חמצה שום בצהל"},{"start":383.86,"end":385.86,"text":"ואמא שלי פרצות כל הגוף"},{"start":385.86,"end":387.86,"text":"הבן שלי מה קרה איתו?"},{"start":387.86,"end":389.86,"text":"הכל ולתי מספיק"},{"start":389.86,"end":390.86,"text":"ולתי מספיק"},{"start":390.86,"end":391.86,"text":"ולתי מספיק"},{"start":391.86,"end":392.86,"text":"איך הוא יספיק?"},{"start":392.86,"end":394.86,"text":"הוא עשו כל היום בבשה אקסטנגה"},{"start":394.86,"end":397.86,"text":"אבל מה שהרטיח אותי הייתה המורה שלו"},{"start":397.86,"end":399.92,"text":"המחנכת הלפלפית"},{"start":399.92,"end":401.92,"text":"עם החיגולה דין והקצמות"},{"start":401.92,"end":402.95,"text":"מה אמרה?"},{"start":402.95,"end":404.95,"text":"תבוא מיד לבית ספר לאסיפה"},{"start":404.95,"end":405.95,"text":"בריצה הגיתי"},{"start":405.95,"end":406.95,"text":"חשבתי מה קרה לבן"},{"start":406.95,"end":407.95,"text":"מה עשה הבא לגן?"},{"start":407.95,"end":408.95,"text":"הגיתי לבית ספר"},{"start":408.95,"end":410.95,"text":"כולי מזיע באימא שלי"},{"start":410.95,"end":411.95,"text":"רואה אותי המחנכת"},{"start":411.95,"end":413.95,"text":"עושה לי תשמע שער וריאה"},{"start":413.95,"end":414.95,"text":"אמרתי לה שו"},{"start":414.95,"end":416.95,"text":"אמרה לי הבן שלך"},{"start":416.95,"end":418.95,"text":"אמר לי ליד כל הכיתה"},{"start":418.95,"end":419.92,"text":"מכוערת"},{"start":419.92,"end":421.55,"text":"ישבתי הסתכלתי עליה טוב"},{"start":421.55,"end":423.48,"text":"באמא שלי הוא צודק"},{"start":423.48,"end":424.58,"text":"מכועמת פרצומת לבבון"},{"start":424.58,"end":426.58,"text":"מה זה השפה? מה זה שיוצא אלה? מה זה?"},{"start":426.58,"end":428.58,"text":"באמא שלי בלתי נזבל"},{"start":428.58,"end":429.58,"text":"איך התלמידים ארטיבים?"},{"start":429.58,"end":430.58,"text":"עכשיו אני מבין למה"},{"start":430.58,"end":431.58,"text":"מהפעד"},{"start":431.58,"end":432.58,"text":"באמא שלי הלכתי איתה"},{"start":432.58,"end":433.58,"text":"תפשתי אותה"},{"start":433.58,"end":434.58,"text":"לקחתי אותה לחדר של המנהל"},{"start":434.58,"end":435.58,"text":"אמרתי לו המנהל"},{"start":435.58,"end":436.58,"text":"מכוערת או לא"},{"start":436.58,"end":437.58,"text":"אמר מכוערת"},{"start":437.58,"end":438.58,"text":"אה, הוא שקשוקה"},{"start":438.58,"end":439.58,"text":"מוזר עסקה"},{"start":439.58,"end":441.86,"text":"פעם הבאה שאתה רושם את הילד לבית ספר"},{"start":441.86,"end":443.86,"text":"זכור את הפתגם"},{"start":443.86,"end":446.01,"text":"לא הביישן למד"},{"start":446.01,"end":448.2,"text":"ולא המכוער מלמד"},{"start":448.2,"end":450.32,"text":"ותחשבו על זה"},{"start":450.32,"end":455.14,"text":"כי אבא שלי הוא הכי בעולם"},{"start":455.14,"end":458.17,"text":"אבא שלי הוא את הטוב מכולם"},{"start":458.17,"end":461.17,"text":"ואבא שלי הוא הכי המגניב"},{"start":461.17,"end":463.23,"text":"אבא שלי"},{"start":463.23,"end":465.23,"text":"כמוד, כמוד"},{"start":465.23,"end":467.67,"text":"כן, אם לא אכפת לך"},{"start":467.67,"end":469.67,"text":"לרוז לנו את השאריות"},{"start":469.67,"end":470.67,"text":"אתה יודע בשביל הכלבה"},{"start":470.67,"end":471.64,"text":"אבא"},{"start":471.64,"end":472.64,"text":"מה?"},{"start":472.64,"end":473.91,"text":"אין לנו כלבה"},{"start":473.91,"end":475.08,"text":"שטוק"},{"start":475.08,"end":476.08,"text":"אבל אין לנו כלבה אבא"},{"start":476.08,"end":477.24,"text":"שטוק"},{"start":477.24,"end":478.24,"text":"כמוד"},{"start":478.24,"end":480.24,"text":"אם אפשר להרוז לנו בשביל הכלבה"},{"start":480.24,"end":482.24,"text":"אבל אבא לולי זה עוגר, זה לא כלבה"},{"start":482.24,"end":483.24,"text":"אתה רוצה גלידה אולי?"},{"start":483.24,"end":485.24,"text":"מה גלידה ומה אתה תוכל לך אסור נחול?"},{"start":485.24,"end":487.24,"text":"גלידה אמא אמרה לי בגלל האולקות שלך"},{"start":487.24,"end":489.24,"text":"אמא אמרה לשמור עליך טוב טוב טוב טוב"},{"start":489.24,"end":490.2,"text":"תשטוק אמרתי לך"},{"start":490.2,"end":492.2,"text":"עכשיו אני מבין"},{"start":492.2,"end":494.26,"text":"אתה מבין זה לא בשביל הכלבה"},{"start":494.26,"end":496.26,"text":"זה בשביל אמא שלי"},{"start":496.26,"end":498.26,"text":"הוא תמיד קורא לכלבה והוא גם כושר אותה ברצועות"},{"start":498.26,"end":500.26,"text":"עכשיו אני מבין"},{"start":500.26,"end":502.21,"text":"אשתו"},{"start":502.21,"end":504.21,"text":"אבא מה אתה רוצה? מה בסך הכל נעשה?"},{"start":504.21,"end":506.21,"text":"אנחנו נשתי סודה בכיף"},{"start":506.21,"end":509.21,"text":"ואלת תשים לך כוסית עם סודה לשתייה"},{"start":509.21,"end":511.21,"text":"כי אסור לך הרופא אמר שזה מרגיע לו את היצר"},{"start":511.21,"end":512.21,"text":"הסודה לשתייה"},{"start":512.21,"end":514.21,"text":"אולי אתה רוצה לשירותים?"},{"start":514.21,"end":516.21,"text":"בוא תלך לשירותים שלא יברח לך"},{"start":516.21,"end":518.21,"text":"מה כמו שבורח לך?"},{"start":518.21,"end":519.21,"text":"יש לו דחורים"},{"start":519.21,"end":520.21,"text":"בגלל זה יש לו דחורים"},{"start":520.21,"end":522.21,"text":"הוא קצת אתה מבין"},{"start":522.21,"end":524.21,"text":"אבא שלי הכי רחם בעולם"},{"start":524.21,"end":526.21,"text":"הוא הכי הרחם"},{"start":526.21,"end":528.21,"text":"אבא שלי חתם ערבות לאנשים שהוא לא מכיר"},{"start":528.21,"end":531.21,"text":"ועכשיו אנחנו חייבים ארבע מאות אלף דולר"},{"start":531.21,"end":532.21,"text":"ארבע מאות אלף"},{"start":532.21,"end":534.21,"text":"ובגלל זה אמא גם עובדת בשלוש משרות"},{"start":534.21,"end":536.21,"text":"תשתוק אמרתי לך"},{"start":536.21,"end":537.21,"text":"מה? מה אתה רוצה?"},{"start":537.21,"end":538.21,"text":"תגידי דרך אגב"},{"start":538.21,"end":539.21,"text":"האוטוביאנקי האדומה בחוץ"},{"start":539.21,"end":540.21,"text":"אם אני לא טועה"},{"start":540.21,"end":541.21,"text":"זה לא שלך?"},{"start":541.21,"end":542.36,"text":"בטח"},{"start":542.36,"end":543.36,"text":"אה הנה אבא"},{"start":543.36,"end":544.36,"text":"זה האוטוביאנקי שלו"},{"start":544.36,"end":545.36,"text":"זאת שדפקת בחנייה"},{"start":545.36,"end":546.36,"text":"זה שלו"},{"start":546.36,"end":547.36,"text":"תשתוק"},{"start":547.36,"end":548.36,"text":"תשתוק זו"},{"start":548.36,"end":549.36,"text":"אבל מה תשתוק"},{"start":549.36,"end":550.36,"text":"אני אמרתי לך שאסור לך"},{"start":550.36,"end":551.36,"text":"לנסוע בלי דישיון"},{"start":551.36,"end":552.61,"text":"נכון?"},{"start":552.61,"end":553.57,"text":"מה?"},{"start":553.57,"end":555.73,"text":"אבא הנה השוטר"},{"start":555.73,"end":556.73,"text":"שאבא ניינת בחוץ"},{"start":556.73,"end":558.73,"text":"שאמרת שכל השוטרים מענייקים"},{"start":558.73,"end":559.73,"text":"הנה זה שאמרת"},{"start":559.73,"end":561.73,"text":"איזה מכוער נוהג בניינת"},{"start":561.73,"end":564.73,"text":"אבא נכון כיף לנו היום איזה כיף"},{"start":564.73,"end":567.79,"text":"אבא שלי הוא הכי בעולם"},{"start":567.79,"end":569.79,"text":"אבא שלי הוא אוהב את כולם"},{"start":569.79,"end":571.79,"text":"ורק בגללי הוא..."},{"start":571.79,"end":572.79,"text":"תזוב אותי כבא!"},{"start":572.79,"end":574.55,"text":"אבא, אתה רואה?"},{"start":574.55,"end":575.55,"text":"אתה מתעדבן"},{"start":575.55,"end":576.55,"text":"אמא אמרה שאתה מתעדבן"},{"start":576.55,"end":577.55,"text":"תשתה מהר משהו"},{"start":577.55,"end":579.74,"text":"והייתי צריך אליי"},{"start":579.74,"end":656.28,"text":"יופי איי איי אור, יופי איי אור, יופי איי אור, יופי איי אור."},{"start":656.28,"end":659.63,"text":"I have a rifle, I have a gun."},{"start":659.63,"end":662.55,"text":"I have a rifle, I have a gun."},{"start":662.55,"end":665.57,"text":"This is for killing, this is for fun."},{"start":665.57,"end":668.41,"text":"This is for killing, this is for fun."},{"start":668.41,"end":670.7,"text":"אחת, שתיים, שלוש."},{"start":670.7,"end":673.76,"text":"בשמלה, אדומה ושתי צמות."},{"start":674.92,"end":684.99,"text":"ידה, תמה, יחידה ותמה, עמדה ושאלה, למה, לכל הרי הגש, לכל הרי הרום."},{"start":684.99,"end":689.06,"text":"24, גש למחובה 4, אדב בקולצה כתובה."},{"start":689.06,"end":690.16,"text":"זה בסדר, אני מייד מגיע."},{"start":690.16,"end":722.02,"text":"אדוני, אל תיברח. אדוני, אין לך סיכוי, אני חמוש."},{"start":722.02,"end":728.24,"text":"אדוני, אין לך סיכוי, רדמה, תזרוק את עצמך במושב אחורי, אבל מיד, עכשיו."},{"start":729.37,"end":732.9,"text":"אוקיי, דיכתי למקום, ראיתי את הבן אדם, הכל בסדר."},{"start":732.9,"end":735.67,"text":"לאן אתה צריך, אדוני?"},{"start":735.67,"end":737.24,"text":"גורדון פרישמן."},{"start":737.24,"end":738.91,"text":"20 שקל."},{"start":738.91,"end":741.33,"text":"מה 20 שקל? את מלאה לי 15."},{"start":741.33,"end":743.17,"text":"גורדון פרישמן 20 שקל."},{"start":743.17,"end":743.93,"text":"אז תצאי מונה."},{"start":743.93,"end":744.89,"text":"זה יעלה לך יותר."},{"start":744.89,"end":745.77,"text":"לא אוכפת, אתה מונה."},{"start":745.77,"end":746.55,"text":"קורא מה אני אומר לך."},{"start":746.55,"end":747.73,"text":"אני רוצה לראות, אתה פיל מונה."},{"start":747.73,"end":749.01,"text":"פיל מונה, אתה מלא תקורא."},{"start":749.01,"end":749.71,"text":"20 שקל."},{"start":749.71,"end":750.91,"text":"הנה מונה."},{"start":750.91,"end":751.53,"text":"יפה."},{"start":759.01,"end":767.4,"text":"אחד בשביל כולם. כולם בשביל אחד. אחד בשביל כולם. כולם בשביל אחד."},{"start":796.72,"end":818.5,"text":"יש לי משהו נדר, להקשיב, להקשיב, להקשיב. בבקשה, לוצי הוגן? לא, לוציפר, לוציפר, לוציפר, לוציפר, נגדתי, נגדתי, נגדתי, נגדתי, נגדתי, נגדתי, נגדתי, נגדתי."},{"start":818.5,"end":821.22,"text":"רגע, יש לו, רגע, רגע, יש לו."},{"start":821.22,"end":827.13,"text":"פרדי קרוגר? לא, לא, אני לא יכול לישון. איזה פחד."},{"start":827.13,"end":832.19,"text":"יוק, מפחיד."},{"start":832.19,"end":834.19,"text":"אחו מולד."},{"start":834.19,"end":837.19,"text":"אחו מולד."},{"start":837.19,"end":839.15,"text":"שקת, שקת."},{"start":839.15,"end":844.12,"text":"ערב צاخ, תמיד רציתי להגיד כמו המןחים אנגלימה, אלה הלפ לה في מספן ועיגולה דים."},{"start":844.12,"end":846.12,"text":"להעביר 100 שדורףירסובות."},{"start":846.12,"end":849.12,"text":"אני אגידי די פעם אחת באחד באחד בישבילה, סבבי, מי מי מי מי מי מי מי."},{"start":849.12,"end":850.12,"text":"בסדר?"},{"start":850.12,"end":854.71,"text":"ולבי בקק, ראית אףתר, די, קומרشتز."},{"start":854.71,"end":858.51,"text":"קומרشتز, אה, يعني, פרסובות."},{"start":858.51,"end":860.51,"text":"ביידה, נחרזי נחזור."},{"start":860.51,"end":861.4,"text":"ביי."},{"start":861.4,"end":899.36,"text":"כן, אדוני, זה שקל."},{"start":899.36,"end":901.45,"text":"כן, בבקשה, מה אפשר לעזור לך?"},{"start":901.45,"end":904.45,"text":"אדוני, אל תתייאש כמה זה בצל יבש."},{"start":904.45,"end":906.45,"text":"שקל ארבעים הבצל, אדוני."},{"start":906.45,"end":910.45,"text":"איזה בלגניה, כמה זה עגבניה?"},{"start":910.45,"end":912.45,"text":"שתיים שלושים, עגבניות חממה, זה משהו משהו."},{"start":912.45,"end":916.45,"text":"אדוני, על הכי פגשו, כמה פה עולה קישו?"},{"start":916.45,"end":918.45,"text":"קישויים שלוש שישים, מובחר, מובחר."},{"start":918.45,"end":922.45,"text":"זה יקר בחייך, אתה עשה לי הנחה,"},{"start":922.45,"end":926.45,"text":"כי אני עוד לא מליין, כל דבו חמל מליין."},{"start":927.06,"end":932.35,"text":"אין הנחות, אדוני, אין הנחות. - אדוני, וחיית חרם, שקול לי הוא 1 קילוגרם."},{"start":932.35,"end":937.5,"text":"20 שקל, אדוני. - חסר לך זה לא תרעי, סלמה תהיה בריא."},{"start":937.5,"end":941.64,"text":"כל טוב, להתראות. - תראה לי."},{"start":941.64,"end":945.14,"text":"את יודע איך אני מגיע מפה לדוער? - לדוער?"},{"start":945.14,"end":952.1,"text":"ימין השמאלה וישר, ממולך תראה כיכר, תעקוף אותה משמאל."},{"start":952.1,"end":957.65,"text":"שם תשאל, שם תשאל את ה..."},{"start":957.65,"end":961.76,"text":"שם תשאל, כל איש ואיש. - כל איש ואיש."},{"start":961.76,"end":966.79,"text":"ורק תיזהר בכמיש, בכמיש, שם תשאל, כל איש."},{"start":966.79,"end":968.79,"text":"תראה, תודה."},{"start":968.79,"end":986.73,"text":"הפולניה יקרה, והפעם כיצד נתמודד עם העובדה שהילד רוצה ללכת לקרבי בצבא."},{"start":986.73,"end":990.92,"text":"קודם כל תפנימי, תפנימי סולידי, תפנימי."},{"start":990.92,"end":996.92,"text":"דבר שאני כבר מגיל צעיר להתחיל לתת לו מכות שילמד שאומרים לו גם לא."},{"start":996.92,"end":1002.52,"text":"קוץ מזה שיש גם מכות שמורידות פרופיל, אבל אני לא אמרתי את זה."},{"start":1002.52,"end":1007.52,"text":"באמת בחיי יחסות צורה אני מכירה את כל החבר'ס הקרבים האלה."},{"start":1007.52,"end":1012.52,"text":"גומרים שלוש שנת צבא פייטרים ואחרי זה רוצים לשאול לטיבט."},{"start":1012.52,"end":1018.52,"text":"רוצים לשאול למזרח המוישה גויס הוא רוצה לשאול למזרח אני לא מוכנה אני לא מוכנה."},{"start":1018.52,"end":1026.52,"text":"יתחיל לגדלי פעות בכל מיני טבעות על האוזניים מה זה שמים גיטרות מוזיקה חזקה ועוד בין שתיים לארבע אני לא מוכנה."},{"start":1026.52,"end":1055.51,"text":"אני לא מוכנה שאת מועבל של ג'אקלין בן שתיים לארבע משחק בקדו תצא החוצה תזוז מהממטר התילמד שורים אני אעזמין לך שוטר תתבייש לך אני לא מוכנה אני לא מוכנה והכל מתחיל בפסטיבל הרעד הגועל נפש סייבושה וחרפה אנשים מסתובבים יחפים מגעילים מהשנים חשיש ואני אגיד לך מה עוד משהו הם אחרי זה לא רוצים להתגייס הם לא רוצים ללכת לצבא לא רוצים לתרום למדינה אני לא מוכנה שיוגה ושלי לא יתרום למדינה."},{"start":1055.51,"end":1086.07,"text":"ה... בן שלי יהיה קרבי האבא של הקרבי הוא יהיה פייטר. אלו אלו תרופות בית מרכחת בית מרכחת הכל בשקל אדוני הופה הופה אדון אחד איך אישה יפה בוא תקנה אצלי תרופה גם היום וגם אתמול בוא תקנה פה אקמון רגע אדוני אלו אלו אלו אל תגע לי שם במוקסיפן אתה שומע הכל טוב הלאס בבת שלום אני צריך משהו נגד כאבים."},{"start":1086.07,"end":1116.66,"text":"אצלית תמצא יש גם הפורטה במבצע טוב ואני גם צריך אם יש לך אני צריך דולן אדוני אין בי אשם לא מוכר בלי מרצם יש לי גם פצע פה האמ מוגלק או בציקה יש לי גם טמביוטיקה המחיר הוא לא מוגזם עשר שקל בלי מאם בגשה זה לקוח אמיתי מכוער כמו אשתי"},{"start":1116.66,"end":1118.88,"text":"סלח לי אדוני איפה זה פה הדואר"},{"start":1118.88,"end":1119.81,"text":"דואר"},{"start":1119.81,"end":1122.99,"text":"ימין השמאלה וישר"},{"start":1122.99,"end":1124.99,"text":"ממולך תראה כיקר"},{"start":1124.99,"end":1126.99,"text":"שם תשאל כל איש ואיש"},{"start":1126.99,"end":1128.99,"text":"ורק תיזהר בכביש"},{"start":1128.99,"end":1141.89,"text":"סלח ושוב אנחנו בחלסטרה"},{"start":1141.89,"end":1143.89,"text":"ושוב עם הילדים בחופש"},{"start":1143.89,"end":1145.92,"text":"והפעם קייטניות"},{"start":1145.92,"end":1148.07,"text":"באמא שלי מה זה החרטזיה הקייטניות האלה של הלפלפים"},{"start":1148.07,"end":1150.07,"text":"מה זה? בואו לי קייטנת טבע"},{"start":1150.07,"end":1152.07,"text":"בואו לי קייטנת רכיבה"},{"start":1152.07,"end":1154.07,"text":"ובואו לי קייטנת לפלפיה"},{"start":1154.07,"end":1156.07,"text":"מה זה החרטזיה?"},{"start":1156.07,"end":1158.07,"text":"אמא שלי, הבן שלי לא מוצא את עצמו"},{"start":1158.07,"end":1159.07,"text":"חוזר הבית מדוקה כל יום"},{"start":1159.07,"end":1160.07,"text":"אמא שלי דופק על ראש בקיר"},{"start":1160.07,"end":1161.07,"text":"ואני מצדיק אותו"},{"start":1161.07,"end":1163.07,"text":"מה הם נותנים להם שם?"},{"start":1163.07,"end":1165.07,"text":"הם באים בבוקר כל אלף לפים"},{"start":1165.07,"end":1168.07,"text":"ונותנים להם שוקו ולחמנייה"},{"start":1168.07,"end":1171.07,"text":"ואחר כך נותנים להם לשחק בפלסטלינה"},{"start":1171.07,"end":1174.07,"text":"ולעשות קולות של קופים ופילים"},{"start":1174.07,"end":1176.07,"text":"ולשחק הנחיות"},{"start":1176.07,"end":1177.07,"text":"מה זה החרטה הזה?"},{"start":1177.07,"end":1179.04,"text":"ואם אמא שלי הכל חרטה"},{"start":1179.04,"end":1181.1,"text":"בואו נפתח קייטנת חושק שוקה"},{"start":1181.1,"end":1183.1,"text":"קייטנת ג'וזו ובניו"},{"start":1183.1,"end":1185.1,"text":"ואם אמא שלי זה קייטנת"},{"start":1185.1,"end":1188.1,"text":"מגיע על הבוקר דבר שאום מקבל רסיה ושתי כפות מתעורר"},{"start":1188.1,"end":1190.1,"text":"מגיע מקבל ערוכת עשר"},{"start":1190.1,"end":1191.1,"text":"לא הולך מניה ושוקו"},{"start":1191.1,"end":1194.1,"text":"הוא מקבל קוסקוס וערק זחלאוי"},{"start":1194.1,"end":1196.1,"text":"ושמים לו כזה חריף בקוסקוס"},{"start":1196.1,"end":1198.1,"text":"זה שהוא נכנס לבריכה"},{"start":1198.1,"end":1200.06,"text":"הוא שוטט כל הבריכה מהחריף"},{"start":1200.06,"end":1201.07,"text":"נגמר המים בבריכה"},{"start":1201.07,"end":1203.07,"text":"הילדים יוצאים הבית מבסוטים"},{"start":1203.07,"end":1204.07,"text":"יש שיעורים מיוחדים"},{"start":1204.07,"end":1206.07,"text":"איך לשמור האותו שלא יגנבו לו טסות"},{"start":1206.07,"end":1209.07,"text":"איך שומרים על האותו לא לשרות את הצבע"},{"start":1209.07,"end":1211.07,"text":"שיעורים חינוכים שהילד יצא בפשוט"},{"start":1211.07,"end":1214.07,"text":"איך עושים פן, איך עושים ספורט סטייל אלגנט"},{"start":1214.07,"end":1216.07,"text":"רבותיי, זה דברים חשובים"},{"start":1216.07,"end":1221.07,"text":"ותחשבו על זה לפני שאתם שולחים את הילד שלכם לאיזה לפלפיה כזאת"},{"start":1221.07,"end":1223.26,"text":"תחשבו על זה"},{"start":1223.26,"end":1230.47,"text":"אני כל כך אוהבת רגל קרושה"},{"start":1230.47,"end":1232.47,"text":"מה רק רגל"},{"start":1232.47,"end":1236.47,"text":"אתה עושה זה, אתה עושה זה הרגל אחת"},{"start":1236.47,"end":1238.47,"text":"יש לי יש לי יש לי"},{"start":1238.47,"end":1240.47,"text":"יש לי"},{"start":1240.47,"end":1242.47,"text":"בבקשה תקשיבי תקשיבי"},{"start":1242.47,"end":1243.47,"text":"תקשיבי"},{"start":1243.47,"end":1245.47,"text":"אברקדה טוב"},{"start":1245.47,"end":1247.47,"text":"לא אברקדה רע"},{"start":1247.47,"end":1249.47,"text":"לא"},{"start":1249.47,"end":1255.47,"text":"תקשיבו תקשיבו תקשיבו"},{"start":1255.47,"end":1257.47,"text":"תקשיבו תקשיבו"},{"start":1257.47,"end":1260.05,"text":"הוקוס שווקוס"},{"start":1260.05,"end":1262.01,"text":"הוקוס פוקוס"},{"start":1262.01,"end":1264.01,"text":"הוקוס פוקוס"},{"start":1264.01,"end":1266.01,"text":"תקשיבו"},{"start":1266.01,"end":1268.01,"text":"רגע רגע יש לי גם"},{"start":1268.01,"end":1272.21,"text":"יש לי גם, תקשיבו, תקשיבו, רק רגע, רגע תני לדבר."},{"start":1272.21,"end":1277.96,"text":"אופן סזר רא? לא, אופן סזר בי."},{"start":1277.96,"end":1282.99,"text":"וזמר רא, וזמר רא, וזמר רא, וזמר רא."},{"start":1282.99,"end":1286.99,"text":"יש לי, יש לי, יש לי, יש לי."},{"start":1286.99,"end":1288.01,"text":"רגע, יש לו."},{"start":1288.01,"end":1292.26,"text":"תיקי תיקוץ, משונוב קונץ."},{"start":1292.26,"end":1298.52,"text":"לא, תיקי תיקוץ, ברבה בקונץ."},{"start":1298.52,"end":1300.03,"text":"אה?"},{"start":1300.03,"end":1302.28,"text":"תיקי תיקוץ, ברבה בקונץ."},{"start":1302.28,"end":1307.28,"text":"תיקי תיקוץ, ברבה בקונץ."},{"start":1307.28,"end":1309.28,"text":"תיקי תיקוץ, ברבה בקונץ."},{"start":1309.28,"end":1310.28,"text":"לא!"},{"start":1310.28,"end":1315.72,"text":"אה לא!"},{"start":1315.72,"end":1318.7,"text":"לאן ברחתם, איפה אתם?"},{"start":1318.7,"end":1321.15,"text":"אה לא!"},{"start":1321.15,"end":1324.48,"text":"יש לי, יש לי, יש לי, יש לי, יש לי."},{"start":1324.48,"end":1327.24,"text":"ג'ו, בסנג'ר!"},{"start":1327.24,"end":1328.4,"text":"לא!"},{"start":1328.4,"end":1329.43,"text":"ג'ו, קים!"},{"start":1329.43,"end":1335.82,"text":"יש לי, יש לי, אך ברגל!"},{"start":1335.82,"end":1336.73,"text":"לא!"},{"start":1336.73,"end":1339.08,"text":"אך בראש!"},{"start":1339.08,"end":1344.39,"text":"העיר תל אביב, מדינת ישראל והעולם כולו"},{"start":1344.39,"end":1348.65,"text":"ולא חייבים להכיר תודה לאותו משיעם היסטורי"},{"start":1348.65,"end":1351.65,"text":"אך הוא מצידו, יישאר על מוני כל חייו"},{"start":1351.65,"end":1355.96,"text":"וזהותו הבדויית, יישאר חידה סתומה לעד"},{"start":1355.96,"end":1360.42,"text":"אני כה בטוח!"},{"start":1360.42,"end":1362.03,"text":"לא!"},{"start":1362.03,"end":1363.97,"text":"אני קשוט!"},{"start":1363.97,"end":1369.69,"text":"כאן ג'ודי לא צהרונוב, רוט שחמורוב, קרפין סממה, גרין סוכניק,"},{"start":1369.69,"end":1371.69,"text":"האנס קריסטיאן אנדרסן"},{"start":1371.69,"end":1375.42,"text":"יש לי, יש לי, וושינגטון."}]