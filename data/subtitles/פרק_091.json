[{"start":21.22,"end":30.3,"text":"אבישיר שאול"},{"start":30.3,"end":31.32,"text":"עזור אותך מהר"},{"start":31.32,"end":32.54,"text":"שאול אבישיר"},{"start":32.54,"end":34.13,"text":"לא זרוק נושא"},{"start":34.13,"end":36.11,"text":"עקום דיסטור"},{"start":36.11,"end":40.11,"text":"בואו כולם יחד לראות עקום הדיסטור"},{"start":40.11,"end":42.61,"text":"יש מקום לכולם, לא צריך לעמוד בתור"},{"start":42.61,"end":46.21,"text":"יש גם הובי, גם גיל, אסף יני וגם ליאור"},{"start":46.21,"end":49.18,"text":"או אלא לראות אותם, לחטוף פריחה בעור"},{"start":49.18,"end":56.51,"text":"אתה יכול לעשות את זה יותר פושיה"},{"start":56.51,"end":62.55,"text":"אתה יכול להביא שוודיות שיבואו לקומדיסטור"},{"start":62.55,"end":66.57,"text":"יבואו ככה, ילטפו את כולם בעיקר את רובי"},{"start":66.57,"end":67.81,"text":"תעשה כזה אחד"},{"start":67.81,"end":72.28,"text":"לראות הקומדיסטור אני ממליץ"},{"start":72.28,"end":76.2,"text":"תהיינה שם הרבה שוודיות כאלה שירחה ממעריץ"},{"start":76.2,"end":79.62,"text":"לכל אחד תהיה טוסיק, לכל אחד תהיה ציץ"},{"start":79.62,"end":81.5,"text":"את הרייטינג זה בטח יקפיא"},{"start":81.5,"end":96.21,"text":"לקחת תוכנית ממה, עשית אותה פושעת"},{"start":96.21,"end":100.95,"text":"מתי יבוא התוכנית הזאת עם השוודיות עכשיו?"},{"start":100.95,"end":103.47,"text":"תרגע, תרגע, אל תעשה מהומות"},{"start":103.47,"end":106.89,"text":"הקומדיסטור לא עכשיו, אלא מיד בתום הפרסומות"},{"start":106.89,"end":110.69,"text":"תביא גם שוודיות בפרסומות"},{"start":110.69,"end":111.69,"text":"עזוב לך בהכן"},{"start":111.69,"end":117.9,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות"},{"start":117.9,"end":123.39,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט"},{"start":123.39,"end":129.23,"text":"שמות האנשים והמקומות שונו לצורך העלילה"},{"start":129.23,"end":130.65,"text":"ומאתה הם נקראים"},{"start":130.65,"end":131.77,"text":"הקומית"},{"start":131.77,"end":166.97,"text":"פקות גאים להציג פרק נוסף בסדרה הקומית הישראלית הגרועה ביותר"},{"start":166.97,"end":169.25,"text":"משפחת ישראלית"},{"start":169.25,"end":204.05,"text":"לא במוחתרם, אני אצכה לצאת לנסיבה"},{"start":204.05,"end":207.28,"text":"אגזמה, את במיטה בשעה עשר"},{"start":207.28,"end":209.9,"text":"זה עשרה, מה כל כך מוקדם, אבא?"},{"start":209.9,"end":213.12,"text":"כי ואחת עשרה צריכה לצאת מהמטה ולחזור הביתה"},{"start":213.12,"end":222.16,"text":"תגיד, למה אתה צריך ראש כל כך גדול שיש לך מוח מוגלתי כל כך קטן?"},{"start":222.16,"end":226.92,"text":"באמת, יציג, ולמה אתה צריך תחתונים אקסטרלארד?"},{"start":226.92,"end":235.64,"text":"דומן, אולי במקום לדבר שטויות אבית ארוחת הערב הצמחונית שאת הכנת לנו?"},{"start":235.64,"end":238.85,"text":"האמת היא שלא הייתי צריכה להכין כלום"},{"start":238.85,"end":240.07,"text":"אודי תסביר להם?"},{"start":240.07,"end":240.97,"text":"אוי ואבוי"},{"start":240.97,"end":242.79,"text":"אז זהו, אני המצאתי מכונת טלפתיה"},{"start":242.79,"end":244.79,"text":"כל מה שצריך לעשות זה לחשוב על אוכל"},{"start":244.79,"end":246.79,"text":"ועד המכונה מכינה לך"},{"start":246.79,"end":248.79,"text":"ומגישה לך אותו"},{"start":248.79,"end":251.27,"text":"הנה אני אפיל אותה"},{"start":251.27,"end":253.79,"text":"עכשיו אני אפישב על ארוחה צמחונית"},{"start":253.79,"end":258.64,"text":"זה עובר תקווה לה"},{"start":258.64,"end":260.92,"text":"אם זה ארוחה צמחונית"},{"start":260.92,"end":262.92,"text":"אני מעדיף ללכת לשכונת התקווה לה"},{"start":262.92,"end":265.04,"text":"ולהזמין שיפודים"},{"start":265.04,"end":267.04,"text":"הופלה"},{"start":267.04,"end":269.04,"text":"אבא איך אפשר שיפודים בלי פיטות?"},{"start":269.04,"end":271.69,"text":"פיטות"},{"start":271.69,"end":275.69,"text":"וואו רודי, הדבר הזה תופק כמו שוויצרי"},{"start":275.69,"end":277.69,"text":"כמו שעון שוויצרי זיבה"},{"start":277.69,"end":282.3,"text":"ועכשיו תשתקי ותפני לאמא לחשוב מה היא רוצה לאכול"},{"start":282.3,"end":284.39,"text":"משהו עסיסי כזה"},{"start":284.39,"end":291.57,"text":"טוב, הרי"},{"start":291.57,"end":295.84,"text":"אברן פניטה, קיבלת הסטייק"},{"start":295.84,"end":297.81,"text":"בפיטה"},{"start":297.81,"end":300.1,"text":"ניילון"},{"start":300.1,"end":302.1,"text":"איזה גניבה, שושות הארים"},{"start":302.1,"end":304.32,"text":"אגזמות קטנות"},{"start":304.32,"end":306.32,"text":"ואז אתכם לעזור למוגלה הזאת"},{"start":306.32,"end":308.32,"text":"ביחד לאכול את אלפרד"},{"start":308.32,"end":310.32,"text":"רק אל תשכחו להשאיר עצמות לכלבים"},{"start":310.32,"end":312.38,"text":"האמת אבא"},{"start":312.38,"end":314.38,"text":"אני חשבתי על משהו דומה לאלפרד"},{"start":314.38,"end":316.38,"text":"רק יותר גדול"},{"start":316.38,"end":316.48,"text":"מתוקה"},{"start":316.38,"end":318.54,"text":"אלפרד יש רק אחד"},{"start":318.54,"end":320.54,"text":"וטוב שכך"},{"start":320.54,"end":323.55,"text":"באמת?"},{"start":323.55,"end":324.61,"text":"כן"},{"start":324.61,"end":325.61,"text":"אלפרד יש רק אחד?"},{"start":325.61,"end":326.61,"text":"כן"},{"start":326.61,"end":328.44,"text":"כן"},{"start":328.44,"end":330.44,"text":"עכשיו מה מצקיק פה?"},{"start":330.44,"end":333.46,"text":"בו"},{"start":333.46,"end":347.87,"text":"בו"},{"start":347.87,"end":348.87,"text":"בו"},{"start":348.87,"end":349.87,"text":"בו"},{"start":349.87,"end":350.87,"text":"בו"},{"start":350.87,"end":354.87,"text":"משפחת ישראליה דגנרטים תכירו את אחי התאום איז'וס"},{"start":354.87,"end":355.87,"text":"איז'וס"},{"start":355.87,"end":363.08,"text":"להכי מורתדיר הפניתה קיבלת סטייק בנילון במיקרו"},{"start":363.08,"end":365.08,"text":"איזה גנבה"},{"start":365.08,"end":366.08,"text":"נעלדינגי"},{"start":366.08,"end":367.08,"text":"נעלדינגי"},{"start":367.08,"end":368.08,"text":"אופה"},{"start":368.08,"end":369.08,"text":"תגידו"},{"start":369.08,"end":372.34,"text":"איך זה יכול להיות שאתם אחים תאומים"},{"start":372.34,"end":375.53,"text":"שאחד נראה כמו זבוב בדיאטה"},{"start":375.53,"end":378.53,"text":"והשני נראה כמו ממוטה בקונדיטוריה"},{"start":378.53,"end":381.53,"text":"אתה לא הבנת"},{"start":381.53,"end":383.62,"text":"זה בגלל שאנחנו לא מאותו אבא"},{"start":383.62,"end":384.53,"text":"מה?"},{"start":384.53,"end":386.62,"text":"אבל לעומת זאת גם לא מאותו אמא"},{"start":386.62,"end":387.62,"text":"איזה גנבה"},{"start":387.62,"end":389.62,"text":"נעלדינגי"},{"start":389.62,"end":391.62,"text":"רגע אני לא מבינה"},{"start":391.62,"end":393.62,"text":"למה אתם קוראים לעצמכם אחים"},{"start":393.62,"end":395.62,"text":"את לא מבינה מדון"},{"start":395.62,"end":399.62,"text":"זה בגלל שאנחנו אחים מצחיקים מה שיש"},{"start":399.62,"end":400.62,"text":"איזה גנבה"},{"start":400.62,"end":401.62,"text":"נעלדינגי"},{"start":401.62,"end":402.62,"text":"נעלדינגי"},{"start":402.62,"end":403.62,"text":"חסטארים"},{"start":403.62,"end":404.62,"text":"איי איי איי"},{"start":404.62,"end":407.73,"text":"אז למה אלפו את אמר אך תאום?"},{"start":407.73,"end":411.24,"text":"לא, את לא אמן בובה"},{"start":411.24,"end":413.24,"text":"זה לא אך תאום"},{"start":413.24,"end":415.2,"text":"זה אך תאום"},{"start":415.2,"end":417.2,"text":"אך תאום זה בגלל שאני צ'בוד"},{"start":417.2,"end":419.2,"text":"נתגנבה"},{"start":419.2,"end":421.2,"text":"רגע רגע את אני לא הבנתי"},{"start":421.2,"end":423.2,"text":"אתם לא מאות המשפחה?"},{"start":423.2,"end":424.2,"text":"תשמע ציפופו"},{"start":424.2,"end":427.2,"text":"פעם היינו שהיינו צינוקות"},{"start":427.2,"end":429.2,"text":"היינו משפחת היונקים"},{"start":429.2,"end":432.2,"text":"אחר כך גדלנו והיינו משפחת הזוכלים"},{"start":432.2,"end":436.2,"text":"ועכשיו אנחנו משפחת מורטדלה"},{"start":436.2,"end":446.07,"text":"אופה אתם מצחיקים אתם"},{"start":446.07,"end":448.07,"text":"אתם מצחיקים"},{"start":448.07,"end":450.29,"text":"אודי אודי בוא תקשיב משהו"},{"start":450.29,"end":452.32,"text":"האחים רייט הם בנו מטוסים"},{"start":452.32,"end":454.53,"text":"האחים גרים כתבו אגדות"},{"start":454.53,"end":456.59,"text":"האחים מרקס צילמו סרטים"},{"start":456.59,"end":458.59,"text":"האחים פלדמן פתחו לגריה פה"},{"start":458.59,"end":460.59,"text":"ואחים יעקב יסגלו להם אותי"},{"start":460.59,"end":465.62,"text":"ועוד האחים האלה הם מצחיקים"},{"start":465.62,"end":467.62,"text":"מצחיקים כמו צ'ורבא ומשבר"},{"start":467.62,"end":469.62,"text":"לקרדה ודימוס"},{"start":469.62,"end":470.62,"text":"יקרא מצוננת"},{"start":470.62,"end":472.62,"text":"כבב עם פטריות מהרגליים"},{"start":472.62,"end":473.62,"text":"ממליגה ביוטה"},{"start":473.62,"end":474.62,"text":"חושבר על הידה"},{"start":474.62,"end":475.62,"text":"כן?"},{"start":475.62,"end":476.62,"text":"כן!"},{"start":476.62,"end":477.62,"text":"כן!"},{"start":477.62,"end":478.59,"text":"כן!"},{"start":478.59,"end":480.59,"text":"ותקפוץ לסטנגה בשבת"},{"start":480.59,"end":482.59,"text":"זה לא חי, אתם שניים נגד אחד"},{"start":482.59,"end":484.75,"text":"זה בסדר, אתה תהיה שואר מהופך"},{"start":484.75,"end":486.75,"text":"לא רוצה להיות שואר, אני לא רוצה"},{"start":486.75,"end":488.75,"text":"רק תשמע, תשמע, תרגע"},{"start":488.75,"end":490.75,"text":"למה תעצבני, באמת תנשום קצת"},{"start":490.75,"end":492.75,"text":"את הטבע, אל תרגע תקחמוני"},{"start":492.75,"end":494.75,"text":"בקייקה, תשמע, אני בסך הכל"},{"start":494.75,"end":496.75,"text":"באת פה ליום יומיים אצל אלפרד"},{"start":496.75,"end":498.75,"text":"אני כבר שכרתי דירה משלי"},{"start":498.75,"end":500.75,"text":"אני עובר לשמות אותו"},{"start":500.75,"end":502.91,"text":"מזל טוב, שיהיה בשעה טובה"},{"start":502.91,"end":504.91,"text":"אני ממש שמח בשבילך"},{"start":504.91,"end":506.91,"text":"תודה רבה לך, לבקשה"},{"start":506.91,"end":508.91,"text":"מה מצחיק פה?"},{"start":508.91,"end":510.91,"text":"אלפרד, אמר לי שאתה מכיר פה"},{"start":510.91,"end":512.83,"text":"את בל הדירה ממול"},{"start":512.83,"end":514.91,"text":"אולי אתה יכול לדבר איתו"},{"start":514.91,"end":516.89,"text":"יעשה לי הנחה בסקאר דירה?"},{"start":516.89,"end":519.07,"text":"לא!"},{"start":519.07,"end":531.0,"text":"קלום לך ברוך הבא לציון פקה להפקות"},{"start":531.0,"end":534.0,"text":"המשרד שממוקם כאן בתוך הקולנוע של ציון"},{"start":534.0,"end":536.0,"text":"אני ציוני מאוד תשמע"},{"start":536.0,"end":539.22,"text":"הבעיה היא כזאת אני כבר עשר שנים עושה סרטים"},{"start":539.22,"end":542.22,"text":"אף אחד לא בא לראות אותם, אתה מבין אין קהל"},{"start":542.22,"end":546.34,"text":"יש בעיה רק הערב שני כרטיסים הזמינו זה הכל"},{"start":546.34,"end":550.57,"text":"שלום ציון פקה להפקות מתבר ציון"},{"start":550.57,"end":553.43,"text":"למה לבטל?"},{"start":553.43,"end":556.03,"text":"כולה שני כרטיסים למו..."},{"start":556.03,"end":557.03,"text":"יאללה כרטיס אחד עלינו"},{"start":557.03,"end":560.31,"text":"טוב יאללה בסדר"},{"start":560.31,"end":563.75,"text":"הבנת מה הבעיה?"},{"start":563.75,"end":564.78,"text":"לא עם עבודה"},{"start":564.78,"end":566.94,"text":"אין לי מזכורות לשלם"},{"start":566.94,"end":568.22,"text":"לא לצוות"},{"start":568.22,"end":569.22,"text":"לא לצלמים"},{"start":569.22,"end":570.22,"text":"לא לנשי סאונד"},{"start":570.22,"end":571.22,"text":"לא לבמיי"},{"start":571.22,"end":572.22,"text":"וגם לא לשחקנים"},{"start":572.22,"end":574.22,"text":"אני רוצה שתארגן לי צוות"},{"start":574.22,"end":576.28,"text":"הכי מצומצם שאני יכול"},{"start":576.28,"end":578.28,"text":"שיהיה לי כמה משפחות תוצאות"},{"start":578.28,"end":579.41,"text":"מה את אומרת?"},{"start":579.41,"end":580.41,"text":"אתה יכול לעשות את זה?"},{"start":580.41,"end":581.41,"text":"אוכל ניסי משכילה"},{"start":581.41,"end":582.41,"text":"לחול לעשות את זה רדול"},{"start":582.41,"end":583.41,"text":"לחול"},{"start":583.41,"end":584.47,"text":"יאללה בהצלחה"},{"start":584.47,"end":585.47,"text":"עשינו עסק"},{"start":585.47,"end":586.47,"text":"עשינו עסק"},{"start":586.47,"end":587.88,"text":"שרעות"},{"start":587.88,"end":599.96,"text":"יאללה חבר'ה"},{"start":599.96,"end":600.96,"text":"יאללה חבר'ה"},{"start":600.96,"end":605.42,"text":"תודה רבה. תודה רבה. תודה רבה."},{"start":605.42,"end":612.08,"text":"תודה רבה. תודה רבה."},{"start":612.08,"end":612.18,"text":"תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה. תודה רבה."},{"start":612.08,"end":639.01,"text":"תודה רבה. תודה רבה."},{"start":639.01,"end":641.01,"text":"תודה רבה, תודה רבה."},{"start":641.01,"end":642.01,"text":"תודה רבה."},{"start":642.01,"end":643.01,"text":"תודה רבה."},{"start":643.01,"end":643.98,"text":"תודה רבה."},{"start":643.98,"end":644.98,"text":"תודה רבה."},{"start":644.98,"end":645.98,"text":"תודה רבה."},{"start":645.98,"end":646.98,"text":"תודה רבה."},{"start":646.98,"end":647.98,"text":"תודה רבה."},{"start":647.98,"end":648.98,"text":"תודה רבה."},{"start":648.98,"end":649.98,"text":"תודה רבה."},{"start":649.98,"end":650.98,"text":"תודה רבה."},{"start":650.98,"end":651.98,"text":"תודה רבה."},{"start":651.98,"end":652.98,"text":"תודה רבה."},{"start":652.98,"end":653.98,"text":"תודה רבה."},{"start":653.98,"end":656.09,"text":"תודה רבה."},{"start":656.09,"end":657.42,"text":"תודה רבה."},{"start":657.42,"end":659.95,"text":"תודה רבה."},{"start":659.95,"end":660.95,"text":"תודה רבה."},{"start":660.95,"end":661.95,"text":"תודה רבה."},{"start":661.95,"end":662.95,"text":"תודה רבה."},{"start":662.95,"end":663.95,"text":"תודה רבה."},{"start":663.95,"end":664.95,"text":"תודה רבה."},{"start":664.95,"end":665.95,"text":"תודה רבה."},{"start":665.95,"end":666.95,"text":"תודה רבה."},{"start":666.95,"end":667.95,"text":"תודה רבה."},{"start":667.95,"end":669.07,"text":"תודה רבה."},{"start":669.07,"end":670.1,"text":"תודה רבה."},{"start":670.1,"end":674.98,"text":"שדר, ארידו! אחלה, אחלה, אופי, כל הכבוד, אורח, אופי."},{"start":674.98,"end":677.48,"text":"עכשיו, רשע, חניס, תחניס הרשע."},{"start":677.48,"end":681.11,"text":"Well, you two won't live so long."},{"start":681.11,"end":682.33,"text":"סכה."},{"start":682.33,"end":685.37,"text":"זה ערוב בקוף. ערוב בטוב."},{"start":685.37,"end":689.97,"text":"איך היה? שדר זה!"},{"start":689.97,"end":699.47,"text":"ביי."},{"start":699.47,"end":704.48,"text":"אה, קל! תחפי, אחלה, סרט, כל הכבוד חבר'ה, כל הכבוד מסכילה, אופי."},{"start":704.48,"end":708.48,"text":"תראו נשמח, תראו למקום הרקל בכל אודיומיים, אופי, אופי."},{"start":708.48,"end":738.76,"text":"קלנית, מה רכפת? תגשי לי שיר, יאללה. כן לציפור בין העצים ובכן לשלוש בצים, ובכל בצה, הספנתאיר. יושן לא הפוח, הפוח זהיר. וואו. איזה מצמרר. איזה משורר. איזה חיים. איזה נחמן. איזה ביאליק. איזה שלוש בצים. איזה גבר'י. וואו. אלק, וואו. את לא בת מה יש בכל בצה. אלק, אני לא הבנתי מה יש בכל בצה. מה? אלק, אני לא הבנתי. מה?"},{"start":738.76,"end":768.76,"text":"נו. אלק, אני לא הבנתי. נו. נו, מה יש? פגרת, כתוב. ובכל בצה, אספנטאיר. אספנטאיר זה סוג של שלדג. זה ידוש נוני. וואו, מאיפה הולך? אני עושה עבודה על חיו ומוטו באודו ביבו. אז מה? גם אני עושה עבודה על שרניחובסקי באודו ביבו. אלק, על שרניחובסקי. את לא יודעת ספרות. אז מה? ואת לא יודעת חשבו. אז מה? אז מה? תגידו. סליחה, איפה זה רחוב ביאליק? ביאליק, אתה הולך ימינה. כן."},{"start":768.76,"end":805.17,"text":"ביאליק ימינה. אחרת את איפה זה ביאליק. אליק, אני לא יודעת איפה זה ביאליק. מי? אליק, אני לא יודעת איפה. נו. נו, איפה זה? איזה מפגרים, זה מה זה בסיסי? רחוב ביאליק, זה נגיד, אתה הולך כל הרחוב. כן. אתה עולה במעלית, ואת רוספן תאיר? אז זה זה. תודה רבה. וואו, מאיפה הולך? ממפה תאיר לרווחת התושב. וואו. קלני? מה, רכפת. על מה את חושבת? את זוכרת זה ששאל איפה רחוב ביאליק?"},{"start":805.17,"end":843.51,"text":"חלק? נראה לי נדלק עליי. חלק עלייך? נראה לי נדלק עליי. אז מה, גם עליי הוא נדלק. וואוי. איזה טלמסר? לא טלמסר. טלפתיה. רגע, תגידי, את הרז תבורמוליקוס. כן, אישי החביב. יש הכל בפנים. כן, בעלי היקר. אח, חשת חיל מי המצא ורחוק מבנני מכרה. אח, איזה אישה, איזה אישה. רגע, את יודעת ליפת שאנחנו נוסעים והוא לא בא?"},{"start":843.51,"end":873.31,"text":"לא, הייתי בתוכה שאתה אמרת לו. לא נכון. אני מצטערת, הייתי בתוכה שאמרת לו. אוי ואבוי. יפת, יפת, בוא, בוא, בוא רגע, בוא. רק תודיע לו את זה באדינות, הוא מאוד רגיש לאחרונה. או, בוקר טוב, יפת. בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר, בוקר. יפת, יש משהו שלא סיפרנו לך. אנחנו נוסעים. אנחנו נוסעים לפידים."},{"start":873.31,"end":878.31,"text":"בלילות האפלים, לא. לא סתם נוסעים, נוסעים לפלמה דמיורקה."},{"start":878.31,"end":890.34,"text":"פלמה דמיורקה, קוו, קוו, קוו, קוו, עדסים עוד ריקות, ריקות ריקות ריקות ריק. ולא, ולא, ולא, ולא לוקחים אותך, ולא, לא לוקחים אותך."},{"start":890.34,"end":893.23,"text":"אבל למה אתם לוקחים אותי?"},{"start":893.23,"end":897.38,"text":"יפת, אתה לא יכול לבכות, אתה פשוט לא יכול לבוא איתנו יחד."},{"start":897.38,"end":902.51,"text":"יחד, כל הדרך, יחד, לוקחים."},{"start":902.51,"end":909.5,"text":"לא, לא, לא, לא, יפת, יפת, באמת, עוד מעט יבוא סבא, הוא יבוא וישגיח עליך."},{"start":909.5,"end":916.23,"text":"מי זה דופק בדלת? גוסטלה גוסטלה גוסטלה גוסטלה. מי זה דופק קלחלוני?"},{"start":916.23,"end":918.23,"text":"אוי, אלה זה סבא!"},{"start":918.23,"end":923.23,"text":"סבא בא, אבא בא, אריה מכבר סבא בא, על אנו מכנת."},{"start":923.23,"end":926.44,"text":"שלום!"},{"start":926.44,"end":932.43,"text":"שלום למושבת, שלום למושבת, שלום לך, שבת ושבת!"},{"start":932.43,"end":934.52,"text":"אני לא רוצה להישאר עם סבא, די!"},{"start":934.52,"end":940.52,"text":"די דיינו, די דיינו, דיינו, דיינו, דיינו, דיינו, דיינו, דיינו, דיינו, דיינו!"},{"start":940.52,"end":943.52,"text":"יש לו כל מעצבן ועל כל מילה שאני אומר הוא שר שיר."},{"start":943.52,"end":946.52,"text":"שיר הוא שיר, אמן."},{"start":946.52,"end":949.93,"text":"שיר הוא שיר, אמן."},{"start":949.93,"end":953.93,"text":"ונגמי שאת תגמלו עבודה."},{"start":953.93,"end":954.88,"text":"שיר."},{"start":954.88,"end":958.29,"text":"אה."},{"start":958.29,"end":959.67,"text":"אה."},{"start":959.67,"end":960.67,"text":"אה."},{"start":960.67,"end":961.67,"text":"משגע אותי."},{"start":961.67,"end":962.8,"text":"אז תשגע אותו בחזרה."},{"start":962.8,"end":965.8,"text":"מה יש? הוא משגע אותך תשגע אותו רוב הזמן הוא בסדר."},{"start":965.8,"end":967.71,"text":"רוב הזמנת אשתי."},{"start":967.71,"end":969.92,"text":"ואני מחוטרבך."},{"start":969.92,"end":972.02,"text":"חיכינו תשעבא."},{"start":972.02,"end":974.02,"text":"שי ילדת בעצב."},{"start":974.02,"end":978.81,"text":"פה זה עניין הכלם."},{"start":978.81,"end":981.99,"text":"פה בך שמכם דתבות."},{"start":981.99,"end":985.08,"text":"תתגשם לכל התקבות."},{"start":985.08,"end":988.07,"text":"פה נחי ופה ניצור."},{"start":988.07,"end":989.07,"text":"תודה רבה."},{"start":1022.67,"end":1023.67,"text":"תודה רבה."},{"start":1063.74,"end":1064.83,"text":"אני אוהב אותך."},{"start":1064.83,"end":1066.4,"text":"יאללה, בוא נגור."},{"start":1066.4,"end":1068.59,"text":"יאללה, בוא נתניף קצת, מה יש?"},{"start":1068.59,"end":1077.28,"text":"הלו?"},{"start":1077.28,"end":1078.28,"text":"שלום."},{"start":1078.28,"end":1079.31,"text":"שלום."},{"start":1079.31,"end":1083.31,"text":"תראה, אתה לא מכיר אותי, אני זאת ההיא שהולכת עם אשתך למספרה."},{"start":1083.31,"end":1084.35,"text":"נו."},{"start":1084.35,"end":1087.4,"text":"אז תדע לך שאתמול היא לא בעל המספרה."},{"start":1087.4,"end":1092.4,"text":"נדמה לי, זאת אומרת, אני חושבת שהיא הלכה לבית מלון עם דוד, החבר שלך."},{"start":1092.4,"end":1095.49,"text":"תודה, תודה שאת אומרת לי את זה."},{"start":1095.49,"end":1097.49,"text":"תגידי, איך אמרת שקוראים לך?"},{"start":1097.49,"end":1100.49,"text":"עזוב, לא משנה, אני זאת ההיא שהולכת עם אשתך למספרה."},{"start":1100.49,"end":1102.49,"text":"אוקיי, תודה רבה."},{"start":1102.49,"end":1103.52,"text":"בבקשה."},{"start":1103.52,"end":1106.17,"text":"ביי ביי."},{"start":1106.17,"end":1108.56,"text":"אך דוויד, דוויד."},{"start":1108.56,"end":1110.77,"text":"באמת יכול להיות שאשתי בקדבי."},{"start":1110.77,"end":1113.02,"text":"אבל מה שכואב לי בכל הסיפור הזה,"},{"start":1113.02,"end":1116.16,"text":"שזה היית אתה."},{"start":1116.16,"end":1118.16,"text":"רגע, רגע, רגע, לא הבנתי."},{"start":1118.16,"end":1119.1,"text":"מה אני אמרתי עכשיו?"},{"start":1119.1,"end":1121.67,"text":"אמרתי שזה היית אתה?"},{"start":1121.67,"end":1124.67,"text":"או שזה היית אתה?"},{"start":1124.67,"end":1127.24,"text":"לא ברור פה, זה היית אתה."},{"start":1127.24,"end":1129.43,"text":"לא, לא, אני עדיין לא מבין."},{"start":1129.43,"end":1132.68,"text":"יש זה היית אתה."},{"start":1132.68,"end":1137.68,"text":"זה היית אתה, זה דבר אחד, בוא נגיד הוא לא נעים."},{"start":1137.68,"end":1139.68,"text":"ויש זה היית אתה."},{"start":1139.68,"end":1142.81,"text":"זהו, ואם היית אתה זה לא יכול להיות אתה."},{"start":1142.81,"end":1146.54,"text":"רגע רגע רגע רגע רגע, שנייה, אני אדן מסבך את עצמי."},{"start":1146.54,"end":1150.54,"text":"זה היית אתה או שזה היית אתה?"},{"start":1150.54,"end":1155.63,"text":"לא, כי יש זה היית אתה, זה דבר אחד, נשים אותו בצד."},{"start":1155.63,"end":1157.63,"text":"ויש זה היית אתה."},{"start":1157.63,"end":1160.69,"text":"היית אתה, זה דבר אחר, כי היית אתה."},{"start":1160.69,"end":1162.69,"text":"אה, זכר לך! -סליחה, אני לא מבין!"},{"start":1162.69,"end":1165.6,"text":"אתה יכול בבקשה לחשוב קצת יותר בשקט?"},{"start":1165.6,"end":1168.13,"text":"סליחה, אני לא ידעתי..."},{"start":1168.13,"end":1171.12,"text":"אני פה מנהל את המקום הזה, אני נכנס, אני שומע הצעקות!"},{"start":1171.12,"end":1174.12,"text":"אני נכנס לפניקה, אני מסתכל, אני רואה שזה איטה-טה!"},{"start":1174.12,"end":1174.22,"text":"אווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":1174.12,"end":1185.29,"text":"יא מניאק!"},{"start":1185.29,"end":1187.82,"text":"מה אמרת?"},{"start":1187.82,"end":1191.56,"text":"יא מניאק!"},{"start":1191.56,"end":1194.26,"text":"תחזור שלי"},{"start":1194.26,"end":1197.2,"text":"מין!"},{"start":1197.2,"end":1200.37,"text":"אני מניאק!"},{"start":1200.37,"end":1202.91,"text":"לא!"},{"start":1202.91,"end":1204.86,"text":"אתה"},{"start":1204.86,"end":1206.24,"text":"מין מניאק!"},{"start":1206.24,"end":1210.58,"text":"שנסה אחונה!"},{"start":1210.58,"end":1212.02,"text":"אני"},{"start":1212.02,"end":1213.14,"text":"מניאק!"},{"start":1213.14,"end":1214.08,"text":"לא!"},{"start":1214.08,"end":1216.92,"text":"אתה מניאק!"},{"start":1216.92,"end":1218.95,"text":"אימא שכם מניאק!"},{"start":1218.95,"end":1220.95,"text":"אבי שכם מניאק!"},{"start":1220.95,"end":1221.95,"text":"אחי חגתן מניאק!"},{"start":1221.95,"end":1222.95,"text":"אכי חגתן מניאק!"},{"start":1222.95,"end":1223.95,"text":"כל המשפח שכם מניאק!"},{"start":1223.95,"end":1225.01,"text":"מניאק!"},{"start":1225.01,"end":1226.9,"text":"אבל בעיקר..."},{"start":1226.9,"end":1227.9,"text":"אסך!"},{"start":1227.9,"end":1229.02,"text":"מניאק!"},{"start":1229.02,"end":1235.76,"text":"ברגעים אלו ממש נפתח עוד ראש בשיקון ור."},{"start":1235.76,"end":1237.82,"text":"הראש של צ'ארלי."},{"start":1237.82,"end":1241.07,"text":"תח ותהנה."}]