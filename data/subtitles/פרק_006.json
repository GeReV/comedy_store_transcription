תי אותך"},{"start":934.96,"end":935.96,"text":"אה עדבתי אותך"},{"start":935.96,"end":936.96,"text":"אה אני אגזור אותך"},{"start":936.96,"end":937.96,"text":"אה אני אגזור אותך"},{"start":937.96,"end":941.71,"text":"היום אני ארים את הקופה שלי"},{"start":941.71,"end":947.06,"text":"let's do it"},{"start":947.06,"end":953.15,"text":"שקט"},{"start":953.15,"end":957.47,"text":"שעוד"},{"start":957.47,"end":958.47,"text":"משה מה עניינים?"},{"start":958.47,"end":959.76,"text":"לא השתנאת אה?"},{"start":959.76,"end":960.72,"text":"מה שלא מימה?"},{"start":960.72,"end":961.69,"text":"תשמע"},{"start":961.69,"end":963.69,"text":"תגיד לה שתמסור לי את המתכון"},{"start":963.69,"end":965.69,"text":"את המתכון להוגת תפוחים שלה, בסדר?"},{"start":965.69,"end":968.07,"text":"בסדר"},{"start":968.07,"end":982.19,"text":"אני יודע"},{"start":982.19,"end":984.47,"text":"לשוק"},{"start":984.47,"end":985.86,"text":"שקט לשוק"},{"start":985.86,"end":986.85,"text":"שקט לשוק"},{"start":986.85,"end":992.6,"text":"שקט"},{"start":992.6,"end":993.56,"text":"לשוק"},{"start":993.56,"end":996.35,"text":"רק רגע משה"},{"start":996.35,"end":998.35,"text":"כן, מה עם ההוגת תפוחים עם המתכון?"},{"start":998.35,"end":999.96,"text":"לא, לא הספקתי"},{"start":999.96,"end":1025.06,"text":"שקט לשוק?"},{"start":1025.06,"end":1027.06,"text":"או משה, או שלא רואים אותך בכלל"},{"start":1027.06,"end":1028.06,"text":"או שרואים אותך כל הזמן"},{"start":1028.06,"end":1030.06,"text":"תשמע, תגיד לאמא שכבר לא צריך את המתכון"},{"start":1030.06,"end":1032.06,"text":"אני השגתי לבד, בסדר?"},{"start":1032.06,"end":1033.02,"text":"ביי נראה"},{"start":1033.02,"end":1038.92,"text":"אתם יפים אני אגיד לכם"},{"start":1038.92,"end":1042.92,"text":"תשאל אותי, תשאל אותי"},{"start":1042.92,"end":1043.92,"text":"תגיד"},{"start":1043.92,"end":1044.92,"text":"יש גדי?"},{"start":1044.92,"end":1045.91,"text":"לא"},{"start":1045.91,"end":1047.91,"text":"אין גדי"},{"start":1047.91,"end":1053.22,"text":"תגיד"},{"start":1053.22,"end":1054.16,"text":"תל אמו?"},{"start":1054.16,"end":1055.18,"text":"לא"},{"start":1055.18,"end":1056.18,"text":"תל אביב"},{"start":1056.18,"end":1062.56,"text":"תגיד"},{"start":1062.56,"end":1065.47,"text":"בין שמאלה?"},{"start":1065.47,"end":1066.6,"text":"לא"},{"start":1066.6,"end":1067.6,"text":"בין ימינה"},{"start":1067.6,"end":1069.6,"text":"בין ימינה"},{"start":1074.08,"end":1076.0,"text":"תגיד"},{"start":1076.0,"end":1077.18,"text":"תגיד"},{"start":1077.18,"end":1078.34,"text":"כפר"},{"start":1078.34,"end":1079.85,"text":"סבתא"},{"start":1079.85,"end":1081.19,"text":"לא"},{"start":1081.19,"end":1082.19,"text":"פשמליהוד"},{"start":1082.19,"end":1130.33,"text":"אתה רוצה לשמור בית 9?"},{"start":1130.33,"end":1131.33,"text":"מה פתאום אני לא שומר בית 9"},{"start":1131.33,"end":1132.33,"text":"למה?"},{"start":1132.33,"end":1134.33,"text":"כי אני רוצה לראות את התוכנית של האו עם האקטואליה"},{"start":1134.33,"end":1135.33,"text":"עם השולחן"},{"start":1135.33,"end":1136.25,"text":"מי?"},{"start":1136.25,"end":1138.68,"text":"זה נו שאשתו עם הזה"},{"start":1138.68,"end":1140.73,"text":"בתשע?"},{"start":1140.73,"end":1141.79,"text":"בטח"},{"start":1141.79,"end":1143.79,"text":"אבל קודם יש את הפרצומות אני רוצה לראות"},{"start":1143.79,"end":1145.79,"text":"שזה עם הילדים עם השלוק"},{"start":1145.79,"end":1147.79,"text":"שהוא סוחב את כל המים על הגב"},{"start":1147.79,"end":1148.79,"text":"שעוברת העים עם הגבינות"},{"start":1148.79,"end":1149.85,"text":"של הלימון"},{"start":1149.85,"end":1150.85,"text":"עם התפוח"},{"start":1150.85,"end":1153.77,"text":"השם שלו מתחיל בגימל אני חושב"},{"start":1153.77,"end":1155.73,"text":"אה זה שבלקה של הדבורים"},{"start":1155.73,"end":1157.89,"text":"כן זהו אבל לא"},{"start":1157.89,"end":1159.89,"text":"יש תוכנית אחת לפני קודם"},{"start":1159.89,"end":1161.92,"text":"נו זה שכבר יחליפו לו את השולחן"},{"start":1161.92,"end":1163.95,"text":"שישתו עם המשקפיים"},{"start":1163.95,"end":1164.95,"text":"שישתו עם הזה נו"},{"start":1164.95,"end":1167.27,"text":"נו השם שלו מתחי