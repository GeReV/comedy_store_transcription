[{"start":2.11,"end":9.23,"text":"סליחה, סליחה, סליחה, אני רוצה לדעת מה המינוס שלי"},{"start":9.23,"end":10.14,"text":"בבקשה"},{"start":10.14,"end":13.4,"text":"וואו"},{"start":13.4,"end":14.3,"text":"עזוב לא רוצה לדעת"},{"start":14.3,"end":58.39,"text":"אני רואה שהשאולי שלך ממש השתפר"},{"start":58.39,"end":61.76,"text":"כן דוקטור אני התאמנתי על זה כל הלילה"},{"start":61.76,"end":80.19,"text":"כל השבוע התכוננו"},{"start":80.19,"end":83.36,"text":"הגענו למגרש בשבת מה זה מחוממים"},{"start":83.36,"end":85.43,"text":"התכוננו טוב טוב טוב למשחק"},{"start":85.43,"end":88.38,"text":"שלא יהיה הבנות מפה הבוס פה אה"},{"start":88.38,"end":90.62,"text":"שרשרות הבאנו הבאנו"},{"start":90.62,"end":93.62,"text":"נבוטים הבאנו הבאנו"},{"start":93.62,"end":96.65,"text":"וואלה התנפלנו עליהם קרענו להם את הצורה"},{"start":96.65,"end":99.65,"text":"נקרנו להם את העיניים שברנו להם את האף"},{"start":99.65,"end":102.65,"text":"הוצאנו להם את השיניים קרענו להם את המעיים"},{"start":102.65,"end":105.65,"text":"למה אנחנו פרארים של מישהו אנחנו"},{"start":105.65,"end":118.91,"text":"תגיד אתה אתה נוהג או אתה הולך"},{"start":118.91,"end":121.36,"text":"אני נוהג ללכת"},{"start":121.36,"end":128.36,"text":"תגיד אתה עומד או יושב"},{"start":128.36,"end":131.61,"text":"אני עומד לשבת"},{"start":131.61,"end":137.61,"text":"תגיד אתה הולך או שוכף"},{"start":137.61,"end":140.73,"text":"אני הולך לשכב"},{"start":140.73,"end":147.23,"text":"אתה אוכל או שותה"},{"start":147.23,"end":149.48,"text":"לא תודה אני בדיאטה"},{"start":149.48,"end":157.59,"text":"הסטנדאפ מתפשט בארץ ובעולם"},{"start":157.59,"end":160.59,"text":"בעיר, בכפר, במושב, בקיבוץ ובכל חור"},{"start":160.59,"end":163.59,"text":"צומחים להם סטנדאפיסטים כפטריות אחר הגשם"},{"start":163.59,"end":170.74,"text":"יש פה תרנגול מבת ים?"},{"start":170.74,"end":174.38,"text":"אההה אין לו ביצים להודות"},{"start":174.38,"end":177.38,"text":"הלן הלן תגידי מה זאת הקרבולת הזאת?"},{"start":177.38,"end":180.49,"text":"זה הקרבולת שלך או שאת יושבת הפוך?"},{"start":180.49,"end":183.99,"text":"אוי אוי תגידי עכשיו שאני רואה אותך בפרופיל את יודעת מה?"},{"start":183.99,"end":187.99,"text":"מתאים לך צ'יפס מתאים לך רגע רגע אני יודע מיד"},{"start":187.99,"end":189.99,"text":"אני ראיתי אותך אתמול במסך נסה נכון?"},{"start":189.99,"end":192.99,"text":"תגידי מה עשיתי את שם ניקוי במקור?"},{"start":192.99,"end":194.99,"text":"אוי מי רוצה לראות סטנדטיסט?"},{"start":194.99,"end":198.28,"text":"אה לא שומע אתם רוצים לראות סטנדטיסט?"},{"start":198.28,"end":201.28,"text":"אז בואו אחריי להיט ליסט"},{"start":201.28,"end":203.28,"text":"הייתי אתמול בסרט שחטו אותי בבית"},{"start":203.28,"end":205.28,"text":"אוי כל מיני סרטים"},{"start":205.28,"end":206.34,"text":"ראיתי את בעלך"},{"start":206.34,"end":207.34,"text":"זאת, כן ראיתי את בעלך"},{"start":207.34,"end":209.34,"text":"אל תשאלי מסתובב בדיזינגוף"},{"start":209.34,"end":211.34,"text":"על שיפוד"},{"start":211.34,"end":213.34,"text":"אוי אני מצחיק אני מצחיק"},{"start":213.34,"end":214.34,"text":"תודה רבה לכם"},{"start":214.34,"end":215.34,"text":"תודה רבה"},{"start":215.34,"end":217.34,"text":"מייתנניאף"},{"start":217.34,"end":230.04,"text":"משובח לכולם"},{"start":230.04,"end":231.04,"text":"זוכרים אותי איזה שוב אני"},{"start":231.04,"end":233.04,"text":"הפרופסור יוקמץ בן פסיק"},{"start":233.04,"end":235.04,"text":"בפינת הדבר עברית כהלכה"},{"start":235.04,"end":237.04,"text":"שימו לב אני נמצא כרגע"},{"start":237.04,"end":238.04,"text":"בסדרות רוטשילד"},{"start":238.04,"end":240.04,"text":"אני אמרתי סדרות"},{"start":240.04,"end":242.04,"text":"ולא שדרות כי כך יש לומר"},{"start":242.04,"end":244.04,"text":"סדרות בשין שמאלית"},{"start":244.04,"end":246.04,"text":"לצערי כל בית ישראל טועים להגות שדרות"},{"start":246.04,"end":248.04,"text":"שימו לב אני אדגים לכם את זה"},{"start":248.04,"end":250.04,"text":"בוא ענה אדוני בוא ענה"},{"start":250.04,"end":251.04,"text":"שלום לך"},{"start":251.04,"end":252.04,"text":"היכן אנו נמצאים"},{"start":252.04,"end":253.48,"text":"שדרות רוטשילד"},{"start":253.48,"end":255.48,"text":"אהה אמרתי לכם הוא טועה"},{"start":255.48,"end":256.48,"text":"פוץ לך פוץ לך"},{"start":256.48,"end":257.48,"text":"שימו לב הנה מגיע שוב"},{"start":257.48,"end":259.48,"text":"הלו שלום לך אדוני"},{"start":259.48,"end":260.89,"text":"מה זה למה מצלמים פה"},{"start":260.89,"end":262.89,"text":"היכן אנו נמצאים אדוני"},{"start":262.89,"end":263.89,"text":"בשדרות רוטשילד"},{"start":263.89,"end":265.89,"text":"ידעתי הוא שוב אמר שדרות"},{"start":265.89,"end":267.89,"text":"לך מפה, לך מפה, לך מפה"},{"start":267.89,"end":269.82,"text":"בור ועם הארץ"},{"start":269.82,"end":272.11,"text":"שימו לב, שימו לב, כולם טועים"},{"start":272.11,"end":274.07,"text":"הנה זה שוב, הנה מגיע"},{"start":274.07,"end":276.61,"text":"הלו, שלום לך"},{"start":276.61,"end":278.79,"text":"איפה אנחנו נמצאים?"},{"start":278.79,"end":281.71,"text":"סדרות רוטשילד"},{"start":281.71,"end":284.18,"text":"מה? סדרות רוטשילד"},{"start":284.18,"end":286.52,"text":"אתה מקומי?"},{"start":286.52,"end":288.52,"text":"לא, אני מביר סבא"},{"start":288.52,"end":290.52,"text":"פעם סליסית בתל אביב"},{"start":290.52,"end":294.98,"text":"מה זה יגל סילון?"},{"start":294.98,"end":296.98,"text":"ערב צה"},{"start":296.98,"end":301.4,"text":"ערב צה"},{"start":301.4,"end":303.4,"text":"ושומות שמביאות לז'וז'ו תחלסטרה"},{"start":303.4,"end":305.43,"text":"והפעם מים מינרלים"},{"start":305.43,"end":307.43,"text":"אלה לא נורמלים, באמא שלי"},{"start":307.43,"end":309.51,"text":"באמצע הקניון"},{"start":309.51,"end":311.57,"text":"באמצע התהום"},{"start":311.57,"end":313.57,"text":"פתאום עומד לו לבד מגבוק של מים מינרלים"},{"start":313.57,"end":315.57,"text":"איך הוא הגיע לשם? אף אחד לא יודע"},{"start":315.57,"end":317.57,"text":"מי שידע באמא שלי קבל את הפרס של הטוטו"},{"start":317.57,"end":319.49,"text":"מה נגיד לכם? וזה עוד כלום"},{"start":319.49,"end":321.59,"text":"פתאום בא איזה לפלף קטן עם קוקו"},{"start":321.59,"end":323.59,"text":"והוא מתחיל לרוץ בסלעים"},{"start":323.59,"end":325.59,"text":"והוא רץ בסלעים"},{"start":325.59,"end":327.59,"text":"והוא עולה במעלה הער"},{"start":327.59,"end":329.59,"text":"ופתאום ישמו לו איסוס שחור"},{"start":329.59,"end":331.59,"text":"באימא שלי סוס שחור"},{"start":331.59,"end":333.59,"text":"אמיתי"},{"start":333.59,"end":335.59,"text":"והסוס בורח לו"},{"start":335.59,"end":337.59,"text":"והוא רץ והוא מזיע והוא מתעמץ"},{"start":337.59,"end":339.59,"text":"והוא קופץ על הסוס"},{"start":339.59,"end":341.59,"text":"והוא רודף עם הסוס אחרי המים"},{"start":341.59,"end":343.59,"text":"באימא שלי מפגר"},{"start":343.59,"end":345.59,"text":"כנס לקיוק שתקנה בקבוק מים מינרליים"},{"start":345.59,"end":347.59,"text":"וגמרנו לא יותר פשוט"},{"start":347.59,"end":349.59,"text":"תחשבו על זה באימא שלי"},{"start":349.59,"end":353.82,"text":"תחשבו"},{"start":353.82,"end":355.82,"text":"אז את הפעם פשיך להתפשט"},{"start":355.82,"end":367.87,"text":"והפעם נתונים למוות"},{"start":367.87,"end":369.87,"text":"אני בטוח שאתם תבוטו עליי"},{"start":369.87,"end":371.87,"text":"תגידו יש כאן מישהו מבט ים"},{"start":371.87,"end":371.97,"text":"כן"},{"start":371.87,"end":373.87,"text":"היית מת"},{"start":373.87,"end":375.87,"text":"חבר'ה"},{"start":375.87,"end":377.87,"text":"אני רוצה להגיד לכם בהזדמנות הזאת"},{"start":377.87,"end":379.87,"text":"ראיתי את מה סרט פנטסטי"},{"start":379.87,"end":381.87,"text":"מת לחיות שתיים"},{"start":381.87,"end":383.87,"text":"הדרך תמיד מלאה"},{"start":383.87,"end":385.87,"text":"בכוונות טובות"},{"start":385.87,"end":387.87,"text":"כוונות"},{"start":387.87,"end":389.87,"text":"כן"},{"start":389.87,"end":391.87,"text":"חבר'ה הייתי רוצה שירה וציבור קצת"},{"start":391.87,"end":393.87,"text":"שירה וציבור"},{"start":393.87,"end":395.87,"text":"אני מת"},{"start":395.87,"end":400.05,"text":"חבר'ה"},{"start":400.05,"end":402.05,"text":"חבר'ה כל מה שנותר לי להגיד לכם זה עוד בהצלחה"},{"start":402.05,"end":404.05,"text":"תעשו חיים כי איך אומרים"},{"start":404.05,"end":406.11,"text":"מי שאוכל לבד מת לבד"},{"start":406.11,"end":408.11,"text":"חבר'ה יכלו ושיטו"},{"start":408.11,"end":410.11,"text":"כמחר מתים"},{"start":410.11,"end":412.11,"text":"חבר'ה חבר'ה שימו לב"},{"start":412.11,"end":414.11,"text":"אופה"},{"start":414.11,"end":420.11,"text":"אני חושב שאני לא אבוא להופיע פה יותר"},{"start":420.11,"end":422.11,"text":"ולא בגללי"},{"start":422.11,"end":424.11,"text":"אתם חבר'ה תעשו חיים"},{"start":427.25,"end":435.13,"text":"תגיד לי"},{"start":435.13,"end":437.13,"text":"מה זה הביא אותנו פה? זה מקום לעשות בו מילואים זה?"},{"start":437.13,"end":439.12,"text":"זה מה? זה מוזיאון ארץ ישראל תל אביב זה"},{"start":439.12,"end":441.12,"text":"זה לא"},{"start":441.12,"end":443.14,"text":"לא אתה לא הבנת"},{"start":443.14,"end":445.14,"text":"הם הרי החזירו את עזה"},{"start":445.14,"end":447.14,"text":"אז אין אפוא לעשות מילואים אז עושים את זה פה"},{"start":447.14,"end":449.61,"text":"עוד מעט כל הצבא יהיה פה"},{"start":449.61,"end":451.61,"text":"אבל מה יש פה? על מה יש פה לשמור פה?"},{"start":451.61,"end":453.61,"text":"על מה יש פה לשמור פה? יש פה עד כל התמונות האלה"},{"start":453.61,"end":455.61,"text":"של הבך, שטראוס, הוויטמן"},{"start":455.61,"end":460.11,"text":"מה זה? אבל מי ירצה לגנום כזה דבר זה?"},{"start":460.11,"end":462.11,"text":"מה? מה יש לגנום?"},{"start":462.11,"end":466.49,"text":"זה דבר כזה? זה... תגידי דבר אחר"},{"start":466.49,"end":470.05,"text":"הם הסתדרו בלעדינו בתוכנית"},{"start":470.05,"end":471.05,"text":"הסתדרו? לא, הסתדרו"},{"start":471.05,"end":473.05,"text":"מה זה? הסתדרות זה מעולה"},{"start":473.05,"end":475.97,"text":"הסתדרות זה... בסתדרות יש לך קופת חולים"},{"start":475.97,"end":478.26,"text":"יש לך... קופת חול... אתה מספר לי"},{"start":478.26,"end":480.26,"text":"הרי אשתי מסכנה, ילדה לא הרגישה טוב"},{"start":480.26,"end":482.26,"text":"מהבוקר אני..."},{"start":486.43,"end":492.18,"text":"מריד, אתה נוסע בדרך אגב?"},{"start":492.18,"end":494.5,"text":"לא, אני נוסע בדרך כלל"},{"start":494.5,"end":499.5,"text":"יש, יש"},{"start":499.5,"end":501.88,"text":"אתה נוסע בדרך צליחה?"},{"start":501.88,"end":503.94,"text":"לא, אני נוסע בדרך כל בשר"},{"start":503.94,"end":509.97,"text":"יש, יש, יש"},{"start":509.97,"end":511.97,"text":"אתה נוסע בדרך ארץ?"},{"start":511.97,"end":513.97,"text":"לא, אני נוסע בדרך המלך"},{"start":513.97,"end":520.35,"text":"יש, יש, יש"},{"start":520.35,"end":522.35,"text":"אתה נוסע בדרך כביש החוב?"},{"start":522.35,"end":524.47,"text":"לא, יש שם פקקים עכשיו"},{"start":524.47,"end":531.55,"text":"דוקטור, מה יש לי?"},{"start":531.55,"end":534.09,"text":"תראה, חוששת לי שמדובר באידס"},{"start":534.09,"end":537.43,"text":"אידס?"},{"start":537.43,"end":541.95,"text":"אני יכול לקבל דעה שנייה?"},{"start":541.95,"end":543.95,"text":"בוודאי, אתה גם מכוער"},{"start":543.95,"end":548.19,"text":"הסטנדאפ ממשיך להתפשט"},{"start":548.19,"end":550.19,"text":"והפעם בחגנון סטיני וונדר"},{"start":550.19,"end":555.3,"text":"הלו, הלן, הלן חבר'ה"},{"start":555.3,"end":557.49,"text":"אה, אה, אוקיי"},{"start":557.49,"end":561.15,"text":"הלן חבר'ה, מה אני נהים?"},{"start":561.15,"end":562.21,"text":"שומעים אותי כולם?"},{"start":562.21,"end":563.21,"text":"כן"},{"start":563.21,"end":564.21,"text":"כמה זה?"},{"start":566.17,"end":569.17,"text":"חבר'ה, אפשר להוריד טיפה את האור, זה מסנביר"},{"start":569.17,"end":571.17,"text":"אה, גדול"},{"start":571.17,"end":573.17,"text":"לא, אני אורגילה, יש פה מישהו מבט יב?"},{"start":573.17,"end":574.17,"text":"כן"},{"start":574.17,"end":575.17,"text":"איפה אתה אחי, שנים לא ראינו אותך?"},{"start":575.17,"end":577.17,"text":"אה, גדול"},{"start":577.17,"end":580.39,"text":"ואללה, דברים שרואים מכאן, לא רואים משם"},{"start":580.39,"end":581.39,"text":"לא, זה קטע"},{"start":581.39,"end":584.48,"text":"אתם יודעים איזה תוכנית טלוויזיה אני הכי אוהב?"},{"start":584.48,"end":585.54,"text":"אה"},{"start":585.54,"end":586.66,"text":"אתם יודעים איזה?"},{"start":586.66,"end":587.88,"text":"לא"},{"start":587.88,"end":588.88,"text":"רואים ששש?"},{"start":588.88,"end":589.88,"text":"אה, גדול"},{"start":589.88,"end":592.88,"text":"או רואים עולם בערב, זה מדהים"},{"start":592.88,"end":596.19,"text":"יאללה, חבר'ה, הייתי מת לראות אתכם בהופעה הבאה"},{"start":596.19,"end":598.19,"text":"אתם יודעים, אפרופו ההופעה"},{"start":598.19,"end":600.19,"text":"אתם יודעים מה היה אחרי ההופעה שלי"},{"start":600.19,"end":602.18,"text":"אני לא רואה את הכסף"},{"start":602.18,"end":605.18,"text":"יאללה, חבר'ה גדול, הייתם גדולים"},{"start":605.18,"end":617.89,"text":"בסדר, שנייה"},{"start":617.89,"end":623.36,"text":"לא שומעים, אלו"},{"start":623.36,"end":624.27,"text":"לא שומע"},{"start":624.27,"end":629.29,"text":"אלו, תגביר את הבניום"},{"start":629.29,"end":632.38,"text":"מה, מה אני עושה עם זה?"},{"start":632.38,"end":635.04,"text":"פה תכניס בפנאים"},{"start":635.04,"end":641.48,"text":"אתה חולל"},{"start":641.48,"end":642.67,"text":"אלן, מה נשמע?"},{"start":642.67,"end":643.89,"text":"אני לא שומע"},{"start":643.89,"end":645.21,"text":"דברי חזק"},{"start":645.21,"end":646.46,"text":"עדי צעקי"},{"start":646.46,"end":648.19,"text":"כן"},{"start":648.19,"end":650.51,"text":"כן, הגענו, אנחנו במילואים"},{"start":650.51,"end":651.51,"text":"ברמה"},{"start":651.51,"end":652.51,"text":"רמת אביב משהו"},{"start":652.51,"end":653.51,"text":"כן"},{"start":653.51,"end":654.6,"text":"כן"},{"start":654.6,"end":654.7,"text":"יש הכל"},{"start":654.6,"end":655.6,"text":"בסדר"},{"start":655.6,"end":656.6,"text":"אנחנו שנינו ביחד"},{"start":656.6,"end":656.7,"text":"כן"},{"start":656.6,"end":657.62,"text":"כן"},{"start":657.62,"end":658.81,"text":"בסדר"},{"start":658.81,"end":659.87,"text":"אני לובש"},{"start":659.87,"end":660.87,"text":"שלוש חבות"},{"start":660.87,"end":661.87,"text":"כן"},{"start":661.87,"end":662.9,"text":"בסדר"},{"start":662.9,"end":663.9,"text":"יש הכל"},{"start":663.9,"end":664.9,"text":"יש פה מקולת"},{"start":664.9,"end":665.9,"text":"יש פה אניברסיטה"},{"start":665.9,"end":666.9,"text":"הכל, הכל בסדר גמול"},{"start":666.9,"end":668.22,"text":"כן"},{"start":668.22,"end":669.72,"text":"איפה?"},{"start":669.72,"end":671.14,"text":"מה?"},{"start":671