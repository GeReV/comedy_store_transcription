[{"start":1.03,"end":7.53,"text":"בתשע ושלושים קם בטלעד, לילה גוב עם גידי גוב בשידור חי, עם חיות שונות ואורחים נוספים."},{"start":7.53,"end":11.69,"text":"לאחר לילה גוב, פרק נוסף בסדרה המצליחה, סודות העיר."},{"start":11.69,"end":17.81,"text":"ועכשיו, יש לי יש לי, המצלמה המשוטטת של ג'ודי, וכמובן החלסטרה של ז'וז'ו."},{"start":17.81,"end":23.13,"text":"כולם בקומדיסטור, עם קליפ חדש, תנו יד ללפלף, ולקת פספוסים."},{"start":23.13,"end":24.31,"text":"תשארו אימנו."},{"start":24.31,"end":88.27,"text":"קומדיסטור!"},{"start":88.27,"end":91.36,"text":"תשאר לזה יום היה לי היום."},{"start":91.36,"end":93.66,"text":"על הבוקר שוטר דפק לי רפורט."},{"start":94.75,"end":96.24,"text":"חמש מאות שקל."},{"start":96.24,"end":100.45,"text":"אחרי זה בעבודה, הבוס פיטר אותי."},{"start":100.45,"end":104.41,"text":"חזרתי הביתה, אשתי ברחה עם האומה המקולת."},{"start":104.41,"end":107.6,"text":"הלאה, חיים בזבל."},{"start":107.6,"end":111.6,"text":"חזל שעוד מעט מתחיל הקומדיסטור."},{"start":111.6,"end":112.76,"text":"אה, קומדיסטור."},{"start":112.76,"end":114.66,"text":"כן, אבל רק אחרי הפרסומות."},{"start":114.66,"end":115.62,"text":"פרסומות!"},{"start":115.62,"end":133.48,"text":"שתיים, דומינוס פיצה יוצאת לדל."},{"start":133.48,"end":135.16,"text":"ועכשיו נמצא."},{"start":135.16,"end":139.44,"text":"מזמינים פיצה ומקבלים פוגים אמיתיים מהסדרה האמריקאית המנצח."},{"start":139.44,"end":140.64,"text":"דומינוס פיצה."},{"start":140.84,"end":143.34,"text":"אחד, דומינוס."},{"start":143.34,"end":149.02,"text":"בכל חורף אני נטף געגועים לבית הכי חם שאני מכיר."},{"start":149.02,"end":151.88,"text":"חם מדי, האישה הזאת מנסה לשרוף אותי."},{"start":151.88,"end":153.94,"text":"לאבא שלי שחלם להיות הקוסם הודיני."},{"start":153.94,"end":156.78,"text":"אולי הרבה שלא הצליח לצאת מהמזבד."},{"start":156.78,"end":159.95,"text":"לאחותי שרוצה להיות דוגמנית."},{"start":159.95,"end":161.15,"text":"שבילי רק טיפ טיפה."},{"start":161.15,"end":163.03,"text":"לדאנה."},{"start":163.03,"end":165.69,"text":"הכירו, זה משה. תראו איך הוא אוכל יפה."},{"start":165.69,"end":167.29,"text":"שכל כך רוצה להתחתן."},{"start":167.29,"end":170.93,"text":"לאריאלה הקטנה שקיבלה את הרגליים היפות שלה מעדות גנץ."},{"start":170.93,"end":172.91,"text":"ששיחק כדורגל עם שיה גלזר."},{"start":172.91,"end":175.05,"text":"לדודה אלגרה שפעם אבא יפנט אותה."},{"start":175.05,"end":177.59,"text":"מאז היא משוכנעת שהיא מלכת היופי של אום רש-רש."},{"start":177.59,"end":179.55,"text":"אני רוצה להביא שלום בהכבה לעולם."},{"start":179.55,"end":181.69,"text":"והכי הכי לאימא שלי שתמיד אומרת."},{"start":181.69,"end":184.29,"text":"ככה זה מרק בוחרים? משפחה לא."},{"start":184.29,"end":189.67,"text":"בית חם. סדרת מרקים עשירים בתאמים ביתיים של אוסם."},{"start":189.67,"end":193.37,"text":"אני הולכת עם הזמן. אני דורשת יעילות ואיכות."},{"start":193.37,"end":198.01,"text":"למלחמה שלי בקמטים גיליתי את הקרם הפעיל נגד קמטים של פלניטוד."},{"start":198.01,"end":205.57,"text":"דקות מדעיות מוכיחות כי לאחר שלושה שבועות של שימוש בקרם פעיל נגד קמטים,"},{"start":205.57,"end":209.35,"text":"עומק הקמטים מצטמצם וחל שיפור משמעותי במראה האור."},{"start":209.35,"end":214.57,"text":"הקמטים שלי מתשתשים, האור שלי גמיש יותר, חלק יותר ונראה צעיר ורענן."},{"start":214.57,"end":219.03,"text":"פלניטוד, קרם פעיל נגד קמטים של לא ריאל פריס, מעכבת השפעות ההזדקנות."},{"start":219.03,"end":228.73,"text":"לפני שאני יורד מהפסים, אני יורד לים המלח."},{"start":228.73,"end":232.93,"text":"זה, הנה."},{"start":232.96,"end":236.7,"text":"ביאמבה."},{"start":236.7,"end":239.5,"text":"דבר ראשון על כל לשון."},{"start":239.5,"end":243.83,"text":"אין אין אין אין אין."},{"start":243.83,"end":245.83,"text":"כמו ביאמבה, לא נוטה."},{"start":245.83,"end":253.83,"text":"כמו ביאמבה, לא היה."},{"start":253.83,"end":264.25,"text":"THIS IS ONE OF THE MOST POWERFUL UPRIGHT CLINERS."},{"start":264.25,"end":268.08,"text":"THIS IS THE NEW ELECTROLUX CONTOR."},{"start":268.08,"end":270.33,"text":"YOU WON'T BELIEVE HOW POWERFUL IT IS."},{"start":270.33,"end":272.33,"text":"אלקטרולוקס עכשיו במבצע."},{"start":272.33,"end":275.58,"text":"12 תשלומים ללא ריבית ועצמדה."},{"start":275.58,"end":281.08,"text":"קומדיסטור מיד בתום הפרסומות."},{"start":281.08,"end":284.15,"text":"חדש מחום הגן."},{"start":284.15,"end":286.15,"text":"מייצחימום עם מערכת בקרה אלקטרונית."},{"start":286.15,"end":287.15,"text":"ברור כשמש."},{"start":287.15,"end":288.15,"text":"חום הגן."},{"start":288.15,"end":293.89,"text":"יותר אנשים ביותר משפחות ביותר מקומות בישראל אוהבים מיונז טלמה."},{"start":293.89,"end":295.89,"text":"תרשבה ודימונה תל אביב בנסיונה."},{"start":295.89,"end":297.89,"text":"חיפה ומודיעין ערד בהדסים."},{"start":297.89,"end":299.81,"text":"מיונז."},{"start":299.81,"end":306.78,"text":"הריאק פרציון בהרציון."},{"start":306.78,"end":307.78,"text":"ירושלים וגהיבתיים."},{"start":307.78,"end":308.78,"text":"מיונז."},{"start":308.78,"end":326.42,"text":"יש לך כאב ראש חזק מהרגיל?"},{"start":326.42,"end":328.42,"text":"כך קוד אקמול פורטה."},{"start":328.42,"end":331.55,"text":"על ידי הוספת קודאין לחומר הבעיל של האקמול,"},{"start":331.55,"end":335.55,"text":"נוצר קוד אקמול פורטה."},{"start":335.55,"end":339.97,"text":"קוד אקמול פורטה, לחאבי ראש חזקים יותר."},{"start":339.97,"end":345.2,"text":"לחמישים מיליון משפחות ברחבי העולם וגם בישראל,"},{"start":345.2,"end":347.2,"text":"יש מכנה משותף צלול."},{"start":347.2,"end":352.39,"text":"פעם בחודש מחליפים פילטר בריטה ונהנים ממים צלולים לכל החודש."},{"start":352.39,"end":355.36,"text":"בריטה, מחזירה למים את הטעם."},{"start":355.36,"end":358.1,"text":"ומחזירה גם לטה את הטעם."},{"start":358.1,"end":362.1,"text":"קונים שלישיית פילטר בריטה ומקבלים חבילת טייליפטון במתנה."},{"start":362.1,"end":410.1,"text":"וחד זקית נראות יופי מצוין חיים ככה נחתורן."},{"start":410.1,"end":412.06,"text":"חזק חזק וברוך חזק וברוך."},{"start":412.06,"end":415.13,"text":"כאן מתקבלים לתנועת הנוער בני עקיבה."},{"start":415.13,"end":416.13,"text":"כן זה המקום."},{"start":416.13,"end":418.13,"text":"אז בוא בני תפוס את מקומך."},{"start":418.13,"end":419.48,"text":"אמור שלום."},{"start":41