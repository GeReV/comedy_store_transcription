[{"start":30.24,"end":32.33,"text":"ברוכים הבאים"},{"start":32.33,"end":35.44,"text":"כובן הסתול"},{"start":35.44,"end":37.66,"text":"נעבור מיד לצפות בקטע מחול"},{"start":37.66,"end":39.66,"text":"מתוך מפצח האגוזים"},{"start":39.66,"end":41.62,"text":"לצ'ייקובסקי"},{"start":41.62,"end":56.48,"text":"עוד מחול מודרני"},{"start":56.48,"end":58.54,"text":"מיד אחרי הפרסמות"},{"start":58.54,"end":103.34,"text":"את המקסים"},{"start":103.34,"end":106.87,"text":"כן, בדח"},{"start":106.87,"end":109.92,"text":"תגיד, אני יכול לשאול אותך שאלה"},{"start":109.92,"end":112.97,"text":"כן, מה נו?"},{"start":112.97,"end":116.11,"text":"רצית לשאול אותי שאלה?"},{"start":116.11,"end":119.84,"text":"רגע, רגע, רגע, מה הייתה השאלה?"},{"start":119.84,"end":122.32,"text":"תגיד, אני יכול לשאול אותך שאלה"},{"start":122.32,"end":124.32,"text":"מה הייתה השאלה הראשונה שרצית לשאול אותי?"},{"start":124.32,"end":127.32,"text":"לא הייתה השאלה הראשונה שרציתי לשאול אותך מעבר לשאלה הזאת"},{"start":127.32,"end":129.32,"text":"אתה למעשה ביקשת ממני שאני אשאל אותה שוב"},{"start":129.32,"end":134.3,"text":"עכשיו, אתה שואל שאלה?"},{"start":134.3,"end":136.22,"text":"איזה שאלה שאלתי?"},{"start":136.22,"end":137.21,"text":"אני שמעתי אותך שואל"},{"start":137.21,"end":138.38,"text":"מה שמעת אותי שואל?"},{"start":138.38,"end":141.07,"text":"מה?"},{"start":141.07,"end":142.07,"text":"מה שמעת אותי שואל?"},{"start":142.07,"end":143.99,"text":"מה?"},{"start":143.99,"end":145.18,"text":"מה?"},{"start":145.18,"end":146.46,"text":"כן, מה?"},{"start":146.46,"end":147.48,"text":"מה, כן, מה?"},{"start":147.48,"end":148.48,"text":"מה שאתה שומע?"},{"start":148.48,"end":149.48,"text":"מה אני שומע?"},{"start":149.48,"end":150.48,"text":"מה שאתה שואל?"},{"start":150.48,"end":151.48,"text":"מה שאתה שואל?"},{"start":151.48,"end":152.48,"text":"מה, איזה שאלה שואל?"},{"start":152.48,"end":154.48,"text":"רגע, רגע!"},{"start":154.48,"end":157.98,"text":"רגע, רגע!"},{"start":157.98,"end":159.01,"text":"בוא נרגע, בוא נרגע."},{"start":159.01,"end":162.6,"text":"מה הייתה השאלה הראשונה ששאלת אותי?"},{"start":162.6,"end":163.67,"text":"בהתחלה."},{"start":163.67,"end":164.67,"text":"בהתחלה, כן."},{"start":164.67,"end":169.05,"text":"תגיד, אני יכול לשאול אותך שאלה?"},{"start":169.05,"end":170.11,"text":"נא!"},{"start":170.11,"end":172.67,"text":"נא!"},{"start":172.67,"end":174.24,"text":"נא!"},{"start":174.24,"end":176.24,"text":"בואו, אני זוכרת אום המשימה אתמול."},{"start":176.24,"end":177.24,"text":"איזה מי?"},{"start":177.24,"end":180.24,"text":"זהו, זה שהיא הקפיצת הקינות קראה אותנו מצרוגת."},{"start":180.24,"end":182.24,"text":"בואו, נא, בדרן הזה."},{"start":182.24,"end":184.24,"text":"גמר אותי, דו."},{"start":184.24,"end":186.2,"text":"הוא גדול, איזה בניחות יש."},{"start":186.2,"end":188.2,"text":"פאוסי אחד, אולי?"},{"start":188.2,"end":190.39,"text":"איך הוא חיכה את האימא השמני?"},{"start":190.39,"end":192.39,"text":"הוא גדול, גדול."},{"start":192.39,"end":194.39,"text":"זה באמת הייתי, זה באמת הייתי."},{"start":194.39,"end":197.48,"text":"הוא ענק, הוא פשוט מטרן ברמה, אני לא יודע."},{"start":197.48,"end":199.48,"text":"תגיד לי, מה הייתו, מה הייתו?"},{"start":199.48,"end":200.38,"text":"הוא מת."},{"start":200.38,"end":203.27,"text":"מה אתה אומר?"},{"start":203.27,"end":207.24,"text":"שלום לכם."},{"start":207.24,"end":208.53,"text":"ברוכים הבאים לפינתנו,"},{"start":208.53,"end":210.53,"text":"האסכימוסי הבלתי נראה."},{"start":210.53,"end":216.1,"text":"זאת הייתה פינתנו,"},{"start":216.1,"end":218.01,"text":"האסכימוסי הבלתי נראה."},{"start":218.01,"end":219.84,"text":"בואו אני זוכר את זה שמת מהמציבה,"},{"start":219.84,"end":221.9,"text":"זה סיפרתי לך עליו?"},{"start":221.9,"end":222.9,"text":"כן, בואו נצחק."},{"start":222.9,"end":223.9,"text":"מורה הגדול, לא?"},{"start":223.9,"end":225.41,"text":"איזה ענק."},{"start":225.41,"end":228.81,"text":"אה!"},{"start":228.81,"end":230.81,"text":"אה!"},{"start":230.81,"end":231.81,"text":"אה!"},{"start":231.81,"end":232.81,"text":"אה!"},{"start":232.81,"end":233.81,"text":"אה!"},{"start":233.81,"end":234.81,"text":"אה!"},{"start":234.81,"end":235.81,"text":"אה!"},{"start":235.81,"end":236.88,"text":"אה!"},{"start":236.88,"end":238.75,"text":"אה!"},{"start":238.75,"end":242.37,"text":"אה!"},{"start":242.37,"end":243.95,"text":"אה!"},{"start":243.95,"end":246.28,"text":"שלום לכם."},{"start":246.28,"end":247.28,"text":"ברוכים הבאים לפינתנו,"},{"start":247.28,"end":252.34,"text":"שני הסכימוסים בלתי נראים."},{"start":252.34,"end":253.7,"text":"זאת הייתה פינתנו,"},{"start":253.7,"end":256.69,"text":"שני הסכימוסים בלתי נראים."},{"start":256.69,"end":259.97,"text":"ויהלך יעקב הלבן הערמי,"},{"start":259.97,"end":261.93,"text":"ויהאמר לו."},{"start":261.93,"end":262.93,"text":"אה!"},{"start":262.93,"end":263.93,"text":"שלום לך לבן הערמי."},{"start":263.93,"end":265.93,"text":"שלום לך יעקב."},{"start":265.93,"end":267.99,"text":"אני עבדתי בשבילך שבע שנים,"},{"start":267.99,"end":270.99,"text":"על מנת לזכות ברחל ביתך הקטנה."},{"start":270.99,"end":272.99,"text":"האם סוף סוף אני יכול ללכת אליה?"},{"start":272.99,"end":274.21,"text":"לך אליה."},{"start":274.21,"end":276.13,"text":"תודה רבה."},{"start":276.13,"end":278.3,"text":"רגע, רגע, לא הבנתי."},{"start":278.3,"end":280.3,"text":"אתה התכוונת שאני יכול ללכת אליה,"},{"start":280.3,"end":282.3,"text":"או יכול ללכת אל-לה?"},{"start":282.3,"end":285.26,"text":"אתה יכול ללכת אליה."},{"start":285.26,"end":286.42,"text":"לא, יש הבדל."},{"start":286.42,"end":287.42,"text":"יש ללכת אליה,"},{"start":287.42,"end":289.42,"text":"ויש ללכת אל-לה."},{"start":289.42,"end":290.42,"text":"זאת אחת אחרת לגמרי."},{"start":290.42,"end":291.42,"text":"למה אתה מתכוון?"},{"start":291.42,"end":292.42,"text":"אני מתכוון."},{"start":292.42,"end":293.42,"text":"אתה יכול ללכת אליה."},{"start":293.42,"end":296.42,"text":"למה אני ללכת אל-לה או אל-לה?"},{"start":296.42,"end":297.42,"text":"ללכת אל-לה!"},{"start":297.42,"end":300.7,"text":"אליה! -לא, תהיה יותר ברור, תהיה יותר ישנית כבר. -לא, אל תגיד, אל תגיד, אל תגיד."},{"start":300.7,"end":306.42,"text":"יש לה לכת אליה, יש לה לכת אל אליה! -ליה! אליה! אליה!"},{"start":306.42,"end":312.72,"text":"יש לה רגע עם חבר'ה. -חבר'ה, אל תריבו, חבל."},{"start":312.72,"end":319.33,"text":"עזבו אתכם יש טויות, בואו נלך, נשב, נשתה משהו, נעשה סליחה דברים, נלך לרחל קצת."},{"start":319.33,"end":323.61,"text":"רגע, רגע, רגע, רגע, אתה, אתה מתכוון ללכת לרחל קצת? -כן."},{"start":323.61,"end":335.37,"text":"או ללכת לרחל קצת. -מה ההבדל? ללכת לרחל קצת? -יש הבדל, חמור מאוד. יש ללכת לרחל קצת ויש ללכת לרחל קצת. -לרחל קצת! -לרחל!"},{"start":335.37,"end":340.91,"text":"אתה לא משהו לבין לנו פרקים לכם, יש לך חד! -לרחל! -ללכת לרחל!"},{"start":340.91,"end":344.6,"text":"לאל אתם הולכים? -באל! -באל!"},{"start":344.6,"end":347.55,"text":"ומחתתי! אה!"},{"start":347.55,"end":354.61,"text":"שלום לכם. ברוכים הבאים לפינתנו, אלפי אסכימוסים בלתי נירים. -וואוא!"},{"start":354.61,"end":361.31,"text":"אה! שלום לכם, אלפי אסכימוסים בלתי נירים."},{"start":361.31,"end":369.63,"text":"אה! שלום לכם, אה! תיכנסו, ברוכים הבאים, ובסורד הפרסום של שימשוני, זה איתוני חרמוני."},{"start":369.63,"end":372.39,"text":"אה! -אה, בבקשה, אילת כפיריזים, אם לא אמרתי זאת. -שימון, שימון."},{"start":372.39,"end":374.11,"text":"באיתון נושא חיים, די מאוד. -היא מאוד."},{"start":374.11,"end":375.07,"text":"אה!"},{"start":375.07,"end":380.38,"text":"אז אם לא צייתי את זה קודם, אני הקריאטיב דירקטור של משרד הפרסום הזה. -אה!"},{"start":380.38,"end":385.3,"text":"ואנחנו קיבלנו תקציב היסטרי, ושל מר היסטרים בגבד היסטרי,"},{"start":385.3,"end":389.55,"text":"של המוצר החדש, של ה\"בפלה\" החדשה של חברת מעדנית."},{"start":389.55,"end":391.91,"text":"אפשר לטעום? -אה, בוודאי שאפשר לטעום."},{"start":391.91,"end":395.81,"text":"אנחנו תמיד שמחים לשמוע את דעתו של העמךה בנושא."},{"start":395.81,"end":401.37,"text":"אה, אה, טעים, טעים מאוד. -לפי מאוד, אני רואה שקהל היעד שלנו אוהב את המוצר."},{"start":401.37,"end":406.09,"text":"ובכן ככה, אנחנו ישבנו כל ה\"ר דירקטורים\" וכל הקופירייטרים,"},{"start":406.09,"end":409.72,"text":"ועשינו בראינסטורמינג, שברנו את הראש כל הלילה,"},{"start":409.72,"end":412.9,"text":"וכיוון שהלכנו על קונספט פשוט ועממי,"},{"start":412.9,"end":417.09,"text":"שברנו את הראש והגענו לשם מהפכני,"},{"start":417.09,"end":421.7,"text":"והשם של המוצר החדש הוא אחלה,"},{"start":421.7,"end":425.63,"text":"בפלה אחלה, תודו שזה אחלה שם."},{"start":425.63,"end":427.61,"text":"ועכשיו אני מגיע לתכלס."},{"start":427.61,"end":431.66,"text":"אנחנו בחרנו בכם כשתי דמיות אותנטיות,"},{"start":431.66,"end":434.3,"text":"שבאו מהעמך, צמחו מלמטה,"},{"start":434.3,"end":439.42,"text":"אתם יהיו הכוכבים החדשים של הפרסומת שלנו לאחלה בפלה."},{"start":439.42,"end":442.3,"text":"אנחנו גם בחרנו ג'ינגל, הג'ינגל הולך ככה,"},{"start":442.3,"end":445.59,"text":"בפלה, אחלה, אחלה, בפלה,"},{"start":445.59,"end":448.73,"text":"בפלה יש לטעם מצוין, אחלה."},{"start":448.73,"end":451.87,"text":"הבפלה של העם, oh yeah."},{"start":451.87,"end":455.01,"text":"תגיד שמעון, אה?"},{"start":455.01,"end":458.1,"text":"איזה קורקנת עבר על אמא שלו?"},{"start":458.1,"end":459.2,"text":"לא יודע."},{"start":459.2,"end":461.02,"text":"נו, אז מה אתם אומרים?"},{"start":461.02,"end":464.51,"text":"מה אדוני, אתה בן אדם מאוד נחמד."},{"start":464.51,"end":472.46,"text":"אבל בפרסומת שלך חסר בכל הקמפיין מישור."},{"start":472.46,"end":473.99,"text":"אני גם כן שמתי לב."},{"start":473.99,"end":476.54,"text":"חסר מישור שלם חסר."},{"start":476.54,"end":478.66,"text":"דברו, דברו חופשי, איך אומרים אצלנו?"},{"start":478.66,"end":481.31,"text":"אנחנו תמיד אוהבים לשמוע את הדעה של העמך."},{"start":481.31,"end":485.37,"text":"תראה, אני בעלי מחשבה."},{"start":485.37,"end":490.14,"text":"בוא נאמר, \"באפלה\" זה כמו בחורה."},{"start":490.14,"end":494.01,"text":"בחורה? איזה חדופן על גיסתך?"},{"start":494.01,"end":500.89,"text":"טוב, עכשיו, נגיד אתה הולך לקנות \"באפלה\", בסדר?"},{"start":500.89,"end":502.53,"text":"קנית? -קנינו."},{"start":502.53,"end":503.93,"text":"קנית. -קנינו."},{"start":503.93,"end":505.85,"text":"סבבה, והבאפלה טעים? -טעים."},{"start":505.85,"end":507.85,"text":"טעים מאוד. -הנה, טעמנו, טעים."},{"start":507.85,"end":508.61,"text":"טעים מאוד. -טעים מאוד."},{"start":508.61,"end":512.1,"text":"יפה. עכשיו, בגלל שאתם בקמפיין של זרמוני, חרמוני, טמפוני,"},{"start":512.1,"end":515.1,"text":"אין לכם זמן להתעסק בבאפלה, לטעום אותו, אין לכם זמן לטעום."},{"start":515.1,"end":518.09,"text":"אז תשם אותו בסבבה, ככה במגירה בכיף, נכון?"},{"start":518.09,"end":521.06,"text":"רגע, אבל למה שאני לא אוכל את הבאפלה ישר?"},{"start":521.06,"end":523.82,"text":"בלום, בלום, עצור."},{"start":523.82,"end":525.82,"text":"הוא מדבר איתך במישור הפילוסופי."},{"start":525.82,"end":528.14,"text":"אה, אוקיי, אוקיי."},{"start":528.14,"end":530.16,"text":"מתחיל להבין, נכון? יפה."},{"start":530.16,"end":533.41,"text":"אתה עוקב אחריי? יפה, שים לי, וכנסת את הבאפלה למגירה?"},{"start":533.41,"end":536.02,"text":"יפה, עכשיו הבאפלה שוכב שם בחודש."},{"start":536.02,"end":538.02,"text":"איזה חודש, שוכבת חודשיים, שלושה?"},{"start":538.02,"end":540.02,"text":"איזה חודש, שנה, שנתיים עבר,"},{"start":540.02,"end":542.02,"text":"וכבר הטעם של הבאפלה זה לא מה שהיה פעם,"},{"start":542.02,"end":545.02,"text":"והוא כבר לא טעיר למה, הוא שנתיים שוכב במגירה."},{"start":545.02,"end":546.21,"text":"אז?"},{"start":546.21,"end":547.3,"text":"אז זה בדיוק כמו בחורה."},{"start":547.3,"end":549.49,"text":"אם אתה לא פועל מהר, הלך עליך."},{"start":549.49,"end":551.52,"text":"רגע, מה זאת אומרת?"},{"start":551.52,"end":554.48,"text":"וואלה, הבאפלה בדיוק כמו בחורה."},{"start":554.48,"end":556.51,"text":"רגע, ונו עם כל הקמפיין שעשינו,"},{"start":556.51,"end":558.51,"text":"כל האר דירקטורים והקופיירייטרים,"},{"start":558.51,"end":562.51,"text":"עשינו בראינסטורמינג כל הלילה."},{"start":562.51,"end":564.51,"text":"בראינסטורמינג זה עבודה בעיניהם, זה רדוד."},{"start":564.51,"end":567.51,"text":"זה רדוד, הפרסומט רדוד חסר מישור שלם."},{"start":567.51,"end":568.51,"text":"זה הכל בלמטה."},{"start":568.51,"end":571.51,"text":"אבל אתם לא מבינים, אתם יכולים להרוויח הון כסף."},{"start":571.51,"end":572.51,"text":"כשאני אומר הון, אני מתכוון הון."},{"start":572.51,"end":574.51,"text":"אתם תהיו כוכבים."},{"start":574.51,"end":578.43,"text":"בלום, תעבדו על זה, תשפצו,"},{"start":578.43,"end":580.61,"text":"תכניסו מישור פילוסופי ותקראו לנו."},{"start":580.61,"end":583.61,"text":"כמו שאומרים, don't call us, ניקולס."},{"start":583.61,"end":585.6,"text":"יאללה בובו."},{"start":585.6,"end":587.6,"text":"ואללה שימון, אתה יודע מה שאנחנו עושבים פה?"},{"start":587.6,"end":588.88,"text":"בא לי עוד מחשבה."},{"start":588.88,"end":589.85,"text":"מה?"},{"start":589.85,"end":595.5,"text":"משרד פרסום זה כמו בית זונות."},{"start":595.5,"end":596.82,"text":"למה?"},{"start":596.82,"end":600.1,"text":"כמה שאתה משלם יותר, תופקים אותך בסוף."},{"start":600.1,"end":602.1,"text":"ואללה, אתה אתה, ואללה."},{"start":602.1,"end":603.1,"text":"ואללה, תודה על הבאפלות."},{"start":603.1,"end":604.1,"text":"בלדון טוב."},{"start":604.1,"end":605.23,"text":"יאללה, בוא."},{"start":605.23,"end":606.23,"text":"רגע, הלו, הלו, רגע!"},{"start":606.23,"end":608.16,"text":"אה, שימון, בי תולד!"},{"start":608.16,"end":610.19,"text":"מה אתם יוצאים לי באמצע הקמפיין?"},{"start":610.19,"end":612.7,"text":"ערב טוב."},{"start":612.7,"end":614.66,"text":"הרי די השיגי הזה הכר."},{"start":614.66,"end":616.66,"text":"מכה חדשה פוקדת את תל אביב."},{"start":616.66,"end":618.66,"text":"מה משוטטת של ג'ודי?"},{"start":618.66,"end":626.77,"text":"ג'ודי, ג'ודי מכה לך מצלמים."},{"start":626.77,"end":627.77,"text":"ערב טוב."},{"start":627.77,"end":630.99,"text":"כאן ג'ודי לא צהרו נובשים רית קרפינור,"},{"start":630.99,"end":633.99,"text":"מרילו סוכניק שיער ואני אוהב אותך לאה."},{"start":633.99,"end":637.12,"text":"מכה חדשה נוחתת על המדינה,"},{"start":637.12,"end":639.12,"text":"מכת הצביק הפיקומניה."},{"start":639.12,"end":641.12,"text":"צביק הפיקומניה,"},{"start":641.12,"end":645.12,"text":"תופעה מוזרה ובלתי נשלטת של הזמר מלכין צביק הפיק,"},{"start":645.12,"end":651.12,"text":"להופיע בכל מקום ולהשפיע על חיי היומיום השלבים של התושבים התמימים."},{"start":651.12,"end":657.18,"text":"לקחנו את המצלמה המשוטטת ויצאנו לבדוק הקצה הקטע."},{"start":657.18,"end":662.75,"text":"כאן שורום זורום זורום רימצוויקה פיקדילי סקוויר."},{"start":662.75,"end":668.44,"text":"תקווה! נגמר פה הסבון! יש עוד סבון!"},{"start":668.44,"end":674.4,"text":"הסבון בך מאוד, דני לא רוצה בי עוד, הוא מברש את השיניים."},{"start":674.4,"end":677.4,"text":"תקווה! תקווה פיפו בבקלחה!"},{"start":677.4,"end":685.4,"text":"ואומרת למשך, אל תפקיע חיבוכה, והברז כעסן, הוא כועס מאוד אדן."},{"start":685.4,"end":688.68,"text":"מה? ככה, מיד, ישר, בלי נשיקה?"},{"start":688.68,"end":691.03,"text":"בטח שאני אתן לך נשיקה."},{"start":691.03,"end":699.34,"text":"אלף נשיקות, לך אהובתי, אלף נשיקה ונשיקה."},{"start":699.34,"end":702.38,"text":"תן לי אש. אש, אש."},{"start":702.38,"end":705.53,"text":"כך, שמור, זה יקר המצית הזה."},{"start":705.53,"end":706.62,"text":"היא לא נדלקת."},{"start":706.62,"end":707.62,"text":"מה לא נת..."},{"start":707.62,"end":709.58,"text":"תן מכה, זה מצית מהולנד."},{"start":709.58,"end":711.58,"text":"ופתאום נדלקתי..."},{"start":711.58,"end":714.69,"text":"אווו, כמה זה טוב!"},{"start":714.69,"end":720.16,"text":"כן?"},{"start":720.16,"end":721.13,"text":"שלום משפחת כהן?"},{"start":721.13,"end":722.19,"text":"לא, זה צביק הפיק."},{"start":722.19,"end":723.13,"text":"סליחה."},{"start":723.13,"end":727.51,"text":"שלום משפחת כהן?"},{"start":727.51,"end":728.63,"text":"לא, זה צביק הפיק."},{"start":728.63,"end":730.59,"text":"סליחה."},{"start":730.59,"end":734.05,"text":"שלום משפחת כהן?"},{"start":734.05,"end":736.34,"text":"לא, זה צביק הפיק."},{"start":736.34,"end":737.62,"text":"סליחה!"},{"start":737.62,"end":740.63,"text":"שלום."},{"start":740.63,"end":742.07,"text":"שלום."},{"start":742.07,"end":743.2,"text":"מי זה?"},{"start":743.2,"end":745.18,"text":"יוסי כהן."},{"start":745.18,"end":746.18,"text":"זה לא צביק הפיק?"},{"start":746.18,"end":749.27,"text":"לא אני, הוא האיש, לא אני."},{"start":749.27,"end":753.43,"text":"אין שובו מי שכבר מצפעת."},{"start":753.43,"end":754.53,"text":"זה היה נפלא."},{"start":754.53,"end":755.75,"text":"תודה."},{"start":755.75,"end":757.42,"text":"את רוצה עוד הפעם?"},{"start":757.42,"end":758.42,"text":"לא לא לא."},{"start":758.42,"end":760.89,"text":"שוב נתחיל מחדש."},{"start":760.89,"end":761.98,"text":"למה לא?"},{"start":761.98,"end":762.98,"text":"מה זה רע?"},{"start":762.98,"end":763.98,"text":"לא לא לא."},{"start":763.98,"end":766.98,"text":"גם הזמן לפעמים מתבלבל בספירה."},{"start":766.98,"end":768.2,"text":"לא."},{"start":768.2,"end":769.2,"text":"אה, בוא נראה, ארתי!"},{"start":769.2,"end":770.2,"text":"ארתי!"},{"start":770.2,"end":772.71,"text":"ארתי, שוקולד בננה."},{"start":772.71,"end":774.71,"text":"ארתי, קרתי, שוקולד לימון."},{"start":774.71,"end":776.71,"text":"איזה איזה טעמים יש לך?"},{"start":776.71,"end":778.71,"text":"ארתי, קרתי, שוקולד בננה."},{"start":778.71,"end":780.71,"text":"ארתי, קרתי, שוקולד לימון."},{"start":780.71,"end":781.71,"text":"יש לך עוד משהו?"},{"start":781.71,"end":783.77,"text":"ארתי, קרתי, שוקולד בננה."},{"start":783.77,"end":787.09,"text":"ארתי, קרתי, שוקולד לימון."},{"start":787.09,"end":788.09,"text":"הבנתי, הבנתי."},{"start":788.09,"end":790.06,"text":"אני חוזר ומדגיש לציבור בארץ,"},{"start":790.06,"end":792.06,"text":"אין מה לדאוג משטרה ארץ ישראל"},{"start":792.06,"end":794.06,"text":"תטפל בבעיית הצביק הפיקומני הזאת"},{"start":794.06,"end":796.06,"text":"ממש כשם שהיא פטרה את העלומת השוד הגדול."},{"start":796.06,"end":799.21,"text":"השוד הגדול? אני לא זוכר את זה. מתי זה היה?"},{"start":799.21,"end":802.56,"text":"זה היה בסוף הקיץ."},{"start":802.56,"end":805.1,"text":"האוויר היה חמים."},{"start":805.1,"end":808.12,"text":"הוא רחב על אופניים."},{"start":808.12,"end":810.98,"text":"לא היה מבט תמים."},{"start":810.98,"end":814.01,"text":"מתאב ומת אלול ומת חומם."},{"start":814.01,"end":817.01,"text":"אך פתרול ומענה מבוששים לבוא."},{"start":817.01,"end":822.98,"text":"ואותו הפיק עדיין מטיל עלינו פיק ברכיים שפיקתן מתפוקקת."},{"start":822.98,"end":827.98,"text":"ומובילנו לגורל פקוק ולמחר מפוקפק פיקמה."},{"start":827.98,"end":830.94,"text":"אולם ברם מידך גיסת ארתי משמע."},{"start":830.94,"end":836.94,"text":"המאמצים הבלתי נלאים למציאה תרופה ומזור עדיין נמשכים."},{"start":836.94,"end":840.0,"text":"דוקטור פוביה, האם יש פתרון לתופעת הצביק הפיקומניה?"},{"start":840.0,"end":844.0,"text":"אתה ראה, בעיה קשה מאוד לך, בעיה של צביק הפיקה."},{"start":844.0,"end":849.0,"text":"אבל אני חושב שמה צריך לצביקה, הסר לו אהבה."},{"start":849.0,"end":851.0,"text":"הוא צריך לקבל אהבה."},{"start":851.0,"end":855.0,"text":"אם הוא המצא מישהי שבאמת תאהף אותו ותתא לו קונטרי,"},{"start":855.0,"end":862.0,"text":"אני חושב שיש סיכוי לההלים מהמכה הקשה הזאת שנפלה על תל אביב."},{"start":862.0,"end":865.6,"text":"אה, צביקה אתה צריך אהבה?"},{"start":865.6,"end":871.6,"text":"לי לא אכפת להתנדב, לי לא אכפת להיות שלך."},{"start":871.6,"end":874.6,"text":"צביקה, אתה חולם עליי."},{"start":874.6,"end":877.75,"text":"צביקה, אתה רוצה אותי."},{"start":877.75,"end":883.21,"text":"תמיד אותו חלום, חלום בשם ג'ודי."},{"start":883.21,"end":903.76,"text":"רפואה, אתה שאל."},{"start":903.76,"end":909.82,"text":"קפים, סמם, מסוקים."},{"start":909.82,"end":918.99,"text":"אה, אה, אה, אה, שובה, קולד, שוקולד, דימון."},{"start":918.99,"end":947.65,"text":"כמו הבורפני, הסיף, בעלה."},{"start":947.65,"end":1005.46,"text":"הראש שלי אתה לא מאמין, פשוט אני מתפוצץ, אני שומע פטישים כל היום."},{"start":1005.46,"end":1007.46,"text":"זה כאבי טופת שהסטן לא ברע, אתה יודע לך."},{"start":1007.46,"end":1008.46,"text":"זה פה, נכון?"},{"start":1008.46,"end":1010.46,"text":"כן, פה, לקחתי הקמול, שום דבר, זה פשוט אתה..."},{"start":1010.46,"end":1013.46,"text":"אחי, אתמול גם היה לי את זה, הגעתי הביתה."},{"start":1013.46,"end":1018.46,"text":"חברה שלי, איזה פינוקים, איזה פינוקים, אתה יודע מה, מסאז ברקות."},{"start":1018.46,"end":1022.46,"text":"ליטופים כל הגוף, חיבוקים, מקלחת ויחד."},{"start":1022.46,"end":1026.46,"text":"אחי, אחרי הכל, תאמין לי מלך, מלך הרגשתי אחרי זה."},{"start":1026.46,"end":1028.71,"text":"כדאי לך לנסות, באמת."},{"start":1028.71,"end":1038.19,"text":"מה המספר של החברה יש לך, אתה גיל?"},{"start":1045.76,"end":1047.74,"text":"ועפה מנוחה."},{"start":1047.74,"end":1050.82,"text":"חג פורים נגמר, נגמרו ההופעות."},{"start":1050.82,"end":1053.82,"text":"הבלאגנים אפשר לנוח בסבבי, בקורסייה, בסלון."},{"start":1053.82,"end":1056.82,"text":"לשים רגלית בסבבה ולצפות בטלוויזיה."},{"start":1056.82,"end":1057.82,"text":"מה צריך יותר מזה?"},{"start":1057.82,"end":1059.82,"text":"שופופו איתי."},{"start":1059.82,"end":1062.3,"text":"איי, איך קוראים לו זה?"},{"start":1062.3,"end":1064.3,"text":"גבי גזית. ערב צח, גבי."},{"start":1064.3,"end":1066.3,"text":"ערב צח, שלום לך ולהתראות."},{"start":1066.3,"end":1067.3,"text":"מה אתה עורב?"},{"start":1067.3,"end":1071.89,"text":"איי, איך קוראים לו זה דודו תופז?"},{"start":1071.89,"end":1073.98,"text":"ג'וג'ו חלסטרה."},{"start":1073.98,"end":1080.27,"text":"אה, באמת, נו."},{"start":1080.27,"end":1082.68,"text":"נו."},{"start":1082.68,"end":1084.48,"text":"ולד יושבת, מה אני רואה בולי?"},{"start":1084.48,"end":1085.48,"text":"ג'י!"},{"start":1085.48,"end":1086.6,"text":"הלוי!"},{"start":1086.6,"end":1088.6,"text":"נו, מה זה זהבי, מה שלאי, נו, מה שוואדה ש..."},{"start":1088.6,"end":1089.47,"text":"אי!"},{"start":1089.47,"end":1095.48,"text":"בוא נס יערה, סנטם לפורגרמה, לתלוויזיאנו רומניקה, צי מי פארג ג'וג'ו חלסטרה."},{"start":1095.48,"end":1099.54,"text":"מרסי פרומוס, מי מוצא, סונו מייבז לומינה זילה."},{"start":1099.54,"end":1109.54,"text":"יו, מסיב דבר טי ביני, יו, כום סספון יחו שקשוקי, שווראו סספון קורקט לתות ספופולר כרער סווית לנוי,"},{"start":1109.54,"end":1113.54,"text":"לנוי גנדשתי די אסטה כוסספוני חלאסטרה."},{"start":1113.54,"end":1115.54,"text":"ישו חלאסטרה, פופולרה סבבי בבי."},{"start":1115.54,"end":1117.54,"text":"קופיה, כל קופי, בימושי..."},{"start":1117.54,"end":1132.86,"text":"אה, משהו, באמת אולי, אה, הנה, הנה, זה ערוץ הספורט, נראה זה משחק."},{"start":1132.86,"end":1137.86,"text":"ערב צח, שוב עלו בתוכנית הספורט הנפלאה, סחבסקקח,"},{"start":1137.86,"end":1142.86,"text":"ונקרת הדרבי המופלאה, אנו מארחים את קפטנים של שני הקבוצות, מקבי והפועל תל אביב."},{"start":1142.86,"end":1147.86,"text":"נמצאתי כאן ביום עם קפטן הפועל תל אביב, מר זוזו חלסטרה, ערב צח."},{"start":1147.86,"end":1152.99,"text":"ונמצאתי קפטן מקבי תל אביב, מר זוזו חלסטרה, ערב צח."},{"start":1152.99,"end":1158.13,"text":"ובכן, בעוד יומיים הדרבי, כדאי שתחשבו על תלבושות ותחשבו על זה."},{"start":1158.13,"end":1165.11,"text":"חלש, נחווה הטלוויזיית, כבירותיי ורבותיי, כמו שאומרת אשתי,"},{"start":1165.11,"end":1172.42,"text":"עדיף, ג'וזו אחד ביד, משמונה בתלעד, ועמימיר ימיר, תחשבו על זה."},{"start":1172.42,"end":1213.73,"text":"תמיד אותו חלום, חלום בשם ג'ודי לוקס, לפה אתה בינסם עדימו."}]