ם"},{"start":651.4,"end":654.2,"text":"זה מטוס, ולא טייסים כאלה"},{"start":654.2,"end":656.06,"text":"לפלפים, שלום, כרגע אנחנו"},{"start":656.06,"end":658.06,"text":"נמצאים על טורקיה, עוד מעט"},{"start":658.06,"end":659.18,"text":"מזיג האוויר, 22"},{"start":659.18,"end":660.82,"text":"מזימא, זה מעניין אחרת הזה"},{"start":660.82,"end":662.3,"text":"הטייס שילנו במטוס"},{"start":662.3,"end":663.76,"text":"החושק שוקה טייס גבר"},{"start":663.76,"end":666.44,"text":"עם שיגרה בזווית של הפה, עם היד על החלון"},{"start":666.44,"end":668.3,"text":"זה טייס, שוב אליי, חבר'ה"},{"start":668.3,"end":671.18,"text":"ערב צח, דבר ראשון, כולה בפזוטים"},{"start":671.18,"end":672.6,"text":"והטייס, מה אכפת לכלוב"},{"start":672.6,"end":673.88,"text":"הוא רואה את הסרטים כולה ביחד"},{"start":673.88,"end":676.32,"text":"הסרטים שילנו במטוס, לא דוקומנטרי"},{"start":676.32,"end":681.66,"text":"והמטוס עצמו, הטס של הטייס"},{"start":681.66,"end":682.96,"text":"פרווה על הדשבורד"},{"start":682.96,"end":685.1,"text":"מחזיק מפתחות זנף של סנאי בן 900"},{"start":685.1,"end":685.9,"text":"באמא שלי"},{"start":685.9,"end":687.36,"text":"אה, זה העושה קשוקה"},{"start":687.36,"end":688.76,"text":"כל המטחת של המטוס"},{"start":688.76,"end":690.62,"text":"זה נאונים זוהרים בצבע ירוק"},{"start":690.62,"end":693.46,"text":"ועל הזנף של המטוס"},{"start":693.46,"end":695.38,"text":"תמונות של בחורות הרובות"},{"start":695.38,"end":696.82,"text":"זה מתוס העושינג"},{"start":696.82,"end":699.34,"text":"המטוס בפנים, כולו פרווה של נמר"},{"start":699.34,"end":701.34,"text":"על הכיסאות כל אחד יש לו גורמת אישי"},{"start":701.34,"end":703.78,"text":"מה זה אוזניות האלה? גורמת העושה קשוקה"},{"start":703.78,"end":705.82,"text":"זה מתוס העושינג"},{"start":705.82,"end":707.82,"text":"ותחשבו על זה"},{"start":707.82,"end":716.06,"text":"אלן בואי נשמואל גיב אחי טוב לראות אותך"},{"start":716.06,"end":719.04,"text":"בואי נה איזה בן אדם בואי נה גזעי אה?"},{"start":719.04,"end":721.04,"text":"איזה יופי בואי נה תגיד מה תעודו אותה כול"},{"start":721.04,"end":724.96,"text":"בואי נה תעשה שלום תעשה שלום בואי נה תחייך"},{"start":724.96,"end":727.97,"text":"איזה יופי בואי נה תשב על התחת תחת על הארץ"},{"start":727.97,"end":730.06,"text":"קדימה קדימה שקב על הרצפה"},{"start":730.06,"end":732.12,"text":"שקב על רגליים באוויר רגליים באוויר"},{"start":732.12,"end":735.12,"text":"בואי נה שמואל שיחקת אותה כמו גדול אחי"},{"start":735.12,"end":737.12,"text":"בואי נה אתה ענק יאללה שמול"},{"start":737.12,"end":739.12,"text":"להתראות במשיבות אחי יום שישיבות כבחורות"},{"start":739.12,"end":740.12,"text":"אל תוותר על זה אה?"},{"start":740.12,"end":741.12,"text":"יאללה להתראות"},{"start":741.12,"end":743.12,"text":"ארצה שקב על הארץ שקב"},{"start":743.12,"end":745.15,"text":"ביי שמול"},{"start":745.15,"end":753.14,"text":"שפן הקטן שכח לסגור הדלת"},{"start":753.14,"end":757.14,"text":"הצטנן המסכן וקיבל נזלת"},{"start":757.14,"end":758.14,"text":"שלום"},{"start":758.14,"end":760.13,"text":"גם היום הייתה לי יום הולדת"},{"start":760.13,"end":763.13,"text":"וגם היום הייתי חולה ונשארתי לבד בבית"},{"start":763.13,"end":769.08,"text":"ולבשתי את הסמלה של אמא"},{"start":769.08,"end":771.08,"text":"וגם את החזיה"},{"start":771.08,"end":774.04,"text":"כן, אבא הוא תמיד לובש את הסמלה"},{"start":774.04,"end":777.04,"text":"ואת החזיה של אמא כשאמא היא לא בבית"},{"start":777.04,"end":779.04,"text":"אז אם לא מותר זכותי גם לי מותר"},{"start":779.04,"end":782.04,"text":"וגם נעלתי את המגפיים של אמא"},{"start":782.04,"end":785.04,"text":"שהיא דורכת על אבא כל הזמן"},{"start":785.04,"end":788.16,"text":"ושלבשתי את הסמלה נורא נהנת"},{"start":788.16,"end":790.16,"text":"היא היה לי ממש ממש כיף"},{"start":790.16,"end":793.16,"text":"ושאני אהיה גדול אני גם אני רוצה להיות אישה"},{"start":793.16,"end":800.38,"text":"מה זה איתיים אצל מי?"},{"start":800.38,"end":805.22,"text":"עוד מעט אני אגמור את הפינה שלי"},{"start":805.22,"end":812.69,"text":"זהו סטור הארץ נגת באדום"},{"start":812.69,"end":817.22,"text":"בוקר טוב לכם מאזינים"},{"start":817.22,"end":818.22,"text":"כאן רדיו ביץ'"},{"start":818.22,"end":821.22,"text":"כאן נמצא אתכם יוסי ג'ילרה"},{"start":821.22,"end":822.22,"text":"כאן באולפן"},{"start":822.22,"end":824.22,"text":"ושוב אנחנו בתוכנית הבוקר שלנו"},{"start":824.22,"end":827.22,"text":"וישירות נרצה לעבור למטוס המאופף של רדיו ביץ'"},{"start":827.22,"end":830.22,"text":"נמצא אתנו שם בשמיים אלעד פרופלור"},{"start":830.22,"end":832.43,"text":"בבקשה"},{"start":832.43,"end":834.43,"text":"שלום לכם שלום לכולם"},{"start":834.43,"end":837.43,"text":"כאן אלעד פרופלור במטוס של מטוס ביץ'"},{"start":837.43,"end":839.43,"text":"שוב רמותיים פקקים איומים"},{"start":839.43,"end":841.43,"text":"פקקים איומים באזור הילון"},{"start":841.43,"end":843.43,"text":"יש פקקים בצומת אולץ"},{"start":843.43,"end":845.43,"text":"גם צומת חולון פקוק"},{"start":845.43,"end":847.43,"text":"צומת ירקון עמוס לעיפה"},{"start":847.43,"end":849.43,"text":"תודה רבה לכם"},{"start":849.43,"end":851.43,"text":"אני מודה לרמי מתחסת היאס הנאמן"},{"start":851.43,"end":852.41,"text":"תודה"},{"start":852.41,"end":853.49,"text":"תודה רבה לך"},{"start":853.49,"end":855.49,"text":"אלעד פרופלור שם המטוס"},{"start":855.49,"end":856.49,"text":"במסוק הקל שלנו"},{"start":856.49,"end":859.49,"text":"ולפני שאנחנו עוברים למוזיקה על הבוקר"},{"start":859.49,"end":861.49,"text":"אני רוצה לעבור לשמרית פטיש"},{"start":861.49,"end":862.49,"text":"אי שם בצומת אשדוד"},{"start":862.49,"end":863.49,"text":"עם החכה בטרמפיאדה"},{"start":863.49,"end":865.49,"text":"בואי נעבור אלייך שמרית, בבקשה"},{"start":865.49,"end":867.45,"text":"שומעים אותי?"},{"start":867.45,"end":869.51,"text":"שומעים אותי? שומעים אותי שלער?"},{"start":869.51,"end":871.51,"text":"כאן שמרית פטיש?"},{"start":871.51,"end":873.51,"text":"אני נמצאת בצומת"},{"start":873.51,"end":875.51,"text":"אשדוד"},{"start":875.51,"end":877.51,"text":"בבקקים איומים"},{"start":877.51,"end":879.51,"text":"בצומת אשדוד"},{"start":879.51,"end":881.51,"text":"אני מקווה שהכל בסדר שומעים"},{"start":881.51,"end":883.51,"text":"חלים"},{"start":883.51,"end":885.51,"text":"בואי להתיים האוטו מוסדר"},{"start":885.51,"end":887.51,"text":"תודה רבה לך שמרית"},{"start":887.51,"end":889.51,"text":"אין ספק שיש בבקקים איומים בצומת אשדוד"},{"start":889.51,"end":891.51,"text":"ובכן תוכנית הבוקר שלנו מתחילה"},{"start":891.51,"end":893.51,"text":"כרגיל בבקקים"},{"start":893.51,"end":895.51,"text":"אבל עוד שעה שעתיים הכל ייפתח"},{"start":895.51,"end":897.83,"text":"כאן יוסף ג'ילרה"},{"start":897.83,"end":898.83,"text":"כאן באולפן"},{"start":898.83,"end":899.83,"text":"הרדיו שלכם"},{"start":899.83,"end":900.83,"text":"רדיו ביץ'"},{"start":900.83,"end":901.83,"text":"רדיו ביטנוחה"},{"start":901.83,"end":902.95,"text":"תודה"},{"start":902.95,"end":904.39,"text":"ערב טוב לכולם"},{"start":904.39,"end":906.39,"text":"ושוב אנו בתוכנית הרעיונות הנפלאה"},{"start":906.39,"end":909.39,"text":"התוכנית היחידה שמצליחה לדובב את כולם"},{"start":909.39,"end":910.39,"text":"עונת הקיץ בעיצומה"},{"start":910.39,"end":911.39,"text":"רבים טסים לחול"},{"start":911.39,"end":912.39,"text":"תגידי לי את"},{"start":912.39,"end":914.39,"text":"לאן את טסה"},{"start":914.39,"end":915.39,"text":"יפה מאוד"},{"start":915.39,"end":916.39,"text":"יש לנו כאן עיתות פה בצד"},{"start":916.39,"end":918.39,"text":"או חטפתי פנס בעין"},{"start":918.39,"end":920.39,"text":"בואי נעתה מספר"},{"start":920.39,"end":921.39,"text":"ועכשיו שאלה למאזינים"},{"start":921.39,"end":923.39,"text":"אנחנו עשינו בה משהו"},{"start":923.39,"end":924.39,"text":"השאלה שלי"},{"start":924.39,"end":926.39,"text":"למה היא שימשה"},{"start":926.39,"end":927.35,"text":"תגידי לי מותק"},{"start":927.35,"end":929.35,"text":"תגידי מה את מראה לנו פה"},{"start":929.35,"end":930.35,"text":"אתה קרא את הספר"},{"start":930.35,"end":932.35,"text":"איזה ספר תקרא"},{"start":932.35,"end":935.41,"text":"תגידי מאיזה מושב אתה"},{"start":935.41,"end":936.5,"text":"אתה תסתום את הפה"},{"start":936.5,"end":937.5,"text":"אל תוציא הגה"},{"start":937.5,"end":939.58,"text":"מצפצף עליי"},{"start":939.58,"end":941.58,"text":"ערב טוב לכם"},{"start":941.58,"end":942.58,"text":"שוב הגיעה לסיומה"},{"start":942.58,"end":943.58,"text":"עוד תוכנית נפלאה"},{"start":943.58,"end":944.58,"text":"תוכנית הרעיונות"},{"start":944.58,"end":945.58,"text":"שמה צריכה לדובב את כולם"},{"start":945.58,"end":946.58,"text":"היו עם אנו כמו היום"},{"start":946.58,"end":947.58,"text":"גם בשבוע הבא"},{"start":947.58,"end":948.58,"text":"באותה שעה"},{"start":948.58,"end":949.58,"text":"באותו ערוץ"},{"start":949.58,"end":950.58,"text":"להתראות"},{"start":950.58,"end":951.58,"text":"לילה טוב"},{"start":951.58,"end":953.41,"text":"חג שמח"},{"start":953.41,"end":954.41,"text":"תלחת לקלוט משהו"},{"start":954.41,"end":955.41,"text":"מכל העניין הזה"},{"start":955.41,"end":959.73,"text":"תודה רבה"},{"start":959.73,"end":968.83,"text":"רבותיי"},{"start":968.83,"end":969.83,"text":"פלאפונים"},{"start":969.83,"end":970.79,"text":"פלאפונים"},{"start":970.79,"end":971.79,"text":"ביפרים"},{"start":971.79,"end":972.79,"text":"ווקי-טוקי"},{"start":972.79,"end":973.79,"text":"מכשירי על חוץ"},{"start":973.79,"end":974.79,"text":"רק היום רבותיי"},{"start":974.79,"end":975.79,"text":"בואי גברת"},{"start":975.79,"end":976.79,"text":"בואי אדון"},{"start":976.79,"end":977.79,"text":"בואי תקנו"},{"start":977.79,"end":978.79,"text":"עוד פלאפון"},{"start":978.79,"end":979.79,"text":"אלו גברת"},{"start":979.79,"end":980.79,"text":"לא תקנה חולצת שיפונים"},{"start":980.79,"end":981.79,"text":"לא נביא לך"},{"start":981.79,"end":982.79,"text":"פלאפון"},{"start":982.79,"end":983.79,"text":"מה לא כלום"},{"start":983.79,"end":985.01,"text":"כן בבקשה"},{"start":985.01,"end":986.01,"text":"מה אני יכול"},{"start":986.01,"end":987.01,"text":"יש הכל"},{"start":987.01,"end":988.01,"text":"שימי"},{"start":988.01,"end":989.01,"text":"זה עם חיבור ישיר"},{"start":989.01,"end":990.01,"text":"אלפיים שקל"},{"start":990.01,"end":991.01,"text":"זה החדש"},{"start":991.01,"end":992.01,"text":"עוד יותר טוב"},{"start":992.01,"end":992.11,"text":"זה נפתח קטן"},{"start":992.01,"end":993.01,"text":"אלפיים שבע מאות"},{"start":993.01,"end":994.01,"text":"יש לי לי ילדים"},{"start":994.01,"end":995.01,"text":"אלף שקל"},{"start":995.01,"end":995.98,"text":"לבית"},{"start":995.98,"end":996.98,"text":"מה תרצה?"},{"start":996.98,"end":998.3,"text":"כמה יש לך?"},{"start":998.3,"end":999.3,"text":"יש לי עשרה שקלים"},{"start":999.3,"end":1000.3,"text":"עשרה שקלים?"},{"start":1000.3,"end":1001.3,"text":"אין בעיה"},{"start":1001.3,"end":1002.3,"text":"אני נותן שירות לכל אחד"},{"start":1002.3,"end":1003.45,"text":"כך אחי"},{"start":1003.45,"end":1004.58,"text":"כך כונחייה"},{"start":1004.58,"end":1005.51,"text":"תתחבר לבד"},{"start":1005.51,"end":1005.61,"text":"בסדר?"},{"start":1005.51,"end":1006.76,"text":"יאללה"},{"start":1006.76,"end":1007.76,"text":"יאללה"},{"start":1007.76,"end":1008.76,"text":"פלאפוני מוקיטוק"},{"start":1008.76,"end":1009.76,"text":"ילחותי"},{"start":1009.76,"end":1010.76,"text":"יאללה"},{"start":1010.76,"end":1011.76,"text":"הופה הופה"},{"start":1011.76,"end":1022.11,"text":"שרון סטונס וקלודיה שיפר משתמשת רק בביפר והביפר הוא רוטט יש לי אחלה של גורבת"},{"start":1022.11,"end":1023.11,"text":"תודה"},{"start":1023.11,"end":1027.14,"text":"חייטומי! חייטומי! יאללה! יאללה תחתוב!"},{"start":1027.14,"end":1028.14,"text":"תחתוב המתיח!"},{"start":1028.14,"end":1032.13,"text":"לא! אל תהרגו אותי בבקשה!"},{"start":1032.13,"end":1034.09,"text":"מה זה זה?"},{"start":1034.09,"end":1035.09,"text":"אל תהרגו אותי בבקשה באמת!"},{"start":1035.09,"end":1036.09,"text":"מי זה?"},{"start":1036.09,"end":1037.09,"text":"מי תהבר? אלו? מי אתה?"},{"start":1037.09,"end":1040.79,"text":"אני אני, אני, אני אבטיח פלא! אל תהרגו אותי בבקשה!"},{"start":1040.79,"end":1041.79,"text":"מה זאת אומרת אבטיח פלא?"},{"start":1041.79,"end":1043.79,"text":"אבטיח פלא! אני מגשים משאלות!"},{"start":1043.79,"end":1047.87,"text":"אם תחוסו על חיי, כל אחד ממכם יקבל משאלה."},{"start":1047.87,"end":1049.87,"text":"אבל רק אחת, משאלה אחת בלבד."},{"start":1049.87,"end":1052.63,"text":"יש לי! יש לי, יש לי, יש לי!"},{"start":1052.63,"end":1053.63,"text":"דבר."},{"start":1053.63,"end":1057.27,"text":"אני רוצה להיות בפה גבה?"},{"start":1057.27,"end":1060.62,"text":"לא! אני רוצה להיות בפה ריס!"},{"start":1060.62,"end":1062.61,"text":"פריס!"},{"start":1062.61,"end":1070.76,"text":"יש לי גם, יש לי!"},{"start":1070.76,"end":1073.89,"text":"תשמע, אני רוצה להיות ברו-איך?"},{"start":1073.89,"end":1076.21,"text":"לא! אני רוצה להיות ברו-מה!"},{"start":1076.21,"end":1078.27,"text":"רו-מה!"},{"start":1080.27,"end":1085.71,"text":"יש לי, יש לי, יש לי, יש לי!"},{"start":1085.71,"end":1088.99,"text":"אני רוצה להיות בלס ועדין!"},{"start":1088.99,"end":1093.36,"text":"לא! אני רוצה להיות בלס וגס!"},{"start":1093.36,"end":1095.36,"text":"לס וגס!"},{"start":1095.36,"end":1098.35,"text":"אה! איפה?"},{"start":1098.35,"end":1102.13,"text":"חבר'ה! איפה אתם?"},{"start":1102.13,"end":1105.38,"text":"חבר'הם! איפה אתם?"},{"start":1105.38,"end":1107.84,"text":"יש לי, יש לי, יש לי!"},{"start":1107.84,"end":1109.84,"text":"אבטיח פלא, אבטיח פלא!"},{"start":1109.84,"end":1110.84,"text":"יש לי!"},{"start":1110.84,"end":1114.65,"text":"אני רוצה להיות לבד!"},{"start":1114.65,"end":1117.88,"text":"לא! משעמם לי!"},{"start":1117.88,"end":1126.92,"text":"אני רוצה שהם יחזרו לפה!"},{"start":1126.92,"end":1129.44,"text":"איי!"},{"start":1129.44,"end":1132.0,"text":"מה?"},{"start":1132.0,"end":1133.18,"text":"יש לי, יש לי!"},{"start":1133.18,"end":1135.32,"text":"חבר'ה, אתם שוב ביחד!"},{"start":1135.32,"end":1137.5,"text":"כאס!"},{"start":1137.5,"end":1140.97,"text":"היינו בכל את הלמדים!"}]