[{"start":31.2,"end":33.35,"text":"הלוחים הוואים"},{"start":33.35,"end":50.91,"text":"שמעתי שבהגרלה יצא לאוזי פוקס"},{"start":50.91,"end":64.6,"text":"שמעתי שבמשפט הוציאו את דודו, זכאי"},{"start":64.6,"end":78.17,"text":"שמעתי שבעסקים היה לזאב רווח"},{"start":89.55,"end":91.93,"text":"יש לי, יש לי, יש לי, נו?"},{"start":91.93,"end":98.28,"text":"שמעתי שספי ריבלין מוכשר, יוווו מוכשר!"},{"start":98.28,"end":107.29,"text":"הבית של פסטוקו, בית מוזר, עוברים את ההר מסביב לבית שלי."},{"start":107.29,"end":119.63,"text":"ערב זך, ערב זך ושוב אנחנו בחלסטרה של זוזו."},{"start":119.63,"end":123.66,"text":"והפעם, כמו כל עם ישראל, נסיתי לחול, אמרתי מה יש, ניסה לחופש."},{"start":123.66,"end":127.65,"text":"באמא שלי, איך שאליתי על המטוס, עלתה לי החלסטרה."},{"start":127.65,"end":130.65,"text":"מה זה העלעלה זה באמא שלי? שגעו אותי, לא ידעתי מה לעשות."},{"start":130.65,"end":133.65,"text":"קודם כל, כל הדיילות לבושות באמא שלי לא ידעתי איך."},{"start":133.65,"end":137.65,"text":"חולצה סגורעת פה ושמו להם כזאת עניבה כמו של הצופים."},{"start":137.65,"end":140.65,"text":"חשבתי הולכים על שנדות עוד מעט נעשה עליכת זיקית במטוס."},{"start":140.65,"end":141.65,"text":"מה זה הערת הזה?"},{"start":141.65,"end":145.65,"text":"אחר כך, הם באו עלינו עם כל מיני דוגמיות כאלה של פינלנדיה קטל."},{"start":145.65,"end":147.65,"text":"ואני רגע לשתות ארבע וודקה בשקט."},{"start":147.65,"end":152.65,"text":"בי קוקה קולה עוד יותר קטן, בימא שלי בקסועית כזה מגעיל."},{"start":152.65,"end":157.65,"text":"והחייבסה הביאו לנו חביתה ארוחת בוקר, מקופלת שמונה פעמים חשבתי תישו, הביתי כנוע."},{"start":157.65,"end":164.65,"text":"אחר כך, באה לנו הדיילת הראשית בימא שלי עם שפם, והתחילה לעשות לנו פרסומת מה קורה בשעת אסון."},{"start":164.65,"end":169.65,"text":"בימא שלי איזה פחד, אם קורה משהו, ככה היא תעשה את הקעה, תוריד עליה, תורי את המסכת חמצן, תשימ אותה."},{"start":169.65,"end":171.65,"text":"בימא שלי מהפחד, הכיתי על זה שלפניי."},{"start":171.65,"end":172.65,"text":"מה זה החרט הזה?"},{"start":172.65,"end":179.11,"text":"חלס, הגיע הזמן להקשיב לי, זו זו ארפלייס, חברת התעופה הבינלאומית."},{"start":179.11,"end":183.11,"text":"ואללה, אתה נכנס למטוס, באה לך דיילת, חתיכה."},{"start":183.11,"end":186.11,"text":"נוטט חשתי בקבוקה, רק זכלהוי, רק מהסבבי אתה שותה אותו."},{"start":186.11,"end":189.11,"text":"אתה כבר עולה מעביר בכלל והמטוס עוד על הקרקע."},{"start":189.11,"end":196.11,"text":"אחר כך כולם בסבבי בבי, מוזיקה, בלגנים, באות עליך דיילות עם בגדים של ריקודי בטת."},{"start":196.11,"end":199.11,"text":"ובאות עליך עם האוכל, ומה זה אוכל?"},{"start":199.11,"end":202.15,"text":"בזה נפשי למטוס, שוחדתי בקבס!"},{"start":202.15,"end":206.17,"text":"סביב קבס וסמים אותו על המעבר של המטוס שיצרח בכל הצדדים."},{"start":206.17,"end":208.17,"text":"והיא מביאים לכל אחד אוכל!"},{"start":208.17,"end":211.17,"text":"ובירות! וסבבי בבי בבי, בבי, בבי, בבי, בבי מסליף!"},{"start":211.17,"end":212.17,"text":"לא רוצים להרדמה המטוס!"},{"start":212.17,"end":214.17,"text":"שבועיים טסתי ולא חזרתי עוד לארץ!"},{"start":214.17,"end":216.17,"text":"אז תחשבו על זה!"},{"start":216.17,"end":231.6,"text":"שקל כמה, תוחל!"},{"start":231.6,"end":233.6,"text":"תראה איזה רזה, מה קל!"},{"start":233.6,"end":235.6,"text":"שקל כמה, תחשב לאבא שלך!"},{"start":235.6,"end":237.6,"text":"שקל כמה, תחשב!"},{"start":237.6,"end":238.6,"text":"אתה תוכל!"},{"start":238.6,"end":239.6,"text":"שאומרים לך תוכל!"},{"start":239.6,"end":240.6,"text":"תשתוג ותוכל!"},{"start":240.6,"end":242.6,"text":"אתה גם עדית אבא שלך!"},{"start":242.6,"end":245.57,"text":"שקל כמה, חיילים!"},{"start":245.57,"end":247.57,"text":"שקל כמה, שקל כמה, שקל כמה!"},{"start":247.57,"end":249.57,"text":"שקל כמה, שקל כמה, שקל כמה!"},{"start":249.57,"end":251.57,"text":"לא, לא, לא, אכלו בו הים עלי מנכלים!"},{"start":251.57,"end":253.57,"text":"לא, לא, אתם חיילי צאצ'"},{"start":253.57,"end":255.57,"text":"שקל כמה, תראה, תלמד!"},{"start":255.57,"end":257.57,"text":"שקל כמה, חיילים!"},{"start":257.57,"end":259.57,"text":"זה גולעתי!"},{"start":259.57,"end":261.57,"text":"מה גולעתי, זה צלחתי!"},{"start":261.57,"end":263.57,"text":"בלי להליף, לא, לא, תעזבו, תעזבו, תעזבו."},{"start":263.57,"end":265.57,"text":"היי לא, בנאדם יוטה לך אוהב, לא."},{"start":265.57,"end":265.67,"text":"לא, די, נו, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי, אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי אחי"},{"start":265.57,"end":267.57,"text":"לא, די, נו אחי, תעזבו."},{"start":267.57,"end":269.53,"text":"גם אני אבי משחל."},{"start":269.53,"end":272.08,"text":"שקל! אני אמרתי לך תוכל!"},{"start":272.08,"end":274.08,"text":"ושמעת מה אמר לך תוכל."},{"start":274.08,"end":276.08,"text":"אמרתי לך, מביא לך אוכל, תוכל!"},{"start":276.08,"end":278.4,"text":"לא, תוכל!"},{"start":278.4,"end":280.49,"text":"אני אמרתי לך תוכל, לא?"},{"start":280.49,"end":282.49,"text":"תוכלו, איש לי אוכל, אה!"},{"start":282.49,"end":284.49,"text":"אתם תוכלו!"},{"start":284.49,"end":309.4,"text":"בואי עשה בלבור!"},{"start":309.4,"end":314.78,"text":"איזה מדינה מלוכדת מדינה שלה לוחדת,"},{"start":314.78,"end":317.35,"text":"מדינה נלוחדת,"},{"start":317.35,"end":319.35,"text":"איזה מדינה..."},{"start":319.35,"end":321.82,"text":"אה!"},{"start":322.95,"end":324.95,"text":"אמר לכם לאכול בטוב, לא!"},{"start":324.95,"end":326.95,"text":"ותאבול כפר עליך, תאבול!"},{"start":326.95,"end":328.95,"text":"יהיה בריא, יהיה בריא, כך!"},{"start":328.95,"end":330.95,"text":"אה, לא תאכלו בטוב, תאכלו ברע!"},{"start":330.95,"end":332.95,"text":"תאכלו, תאכלו!"},{"start":332.95,"end":334.17,"text":"סבתא!"},{"start":334.17,"end":337.57,"text":"נו סבתא, תגיד איך צבא, איך מסע קומת?"},{"start":337.57,"end":339.21,"text":"קשה מסע קומת!"},{"start":339.21,"end":340.21,"text":"אתה מתגייס, מתי?"},{"start":340.21,"end":341.21,"text":"מתגייל אותו!"},{"start":341.21,"end":342.59,"text":"מתי?"},{"start":342.59,"end":345.65,"text":"אני 24, אותו, בסדר, יב, בסדר, כך!"},{"start":345.65,"end":346.65,"text":"סבתא!"},{"start":346.65,"end":347.65,"text":"לאן אתה רוצה להתגייס?"},{"start":347.65,"end":349.65,"text":"לאן שקחו אותי טוב?"},{"start":349.65,"end":350.65,"text":"ליד הבית!"},{"start":350.65,"end":352.35,"text":"חלב!"},{"start":352.35,"end":354.37,"text":"חלב רוצה עוד קרובי!"},{"start":354.37,"end":355.37,"text":"לא!"},{"start":355.37,"end":357.37,"text":"אבירון!"},{"start":357.37,"end":361.37,"text":"עכשיו אם מישהו יגיד משהו על האוכל"},{"start":361.37,"end":362.37,"text":"ואם אשליתי זר רוחה"},{"start":362.37,"end":364.37,"text":"איך האוכל? טעים, אה?"},{"start":364.37,"end":365.37,"text":"עצר, עצר!"},{"start":365.37,"end":366.37,"text":"שטעק!"},{"start":366.37,"end":367.29,"text":"איזה מי!"},{"start":367.29,"end":383.0,"text":"לעיר נשא יעל!"},{"start":383.0,"end":384.12,"text":"ערד!"},{"start":384.12,"end":385.12,"text":"יעל ערד!"},{"start":385.12,"end":386.08,"text":"יעל!"},{"start":386.08,"end":389.79,"text":"יש לי, יש לי, יש לי!"},{"start":389.79,"end":391.82,"text":"לעיזה עיר נשא ירון?"},{"start":391.82,"end":393.81,"text":"לונדון ירון!"},{"start":393.81,"end":395.81,"text":"לונדון!"},{"start":395.81,"end":399.95,"text":"יש לי, יש לי!"},{"start":399.95,"end":400.95,"text":"נו!"},{"start":400.95,"end":401.95,"text":"לאיזה עיר נשא גבי?"},{"start":401.95,"end":402.91,"text":"ברלין!"},{"start":402.91,"end":405.58,"text":"גבי ברלין!"},{"start":405.58,"end":407.58,"text":"ברלין!"},{"start":407.58,"end":411.58,"text":"יש לי, יש לי, יש לי, יש לי!"},{"start":411.58,"end":415.47,"text":"איפה נמצא עכשיו יאיר לוי?"},{"start":415.47,"end":416.98,"text":"בכלא!"},{"start":416.98,"end":425.17,"text":"יאיר..."},{"start":425.17,"end":427.29,"text":"בכלא!"},{"start":427.29,"end":432.51,"text":"משונה שלי ברדיו, אז..."},{"start":432.51,"end":434.51,"text":"אל תתרגש, אל תתרגש."},{"start":434.51,"end":436.51,"text":"בסך הכל מאוד פשוט."},{"start":436.51,"end":438.51,"text":"נדאג את שם נורא אדומה שאנחנו בשידור."},{"start":438.51,"end":440.51,"text":"אה, שיש מנורה אדומה שאנחנו מתחילים..."},{"start":440.51,"end":442.51,"text":"שאנחנו בשידור, אתה תשימה אליך אוזניות,"},{"start":442.51,"end":444.51,"text":"אתה תשמע את הכל."},{"start":444.51,"end":446.51,"text":"אתה תגיד לי, לא?"},{"start":446.51,"end":448.51,"text":"כן, אנחנו כבר עוד דקה, שניים,"},{"start":448.51,"end":450.51,"text":"כבר אתה יכול לשים את האוזניות, בוא נתכונן."},{"start":450.51,"end":452.51,"text":"אנחנו מתחילים בשידור, אתה תשמע את מוזיקלי,"},{"start":452.51,"end":454.51,"text":"ומיד אחר כך לא מתחילים, אוקיי?"},{"start":454.51,"end":456.45,"text":"אני אשאלת לך כמה שאלות, זה יהיה נורא."},{"start":456.45,"end":462.08,"text":"אוקיי, אנחנו בשידור, אוקיי?"},{"start":462.08,"end":464.08,"text":"ערב טוב, שלום רב, מאזינים יקרים."},{"start":464.08,"end":466.08,"text":"כאן אנחנו בתוכניתנו"},{"start":466.08,"end":470.08,"text":"רדיו תרבות, ברדיו ביט, שאתם על הסקאלה ב-32.4"},{"start":470.08,"end":472.08,"text":"איתכם נמצא אלכס פרידמן"},{"start":472.08,"end":474.08,"text":"ברדיו תרבות, והפעם"},{"start":474.08,"end":476.08,"text":"אנחנו מערכים את ענו כאן בערב"},{"start":476.08,"end":478.23,"text":"את הסופר הנודע"},{"start":478.23,"end":480.23,"text":"את מי שכתב את הספר הלאית היום"},{"start":480.23,"end":482.23,"text":"בדוכנים, נמר בחיסלב"},{"start":482.23,"end":484.23,"text":"נמצא איתנו כאן דן שיגולד"},{"start":484.23,"end":486.23,"text":"אנחנו נשאל אותו כמה שאלות"},{"start":486.23,"end":488.23,"text":"ואנחנו נמשיך במוזיקה קלה"},{"start":488.23,"end":490.23,"text":"ובכן, ערב טוב, דן"},{"start":490.23,"end":493.22,"text":"ובכן, דן שיגולד, אין ספק"},{"start":493.22,"end":495.22,"text":"אחרי שקראתי את הספר, אני חושב"},{"start":495.22,"end":497.66,"text":"שאין ספק שאנחנו יוצרים כאן"},{"start":497.66,"end":500.04,"text":"ז'אנר חדש בכתיבה העברית"},{"start":500.04,"end":500.88,"text":"האם אתה מסכים איתי?"},{"start":500.88,"end":505.12,"text":"ובכן, האם אתה חושב שהסיפור"},{"start":505.12,"end":507.54,"text":"על נסיכה שגילתה את המיניות שלה"},{"start":507.54,"end":509.39,"text":"לא מזכיר מעט את הכתיבה"},{"start":509.39,"end":510.97,"text":"של הסופר ג' ב' קרציה?"},{"start":510.97,"end":513.73,"text":"אני מבין, אכן"},{"start":513.73,"end":516.71,"text":"האם יש סיכוי שהספר"},{"start":516.71,"end":518.15,"text":"יהפוך למחזה להורא?"},{"start":518.15,"end":523.62,"text":"אני מבין"},{"start":523.62,"end":525.62,"text":"תראה, היו מבקרים"},{"start":525.62,"end":526.94,"text":"שלא כל כך אהבו את הספר"},{"start":526.94,"end":528.26,"text":"בלשון המעתיים, מותר לי"},{"start":528.26,"end":530.65,"text":"אולי לא נצטט, אבל בעיקר המבקר"},{"start":530.65,"end":532.23,"text":"מאיר חזה אוף"},{"start":532.23,"end":534.33,"text":"ממש קטל את הספר בהחזריות"},{"start":534.33,"end":537.16,"text":"האם אתה? אני מקווה שנהנית"},{"start":537.16,"end":538.94,"text":"איתנו באולפן כמו שאנחנו נהננו"},{"start":538.94,"end":540.97,"text":"מאזינים עיקרים, רדיו ביץ'"},{"start":540.97,"end":542.67,"text":"אנחנו כאן על הסקאלה"},{"start":542.67,"end":545.08,"text":"כאן מאיר פרידמן, להתראות"},{"start":545.08,"end":549.31,"text":"היה אחלה, בואי נה, יופי"},{"start":549.31,"end":551.41,"text":"אני חושב שזה קלח"},{"start":551.41,"end":552.39,"text":"אשמח עוד עוד פעם"},{"start":552.39,"end":557.01,"text":"100% בהצלחה, אני מאוד אוהב את הכתיבה שלך"},{"start":557.01,"end":558.01,"text":"ערב טוב לכולם"},{"start":558.01,"end":560.63,"text":"שוב אנו בתוכנית הרעיונות הנפלאה שלנו"},{"start":560.63,"end":563.93,"text":"התוכנית היחידה המדהימה שמצליחה לדובב את כולם"},{"start":563.93,"end":565.47,"text":"שימו לד, ערב טוב לך"},{"start":565.47,"end":566.91,"text":"את עשית טיול סביב לעולם"},{"start":566.91,"end":569.3,"text":"ספרי לנו איזה חוויות חווית"},{"start":569.3,"end":570.21,"text":"יפה מאוד"},{"start":570.21,"end":571.35,"text":"ואתה קראת הספר"},{"start":571.35,"end":573.09,"text":"לאיזה עמוד הגעת"},{"start":573.09,"end":576.62,"text":"אלו אלו, תפסיקו לבכות פה בחית המרורים"},{"start":576.62,"end":579.32,"text":"אלו אדוני, אתה אל תדאג"},{"start":579.32,"end":580.64,"t