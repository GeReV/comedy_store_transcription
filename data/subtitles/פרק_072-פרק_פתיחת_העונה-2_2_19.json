[{"start":0.51,"end":3.85,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות"},{"start":3.85,"end":9.33,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט"},{"start":9.33,"end":15.21,"text":"שמות האנשים והמקומות שונו לצורך העלילה"},{"start":15.21,"end":16.65,"text":"ומאתה הם נקראים"},{"start":16.65,"end":18.08,"text":"הקומדיס"},{"start":18.08,"end":58.92,"text":"שפיה, מה שלום הבת שלך?"},{"start":58.92,"end":60.15,"text":"יופי"},{"start":60.15,"end":62.89,"text":"ערב טוב כאן נכבד אתם איתנו כאן איתי"},{"start":62.89,"end":65.65,"text":"עם סרוליק פדידה במועדון שלי"},{"start":65.65,"end":67.89,"text":"מועדון הג'יפה"},{"start":67.89,"end":75.99,"text":"תודה, תודה שפיה, תודה קאקון"},{"start":75.99,"end":79.71,"text":"וכבר לפני שנפתח אני רק אציין שהיום ההכנסות"},{"start":79.71,"end":82.55,"text":"כאן כאן במועדון שלנו שעבר שיפוץ לא מכבר"},{"start":82.55,"end":87.21,"text":"הם קודש תרומה לסוני אבוטשבילי שעשתה לו מזמן כבלים"},{"start":87.21,"end":90.18,"text":"אבל לא נשאר לכסף לממיר"},{"start":90.18,"end":92.45,"text":"תקפיים לסוני אבוטשבילי"},{"start":92.45,"end":93.9,"text":"שנייה אחד"},{"start":93.9,"end":103.56,"text":"חבר'ה, מי שגנב להיסע סחר את ההגה מהאוטו"},{"start":103.56,"end":106.08,"text":"שיחזיר לו כי הוא חוסם את המתנס"},{"start":106.08,"end":111.92,"text":"סחר, הלו שויה, הלו קאקון"},{"start":111.92,"end":114.56,"text":"ועכשיו כאן, אכבד, יש לי הכבוד להזמין אותם"},{"start":114.56,"end":116.32,"text":"הם כאן, הם משלנו"},{"start":116.32,"end":117.42,"text":"קבלו אותם"},{"start":117.42,"end":122.07,"text":"הצמד מהשכונה, הם גרים בבלוק מספר 4"},{"start":122.07,"end":123.23,"text":"קבלו אותם"},{"start":123.23,"end":128.14,"text":"הצמד שחזר מתור הופעות ביפו הציקה"},{"start":128.14,"end":131.89,"text":"האחים הנפלאים"},{"start":131.89,"end":135.4,"text":"צמד הציקוצית, הלו הם, האחים"},{"start":135.4,"end":136.81,"text":"ROA"},{"start":136.81,"end":148.13,"text":"תודה רבה לכולם, אנחנו אחים ARLA"},{"start":148.13,"end":150.47,"text":"זהו רובי, אני אסה"},{"start":150.47,"end":151.35,"text":"תודה רבה"},{"start":151.96,"end":155.72,"text":"אנחנו נשמיע לכם אתיו נעימות של שירים אהובים ומוכרים לכולם"},{"start":155.72,"end":158.32,"text":"להיטים שהפכו לקלאסיקה עולמית"},{"start":158.32,"end":160.78,"text":"עיר גדולה וזרה"},{"start":160.78,"end":163.87,"text":"לילה אפל ואפלולי ותחוב"},{"start":163.87,"end":166.55,"text":"ברחוב הרשי פוסעים להם שני אנשים"},{"start":166.55,"end":168.33,"text":"אולי אתם מכירים אותנו"},{"start":168.33,"end":170.37,"text":"בשבילנו הם זרים לחלוטין"},{"start":170.37,"end":171.76,"text":"זרים בלילה"},{"start":171.76,"end":173.52,"text":"strangers in the night"},{"start":173.52,"end":194.8,"text":"תודה רבה, תודה רבה"},{"start":194.8,"end":199.03,"text":"בואו ניכנס כולנו לאווירה רומנטית"},{"start":199.03,"end":203.05,"text":"בואו נדליק כולנו נרות בחומו של יום קיץ"},{"start":203.05,"end":204.78,"text":"summer time"},{"start":204.78,"end":208.43,"text":"בואו כולנו יחד נגרגר גרשוין"},{"start":208.43,"end":241.39,"text":"נצא כולנו מן האווירה המלנקולית"},{"start":241.39,"end":243.35,"text":"וניכנס לרגע של נוסטלגיה"},{"start":243.35,"end":245.41,"text":"הישר מהאלבום הקודם שלנו"},{"start":245.41,"end":248.15,"text":"מנגינה עליזה סוחפת ומוכרת"},{"start":248.15,"end":249.35,"text":"עבירותיי ועבירותיי"},{"start":249.35,"end":250.71,"text":"הבימבו"},{"start":250.71,"end":310.59,"text":"מה עשו לכם, מה היה?"},{"start":311.36,"end":313.36,"text":"נראה לי לא התקבלתי"},{"start":313.36,"end":314.61,"text":"למה?"},{"start":314.61,"end":315.61,"text":"רצו שנעשה ג'ודי לוץ"},{"start":315.61,"end":316.61,"text":"ג'ודי לוץ, הם לא יום מרוצים"},{"start":316.61,"end":317.61,"text":"עשית?"},{"start":317.61,"end":318.61,"text":"כן, עשיתי"},{"start":318.61,"end":319.61,"text":"איפה, טוב"},{"start":319.61,"end":320.61,"text":"כאן קרפינס, ממה ג'ודי"},{"start":320.61,"end":321.61,"text":"ממה זבי"},{"start":321.61,"end":322.61,"text":"גדול"},{"start":322.61,"end":323.61,"text":"מה אתה עושה?"},{"start":323.61,"end":324.61,"text":"לא יודע, זה כנראה צריך פרוטקציה"},{"start":324.61,"end":326.7,"text":"אני לא מאמין, חברי חבר"},{"start":326.7,"end":327.7,"text":"מה תעשה?"},{"start":327.7,"end":328.7,"text":"אני הולך לנסה להתקבל"},{"start":328.7,"end":329.7,"text":"לפחות מזל מסכל עם נתן דאטנר"},{"start":329.7,"end":330.96,"text":"אה, מגנים"},{"start":330.96,"end":331.96,"text":"דה רבה"},{"start":331.96,"end":332.96,"text":"בהצלחה"},{"start":332.96,"end":333.96,"text":"על הכפק, ביי"},{"start":333.96,"end":334.96,"text":"דה רבה"},{"start":334.96,"end":340.96,"text":"טוב, אז ככה נשארו ככה דולב, כפיר, צור, סניר וחלפון"},{"start":340.96,"end":343.4,"text":"חלפון מחכה כבר איזה ארבע שעות, לא?"},{"start":343.4,"end":344.4,"text":"אולי בכל זאת"},{"start":344.4,"end":345.4,"text":"טוב, יאללה, חלפון"},{"start":345.4,"end":346.4,"text":"חלפון"},{"start":346.4,"end":347.4,"text":"חלפון"},{"start":347.4,"end":349.93,"text":"חלפון"},{"start":349.93,"end":353.17,"text":"שלום"},{"start":353.17,"end":357.25,"text":"רק כפי שנתחיל ברשותכם אני הייתי רוצה לגמות את החימום שלי"},{"start":357.25,"end":358.25,"text":"לא הספקתי פשוט, אוקיי?"},{"start":358.25,"end":368.57,"text":"עצור"},{"start":368.57,"end":370.99,"text":"דה, אני אתרגש קצת"},{"start":370.99,"end":382.26,"text":"מה הכנת לנו?"},{"start":382.26,"end":384.21,"text":"חלפון"},{"start":384.21,"end":386.21,"text":"יש לך אולי משהו קצת יותר ורבלי?"},{"start":386.21,"end":387.5,"text":"כן, שנייה"},{"start":387.5,"end":392.18,"text":"מה, ניצחת?"},{"start":392.18,"end":393.88,"text":"שני מילים"},{"start":393.88,"end":394.81,"text":"מילה ראשונה"},{"start":394.81,"end":399.32,"text":"מילה ראשונה"},{"start":399.32,"end":402.0,"text":"תכנת בשר"},{"start":402.0,"end":403.47,"text":"סרט"},{"start":403.47,"end":404.47,"text":"סרט"},{"start":404.47,"end":405.47,"text":"אבנואלה"},{"start":405.47,"end":406.47,"text":"סרט"},{"start":406.47,"end":407.47,"text":"מה שהוא אומר זה סרט"},{"start":407.47,"end":411.0,"text":"סרט"},{"start":411.0,"end":412.0,"text":"וישר"},{"start":412.0,"end":414.0,"text":"גיבץ'"},{"