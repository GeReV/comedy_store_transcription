[{"start":16.96,"end":22.46,"text":"שלום, אנחנו כולנו פה ברדיו שלי, רדיו לוי"},{"start":22.46,"end":29.22,"text":"הרדיו כאן, אני פה משזר אליכם"},{"start":29.22,"end":32.9,"text":"ואני עושה את הספטח ככה של השידורים של רדיו לוי"},{"start":32.9,"end":34.78,"text":"הרדיו האזורי הזה"},{"start":34.78,"end":38.2,"text":"ומי שרוצה ככה להתחלה"},{"start":38.2,"end":41.38,"text":"שהתקשר אלינו כאן, לאולפן"},{"start":41.38,"end":43.18,"text":"אני מחכה לדבר ככה"},{"start":43.18,"end":45.95,"text":"עם מי שרוצה על הפדי להעביר איתי ככה"},{"start":45.95,"end":47.22,"text":"תיכב סבבה"},{"start":47.22,"end":51.9,"text":"אז הנה אני שומע את המאזין הראשון שבא לו לדבר איתי"},{"start":51.9,"end":55.16,"text":"הוא כבר נלצה פה על הטלפון, הוא צלצל אלינו עכשיו"},{"start":55.16,"end":56.8,"text":"ערב טוב לך ולכל המאזינים"},{"start":56.8,"end":58.8,"text":"מה, מה נשמע, אה?"},{"start":58.8,"end":63.18,"text":"אני יאיר הרנבו מחיפה ואני מאזין קבוע לרדיו לוי"},{"start":63.18,"end":64.86,"text":"הרדיו האזורי שלכם"},{"start":64.86,"end":67.24,"text":"אז מה יאיר, אתה..."},{"start":67.24,"end":71.46,"text":"דבר, כבר מה ראשונה שלך ככה ברדיו, מה, אה?"},{"start":71.46,"end":74.48,"text":"כן, כמובן, לא בכל יום מזדמן לאזרח מן השור הקמות"},{"start":74.48,"end":75.74,"text":"והעתר"},{"start":75.74,"end":78.8,"text":"תגיד ככה בינינו בראש לך למסור"},{"start":78.8,"end":84.24,"text":"פעם דרישה שלום כמה כמה לאמא, לאבא ולכל חבריי לעבודה בשוט לצלאל"},{"start":84.24,"end":87.02,"text":"עם ביוחד לאברהם בן הרוש מבסת הבננות"},{"start":87.02,"end":92.84,"text":"יאללה, אתה מצטרל חפה, אתה יגיש חופשית, תמסור, אפילו"},{"start":92.84,"end":97.44,"text":"אה, שני פעמים דשים אתה רוצה, אפילו יותר"},{"start":97.44,"end":101.14,"text":"אמר לוי, אמר לוי, אקשב, סליחה, אני מתתאר, רק זמנכם קצר"},{"start":101.14,"end":103.3,"text":"ובוודאי ישנם עוד מספים שמרנים לקשה עליכם"},{"start":103.3,"end":104.66,"text":"אני מאלץ לסיים בנקודה זו"},{"start":104.66,"end":108.95,"text":"אתה יודע מה יאיר ככה בעוסול, תגיד"},{"start":108.95,"end":113.97,"text":"לא מלך לשמוע איזה שיר ספציפי אחד ככה בפנן שלך"},{"start":113.97,"end":116.71,"text":"אכן, הגיע הזמן למעט צלילים"},{"start":116.71,"end":120.11,"text":"חווה ונשמע את שירה מחדש של צמד הבנות רכפת וחלנית"},{"start":120.11,"end":122.93,"text":"שהתאחדו להרכב מוסיקלי מעניין ומבטיח"},{"start":122.93,"end":126.26,"text":"אז קבלו אותן לשיפותכם רכפת וחלנית"},{"start":126.26,"end":129.82,"text":"יאללה, מה שתרצה, תקבל"},{"start":129.82,"end":133.36,"text":"בואו נשמע באמת השיר של הקלנית ורכפת האלה"},{"start":133.36,"end":138.42,"text":"רק תשכחו לחזור לרדיו שלכם, הרדיו של לוי, לוי"},{"start":138.42,"end":143.57,"text":"תבובות לי בובותיים, רכפת, קלנית, הזמן, הזמן"},{"start":143.57,"end":148.03,"text":"היינו תדעו להבדיל בן השתיים, מי פגר את ומי חכמה"},{"start":148.03,"end":152.81,"text":"קלנית מפגרת, תגידו מה קורא לה ורכפת וחונדת, תראו מה זה עוזלה"},{"start":152.81,"end":156.61,"text":"איזה תנדפת, כגידי כמה זה על הנוח, איי, זה פגר"},{"start":156.61,"end":163.65,"text":"בלסודמל, שאני יפה כזאת"},{"start":163.65,"end":172.94,"text":"שכל הזמן רק מחמצנו צפה"},{"start":172.94,"end":176.6,"text":"מה שקוראים לרקפת?"},{"start":176.6,"end":179.64,"text":"אה, אפי מלחרו, זה אדיש תעשי מסייג למושג"},{"start":179.64,"end":182.32,"text":"קללית מרקפת מוחמה עוד מרגזינה"},{"start":182.32,"end":184.62,"text":"רקבת וקללית מושל שפת ועדינה"},{"start":184.62,"end":186.96,"text":"שמלות כסף את שוקולד בנירותינה"},{"start":186.96,"end":188.58,"text":"איזה פגר"},{"start":188.58,"end":189.22,"text":"אז מה?"},{"start":189.22,"end":196.01,"text":"עוד לא"},{"start":196.01,"end":197.69,"text":"סלה"},{"start":197.69,"end":201.56,"text":"ובולבות"},{"start":201.56,"end":202.16,"text":"אז מה?"},{"start":202.16,"end":205.35,"text":"צ'מיק, עשו טובה ורש"},{"start":205.35,"end":207.35,"text":"איזה פגר, איזה מה זה פגר?"},{"start":207.35,"end":208.59,"text":"אלק, אלק לא"},{"start":208.59,"end":210.79,"text":"אלק לא, אלק לא, אלק לא"},{"start":210.79,"end":211.74,"text":"אלק לא"},{"start":211.74,"end":214.25,"text":"סלה לי זה פגר, תגידו מה קורה לה"},{"start":214.25,"end":216.63,"text":"ורגב את זה פוגרת, תראו מה זה עושה לה"},{"start":216.63,"end":218.95,"text":"השיר הזה נסה להיות, אלק מה קרנה?"},{"start":218.95,"end":225.75,"text":"איזה פגר, זה פגר וצלטים כמו שם שחל והגילה"},{"start":225.75,"end":227.97,"text":"שמה לא כסף את שוקולד בנירותינה?"},{"start":227.97,"end":229.7,"text":"איזה פגר"},{"start":229.7,"end":266.43,"text":"ערב טוב, אני הוא הפרופסור יוקמת בן סיק"},{"start":266.43,"end":268.61,"text":"ואתם נמצאים בפינת הלשון שלנו"},{"start":268.61,"end":273.17,"text":"השפה העברית נחלקת כידוע למספר תקי שפות"},{"start":273.17,"end":275.69,"text":"והפעם נעסוק בערסית מדוברת"},{"start":275.69,"end":278.37,"text":"עימנו באולפן מר ג'קי"},{"start":278.37,"end":279.77,"text":"ערב טוב לך ג'קי?"},{"start":279.77,"end":286.08,"text":"ג'קי ידגים באוזננו מעט ממכווני הלשון של שפה קולחת בעשירה זו"},{"start":286.08,"end":290.44,"text":"ובכן ג'קי, איך נאמר בערסית מדוברת את המשפט הבא?"},{"start":290.44,"end":296.33,"text":"ידידי המלומד, אני חולק על דעותיך המפולפלות"},{"start":296.33,"end":305.96,"text":"לא ירדתי לסוף דעתך האם תועיל לחזור על דבריך המאלפים"},{"start":305.96,"end":312.92,"text":"יזהר והישמר פנייבולע לך"},{"start":312.92,"end":322.59,"text":"את יפה וחטובת גב, ברצוני להחמילך על הופעתך המסודדת"},{"start":322.59,"end":330.65,"text":"הבעיה אינה נמצאת כרגע בראש מעייניי ולכן אתעלם ממנה"},{"start":330.65,"end":339.37,"text":"אכן פנינים ומרגליות תודה רבה לך מר ג'קי אנו נאלתים לסיים את התוכנית"},{"start":339.37,"end":344.13,"text":"ולטול מכם ברכת פרדה או כפי שעושים זאת בערצית המדוברת"},{"start":344.13,"end":349.27,"text":"לךו לךו יאללה נגמר יאללה תחפפו תחפפו יאללה"},{"start":349.27,"end":372.65,"text":"אחי הצעיר אני בתשע וחצי ואוזיאל בן רב אלה ארבע"},{"start":372.65,"end":379.5,"text":"טוב והיום אני ללמד אתכם כאן בפינת ללכת היעץ שלנו איך להכין חייפציות"},{"start":379.5,"end":380.92,"text":"חרסים טוב"},{"start":380.92,"end":391.31,"text":"ואנחנו נתגיד קודם כל מה שצריך זה תרוכי רעפיה שאנחנו לקחנו במקרה הזה מהחצאית העיקרה של אמא"},{"start":391.31,"end":400.03,"text":"ונקשור לאח הקטן במקרה הזה לאוזיאל את האוזן ונעשה אותה כבשות כבשות כבשות"},{"start":400.03,"end":410.49,"text":"ככה ואחרי שעשינו לו את זה וניצול גם את המקלונים האלה שהם מקלוני ארציק שאותם צבנו במאוד מועד"},{"start":410.49,"end":413.92,"text":"ונשים לו על הראש ככה הנה כך"},{"start":413.92,"end":419.27,"text":"אחרי שקיימנו ניצול דלת פלסיק שיש לכל אחד בבית"},{"start":419.27,"end":423.57,"text":"ונדפיק את עוזיאר"},{"start":423.57,"end":425.85,"text":"נדפיק את עוזיאר"},{"start":425.85,"end":426.94,"text":"ונדפיק את עוזיאר"},{"start":426.94,"end":429.12,"text":"ונדפיק את עוזיאר"},{"start":429.12,"end":430.1,"text":"ונדפיק את עוזיאר"},{"start":430.1,"end":434.02,"text":"ועד הוא יהיה לגמרי מדוע"},{"start":434.02,"end":435.49,"text":"עוזיאר"},{"start":435.49,"end":438.69,"text":"אחרי שקיימנו ניטול נוטו"},{"start":438.69,"end":441.28,"text":"שנקחנו מהקרית של האבר"},{"start":441.28,"end":445.77,"text":"ונתבזר אותם עוזיאר"},{"start":445.77,"end":451.23,"text":"אם נדבק ליד נתבקש ונדפיק עוזיאר"},{"start":451.23,"end":455.1,"text":"אחרי הקטפקנו אשר לפיל עוד ונדבק"},{"start":455.1,"end":458.48,"text":"וגם סים פמפמי"},{"start":458.48,"end":461.57,"text":"לסת פונפונים אלו דיאר"},{"start":461.57,"end":464.85,"text":"וגם את הרפיה אשר לסים אלו דיאר"},{"start":464.85,"end":466.53,"text":"ואחרי קטעים אלו דיאר"},{"start":466.53,"end":469.73,"text":"עדול את הגרם ניילון שכנם נעימה"},{"start":469.73,"end":473.02,"text":"מנחשת ודיאר לגמרי"},{"start":473.02,"end":476.66,"text":"איזה קוין?"},{"start":476.66,"end":480.56,"text":"והנה יש לנו חייצוף"},{"start":480.56,"end":483.23,"text":"ודיאר תעשי חייצוף"},{"start":483.23,"end":485.79,"text":"אני לא יכולים לשם"},{"start":485.79,"end":488.72,"text":"טוב וכמובן המהדרים"},{"start":488.72,"end":493.6,"text":"יכולים לצקת את הדבק שנשאר"},{"start":493.6,"end":497.42,"text":"הנה כך על ראשו של האח הקטן"},{"start":497.42,"end":499.82,"text":"במקרה הזה הוא תהיה לדביר"},{"start":499.82,"end":502.43,"text":"ולשים את הרפיה"},{"start":502.43,"end":507.12,"text":"ככה שיהיה לך לצוף פרוע"},{"start":507.12,"end":510.43,"text":"אבל אפשר גם להוציא כלום עיניים"},{"start":510.43,"end":512.76,"text":"לדביק את העיניים עם הדבק"},{"start":512.76,"end":515.84,"text":"ונשים אותם ככה"},{"start":515.84,"end":516.96,"text":"ונצוף פרוע"},{"start":516.96,"end":520.35,"text":"הנה ככה יש לנו חרציף לחליטין"},{"start":520.35,"end":522.61,"text":"שדא לכם שהייתם איתנו עד שם"},{"start":522.61,"end":523.61,"text":"בפינה שלנו"},{"start":523.61,"end":524.69,"text":"מה זה צריך להיות נבלות"},{"start":524.69,"end":527.29,"text":"טיפות אזרוע אין לי מכן נבלות"},{"start":527.29,"end":528.79,"text":"אימא"},{"start":528.79,"end":531.21,"text":"זה אוזיאל הסקן בלרן"},{"start":531.21,"end":533.25,"text":"שפח את הדבק לקח לך את הגרב ניילון"},{"start":533.25,"end":535.37,"text":"הוא יצרפש לחרציף"},{"start":535.37,"end":537.33,"text":"אוזיאל אני ארא לך"},{"start":537.33,"end":538.51,"text":"חכה שעבבו"},{"start":538.51,"end":540.55,"text":"העיקר להתייחס אל לך כמו על גדול"},{"start":540.55,"end":541.89,"text":"אין חוק חליליני"},{"start":541.89,"end":545.49,"text":"אמרתי לך"},{"start":545.49,"end":548.75,"text":"עד כאן הפילה שלנו"},{"start":548.75,"end":550.43,"text":"ציורית על אוגן בשבועה"},{"start":550.43,"end":552.92,"text":"יש לי אוף קסן"},{"start":552.92,"end":555.06,"text":"שלא נזמן ברע עולם"},{"start":555.06,"end":560.72,"text":"נד, תחמוד שאתה תחמיד"},{"start":560.72,"end":562.45,"text":"נפוך את כל זה"},{"start":562.45,"end":563.87,"text":"לך נפנת אשלה"},{"start":563.87,"end":565.03,"text":"אני לא יום לך"},{"start":565.03,"end":568.16,"text":"לום גם לך, מי אתה?"},{"start":568.16,"end":569.52,"text":"מי אתה, חייסי משקילה"},{"start":569.52,"end":572.02,"text":"פה זה הדרושים נדבים לריסוק המדעי"},{"start":572.02,"end":574.74,"text":"ניסוי מדעי, אתה מתנדר"},{"start":574.74,"end":576.32,"text":"ברוך הבעלי"},{"start":576.32,"end":578.78,"text":"פרנק, דורי מפסולה"},{"start":578.78,"end":580.43,"text":"נצרה, זה אני"},{"start":580.43,"end":581.47,"text":"אתה יודע שאתה עומד"},{"start":581.47,"end":584.54,"text":"לעוף בתוך מכונת הז"},{"start":584.54,"end":585.21,"text":"מה?"},{"start":585.21,"end":588.68,"text":"על מנת לענות על כל מיני שאהה"},{"start":588.68,"end":590.91,"text":"שיתעוררו כאן"},{"start":590.91,"end":594.09,"text":"אתה תשוגר ותעוף על פני ההיסטוריה כולה"},{"start":594.09,"end":596.99,"text":"ותוכל לרחב לך בזמן ועוד"},{"start":596.99,"end":597.82,"text":"מה?"},{"start":597.82,"end":600.83,"text":"רבה, זהו, אתה פשוט עכשיו"},{"start":600.83,"end":602.93,"text":"תשתגר ותעוף כי"},{"start":602.93,"end":604.09,"text":"בנימד"},{"start":604.09,"end":607.29,"text":"לא, כי צריך מישהו שיעשה את העבודה השחורה"},{"start":607.29,"end":624.84,"text":"לא נודע? כן, עבודה, עבודה. לא נודע. אלא לא נודע. מה שעה? בזמן. מנהרת הזמן."},{"start":644.73,"end":646.73,"text":"מטיפות?"},{"start":646.73,"end":648.69,"text":"מטפילה?"},{"start":648.69,"end":650.71,"text":"אה?"},{"start":650.71,"end":652.9,"text":"מטפילה עסיפונו לי, אה?"},{"start":652.9,"end":655.37,"text":"שוטי שוטי, ספינתי!"},{"start":655.37,"end":658.37,"text":"אני יהיה עוד רבי חובל!"},{"start":658.37,"end":659.33,"text":"אישי..."},{"start":659.33,"end":660.3,"text":"אוק!"},{"start":660.3,"end":661.5,"text":"לא יום חבודה!"},{"start":661.5,"end":663.8,"text":"מה זה?"},{"start":663.8,"end":683.16,"text":"אה?"},{"start":683.16,"end":685.26,"text":"בני, אה?"},{"start":685.26,"end":738.66,"text":"אוווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":738.66,"end":739.66,"text":"איזה בונבון?"},{"start":739.66,"end":740.66,"text":"אימא שלך בונבוא"},{"start":740.66,"end":741.66,"text":"מה זה מצבשים ככה?"},{"start":741.66,"end":742.66,"text":"הלאה כולם פה מתחנגלים"},{"start":742.66,"end":743.66,"text":"הלאה הלאה"},{"start":743.66,"end":745.62,"text":"יואו נתן אני באה"},{"start":745.62,"end":755.92,"text":"מה זה פה?"},{"start":755.92,"end":758.05,"text":"הבותקילה הלאה תפוחים הלאה"},{"start":758.05,"end":759.05,"text":"איזה אופי"},{"start":759.05,"end":761.05,"text":"בותקילה, תפוחים וברים"},{"start":761.05,"end":763.05,"text":"אני כדאום איך הוא לא אומר"},{"start":763.05,"end":764.05,"text":"עד האמת"},{"start":764.05,"end":765.02,"text":"תפוח"},{"start":765.02,"end":771.49,"text":"הלאה זה בותקילה אוכל"},{"start":771.49,"end":772.46,"text":"איך תולעת?"},{"start":772.46,"end":773.46,"text":"הלאה זרע עוד"},{"start":773.46,"end":795.2,"text":"איפה הבותקילה?"},{"start":795.2,"end":796.2,"text":"מה זה פה?"},{"start":796.2,"end":798.0,"text":"תלם לך"},{"start":798.0,"end":799.7,"text":"תלם לך"},{"start":799.7,"end":800.7,"text":"תלם לך"},{"start":800.7,"end":801.7,"text":"תלם לך"},{"start":801.7,"end":802.7,"text":"מה זה מצייר פה?"},{"start":802.7,"end":804.17,"text":"מה?"},{"start":804.17,"end":808.29,"text":"אני מצייר את עכבר בשביל קרסון"},{"start":808.29,"end":809.29,"text":"זה עבודה שאני ארסי"},{"start":809.29,"end":811.48,"text":"לא קרקם תלם עכבר"},{"start":811.48,"end":812.48,"text":"תביא עבודקילה עליך"},{"start":812.48,"end":813.48,"text":"תביא עביר פה"},{"start":813.48,"end":815.48,"text":"תכי... תכי... תכי... תכי... תכי..."},{"start":815.48,"end":815.58,"text":"ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו... ו"},{"start":815.58,"end":817.58,"text":"מה... מה..."},{"start":817.58,"end":822.0,"text":"יחייה!"},{"start":822.0,"end":823.74,"text":"וואו!"},{"start":823.74,"end":825.11,"text":"וואו!"},{"start":825.11,"end":826.11,"text":"וואו!"},{"start":826.11,"end":827.55,"text":"וואו!"},{"start":827.55,"end":827.65,"text":"וואו!"},{"start":827.55,"end":828.55,"text":"וואו!"},{"start":828.55,"end":829.55,"text":"וואו!"},{"start":829.55,"end":830.55,"text":"וואו!"},{"start":830.55,"end":831.55,"text":"וואו!"},{"start":831.55,"end":832.77,"text":"וואו!"},{"start":832.77,"end":833.73,"text":"וואו!"},{"start":833.73,"end":834.87,"text":"וואו!"},{"start":834.87,"end":835.98,"text":"וואו!"},{"start":835.98,"end":837.93,"text":"וואו!"},{"start":837.93,"end":838.93,"text":"וואו!"},{"start":838.93,"end":841.24,"text":"וואו!"},{"start":841.24,"end":843.59,"text":"וואו!"},{"start":843.59,"end":844.57,"text":"וואו!"},{"start":844.57,"end":845.99,"text":"וואו!"},{"start":845.99,"end":851.85,"text":"וואו!"},{"start":851.85,"end":855.72,"text":"וואו!"},{"start":855.72,"end":856.72,"text":"וואו!"},{"start":856.72,"end":857.97,"text":"וואו!"},{"start":857.97,"end":860.41,"text":"וואו!"},{"start":860.41,"end":861.41,"text":"וואו!"},{"start":861.41,"end":862.41,"text":"וואו!"},{"start":862.41,"end":863.41,"text":"וואו!"},{"start":863.41,"end":865.43,"text":"וואו!"},{"start":865.43,"end":866.43,"text":"וואו!"},{"start":866.43,"end":869.1,"text":"וואו!"},{"start":869.1,"end":870.1,"text":"הלם לך!"},{"start":870.1,"end":871.04,"text":"אה!"},{"start":871.04,"end":873.73,"text":"מה זה זה?"},{"start":873.73,"end":874.73,"text":"אה!"},{"start":874.73,"end":875.73,"text":"מי אתה?"},{"start":875.73,"end":876.73,"text":"אני מעבודה!"},{"start":876.73,"end":877.73,"text":"אני מעבודה!"},{"start":877.73,"end":878.73,"text":"אני מעבודה!"},{"start":878.73,"end":879.73,"text":"אני מעבודה!"},{"start":879.73,"end":880.73,"text":"מה אתה עני?"},{"start":880.73,"end":881.73,"text":"אה!"},{"start":881.73,"end":882.65,"text":"אה!"},{"start":882.65,"end":883.95,"text":"הבריאות!"},{"start":883.95,"end":884.95,"text":"הבריאות!"},{"start":884.95,"end":885.95,"text":"מי אני אתה?"},{"start":885.95,"end":886.95,"text":"מי אני אתה?"},{"start":886.95,"end":887.95,"text":"אתה אני אמר?"},{"start":887.95,"end":889.65,"text":"מה אמרנו?"},{"start":889.65,"end":890.65,"text":"הבריאות!"},{"start":890.65,"end":891.65,"text":"הבריאות!"},{"start":891.65,"end":892.65,"text":"אתה הייתם בנזה?"},{"start":892.65,"end":893.65,"text":"אתה הייתם בנזה?"},{"start":893.65,"end":894.65,"text":"אה!"},{"start":894.65,"end":895.65,"text":"אה!"},{"start":895.65,"end":896.65,"text":"הניסו יצליח!"},{"start":896.65,"end":897.65,"text":"תחזור אלינו!"},{"start":897.65,"end":899.65,"text":"כמה רוצים הסיבה ציום?"},{"start":899.65,"end":901.65,"text":"לא, לא, אני בשקילה סבא פה!"},{"start":901.65,"end":903.65,"text":"כיף, כיף, כיף, עבדו נפרק!"},{"start":903.65,"end":905.65,"text":"על הכיפה, יש הרבה דברים..."},{"start":905.65,"end":907.65,"text":"בשקילה, הוטל סדר!"},{"start":907.65,"end":909.65,"text":"עושה איך הרבה הרבה עבודה עליהם עבודה!"},{"start":909.65,"end":909.75,"text":"וואווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":909.65,"end":912.67,"text":"חייסתה ברה, ברה, בוא מי בולים!"},{"start":912.67,"end":914.67,"text":"ועודים!"},{"start":914.67,"end":915.7,"text":"עודים!"},{"start":915.7,"end":921.44,"text":"שלום לך, פיליפו זוסף!"},{"start":921.44,"end":923.43,"text":"את השם רלגרמה שם לא עושה טאפתמה!"},{"start":923.43,"end":924.43,"text":"עזוסף! עזוסף!"},{"start":924.43,"end":925.43,"text":"קוקיסי קיסי מקק!"},{"start":925.43,"end":927.43,"text":"ברי, ברה, פוטה ברה, פוטה ברינה!"},{"start":927.43,"end":929.43,"text":"דנבולי, פודל מנגו!"},{"start":929.43,"end":930.43,"text":"הו! הו!"},{"start":930.43,"end":932.43,"text":"למה אתה רוצה לאכול פה מקרלים?"},{"start":932.43,"end":933.43,"text":"או, מקרלים!"},{"start":933.43,"end":935.46,"text":"זיהדת עורדה!"},{"start":935.46,"end":936.46,"text":"ובכן, ערב טוב לך!"},{"start":936.46,"end":937.46,"text":"סבורסווה!"},{"start":937.46,"end":938.46,"text":"מה הבאת לנו הפעם?"},{"start":938.46,"end":939.46,"text":"ובכן, אה!"},{"start":939.46,"end":944.45,"text":"את המכונה הזאתי, שהיא מכונה אקטרה אורדינר במבסקית, תרם רעתה אין אדם!"},{"start":944.45,"end":946.45,"text":"זו מכונה גדולה, גרנדיוזית!"},{"start":946.45,"end":947.45,"text":"או, מה יעשויה?"},{"start":947.45,"end":948.35,"text":"אה!"},{"start":948.35,"end":957.83,"text":"זה כל מיני שבבים, כל מיני מנורות ישנות, אפשר לראות לטלטיש, גרבזור, טילפון, טחתולזור, וגם את הגרבודלור!"},{"start":957.83,"end":958.89,"text":"אה!"},{"start":958.89,"end":960.89,"text":"זה תעמוקה, משהו גרנדיוזי!"},{"start":960.89,"end":961.89,"text":"מה יעושה?"},{"start":961.89,"end":963.17,"text":"אה!"},{"start":963.17,"end":967.51,"text":"זוהי מכונה שגורמת למנחה, להיעלם!"},{"start":967.51,"end":969.51,"text":"או, יש לה פונקציות נוספות?"},{"start":969.51,"end":972.51,"text":"כמובן, יש פה עוד אלפי פונקציות ביניהם."},{"start":972.51,"end":975.51,"text":"כמו שאמרתי, הפונקציה שגורמת למראיין להיעלם,"},{"start":975.51,"end":978.45,"text":"היא יכולה גם לגרום למראיין להיעלם!"},{"start":978.45,"end":980.45,"text":"אם כן, זה הכל להפעם."},{"start":980.45,"end":981.45,"text":"קלמה מבזק של ז'ק..."},{"start":981.45,"end":983.45,"text":"אם אני יכול, אם יותר לי למסור דאצ'ל..."},{"start":983.45,"end":985.45,"text":"לא, בשום פנים ואופן לא."},{"start":985.45,"end":986.45,"text":"אז תשכחי לי זך, ננה!"},{"start":986.45,"end":988.82,"text":"שראוי!"},{"start":988.82,"end":990.98,"text":"תגיד לי, זה הראש שלך או שזה צלחת פול?"},{"start":990.98,"end":994.93,"text":"די, די!"},{"start":994.93,"end":997.3,"text":"מישהו רוצה פה סנגה?"},{"start":997.3,"end":999.29,"text":"אם נוכל להפסיק אם זה, זה הראש שלי!"},{"start":999.29,"end":1001.33,"text":"שבתי זה במבי צעיר!"},{"start":1001.33,"end":1002.33,"text":"די, אתה כל הזמן מתעלם!"},{"start":1002.33,"end":1003.33,"text":"די עם זה!"},{"start":1003.33,"end":1004.33,"text":"למה אני מביא אותך לאולפן?"},{"start":1004.33,"end":1006.33,"text":"אני לא יכול להביא את זה מראיין אחר פעם אחת!"},{"start":1006.33,"end":1007.33,"text":"שאלתי תצבית את השאלה!"},{"start":1007.33,"end":1008.33,"text":"די עם זה!"},{"start":1008.33,"end":1009.33,"text":"לא רוצה!"},{"start":1009.33,"end":1010.33,"text":"די!"},{"start":1010.33,"end":1012.8,"text":"ים!"},{"start":1012.8,"end":1013.8,"text":"ים השיער!"},{"start":1013.8,"end":1014.8,"text":"אמן אמן!"},{"start":1014.8,"end":1017.18,"text":"שאול תראה מה הכבוד הבא הביא לי!"},{"start":1017.18,"end":1019.79,"text":"הוא הביא לי שיקוי!"},{"start":1019.79,"end":1021.79,"text":"שיקוי תעזוב אותה בעיה!"},{"start":1021.79,"end":1023.81,"text":"שיקוי שאול מי שתשתה מזה, היא תתאהב בי!"},{"start":1023.81,"end":1026.29,"text":"היא תתאהב בכלל אתה תעזוב אותה!"},{"start":1026.29,"end":1029.83,"text":"נחת כולה, הנה אפילו זאתי! היא יפה!"},{"start":1029.83,"end":1033.09,"text":"בוא תעזור לי להתחיל איתנו, בוא נראה אותה!"},{"start":1033.09,"end":1037.45,"text":"שלום!"},{"start":1037.45,"end":1040.74,"text":"אהלי, זה החבר שלי הוא שאול המשורר."},{"start":1040.74,"end":1043.35,"text":"שאול תשאיר לשיר."},{"start":1043.35,"end":1046.35,"text":"רחמים שלנו בחור יפה, מתוק חזק, ממש מוקפה,"},{"start":1046.35,"end":1049.35,"text":"ייתן לך הרבה נחת וגם צוויתה בתח."},{"start":1049.35,"end":1053.35,"text":"אהלי, הוא פושע, כמו ששמת לב ביתך."},{"start":1053.35,"end":1058.35,"text":"עכשיו תשתהי למה חם ואת מתקררת וזה תכף מתפוגג."},{"start":1058.35,"end":1061.15,"text":"פוגג, אלה."},{"start":1061.15,"end":1062.15,"text":"שני סוטים, זה מה שאתם."},{"start":1062.15,"end":1064.15,"text":"הראתם לי את כל הצימאון."},{"start":1064.15,"end":1067.08,"text":"לא, אה, לא!"},{"start":1067.08,"end":1070.07,"text":"נשאר, נשאר לי עוד קצת, בוא בוא ננסע."},{"start":1070.07,"end":1073.07,"text":"הנה על הבחורה הזאת, יפה, בוא, בוא."},{"start":1073.07,"end":1079.37,"text":"אלה, אלה, שלום, אלה."},{"start":1079.37,"end":1082.59,"text":"זה החבר שלי הוא שאול המשורר,"},{"start":1082.59,"end":1084.59,"text":"והוא ישיר לך שיר."},{"start":1084.59,"end":1087.0,"text":"שאול תעשה לשיר."},{"start":1087.0,"end":1090.0,"text":"רחמים שלנו הוא בחור חזק עם שרירים."},{"start":1090.0,"end":1092.0,"text":"הוא לא קטן וסתם צוציק,"},{"start":1092.0,"end":1094.0,"text":"הוא ייתן לך צביתה בטוסי."},{"start":1094.0,"end":1097.0,"text":"אילי, כמו שאת רואה, הוא פושע."},{"start":1097.0,"end":1099.97,"text":"עכשיו שהיא לא התעקה לך הביץ בגרון,"},{"start":1099.97,"end":1101.96,"text":"זה למה שלא תשתים משהו."},{"start":1101.96,"end":1103.95,"text":"אני מצטערת, זה לא שלי."},{"start":1103.95,"end":1104.95,"text":"אז של מי זה?"},{"start":1104.95,"end":1106.88,"text":"אז לא."},{"start":1106.88,"end":1117.91,"text":"לא, לא, לא, לא."},{"start":1117.91,"end":1119.91,"text":"זה מה טוב, בוא אליי."},{"start":1119.91,"end":1121.91,"text":"סבבה, בסבבה."},{"start":1121.91,"end":1123.91,"text":"בוא אליי חמוד, בוא אליי בבית."},{"start":1123.91,"end":1125.91,"text":"אתם לא משאול, שאול הוא יסביר לך."},{"start":1125.91,"end":1127.91,"text":"בוא בוא גם אתה שאול, נעשה וחת תעלול."},{"start":1127.91,"end":1129.91,"text":"בוא בוא בוא."},{"start":1129.91,"end":1131.91,"text":"בוא בוא בוא בוא בוא בוא סבבה."},{"start":1131.91,"end":1133.91,"text":"שאול, בוא בוא."},{"start":1133.91,"end":1135.91,"text":"שתי בובות לי בובותיים"},{"start":1135.91,"end":1137.91,"text":"קלה לי את מה הזמן"},{"start":1137.91,"end":1139.91,"text":"האם תדעו להובדיל בן השתיים?"},{"start":1139.91,"end":1141.91,"text":"מי פגרת ומי חכמה?"},{"start":1141.91,"end":1143.91,"text":"קלה לי בפגרת, תקידו מה קורה לה"},{"start":1143.91,"end":1145.91,"text":"ורקפת וחותרת, תראו מה זה עוצה לה."},{"start":1145.91,"end":1147.91,"text":"איזה פן דפק, אגידי כמה זה על המח?"},{"start":1147.91,"end":1149.91,"text":"איזה פגרת עצמו."},{"start":1149.91,"end":1156.83,"text":"שאני יופה כזאת."},{"start":1156.83,"end":1164.88,"text":"כל הזמן רק מחבצלו צבא."},{"start":1164.88,"end":1170.17,"text":"שקוראים לה רכפת."},{"start":1170.17,"end":1173.42,"text":"אה, איתי מלך הרוז, עדי שתעשים יצייג למושג."},{"start":1173.42,"end":1176.39,"text":"חללית מרכפת מוחמה או מרגרינה,"},{"start":1176.39,"end":1178.39,"text":"רכבת וחללית כמו של שפת גאה."},{"start":1178.39,"end":1180.39,"text":"שפת שוקולד בנירותינה."},{"start":1180.39,"end":1182.39,"text":"אה, זה פגרת."},{"start":1182.39,"end":1183.39,"text":"עד מה?"},{"start":1183.39,"end":1189.67,"text":"שיר."},{"start":1189.67,"end":1193.84,"text":"עוד לא."},{"start":1193.84,"end":1198.42,"text":"ובולבו."},{"start":1198.42,"end":1199.42,"text":"שמיק, עשו טובה, זה רשת."},{"start":1199.42,"end":1201.45,"text":"זה פגרת, ומה זה בסיסי?"},{"start":1201.45,"end":1202.45,"text":"אלה קט?"},{"start":1202.45,"end":1203.45,"text":"אלה קט."},{"start":1203.45,"end":1204.45,"text":"לא, אלה קט."},{"start":1204.45,"end":1205.74,"text":"אלה קט."},{"start":1205.74,"end":1207.74,"text":"חללית מפגרת, תגידו מה קורה לה,"},{"start":1207.74,"end":1209.74,"text":"תגידו מה זה עוצה לה."},{"start":1209.74,"end":1214.25,"text":"אלה קט."},{"start":1214.25,"end":1219.87,"text":"אלה קט."}]