[{"start":56.83,"end":83.88,"text":"תחבית? איזה בידוד?"},{"start":83.88,"end":94.78,"text":"קינמון? לא עזור לך להיטקה?"},{"start":94.78,"end":98.08,"text":"אורח מהבידוד, אני צריך להיטחה!"},{"start":98.08,"end":100.48,"text":"לא! זה לא יעזור לי!"},{"start":100.48,"end":102.48,"text":"השפק ידפוס אותי!"},{"start":102.48,"end":104.48,"text":"יאו! יעקן לי את הטלפון!"},{"start":104.48,"end":106.48,"text":"ידע איפה אני..."},{"start":106.48,"end":113.56,"text":"איזה מטף, כאילו..."},{"start":113.56,"end":115.56,"text":"ערב טוב, ערב טוב,"},{"start":115.56,"end":117.56,"text":"מקר חדשה נוחתת על המדינה,"},{"start":117.56,"end":119.56,"text":"המסלמה המסוטטת של ז'ודי."},{"start":119.56,"end":121.5,"text":"ערב טוב!"},{"start":153.93,"end":156.93,"text":"עידוד המשחקים נגזלה מהם באכזריות,"},{"start":156.93,"end":160.93,"text":"ובאין החסניה עולמת לפרוק את יצריהם הנלהמים,"},{"start":160.93,"end":163.93,"text":"פשטה בהם קרקה החדשה,"},{"start":163.93,"end":165.84,"text":"העידודומניה."},{"start":165.84,"end":168.96,"text":"עידודומניה, דחף בלתי נשלט"},{"start":168.96,"end":170.96,"text":"לעודד בכל חלקה טובה,"},{"start":170.96,"end":173.96,"text":"ומתחת קולץ רענן."},{"start":173.96,"end":177.69,"text":"אין מה לעודד, אין אחי, אין כלום."},{"start":177.69,"end":179.69,"text":"אפילו סנוקר לא משדרים כבר."},{"start":179.69,"end":181.69,"text":"אפילו דפנה בידוד עידוד."},{"start":181.69,"end":183.69,"text":"הנה, הנה, הנה, הנה מישהו הולך."},{"start":183.69,"end":185.69,"text":"לך אח שלי, לך!"},{"start":185.69,"end":205.0,"text":"הוא הולך, הוא הולך!"},{"start":205.0,"end":207.97,"text":"אך מה שהחל כפרפרה המשעשת"},{"start":207.97,"end":210.97,"text":"סתה במהרה לכיוונים מדהיגים."},{"start":210.97,"end":228.88,"text":"זו היית אשתי."},{"start":228.88,"end":252.23,"text":"אך אין תמונות קשות."},{"start":252.23,"end":256.41,"text":"אך ברם עולם היא דח כיסת ארתי משמע."},{"start":256.41,"end":259.41,"text":"בעוד העולם כולו מרכזת מה המצב"},{"start":259.41,"end":261.34,"text":"לחסל את הנגיף המשתולל."},{"start":261.34,"end":264.37,"text":"גילת צוות התחקירנים שלנו שלו."},{"start":264.37,"end":266.37,"text":"לא הקורונה שרפה את הדשע"},{"start":266.37,"end":268.37,"text":"על מגרשי הכדורגל ובמשבי היציאים,"},{"start":268.37,"end":270.37,"text":"אלא דמות מסתורית."},{"start":270.37,"end":273.37,"text":"דמות מסתורית שנגלתה על הראשונה"},{"start":273.37,"end":275.37,"text":"לפני 26 שנים."},{"start":275.37,"end":289.55,"text":"כן, כן."},{"start":289.55,"end":291.77,"text":"זהו הבועט מבוסטון"},{"start":291.77,"end":293.77,"text":"שבימים אין לידוע כבועט"},{"start":293.77,"end":295.68,"text":"מדפורטיבולה מקורונה."},{"start":295.68,"end":298.02,"text":"הוא שוב מסתובב בינינו."},{"start":298.02,"end":300.02,"text":"הוא שוב מתי לימה לוהדי הכדורגל"},{"start":300.02,"end":302.02,"text":"באשר הם שב."},{"start":302.02,"end":303.98,"text":"וואו, אין משחק."},{"start":303.98,"end":306.18,"text":"פסור את הכדור."},{"start":306.18,"end":308.18,"text":"פסור את הכדור."},{"start":308.18,"end":310.18,"text":"אין משחק, אין כדורגל, אין צ'פיון, אין אוליפיון."},{"start":310.18,"end":312.18,"text":"איי, אני ג'ודי, איי."},{"start":312.18,"end":314.18,"text":"איי, אין משחק."},{"start":314.18,"end":316.52,"text":"גם ג'ודי קוף שחץ קיצן"},{"start":316.52,"end":318.52,"text":"צעיל דיסנבו שירי על הג'ן."},{"start":318.52,"end":320.52,"text":"על ג'מי."},{"start":331.11,"end":333.11,"text":"נחשוב אנחנו בחלסטרה של זוזו"},{"start":333.11,"end":335.11,"text":"ובאמת כל הזמן עוצרים אותי"},{"start":335.11,"end":337.11,"text":"ואומרים לי, זוזו, לאן נעלמת?"},{"start":337.11,"end":339.11,"text":"יש התדרדרות קשה של המצב,"},{"start":339.11,"end":341.11,"text":"לכן אני נעלמתי,"},{"start":341.11,"end":343.11,"text":"אבל הפעם אני חייב לחזור"},{"start":343.11,"end":345.11,"text":"והנושא שאני רוצה לדבר איתכם"},{"start":345.11,"end":347.46,"text":"זה על כוחות הביטחון."},{"start":347.46,"end":349.46,"text":"באמא שלי, אנשי הצפרדע,"},{"start":349.46,"end":351.46,"text":"אנשי החיידק."},{"start":351.46,"end":353.46,"text":"מה זה אחרת הזה? לאן נדרדרנו?"},{"start":353.46,"end":355.46,"text":"פעם היו מבצעים באמא שלי,"},{"start":355.46,"end":357.46,"text":"בחורות היו חזרות הבית הגאות,"},{"start":357.46,"end":359.46,"text":"הרוס שלי סוסויסט."},{"start":359.46,"end":363.46,"text":"ובאמא שלי הוא חיישל במועצמו את מפחוק מפחוק."},{"start":363.46,"end":366.46,"text":"הם דרכונים מזויפים, הם מבצעים,"},{"start":366.46,"end":369.46,"text":"הם מפוצץ מטושים, הוא חוטף חטופים,"},{"start":369.46,"end":371.46,"text":"עם ג'מס בועדנה שזה ג'מס בון שלנו,"},{"start":371.46,"end":373.46,"text":"ואמא שלי באורף האויב,"},{"start":373.46,"end":376.46,"text":"והם סוחים בקישון בלילה ולועשים צווים,"},{"start":376.46,"end":378.46,"text":"ואמא שלי מריסים של העיניים,"},{"start":378.46,"end":381.46,"text":"הם זוהלים בחולות ורואים את הרעים וקופצים עליהם,"},{"start":381.46,"end":385.46,"text":"ופאודה וליאורז וידן עמדי ורונה לשימות מלחבים ולחבים."},{"start":385.46,"end":387.46,"text":"זה הכבוד! כבוד!"},{"start":387.46,"end":390.49,"text":"כבוד! ועכשיו מה אנחנו מגלים?"},{"start":390.49,"end":393.8,"text":"שהמוסד הגיע לבצו כזה,"},{"start":393.8,"end":396.77,"text":"שהוא המבצע האחרון שלו זה להביא מטושים."},{"start":396.77,"end":399.19,"text":"מה זה מטושים?"},{"start":399.19,"end":404.35,"text":"מטושים זה הדבר הזה שנוחפים בגרון עמוק עם צמר גפן כזה,"},{"start":404.35,"end":407.35,"text":"להוציא את הבדיקה של החיידקית של הביקרונית."},{"start":407.35,"end":410.41,"text":"קחו שיפוד, תורידו ממנו את הלבבות,"},{"start":410.41,"end":413.41,"text":"שימו צמר גפן של כבש ותבדקו!"},{"start":413.41,"end":417.41,"text":"בשביל זה צריך לסוע המבצע למוסד ושיפודים!"},{"start":417.41,"end":419.41,"text":"ככה, ככה, ויהיה לה בדיקה!"},{"start":419.41,"end":421.41,"text":"באמא שלי, שמוסדתם בטוח, היו מי לעבוד?"},{"start":421.41,"end":423.41,"text":"אני שמוסדתם יעבוד בשביל כזה אמר?"},{"start":423.41,"end":425.41,"text":"מה קרה לכם? משתגעתם, והשביק?"},{"start":425.41,"end":427.41,"text":"השביק? מה נהיה עם השביק, באמא שלי?"},{"start":427.41,"end":429.41,"text":"פעמיים מבצעים של השביק, אנחנו לא היו נושאים מלחמה"},{"start":429.41,"end":431.41,"text":"אם שלא יבוא השביק, מה השביק?"},{"start":431.41,"end":435.41,"text":"מספר 163 היה בשבוע שעבר בתחנת דלקמנטה"},{"start":435.41,"end":438.41,"text":"והוא קנה ג'חנון במקרי החותחה"},{"start":438.41,"end":440.41,"text":"נחשפה הראלה ולביצה הקשה שלו"},{"start":440.41,"end":442.41,"text":"וכולם יודעים שהיא חייבת להתבודד"},{"start":442.41,"end":444.41,"text":"כי בדיוק לא התבודדו"},{"start":444.41,"end":446.41,"text":"זה מה שעושה שביך"},{"start":446.41,"end":448.41,"text":"באמא שלי פעם השביק היה עושה מלחמות"},{"start":448.41,"end":450.41,"text":"היום מה הוא עושה מלחמות בבית"},{"start":450.41,"end":452.41,"text":"ואמא שלי מלחביים מלחביים"},{"start":452.41,"end":454.41,"text":"לכן מוסר השכל"},{"start":454.41,"end":457.47,"text":"לא רק עם ישראל כולו יישב בבית בבידוד"},{"start":457.47,"end":459.47,"text":"כי זה מה שמבקשים"},{"start":459.47,"end":463.43,"text":"שנישב בבית גם השביך וגם המוסד"},{"start":463.43,"end":465.43,"text":"וכולם תשבו בבית"},{"start":465.43,"end":468.42,"text":"באמא שלי תשבו בבית"},{"start":468.42,"end":471.67,"text":"כי זה יעבור שבועיים בבית"},{"start":471.67,"end":472.98,"text":"הבנתם?"},{"start":472.98,"end":473.98,"text":"אז תחשבו על זה"},{"start":473.98,"end":476.01,"text":"עד כאן ג'ושבו מסלון ביתי"},{"start":476.01,"end":487.55,"text":"תציוו את הנוציא"},{"start":487.55,"end":489.47,"text":"יאללה תציב לו עם מה התחלה עכשיו"},{"start":489.47,"end":498.64,"text":"על ג'מי"},{"start":498.64,"end":501.06,"text":"על ג'מי"}]