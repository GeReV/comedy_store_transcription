[{"start":36.99,"end":42.41,"text":"אני מצא איתי כאן באולפן ממציא מכונת העתידות הישראלים מר עמית נבא. ערב טוב מר נבא."},{"start":42.41,"end":44.35,"text":"אה אה אה אה, ז'רנת עודה."},{"start":44.35,"end":46.85,"text":"ספר לנו ולצופים על המצאתך החדשה."},{"start":46.85,"end":53.61,"text":"ובכן, כמו שניתן לראות זו היא מכונה מיוחדת, אקסטראורדינר, מכונה שחוזה בדיוק מה יהיה היום בתוכנית הקומדיסטור."},{"start":53.61,"end":55.31,"text":"אוו, אתה יכול להדגים?"},{"start":55.31,"end":62.93,"text":"בדי, שים לב, לוקח את האוזניות והנה אני מקשיב, וואו, היום בתוכנית תהיה דמות יוצאת מגדר הרגיל, משהו חד שני ביותר."},{"start":62.93,"end":71.84,"text":"ז'וז'ו! זה דמות של ארס עם גורמטים. הוא מפתיע, הוא מדבר על פטישים, משהו חד... אופה! מה יש לנו כאן עוד? יהיה היום משהו חד שני!"},{"start":71.84,"end":80.03,"text":"זה מין בן אדם שהוא לא מצחיק את החברים שלו, מצחיק את כולם, אף אחד לא צוחק, רק הוא צוחק בעצמו. זה יש לי, יש לי, משהו חדש. אקסטראורדינר."},{"start":80.03,"end":88.38,"text":"ומה יהיה עוד? יהיה מבזקן כריח וצרפתי דביל. כן! זה הכל יהיה אני חושב בערך אבל בסך הכל..."},{"start":88.38,"end":94.16,"text":"אופלה! אני שומע הצחוקים! אני שומע הצחוקים היסטריים מבית של בן אדם אחד. תודה לך יעקב."},{"start":94.16,"end":97.16,"text":"אוקיי. זה כל זאת ועוד מיד בתום הפרסומות."},{"start":97.16,"end":100.66,"text":"רגע, רגע, רגע, רגע. אופה. עכשיו מה אני שומע? עכשיו יבוא הכחול לזה, מה ההפעד הזה?"},{"start":100.66,"end":103.86,"text":"זה זה בדיוק עם השתיים. הנה הוא בא."},{"start":103.86,"end":154.57,"text":"באים לבדיחה חכה עם חיים בלוף."},{"start":154.57,"end":159.63,"text":"שוב אנחנו כאן, בבדיחה חכה עם חיים בלוף."},{"start":159.63,"end":164.59,"text":"הנה איגור גל לצידי ומוש... מושון שלנו."},{"start":164.59,"end":167.59,"text":"איגור, אנחנו מתחלקים למשימות."},{"start":167.59,"end":169.59,"text":"אתה ניגש לסופר מרקד הסמוך."},{"start":169.59,"end":172.59,"text":"אתה... אתה גונב שק מלש."},{"start":172.59,"end":176.06,"text":"שסק. וחוזר."},{"start":176.06,"end":180.75,"text":"קדימה, איגור. תמצא אותה שלננותה."},{"start":180.75,"end":182.75,"text":"ומושון שלנו."},{"start":182.75,"end":185.91,"text":"אנחנו הולכים לבצע את הבסיס של הקומדיה."},{"start":185.91,"end":187.91,"text":"בדיוק כמו שרניץ' אפלין."},{"start":187.91,"end":190.91,"text":"כמו השמן והרזה וכהד וכהד וכהים בלוף."},{"start":190.91,"end":194.91,"text":"מושון התחפש לקליפה של בננה."},{"start":194.91,"end":198.29,"text":"הוא הולך לשכב על הכביש."},{"start":198.29,"end":199.29,"text":"בוא נראה מה יהיה."},{"start":199.29,"end":201.29,"text":"מושון, ארצה."},{"start":201.29,"end":204.39,"text":"שימו לב."},{"start":204.39,"end":210.26,"text":"הנה עובר לעובר אורח תמים."},{"start":210.26,"end":212.26,"text":"הוא לראה שמושון זה בננה."},{"start":212.26,"end":213.26,"text":"ואורח."},{"start":213.26,"end":219.95,"text":"הנה, הנה עוד אחד בגילה."},{"start":219.95,"end":220.95,"text":"מה קרה אדוני?"},{"start":220.95,"end":221.95,"text":"שימו לבובל לעזור לו ואורח."},{"start":221.95,"end":231.75,"text":"שלום לך אדוני, מה קרה?"},{"start":231.75,"end":232.75,"text":"נשבר לי הגב."},{"start":232.75,"end":236.81,"text":"נשבר לו הגב."},{"start":236.81,"end":238.81,"text":"שלום לך אדוני, מה קרה?"},{"start":238.81,"end":240.81,"text":"אף הרגל."},{"start":240.81,"end":244.81,"text":"הם פשוט לא הבחינו שמושון שלנו."},{"start":244.81,"end":246.77,"text":"הוא קליפה שלנו."},{"start":246.77,"end":249.34,"text":"אתם צריכים אבולה."},{"start":249.34,"end":251.5,"text":"אנחנו לא נזריק אבולה."},{"start":251.5,"end":254.07,"text":"קרקעי בלוף."},{"start":254.07,"end":257.07,"text":"מושון, בוא נתחפש לגויאבה."},{"start":257.07,"end":259.54,"text":"אלי, קח הכל, אלי, קח הכל."},{"start":259.54,"end":261.54,"text":"קח את הקטע הזה."},{"start":261.54,"end":273.29,"text":"צוחר אף זאך, שוב הלכנו בחלסטרה,"},{"start":273.29,"end":275.29,"text":"והפעם בחלסטרה מוקדשת"},{"start":275.29,"end":277.29,"text":"לפרש האוסקר הישראלי קולוע."},{"start":277.29,"end":279.29,"text":"איזה חרטוות ביבש שני?"},{"start":279.29,"end":281.29,"text":"ביבש שני?"},{"start":281.29,"end":283.29,"text":"כולם באו, משחקים אותה עליווד ווד."},{"start":283.29,"end":285.29,"text":"עם חליפות, עם עניוות."},{"start":285.29,"end":287.29,"text":"היא גזימה מכולם רונינטל כבץ,"},{"start":287.29,"end":289.29,"text":"איך הגיעה לקבל תפרז."},{"start":289.29,"end":291.29,"text":"בימא שלי, השיער שלה התחברה לתקע עמד ככה."},{"start":291.29,"end":293.29,"text":"בימא שלי פרשומת לי כיפודן מצוי."},{"start":293.29,"end":295.29,"text":"לא ידעתי מה לעשות."},{"start":295.29,"end":297.29,"text":"והשמחה התנפחה כאילו הביאו לה משבע."},{"start":297.29,"end":299.29,"text":"לא ידענו מה."},{"start":299.29,"end":301.29,"text":"ואיזה סרטיב, איזה ביצוקה."},{"start":301.29,"end":303.51,"text":"שמחה חשמלית ושמה משה."},{"start":303.51,"end":305.51,"text":"דויד, טוסטר אובן, קוראים לו שמעון."},{"start":305.51,"end":307.51,"text":"כפה לא קוראים לה, היא באה לבד."},{"start":307.51,"end":309.51,"text":"מה זה החרט הזה? איזה שמעון?"},{"start":309.51,"end":311.6,"text":"הכל מתחיל בלוויה של נחש."},{"start":311.6,"end":313.6,"text":"אחותיה צולעת בלוויה של הצפרדה."},{"start":313.6,"end":315.6,"text":"מה זה החרט הזה? לא יאומן."},{"start":315.6,"end":317.6,"text":"זה פשוט מצוקה. לא יאומן. איזה שמעון?"},{"start":317.6,"end":319.58,"text":"יש להם האח של דריקס."},{"start":319.58,"end":322.01,"text":"אחותו הצולעת. מה אכפת לנו?"},{"start":322.01,"end":324.01,"text":"עוד מעט יעשו סרט."},{"start":324.01,"end":326.01,"text":"אמא של זועבי."},{"start":326.01,"end":328.01,"text":"עם שפה מבעה."},{"start":328.01,"end":330.01,"text":"וידויו של ויקו חדד. אני טריפוליטאי."},{"start":330.01,"end":332.01,"text":"שימון ביטון. אני כופיף."},{"start":332.01,"end":334.01,"text":"מה זה החרט הזה?"},{"start":334.01,"end":336.01,"text":"לא יאומן כי יסופר. פשוט."},{"start":336.01,"end":338.01,"text":"חרטוואטה. והכל בגלל הסרטים בלועזית."},{"start":338.01,"end":340.01,"text":"הסרטים בארץ מושפעים."},{"start":340.01,"end":342.01,"text":"הסרטים בחול. שופו של הגיפה."},{"start":342.01,"end":344.01,"text":"לא מה זה."},{"start":344.01,"end":346.01,"text":"העולם על פי גרפס. מה זה השטויות האלה?"},{"start":346.01,"end":348.01,"text":"שלוש חתונות וצ'קחת."},{"start":348.01,"end":350.03,"text":"מה זה החרט הזה?"},{"start":350.03,"end":352.03,"text":"וירותיי ורבותיי. לאור המצוקה הקשה."},{"start":352.03,"end":354.03,"text":"יצא צוות הצילום של זו זו ולבלאש."},{"start":354.03,"end":356.03,"text":"להעניק את הפרס האמיתי לכל נועה."},{"start":356.03,"end":358.09,"text":"פרס הפטיש רבותיי."},{"start":360.09,"end":362.09,"text":"זהב לסרט האיכותי של השנה."},{"start":362.09,"end":364.37,"text":"שימו לב."},{"start":364.37,"end":370.8,"text":"תודה, תודה."},{"start":370.8,"end":372.8,"text":"שלום לכולם."},{"start":372.8,"end":374.8,"text":"וברוכים הבאים לטקס הראשון"},{"start":374.8,"end":376.8,"text":"של חלוקת פרסי זוזו"},{"start":376.8,"end":378.8,"text":"לכל נועה הישראלית."},{"start":378.8,"end":385.42,"text":"תודה, תודה."},{"start":385.42,"end":387.42,"text":"אני מתכבד לפתוח בקטגוריה הראשונה."},{"start":387.42,"end":389.31,"text":"קטגוריית"},{"start":389.31,"end":391.33,"text":"קפת הזהב."},{"start":391.33,"end":393.43,"text":"הסרט המקפקף של השנה."},{"start":396.09,"end":399.01,"text":"והסרטים הם:"},{"start":399.01,"end":402.49,"text":"הטוב, הרע והמסוגה"},{"start":402.49,"end":411.55,"text":"יש לי, יש לי, יש לי, יש לי"},{"start":411.55,"end":413.77,"text":"אתה הטוב?"},{"start":413.77,"end":419.31,"text":"לא, אתה רע!"},{"start":419.31,"end":425.42,"text":"הדרמה: בלוזה לקפה הגדולה"},{"start":425.42,"end":433.33,"text":"קפה, שחלפה"},{"start":433.33,"end":436.02,"text":"לקפה, לקפה"},{"start":436.02,"end":440.49,"text":"תום תפה"},{"start":440.49,"end":446.3,"text":"גברת המתיחות, גברת תפתחי"},{"start":446.3,"end":449.3,"text":"או שאני מביא לך נוגרה!"},{"start":449.3,"end":453.3,"text":"שלחנו את נושון לדפוק"},{"start":453.3,"end":455.3,"text":"הדלתה של הגברת ממול"},{"start":455.3,"end":457.3,"text":"סיבו לב"},{"start":457.3,"end":460.26,"text":"גברת תפתחי או שאני אתן לך נוגרה"},{"start":460.26,"end":467.66,"text":"למי אתה תיתן נוגרה?"},{"start":467.66,"end":469.65,"text":"והזוכה בפרס הקפה"},{"start":469.65,"end":473.81,"text":"הוא משה"},{"start":473.81,"end":480.43,"text":"איפגי"},{"start":480.43,"end":483.04,"text":"משה מה קרה לסער שלך?"},{"start":483.04,"end":485.04,"text":"אני עכשיו בדיוק עובד על סרט חדש"},{"start":485.04,"end":492.13,"text":"באתי באמצע צילומים"},{"start":492.13,"end":494.13,"text":"אבל לכם אין מילים בפעיל להביע"},{"start":494.13,"end":508.51,"text":"את התרגשותי הגדולה"},{"start":508.51,"end":510.64,"text":"פרס עיגולת הזהב"},{"start":510.64,"end":512.64,"text":"המועמדים הם"},{"start":512.64,"end":515.79,"text":"הסרט"},{"start":515.79,"end":517.79,"text":"סיפורי שנקין"},{"start":517.79,"end":521.44,"text":"אז אתה שומע?"},{"start":521.44,"end":523.6,"text":"אז יוסי וחזי חיו באושר ובאושר עד היום זה?"},{"start":523.6,"end":525.98,"text":"בוא נשנקין יש לך כאלה סיפורים"},{"start":525.98,"end":530.54,"text":"תודה"},{"start":530.54,"end":537.25,"text":"בשבע"},{"start":537.25,"end":541.6,"text":"אמא!"},{"start":541.6,"end":544.3,"text":"אז אני הולך לישון"},{"start":544.3,"end":550.26,"text":"והסרט"},{"start":550.26,"end":553.03,"text":"שירת הווגידה"},{"start":553.03,"end":555.85,"text":"אני אטום כחדר אטום"},{"start":555.85,"end":557.85,"text":"אני חנוק ללא פילטר"},{"start":557.85,"end":559.85,"text":"אני נחש צפה"},{"start":559.85,"end":561.85,"text":"אני שרב כבד"},{"start":561.85,"end":563.85,"text":"אני שרב כבד"},{"start":563.85,"end":566.36,"text":"אז אני בועז"},{"start":566.36,"end":570.28,"text":"שרבי"},{"start":570.28,"end":572.28,"text":"והזוכה מפרס עיגולת הזהב"},{"start":572.28,"end":574.28,"text":"לשנת 1994"},{"start":574.28,"end":576.84,"text":"בושה יפגי"},{"start":576.84,"end":586.3,"text":"עוד פעם תודה רבה"},{"start":586.3,"end":588.3,"text":"אני עדיין מאוד מאוד מתרגש"},{"start":588.3,"end":597.11,"text":"תודה רבה"},{"start":597.11,"end":599.2,"text":"לקטגוריה האחרונה"},{"start":599.2,"end":601.2,"text":"בקטגוריה"},{"start":601.2,"end":603.2,"text":"שבת שיגור הטילים"},{"start":603.2,"end":605.58,"text":"של השנה"},{"start":605.58,"end":607.99,"text":"והמתמודדות הן"},{"start":607.99,"end":610.02,"text":"ממכוערת"},{"start":610.02,"end":616.43,"text":"בסרטה וואו"},{"start":616.43,"end":618.43,"text":"ג'ודי אהרונוב קרפין"},{"start":618.43,"end":620.43,"text":"סממה כלאוווין"},{"start":620.43,"end":622.53,"text":"בסרטה"},{"start":622.53,"end":624.53,"text":"ג'ודי בת 17"},{"start":624.53,"end":629.98,"text":"וקים בסנג'ר"},{"start":629.98,"end":631.98,"text":"על משחקה"},{"start":631.98,"end":633.98,"text":"באופן כללי"},{"start":633.98,"end":637.1,"text":"ובפרס"},{"start":637.1,"end":639.1,"text":"שיגור הטילים"},{"start":639.1,"end":641.86,"text":"לשנה זו זוכה"},{"start":641.86,"end":643.86,"text":"משה איפגי"},{"start":643.86,"end":650.62,"text":"משה האם זהו חלק"},{"start":650.62,"end":652.61,"text":"מסרט חדש"},{"start":652.61,"end":655.8,"text":"לא כידוע קשה להתפרס"},{"start":655.8,"end":657.8,"text":"מקולנוע אז אני עושה חלטורות"},{"start":657.8,"end":663.76,"text":"בבר מצווה"},{"start":663.76,"end":665.76,"text":"שכדאי לסיים את הערב הזה בבשורה"},{"start":665.76,"end":668.05,"text":"בסבכת"},{"start":668.05,"end":668.15,"text":"צרת האומנויות"},{"start":668.05,"end":670.05,"text":"הודיעה בפאקס מחול"},{"start":670.05,"end":672.14,"text":"של השנה הבאה"},{"start":672.14,"end":674.14,"text":"היא תורמת לטובת הקולנוע"},{"start":674.14,"end":676.14,"text":"שלנו ארוחת"},{"start":676.14,"end":678.2,"text":"צהריים עסקית"},{"start":678.2,"end":680.2,"text":"במזנון הכנסת"},{"start":680.2,"end":680.3,"text":"לזוכם הפרס"},{"start":680.2,"end":682.2,"text":"איזה מחיאת הקפיים שלנו"},{"start":682.2,"end":688.97,"text":"להתראות בשנה הבאה"},{"start":688.97,"end":690.97,"text":"הריאו"},{"start":690.97,"end":700.71,"text":"ערב טוב"},{"start":700.71,"end":702.71,"text":"כאן הצנזור הראשי ירחמיאל חתך"},{"start":702.71,"end":704.71,"text":"וערב נדבר על תופעה מדאיגה"},{"start":704.71,"end":706.87,"text":"מסרים של תואבה"},{"start":706.87,"end":708.87,"text":"שמושתלים בתוך