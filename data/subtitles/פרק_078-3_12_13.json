[{"start":1.25,"end":4.61,"text":"תוכנית זו מבוססת המקרים שהתרחשו במזיאות"},{"start":4.61,"end":10.12,"text":"קשר בין המציאות לדמיון, הינו מקרי בהחלט"},{"start":10.12,"end":15.95,"text":"כמות האנשים והמקומות שונו לצורך העלילה"},{"start":15.95,"end":17.37,"text":"ומאתה הם ניקאים"},{"start":17.37,"end":56.37,"text":"עבודה"},{"start":56.37,"end":61.69,"text":"עבודה"},{"start":61.69,"end":63.23,"text":"איך קוראים לך?"},{"start":63.23,"end":65.45,"text":"אסים בוסקילה"},{"start":65.45,"end":67.71,"text":"אמרת בוסקילה?"},{"start":67.71,"end":69.48,"text":"אסים בוסקילה"},{"start":69.48,"end":74.97,"text":"אתה קרוב של דון בוסקילה דה מדרי מהצד של הפאדרי?"},{"start":74.97,"end":77.95,"text":"אה לא, אסים בוסקילה"},{"start":77.95,"end":81.73,"text":"תגיד לי, למה אתה מדבר בכל כזה?"},{"start":81.73,"end":85.3,"text":"אתה עושה צחוק מהפאבינו"},{"start":85.3,"end":86.43,"text":"פאבינו"},{"start":86.43,"end":88.43,"text":"פאבינו, פאבינו"},{"start":88.43,"end":89.62,"text":"פאבינו, פאבינו"},{"start":89.62,"end":92.74,"text":"ילדים, אתה פלובו"},{"start":92.74,"end":95.24,"text":"פלובו"},{"start":95.24,"end":96.46,"text":"אין בעיות, פאבינו"},{"start":96.46,"end":101.11,"text":"הלו? הלו?"},{"start":101.11,"end":103.64,"text":"אוקיי ג'וני, לעבודה"},{"start":103.64,"end":104.64,"text":"בשמחה"},{"start":104.64,"end":113.0,"text":"איך היה?"},{"start":113.0,"end":115.05,"text":"לא רע"},{"start":115.05,"end":116.68,"text":"לא רע"},{"start":116.68,"end":120.44,"text":"אני רואה שאתה שולט באומנות הלחימה היפנית"},{"start":120.44,"end":122.63,"text":"אוכל אירופניות?"},{"start":122.63,"end":125.2,"text":"בושידו"},{"start":125.2,"end":126.2,"text":"לא בושידו"},{"start":126.2,"end":128.09,"text":"בוסקילה"},{"start":128.09,"end":129.09,"text":"אתה יודע להשתמש בסכינים"},{"start":129.09,"end":130.31,"text":"מכינים?"},{"start":130.31,"end":131.31,"text":"סכינים, סכינים"},{"start":131.31,"end":133.31,"text":"מכינים, מכינים"},{"start":133.31,"end":135.27,"text":"עשה"},{"start":135.27,"end":136.56,"text":"מכינים"},{"start":136.56,"end":138.81,"text":"יא!"},{"start":138.81,"end":140.6,"text":"פירא!"},{"start":140.6,"end":145.83,"text":"איך היה?"},{"start":145.83,"end":148.48,"text":"אה"},{"start":148.48,"end":150.03,"text":"לא רואים עבודה?"},{"start":150.03,"end":151.25,"text":"איך אתה בביליארד?"},{"start":151.25,"end":152.86,"text":"ביליארד"},{"start":152.86,"end":155.01,"text":"סנוקר"},{"start":155.01,"end":156.23,"text":"רוקר"},{"start":156.23,"end":158.22,"text":"סנוקר, סנוקר"},{"start":158.22,"end":160.19,"text":"רוקר, רוקר"},{"start":160.19,"end":168.92,"text":"אתה לא ניגש לשולחן?"},{"start":168.92,"end":172.43,"text":"אוקיי, אוקיי, אוקיי, אוקיי!"},{"start":222.86,"end":225.2,"text":"אלוהים עבודה אה!"},{"start":225.2,"end":227.2,"text":"מי לוסט סאנ!"},{"start":227.2,"end":228.42,"text":"פפה!"},{"start":228.42,"end":232.56,"text":"אלוהים עבודה!"},{"start":232.56,"end":234.56,"text":"דיסיס מי לוסט סאנ!"},{"start":234.56,"end":235.56,"text":"אוסט סאנ!"},{"start":235.56,"end":237.52,"text":"איזה פפינו לפורס אולדה!"},{"start":237.52,"end":239.81,"text":"אני הפיפינו שלך!"},{"start":239.81,"end":240.86,"text":"פיפ...אינו!"},{"start":240.86,"end":243.24,"text":"פפינו מי מוץ!"},{"start":243.24,"end":245.23,"text":"אל גיבים עול מי מני!"},{"start":245.23,"end":248.02,"text":"אלחמני!"},{"start":248.02,"end":250.02,"text":"עבודה אלוהים!"},{"start":250.02,"end":251.11,"text":"אלוהים!"},{"start":251.11,"end":252.2,"text":"מה הפינו!"},{"start":252.2,"end":256.47,"text":"מה זה עבודה!"},{"start":256.47,"end":259.47,"text":"קל האפקות גאים להציג את הסדרה הקומית הישראלית"},{"start":259.47,"end":264.47,"text":"שזכתה בפרס האמו לסדרות ג'יפה כתוכנית הגרועה ביותר: משפחת ישראלי"},{"start":264.47,"end":294.99,"text":"המותקת זוכרת את שושנה השמנה"},{"start":294.99,"end":297.21,"text":"כן, זאת שלמדה איתנו בתיכון"},{"start":297.21,"end":301.21,"text":"זאת שהייתה כל כך שמנה שלתמונת ספר המחזור צילמו אותה מהאוויר"},{"start":301.21,"end":304.4,"text":"כן, כן, זאת שהייתה איתנו אחר כך בתירונות"},{"start":304.4,"end":307.4,"text":"וקיבלנו עונש מחלקתי להקיף אותה שלוש פעמים"},{"start":307.4,"end":310.4,"text":"אז בדיוק אותה אחת אני רואה אותה ברחות"},{"start":310.4,"end":313.4,"text":"ואל תשאלי אם מי הסתובבה"},{"start":313.4,"end":315.46,"text":"רק רגש נעמה, מה זה?"},{"start":315.46,"end":316.61,"text":"היי אמא"},{"start":316.61,"end":319.61,"text":"תקידי, אודי, אתה מוכן לחבוט את הכאב ראש הזה?"},{"start":319.61,"end":320.61,"text":"מה זה לא כאב ראש"},{"start":320.61,"end":321.61,"text":"מה קרה לך? אני עורך מחקר"},{"start":321.61,"end":323.61,"text":"על השפעת המוזיקה"},{"start":323.61,"end":325.61,"text":"על התפתחות הצמחים"},{"start":325.61,"end":326.61,"text":"מבחיניו הולטאי טונטרית"},{"start":326.61,"end":327.61,"text":"טוב, תעשה מה שאתה רוצה"},{"start":327.61,"end":329.61,"text":"רק אתה יודע שעוד מה את אבא בא הביתה"},{"start":329.61,"end":331.61,"text":"ואתה יודע יפה מה הוא יעשה לך"},{"start":331.61,"end":332.57,"text":"מה?"},{"start":332.57,"end":334.57,"text":"הוא ידחף לך את הראש לתוך העציץ"},{"start":334.57,"end":337.57,"text":"ואת הקלטת ידחף לך לתוך המוע"},{"start":337.57,"end":340.08,"text":"טוב, אני צריך ללכת"},{"start":340.08,"end":341.3,"text":"יש לי מה לעשות"},{"start":341.3,"end":342.3,"text":"להתראות, אודי, ביי"},{"start":342.3,"end":344.3,"text":"מתראות, בוא עציץ עם התוק, בוא"},{"start":344.3,"end":346.3,"text":"בוא נעשה לך המסקרים"},{"start":346.3,"end":347.3,"text":"בוא, בוא"},{"start":347.3,"end":348.3,"text":"מתראות, אמא"},{"start":348.3,"end":350.3,"text":"אז הקיצרת שומעת פיסטוק"},{"start":350.3,"end":352.3,"text":"אה, ברכה"},{"start":352.3,"end":354.36,"text":"אז אני רואה את שושנה השמנה"},{"start":354.36,"end":355.36,"text":"הי, אמא"},{"start":355.36,"end":359.02,"text":"אני ממהרת לקונסורט החגיגי"},{"start":359.02,"end":361.95,"text":"של התזמורת הפילרמונית של חצור הגלילית"},{"start":361.95,"end":365.08,"text":"תגידי, מה יש לכם היום מחצור הגלילית הזאת?"},{"start":365.08,"end":367.27,"text":"אמא, את הרי יודעת שאני נדלקת"},{"start":367.27,"end":369.27,"text":"מכל דבר שמזכיר לי גליל"},{"start":369.27,"end":372.94,"text":"תגידי לי, את היוצאת עם הקנאר ההוא?"},{"start":372.94,"end":375.94,"text":"אוי, מה פתאום אמא? עם הקנאר יצאתי אתמול"},{"start":375.94,"end":376.94,"text":"היום אני יוצאת עם צ'לן"},{"start":376.94,"end":379.94,"text":"אבל את בעצמיך אמרת שהקנאר הוא מאוד מאוד נחמד"},{"start":379.94,"end":383.97,"text":"נחמד נחמד, אבל אני מעדיפה אחד עם כלי יותר גדול"},{"start":383.97,"end":385.79,"text":"ביי אמא"},{"start":385.79,"end":386.85,"text":"ביי ביי"},{"start":386.85,"end":390.36,"text":"אז הקיצר, את שומעת ברך אני מצטערת שהיא מטנת"},{"start":390.36,"end":392.36,"text":"אבל את חייבת לשמוע את הסיפור על שושנה השמנה"},{"start":392.36,"end":394.36,"text":"אני רואה אותה הולכת ברחוב"},{"start":394.36,"end":396.36,"text":"יוצאת לבלות עם רחמים"},{"start":396.36,"end":398.36,"text":"ועם מסיקה ביחד באותו זמן"},{"start":398.36,"end":399.36,"text":"אחד מכל צד"},{"start":399.36,"end":403.36,"text":"והיא כל כך שמנה שאף אחד בכלל לא ידע על השנים"},{"start":404.36,"end":406.55,"text":"ברח אני חייבת לנתק"},{"start":406.55,"end":407.55,"text":"אני שומעת את בעלי בדלת"},{"start":407.55,"end":408.55,"text":"אוקיי ביי ביי"},{"start":408.55,"end":409.55,"text":"אני אספר לה כל מחר"},{"start":409.55,"end":410.55,"text":"ביי"},{"start":410.55,"end":415.46,"text":"שלום לך עיצית בעלי"},{"start":415.46,"end":416.46,"text":"שלום לך"},{"start":416.46,"end":417.46,"text":"אתה יודע שהכרת?"},{"start":417.46,"end":420.46,"text":"תגיד אני לא ידעתי שיש שעות נוספות במוסק"},{"start":420.46,"end":423.46,"text":"אל תשאלי איזה בעיות היה לי בעבודה"},{"start":423.46,"end":425.59,"text":"אך איך שאמרתי לסגור את אבסטה"},{"start":425.59,"end":427.72,"text":"נכנס יעקב"},{"start":427.72,"end":430.0,"text":"עם אשתו שושנה אשמנה"},{"start":430.0,"end":431.97,"text":"הם רצו שהם ישים לצפצפה"},{"start":431.97,"end":433.97,"text":"כמו במסעית שהיא הולכת אחורה"},{"start":433.97,"end":435.97,"text":"יהיה בים בים בים"},{"start":435.97,"end":438.0,"text":"איך שאני גומר איתיו?"},{"start":438.0,"end":440.0,"text":"נכנסת איזה מישהי חדשה"},{"start":440.0,"end":442.53,"text":"אך איזה בודי"},{"start":442.53,"end":444.87,"text":"עשיתי לטיפול הסרט אלפים"},{"start":444.87,"end":447.87,"text":"אתה יודע יציק לפעמים ידמה לי שאתה מטפל במכוניות שלך"},{"start":447.87,"end":449.83,"text":"יותר ממה שאתה מטפל בי"},{"start":449.83,"end":453.85,"text":"את רוצה שאני אטפל בך?"},{"start":453.85,"end":455.85,"text":"תעשי קודם פח רחות"},{"start":455.85,"end":459.07,"text":"אוי יציק אתה לפעמים יכול להיות כל כך מתנתם"},{"start":459.07,"end":462.2,"text":"לא זה בסדר אני אוהב אותך"},{"start":462.2,"end":464.2,"text":"אני אוהב אותך"},{"start":464.2,"end":466.2,"text":"מתומטם מתנה שלי"},{"start":466.2,"end":469.2,"text":"פרה גדולה ומסריחה שכמוש"},{"start":469.2,"end":473.45,"text":"לועס את מסטיק בראש חוצות שכמוש"},{"start":473.45,"end":474.45,"text":"דומן"},{"start":474.45,"end":480.79,"text":"מעניין מי זה יכול להיות אני מקווה שזה לא השכן שלנו"},{"start":480.79,"end":482.79,"text":"אלפרד הסטנדאפיסטה לא מצחיק הזה"},{"start":482.79,"end":484.79,"text":"זה שהורס את כל הבדיחות"},{"start":484.79,"end":486.85,"text":"זה שמספר לנו כל הזמן את הבדיחות קרש"},{"start":486.85,"end":490.85,"text":"איפה היה לפני חודש היינו צריכים לבנות סוכה מהקרשים שלו"},{"start":490.85,"end":493.85,"text":"אם זהו אני משחרר לו את האפריקס מדרדר אותו במדרגות"},{"start":493.85,"end":496.94,"text":"אלפרד לא תשאר יצא חימות מהאישה"},{"start":496.94,"end":498.96,"text":"לא תודה התחבקתי כבר בבית"},{"start":498.96,"end":499.96,"text":"אני מבין אותך"},{"start":499.96,"end":504.96,"text":"נו לאלפרד פניטה קיבלת סטאג בפיטה"},{"start":504.96,"end":506.96,"text":"נילון איזה שיבוע"},{"start":506.96,"end":508.96,"text":"אתה מצחיק אתה"},{"start":508.96,"end":511.96,"text":"אולי תישאר אלפרד חמודי לקוס קפה"},{"start":511.96,"end":513.96,"text":"תשימי לו אורל במקום סוכן"},{"start":513.96,"end":515.96,"text":"לא תודה התחבקתי בבית"},{"start":515.96,"end":517.96,"text":"חבר'ה שימו לב אני חייב לנסות עליכם קטע"},{"start":517.96,"end":521.96,"text":"אני הולך עכשיו לחימום בהופעה הגלילית של הצורך הגיעית"},{"start":521.96,"end":522.96,"text":"זה קונצרט בומבסטי"},{"start":522.96,"end":523.96,"text":"אני דופק שם קטע גדול"},{"start":523.96,"end":526.96,"text":"שימו לב הילייט קצר תגידו לי מבדיחה מצחיקה"},{"start":526.96,"end":527.96,"text":"אוקיי"},{"start":527.96,"end":530.53,"text":"איש אחד בא לדוקטור ואומר לו"},{"start":530.53,"end":532.53,"text":"דוקטור דוקטור אל תשאל"},{"start":532.53,"end":534.53,"text":"הבן שלי מנגן על מפוחית פה"},{"start":534.53,"end":535.53,"text":"והוא בלה את המפוחית"},{"start":535.53,"end":536.53,"text":"מה לעשות"},{"start":536.53,"end":537.55,"text":"אומר לו הדוקטור"},{"start":537.55,"end":540.55,"text":"איזה מזל שהוא לא מנגן על פסנתר כנף"},{"start":540.55,"end":541.55,"text":"כוסוקטי"},{"start":541.55,"end":542.55,"text":"איזה גנב הייתי"},{"start":542.55,"end":543.55,"text":"הנה לבוקדיני"},{"start":543.55,"end":544.58,"text":"כושלוקי"},{"start":544.58,"end":548.07,"text":"מה"},{"start":548.07,"end":549.07,"text":"עכשיו מה מצחיק פה"},{"start":549.07,"end":550.07,"text":"מה מצחיק פה"},{"start":550.07,"end":551.26,"text":"הרופא אומר לו"},{"start":551.26,"end":553.26,"text":"איזה מזל שהוא לא מנגן על פסנתר כנף"},{"start":553.26,"end":554.26,"text":"דהי נו"},{"start":554.26,"end":556.26,"text":"איך הוא יכול אם הוא מנגן עם הידיים"},{"start":556.26,"end":557.26,"text":"לבלוע את הפסנתר כנף"},{"start":559.26,"end":567.79,"text":"לא לא אתה באמת מצחיק אתה"},{"start":567.79,"end":569.79,"text":"אתה מצחיק מאוד אתה"},{"start":569.79,"end":571.79,"text":"אדי מרפי הוא כזה שנון"},{"start":571.79,"end":573.75,"text":"צ'רלי צ'אפלין היו לו יציאות"},{"start":573.75,"end":574.75,"text":"אבל אתה"},{"start":574.75,"end":575.91,"text":"אתה מצחיק אתה"},{"start":575.91,"end":577.91,"text":"בבקשה"},{"start":577.91,"end":578.91,"text":"חבר'ה באמת"},{"start":578.91,"end":580.91,"text":"תודה רבה לכם על הפרגון"},{"start":580.91,"end":581.91,"text":"לאלפרד פניטה"},{"start":581.91,"end":583.91,"text":"קיבלת סטייק בניילון"},{"start":583.91,"end":585.91,"text":"לא שילמת ועד בית"},{"start":585.91,"end":587.91,"text":"עד מחר את הצ'ק על החדשיים האחרמים"},{"start":587.91,"end":588.91,"text":"להתראות"},{"start":588.91,"end":589.91,"text":"בסדר זבל"},{"start":589.91,"end":590.88,"text":"מאמית מצוננת"},{"start":590.88,"end":591.88,"text":"מאפעה מלוכלכת"},{"start":591.88,"end":593.88,"text":"יפות ארסי"},{"start":593.88,"end":594.88,"text":"אקזמה קטלנית"},{"start":594.88,"end":595.88,"text":"נחש בלי תכתית"},{"start":595.88,"end":596.88,"text":"וירוסים תחת"},{"start":596.88,"end":597.88,"text":"תקפוץ לכדורגל בשבן"},{"start":597.88,"end":598.88,"text":"אין בעיות"},{"start":598.88,"end":601.2,"text":"מצחיק כמו דויארה"},{"start":601.2,"end":602.2,"text":"ריקובה"},{"start":602.2,"end":605.06,"text":"אבוקדו בדימוס"},{"start":605.06,"end":608.65,"text":"אתה אל תזלזל בו, אתה יודע"},{"start":608.65,"end":612.64,"text":"שהוא נתן הופעות סטנדאפ וחיממת להקת משינה?"},{"start":612.64,"end":615.25,"text":"נו מה הפלא שהם יתפרקו?"},{"start":615.25,"end":623.31,"text":"במקום השלישי, יניב"},{"start":623.31,"end":628.92,"text":"במקום השני, אסך"},{"start":628.92,"end":634.38,"text":"במקום הראשון, רובי"},{"start":634.38,"end":675.26,"text":"רובי"},{"start":675.26,"end":677.23,"text":"של הדוקטור פליקס"},{"start":677.23,"end":679.23,"text":"שוב אתם כאן איתי"},{"start":679.23,"end":681.21,"text":"והיום נבדוק הרגשת כאב מי"},{"start":681.21,"end":683.21,"text":"כל אחד כמובן חש כאב מידי יום ביומו"},{"start":683.21,"end":685.21,"text":"ואנחנו נבדוק כאן כאב מהו"},{"start":685.21,"end":687.23,"text":"תחילה נקרא לאסיסטנט שלי, מרטין"},{"start":687.23,"end":689.23,"text":"מרטין!"},{"start":689.23,"end":691.23,"text":"שלום לך, איך המרגש?"},{"start":691.23,"end":693.22,"text":"שתוק, אל תענה לי, אל תענה אם לא נשאלת"},{"start":693.22,"end":697.4,"text":"ובכן, תחילה נבדוק האם מרטין חש בכאבים"},{"start":697.4,"end":699.4,"text":"היה כואב, כואב, כואב"},{"start":699.4,"end":701.4,"text":"ועכשיו..."},{"start":701.4,"end":703.4,"text":"נפלא! תודה רבה לך"},{"start":703.4,"end":705.4,"text":"ועכשיו, כאן במעבדה שלנו"},{"start":705.4,"end":707.4,"text":"הכינון ובמאוד בועד ספרי תרסיס"},{"start":707.4,"end":709.4,"text":"זה ספרי נפלא!"},{"start":709.4,"end":711.4,"text":"על מנת לבנוע כאבים"},{"start":711.4,"end":713.4,"text":"ועכשיו, נדגים את השפעת הספרי"},{"start":713.4,"end":715.84,"text":"על האסיסטנט שלי, מרטין"},{"start":715.84,"end":718.25,"text":"גרישה! בוא לכאן אלפרד"},{"start":718.25,"end":721.21,"text":"תחילה, נרסס את מיכל"},{"start":721.21,"end":724.09,"text":"הסר את משקפיך, בומבון"},{"start":724.09,"end":726.61,"text":"זרק אותה בצדה"},{"start":726.61,"end":730.8,"text":"יש לי מנע ממגע ספרי בעיניים"},{"start":730.8,"end":732.86,"text":"ועכשיו, אחרי שריססנו"},{"start":732.86,"end":737.11,"text":"נבדוק האם הוא חש כאבים כלל"},{"start":737.11,"end":741.11,"text":"תמתין מעט"},{"start":741.11,"end":743.43,"text":"ואחרי שמתאנו נבדוק שנית"},{"start":743.43,"end":749.5,"text":"יש פה זה קלה קלה"},{"start":749.5,"end":751.71,"text":"לאחר שנים של עבודה"},{"start":751.71,"end":753.71,"text":"על הספרי הנפלא הזה"},{"start":753.71,"end":755.71,"text":"ספרי אקסטרווגנטי זה"},{"start":755.71,"end":762.92,"text":"יש את הקלה קלה, זהו הספרי של השירותים"},{"start":762.92,"end":765.05,"text":"ובכן, נבדוק שנית את ההשפעת הספרי"},{"start":765.05,"end":767.05,"text":"על אלברטו"},{"start":767.05,"end":772.91,"text":"נרסש את הוקלות ועכשיו נפוצש אותו במכות"},{"start":772.91,"end":774.87,"text":"פו, פו, קה!"},{"start":774.87,"end":776.87,"text":"פרדיננד חש כאבים"},{"start":776.87,"end":779.02,"text":"אולי בעזרת הלומית"},{"start":779.02,"end":781.02,"text":"קה! קה! קה!"},{"start":781.02,"end":783.02,"text":"קה! קה!"},{"start":783.02,"end":786.49,"text":"מסקנה?"},{"start":786.49,"end":789.1,"text":"מרטין אינו בן אדם"},{"start":789.1,"end":791.1,"text":"מרטין חש כאבים למרות איסוס הספרי"},{"start":791.1,"end":793.1,"text":"היו איתנו שוב כאן במעבדה שלי"},{"start":793.1,"end":795.1,"text":"של הדוקטור"}