[{"start":29.41,"end":34.55,"text":"תודה רבה רבותיי, ברוכים הבאים, לקו במסדור!"},{"start":34.55,"end":45.09,"text":"אני פשוט לא מביא למה אתה מעשה, זה יש לך כאן עסקה מצוינת, זה הספקה מיידית, זה להיט באירופה, אני נותן לך את זה בחמישת השלומים, מה הבעיה בכלל? בוא נסגור עסקה."},{"start":45.09,"end":48.78,"text":"הכל הלאה כיפה, ככה אני לא שעלה ממצבע."},{"start":53.79,"end":76.17,"text":"החדר של שושנה השמינה עם תין המאהב."},{"start":76.17,"end":81.38,"text":"המאהב."},{"start":81.38,"end":87.16,"text":"סבתא, סבתא, מה זה מההב?"},{"start":87.16,"end":89.56,"text":"מההב."},{"start":89.56,"end":101.66,"text":"סבתא?"},{"start":101.66,"end":131.82,"text":"ושלום, שוב אנחנו בחלסטרה של זוז'ו, ושוב פרסומות."},{"start":131.82,"end":135.94,"text":"הפעם רציתי לדבר אתכם כהל לכבד על הפרסומות של סוני."},{"start":135.94,"end":138.03,"text":"ואם השלילי לא נורמנים, זה פרסומות לא יומנום."},{"start":138.03,"end":140.03,"text":"מה שרואים זה כזה דבר?"},{"start":140.03,"end":142.03,"text":"רואים בן אדם, עומד על ספסל, יושבי סבבה."},{"start":142.03,"end":144.03,"text":"גם גולד אם שמו עליו."},{"start":144.03,"end":146.03,"text":"והוא נרקמו לפלף, כבר זה חשוד."},{"start":146.03,"end":149.03,"text":"עכשיו, פתאום עוברים שתי אנשים, נותנים את המצלמה שלו בשבילו."},{"start":149.03,"end":151.03,"text":"אומרים לו, צלם אותנו, צלם אותנו."},{"start":151.03,"end":154.03,"text":"אעוב צלם, והם נופלים במים, והוא מבריז."},{"start":154.03,"end":157.06,"text":"זה לא מקורי, זה מועתק."},{"start":157.06,"end":159.06,"text":"שנים אני עובד ככה בשכונה, שנים."},{"start":159.06,"end":162.06,"text":"כל מי שעובר בלו לכלך הולב לעבת שלמה."},{"start":162.06,"end":164.06,"text":"רק מה שאני לא שוני, זה לא חייב."},{"start":164.06,"end":171.09,"text":"גם בראדרסד, גם אריסטונסד, גם שרוונסד, גם שני אונסד."},{"start":171.09,"end":175.09,"text":"כל החברות אני בעד, למה לא? גם מצובשטין, גם סוברטו, הכל."},{"start":175.09,"end":178.09,"text":"בשביל זה מה שאני אומר חבר'ה, לא צריך להיות קטנוני."},{"start":178.09,"end":180.09,"text":"כל דבר לוקחים, מטבעים ובורחים."},{"start":180.09,"end":182.15,"text":"דבר נוסף, יש את השני כלבים."},{"start":182.15,"end":185.21,"text":"שני כלבים מכוערים, יושבים בסלון,"},{"start":185.21,"end":188.21,"text":"איפה הבעל בית אין למושג, הוא פותח טלוויזיה הכלב."},{"start":188.21,"end":190.21,"text":"מוכשר, מעולף."},{"start":190.21,"end":193.21,"text":"פתאום הוא שומע את המנגינה של אל-בנדי."},{"start":193.21,"end":196.21,"text":"לב אין מריג', לב אין מריג'."},{"start":196.21,"end":197.21,"text":"עכשיו הוא חכה להי."},{"start":197.21,"end":200.21,"text":"לאשתו של אל-בנדי עם הריאות שלה שתיכנס."},{"start":200.21,"end":201.21,"text":"פתאום רואה כלבה."},{"start":201.21,"end":202.21,"text":"מאיפה היא באה כלבה?"},{"start":202.21,"end":204.21,"text":"הוא נעשה לבסך לראות מאיפה היא באה."},{"start":204.21,"end":206.21,"text":"ופתאום כלבה, פה כלבה שם הוא נגנב."},{"start":206.21,"end":209.21,"text":"הבן אדם נקרא לו המוח הכלב, אפילו שהוא כלב."},{"start":209.21,"end":212.21,"text":"בשביל זה כל הפרסובת הזאת זה שערוריה אחת גדולה."},{"start":212.21,"end":214.21,"text":"והמסקנה הפשוטה."},{"start":214.21,"end":216.59,"text":"במידה ואתה רוצה לראות אל-בנדי,"},{"start":216.59,"end":218.59,"text":"זה לא שוני ולא שוני ולא ההבדל."},{"start":218.59,"end":220.59,"text":"זה ערוצים בטלוויזיה."},{"start":220.59,"end":222.59,"text":"ותחשיבו על החלסטרה."},{"start":275.69,"end":281.81,"text":"שמה, אני כתבתי את זה, אני חייב לשמוע עוד דעה."},{"start":281.81,"end":282.81,"text":"תקרא את זה רגע."},{"start":282.81,"end":284.72,"text":"נו, מה אתה אומר?"},{"start":284.72,"end":291.41,"text":"אמא, אני אגיד לך, זה די מסובך."},{"start":291.41,"end":292.53,"text":"יש לך ראש לכל העניין הזה?"},{"start":292.53,"end":294.53,"text":"יש לי ראש, בטח שיש לי ראש לזה."},{"start":294.53,"end":300.69,"text":"השאלה היא, אני שואל את עצמי אם יש לך מטרה לנושא הזה."},{"start":300.69,"end":303.69,"text":"שמה, יש לי מטרה, יש לי מטרה לכל זה ואני כבר השגתי אותה."},{"start":303.69,"end":308.01,"text":"הבעיה שאני רוצה לשמוע עוד דעה, עוד דעה נוספת."},{"start":308.01,"end":310.01,"text":"תאמין, מישהו שיגיד לי משהו על זה."},{"start":310.01,"end":312.04,"text":"תראה, אני אגלוי איתך עד הסוף."},{"start":312.04,"end":313.93,"text":"כן."},{"start":313.93,"end":314.93,"text":"בוא נשים את כל הכליפים על השולחן."},{"start":314.93,"end":317.93,"text":"בוא נשים, אין בעיה, אין בעיה. אני מוכן ללכת איתך עד הסוף."},{"start":317.93,"end":319.93,"text":"רק תגיד לי מה קורה."},{"start":319.93,"end":323.2,"text":"לדעתי, וזו רק לדעתי את כל \"Take it or leave it\"."},{"start":323.2,"end":326.73,"text":"אתה חייב לשנות את הכל."},{"start":326.73,"end":328.43,"text":"בסדר, ככה זה בסדר."},{"start":328.43,"end":330.4,"text":"לא, קצת יותר גבוה."},{"start":330.4,"end":332.48,"text":"ככה זה בסדר."},{"start":332.48,"end":335.48,"text":"זה מצוין, אז בכל זאת אני רוצה שיש על מה לדבר."},{"start":335.48,"end":338.51,"text":"אז אני עכשיו נוסע על המשרד, בתל אביב, אני..."},{"start":338.51,"end":340.41,"text":"אז אתה יכול להקפיץ אותי?"},{"start":340.41,"end":341.51,"text":"למה לא?"},{"start":341.51,"end":342.51,"text":"בסדר, נכון."},{"start":342.51,"end":345.87,"text":"אוקיי."},{"start":345.87,"end":346.87,"text":"תודה רבה."},{"start":346.87,"end":350.46,"text":"עשה לו."},{"start":350.46,"end":351.46,"text":"עשה לו."},{"start":351.46,"end":352.46,"text":"עשה לו."},{"start":352.46,"end":353.46,"text":"עשה לו."},{"start":353.46,"end":358.7,"text":"עשה לו."},{"start":358.7,"end":359.7,"text":"עוד, מורבי."},{"start":359.7,"end":361.7,"text":"נגיש טוב, ביי."},{"start":361.7,"end":362.76,"text":"אוקיי."},{"start":362.76,"end":364.89,"text":"עשה, עשה לשם, ישם."},{"start":364.89,"end":365.92,"text":"כן, כן."},{"start":365.92,"end":369.61,"text":"עשה, עשה, יופי."},{"start":369.61,"end":372.05,"text":"עשה, ישם."},{"start":372.05,"end":374.45,"text":"אוקיי, יופי."},{"start":374.45,"end":375.45,"text":"אכן תמונות קשות."},{"start":375.45,"end":377.54,"text":"מאה שנים של בדידות."},{"start":377.54,"end":379.72,"text":"מה היה קורה אם היינו שוכחים עדוב?"},{"start":379.72,"end":383.94,"text":"כאן ג'ודילוס, גרסיה, מרקל, שטרייט, וורצל, בורשטיין, לזר."},{"start":383.94,"end":386.22,"text":"מריאם ילן שטקליס."},{"start":386.22,"end":387.28,"text":"סבון."},{"start":387.28,"end":396.31,"text":"מוריד דמה שחור."},{"start":396.31,"end":399.27,"text":"למה סבלת את זה, יוכל לבש לך פה עם ה-10 אבל."},{"start":399.27,"end":402.83,"text":"לוקח את הדמה שלך."},{"start":402.83,"end":403.99,"text":"הוא לקח את הדמה."},{"start":403.99,"end":404.99,"text":"ומוריד 4 לב אדום."},{"start":404.99,"end":407.4,"text":"לוקח קופה."},{"start":407.4,"end":411.18,"text":"שתיים, שים את השתיים פה פה."},{"start":411.18,"end":413.18,"text":"בין ה-3 וה-4."},{"start":413.18,"end":415.13,"text":"לתכביר לך עם ה-5, נתחבר לך."},{"start":415.13,"end":418.82,"text":"לוקח קופה."},{"start":418.82,"end":420.82,"text":"למה כך? כך תהיה משהו זרק."},{"start":420.82,"end":422.94,"text":"טוב, נוי, מתי שאת שימו אותו פה."},{"start":422.94,"end":424.04,"text":"אפשר לב לך 8."},{"start":424.04,"end":426.04,"text":"תעשה לי טובה, תעשה לי טובה."},{"start":426.04,"end":428.04,"text":"תיגיע שלו מדבך, תביא לנו פירות, אה?"},{"start":428.04,"end":429.04,"text":"זה מאוד יעזור."},{"start":429.04,"end":431.04,"text":"כן, ניחדתי שם בצלחת, רק תביא את זה לפה."},{"start":431.04,"end":433.04,"text":"את העשר פה, אל תזרוק, כי תכף יבוא לך עם האם."},{"start":433.04,"end":435.04,"text":"כן, כן, 100%, 100%, כן."},{"start":435.04,"end":436.46,"text":"מה זה?"},{"start":436.46,"end":438.53,"text":"חבר'ה, חבר'ה."},{"start":438.53,"end":439.65,"text":"בואו נצטלבט עליו."},{"start":439.65,"end":442.72,"text":"תכף חוזר ומסטלבטים, הוא לא יודעים איפה זה כבר."},{"start":442.72,"end":446.25,"text":"אבל הנה הפירות, לא היו הרבה, אני מצטער, בסדר?"},{"start":446.25,"end":448.25,"text":"זה מצטער איזה 100%, תודה, תודה רבה."},{"start":448.25,"end":454.78,"text":"אני לוקח שטמפה, שוסטה, אפ."},{"start":454.78,"end":457.49,"text":"אופה, אופה, אתה יודע מה?"},{"start":457.49,"end":467.69,"text":"לוקח רבע שוסטה שלך, דאו, מוריד אליה שטמפילט, ומקפל רב צגן."},{"start":467.69,"end":478.25,"text":"אני עושה סטריםטה, קלורטה ומונוסודיום גלוטמט."},{"start":478.25,"end":480.3,"text":"אופה."},{"start":480.3,"end":481.52,"text":"שמוספה!"},{"start":481.52,"end":484.52,"text":"למה, למה, למה? חבר'ה, בונה, בונה, למה מונוסודיום גלוטמט?"},{"start":484.52,"end":486.52,"text":"אתה לא יודע לשחק, נשבר לך שאתה לא יודע לשחק."},{"start":486.52,"end":488.52,"text":"יש לך פה דבלנקה, כן?"},{"start":488.52,"end":490.48,"text":"עם הצ'ומפה שהייתה לך מקודם,"},{"start":490.48,"end":491.48,"text":"שהוא זרק לך את הסטמפה,"},{"start":491.48,"end":493.48,"text":"אתה לוקח את האפ שלו, יש לך גלוק אלוק."},{"start":493.48,"end":496.59,"text":"אתם לא יודעים לשחק, נשבר לכם אתם לא יודעים לשחק."},{"start":498.93,"end":514.38,"text":"מפקד משטרה?"},{"start":514.38,"end":517.38,"text":"מה פתאום, אני מפקד מגב."},{"start":517.38,"end":518.38,"text":"מגב!"},{"start":518.38,"end":521.54,"text":"יש לי, יש לי, יש לי."},{"start":521.54,"end":524.54,"text":"תגיד לי, אתה מפקד עוגדה?"},{"start":524.54,"end":526.54,"text":"מה פתאום, אני מפקד ענף!"},{"start":526.54,"end":528.54,"text":"מפקד ענף!"},{"start":528.54,"end":531.54,"text":"אני מפקד ענף!"},{"start":531.54,"end":534.54,"text":"תגיד לי, אתה מפקד טייסת?"},{"start":534.54,"end":536.6,"text":"לא, אני מפקד סוללה!"},{"start":536.6,"end":542.78,"text":"יש לי, יש לי, יש לי, יש לי"},{"start":542.78,"end":546.25,"text":"תגידו, אני מפקד מחנה!"},{"start":546.25,"end":548.5,"text":"לא! אני עובד רסר!"},{"start":548.5,"end":555.27,"text":"ללך לשמור, ללך לשמור!"},{"start":555.27,"end":556.27,"text":"ללך לשמור!"},{"start":556.27,"end":557.27,"text":"ללך לשמור!"},{"start":557.27,"end":558.27,"text":"ללך!"},{"start":558.27,"end":566.57,"text":"אוי בבוי לי, איזה יום, איזה יום"},{"start":566.57,"end":570.65,"text":"אני לא בשבילי קולסי כזה של השודים"},{"start":570.65,"end":574.79,"text":"אוי בבוי לי"},{"start":574.79,"end":614.25,"text":"איי איי"},{"start":643.02,"end":645.02,"text":"ממתי אני אגונה אחת? אני לא מוכנה"},{"start":645.02,"end":647.02,"text":"אני לא נערת ליווי של אוהב"},{"start":647.02,"end":648.02,"text":"ולא של אף אחד"},{"start":648.02,"end":650.02,"text":"והגיע הזמן שהוא ילמד את זה"},{"start":650.02,"end":652.02,"text":"וחוץ לזה שנמסע על ההפינה הזאת"},{"start":652.02,"end":653.02,"text":"ואני לא מוכנה לדבר על זה"},{"start":653.02,"end":654.02,"text":"תתביישו לכם"},{"start":654.02,"end":656.02,"text":"זו תוכנית לכל המשפחה"},{"start":656.02,"end":657.92,"text":"ואני לא מוכנה לדבר על דברים שכאלה"},{"start":657.92,"end":660.05,"text":"ואם אני כן אדבר אז אני לא אדבר"},{"start":660.05,"end":662.01,"text":"אני אפנים"},{"start":662.01,"end":663.01,"text":"ואת יודעת מה? אני לא יודע"},{"start":663.01,"end":697.56,"text":"יש לי, יש לי, יש לי"},{"start":697.56,"end":698.49,"text":"מה יש לי?"},{"start":698.49,"end":701.04,"text":"לאיזה דרגה יש טוריה?"},{"start":701.04,"end":702.7,"text":"טוריי"},{"start":702.7,"end":704.7,"text":"טוריי"},{"start":704.7,"end":705.7,"text":"טוריי"},{"start":705.7,"end":706.7,"text":"טוריי"},{"start":706.7,"end":707.7,"text":"יש לי גם, יש לי גם"},{"start":707.7,"end":708.7,"text":"שים לב"},{"start":708.7,"end":711.11,"text":"לאיזה דרגה יש סמלה?"},{"start":711.11,"end":712.11,"text":"סמל"},{"start":712.11,"end":713.11,"text":"סמל"},{"start":713.11,"end":714.11,"text":"טוריי"},{"start":714.11,"end":715.11,"text":"טוריי"},{"start":715.11,"end":716.11,"text":"יש לי בשבילך"},{"start":716.11,"end":718.11,"text":"לאיזה דרגה יש סירנה?"},{"start":718.11,"end":719.94,"text":"סרן"},{"start":719.94,"end":720.94,"text":"טוריי"},{"start":720.94,"end":721.94,"text":"טוריי"},{"start":721.94,"end":722.94,"text":"טוריי"},{"start":722.94,"end":724.94,"text":"יש לי, יש לי"},{"start":724.94,"end":725.94,"text":"יש לי, יש לי"},{"start":725.94,"end":729.88,"text":"לאיזה דרגה יש שפן?"},{"start":729.88,"end":733.09,"text":"לך סורד"},{"start":733.09,"end":738.76,"text":"כך, כך, כך, שים עליך יותר טוב, שים"},{"start":738.76,"end":740.76,"text":"שים, שים עליך חזק תקשור"},{"start":740.7