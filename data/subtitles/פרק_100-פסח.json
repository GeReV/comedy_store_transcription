[{"start":0.0,"end":2.12,"text":"לומר אדוני אל משה:"},{"start":2.12,"end":6.93,"text":"לך אל פרעו ודבר אל ליבו למען ישלח את עמי"},{"start":6.93,"end":10.96,"text":"ומשה כבד פה וכבד לשון הוא."},{"start":10.96,"end":12.37,"text":"למעבודה!"},{"start":12.37,"end":14.58,"text":"משה, משה."},{"start":14.58,"end":16.1,"text":"משה, משה."},{"start":16.1,"end":18.83,"text":"משה, גלה את פניך."},{"start":18.83,"end":21.06,"text":"משה, עלי על פניך."},{"start":21.06,"end":22.5,"text":"גש, הלום."},{"start":22.5,"end":23.8,"text":"הלום לך?"},{"start":23.8,"end":25.18,"text":"משה?"},{"start":25.18,"end":28.48,"text":"משה, משה, בוסקי לרבינו, איזוש רסבית, מי אתה?"},{"start":28.48,"end":31.43,"text":"אני, אדוני, אלוהיך."},{"start":31.43,"end":38.64,"text":"איפה נדבר על אלוהיך? איפה, איפה מתחבא למשיקו רבנו בשקילה? איפה הוא מתחבא? איפה? אחורם זדה ומחלה הוא עמיד חת מלוש?"},{"start":38.64,"end":48.3,"text":"גש אל פרעו מלך מצרים ואמור לו שלח את עמי. עמית? מי זה עמית? שלח את עמי, שלח את עמי."},{"start":48.3,"end":58.98,"text":"איפה שלח את עמונית? מי? המלך מתמיים הזה. מה? המלך מתמיים הוא שלח את עמונית עם העמית, איפה זה? מי?"},{"start":58.98,"end":62.99,"text":"מי? מי? מי? מי? מי? אלוהים עבודה?"},{"start":62.99,"end":66.75,"text":"כן, כן. אלוהים עבודה רק תלך לפרעו כבר."},{"start":66.75,"end":71.15,"text":"תדר, אלוהים עדירים."},{"start":71.15,"end":72.03,"text":"מה?"},{"start":72.03,"end":72.85,"text":"אה?"},{"start":72.85,"end":74.16,"text":"קראת לי."},{"start":74.16,"end":79.96,"text":"לא קראת לך, קראת לך, אמר לך על זה, עכשיו הוא עכשיו קוראים לו. תדר, אלוהים עבודה, תדר, אלוהים עבודה."},{"start":79.96,"end":81.8,"text":"טוב, טוב, סליחה, אני מצטער משה."},{"start":81.8,"end":84.84,"text":"בסדר, אמרתי שאני מצטער, לא?"},{"start":84.84,"end":88.93,"text":"משה, לאן אתה הולך? אחרי הפרסומות הקומדיסטור."},{"start":88.93,"end":92.48,"text":"משה, משה, אחרי הפרסומות הקומדיסטור."},{"start":92.48,"end":96.94,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות."},{"start":96.94,"end":102.47,"text":"קשר בין המציאות לדמיון, הינו מקרי בהחלט."},{"start":102.47,"end":108.15,"text":"שמות האנשים והמקומות שונו לצורך העלילה."},{"start":108.15,"end":122.86,"text":"ומאתה הם נקראים הקומדיסטור."},{"start":122.86,"end":144.25,"text":"משק, קס מסכת, אביב. אני שקט, רגלי."},{"start":144.25,"end":147.1,"text":"בואי לה, אופה, סקרה, לא נורא."},{"start":147.1,"end":149.59,"text":"כל חבר המשק שימו לב, פוס אותו."},{"start":149.59,"end":153.9,"text":"גוברמן רסי, אין דבר ראשון אני רוצה לעשות את סוגת לבכם לבעיה קלה."},{"start":153.9,"end":164.11,"text":"רובכם ודאי חושבים שהאביב סומד בחובו צעירות, התחדשות ועליזות, אך לא ככו לאביב פן נוסף."},{"start":164.11,"end":172.03,"text":"אנו מכירים את האלרגיות, אקזמות, גירודים שונים, קקה תנועה, מאמורות ורון לבנטל."},{"start":172.03,"end":180.37,"text":"ובכן שימו לב חברי המשק, הפעם נציג לכם במיטב מסור את הרפ הצעירה של חברי המשק, שיר על האביב."},{"start":180.37,"end":184.74,"text":"קבלו בבקשה את להקת בני המשקים בליווי הפרות המשוגעות."},{"start":184.74,"end":198.33,"text":"בבקשה! נחשה! אל תרוקד יותר קולביינית בתוך האבוקדה! צא מפה! צא! ולעניין אחר!"},{"start":198.33,"end":203.9,"text":"מה תבחר הבא! אנרגיה ולמי יש..."},{"start":203.9,"end":209.18,"text":"על מי נדה!"},{"start":209.18,"end":216.18,"text":"לא נדומות, לא מגירותים, לא נהנו לך!"},{"start":216.18,"end":227.6,"text":"לבוא אגס וגם תבואה, נסו ישר אל הראות, וקשה לי לנשום כי יש לי אסמה!"},{"start":227.6,"end":231.6,"text":"עסמה לא יכול לשמול את הראות!"},{"start":231.6,"end":235.81,"text":"חרבה נספה, הלבי נגיע בצחפה!"},{"start":235.81,"end":276.09,"text":"שמצביב, אלי תגוש ייתן פה קפה, אלי חלבים של השפה, רק את הראש של הצירפה!"},{"start":276.09,"end":281.68,"text":"לצחבל הצעים בצבל אסור לנו!"},{"start":281.68,"end":290.07,"text":"ונלך את מה תהיה שיפה!"},{"start":290.07,"end":297.17,"text":"יבשה היא מחוספסת מלובעת עם חורים!"},{"start":297.17,"end":300.19,"text":"בגלון תמיד נתקעת כמו דמק נגרים!"},{"start":300.19,"end":304.38,"text":"היא כמו קקטי, כמו קרש, כמו גבס כמו קרטון!"},{"start":304.38,"end":308.47,"text":"ובבטן היא יושבת כמו גוספלה כמו בטון!"},{"start":308.47,"end":312.47,"text":"ובבטן היא יושבת כמו גוספלה כמו בטון!"},{"start":312.47,"end":315.52,"text":"ארבע!"},{"start":315.52,"end":320.77,"text":"נסטרה!"},{"start":320.77,"end":323.24,"text":"מי יודע?"},{"start":323.24,"end":324.85,"text":"אי סעלה!"},{"start":324.85,"end":326.84,"text":"אני יודע!"},{"start":326.84,"end":329.41,"text":"נסטרה!"},{"start":329.41,"end":330.41,"text":"שמידיות!"},{"start":330.41,"end":331.73,"text":"תישה!"},{"start":331.73,"end":332.73,"text":"שמידיות!"},{"start":332.73,"end":334.73,"text":"שמונה!"},{"start":334.73,"end":335.73,"text":"שמידיות!"},{"start":335.73,"end":336.73,"text":"שימה!"},{"start":336.73,"end":337.73,"text":"שמידיות!"},{"start":337.73,"end":338.73,"text":"תעזוב אותך בעדו!"},{"start":338.73,"end":339.73,"text":"תעזוב אותך בעדו!"},{"start":339.73,"end":340.73,"text":"תעזוב אותך בעדו!"},{"start":340.73,"end":341.73,"text":"תעזוב אותך בעדו!"},{"start":341.73,"end":342.73,"text":"תעזוב אותך בעדו!"},{"start":342.73,"end":343.73,"text":"תעזוב אותך בעדו!"},{"start":343.73,"end":344.73,"text":"איני, איזה חג שמח!"},{"start":344.73,"end":347.23,"text":"אמר רבי אלעזר בן הזריה,"},{"start":347.23,"end":349.23,"text":"הרי אני כבן 70 שנה,"},{"start":349.23,"end":351.23,"text":"ולא זכיתי שתאמר יציאת מצרים בלילות,"},{"start":351.23,"end":353.23,"text":"עד שברשב בן זומך!"},{"start":353.23,"end":359.47,"text":"איזה זומך!"},{"start":359.47,"end":361.47,"text":"איזה זומך!"},{"start":361.47,"end":363.79,"text":"איזה זומך!"},{"start":363.79,"end":364.79,"text":"איזה זומך!"},{"start":364.79,"end":366.79,"text":"תקריא עוד משהו!"},{"start":366.79,"end":367.79,"text":"תעזרבן קבעייך!"},{"start":367.79,"end":369.79,"text":"לא תקריא תקריא תקריא!"},{"start":369.79,"end":371.79,"text":"והיא שאני לא אבותנו ולאבו שלו!"},{"start":371.79,"end":373.23,"text":"איזה זומך!"},{"start":373.23,"end":375.23,"text":"לא לא! מה אמרת?"},{"start":375.23,"end":376.26,"text":"והיא שעמת!"},{"start":376.26,"end":380.26,"text":"איזה זמן!"},{"start":380.26,"end":383.26,"text":"ניסית לקחת משהו פושח!"},{"start":383.26,"end":391.28,"text":"תקריא עוד משהו."},{"start":415.32,"end":429.19,"text":"שוודית שוודית שוודית שוודית שוודית שבשמיים ובסטוקולם."},{"start":429.19,"end":430.19,"text":"נו אז איך היה בסדר?"},{"start":430.19,"end":434.17,"text":"פעלת שמע, זה אחד הסדרים הכי מצחיקים שהיו לי."},{"start":434.17,"end":436.25,"text":"אני יושב בבית, כאילו מי בא אלינו לסדר?"},{"start":436.25,"end":437.25,"text":"-נו. -הדי מרפי."},{"start":437.25,"end":439.25,"text":"גדול, בואו נה, בן אדם הזה מצחיק."},{"start":439.25,"end":444.25,"text":"קרא אותנו כל הסדר, הבן אדם יושב לא מפסיק לזרוק בדיחות."},{"start":444.25,"end":446.24,"text":"ומדונה יושבת ממול."},{"start":446.24,"end":450.21,"text":"אתה יודע, והיא זורקת עליו כזה חתיכות של חסנים של זטים, ולא נעים לי."},{"start":450.21,"end":451.21,"text":"היא גדולה, בואו נה, אבל היא גדולה."},{"start":451.21,"end":455.21,"text":"היא גדולה, וג'וליה רוברסט לידי כל הסדר, כאילו חברוסט, חברוסט."},{"start":455.21,"end":457.21,"text":"אמרה משהו עליי, עשתה עליי קטע פעם."},{"start":457.21,"end":461.21,"text":"היא אמרה כאילו שבזמן האחרון לא מסתדר לכם כל כך ביחד."},{"start":461.21,"end":463.21,"text":"אבל לא זה מה שרציתי ספך."},{"start":463.21,"end":465.21,"text":"קיצור, אני הורד עם ההשפעה של כל הסדר."},{"start":465.21,"end":468.21,"text":"אני אומר לרופי גולדברג, \"Just a minute\", כאילו, \"I'm right back\"."},{"start":468.21,"end":471.43,"text":"איך שאני הורד לפחימת? מי הרואה מי מול יד הפך?"},{"start":471.43,"end":472.43,"text":"נו."},{"start":472.43,"end":473.39,"text":"לא תעמין."},{"start":473.39,"end":475.44,"text":"לאה לופתי."},{"start":475.44,"end":476.44,"text":"לאה לופתי."},{"start":476.44,"end":477.44,"text":"דיברתי איתה ליד הפך?"},{"start":477.44,"end":478.44,"text":"כן, כן."},{"start":478.44,"end":479.44,"text":"נשבע לך ש..."},{"start":479.44,"end":482.44,"text":"ראית אותה, דיברת איתה, זה ממש לך שלום."},{"start":482.44,"end":485.56,"text":"לא, היא לא אמרה לי שלום, אבל היא הסתכלה עליי."},{"start":485.56,"end":487.56,"text":"נשבע לך ספי, הסתכלה עליי."},{"start":487.56,"end":489.56,"text":"לא ממש עליי, הסתכלה על הכיוון."},{"start":489.56,"end":491.56,"text":"כאילו אני בטוח, תראים את העיניים."},{"start":491.56,"end":493.56,"text":"לאה לופתם, נראים מה עליך את העיניים."},{"start":493.56,"end":495.56,"text":"לא תראים, לא תראים, לא תראים."},{"start":495.56,"end":497.56,"text":"לא תראים, אתה וסיפורים שלך."},{"start":497.56,"end":498.56,"text":"אתה יודע."},{"start":498.56,"end":499.56,"text":"אתה וסיפורים שלך."},{"start":499.56,"end":500.56,"text":"בסדר, תעזובתי בשקט."},{"start":500.56,"end":501.56,"text":"להלוכה."},{"start":501.56,"end":505.56,"text":"בסדר."},{"start":505.56,"end":507.91,"text":"Hi there, this is NTV's Spring Hit List."},{"start":507.91,"end":509.91,"text":"I'm Ray Coxenun, still Ray, still Coxenun,"},{"start":509.91,"end":511.9,"text":"but this time, tonight, I'm also a knight."},{"start":511.9,"end":514.44,"text":"YO NIGHTMARE!"},{"start":514.44,"end":516.44,"text":"Well, never mind about this silly joke."},{"start":516.44,"end":519.44,"text":"Now, let's move just right to the result of the Pesach Hit List,"},{"start":519.44,"end":521.43,"text":"what you may call \"Nitz'ad-Shirei Pesah\"."},{"start":521.43,"end":522.85,"text":"Pesah, is it?"},{"start":522.85,"end":524.66,"text":"Pesach."},{"start":524.66,"end":526.07,"text":"Pesach."},{"start":526.07,"end":527.48,"text":"Thank you, Adam."},{"start":527.48,"end":528.48,"text":"Pesach."},{"start":528.48,"end":532.63,"text":"And for the first category, the most silly, stupid and not really important song,"},{"start":532.63,"end":535.63,"text":"won the hit single \"Eh Hayah\" by Nesim Buskila."},{"start":535.63,"end":538.72,"text":"Let's see it, and don't you go away and stay tuned."},{"start":538.72,"end":543.83,"text":"Ah, thank you, Adam."},{"start":543.83,"end":569.51,"text":"*Pesach*"},{"start":569.51,"end":673.38,"text":"*Pesach*"},{"start":673.38,"end":677.9,"text":"*Pesach*"},{"start":677.9,"end":679.89,"text":"*Pesach*"},{"start":679.89,"end":681.89,"text":"*Pesach*"},{"start":681.89,"end":688.65,"text":"*Pesach*"},{"start":688.65,"end":690.65,"text":"*Pesach*"},{"start":690.65,"end":692.65,"text":"*Pesach*"},{"start":692.65,"end":694.65,"text":"*Pesach*"},{"start":694.65,"end":696.65,"text":"*Pesach*"},{"start":696.65,"end":714.84,"text":"*ערבית*"},{"start":762.19,"end":770.19,"text":"אה, תאמין לי אם קים בסינג'ר הסתדרתי יותר טוב, בקיצור, את יודעי, כל היחסים האינטריגות האלה ביניהם בסוף מאשימים אותי, אבל מה אני אשר?"},{"start":770.19,"end":771.19,"text":"תחליק את זה, תחליק את זה, תמיד"},{"start":771.19,"end":774.19,"text":"בבטא שאני אשר, למה? מה שסטינג סיפר לי עליהם אני בכלל לא מאמין"},{"start":774.19,"end":775.19,"text":"אל תאמין לו, אל תאמין לו"},{"start":775.19,"end":777.19,"text":"בקיצור, בשולחן ממול, את מי אני רואה?"},{"start":777.19,"end":779.19,"text":"מוטי גלעדי, שולחן לידי"},{"start":779.19,"end":784.14,"text":"נשבע לך, נו, מה אתה לומר, בעיניים שמוטי גלעדי ישב ל..."},{"start":784.14,"end":786.14,"text":"לא היית את מוטי גלעדי במציאות?"},{"start":786.14,"end":787.14,"text":"כן, הוא היה ב..."},{"start":787.14,"end":789.14,"text":"אוקיי, הוא ישב כמה שולחנות ליד, נו"},{"start":789.14,"end":790.14,"text":"נו, כמה..."},{"start":790.14,"end":791.14,"text":"מברותה מסעדה"},{"start":791.14,"end":792.14,"text":"אני אומר לך, מוטי גלעדי ישב ל..."},{"start":792.14,"end":794.14,"text":"ואני אלך תמיד, אתה פוגש אותו ואני לא נמצא, נכון?"},{"start":794.14,"end":796.14,"text":"אבל מה קרה לך? תשאל את ברד פיטמור"},{"start":796.14,"end":798.17,"text":"אני באמת תשאל אותו"},{"start":798.17,"end":801.17,"text":"אל תאמין לי, אל תאמין לי, תאדריש אספר לך כלום"},{"start":801.17,"end":805.47,"text":"רי פקה להפקות מציגים?"},{"start":805.47,"end":808.78,"text":"סדרת פעובה כשאירה למעדרים"},{"start":808.78,"end":810.78,"text":"על פי הסדרה המשוקצת"},{"start":810.78,"end":812.87,"text":"די אייטים?"},{"start":812.87,"end":814.93,"text":"סבר למיניין"},{"s