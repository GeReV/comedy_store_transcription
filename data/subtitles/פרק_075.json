[{"start":0.67,"end":3.99,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות."},{"start":3.99,"end":9.52,"text":"קשר בין המציאות לדמיון הינו מקרי בהחלט."},{"start":9.52,"end":15.35,"text":"תמות האנשים והמקומות שונו לצורך העלילה."},{"start":15.35,"end":16.75,"text":"ומאתה הם ניקאים."},{"start":16.75,"end":49.73,"text":"מאוד מוזר, אתה חייב לא..."},{"start":49.73,"end":51.92,"text":"אל תדאג, אנחנו נטפל בהכל."},{"start":51.92,"end":54.06,"text":"יש כאן רק משהו לא ברור כל כך בצילום הזה."},{"start":54.06,"end":55.9,"text":"אני אעבור לצילום הגדול יותר."},{"start":55.9,"end":56.7,"text":"רק רגע, שנייה."},{"start":56.7,"end":59.5,"text":"מה אומר הרנטגן, דוקטור?"},{"start":59.5,"end":63.17,"text":"מאוד מוזר, האמת."},{"start":63.17,"end":64.77,"text":"רק רגע, אני צריך לבדוק את זה."},{"start":64.77,"end":65.6,"text":"זה?"},{"start":65.6,"end":67.3,"text":"לא."},{"start":69.75,"end":77.6,"text":"מה זה? דוקטור?"},{"start":77.6,"end":79.43,"text":"זה מאוד מעניין, האמת."},{"start":79.43,"end":82.36,"text":"דוקטור, אתה חייב לעזור לי, דוקטור."},{"start":82.36,"end":84.4,"text":"מה אני עושה עם הדבר הזה, דוקטור?"},{"start":84.4,"end":85.7,"text":"שש, תרגע, תרגע."},{"start":85.7,"end":86.95,"text":"מה אני עושה עכשיו?"},{"start":86.95,"end":89.49,"text":"תרגע, זה פעם שונה, אמנם שאני רואה את זה כאן."},{"start":89.49,"end":94.81,"text":"אבל יש רק דבר אחד שאפשר לעשות איתך."},{"start":94.81,"end":98.59,"text":"יו, יו, יו, יו, יו, יו, יו, יו, יו, יו, יו, יו, יו, יו."},{"start":98.59,"end":127.47,"text":"שלום, שלום לכולם."},{"start":127.47,"end":130.46,"text":"שוב, אתם איתי, שמעון החוזה."},{"start":130.46,"end":132.7,"text":"כאן, במזג אוויר."},{"start":133.22,"end":135.56,"text":"ובואו נראה מה יהיה הטמפרטורות למחר."},{"start":135.56,"end":142.63,"text":"אז כמו שאתם רואים, מחר יהיה מזג אוויר, יהיה הרבה מזג אוויר,"},{"start":142.63,"end":147.54,"text":"ובאלת יהיה וואו, וואו, וואו, כמה מזג אוויר יהיה."},{"start":147.54,"end":153.37,"text":"וחיצים יבואו מהים על מישור החוף הפילוסופי."},{"start":153.37,"end":157.04,"text":"עכשיו, בואו נראה כמה תמונות של הלוויין."},{"start":157.04,"end":161.24,"text":"בבקשה, זה לוויין פוטוגני."},{"start":161.24,"end":163.31,"text":"רוסי, אבל פוטוגני."},{"start":163.31,"end":166.86,"text":"אתם בטח שואלים את עצמכם, איפה ביטו?"},{"start":167.23,"end":170.87,"text":"אז ביטו, נו במישור האסטרונומי, בחללית."},{"start":170.87,"end":172.73,"text":"הנה, הנה, נראה לכם תמונה, הנה."},{"start":172.73,"end":175.93,"text":"אלו ביטו, נאללה."},{"start":175.93,"end":178.27,"text":"הוא עושה חיים, הוא נהנה שם."},{"start":178.27,"end":180.7,"text":"הביא לי כמה תמונות מהלוויין, תביא, תביא."},{"start":180.7,"end":182.44,"text":"זהו תמונות שקיבלנו מהלוויין."},{"start":182.44,"end":185.48,"text":"תמונה חדה, יש לו עדשה חדה, הוא צילה מעל מיקונוס,"},{"start":185.48,"end":189.86,"text":"מעל החוף ים, כמה תמונות של נערות לוויין."},{"start":189.86,"end":194.54,"text":"ש... אלה, אלה. אך בידול, בידול."},{"start":194.54,"end":197.98,"text":"אה, כן, לא נראה לכם את התמונות האלה, אבל..."},{"start":197.98,"end":202.97,"text":"במקום זה, בואו נראה כמה טמפרטורות מהעולם והסביבה."},{"start":202.97,"end":207.32,"text":"בבקשה, הנה כמה טמפרטורות בעולם."},{"start":207.32,"end":209.61,"text":"כמו שאתם רואים, גם בעולם יש מזג אוויר."},{"start":209.61,"end":213.52,"text":"אבל אנחנו, מה אכפת לנו? אנחנו, אנחנו פה."},{"start":213.52,"end":218.66,"text":"וגם בשבוע הבא נהיה פה, בתוכנית מזג אוויר של שמעון החוזה."},{"start":218.66,"end":223.51,"text":"אז עד אז, יאללה בית. יצא טוב!"},{"start":223.51,"end":235.9,"text":"אך בני היקר, בני היקר, יום יבוא וכל זה יהיה שלך."},{"start":235.9,"end":252.85,"text":"דוקטור, אני יודעת שאתה באמצע ניתוח פרוסטטה מסובך, אבל אפשר לשאול אותך שאלה?"},{"start":252.85,"end":253.79,"text":"כן."},{"start":253.79,"end":256.82,"text":"היום זה היום הולדת שלך, נכון?"},{"start":256.82,"end":262.9,"text":"אה, זהו, אז החלטנו כמה בנות פה במחלקה להביא לך איזה משהו קטן ביחד, התארגלנו."},{"start":262.9,"end":267.06,"text":"בנות, בנות, זה נגד חוקי הבית חולים, אוקיי? זה לא אתי ולא סטרילי, אז בבקשה."},{"start":267.06,"end":268.7,"text":"משהו קטן? לא, לא משהו."},{"start":268.7,"end":270.7,"text":"שימלי דוקטור. משהו שימלי."},{"start":270.7,"end":273.7,"text":"דוקטור, אתה לא יכול לפגוע בין. לא, לא, בסדר, שימלי, זה לא."},{"start":273.7,"end":275.72,"text":"אוקיי."},{"start":275.72,"end":276.72,"text":"מזל טוב דוקטור."},{"start":276.72,"end":278.72,"text":"תודה רבה, תודה רבה, אני אפתח את זה אחרי אני אתרוח, אוקיי?"},{"start":278.72,"end":279.72,"text":"מאוד יפה, דריה, עטיפה יפתמות."},{"start":279.72,"end":280.72,"text":"מזל טוב."},{"start":280.72,"end":282.72,"text":"תודה רבה דוקטור. כן."},{"start":282.72,"end":285.72,"text":"אני וסטר גם הבאנו משהו ביחד, אני והיא."},{"start":285.72,"end":286.72,"text":"עוד משהו."},{"start":286.72,"end":287.72,"text":"לא, לא ביחד עם כולה."},{"start":287.72,"end":288.72,"text":"מזל טוב דוקטור."},{"start":288.72,"end":289.72,"text":"מזל טוב דוקטור. זה מאיתנו."},{"start":289.72,"end":291.72,"text":"נשיקה, נשיקה. גם אני רוצה נשיקה."},{"start":291.72,"end":293.72,"text":"זה רק מהמחלקה שלנו."},{"start":293.72,"end":300.19,"text":"דוקטור, גם ארגנו לך איזה הפתעה קטנה."},{"start":300.19,"end":302.41,"text":"ברשותך, דוקטור, חכה שנייה."},{"start":302.41,"end":304.41,"text":"דוקטור, חכה שנייה ו..."},{"start":304.41,"end":390.47,"text":"יאללה, אולג המתח, זה בדרך."},{"start":390.47,"end":391.47,"text":"אפשר לרדת בצומת?"},{"start":391.47,"end":392.47,"text":"כן, בוא עליה."},{"start":392.47,"end":393.47,"text":"הצומת זה בדיוק בדרך שלי."},{"start":393.47,"end":394.56,"text":"בוא, בוא, בחור, בוא."},{"start":394.56,"end":396.87,"text":"יאללה, אתה יכול להבין לעצמך את המזגן?"},{"start":396.87,"end":398.87,"text":"תעמי לי, תרגיש הרבה יותר נוח בחום הזה."},{"start":398.87,"end":399.87,"text":"זה יפריל לך אם אני אעשן?"},{"start":399.87,"end":401.87,"text":"לא, תעשן, רק שימך גורה."},{"start":401.87,"end":404.86,"text":"היום אנשים לא עוצרים לך, תעמי לי אנשים חולרות."},{"start":404.86,"end":406.86,"text":"שעות להתייבס לא עוצרים לך היום."},{"start":406.86,"end":409.56,"text":"עוד הצומת זה בדיוק בדרך."},{"start":409.56,"end":413.15,"text":"צא, יש לך עוד, צא."},{"start":413.15,"end":415.15,"text":"תגיד, אפשר אולי לשים רדיו?"},{"start":415.15,"end":417.15,"text":"שים רדיו, חופשי רק לא יותר מדי חזק."},{"start":417.15,"end":420.89,"text":"צא, יש לך עוד, צא."},{"start":420.89,"end":423.73,"text":"צא, יש לך עוד."},{"start":423.73,"end":429.73,"text":"קבלו אותו, מועדון, מועדון, מועדון הג'יפה."},{"start":429.73,"end":435.6,"text":"צא, ערב צא, ערב צא."},{"start":435.6,"end":437.6,"text":"הלו שפיה, הלו קאקון."},{"start":437.6,"end":439.66,"text":"אוקיי, כאן נכבד, קבלו."},{"start":439.66,"end":440.66,"text":"WAIT!"},{"start":440.66,"end":442.76,"text":"האומן הראשון שהתארח פה."},{"start":442.76,"end":443.91,"text":"WAIT!"},{"start":443.91,"end":447.91,"text":"מגדל הגרניום, מקיבוץ סאסא."},{"start":447.91,"end":449.17,"text":"יש לך עוד?"},{"start":449.17,"end":451.26,"text":"עץ האחד והיחיד, המעלב שלנו,"},{"start":451.26,"end":453.26,"text":"קרייזי קריזנטמה,"},{"start":453.26,"end":455.26,"text":"והעציץ שלו, ג'רי גרניום."},{"start":455.26,"end":456.26,"text":"קבלו אותם!"},{"start":456.26,"end":515.55,"text":"אני כבר שלוש עוד מחכה פה,"},{"start":515.55,"end":517.55,"text":"התייבשתי לגמרי, הפחד לא עוצר."},{"start":517.55,"end":519.55,"text":"יאללה, מה קורה, בן אתה בדרך הביתה?"},{"start":519.55,"end":521.55,"text":"כן, אני מגיע. קיבלנו חופשה של 24."},{"start":521.55,"end":523.55,"text":"מצוין, גם אני בדרך הביתה."},{"start":523.55,"end":524.55,"text":"אתה מגיע הביתה?"},{"start":524.55,"end":525.55,"text":"כן, גמרתי את עבודה מוקדם היום."},{"start":525.55,"end":526.55,"text":"מצוין, מצוין, יופי."},{"start":526.55,"end":527.55,"text":"מה קורה?"},{"start":527.55,"end":529.55,"text":"אני אספר לך אחרי זה, אני פשוט נורא ממר להגיע הביתה."},{"start":529.55,"end":531.55,"text":"אוקיי, רק תגיע כי ארוחת צהריים, אה?"},{"start":531.55,"end":533.55,"text":"בסדר, נפגש לך, תשמרו לי מהגפים תפי."},{"start":533.55,"end":534.55,"text":"אין בעיה, להתראות, ביי."},{"start":534.55,"end":536.55,"text":"ביי, אבא, להתראות, ביי."},{"start":536.55,"end":545.39,"text":"סרטי אבקה להמציגים."},{"start":545.39,"end":548.41,"text":"הוא היה אבא שלו."},{"start":548.41,"end":550.4,"text":"היי, דאד. היי, סן."},{"start":550.4,"end":551.46,"text":"הוא היה הבן שלו."},{"start":551.46,"end":553.77,"text":"היי, סן. היי, דאד."},{"start":553.77,"end":555.83,"text":"הוא היה האורך דין שלהם."},{"start":555.83,"end":558.15,"text":"אובייקשן, סוסטיין."},{"start":558.15,"end":561.11,"text":"הם אהבו את זה."},{"start":561.11,"end":563.1,"text":"I love you. I love you too."},{"start":563.1,"end":565.33,"text":"אבל לפעמים גם רבו."},{"start":565.33,"end":567.33,"text":"I hate you. I hate you too."},{"start":567.33,"end":569.43,"text":"רק דבר אחד יכל להציל אותם."},{"start":569.43,"end":572.16,"text":"הקובה."},{"start":572.16,"end":574.89,"text":"שובו של הקובה שתיים."},{"start":574.89,"end":576.85,"text":"עכשיו, בקולנוע של ציון."},{"start":576.85,"end":578.85,"text":"בואו, בעמוניכם."},{"start":578.85,"end":582.89,"text":"בבקשה."},{"start":582.89,"end":584.46,"text":"מי זה?"},{"start":584.46,"end":585.38,"text":"זה גיל, רובי נמצא."},{"start":585.38,"end":587.49,"text":"אה, לא, רובי בדיוק יצא."},{"start":587.49,"end":591.37,"text":"מוזר, קבעתי אותו לכדורגל."},{"start":591.37,"end":592.52,"text":"הוא לא בבית."},{"start":592.52,"end":594.61,"text":"טוב, תודה."},{"start":594.61,"end":602.71,"text":"מי זה?"},{"start":602.71,"end":605.32,"text":"איזה אסף, רובי בבית?"},{"start":605.32,"end":607.96,"text":"אני לא שמה אדבר לאינטרקום."},{"start":607.96,"end":610.7,"text":"זה אסף, אסף, רובי בבית!"},{"start":610.7,"end":612.7,"text":"בואו, בואו, תעלה, תעלה."},{"start":612.7,"end":619.03,"text":"שיט."},{"start":619.03,"end":621.03,"text":"רובי בדיוק יצא עכשיו במדרגות, לא ראית אותו?"},{"start":621.03,"end":625.33,"text":"לא, לא ראיתי. טוב, תודה."},{"start":625.33,"end":627.57,"text":"חבל, חבל."},{"start":627.57,"end":628.79,"text":"יש לכם דואר."},{"start":628.79,"end":629.79,"text":"תשימי תחת לדלת."},{"start":629.79,"end":633.7,"text":"להתראות."},{"start":633.7,"end":638.35,"text":"רובי!"},{"start":638.35,"end":639.89,"text":"רובי!"},{"start":639.89,"end":642.91,"text":"חלס, אני יודע שאתה בבית, קבענו לכדורגל."},{"start":642.91,"end":644.41,"text":"רובי!"},{"start":644.41,"end":645.41,"text":"מה?"},{"start":645.41,"end":648.18,"text":"בואו, בואו למטה, בואו לסחק כדורגל, חלס."},{"start":648.18,"end":650.18,"text":"טוב, חכה שנייה, אני יורד."},{"start":650.18,"end":651.98,"text":"הלו, הלו, בואו."},{"start":651.98,"end":654.98,"text":"מה שלא יותר, נו, בואו לסחק קצת כדורגל."},{"start":654.98,"end":669.81,"text":"שלום, תל אביב?"},{"start":669.81,"end":670.81,"text":"תודה."},{"start":670.81,"end":687.3,"text":"תודה רבה."},{"start":687.3,"end":688.32,"text":"הלו, שוויה."},{"start":688.32,"end":689.32,"text":"הלו, קאקון."},{"start":689.32,"end":691.32,"text":"קאקון, קבלו אותו במיטב מסורת הרפ."},{"start":691.32,"end":692.32,"text":"הבאלו לכאן למועדון,"},{"start":692.32,"end":694.32,"text":"את הראפר הישראלי הראשון,"},{"start":694.32,"end":695.32,"text":"יליד השכונה."},{"start":695.32,"end":697.54,"text":"יש לו בעיה קטנה, הוא הילם,"},{"start":697.54,"end":698.54,"text":"אבל הוא משלנו."},{"start":698.54,"end":699.54,"text":"קבלו אותו."},{"start":699.54,"end":700.54,"text":"WAIT!"},{"start":700.54,"end":702.57,"text":"הראפר הישראלי."},{"start":702.57,"end":703.63,"text":"WAIT!"},{"start":703.63,"end":705.32,"text":"אייסטוהן."},{"start":705.32,"end":706.32,"text":"קבלו אותו."},{"start":706.32,"end":790.59,"text":"שוב אתם בתוכנית החשיפה,"},{"start":790.59,"end":791.52,"text":"וואלה,"},{"start":791.52,"end":792.58,"text":"עם אילנה מברן."},{"start":792.58,"end":794.82,"text":"ערב טוב."},{"start":794.82,"end":796.91,"text":"לפני 21 שנה,"},{"start":796.91,"end":799.0,"text":"הם היו צמד בלתי נפרד."},{"start":799.0,"end":800.0,"text":"הוא ספק בוב,"},{"start":800.0,"end":801.0,"text":"ספק בובה,"},{"start":801.0,"end":803.0,"text":"ממריונטה 