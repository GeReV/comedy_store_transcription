[{"start":29.6,"end":34.7,"text":"רבותיי, רבותיי, ברוכים הבאים, לקו ומסתור!"},{"start":34.7,"end":43.32,"text":"אז מרצי זה בישראלי, טורקי ונוצרי, נוסעים לטורקיה כולם ביחד במטוס של אילן."},{"start":43.32,"end":49.32,"text":"עכשיו הם עולים לשביים, כן, הלאה, הם עולים לשביים, תמיד נוסעים, נוסעים, נוסעים, פיטון נגמר הדרך..."},{"start":49.32,"end":52.31,"text":"מזלתו!"},{"start":52.31,"end":58.1,"text":"מזלתו!"},{"start":58.1,"end":62.1,"text":"אז הנוצרי המוסלמי והיהודים משקשקים מפרד במטוס, אתה היה סובר?"},{"start":62.1,"end":64.1,"text":"או, הנה, הנה המלצה, הנה מלצה."},{"start":67.63,"end":73.35,"text":"מזלת! מזלת! מזלת! מזלת! מזלת!"},{"start":73.35,"end":76.32,"text":"חבר'ה, אני יד חוזר, עושה את הסליחה, באמת."},{"start":76.32,"end":80.32,"text":"אז מה קורה? תבין, נוצר מצב של המוסלמי אין מצליח, תבין."},{"start":80.32,"end":82.32,"text":"רק רוזל... אווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו prepare!"},{"start":82.32,"end":86.21,"text":"אנחנו מקווים שתיזהר הפעם, מה? תיזהר עדיר ולאק."},{"start":86.21,"end":89.9,"text":"אז זה עבור, תודה. מגיע!"},{"start":89.9,"end":96.98,"text":"מזלתו! מזלתו!"},{"start":96.98,"end":101.37,"text":"זה בקיבולה, לגד עדד, בל אחי, כולל הפארסי"},{"start":101.37,"end":103.57,"text":"מקבלו, סליחה, אפשר לפנות?"},{"start":103.57,"end":105.13,"text":"אלן, אלן, אלן, אלן, אלן, בוא די"},{"start":105.13,"end":107.57,"text":"כן, של מי התיק פה מפריע במעבר?"},{"start":107.57,"end":109.25,"text":"איזה תיק? של מי התיק הזה?"},{"start":109.25,"end":111.77,"text":"אני באתי בלי תיק? לא, גם אני בלי תיק, זה לא שלנו"},{"start":111.77,"end":116.64,"text":"סליחה, של מי התיק הזה? סליחה?"},{"start":116.64,"end":121.16,"text":"של מי התיק הזה? של מי התיק הזה, סליחה?"},{"start":121.16,"end":123.13,"text":"אההה!"},{"start":123.13,"end":128.36,"text":"מזל טוב!"},{"start":128.36,"end":130.36,"text":"מזל טוב!"},{"start":130.36,"end":132.36,"text":"מזל טוב!"},{"start":132.36,"end":135.8,"text":"מזל טוב!"},{"start":135.8,"end":142.33,"text":"את יודעת, בחפץ חשוד"},{"start":142.33,"end":145.25,"text":"אסור לקחת!"},{"start":145.25,"end":147.25,"text":"וגם לא להתקרב!"},{"start":147.25,"end":158.58,"text":"ערב צחר הפזח ושוב"},{"start":158.58,"end":160.58,"text":"אנחנו בחלסטרה של זוזו"},{"start":160.58,"end":162.58,"text":"שנוסעת לה לחוץ לארץ"},{"start":162.58,"end":164.67,"text":"והפעם החלסטרה הגיעה"},{"start":164.67,"end":166.85,"text":"דווקא בטרמינל"},{"start":166.85,"end":168.85,"text":"באמא שלי"},{"start":168.85,"end":170.85,"text":"אתה מגיע לטרמינל"},{"start":170.85,"end":172.85,"text":"אתה לא יודע מה לעשות"},{"start":172.85,"end":174.85,"text":"70 אלף איש"},{"start":174.85,"end":176.85,"text":"חשבתי בחלקי באוכל"},{"start":176.85,"end":178.91,"text":"איך שאני מגיע לקראת הסוף של התור"},{"start":178.91,"end":181.0,"text":"מה מתגלה לי?"},{"start":181.0,"end":183.0,"text":"חוקר ביטחוני"},{"start":183.0,"end":185.0,"text":"שעומד ועושה פקק לכולם"},{"start":185.0,"end":187.0,"text":"עם עיגולדים וחליפה מכוערת"},{"start":187.0,"end":189.0,"text":"ועניבה עם מלא צבעים"},{"start":189.0,"end":191.0,"text":"ויש לו כזה אוזניה של בזק נכנסת לו באוזן"},{"start":191.0,"end":193.0,"text":"ואחרי קטע זה השירות"},{"start":193.0,"end":195.0,"text":"חושק שוקה"},{"start":195.0,"end":197.0,"text":"ביבא שלי חשבתי דה וול"},{"start":197.0,"end":199.0,"text":"מה זה הקיר הזה? אם היה חושך הייתי דופק עליו גרפיטי"},{"start":199.0,"end":201.0,"text":"ביבא שלי"},{"start":201.0,"end":202.96,"text":"הגיתי אליו עושה לי אהלן"},{"start":202.96,"end":204.96,"text":"אמרתי לו סהלן"},{"start":204.96,"end":206.96,"text":"אמר לי סמי אמרתי לו סוסו"},{"start":206.96,"end":208.96,"text":"ואז אמר לי שלום לך"},{"start":208.96,"end":210.96,"text":"מי עזר לך לארוז?"},{"start":210.96,"end":212.96,"text":"מי נתן לך את התיק?"},{"start":212.96,"end":214.96,"text":"מישהו עזר לך בעריזה?"},{"start":214.96,"end":216.96,"text":"אמרתי לו עבור עבור ביבא שלי חשבתי שאלות של יצחק שמועני"},{"start":216.96,"end":218.96,"text":"אמרתי לו התחלתי ולכן אסיים"},{"start":218.96,"end":220.96,"text":"אני התחלתי פה ואני אסיים במטוס"},{"start":220.96,"end":222.96,"text":"מה זה החלט הזה באמא שלי"},{"start":222.96,"end":223.96,"text":"אמרתי לו זוז"},{"start":223.96,"end":224.96,"text":"זה תחקיר"},{"start":224.96,"end":226.09,"text":"זוז"},{"start":226.09,"end":228.09,"text":"תפסתי את מקומו על ידי זה שדפקתי לרסיה קטנה"},{"start":228.09,"end":230.09,"text":"תפסתי את מקומו, לקחתי את הווקבוק"},{"start":230.09,"end":232.09,"text":"שמתי לי את האוזניה כמו שצריך"},{"start":232.09,"end":233.05,"text":"פול ווליונד"},{"start":233.05,"end":234.08,"text":"עופר לוית"},{"start":234.08,"end":236.08,"text":"עכשיו עופר לוי מנגן"},{"start":236.08,"end":238.07,"text":"אני נכנסתי את דיכאון"},{"start":238.07,"end":240.07,"text":"מהדיכאון התורי האנשים התור מתפזר"},{"start":240.07,"end":242.07,"text":"כולם מדוכאים נעימינו מסים"},{"start":242.07,"end":244.07,"text":"ואז הגיעו כל מיני טיפוסים באמא שלי"},{"start":244.07,"end":246.07,"text":"החלסטר התחילה להסתובב לי"},{"start":246.07,"end":248.07,"text":"בעלי בן אדם לפלפון כזה"},{"start":248.07,"end":253.07,"text":"עם טיק כזה קטן אמרתי לו מה זה? זה בדיקה ביטחונית זה לא טיול שנתי"},{"start":253.07,"end":255.07,"text":"חשבתי הביא שנטוויץ ולחמני על הטיול"},{"start":255.07,"end":257.07,"text":"שלחתי אותו אמרתי לו תבוא שעור הבא"},{"start":257.07,"end":261.13,"text":"פתאום אחריו בא איזה אחד יעני מחזיק מעצמו פטיש"},{"start":261.13,"end":263.38,"text":"עם כזה פתוח"},{"start":263.38,"end":266.62,"text":"גבר עושה לי דרבה לכתיגה עלי בתיק"},{"start":266.62,"end":297.8,"text":"אמרתי לו: \"שוווו\" אמר לי: \"דיר ולגתיג\" אמרתי לו: \"שוווו\" אמר לי: \"שקול מילים\" שקילתי אותו הוא יצא אוברווייט זאת אומרת ציפייה יותר מדי ציפייה ולכן כעונש שלחנו אותו בכלוף של הכלבים לחוץ לרציבת המטען דוג לי עליי האחרונה הייתה הכי אופתימית באמא שלי שוודית חמודה עם עיניים כחולות עם אף סליד עם חזון באמא שלי עושה לי: \"היי\" אמרתי לה: \"היי\" מי רגע?"},{"start":297.8,"end":320.53,"text":"מי עזר לך לערוז, מאמי? אמר לי: \"אף אחד\". ומישהו נטר לך משהו? אמר לי: \"לא\". אז אולי ניתן לך הסכימה. שבועיים בטורקיה, באמא שלי עשינו חיים משוגעים. מוסר אסכל, תמיד, תמיד, תמיד, כשאתה בגיע לתחקיר הביטחוני בשדה התעופה, זכור את הפתגם הידוע. אבא לאורזיך, אסכם לאורזו. ותחשבו על זה."},{"start":332.63,"end":336.29,"text":"וואלה קולטון הזאת, כמה יחייבת אלוהים יעזו לנו."},{"start":336.29,"end":338.22,"text":"שלום. -שלום, אה לאן?"},{"start":338.22,"end":340.41,"text":"וואלה הנה, יש לי, יש לי!"},{"start":340.41,"end":344.45,"text":"אתה יש לי, יש לי מהטלוויזיה, אה לה, איזה עולה, גדול!"},{"start":344.45,"end":346.05,"text":"הנה, הנה הבן שלי, אה?"},{"start":346.05,"end":347.85,"text":"הבן שלי קוראים לו רן?"},{"start":347.85,"end":351.35,"text":"לא, הבן שלי קוראים לו דן, הנה דן, אהלה. -כמה זה, כמה זה?"},{"start":351.35,"end":353.75,"text":"עשר שקל, בוא נעשה, גדול, ואתה פה?"},{"start":353.75,"end":356.61,"text":"בוא נעשה, סביבה, עברתי. -הה, מה אתה אומר?"},{"start":356.61,"end":360.81,"text":"בוא נעשה, גדול, בוא נעשה, אם אתה פה, מה אתה אומר? אולי תעשה לנו פה פרסומת?"},{"start":360.81,"end":362.97,"text":"מה? -כמה, כולת, לא מי יודע מה עכשיו."},{"start":362.97,"end":366.25,"text":"לא, אני לא עושה פרסומת. מה זה בכלל זה? על פי שקלים, כל פרסומת."},{"start":366.25,"end":371.53,"text":"על פי שקלים לך, איך יש פה מצלמה? טיק טק, בוא נעשה, בטלוויזיה אתה יותר דבל, נשמע לך?"},{"start":371.53,"end":374.65,"text":"בוא, אומך פרתך, תראה, תופש את המצלמה, תעשית שחק, תעשי קצת, יש גריש לי בנגן, אה?"},{"start":374.65,"end":377.65,"text":"אני לא, אני רק נשחק, אני לא, אני שחקה, אני לא..."},{"start":377.65,"end":379.65,"text":"אז תוחק לנו, מה אתה אומר, כמה יעלה, כמה?"},{"start":379.65,"end":382.65,"text":"על פשקלים זה עולה, אני גם לא עושה דברים כאלה, שכן, אני מנורם..."},{"start":382.65,"end":386.65,"text":"בסדר, נורם במהר, סחר, לא משנה, נתראות."},{"start":386.65,"end":389.77,"text":"אלא, כרבה כסף, תשמע אותי, דן, תשמע מה אנחנו עושים."},{"start":389.77,"end":395.96,"text":"אתה תופש את המצלמה, אתה מסתכל עליי, אתה הצלם, אני השחקן, נעשה בומבה של פרסומת, הולך?"},{"start":395.96,"end":398.18,"text":"אוקיי? -כן. -יופי."},{"start":401.23,"end":410.32,"text":"אלן, עכשיו תראו, אתה פרסומת הכי הטובה על המקולת של אברהם, הנה שלד שהכנתי, הסלוגן שלנו, המקולת של אברהם הכי הטוב."},{"start":410.32,"end":422.32,"text":"אין. דני, עכשיו בואו צלם קצת את המקולת, תלך טיפה אחורה, זהירות דני, לא ניפול שם, הנה פה, פה זה אגב של המלוכים, פה מה שאתה קונה, יש לנו מבצע, לא את זה, לא את זה, מה אתה, הנה פה, פה, כן?"},{"start":422.32,"end":428.32,"text":"יש לנו מבצע, כל אחד שאתה קונה אתה מקבל שתיים שאל וחידה, דני, דני לא את זה, צלם את המשיצי יפה, הנה אבא, כן."},{"start":431.32,"end":440.29,"text":"אחורה, דני שים מוזיקה אגבה, שייצא טובה, דני תשאיר קצת משהו, תן לנו, דני לא לשיר, לשים את המוזיקה, 1, 2, 1, 2, דני ו..."},{"start":440.29,"end":444.48,"text":"המקול שלה רביו!"},{"start":466.37,"end":471.56,"text":"שייצא טובה, אה?"},{"start":471.56,"end":477.59,"text":"המקול שלה רביו פתוח 24 שעות ביממה, משבע בבוקר עד שבע בערב. איך יצא? טוב, אה?"},{"start":477.59,"end":494.13,"text":"יש לי משחק חדש, משחק ההד!"},{"start":494.13,"end":495.13,"text":"גדול!"},{"start":495.13,"end":497.13,"text":"לא! לא! לא!"},{"start":497.13,"end":499.29,"text":"יש לי זבלם, יש לי, יש לי זבלם."},{"start":499.29,"end":501.26,"text":"אתמול דרכתי על ג'וק."},{"start":501.26,"end":503.63,"text":"האם הג'וק מסכד?"},{"start":503.63,"end":505.99,"text":"כן! כן! כן! כן!"},{"start":505.99,"end":511.26,"text":"יש לי יש לי גל, יש לי יש לי."},{"start":511.26,"end":513.26,"text":"אתמול גם אני דרכתי על ג'וק."},{"start":513.26,"end":515.24,"text":"האם שיחק לו מזל, לא?"},{"start":515.24,"end":517.45,"text":"לא! לא! לא!"},{"start":517.45,"end":521.74,"text":"לא! לא!"},{"start":521.74,"end":523.83,"text":"לא! לא! לא!"},{"start":523.83,"end":525.83,"text":"אתמול גם אני דרכתי על ג'וק."},{"start":525.83,"end":527.8,"text":"מה קרה לו באמת?"},{"start":527.8,"end":529.83,"text":"מת!"},{"start":529.83,"end":534.64,"text":"מת!"},{"start":534.64,"end":536.83,"text":"יש לי, יש לי, יש לי."},{"start":536.83,"end":538.86,"text":"אתמול גם אני הרגתי ג'וק."},{"start":538.86,"end":541.31,"text":"איך הרגתי אותו?"},{"start":541.31,"end":543.92,"text":"אני פליט! פליט!"},{"start":543.92,"end":548.09,"text":"פליט!"},{"start":548.09,"end":552.74,"text":"אני פליט!"},{"start":552.74,"end":554.96,"text":"ונעבור לידיעת ספורט."},{"start":554.96,"end":556.96,"text":"במשחק הכדורגל שנערך בין ביתר אחוזם"},{"start":556.96,"end":558.96,"text":"למכבי ביני אייש,"},{"start":558.96,"end":560.96,"text":"זכתה הפועל כפר חסידים."},{"start":560.96,"end":563.22,"text":"וזאת לאחר שהחלוץ של לקוח מסגבעם,"},{"start":563.22,"end":568.22,"text":"נקע את אוזנו והוחלפה על ידיי תרנגולת ממושב בית חנניה."},{"start":568.22,"end":571.76,"text":"במסיבת הניצחון שנערכה לכבודם במושב מלילות,"},{"start":571.76,"end":574.76,"text":"נכחו גם תושבי שכונת כפר אברהם,"},{"start":574.76,"end":577.76,"text":"וכן כמה נכבדים מכפר מלכישוע."},{"start":577.76,"end":580.59,"text":"ומעניין לעניין באותו עניין,"},{"start":580.59,"end":584.0,"text":"הבועט מבוסטון הגיע לאזור המרכז."},{"start":584.0,"end":588.25,"text":"כתבתנו ג'ודי אהרונוב ליסקרפין סממא סוכניק,"},{"start":588.25,"end":591.33,"text":"יצאה לשטח והרי כתבתה:"},{"start":591.33,"end":602.06,"text":"ערב טוב."},{"start":602.06,"end":606.43,"text":"מכה חדשה נוחתת על תל אביב, הבועט מבוסטון."},{"start":606.43,"end":611.56,"text":"לא, לא מדובר בחינוי לאדם שהפך לחוכב בשמי הכדורגל המקומי."},{"start":611.56,"end":615.69,"text":"מדובר כאן באדם שהפך לתופעה טבע חסרה תקדימים."},{"start":615.69,"end":619.1,"text":"הפסיכולוגים הגדירו אותו חולי נפש."},{"start":619.1,"end":621.1,"text":"אדם מסוכן לציבור."},{"start":621.1,"end":623.06,"text":"אדם הלוקה בחדור רומניה."},{"start":623.06,"end":627.06,"text":"כדור רומניה דך הפכולני לבעוט בכל חדור."},{"start":627.06,"end":632.28,"text":"לקחנו את המצלמה המשוטטת ויצאנו לשטח לבדוק הקצע הקטע."},{"start":632.28,"end":636.1,"text":"כאן רונן חרזי, וושינגטון."},{"start":636.1,"end":647.28,"text":"פסור, פסור תקדור."},{"start":647.28,"end":651.67,"text":"פסור תקדור."},{"start":651.67,"end":652.67,"text":"אנחנו באמת למשחק."},{"start":652.67,"end":655.67,"text":"פסור תקדור, רונן, אין משחק."},{"start":655.67,"end":657.98,"text":"פסור תקדור."},{"start":657.98,"end":659.98,"text":"פסור תקדור."},{"start":659.98,"end":661.98,"text":"מה הוא בא שאני מחפשות עם פסור תקדור?"},{"start":661.98,"end":662.98,"text":"אין משחק."},{"start":662.98,"end":665.98,"text":"אין משחק."},{"start":665.98,"end":667.1,"text":"אין משחק."},{"start":667.1,"end":670.35,"text":"כבר בבית הספר הוא היה ילד מאוד מאוד בעייתי."},{"start":670.35,"end":672.51,"text":"הוא תמיד היה בועט במוסכמות."},{"start":672.51,"end":674.51,"text":"אפשר לומר שהוא אפילו בעט בבית הספר כולו."},{"start":674.51,"end":676.99,"text":"באיזה בית ספר מדובר?"},{"start":676.99,"end":678.21,"text":"כדורי."},{"start":678.21,"end":684.48,"text":"פסור, פסור, פסור."},{"start":684.48,"end":685.9,"text":"פסור את המשחק."},{"start":685.9,"end":686.9,"text":"פסור את הכדור."},{"start":686.9,"end":687.9,"text":"מי אחי?"},{"start":687.9,"end":689.9,"text":"לא אחי, פסור את הכדור."},{"start":689.9,"end":691.9,"text":"לא, מה את שחק?"},{"start":691.9,"end":693.9,"text":"אין משחק."},{"start":693.9,"end":695.9,"text":"אין משחק."},{"start":695.9,"end":697.93,"text":"נשאל, למה להיות מעניין?"},{"start":697.93,"end":698.93,"text":"למה אתה מעניין?"},{"start":698.93,"end":699.93,"text":"אה, פסחה!"},{"start":699.93,"end":701.93,"text":"השחקנים מפרדים לבוא לאימונים."},{"start":701.93,"end":704.93,"text":"נדה ונפלד ודורון ג'מצ'י לא יודעים מה לעשות"},{"start":704.93,"end":706.93,"text":"ומוליק הסורין מגמגם."},{"start":706.93,"end":711.02,"text":"ואמנו ניאסקי כבר נשכח את כל החליפות בבית מרוב פחד."},{"start":711.02,"end":713.02,"text":"אתה חושב שהוא משתל של הפועל תל אביב?"},{"start":713.02,"end":714.02,"text":"יכול להיות שכן."},{"start":714.02,"end":717.02,"text":"תשמע, שאמונה עמסה לזרק, ציר את הקפטן ועבר לפועל חיפה"},{"start":717.02,"end":718.02,"text":"ומיקי ברכוביץ' דיבר איתי."},{"start":718.02,"end":721.02,"text":"היא אמרה לי מרוב פחד הוא כבחתם הפועט תל אביב, הוא לא יודע מה לעשות."},{"start":721.02,"end":723.02,"text":"הפועט בכל פינה עורב לנו פה."},{"start":723.02,"end":727.02,"text":"וגם אני עם הקדוק ואני מנצה להחביא אותו כמה שיותר, הוא יכול לבוא מכל פינה."},{"start":727.02,"end":730.01,"text":"זו, זו, זו!"},{"start":730.01,"end":732.17,"text":"אין משחק, זו, בסורת הקדור, בסורת הקדור!"},{"start":732.17,"end":733.17,"text":"בסורת הקדור!"},{"start":733.17,"end":734.17,"text":"אין משחק!"},{"start":734.17,"end":735.17,"text":"אין משחק!"},{"start":735.17,"end":736.17,"text":"סורת!"},{"start":736.17,"end":737.2,"text":"סורת!"},{"start":737.2,"end":738.2,"text":"סורת!"},{"start":738.2,"end":739.2,"text":"אין משחק!"},{"start":739.2,"end":742.69,"text":"סורת!"},{"start":742.69,"end":743.69,"text":"רגע, שנייה!"},{"start":743.69,"end":746.03,"text":"מה השנייה אומר לך מסורת!"},{"start":746.03,"end":747.03,"text":"משחקים רגע, נו!"},{"start":747.03,"end":748.03,"text":"נו!"},{"start":748.03,"end":749.03,"text":"סורת הכדור!"},{"start":749.03,"end":750.03,"text":"משחקים רגע!"},{"start":750.03,"end":751.03,"text":"מה?"},{"start":751.03,"end":752.03,"text":"אני אומר לך מסורת, תבסורת!"},{"start":752.03,"end":753.03,"text":"זו, זה את משחק!"},{"start":753.03,"end":758.47,"text":"כדורי העיר הגדולה ממשיכים לטעום את נחת רגלו של אותו בעתן כפייתי."},{"start":758.47,"end":764.44,"text":"אולם פרה מידך כיסה התושבים ממשיכים לזהום נוכח חוזלת ידם של המשטרה."},{"start":764.44,"end":768.01,"text":"המשטרה עומדת חסרת עונים, אנחנו לא יודעים מה לעשות."},{"start":768.01,"end":771.01,"text":"תראה, יש לי למשל אקדח פה, אבל זה פרש, זה פרש!"},{"start":771.01,"end":773.01,"text":"אין לי אף כדור באקדח!"},{"start":773.01,"end":774.01,"text":"למה?"},{"start":774.01,"end":776.01,"text":"את כל הכדורים המשוגע הזה."},{"start":776.01,"end":778.01,"text":"זה עוד הוכחה שלמשטרה אין בצים."},{"start":778.01,"end":780.01,"text":"עכשיו גם אין לה כדורים."},{"start":780.01,"end":783.25,"text":"אתה בעצמך שוטר."},{"start":783.25,"end":786.25,"text":"אתה יודע, יש לך תביעת עין מצוינת, אמרו לך את זה פעם."},{"start":786.25,"end":787.44,"text":"שונה רבה, אני כיפה."},{"start":787.44,"end":788.44,"text":"רבה נשאלת."},{"start":788.44,"end":789.63,"text":"פסט."},{"start":789.63,"end":791.65,"text":"פסור את הכדור."},{"start":791.65,"end":794.8,"text":"פסור את הכדור, אני אומר."},{"start":794.8,"end":798.76,"text":"פסור את הכדור, הבן אדם מדבר איתך."},{"start":798.76,"end":800.76,"text":"פסור את הכדור, זוז, אין משחק."},{"start":800.76,"end":802.39,"text":"אין משחק."},{"start":802.39,"end":804.39,"text":"פתאום הוא נכנס, השוואץ החי הזה."},{"start":804.39,"end":811.39,"text":"תפס לי את הכדור צמר, את כל עגול עגולה, הביא לי בומבה כזה מתשוס עם שמירי ואת זה מחוץ מהסלון."},{"start":811.39,"end":813.35,"text":"ואני נשארתי ככה עם הצמר ביד."},{"start":813.35,"end":819.35,"text":"עוד לא הספפתי להגיד, ג'ק רובנסון נחל שווארמה ופיטה עם דחינה ואמבו בפרינל של סיון, והוא נלם."},{"start":819.35,"end":820.92,"text":"נשארתי עם זה ביד."},{"start":820.92,"end":825.36,"text":"דבר צריכה, ישניה, שמילק, תזיז את כולם, הם מציצים לי מלמטה."},{"start":825.36,"end":827.16,"text":"סוד."},{"start":827.16,"end":829.21,"text":"סוציק, שם את הכדור."},{"start":829.21,"end":830.62,"text":"סוד."},{"start":830.62,"end":832.68,"text":"דרה, אני אומר לך, סוד."},{"start":832.68,"end":833.68,"text":"סוד."},{"start":833.68,"end":835.13,"text":"סוד."},{"start":835.13,"end":837.18,"text":"אין משחק."},{"start":837.18,"end":840.18,"text":"אין משחק, אני אומר לך, אין משחק."},{"start":840.18,"end":843.4,"text":"תל אביב, עיר ללא כדורים."},{"start":843.4,"end":848.37,"text":"יש ונדמה, כי גם השמיים מתקדרים לעיתם מעל הכרח הסוען."},{"start":848.37,"end":852.29,"text":"אך לעיתים, המצוקה איהם כל המצאה."},{"start":852.29,"end":856.54,"text":"תושבים לא מעטים ניסו למצוא תחליפים זמניים לחדוריהם,"},{"start":856.54,"end":859.63,"text":"על מנת להקל על חייהם הקשים."},{"start":859.63,"end":863.04,"text":"לדוגמה, כדורי טניס בצורת קוביה."},{"start":863.04,"end":870.3,"text":"הוא מטורף, הוא לא נורמלי, המשוגע זה גזל לנו את כל הפרנסה,"},{"start":870.3,"end":872.3,"text":"אבל מה? מצאנו פתרון."},{"start":872.3,"end":877.36,"text":"הוא בועד בכדורים, אנחנו המצאנו משולשי פלאפל, אתה רואה?"},{"start":877.36,"end":885.45,"text":"מעכשיו אין כל חשש, יש פלאפל משולש, משולש יש לי כעת, המשוגע כבר לא בועד."},{"start":885.45,"end":890.85,"text":"וואו וואו וואו, צורת הכדור, צורת הכדור."},{"start":890.85,"end":892.87,"text":"אתה גם רוצה לשחק?"},{"start":892.87,"end":894.85,"text":"צורת הכדור, אין משחק."},{"start":894.85,"end":910.72,"text":"מה?"},{"start":910.72,"end":913.21,"text":"והנה חלפה לתהילת עולם,"},{"start":913.21,"end":918.31,"text":"ולנו לא נותר אלא לכבוד שאותו בועט מבוסטון למד את הלקח המחאיב,"},{"start":918.31,"end":922.31,"text":"ונגמל סופית מהרגלי הרגל המגונים שלו."},{"start":922.31,"end":925.33,"text":"לא יכול!"},{"start":925.33,"end":927.33,"text":"תפסיק, תפסיק לפקוד, אף אחד לא ירחם עליך כאן."},{"start":927.33,"end":930.55,"text":"הגיע זמן תרופות, אתה מעדיף שאני ארסק לך?"},{"start":930.55,"end":934.49,"text":"מה ארסק?"},{"start":934.49,"end":937.16,"text":"סרט הכדור!"},{"start":937.16,"end":939.54,"text":"סרט הכדור!"},{"start":939.54,"end":948.79,"text":"אין משחק! אין משחק!"},{"start":948.79,"end":958.39,"text":"כאן ג'ודי לא צהרונוב, קרפינס, צממת, תנחום כהל, מינץ, ילן שטקליס, עתר בנין, זי ארמלי, וושינטון."},{"start":958.39,"end":963.61,"text":"גול! גול! גול! גול! גול! גול!"},{"start":963.61,"end":972.99,"text":"אין החייבה!"},{"start":972.99,"end":982.88,"text":"שיהבוי! אין חייבה! אין חייבה! אין חייבה!"},{"start":982.88,"end":985.18,"text":"חבר'ה, יש לי! תקשיבו!"},{"start":985.18,"end":987.29,"text":"כל שנה אני הולך לצעדה!"},{"start":987.29,"end":989.58,"text":"האם כדאי להמשיך לצעוד?"},{"start":989.58,"end":993.75,"text":"עוד! עוד! עוד! עוד!"},{"start":993.75,"end":997.2,"text":"יש לי! יש לי!"},{"start":997.2,"end":1000.9,"text":"כל הלילה רקעתי בלי הפסקה!"},{"start":1000.9,"end":1002.97,"text":"האמשיך את ריקודיי?"},{"start":1002.97,"end":1009.86,"text":"די! די! די! די! די!"},{"start":1009.86,"end":1010.86,"text":"סליגה! סליגה!"},{"start":1010.86,"end":1013.86,"text":"כל הלילה השארתי את הברז פתוח!"},{"start":1013.86,"end":1016.14,"text":"מה את אומרו על הביזבוז?"},{"start":1016.14,"end":1021.79,"text":"בוז! בוז! בוז! בוז!"},{"start":1021.79,"end":1022.79,"text":"יש לי! יש לי! יש לי!"},{"start":1022.79,"end":1026.01,"text":"כל היום עבדתי קשה! קשה!"},{"start":1026.01,"end":1028.7,"text":"מה כדאי לי לעשות?"},{"start":1028.7,"end":1033.65,"text":"לנוח! לנוח! לנוח! לנוח!"},{"start":1033.65,"end":1034.56,"text":"אני אהיה!"},{"start":1034.56,"end":1035.61,"text":"אני רוצה לנוח!"},{"start":1035.61,"end":1043.17,"text":"אלן!"},{"start":1043.17,"end":1044.17,"text":"שלום! איזה הפתעה!"},{"start":1044.17,"end":1045.17,"text":"מה שלומך?"},{"start":1045.17,"end":1047.17,"text":"תודה לאל! תודה לאל!"},{"start":1047.17,"end":1048.17,"text":"איך החיים ככה?"},{"start":1048.17,"end":1050.17,"text":"בלי נדר! חומרים! זורם! זורם!"},{"start":1050.17,"end":1051.17,"text":"תגיד, מה שלא משתך?"},{"start":1051.17,"end":1053.17,"text":"משתית! תדע מה!"},{"start":1053.17,"end":1054.17,"text":"טאצ' ווד!"},{"start":1054.17,"end":1055.17,"text":"כל בסדר!"},{"start":1055.17,"end":1057.17,"text":"יופי, והילדים! הקטן כבר בבית ספר!"},{"start":1057.17,"end":1059.17,"text":"כן! הקטן! תעמי לי טפו-טפו-טפו!"},{"start":1059.17,"end":1060.17,"text":"מיום ליום נהיה גבר!"},{"start":1060.17,"end":1062.17,"text":"לא יכול שהגדולה מתגייסת עוד מעט!"},{"start":1062.17,"end":1067.17,"text":"חמסה חמסה שום בצהל, שקל בנהל שלא נדע, פשוט נהיית פתישה."},{"start":1067.17,"end":1068.17,"text":"ובעבודה הולך הכל..."},{"start":1068.17,"end":1072.17,"text":"עבודה הכל עוד אין חתול שחור ביני לבין הזה, הכל בסדר יחובריו."},{"start":1072.17,"end":1074.17,"text":"נכנסתם מכונה חדשה למפעל, זה..."},{"start":1074.17,"end":1080.17,"text":"אין מכונה חדשה, שמנו עליה שום מכל הצדדים, נהל של תינוק מאחורי, שלא יהיה לנו בעיות יחובריו, שלא יהיה..."},{"start":1080.17,"end":1081.17,"text":"יופי יופי, מצוייה, הכל בסדר."},{"start":1081.17,"end":1083.17,"text":"אתה, אתה, מה שלמה הורים, האימא שלך..."},{"start":1083.17,"end":1086.01,"text":"תפו תפו תפו, הכל בסדר או תפו תפו שלא נדע."},{"start":1086.01,"end":1087.05,"text":"אתה אומר זה האבא שלך כתוב?"},{"start":1087.05,"end":1091.37,"text":"האבא שלוש פעמים, אחד, שתיים, שלוש, הכל בסדר, שלא נדע בצרות."},{"start":1091.37,"end":1092.49,"text":"תביא, קיבלת את צב מילואים?"},{"start":1092.49,"end":1097.09,"text":"צב מילואים, מה פתאום? משתגעת, סנדלים, אחד, שתיים, משתגעת, מה פתאום צריך מילואים?"},{"start":1097.09,"end":1101.57,"text":"אבא, השכנים, השכנים, כיסא, כיסא, כפיצה, כפיצה, כיסא, כפיצה, כפיצה, הכל בסדר, בעיתך."},{"start":1101.57,"end":1103.25,"text":"שכנים, אני צריך בעיות מבעד הבית."},{"start":1103.25,"end":1105.25,"text":"אמרת שאתה קנית לשתך אותו חדש."},{"start":1105.25,"end":1107.25,"text":"אני קניתי לשתי, מה פתאום קניתי לשתך?"},{"start":1107.25,"end":1109.25,"text":"שתיים, שלוש, ואחת, שתיים, שלוש, לא קונה אותו."},{"start":1109.25,"end":1113.25,"text":"אני מסוד מה שיש לי, לא צריך לפתוח, העיניים, לא צריך לפתוח עיניים, לא צריך."},{"start":1113.25,"end":1114.25,"text":"העניין של מה סכנסה."},{"start":1114.25,"end":1120.25,"text":"מה סכנסה, עיגולים, עיגולים, עיגולים, עיגולים, שלא נדע, הכל בסדר."},{"start":1120.25,"end":1121.25,"text":"אההה."},{"start":1121.25,"end":1122.5,"text":"אה, אלן."},{"start":1122.5,"end":1123.5,"text":"אלן, מה שלומך?"},{"start":1123.5,"end":1124.5,"text":"בסדר, הכל בסדר."},{"start":1124.5,"end":1125.57,"text":"בסדר, עושים, נהנים."},{"start":1125.57,"end":1126.59,"text":"אני פה, אם תרצה משהו."},{"start":1126.59,"end":1127.59,"text":"על הכייפה, ביי."},{"start":1127.59,"end":1129.74,"text":"מה זאת אומרת, הכל בסדר, מה?"},{"start":1129.74,"end":1130.74,"text":"מה, הכל בסדר?"},{"start":1130.74,"end":1131.74,"text":"מה, הכל בסדר?"},{"start":1131.74,"end":1132.74,"text":"אין, אה, משהו."},{"start":1132.74,"end":1135.74,"text":"אה, לא, לא, לא, לא, אני לא מאמין באמונות תפלות."},{"start":1135.74,"end":1137.74,"text":"אתה יודע, אומרים שזה מביא מזל רע."},{"start":1137.74,"end":1148.97,"text":"קצה חרב זך ושוב החלסטרה של ג'וזו,"},{"start":1148.97,"end":1150.97,"text":"והפעם חזרתי מחוס לארץ,"},{"start":1150.97,"end":1154.97,"text":"באבא שלי, אחרי שהדפקתי את הקזינו כמו שצריך,"},{"start":1154.97,"end":1156.97,"text":"את האם מהבלק ג'ק שבועיים,"},{"start":1156.97,"end":1157.97,"text":"היא לא ראתה, רק בלק."},{"start":1157.97,"end":1159.97,"text":"החלטתי לחזור לארץ,"},{"start":1159.97,"end":1161.97,"text":"והפעם מצוקה,"},{"start":1161.97,"end":1163.06,"text":"באמא שלי,"},{"start":1163.06,"end":1165.06,"text":"כולם, איך שנפתחות הדלתות של המטוס?"},{"start":1165.06,"end":1166.06,"text":"רצים!"},{"start":1166.06,"end":1167.06,"text":"כאילו, מה קרה?"},{"start":1167.06,"end":1168.06,"text":"רצים בהיסטריה,"},{"start":1168.06,"end":1169.06,"text":"ולאן מגיעים?"},{"start":1169.06,"end":1171.06,"text":"לקרוסלה של המזוודות."},{"start":1171.06,"end":1173.06,"text":"באמא שלי, שעה מסתובב בקרוסלה,"},{"start":1173.06,"end":1174.06,"text":"ולא באה המזוודה."},{"start":1174.06,"end":1175.06,"text":"חשבתי עוד מעט,"},{"start":1175.06,"end":1176.06,"text":"ישימו את השיר."},{"start":1176.06,"end":1178.06,"text":"לא, לא, לא, לא, לא,"},{"start":1178.06,"end":1179.06,"text":"לא, לא, לא,"},{"start":1179.06,"end":1180.06,"text":"של הלפלפים."},{"start":1180.06,"end":1181.06,"text":"אחרי שהתאוששתי,"},{"start":1181.06,"end":1182.06,"text":"לקחתי את המזוודה,"},{"start":1182.06,"end":1183.06,"text":"שמתי אותה על עגלה,"},{"start":1183.06,"end":1185.06,"text":"התחילה תכונה בקהל."},{"start":1185.06,"end":1188.15,"text":"כל הלפלפים המתלפלפים"},{"start":1188.15,"end":1189.15,"text":"התחילו לעשות פרצופים,"},{"start":1189.15,"end":1190.15,"text":"يعني אין לי כלום,"},{"start":1190.15,"end":1192.15,"text":"מלח מים, מלח מים, מלח מים,"},{"start":1192.15,"end":1194.25,"text":"והולכים למסלול הירוק."},{"start":1194.25,"end":1195.25,"text":"איזה פקק תנועה!"},{"start":1195.25,"end":1197.25,"text":"שבע מאות יש במסלול הירוק!"},{"start":1197.25,"end":1198.25,"text":"למה?"},{"start":1198.25,"end":1200.25,"text":"אני הלכתי ישר למסלול האדום."},{"start":1200.25,"end":1202.25,"text":"אין אף אחד יש אנשים יחכים לך,"},{"start":1202.25,"end":1204.25,"text":"יחס אישי, צבע דמדם,"},{"start":1204.25,"end":1206.25,"text":"סבבי, בובי, בובי."},{"start":1206.25,"end":1208.25,"text":"אלי שבע בלחץ אני בעשו לי כה,"},{"start":1208.25,"end":1210.25,"text":"אהלן ערב צח."},{"start":1210.25,"end":1212.25,"text":"שלום, כל אחד פותחים לך תתיק,"},{"start":1212.25,"end":1214.25,"text":"ואני אלי מלפחד."},{"start":1214.25,"end":1216.25,"text":"זה לא שגניבתי, אלי מלפחד."},{"start":1216.25,"end":1217.25,"text":"הכל הביתי מהדיוטי פרי."},{"start":1217.25,"end":1219.25,"text":"אמרו, אם אתה לוקח דברים מהמטוש,"},{"start":1219.25,"end":1221.25,"text":"זה דיוטי פרי."},{"start":1221.25,"end":1223.25,"text":"שמחות לי דודה מדלן, מהמטוש."},{"start":1223.25,"end":1225.25,"text":"אוזניות ווקמן לילדים, מהמטוש."},{"start":1225.25,"end":1227.25,"text":"טלוויזיות קטנות עכשיו הכניסו,"},{"start":1227.25,"end":1229.25,"text":"הביתי כמה שיהיה לילדים טלוויזיות."},{"start":1229.25,"end":1231.25,"text":"מתנות, הכל מהמטוש הביתי."},{"start":1231.25,"end":1233.25,"text":"אפילו יש לי דוד שלי,"},{"start":1233.25,"end":1235.25,"text":"ויש לו אסתמה, הביתי לו את הבלון חמצן,"},{"start":1235.25,"end":1237.25,"text":"שיהיה מהמטוש, ואללה."},{"start":1237.25,"end":1239.25,"text":"מתנות שמחה וסזון."},{"start":1239.25,"end":1240.31,"text":"מוסר אסקל."},{"start":1240.31,"end":1242.31,"text":"תמיד שאתה עובר, תעבור במסלול האדום,"},{"start":1242.31,"end":1244.31,"text":"תקרוץ למעיניים שלי כחולות,"},{"start":1244.31,"end":1246.31,"text":"ותחשבו על זה."},{"start":1246.31,"end":1253.45,"text":"מה זה קשור?"},{"start":1253.45,"end":1263.71,"text":"שרה, הם טובים אדוני, בבקשה על חשבון הבית."},{"start":1263.71,"end":1264.71,"text":"שלום לך, תודה."},{"start":1264.71,"end":1268.11,"text":"מה יש? לא בסדר, אתה לא אוהב את זה אדוני?"},{"start":1268.11,"end":1271.23,"text":"לא לא לא, זה טיון."},{"start":1271.23,"end":1273.32,"text":"נהדר, תודה, נהדר."},{"start":1273.32,"end":1279.33,"text":"מה קרה? מה קרה? מה אתה משתכל?"},{"start":1279.33,"end":1281.33,"text":"מה לא ראית בן אדם כנח תף?"},{"start":1281.33,"end":1282.33,"text":"מה זה הפרצופים האלה?"},{"start":1282.33,"end":1285.29,"text":"לא נהל, לך הלך שבמקום אחר. באמת, איזה אנשים."},{"start":1285.29,"end":1286.86,"text":"הלן."},{"start":1286.86,"end":1287.86,"text":"הלן, מה העניינים?"},{"start":1287.86,"end":1288.86,"text":"חרה."},{"start":1288.86,"end":1289.99,"text":"איך אתה מרגיש?"},{"start":1289.99,"end":1292.99,"text":"הלפנים, כואב לי הראש, מרגיש ממש לא טוב."},{"start":1292.99,"end":1293.99,"text":"מה אתה אומר, תל משהו."},{"start":1293.99,"end":1294.99,"text":"תודה."},{"start":1294.99,"end":1297.27,"text":"לא טעים, אמיץ הזה."},{"start":1297.27,"end":1298.27,"text":"מה אתה אומר?"},{"start":1298.27,"end":1299.27,"text":"ממש לא טעים."},{"start":1299.27,"end":1301.27,"text":"מגיל, גול נפש, אני לא נהנה ממנו."},{"start":1301.27,"end":1304.87,"text":"דווקא מאוד טעים זה."},{"start":1304.87,"end":1306.35,"text":"נו, אז מה שלומך?"},{"start":1306.35,"end":1308.93,"text":"סבבה, נהדר. פיקסי."},{"start":1308.93,"end":1328.49,"text":"פור שעמדה על הרציף."},{"start":1328.49,"end":1329.55,"text":"נו."},{"start":1329.55,"end":1333.55,"text":"טיפ טיפ טיפ טיפ טיפ."},{"start":1333.55,"end":1341.3,"text":"מה אמרה הפרה לילדים שעליו טעמו?"},{"start":1341.3,"end":1352.88,"text":"מה אמר הברווז שבמים נגע?"},{"start":1352.88,"end":1358.49,"text":"גאה גאה גאה גאה גאה גאה."},{"start":1358.49,"end":1362.86,"text":"יש לי יש לי יש לי יש לי."},{"start":1362.86,"end":1368.26,"text":"מה אמר התרנגול הודו כששאלו אותו מתי פורים?"},{"start":1369.26,"end":1372.42,"text":"עקוררר! עקוררר! עקוררר!"},{"start":1372.42,"end":1376.21,"text":"הוא בכלל לא אומר מתי, הוא גוזר!"},{"start":1376.21,"end":1379.52,"text":"לא, לא מבינים."}]