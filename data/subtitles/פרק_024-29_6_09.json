[{"start":33.86,"end":78.57,"text":"הוא מת בניתוח, הוא מת הלבט"},{"start":78.57,"end":80.86,"text":"כן, מה עניין, שוש?"},{"start":80.86,"end":86.06,"text":"דוקטור, נמצא כאן זה שעשית לו את הניתוח במערכת העצבים לפני שבוע, עצבני, והוא רוצה להיכנס"},{"start":86.06,"end":89.02,"text":"לא, לא, תקשיבי, אל תכניס אותו בשום פנים, שישר בחוץ, וואה"},{"start":89.02,"end":91.58,"text":"היופה, שלום לך, אני..."},{"start":91.58,"end":92.3,"text":"שלום?"},{"start":92.3,"end":93.82,"text":"בגלל לא לשוש, למה להזזל, אתה לא נכנס?"},{"start":93.82,"end":96.54,"text":"דוקטור, תראה מה אתה עשית לי, דוקטור"},{"start":96.54,"end":97.28,"text":"מה העניין?"},{"start":97.28,"end":100.49,"text":"אני חושב שלא חיברת לי נכון את מערכת העצבים, דוקטור"},{"start":100.49,"end":102.65,"text":"לסמח מה אתה קובע כזאת מן קביעה?"},{"start":102.65,"end":105.09,"text":"מה זאת אומרת לסמח מה אני קובע מן קזאת קביעה?"},{"start":105.09,"end":107.25,"text":"תסתכל עליי, אני מדבר מהעיניים"},{"start":107.25,"end":109.97,"text":"אני שומע מהפה, אני רואה מהאוזניים"},{"start":109.97,"end":111.41,"text":"ככה אני קובע כזאת קביעה"},{"start":111.41,"end":113.81,"text":"רגע שנייה, כמה יש כאן? דבר עוד קדימה, תסתכל"},{"start":113.81,"end":114.61,"text":"שתיים"},{"start":114.61,"end":118.37,"text":"נו יפה, כל עוד אתה רואה, שומע ומבחין, אין לי שום בעיה, ניתוח הצליח"},{"start":118.37,"end":120.37,"text":"מה זאת אומרת, הניתוח הצליח?"},{"start":120.37,"end":122.29,"text":"תסתכל דוקטור, אני שקשוקה"},{"start":122.29,"end":124.65,"text":"אתה לא תיכלל אצלי במשרד צליח"},{"start":124.65,"end":126.29,"text":"אני דורש פיצועים דוקטור"},{"start":126.29,"end":127.29,"text":"אתה תקום ותצא למשרד"},{"start":127.29,"end":129.65,"text":"אני דורש פיצועים, אני לא יוצא לחוצה דוקטור"},{"start":129.65,"end":131.53,"text":"אני לא שומע, לא רוצה להקשיב לך יותר"},{"start":131.53,"end":133.89,"text":"לא שומע, לא שומע, לא שומע, לא שומע"},{"start":133.89,"end":136.37,"text":"תצא לחוצה ותעוף מהמשרד"},{"start":136.37,"end":142.23,"text":"אך, אך, אך, אך, אך, דווקא על 