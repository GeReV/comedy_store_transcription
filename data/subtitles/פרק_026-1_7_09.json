ת הכותרת"},{"start":330.36,"end":332.36,"text":"לא חשוב הגיל העיקר התרגיל"},{"start":332.36,"end":334.7,"text":"בתגובה נפתחה אתמול בתל אביב"},{"start":334.7,"end":336.7,"text":"הלפלפי ידה הראשונה"},{"start":336.7,"end":338.78,"text":"כתבנו יצא אל השטח"},{"start":338.78,"end":341.04,"text":"תודה רבה ז'ק"},{"start":341.04,"end":343.04,"text":"ואנו נמצאים כאן בלב ליבה של האולימפיאדה הראשונה ללפלפים"},{"start":343.04,"end":345.04,"text":"הלוי הלפלפי ידה הראשונה"},{"start":345.04,"end":347.04,"text":"ניתן לראות כאן את הטוענת לקטר"},{"start":347.04,"end":349.04,"text":"האלופה בחמש אבנים"},{"start":349.04,"end":351.04,"text":"הלוי הקבוצה מבית חנונים"},{"start":351.04,"end":353.55,"text":"אלו חבר'ה שיהיה בהצלחה"},{"start":353.55,"end":356.06,"text":"איזה יכולת"},{"start":356.06,"end":358.06,"text":"ואנחנו עוברים כבר אל אדם אחר שימו לב"},{"start":358.06,"end":360.06,"text":"אלוף העולם לשעבר בקפיצה בחבל"},{"start":360.06,"end":362.18,"text":"דנינו ראופ המומחה בדלגית"},{"start":362.18,"end":364.18,"text":"מה יש לך לומר כמה מילים"},{"start":364.18,"end":366.18,"text":"אני מזמין את עוזי ליום הולדתי"},{"start":366.18,"end":368.14,"text":"אחת שתיים שלום"},{"start":368.14,"end":370.14,"text":"אופה איזה אמביציה"},{"start":370.14,"end":372.65,"text":"בהצלחה לך גם"},{"start":372.65,"end":374.65,"text":"ושימו לב כאן מימיני נמצא"},{"start":374.65,"end":376.65,"text":"אלוף העולם בקרב רב"},{"start":376.65,"end":378.65,"text":"אלו מנשה לפלפי ערב טוב מנשה"},{"start":378.65,"end":380.65,"text":"ערב טוב אני נורא נורא מתרגש"},{"start":380.65,"end":382.65,"text":"שלום לכולם אין ספק שהקרב"},{"start":382.65,"end":384.65,"text":"הפעם היה נורא קשה התחלנו"},{"start":384.65,"end":386.65,"text":"במסלול דוקים עברנו"},{"start":386.65,"end":388.65,"text":"למונופול רצחני דמקה"},{"start":388.65,"end":390.65,"text":"קפיצה בגומי"},{"start":390.65,"end":392.65,"text":"אחר כך היה שוגו ולחמנייה"},{"start":392.65,"end":394.65,"text":"ובסוף היה הכי קשה מכולם"},{"start":394.65,"end":396.65,"text":"זה קפיצה במות לתוך ארגז חול"},{"start":396.65,"end":398.65,"text":"ובניית ארמנות בחול"},{"start":398.65,"end":400.65,"text":"הבנתי מנשה אולי כמה מילים למתחרים"},{"start":400.65,"end":402.65,"text":"כמובן למתחרים נורא חשוב"},{"start":402.65,"end":404.65,"text":"לשמור על ההגינות הספורטיבית"},{"start":404.65,"end":406.65,"text":"וזכרו לא חשוב על אפלוף"},{"start":406.65,"end":408.65,"text":"העיקר הכיוב"},{"start":408.65,"end":410.65,"text":"כל הכבוד"},{"start":410.65,"end":412.75,"text":"עד כאן ז'קמין הלפלפיה"},{"start":412.75,"end":414.94,"text":"להתראות"},{"start":414.94,"end":417.07,"text":"בעקבות החוק החדש העוסר לעשן במקומות עבודה"},{"start":417.07,"end":419.07,"text":"נפתחו במשרדים רבים פינות אישון"},{"start":419.07,"end":424.49,"text":"פינות חדשות נפתחו גם"},{"start":424.49,"end":427.06,"text":"לקוססי ציפורניים"},{"start":427.06,"end":434.91,"text":"פינת איתוש"},{"start":434.91,"end":437.45,"text":"ופינת ארלוזרוב וייצמן"},{"start":437.45,"end":440.12,"text":"והרי ידיעה שפורסמה בעיתוני הצהריים"},{"start":440.12,"end":442.12,"text":"טייר נתפס בלוד"},{"start":442.12,"end":444.12,"text":"כשעל גופו עשרים וחמישה קילוגרם זהב"},{"start":444.12,"end":449.62,"text":"יצאנו לראות מיהו אותו טייר"},{"start":449.62,"end":478.31,"text":"נכנס הזמר האמריקני מייקל ג'קסון לדיכאון עמוק וחרגע הוא נראה כך"},{"start":478.31,"end":480.63,"text":"נראה כך"},{"start":480.63,"end":483.9,"text":"לאלנה שלום"},{"start":483.9,"end":486.25,"text":"ולנושא אחר לגמרי"},{"start":486.25,"end":488.25,"text":"נמצאתי כאן באולפן אפרים מייקאפ"},{"start":488.25,"end":490.25,"text":"שהוא זוכה פרס האוסקר הישראלי בתחום איפור"},{"start":490.25,"end":492.73,"text":"ערב טוב"},{"start":492.73,"end":502.86,"text":"ערב טוב אפרים"},{"start":502.86,"end":505.27,"text":"ערב טוב אפרים"},{"start":505.27,"end":508.27,"text":"אפרים אתה זכית בפרס על האיפור"},{"start":508.27,"end":510.27,"text":"בסרט רומאו ויוליה הגרסה הישראלית"},{"start":510.27,"end":512.27,"text":"מה תספר לנו על העבודה שלך?"},{"start":512.27,"end":515.27,"text":"ובכן כמובן