[{"start":31.23,"end":33.41,"text":"ברוכים הבאים"},{"start":33.41,"end":35.76,"text":"לקום המסתור"},{"start":35.76,"end":138.79,"text":"של ג'ו'זו"},{"start":138.79,"end":140.61,"text":"הפעם גברותיי ורבותיי"},{"start":140.61,"end":142.61,"text":"מדהי לדחקב"},{"start":142.61,"end":144.61,"text":"אמא שלי"},{"start":144.61,"end":146.61,"text":"היום אני רוצה לדבר"},{"start":146.61,"end":148.61,"text":"על הפרסומות של האינטימיות של האישה"},{"start":148.61,"end":150.6,"text":"עוד פעם ילדים לכו"},{"start":150.6,"end":152.63,"text":"רבותיי"},{"start":152.63,"end":154.63,"text":"שמתם לב בזמן האחרון"},{"start":154.63,"end":156.63,"text":"כמה פרסומות יש"},{"start":156.63,"end":158.63,"text":"על האינסטלציה של האישה"},{"start":158.63,"end":160.95,"text":"זה לא יאמן מה שקורה"},{"start":160.95,"end":162.95,"text":"איך על דיילת והשנייה סטודנטית"},{"start":162.95,"end":164.95,"text":"לא מכירים אותם"},{"start":164.95,"end":166.95,"text":"והיא מספרת כמה הטמפון עושה לה כיפו"},{"start":166.95,"end":168.95,"text":"אני יושבת וחסה סבבי"},{"start":168.95,"end":170.95,"text":"לא יאמן"},{"start":170.95,"end":172.95,"text":"כל האישות יושבות כל החודש מדוקאות"},{"start":172.95,"end":174.95,"text":"מגיע להם היום של הטמפון"},{"start":174.95,"end":176.95,"text":"הן רצות על הפנועים וקופצות ושמח"},{"start":176.95,"end":178.95,"text":"לא מבין תחרתה זה"},{"start":178.95,"end":180.95,"text":"ואיזה סוגים יש ואימא שלי"},{"start":180.95,"end":183.14,"text":"יש טמפון אולטימטיבי"},{"start":183.14,"end":185.14,"text":"אולטימטיזי עם רשת הגנה חד-כיווני"},{"start":185.14,"end":187.14,"text":"זה לא טמפון במה זה מעבר גבול"},{"start":187.14,"end":189.14,"text":"מה זה הדבר הזה ואימא שלי"},{"start":189.14,"end":193.14,"text":"הכי מפחיד זה שיעשות בעת טמפונים וזנאים"},{"start":193.14,"end":195.14,"text":"יעני בשביל לשמוע תחת וצרות"},{"start":195.14,"end":197.14,"text":"מה זה החרטבות הזה"},{"start":197.14,"end":199.14,"text":"לכן לפיכך ולמרות הכל"},{"start":199.14,"end":201.14,"text":"החליט צוות הפרסום של זו זו ון אבל האש