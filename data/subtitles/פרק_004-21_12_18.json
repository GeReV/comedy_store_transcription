[{"start":0.77,"end":1.27,"text":"קח"},{"start":1.27,"end":3.21,"text":"אוקיי חבר'ה קדימה מה קורה לכם?"},{"start":3.21,"end":4.55,"text":"אתה לא יודעים מה קורה למטה, היסטריה"},{"start":4.55,"end":5.17,"text":"מה קרה?"},{"start":5.17,"end":6.75,"text":"היסטריה, נשים, אני חושב שתכניסו קהל"},{"start":6.75,"end":8.29,"text":"נכניס קהל עכשיו, עוד מוקדם"},{"start":8.29,"end":9.97,"text":"חבר'ה, שטור היסטריה, נשים לא..."},{"start":9.97,"end":11.13,"text":"קדימה, קהל, זה..."},{"start":11.13,"end":11.97,"text":"אני חושב את היסטריה"},{"start":11.97,"end":13.41,"text":"זה עלינו כבר, אני חושב את היסטריה"},{"start":13.41,"end":15.21,"text":"אין בעיה, יש שום בעיה, אין בעיה"},{"start":15.21,"end":18.8,"text":"בסדר, אני לא נכניס את הנשים, אין בעיה"},{"start":18.8,"end":20.57,"text":"אתה רוצה קפה?"},{"start":20.57,"end":22.99,"text":"לא, עזוב, לא תבלי לעולקוס"},{"start":22.99,"end":23.95,"text":"אז תה"},{"start":23.95,"end":25.02,"text":"זה שיהיה"},{"start":25.02,"end":56.03,"text":"רבותיי ורבותיי"},{"start":56.03,"end":57.96,"text":"ברוכים הבאים"},{"start":57.96,"end":60.12,"text":"לקו ומסתור"},{"start":60.12,"end":68.22,"text":"שלום, אנחנו מעגודה למלחמה והתרמות"},{"start":68.22,"end":70.5,"text":"יש לנו ב-50 שקלים, עצרה שקלים או 5 שקלים"},{"start":70.5,"end":72.3,"text":"מה שעדיף לך, ל-לך"},{"start":72.3,"end":74.3,"text":"ויש גם כל מיני צבעים"},{"start":74.3,"end":75.48,"text":"למושא, אם את לא"},{"start":75.48,"end":78.07,"text":"אמרו את ספר זלמן שני אור"},{"start":78.07,"end":100.9,"text":"לך חיים, לך חיים טובים, לך חיים טובים"},{"start":100.9,"end":103.06,"text":"תגיד"},{"start":103.06,"end":105.16,"text":"אתה מר שלומו?"},{"start":105.16,"end":107.3,"text":"לא, אני מרשמלו"},{"start":107.3,"end":111.72,"text":"רגע, יש לי"},{"start":111.72,"end":114.0,"text":"אתה מרציפורי?"},{"start":114.0,"end":115.88,"text":"מה פתאום, אני מרציפן"},{"start":115.88,"end":117.68,"text":"מרציפן!"},{"start":117.68,"end":121.28,"text":"תגיד, אתה מרמשולם?"},{"start":121.28,"end":122.94,"text":"לא, אני מרמלאדה"},{"start":122.94,"end":129.03,"text":"אתה מרגרינה?"},{"start":129.03,"end":130.83,"text":"לא, אני חמאה"},{"start":144.66,"end":149.03,"text":"ולחול האחרונה מתברר שכל אדם שביעי מפותר מעבודתו"},{"start":149.03,"end":149.63,"text":"תכף"},{"start":149.63,"end":153.58,"text":"בוס, מה אתה עושה פה?"},{"start":153.58,"end":154.38,"text":"מה אתה עושה פה?"},{"start":154.38,"end":156.78,"text":"בלא בזמן לעבודה, אתה מפותר!"},{"start":156.78,"end":163.32,"text":"כל אדם שישי הינו גבר מוקה"},{"start":163.32,"end":164.32,"text":"אני לא מאמינה!"},{"start":164.32,"end":166.0,"text":"פתרו אותך!"},{"start":166.0,"end":168.47,"text":"אל תהי יחזור הביתה!"},{"start":168.47,"end":176.19,"text":"כל אדם חמישי זוכה לפחות פעם אחת בחייו בפייס"},{"start":176.19,"end":180.45,"text":"יש!"},{"start":180.45,"end":182.02,"text":"סליחה"},{"start":182.02,"end":183.77,"text":"אני הייתי אחריו?"},{"start":183.77,"end":185.08,"text":"כן"},{"start":185.08,"end":186.36,"text":"מה?"},{"start":186.36,"end":187.53,"text":"יש!"},{"start":187.53,"end":188.97,"text":"יש!"},{"start":188.97,"end":190.33,"text":"יש, תכיתי!"},{"start":190.33,"end":192.59,"text":"יש, יש!"},{"start":192.59,"end":199.27,"text":"כל אדם רביעי יוצא מביתו ללא מטריה"},{"start":199.27,"end":209.26,"text":"כל אדם שלישי עלול להתקל השבוע בבעיה כבדת משקל"},{"start":209.26,"end":212.89,"text":"מה?"},{"start":212.89,"end":217.97,"text":"תודה!"},{"start":217.97,"end":218.97,"text":"תיקון טעות"},{"start":218.97,"end":222.0,"text":"כל אדם רביעי עומד להתקל בבעיה כבדת משקל"},{"start":222.0,"end":233.41,"text":"ערב צח ושוב שלום לכם"},{"start":233.41,"end":235.41,"text":"שוב אנחנו בפינתו של ז'וז'ו"},{"start":235.41,"end":238.41,"text":"הדברים שמביאים לי תחלסטרה"},{"start":238.41,"end":240.53,"text":"ועכשיו כמירותי ורבותיי"},{"start":240.53,"end":242.53,"text":"יצאתי עם אשתי לבית קפה סבבי בבי"},{"start":242.53,"end":244.13,"text":"לשתות קפה"},{"start":244.13,"end":245.13,"text":"אתם יודעים יומיומי"},{"start":245.13,"end":247.38,"text":"ובכן פה באה לי המצוקה"},{"start":247.38,"end":248.79,"text":"באה לי מלצרית"},{"start":248.79,"end":250.85,"text":"ובתמימות עושה לי"},{"start":250.85,"end":252.85,"text":"איזה תת תרצה לשתות אדוני"},{"start":252.85,"end":255.85,"text":"מה תרצה? חליטת פירות"},{"start":255.85,"end":257.85,"text":"קסם הקינמון"},{"start":257.85,"end":259.85,"text":"עינוגי הטפוח"},{"start":259.85,"end":260.85,"text":"עמדת השקט"},{"start":260.85,"end":261.85,"text":"מה זה אחרת זה?"},{"start":261.85,"end":263.85,"text":"עוד שנייה עוד אומרת לי המלצרית"},{"start":263.85,"end":265.85,"text":"אתה רוצה אולי שירת הנענה"},{"start":265.85,"end":267.85,"text":"ומיצוקת השיבה"},{"start":267.85,"end":268.85,"text":"מה זה אחרת זה?"},{"start":268.85,"end":269.85,"text":"באמא שלי בזה רק אשתי"},{"start":269.85,"end":271.85,"text":"אני רציתי קפה"},{"start":271.85,"end":272.85,"text":"בכלל את חרפנה"},{"start":272.85,"end":274.81,"text":"מה אתה רוצה?"},{"start":274.81,"end":275.81,"text":"14 קראט"},{"start":275.81,"end":276.81,"text":"18 קראט"},{"start":276.81,"end":277.81,"text":"24"},{"start":277.81,"end":278.81,"text":"אני יש לי רק את הקראט הזה"},{"start":278.81,"end":279.81,"text":"באמא שלי"},{"start":279.81,"end":280.81,"text":"חשבתי עושה צחוק על השרשר"},{"start":280.81,"end":281.81,"text":"לא נרגעתי"},{"start":281.81,"end":282.81,"text":"עושה לי"},{"start":282.81,"end":283.81,"text":"אתה רוצה אולי"},{"start":283.81,"end":284.81,"text":"קפה של פעם"},{"start":284.81,"end":285.81,"text":"או קפה של טעם"},{"start":285.81,"end":286.8,"text":"אמרתי לי"},{"start":286.8,"end":287.8,"text":"אני רוצה קפה שחור"},{"start":287.8,"end":288.8,"text":"עם שתיים סוכר"},{"start":288.8,"end":289.8,"text":"ותער וביא אחרי המזיגה"},{"start":289.8,"end":291.8,"text":"חרפנה לי את המוח"},{"start":291.8,"end":293.12,"text":"לשיקום"},{"start":293.12,"end":294.34,"text":"האזרח הקטן"},{"start":294.34,"end":295.5,"text":"כשאתה הולך לבית קפה"},{"start":295.5,"end":297.62,"text":"זכור את הפתגם הידוע"},{"start":297.62,"end":299.9,"text":"אל תסתכל בקדקן"},{"start":299.9,"end":300.87,"text":"אלא קח אותו הבית"},{"start":300.87,"end":302.96,"text":"ותחשבו על זה"},{"start":302.96,"end":308.92,"text":"מטרימים"},{"start":308.92,"end":313.19,"text":"הם לא בבית"},{"start":313.19,"end":315.7,"text":"כל פעם שהם מטרימים הם לא בבית"},{"start":315.7,"end":317.83,"text":"אף פעם הם לא בבית"},{"start":317.83,"end":320.34,"text":"קמצנים"},{"start":320.34,"end":322.57,"text":"הם כאילו לא בבית"},{"start":322.57,"end":325.17,"text":"הם לא בבית"},{"start":325.17,"end":327.67,"text":"אז אולי אתה תתרג לי"},{"start":327.67,"end":331.17,"text":"גם אני לא בבית"},{"start":331.17,"end":333.17,"text":"שלום לכם וערב טוב"},{"start":333.17,"end":335.17,"text":"שוב אנחנו בתוכניתנו אחד על אחד"},{"start":335.17,"end":337.17,"text":"הערב יש לנו את הכבוד להרח אומן סטנדאפ קומדי"},{"start":337.17,"end":339.17,"text":"ואותו נרצה לשאול שאלה אחת פשוטה"},{"start":339.17,"end":341.17,"text":"מר זילבר"},{"start":341.17,"end":345.17,"text":"בבקשה מה התכונה החשובה ביותר לאומן סטנדאפ קומדי?"},{"start":345.17,"end":355.8,"text":"אה... אה... אה... אה... אה... אה... אה... אה... אה... אה... אה... אה... ספונטניות"},{"start":355.8,"end":358.86,"text":"אהההה... נשלוף מה שרבול זה הקטע"},{"start":358.86,"end":360.92,"text":"תודה רבה לך! יהיו איתן!"},{"start":360.92,"end":363.68,"text":"הסטנדאפ כובש את העולם"},{"start":363.68,"end":370.74,"text":"היי! הגלה משה חסוס ואותי אתם מושקים חבר'ה ונדרים היי! איפה אתם?"},{"start":370.74,"end":375.74,"text":"אה הנה! תגיד מה זה? זה הראש שלך או שזה פרסומת את טוסיק סעיר במיוחד?"},{"start":375.74,"end":379.74,"text":"תגיד זה הרווה שלך או שאתה סתם שמח לראות אותי?"},{"start":379.74,"end":383.84,"text":"הנה! תגידו! מה אתה? אתה חוגר?"},{"start":383.84,"end":385.84,"text":"אל תתעלל חוגר כאיש קבע!"},{"start":385.84,"end":387.84,"text":"אני הייתי המון שנים רבת! המון!"},{"start":387.84,"end":390.84,"text":"אחר כך הייתי סתם רבת המון!"},{"start":390.84,"end":393.99,"text":"חבר'ה בדיחות שלי לא הולכות ברגל זה, אתם הולכים!"},{"start":393.99,"end":397.71,"text":"אתם נראים לי קצת עייפים!"},{"start":397.71,"end":399.71,"text":"טוב, הלכת מאה ושמונה עשר קילומטר!"},{"start":399.71,"end":402.71,"text":"עוד שני קילומטר לשוקו! עוד שני קילומטר!"},{"start":402.71,"end":404.71,"text":"זה קר! אתם פותחים אותו!"},{"start":404.71,"end":407.71,"text":"אתם שוטים! תשנם! ליאט ליאט ליאט!"},{"start":407.71,"end":409.71,"text":"יופה! היי לא! מה קרה!"},{"start":409.71,"end":411.71,"text":"מה יש? מה? יאללה!"},{"start":411.71,"end":418.08,"text":"שלום, באתי להטרים!"},{"start":418.08,"end":420.08,"text":"מה קרה? מה קרה? מה קרה?"},{"start":420.08,"end":424.08,"text":"יש בחמישה שקלים, עשרה שקלים או חמישים שקלים."},{"start":424.08,"end":428.08,"text":"יאללה, חיים תלו את הוידאו, נו, גמרנו, יאללה, קח את הוידאו ותחפיתי פה!"},{"start":428.08,"end":431.08,"text":"חיים תלו את הוידאו, תלו את הוידאו, נכן בו!"},{"start":431.08,"end":436.58,"text":"אופה!"},{"start":436.58,"end":440.58,"text":"תגיד! יש, יש, יש!"},{"start":440.58,"end":444.86,"text":"איזה אביב אוהב לאכול הנבים?"},{"start":444.86,"end":446.69,"text":"אביב גפן!"},{"start":446.69,"end":450.69,"text":"יש לי, יש לי!"},{"start":450.69,"end":454.69,"text":"איזה דפנה אוהבת לאכול תמרים?"},{"start":454.69,"end":456.91,"text":"איזה?"},{"start":456.91,"end":457.91,"text":"דפנה דקל!"},{"start":458.91,"end":460.91,"text":"יש לי, יש לי, יש לי!"},{"start":460.91,"end":462.91,"text":"איזה יהודה אוהב לאכול קוצים?"},{"start":462.91,"end":464.91,"text":"נו, יהודה ברקן!"},{"start":464.91,"end":472.51,"text":"מה אוהבת לאכול שושן אדמרי?"},{"start":472.51,"end":473.51,"text":"מה?"},{"start":473.51,"end":474.79,"text":"ג'אמון!"},{"start":474.79,"end":579.84,"text":"שלום רב לכם וערב טוב."},{"start":579.84,"end":581.84,"text":"ערב טוב, שוב אנחנו בתוכניתנו אחד על אחד,"},{"start":581.84,"end":584.84,"text":"והפעם אנחנו עם מפקד סגן אלוף בצעד,"},{"start":584.84,"end":586.84,"text":"סגן אלוף צעדיקס."},{"start":586.84,"end":589.93,"text":"צעדיקס, ספר לנו בבקשה, בתור מפקד שנים רבות,"},{"start":589.93,"end":594.02,"text":"מה התכונה הבולטת ביותר למפקד בצעד?"},{"start":594.02,"end":598.3,"text":"התכונה הבולטת ביותר היא ללא ספק החלטיות!"},{"start":598.3,"end":602.9,"text":"הוא שלא, אני לא יודע, אני לא יודע, אני לא יודע, מה אתה אומר?"},{"start":602.9,"end":603.9,"text":"מה אני עושה?"},{"start":603.9,"end":606.12,"text":"תודה רבה לך, ערב טוב ולהתראות!"},{"start":606.12,"end":611.81,"text":"אלן, אלן, מה העניינים?"},{"start":611.81,"end":612.9,"text":"אלן, אלן!"},{"start":612.9,"end":615.9,"text":"טוב שבאת, תשמע, אתה יודע אני רוצה למכור את האוטו, אבל למה קראתי לך?"},{"start":615.9,"end":617.9,"text":"למה תראה איזה אוטו לא טוב?"},{"start":617.9,"end":620.9,"text":"הצבש לא דפוק, המנוע שלו אוכל, אתה יודע שהוא אחרי טעונה?"},{"start":620.9,"end":622.9,"text":"אני לא, אבל אני לא יודע לדבר, אני אתפקד"},{"start":622.9,"end":623.9,"text":"אל תדאג, אל תדאג"},{"start":623.9,"end":627.9,"text":"אל תדאג, שתי מילים שלי, העסק סגורים ידאג"},{"start":627.9,"end":629.9,"text":"אל תדאג, אחוזים עליי אבל, אה?"},{"start":629.9,"end":631.9,"text":"כן, כן, שכנה האוטו, זה אוטו טוב"},{"start":631.9,"end":632.9,"text":"אל תדאג, איפה הוא, צריך לבוא?"},{"start":632.9,"end":634.9,"text":"מה שלום, מה אישה?"},{"start":634.9,"end":637.41,"text":"שלום"},{"start":637.41,"end":639.41,"text":"אלן, נעים מאוד"},{"start":639.41,"end":641.41,"text":"אלן, שלום"},{"start":641.41,"end":642.41,"text":"מי בא לאוטו?"},{"start":642.41,"end":645.41,"text":"אני בא לאוטו, זה גיסי, נעים מאוד"},{"start":645.41,"end":646.41,"text":"מה אני יכול לעזור לך בבקשה?"},{"start":646.41,"end":648.41,"text":"אם אפשר קצת פרטים"},{"start":648.41,"end":649.41,"text":"תראה, הרבה אין מה לדבר"},{"start":649.41,"end":651.41,"text":"יש לך פה אוטו מציעה"},{"start":651.41,"end":653.57,"text":"אוטו אשתון עשה עליו, מפה לעבודה"},{"start":653.57,"end":655.57,"text":"שלוש קילומטר יום יום, זהו"},{"start":655.57,"end":657.57,"text":"מנוע חדש, אחרי אוברול"},{"start":657.57,"end":659.57,"text":"אקזוז חדש, אתה מבין?"},{"start":659.57,"end":661.57,"text":"יש לך בפנים רדיאטור חדש, הכל חדש"},{"start":661.57,"end":663.57,"text":"צמיגים חדש, אוטו בובה, מה יש לדבר?"},{"start":663.57,"end":665.57,"text":"יש לנהליות לירושלים, כמו נמר סוחב"},{"start":665.57,"end":667.57,"text":"סוחב, אתה יודע מה?"},{"start":667.57,"end":669.6,"text":"ארבע פעמים אילת, צדניות, כל האוטו"},{"start":669.6,"end":671.6,"text":"כולם הילדים נכנסים"},{"start":671.6,"end":673.6,"text":"אין, פשוט, זה אוטו נמר"},{"start":673.6,"end":675.66,"text":"אין ויכוח בכלל, אוטו, אוטו"},{"start":675.66,"end":677.66,"text":"מנוע, בוא תראה זוז, בוא תראה מה זה מנוע"},{"start":677.66,"end":679.81,"text":"זה מנוע, אין, רק עובד"},{"start":679.81,"end":681.81,"text":"אתה מבין, חלפים זולים"},{"start":681.81,"end":683.81,"text":"תראה, עכשיו לא ניקינו לך פה את המנוע"},{"start":683.81,"end":685.81,"text":"זה לא אחר טייה, אני מנקים לך את זה"},{"start":685.81,"end":687.81,"text":"זה שחור, זה אוטו עובד, זה מנוע שחור מהעבודה"},{"start":687.81,"end":689.81,"text":"אין מקום שהמנוע הזה לא הגיע, אתה מבין?"},{"start":689.81,"end":691.81,"text":"אני מדבר איתך על מציעה"},{"start":691.81,"end":693.81,"text":"למעשה אתה קולה פה מציעה"},{"start":693.81,"end":695.81,"text":"זה הכל, זה הכל"},{"start":695.81,"end":698.18,"text":"איזה יד זו?"},{"start":698.18,"end":700.28,"text":"רסמי, האוטו יד רביעי"},{"start":700.28,"end":702.34,"text":"אבל למעשה האוטו יד ראשונה"},{"start":702.34,"end":704.34,"text":"אתה מבין אותי למה, כולם במשפחה החליפו ידיים"},{"start":704.34,"end":706.34,"text":"גיסי כנה, סבתא שלי החליפה"},{"start":706.34,"end":708.34,"text":"הדודה, הילדה קטן, אתה מבין זה הכל"},{"start":708.34,"end":710.34,"text":"יד, אתה מקבל למעשה יד ראשונה"},{"start":710.34,"end":712.34,"text":"הבנתי, הבנתי"},{"start":712.34,"end":714.34,"text":"טסט אחי, טסט"},{"start":714.34,"end":716.4,"text":"אל תדאג, יש לה טסט לשנה"},{"start":716.4,"end":718.4,"text":"טסט, תרים לי טלפון אני מכיר את כולם"},{"start":718.4,"end":720.4,"text":"אין, תמיד, אין ויכוח"},{"start":720.4,"end":722.58,"text":"תגיד, בוא כסף, בוא נדבר תכלס"},{"start":722.58,"end":724.58,"text":"תראה, המחיר של המכונה"},{"start":724.58,"end":726.68,"text":"שבע במחירו"},{"start":726.68,"end":728.96,"text":"אני רוצה בשבילה שבע וחצי"},{"start":728.96,"end":731.14,"text":"שבע וחצי למה היא מושקעת"},{"start":731.14,"end":733.14,"text":"לא, זה קצת יקר לי"},{"start":733.14,"end":735.33,"text":"מה, אתה קונה אוטו טוב?"},{"start":735.33,"end":737.33,"text":"שש שמונה מאות"},{"start":737.33,"end":739.33,"text":"תגיד לי, אתה עושה צחוק, מה קרה?"},{"start":739.33,"end":741.36,"text":"מה דבר הסתלו את עלינו?"},{"start":741.36,"end":743.36,"text":"אוטו מושקע, השקיעה עליו"},{"start":743.36,"end":745.36,"text":"שש שמונה מאות, תמיד לי, נפלט לי בטעות שבע"},{"start":745.36,"end":748.67,"text":"רציתי להגיד שבע שמונה מאות"},{"start":748.67,"end":750.67,"text":"יאללה שבע שגרנו"},{"start":750.67,"end":752.67,"text":"שבע שגרנו יופי על עניין"},{"start":752.67,"end":754.67,"text":"אפשר לסגור את העניין?"},{"start":754.67,"end":756.67,"text":"מה זה סגור? עוד שתי דקות אני מוכן"},{"start":756.67,"end":758.67,"text":"יאללה זריז, יופי של גיס יש לך"},{"start":758.67,"end":760.67,"text":"דרבאלה כה"},{"start":760.67,"end":762.67,"text":"דרבאלה כה, אני מחכה שתי דקות"},{"start":762.67,"end":764.67,"text":"אם לא אני כמות"},{"start":764.67,"end":766.67,"text":"יאללה טיק טק"},{"start":766.67,"end":766.77,"text":"שבע חמש שבועות, שבע מאתיים"},{"start":766.67,"end":768.67,"text":"לא הייתה מוכר אותו בערמטה"},{"start":768.67,"end":770.76,"text":"מה אני מוכר אותו?"},{"start":770.76,"end":772.76,"text":"מה אני מוכר אותו?"},{"start":772.76,"end":774.76,"text":"מה תראה איזה אוטוטו?"},{"start":774.76,"end":777.58,"text":"אני הולדת ארבע פעמים צדניות, מה תראה לך טסט לשנה?"},{"start":777.58,"end":781.58,"text":"ואני עושה טסט, אני מתקשר אליך, אתה מסדר לי הכל, אותו מעורלם, אני פראה."},{"start":781.58,"end":783.58,"text":"לא מכר, לא מכר."},{"start":783.58,"end":791.49,"text":"שלום, אנחנו מאגודה למעלה מלחמה, ואתה..."},{"start":791.49,"end":793.41,"text":"אמא לי! אמא, אמא!"},{"start":793.41,"end":795.19,"text":"אמא!"},{"start":795.19,"end":797.44,"text":"תראה לי על הכי, נכי, הופו."},{"start":797.44,"end":801.84,"text":"אה!"},{"start":801.84,"end":812.52,"text":"אלא, שתה, שתה, אם לא תשתה, היום אתה הייתי שתה."},{"start":812.52,"end":817.5,"text":"תגידו, באיזה חברת תעופה אוהבת לטוס קורין?"},{"start":817.5,"end":818.95,"text":"איזה? - אלא!"},{"start":821.95,"end":823.55,"text":"יש לי, יש לי!"},{"start":823.55,"end":825.53,"text":"איזה רב אוהבת יודית?"},{"start":825.53,"end":827.09,"text":"איזה? - רביץ!"},{"start":827.09,"end":829.65,"text":"רביץ! רביץ!"},{"start":829.65,"end":831.9,"text":"איזה רב חזק? - נו!"},{"start":831.9,"end":834.75,"text":"איזה משחק טלוויזיה אוהבת גלי?"},{"start":834.75,"end":836.04,"text":"נו! - אטארי!"},{"start":836.04,"end":839.2,"text":"אטארי! - איזה, איזה, איזה!"},{"start":839.2,"end":843.13,"text":"איזה יום בשבוע אוהבת להשבת? - איזה?"},{"start":843.13,"end":844.7,"text":"יום ראשון!"},{"start":844.7,"end":855.9,"text":"תגיד לי, אני שמעתי שעכשיו חדש מחשב שעושה את כל הנקיונות בבית."},{"start":855.9,"end":857.78,"text":"זה יכול להיות דבר כזה? - בטח."},{"start":857.78,"end":859.86,"text":"אנחנו היום מחשבים, הם עושים הכל. - כן."},{"start":859.86,"end":861.96,"text":"בטח, איך זה עובד? אני אסביר לכם. - כן."},{"start":861.96,"end":865.56,"text":"אתה בא על המחשב, אתה מתקתק, מה שאתה רוצה לנקות. - כן."},{"start":865.56,"end":868.2,"text":"והוא ישר מוציא לך הכל מה שאתה צריך."},{"start":868.2,"end":871.16,"text":"כל איזה חומרי ניקוי, איפה ואיך לעשות."},{"start":871.16,"end":874.85,"text":"והכל יוצא לך על דף נקי יפה מסודם."},{"start":874.85,"end":876.91,"text":"זה טוב מאוד. - בטח, זה טוב."},{"start":876.91,"end":878.19,"text":"אבל ממנקה?"},{"start":878.19,"end":879.68,"text":"העוזרת."},{"start":879.68,"end":881.6,"text":"ואם אין לי עוזרת, אל תקנה מחשב."},{"start":881.6,"end":884.43,"text":"שלום, חזרנו אליכם."},{"start":884.43,"end":887.47,"text":"וכמו שהבטחנו לפני שבועיים, בשעת שלנו, טלוויזיה שלנו,"},{"start":887.47,"end":889.95,"text":"כאן יוגרלו פרסים, והפעם טיסה ללונדון."},{"start":889.95,"end":893.55,"text":"כן, היה עד שנבחר הוא לונדון, ויש לנו אפילו זוכה."},{"start":893.55,"end":895.84,"text":"בין כל מאות המעטפות יגרלו אחד,"},{"start":895.84,"end":899.2,"text":"ושלואו מר יואל נחימוביץ'."},{"start":899.2,"end":900.08,"text":"קבלו הוא!"},{"start":900.08,"end":902.86,"text":"מר יואל נחימוביץ', בבחשה."},{"start":902.86,"end":905.26,"text":"שלום, ערב טוב. - ערב טוב, ערב טוב."},{"start":905.26,"end":906.86,"text":"תודה רבה. - שלום לך."},{"start":906.86,"end":908.22,"text":"זהו מר יואל נחימוביץ'."},{"start":908.22,"end":909.82,"text":"מר יואל נחימוביץ' מתחקיר שעשינו,"},{"start":909.82,"end":916.4,"text":"סיפר לנו שהוא גר ברישו לציון, הוא מעצב חנות רעבה, והוא צופה בתכנית שלנו, דבר שמתאיג אותנו מאוד, אבל אין מה לעשות."},{"start":916.4,"end":920.28,"text":"ובכן, יואל, אמטה שבאמת הזכרת ארטיסטי סער חשבתי זאת פרודיה."},{"start":920.28,"end":924.56,"text":"בהתחלה חשבתי זאת פרודיה, ולכדי שייתי את הכתובת על המסך, הבנתי שזה רציני יותר."},{"start":924.56,"end":927.9,"text":"כל מה שנותרנו לעשות כרגע זה לראות את החידה מהתוכנית שעברה."},{"start":927.9,"end":930.9,"text":"איי, איי, או!"},{"start":930.9,"end":933.51,"text":"שערה, שערה, אני הוציא לך מהפנים."},{"start":933.51,"end":935.19,"text":"שערה, שערה!"},{"start":936.34,"end":938.84,"text":"ימינוס אמור."},{"start":938.84,"end":939.49,"text":"איי!"},{"start":939.49,"end":943.18,"text":"רק חול וחול."},{"start":943.18,"end":944.08,"text":"תגיד את ההשתגעת?"},{"start":944.08,"end":947.28,"text":"רק חול וחול."},{"start":947.28,"end":948.58,"text":"על איזה מין חול הוא מדבר?"},{"start":948.58,"end":950.58,"text":"רק חול וחול."},{"start":950.58,"end":953.67,"text":"על איזה מין חול אנחנו מדברים?"},{"start":974.74,"end":978.33,"text":"מחר ב-10 בערוץ 24 חדש."},{"start":978.33,"end":986.81,"text":"שחת עשרה."},{"start":986.81,"end":989.02,"text":"תהיו חזקים אוהבי נוטלה."},{"start":989.02,"end":991.9,"text":"לא יכולים לחכות לטעם שאתם הכי אוהבים?"},{"start":991.9,"end":994.09,"text":"נוטלה בי רדי."},{"start":994.09,"end":996.39,"text":"מעטפת ופל קריספי פריחה וטעימה."},{"start":996.39,"end":999.99,"text":"ממולת בממרח נוטלה קרמי ופצפוצי חיטה קרנצ'ים."},{"start":999.99,"end":1001.49,"text":"נוטלה בי רדי."},{"start":1001.49,"end":1002.69,"text":"רדי טו אנג'וי."},{"start":1002.69,"end":1004.42,"text":"חפשו במחלקת ההוגיות."},{"start":1004.42,"end":1006.71,"text":"חגיגת נובמבר אונליין."},{"start":1006.71,"end":1010.01,"text":"מבצעים מיוחדים גם לשופינג היאל וליום הרווקים הסיני."},{"start":1010.01,"end":1015.01,"text":"לדוגמה, אוזניות על חוטיות אבל אלפוד 2 ב-599 שקלים בלבד."},{"start":1015.01,"end":1020.01,"text":"אייפון XR 128 ג'יגבייט ב-2599 שקלים בלבד."},{"start":1020.01,"end":1026.01,"text":"וגם, 200 שקלים הנחה לקנייה הבאה לקונים ב-499 שקלים מהקטגוריות המשתתפות במבצע."},{"start":1026.01,"end":1029.01,"text":"שוב ורסל אונליין, אתר הקניות של ישראל."},{"start":1029.01,"end":1059.52,"text":"מישפחת קרדשיין, ימי שישי, רק בערוצי."},{"start":1060.62,"end":1065.62,"text":"ענג של שוקולד מילקה מתחיל ב-100% חלב איכותי מהרי האלפים."},{"start":1065.62,"end":1069.62,"text":"מילקה, שוקולד מענג מהרי האלפים."},{"start":1069.62,"end":1076.41,"text":"טוב, אתם לא מבינים את הטירוף בחוץ, אנשים רק שומעים ללא מעם, משתגים."},{"start":1076.41,"end":1078.37,"text":"אינה, אני פחדת לצאת."},{"start":1078.37,"end":1083.37,"text":"לאותיות קטנות, כל פריטי הכל בו במשמיר, ללא מעם למועדון."},{"start":1083.37,"end":1087.37,"text":"על הכל, כולל הכל, נוסף על ההנחות הקיימות, המשמיר לצרכן."},{"start":1087.37,"end":1103.44,"text":"ובכן, חזרנו מהחידה. הפעם, מה שנותרנו לעשות זה לראות מה הפתרון. בשביל זה נמצא איתנו יואל."},{"start":1103.44,"end":1105.47,"text":"יואל, מה הפתרון החידה?"},{"start":1105.47,"end":1106.56,"text":"הפתרון הוא זיף זיף."},{"start":1106.56,"end":1110.53,"text":"יואל, I'm very glad to give you this, כרטיס."},{"start":1110.53,"end":1112.53,"text":"אוקיי, אל בבקשה חקטנר."},{"start":1112.53,"end":1117.53,"text":"באמת, אנחנו לא מבקשים שום דבר עבור, כרטיס, לא כסף, אני רוצה רק שתעביר תיק קטן."},{"start":1117.53,"end":1120.53,"text":"תמיד זה תיק שלנו, אל תסתכל מה יש בפנים."},{"start":1120.53,"end":1124.53,"text":"בשדה התופה יחכה לך בחור בשם ג'קי עם פנס ענק על הפנים."},{"start":1124.53,"end":1128.53,"text":"פשוט תן לו את התיק, לא מענות לך שום דבר, כך בסל לבנות בלונדון."},{"start":1128.53,"end":1130.53,"text":"אם תופסים אותך, לא ידעת או שמעת, אוקיי?"},{"start":1130.53,"end":1136.59,"text":"אז זה התיק, this is the bag, אוקיי, תעשה חיים, לונדון מחכה לך, צ'או באו."},{"start":1136.59,"end":1140.59,"text":"ובכן גבירותיי ורבותיי, עכשיו לא נותרנו לעבור לחידה של השבוע."},{"start":1140.59,"end":1142.53,"text":"אני פגעתי פעמיים."},{"start":1142.53,"end":1144.68,"text":"אני הדבקתי פעמיים."},{"start":1144.68,"end":1146.97,"text":"אתה על התות שלי."},{"start":1146.97,"end":1149.03,"text":"אני מצפצף עליך."},{"start":1149.03,"end":1153.74,"text":"מי הוא ומה שמו?"},{"start":1153.74,"end":1155.8,"text":"אני ומה שמי!"},{"start":1155.8,"end":1158.6,"text":"אוקיי!"},{"start":1158.6,"end":1160.6,"text":"זאת הייתה האחידה שלנו לשבוע."},{"start":1160.6,"end":1163.6,"text":"אתם תכתבו לנו לפי הכתובת שמופיעה כרגע על המסך"},{"start":1163.6,"end":1166.6,"text":"ואחד מכם יזכה בקרטיס טיסה ליעד מסוים באירופה."},{"start":1166.6,"end":1168.6,"text":"ראיתם אנחנו לא עובדים עליכם הכל אמיתי."},{"start":1168.6,"end":1171.6,"text":"אני מחכה לגלויות שלכם ולמכתבים."},{"start":1171.6,"end":1173.21,"text":"ביי ביי."},{"start":1173.21,"end":1181.64,"text":"ערב טוב אדוני השוטר."},{"start":1181.64,"end":1182.64,"text":"ערב זך."},{"start":1182.64,"end":1183.82,"text":"אתה חייב לעזור לי."},{"start":1183.82,"end":1184.82,"text":"שמי יעקב אלפנבוים."},{"start":1184.82,"end":1187.2,"text":"אשתי נעלמה כבר."},{"start":1187.2,"end":1188.2,"text":"שני לילות היא לא נמצאת בבית."},{"start":1188.2,"end":1190.2,"text":"שני לילות אני לא יודע מה לעשות."},{"start":1190.2,"end":1191.2,"text":"קרה משהו בינכם?"},{"start":1191.2,"end":1192.2,"text":"לא קרה כלום."},{"start":1192.2,"end":1193.2,"text":"זה מה שמפליא אותי."},{"start":1193.2,"end":1194.2,"text":"זה לא קרה."},{"start":1194.2,"end":1196.2,"text":"אתם חייבים לעזור לי למצוא."},{"start":1196.2,"end":1197.2,"text":"תיאור חיצוני בקשה."},{"start":1197.2,"end":1200.2,"text":"אז ככה היא קצת מלאה."},{"start":1200.2,"end":1201.2,"text":"מלאה?"},{"start":1201.2,"end":1202.2,"text":"שמנמונת."},{"start":1202.2,"end":1203.2,"text":"שמנמונת?"},{"start":1203.2,"end":1204.2,"text":"שמנה."},{"start":1204.2,"end":1205.51,"text":"שמנה."},{"start":1205.51,"end":1208.51,"text":"היא גובה שלה משהו כמו מטר שישים."},{"start":1208.51,"end":1209.51,"text":"מטר שישים?"},{"start":1209.51,"end":1211.51,"text":"אני יודע, קצת פחות לא יודע."},{"start":1211.51,"end":1213.64,"text":"פחות."},{"start":1213.64,"end":1217.7,"text":"שיער של החום קצת ארוך."},{"start":1217.7,"end":1219.7,"text":"טיפה דליל."},{"start":1219.7,"end":1220.95,"text":"דליל."},{"start":1220.95,"end":1225.39,"text":"הוא קצת מקריח באזור הצדאיים."},{"start":1225.39,"end":1226.42,"text":"אני יודע."},{"start":1226.42,"end":1227.42,"text":"יש משהו בולט?"},{"start":1227.42,"end":1230.42,"text":"האף קצת, האמת."},{"start":1230.42,"end":1233.42,"text":"טיפה בולט, הוא מחודד טיפה בקצה."},{"start":1233.42,"end":1234.42,"text":"מחודד."},{"start":1234.42,"end":1236.42,"text":"כיפוף קטן."},{"start":1236.42,"end":1238.42,"text":"עוד משהו?"},{"start":1238.42,"end":1240.42,"text":"השן שלה, יש לה שן אם זה יעזור."},{"start":1240.42,"end":1241.42,"text":"אני לא יודע, שן קדמית."},{"start":1241.42,"end":1242.48,"text":"הוא חסר לה."},{"start":1242.48,"end":1243.48,"text":"זאת אומרת, אין לה שן."},{"start":1243.48,"end":1244.48,"text":"כן, זאת אומרת, אין לה שן."},{"start":1244.48,"end":1246.43,"text":"שן קדמית חד חסרה."},{"start":1246.43,"end":1252.86,"text":"ואני יודע, יש לה גם פה מתחת לשפה, התחתונה פה בסמטר שחומה כזאת."},{"start":1252.86,"end":1253.86,"text":"בזה זה צרה?"},{"start":1253.86,"end":1254.86,"text":"שחומה, ככה."},{"start":1254.86,"end":1256.86,"text":"שחומה, עם שערות?"},{"start":1256.86,"end":1258.99,"text":"כן, עם שערות כאלה."},{"start":1258.99,"end":1259.99,"text":"שחומה?"},{"start":1259.99,"end":1261.99,"text":"עם שערות."},{"start":1261.99,"end":1264.24,"text":"אתה יודע מה? אתה יודע מה?"},{"start":1264.24,"end":1266.36,"text":"נשכח מזה."},{"start":1266.36,"end":1267.35,"text":"עזוב, לא צריך."},{"start":1267.35,"end":1268.42,"text":"תודה."},{"start":1268.42,"end":1270.34,"text":"במחשבה שנייה, עזוב."},{"start":1270.34,"end":1338.44,"text":"באנו להתרים למען..."},{"start":1338.44,"end":1339.44,"text":"סוף!"}]