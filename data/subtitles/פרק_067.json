[{"start":29.67,"end":41.98,"text":"תודה רבה לכם, תודה רבה, ערב טוב לכולם."},{"start":41.98,"end":44.38,"text":"זהו רובי, הוא ילווה אותי בגיטרה."},{"start":44.38,"end":46.88,"text":"אני אסף, אני מנגן בציקוצית."},{"start":46.88,"end":50.5,"text":"אנחנו נעביר לכם ערב עם מיטב סגנונות המוזיקה."},{"start":50.5,"end":54.3,"text":"ונתחיל בארץ ישראל הישנה והטובה, קצת נוסטלגיה."},{"start":54.3,"end":56.48,"text":"בואו נחזור לימי היידיש והלדינו."},{"start":56.48,"end":57.5,"text":"בבקשה רובי."},{"start":57.5,"end":72.43,"text":"אי אפשר להזכיר מוזיקה ישראלית בלי לדבר על מוזיקה מזרחית."},{"start":72.43,"end":73.37,"text":"רובי, בבקשה."},{"start":73.51,"end":86.61,"text":"הרפתקנים שבינינו יגיעו איתנו עד לברזיל הרחוקה."},{"start":86.61,"end":93.07,"text":"שם נסחף כאולנו בסמבה אהבה וכדורגל לצלילי הסמבה."},{"start":93.07,"end":113.06,"text":"רגל המצל תוכנית המשפחות, המשפחה הבאה כבר נמצאת כאן."},{"start":113.06,"end":114.26,"text":"שלום, בואו תציגו את עצמכם."},{"start":114.26,"end":115.6,"text":"חזק וברוך, חזק וברוך."},{"start":115.6,"end":115.88,"text":"כן."},{"start":115.88,"end":117.14,"text":"שם, שם."},{"start":117.14,"end":119.22,"text":"המב וזו בלהא אשתי."},{"start":119.22,"end":120.08,"text":"תגידי שלום."},{"start":120.08,"end":123.51,"text":"שלום לבו שבת, שלום לבו שבת, שלום לך שבת מלכה."},{"start":123.51,"end":125.37,"text":"אה, יש את חיין מימצא."},{"start":125.39,"end":127.73,"text":"זה סרט שהיה פה לפני שנייה."},{"start":127.73,"end":130.6,"text":"יפת! יפת! יפת!"},{"start":130.6,"end":132.89,"text":"איפה אתה יפת? יפת!"},{"start":132.89,"end":141.18,"text":"יפי, נאים זה מירות ישראל, יפי."},{"start":141.18,"end":142.8,"text":"בואו, תביא את הבקבוק לאבא."},{"start":142.8,"end":145.51,"text":"יופי, אז אנחנו יכולים להתחיל, אני ארז."},{"start":145.51,"end":151.69,"text":"ארז, ארז, ארז, ארז, ארז, תלויה, תלויה, תלויה, תלויה, תלויה, תלויה."},{"start":151.69,"end":152.93,"text":"איך נאים זה מירות."},{"start":152.93,"end":154.43,"text":"זאת רות שלנו."},{"start":154.43,"end":169.71,"text":"רות בנסי, רות אונה, תוס במיקה, רות גונזלס, ואנחנו, בואו, אנחנו קצת, אנחנו קצת, אנחנו קצת לחוצים בזמן, בואו נתחיל, אתם מכירים את החוקים? לא לשכוח לקנות אותיות אבי, קדימי."},{"start":169.71,"end":178.57,"text":"אביני, אביני, לאלתה, אביני, בואו, בואו, בואו נתחיל, בואו נתחיל, הגלגל שלך, סובב אותו, יפת, בבקשה."},{"start":184.43,"end":193.43,"text":"יופי, ואתה מקבל מכשיר נטלישת שערות באף של הרבלאף, בבקשה."},{"start":193.43,"end":195.43,"text":"מה זה? מה זה? תגיד לו משהו, זה לא יפה."},{"start":195.43,"end":196.43,"text":"באמת, באמת, אדון איטל."},{"start":196.43,"end":197.43,"text":"סליחה, סליחה."},{"start":197.43,"end":198.43,"text":"הוא צוחק על מומים."},{"start":198.43,"end":199.43,"text":"סליחה, אוקיי."},{"start":199.43,"end":200.43,"text":"לא, לא, לא, זה בסדר."},{"start":200.43,"end":202.43,"text":"כן, פן לסערות באף של הרבלאף."},{"start":202.43,"end":203.43,"text":"מה זה?"},{"start":203.43,"end":204.43,"text":"באמת."},{"start":204.43,"end":205.43,"text":"אנחנו לא עמדנו לכאן שיהיה לי."},{"start":205.43,"end":206.43,"text":"יצא, יצא, יצא, מה אני יכולה לראות, יצא."},{"start":206.43,"end":207.43,"text":"זהו, מה קורה כאן?"},{"start":207.43,"end":208.43,"text":"בבקשה, הנה."},{"start":208.43,"end":213.43,"text":"שואב אבק, שואב אבק, בבקשה, עם התקנה מיוחדת לסערות, אם במקרה נופלות על השטיח של..."},{"start":213.43,"end":216.43,"text":"אדון ארס, לא צריך את הפרסים שלך, תודה רבה."},{"start":216.43,"end":219.43,"text":"אוקיי, אז בוא נמשיך, בוא נמשיך לסתק, בבקשה, הגלגל שלך."},{"start":219.43,"end":226.43,"text":"שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא, שובב ולא."},{"start":226.43,"end":227.43,"text":"600 שקט!"},{"start":227.43,"end":229.43,"text":"בבקשה, אות."},{"start":229.43,"end":236.52,"text":"או תבינו חיים, או תבינו חיים, או תבינו חיים, או תבינו, או תבינו, או תבינו, או תבינו, או תבינו."},{"start":236.52,"end":239.96,"text":"או תבינו, או תבינו, או תבינו, או תבינו, או תבינו, תגיד צדיק, צדיק, צדיק."},{"start":239.96,"end":241.69,"text":"צדיק, צדיק."},{"start":241.69,"end":245.69,"text":"צדיק קדמה, איברח, איברח, צדיק קדמה, איברח."},{"start":245.69,"end":248.69,"text":"אנחנו לא יכולים פשוט להתקדם בצורה כזו, אני מבין שהאות היא צדיק, נכון?"},{"start":248.69,"end":249.69,"text":"צדיק, בבקשה."},{"start":249.69,"end":250.69,"text":"אין צדיק."},{"start":250.69,"end":251.69,"text":"טוב, התור עובר, בבקשה."},{"start":251.69,"end":253.69,"text":"רגע, רגע, אני יודע, אני יודע."},{"start":253.69,"end":254.94,"text":"אבל אני יודע."},{"start":254.94,"end":255.94,"text":"אי אפשר, לא התגלתה אף עוד."},{"start":255.94,"end":256.94,"text":"אבל אני יודע."},{"start":256.94,"end":257.94,"text":"אבל אתה איבדת את התור שלך."},{"start":257.94,"end":258.94,"text":"תגיד, תגיד."},{"start":258.94,"end":259.94,"text":"ברמוליקוס."},{"start":259.94,"end":260.94,"text":"ברמוליקוס, איזה יופי."},{"start":260.94,"end":264.46,"text":"מה זה ברמוליקוס?"},{"start":264.46,"end":266.46,"text":"ברמוליקוס, זה היא מכינה."},{"start":266.46,"end":267.46,"text":"מי הוא?"},{"start":267.46,"end":269.46,"text":"משפתיים ישעקוי עושה ברמוליקוס."},{"start":269.46,"end":271.46,"text":"טוב, יפת, אתה עולה לסיבור הפרס."},{"start":271.46,"end":273.46,"text":"אנחנו צריכים להיפרד."},{"start":273.46,"end":277.46,"text":"אתה מקבל פרס ניחומים צבע לסערות באף של חברת בלה."},{"start":277.46,"end":282.42,"text":"ומכשיר עיסוי לאף ולמיד גדלת שערות."},{"start":282.42,"end":287.42,"text":"ואנחנו מיד לאחר הפרסמות עם יפת בסיבוב הפרס אל תלחו לשום מקום."},{"start":287.42,"end":289.42,"text":"עוד פעם פרסמות."},{"start":289.42,"end":291.42,"text":"עוד פעם צריך לצייר את השתיים האלה."},{"start":291.42,"end":294.42,"text":"רגע איזה מסלולת היום? את הפנימי לוקח או את החיצון?"},{"start":294.42,"end":297.42,"text":"הפנימי? הפנימי יותר קצר אין לי כועד. אז זאת חברך."},{"start":297.42,"end":299.42,"text":"אז זה עוד פעם אני עושה את החיצוני הארוך אני."},{"start":299.42,"end":301.42,"text":"יאללה בואו נכן עושה את זה כבר."},{"start":301.42,"end":303.42,"text":"יאללה שעור."},{"start":303.42,"end":305.42,"text":"בוא נעוף יאללה בוא נעוף."},{"start":312.19,"end":321.9,"text":"בביילה בואו נעוף."},{"start":321.9,"end":325.1,"text":"יפת אני מתפלא על האיכות באמת אני מתפלא על האיכות."},{"start":325.1,"end":327.1,"text":"אבא רוצה את הטלפון שלנו בבית?"},{"start":327.1,"end":328.1,"text":"אנחנו בסביבו בפרס."},{"start":328.1,"end":330.1,"text":"יפת לא להסתכל עליה."},{"start":330.1,"end":332.1,"text":"אני מבקש לא להפריע."},{"start":332.1,"end":335.1,"text":"אנחנו נמצאים בסביבו הפרס מספר בין 1 ל 5."},{"start":335.1,"end":338.06,"text":"ששששששרים עלו."},{"start":338.06,"end":339.97,"text":"מספר בין 1 ל 5."},{"start":339.97,"end":344.47,"text":"חמש שנים על מיכאל עברו ברינק."},{"start":344.47,"end":347.47,"text":"יפת חמש זה המספר רות ההגדרה בבקשה."},{"start":347.47,"end":350.62,"text":"יפת בביילה, רק לך שירים."},{"start":350.62,"end":352.62,"text":"שירים."},{"start":352.62,"end":354.23,"text":"שירים, אוקיי?"},{"start":354.23,"end":357.41,"text":"שירים, חמש אותיות רגילות, שתי אותיות תהבי."},{"start":357.41,"end":359.05,"text":"בבקשה."},{"start":359.05,"end":360.01,"text":"שין."},{"start":360.01,"end":361.01,"text":"תף."},{"start":361.01,"end":362.2,"text":"בית."},{"start":362.2,"end":363.13,"text":"למד."},{"start":363.13,"end":364.97,"text":"וגימל."},{"start":364.97,"end":365.97,"text":"ושתי אותיות תהבי."},{"start":365.97,"end":367.97,"text":"א'."},{"start":367.97,"end":368.97,"text":"אוקיי, אותיות מצוינות."},{"start":368.97,"end":370.97,"text":"מרגע שרות מסובבת את האותיות,"},{"start":370.97,"end":373.99,"text":"יש לך עשר שניות לפתור, אוקיי?"},{"start":373.99,"end":375.99,"text":"וואה, וואה, כל האותיות..."},{"start":375.99,"end":377.95,"text":"אני מבקש, לא להפריע, גהל."},{"start":377.95,"end":380.11,"text":"אוקיי, מרגע שאותיות מסובבות..."},{"start":380.11,"end":382.11,"text":"*ערבית*"},{"start":412.58,"end":414.58,"text":"עזמן עבר"},{"start":414.58,"end":416.58,"text":"ואנחנו מצטערים"},{"start":416.58,"end":417.58,"text":"חבל"},{"start":417.58,"end":418.58,"text":"חבל"},{"start":418.58,"end":419.58,"text":"זה היה די קל דרך גם הייתי בתורש תדע"},{"start":419.58,"end":421.58,"text":"טוב עד כאן אם כן גלגל המזל"},{"start":421.58,"end":423.58,"text":"לא נורדת תהיה איתנו בתוכנית הבאה של גלגל המזל"},{"start":423.58,"end":424.58,"text":"תודה רבה לכם שהייתם איתנו"},{"start":424.58,"end":426.58,"text":"שלום ביי"},{"start":426.58,"end":429.58,"text":"שלום לבות שבת שלום לבות שבת"},{"start":429.58,"end":431.58,"text":"שלום לך שבת בלכר"},{"start":431.58,"end":432.57,"text":"שלום"},{"start":432.57,"end":434.56,"text":"רות גונזלס"},{"start":434.56,"end":435.56,"text":"כן"},{"start":435.56,"end":437.06,"text":"אני אוהב אותך"},{"start":437.06,"end":439.37,"text":"יבט"},{"start":439.37,"end":440.53,"text":"לך להתמעיק"},{"start":444.54,"end":453.32,"text":"סליחה בחור צ'יק"},{"start":453.32,"end":454.32,"text":"עשה טובה בוא תעזור לי פה נתקעתי עם האוטו"},{"start":454.32,"end":455.32,"text":"בוא תעזור לי פה לדחוף"},{"start":455.32,"end":456.32,"text":"בסדר"},{"start":456.32,"end":457.32,"text":"הנה שני הבחורים האלה"},{"start":457.32,"end":458.32,"text":"בחבר'ה נחמדים"},{"start":458.32,"end":459.32,"text":"אולי תעזרו לי פה לדחוף"},{"start":459.32,"end":460.32,"text":"כנס תמי בהכנות שלי"},{"start":460.32,"end":461.32,"text":"פת לכם"},{"start":461.32,"end":462.32,"text":"תודה רבה נתקעתי"},{"start":462.32,"end":463.32,"text":"אתה מבין בחונה חדשה"},{"start":463.32,"end":465.32,"text":"איך תבין היום חבר'ה זה לא חבר'ה"},{"start":465.32,"end":466.32,"text":"אך"},{"start":466.32,"end":468.67,"text":"קדימה הילוך שאני תוריד אנדבקס"},{"start":468.67,"end":469.67,"text":"בסדר ככה בקטנה"},{"start":469.67,"end":470.67,"text":"קצת קדימה"},{"start":470.67,"end":471.73,"text":"תודה"},{"start":471.73,"end":472.73,"text":"קדימה"},{"start":472.73,"end":474.14,"text":"יופי יופי"},{"start":474.14,"end":475.14,"text":"קדימה ישכם עוד"},{"start":475.14,"end":476.58,"text":"ישכם עוד"},{"start":476.58,"end":477.58,"text":"קדימה"},{"start":477.58,"end":478.58,"text":"קדימה"},{"start":478.58,"end":479.58,"text":"קדימה"},{"start":479.58,"end":480.58,"text":"קדימה"},{"start":480.58,"end":481.58,"text":"קדימה"},{"start":481.58,"end":482.58,"text":"קדימה"},{"start":482.58,"end":483.58,"text":"קדימה"},{"start":483.58,"end":484.58,"text":"קדימה"},{"start":484.58,"end":485.58,"text":"קדימה"},{"start":485.58,"end":486.58,"text":"קדימה"},{"start":486.58,"end":488.02,"text":"קדימה"},{"start":488.02,"end":489.66,"text":"תודה"},{"start":489.66,"end":491.66,"text":"בואו נטוס כולנו על כנפי הדמיון אל ארצות הברית הרחוקה"},{"start":491.66,"end":493.66,"text":"אל שדות הקוטנה הלבנים"},{"start":493.66,"end":497.66,"text":"שם העבדים הקושים הולידו את הבלוז"},{"start":497.66,"end":510.41,"text":"זו קצת נוסטלגיה"},{"start":510.41,"end":513.41,"text":"אל התקופה שההורים שלנו היו בני טיפש עשרה"},{"start":513.41,"end":517.41,"text":"ופיזזו וחרקרו לצלילי הרוק'נ'רול"},{"start":517.41,"end":528.5,"text":"תודה רבה"},{"start":528.5,"end":530.5,"text":"לסיום הייתי רוצה לתת לכם קטע קצר"},{"start":530.5,"end":532.5,"text":"שהוא סולו שלי"},{"start":532.5,"end":534.49,"text":"אני אנגן על הציקוצית"},{"start":534.49,"end":536.48,"text":"זהו קטע שרובי הלכין בשבילי"},{"start":536.48,"end":547.43,"text":"בבקשה"},{"start":547.43,"end":553.46,"text":"תודה רבה"},{"start":553.46,"end":560.8,"text":"נו נו מה קורה שם?"},{"start":560.8,"end":562.8,"text":"עוד מעט אדוני קצת צבלנות"},{"start":562.8,"end":564.8,"text":"באומנות הזמן עומד מלחתה"},{"start":564.8,"end":566.8,"text":"אין בעיה קצת קשה לי לשבת ככה"},{"start":566.8,"end":568.8,"text":"אני ממש, אתה יודע, משתוקק לראות מה שקורה שם"},{"start":568.8,"end":571.34,"text":"עוד ירד קדן יהיה בסדר אדוני"},{"start":571.34,"end":572.34,"text":"אה וואלה"},{"start":572.34,"end":573.34,"text":"אתה מוזמן לראות אדוני"},{"start":573.34,"end":574.34,"text":"איזה התרגשות"},{"start":574.34,"end":575.34,"text":"אה בבקשה"},{"start":575.34,"end":577.21,"text":"מה?"},{"start":577.21,"end":578.27,"text":"איזה אתה?"},{"start":578.27,"end":579.27,"text":"מה אני? איפה הציור שלי? סליחה"},{"start":579.27,"end":581.27,"text":"אדוני, הנה הציור שלך"},{"start":581.27,"end":582.81,"text":"מה זה זה אני?"},{"start":582.81,"end":583.81,"text":"בוודאי"},{"start":583.81,"end":585.81,"text":"אתה צוחק איתי, למה?"},{"start":585.81,"end":587.81,"text":"לא אדוני, אני מצייר ריאליסטי וזה אתה"},{"start":587.81,"end":590.07,"text":"סליחה, אתה עושה צחוק בן אדם"},{"start":590.07,"end":593.07,"text":"אדוני, אני בן אדם, מה ציירת לי? מה זה? זה ספרי"},{"start":593.07,"end":595.07,"text":"אדוני, אני עשרים שנה במקצוע, אתה מהליב אותי"},{"start":595.07,"end":598.07,"text":"מה אתה בלבל תמוך? איפה הציור שלי? אני שילמת לך כסף, אתה עושה צחוק"},{"start":598.07,"end":600.07,"text":"אדוני, אני מאוד מצטער"},{"start":600.07,"end":602.07,"text":"או, בחוץ'יק, בחוץ'יק, בוא שנייה, עשה טובה"},{"start":602.07,"end":604.13,"text":"תראה, אני ביקשתי שהוא יצייר אותי"},{"start":604.13,"end":607.13,"text":"כן, אני ישבתי פה ומה הוא צייר, תראה מה הוא צייר"},{"start":607.13,"end":608.13,"text":"ענק"},{"start":608.13,"end":609.73,"text":"מה ענק?"},{"start":609.73,"end":610.73,"text":"בול"},{"start":610.73,"end":612.73,"text":"תודה רבה אדוני, איזה בן אדם שמבין?"},{"start":612.73,"end":614.95,"text":"בוא נה, אתה מזה צחוק"},{"start":614.95,"end":619.11,"text":"סליחה, אתם שתפים פעולה פה, מה זה הקטע? זה נראה לך דומה לי"},{"start":619.11,"end":623.11,"text":"תודה רבה לך אדוני, תודה, סליחה, סליחה, אתה אולי, כן?"},{"start":623.11,"end":628.26,"text":"דביל הזה, סליחה, אני ישבתי כאן, כן? אני מטנתי שהוא יצייר אותי"},{"start":628.26,"end":631.32,"text":"עכשיו תראה, הוא צייר את זה, דומה לדבר הזה, תסתכל"},{"start":631.32,"end":634.36,"text":"דומה? די דומה, פלמון"},{"start":634.36,"end":637.5,"text":"מה דומה? בוא נה, זה ספרי, זה ספרי, זה נראה לך אמוני"},{"start":637.5,"end":638.5,"text":"ממש יפה"},{"start":638.5,"end":640.5,"text":"תודה רבה, תודה רבה"},{"start":640.5,"end":642.5,"text":"בוא נה, אתה איחד מטורף"},{"start":642.5,"end":644.5,"text":"עשרים שנה במקצוע, אתה מהליב אותי"},{"start":644.5,"end":646.5,"text":"קח את הדברים שלך וסמי פה, אתה עושה לצחוק"},{"start":646.5,"end":648.5,"text":"שילמתי לך כסף, מה אתה מצייר?"},{"start":648.5,"end":650.5,"text":"אדוני, אתה סתם פרמיטיב, אתה לא מבין בוא למה"},{"start":650.5,"end":651.5,"text":"אני הולך"},{"start":651.5,"end":652.5,"text":"היית מצייר לי אולי סקטים, סמי פה"},{"start":652.5,"end":654.5,"text":"פרמיטיב מפה, לך אתה מפגר"},{"start":654.5,"end":656.5,"text":"פסיכופט, כולכם משוגעים אתם"},{"start":656.5,"end":659.68,"text":"שלם לבין אדם כסף, אה"},{"start":659.68,"end":695.65,"text":"קצרות"},{"start":695.65,"end":697.65,"text":"בסדר, אל תדאגו חבר'ה"},{"start":697.65,"end":700.28,"text":"תראי את הקרס, ראוש"},{"start":700.28,"end":714.85,"text":"ראוש"},{"start":714.85,"end":716.85,"text":"איפה נו ביחד, מתי יוטילים משנה?"},{"start":716.85,"end":718.85,"text":"אנחנו לא רוצים שיהיו טילים"},{"start":718.85,"end":718.95,"text":"כן רוצים"},{"start":718.85,"end":720.85,"text":"לא רוצים ולא בטיח"},{"start":720.85,"end":722.85,"text":"תביא את המפתחות הנושא מפה"},{"start":722.85,"end":724.85,"text":"לא עוזז לשום מקום, שמעת איזה?"},{"start":724.85,"end":726.85,"text":"אתה לא עוזז לשום מקום, אחרי השעה חמש אתה בבית"},{"start":726.85,"end":728.85,"text":"בימים כאלה של מלחמה"},{"start":728.85,"end":730.85,"text":"כל המשפחה צריכה להיות ביחד"},{"start":730.85,"end":732.85,"text":"מים כאלה של מלחמה"},{"start":732.85,"end":734.85,"text":"איזה מלחמה איזה?"},{"start":734.85,"end":736.85,"text":"מבקש לא לאשן בחדר האטום"},{"start":736.85,"end":738.85,"text":"אם אפשר תודה רבה, תשים את הסיגן למטה"},{"start":738.85,"end":740.85,"text":"מה צריך?"},{"start":740.85,"end":742.85,"text":"נחש צפה"},{"start":742.85,"end":744.94,"text":"אוקיי, זה בא"},{"start":744.94,"end":746.94,"text":"תשימו את המסכה"},{"start":746.94,"end":748.94,"text":"תשאו את המסכה"},{"start":748.94,"end":752.64,"text":"אני לא עושה"},{"start":752.64,"end":754.67,"text":"אתה צריך לראים את המסכה"},{"start":754.67,"end":756.67,"text":"אתה צריך לראות את המסכה"},{"start":756.67,"end":758.67,"text":"אתה צריך לראות את המסכה"},{"start":758.67,"end":760.67,"text":"אל תהוכיץי פה"},{"start":760.67,"end":762.67,"text":"אל תהוכיץי אותי"},{"start":762.67,"end":764.67,"text":"אל תהוכיץי"},{"start":764.67,"end":769.13,"text":"את מה שאני עושה, תשאי את בלילד"},{"start":769.13,"end":771.13,"text":"שנייה"},{"start":771.13,"end":774.13,"text":"רגע, רגע, רגע"},{"start":774.13,"end":776.26,"text":"מה אמרת לי?"},{"start":776.26,"end":778.59,"text":"אתה אמרת לי תלכימי פה?"},{"start":778.59,"end":781.68,"text":"או שאתה אמרת לי תלכימי פה?"},{"start":781.68,"end":782.73,"text":"מה אמרת?"},{"start":782.73,"end":785.73,"text":"אמרתי לך תלכימי פה את מלחיצה את כולם פה גם"},{"start":785.73,"end":786.73,"text":"רגע אבל אני לא הבנתי"},{"start":786.73,"end":787.73,"text":"רגע, רגע!"},{"start":787.73,"end":789.73,"text":"שימ את זה בצד"},{"start":789.73,"end":791.69,"text":"יש תלכימי פה"},{"start":791.69,"end":792.69,"text":"זה תלכימי פה"},{"start":792.69,"end":793.69,"text":"חמור מאוד"},{"start":793.69,"end":795.69,"text":"ויש תלכימי פה"},{"start":795.69,"end":797.69,"text":"שזה קטסטרופה"},{"start":797.69,"end":799.69,"text":"את מלחיצה פה את כל הילדית"},{"start":799.69,"end":800.69,"text":"זה מה את מלחיצה שלי אמרת"},{"start":800.69,"end":802.69,"text":"תשביץ לסמייט תלכימי פה"},{"start":802.69,"end":804.69,"text":"אני אהבת לי אם זה תלכימי פה"},{"start":804.69,"end":806.69,"text":"או תלכימי"},{"start":806.69,"end":808.69,"text":"תבוא מה זה לשלם"},{"start":808.69,"end":817.06,"text":"והרי הודעת"},{"start":817.06,"end":819.26,"text":"דובר צהל אזורים א' וו'"},{"start":819.26,"end":821.34,"text":"תלכימי פה"},{"start":821.34,"end":825.57,"text":"היי! מה אמרתי?"},{"start":825.57,"end":827.95,"text":"מה אמרתי?"},{"start":827.95,"end":830.01,"text":"אל תשאירו אותי לבד החדר לא אטום"},{"start":830.01,"end":832.04,"text":"היי! עוד עכשיו רוורס"},{"start":832.04,"end":834.08,"text":"עכשיו רוורס בואו קדימה רוורס"},{"start":834.08,"end":836.83,"text":"בואו בואו תרים תקנאץ'"},{"start":836.83,"end":838.83,"text":"רוורס עוד עוד עוד חנייה עושה עוד"},{"start":838.83,"end":843.59,"text":"עוד אופה די די אופה זהו זהו"},{"start":843.59,"end":849.56,"text":"אופה תודה רבה חבר'ה תודה רבה לכם"},{"start":849.56,"end":851.85,"text":"אני לא דבר שיחקתם אותה זהו"},{"start":851.85,"end":854.04,"text":"אם לא אוכפתכם אני פה הולך למשרד"},{"start":854.04,"end":856.04,"text":"סדר? חכו לי פה בחמש צריך להגיע הביתם"},{"start":856.04,"end":858.04,"text":"בסדר? אני פה במשרד"},{"start":858.04,"end":860.04,"text":"אחלה חבר'ה תודה רבה"},{"start":860.04,"end":867.85,"text":"שלום קאמן ברמז'ו סעודיה"},{"start":867.85,"end":869.85,"text":"מנתלתקציונל האסראילי"},{"start":869.85,"end":871.85,"text":"מנעור של אמלכות"},{"start":871.85,"end":873.85,"text":"ותאסע עונוש דוקקה"},{"start":873.85,"end":875.85,"text":"בקרוג'רס בעדן כליל"},{"start":875.85,"end":877.85,"text":"פלש גורדון פלש"},{"start":877.85,"end":880.55,"text":"קובי עוז"},{"start":880.55,"end":882.89,"text":"קובי מסל חיר"},{"start":882.89,"end":885.31,"text":"מסל פול"},{"start":885.31,"end":888.91,"text":"כן"},{"start":888.91,"end":889.01,"text":"קובי עוז"},{"start":888.91,"end":890.91,"text":"מנתלתקציונל האסראילי"},{"start":890.91,"end":892.91,"text":"ותאסע עונוש סטיב עוזטין"},{"start":892.91,"end":894.91,"text":"עדיבי סקן הון"},{"start":894.91,"end":896.91,"text":"תרפל הקבוש המילעדי טלפיסיון"},{"start":896.91,"end":899.07,"text":"לא, האמת היא שקובי עוז זה בעלף"},{"start":899.07,"end":901.02,"text":"זה עברות"},{"start":901.02,"end":903.04,"text":"לפני זה הוזן ועכשיו יש לזה משמעות של עוז"},{"start":903.04,"end":905.04,"text":"שזה חסר משמעות לחלוטין"},{"start":905.04,"end":907.04,"text":"איך נאיך נאייל לא"},{"start":907.04,"end":909.04,"text":"וסבסיאן פלטרשקום לאה"},{"start":909.04,"end":911.76,"text":"מה זאת אומרת? איזה לאה?"},{"start":911.76,"end":912.77,"text":"אה"},{"start":912.77,"end":914.77,"text":"וליד הוא ראה תפל בתל תרק"},{"start":914.77,"end":916.77,"text":"איזה תלת תפל בתל עתיק לאה עוז"},{"start":916.77,"end":918.83,"text":"אה לאה עוז"},{"start":918.83,"end":919.83,"text":"לא לאה עוז זה בכלל"},{"start":919.83,"end":920.83,"text":"זה שם משפחה אחר"},{"start":920.83,"end":921.83,"text":"זה בעין"},{"start":921.83,"end":922.83,"text":"לאה עוז"},{"start":922.83,"end":923.83,"text":"קובי עוז"},{"start":923.83,"end":924.83,"text":"לאה עוז"},{"start":924.83,"end":927.83,"text":"מן ברמזו סעודיה מנתלפיסון לעסרעילי"},{"start":927.83,"end":928.83,"text":"עוז"},{"start":928.83,"end":930.21,"text":"איוע"},{"start":930.21,"end":932.17,"text":"מן ברמזו סעודיה"},{"start":932.17,"end":933.17,"text":"פלטרשעון עוז"},{"start":933.17,"end":934.49,"text":"לא לא"},{"start":934.49,"end":936.93,"text":"זה קובי עוז"},{"start":936.93,"end":937.89,"text":"לאה עוז"},{"start":937.89,"end":939.27,"text":"עוז"},{"start":939.27,"end":940.27,"text":"ומה יפים על אלות"},{"start":940.27,"end":941.27,"text":"ביחנען"},{"start":941.27,"end":942.27,"text":"מגייבר"},{"start":942.27,"end":943.62,"text":"עוז"},{"start":943.62,"end":943.72,"text":"זה בה"},{"start":943.62,"end":944.62,"text":"קובי"},{"start":944.62,"end":945.71,"text":"עטיבה"},{"start":945.71,"end":950.04,"text":"פלטרשע קום אמן ברמזו סע"},{"start":950.04,"end":951.16,"text":"אה"},{"start":951.16,"end":952.47,"text":"כן אני אשמח"},{"start":952.47,"end":953.47,"text":"אני אשמח לכתום"},{"start":953.47,"end":954.47,"text":"איך קוראים לבן שלך?"},{"start":954.47,"end":955.82,"text":"עבד"},{"start":955.82,"end":957.39,"text":"עבד"},{"start":957.39,"end":958.39,"text":"עבד זה בעין"},{"start":958.39,"end":959.39,"text":"או באלף"},{"start":959.39,"end":960.39,"text":"אולי דורי עדפל"},{"start":960.39,"end":961.39,"text":"בטעיל לאוין אלען זה"},{"start":961.39,"end":962.49,"text":"בה"},{"start":962.49,"end":963.49,"text":"בה"},{"start":963.49,"end":964.49,"text":"הבנתי"},{"start":964.49,"end":965.48,"text":"לאוין אלען זה"},{"start":965.48,"end":966.58,"text":"אה"},{"start":966.58,"end":967.58,"text":"אנחנו הולכים לראות"},{"start":967.58,"end":968.57,"text":"וידאו קליפ"},{"start":968.57,"end":969.57,"text":"שהוא גרסה נמוכה"},{"start":969.57,"end":970.57,"text":"לשיר"},{"start":970.57,"end":971.57,"text":"של טיפקס"},{"start":971.57,"end":973.73,"text":"שיר שנקרא מעשית"},{"start":973.73,"end":974.73,"text":"והוידאו קליפ הזה נקרא"},{"start":974.73,"end":975.73,"text":"הומור נמוך"},{"start":975.73,"end":976.73,"text":"אבל לפני זה"},{"start":976.73,"end":977.73,"text":"רוך פלבט"},{"start":977.73,"end":978.73,"text":"רוך פטלת הרשק"},{"start":978.73,"end":979.73,"text":"ומנורי"},{"start":979.73,"end":980.73,"text":"בסם זועמות"},{"start":980.73,"end":981.95,"text":"כן נראה פרסומות"},{"start":981.95,"end":983.25,"text":"אה"},{"start":983.25,"end":984.39,"text":"אה"},{"start":984.39,"end":985.57,"text":"אה"},{"start":985.57,"end":986.98,"text":"אה"},{"start":986.98,"end":988.26,"text":"אה"},{"start":988.26,"end":989.26,"text":"אה"},{"start":989.26,"end":991.12,"text":"אה"},{"start":991.12,"end":992.63,"text":"אה"},{"start":992.63,"end":993.63,"text":"אה"},{"start":993.63,"end":1040.35,"text":"אה"},{"start":1040.35,"end":1041.35,"text":"שאלתי מה"},{"start":1041.35,"end":1042.35,"text":"גבר שלך עושה"},{"start":1042.35,"end":1043.35,"text":"אמר לי"},{"start":1043.35,"end":1044.35,"text":"שביליש לי עובד בקורסבל כזה בשוק"},{"start":1044.35,"end":1046.35,"text":"עוד לא הספקתי להשתחל לפוך"},{"start":1046.35,"end":1047.35,"text":"עוד לא הספקתי לה"},{"start":1047.35,"end":1050.48,"text":"ראיתי הנה מסקמן סכסור"},{"start":1050.48,"end":1052.48,"text":"והוק נשאר לי רק עומו"},{"start":1052.48,"end":1053.47,"text":"נמור"},{"start":1053.47,"end":1056.4,"text":"שמעת על הפרסי שהזמין את חבר שלו"},{"start":1056.4,"end":1057.4,"text":"לארוחת צהריים?"},{"start":1057.4,"end":1058.4,"text":"וואלה לא"},{"start":1058.4,"end":1059.66,"text":"זפה לה"},{"start":1059.66,"end":1060.66,"text":"גם לא תשמע"},{"start":1060.66,"end":1061.66,"text":"מה?"},{"start":1061.66,"end":1091.82,"text":"תבוא לבד אבי כיבוד"},{"start":1091.82,"end":1092.82,"text":"רגת רק אותך"},{"start":1092.82,"end":1095.74,"text":"שתי הקפה אתה חמוד"},{"start":1095.74,"end":1096.74,"text":"פתאום ראיתי מי"},{"start":1096.74,"end":1100.4,"text":"רגשתי שאני טיפה מאוך"},{"start":1100.4,"end":1101.4,"text":"הוא בלבי כבר"},{"start":1101.4,"end":1104.87,"text":"לא לבד וזה עוזר סיפור"},{"start":1104.87,"end":1106.87,"text":"מה שנשאר בסוף זה רק עומו"},{"start":1106.87,"end":1107.87,"text":"נמוך"},{"start":1107.87,"end":1110.38,"text":"למה הסיפורים בגרוז יעפות ככה?"},{"start":1110.38,"end":1113.17,"text":"כי עם כנף אחד הם סותמות"},{"start":1113.17,"end":1115.1,"text":"אני לא שומע"},{"start":1115.1,"end":1117.33,"text":"מעשית לי מעשית"},{"start":1117.33,"end":1126.56,"text":"תריה מסליזה דור"},{"start":1126.56,"end":1128.56,"text":"יחד שוז מבוץ מייה"},{"start":1128.56,"end":1130.56,"text":"זה תשע אמרה לבמבר"},{"start":1130.56,"end":1132.82,"text":"זה נקסטראורדינר"},{"start":1132.82,"end":1134.82,"text":"אין פרה"},{"start":1134.82,"end":1136.98,"text":"לא תהיה"},{"start":1136.98,"end":1138.98,"text":"רגע רגע זה מעשית לי מעשית"},{"start":1138.98,"end":1140.98,"text":"או מעשית לי מעשית"},{"start":1140.98,"end":1143.01,"text":"זה לא אותו דבר"},{"start":1143.01,"end":1145.01,"text":"זה שני הדברים שונים לקמרה"},{"start":1145.01,"end":1152.38,"text":"אין לה עוד פעם פרסומות"},{"start":1152.38,"end":1155.36,"text":"בוא בוא נלך לעבוד"},{"start":1155.36,"end":1163.36,"text":"איזה לעבוד"},{"start":1163.36,"end":1165.36,"text":"איזה לעבוד"},{"start":1165.36,"end":1167.36,"text":"איזה לעבוד"},{"start":1167.36,"end":1167.46,"text":"לא הולכים לעבוד"},{"start":1167.36,"end":1169.67,"text":"למה?"},{"start":1169.67,"end":1171.67,"text":"למה סידרתי שני פרפרים תאילנדים"},{"start":1171.67,"end":1173.67,"text":"תראה תראהכם הפים"},{"start":1173.67,"end":1175.67,"text":"וואו כך ימינה יאללה אוף"},{"start":1175.67,"end":1177.67,"text":"בוא נשגיחה כשלא תחילו להתפרפר בואו"},{"start":1177.67,"end":1179.67,"text":"יאללה אוף יש לך עוד אוף"},{"start":1179.67,"end":1181.67,"text":"קדימה"},{"start":1181.67,"end":1190.66,"text":"משרד הפרסום שלנו חכמוני הגמוני תמנון"},{"start":1190.66,"end":1192.66,"text":"החליט ללכת על האתגר שהצבתם בפנינו"},{"start":1192.66,"end":1194.66,"text":"ואנחנו החלטנו גם על איזה קונספציה חדשה"},{"start":1194.66,"end":1196.66,"text":"על משהו מבריק רעיון גאוני בעיניי"},{"start":1196.66,"end":1198.66,"text":"משהו שעוד לא היה בארץ"},{"start":1198.66,"end":1200.66,"text":"שים לב אתה יושב"},{"start":1200.66,"end":1202.66,"text":"בוא נשמע"},{"start":1202.66,"end":1204.66,"text":"אנחנו החלטנו למכור את המיקרופונים שלכם"},{"start":1204.66,"end":1206.66,"text":"באמצעות סקס"},{"start":1206.66,"end":1208.61,"text":"סקס כמקדם מחירות"},{"start":1208.61,"end":1210.88,"text":"סקס זה קצת מהפכני לא?"},{"start":1210.88,"end":1212.88,"text":"אני יודע צריך אומץ בשביל לעשות את הדברים האלה"},{"start":1212.88,"end":1214.88,"text":"אבל זה עוד לא עשו את זה בארץ"},{"start":1214.88,"end":1216.88,"text":"זה משהו חדשני"},{"start":1216.88,"end":1219.01,"text":"תאמין לי זה יהיה טוב"},{"start":1219.01,"end":1223.22,"text":"אני אבל לא מבין מה הקשר בין סאונד של מיקרופון לסקס"},{"start":1223.22,"end":1226.22,"text":"אנשים אוהבים סקס, סקס אוהב אנשים ולהפך"},{"start":1226.22,"end":1227.22,"text":"בדיוק"},{"start":1227.22,"end":1228.22,"text":"ספציפיק למיקרופון"},{"start":1228.22,"end":1232.22,"text":"עזוב אותך את המיקרופון אתה יודע מה עושים זוג ציצים על המסך"},{"start":1232.22,"end":1238.1,"text":"אבל רגע רגע, אולי נעזוב את הסקס"},{"start":1238.1,"end":1241.07,"text":"לא נזרוק אותו אבל בוא נלך אולי על משהו אחר"},{"start":1241.07,"end":1243.7,"text":"לא נוח לך עם סקס"},{"start":1243.7,"end":1245.7,"text":"אם לא נוח לך עם סקס אפשר ללכת על מין"},{"start":1245.7,"end":1248.67,"text":"מין גם כן מוכר, תחשוב אישה עם מיקרופון ביד"},{"start":1248.67,"end":1251.79,"text":"אומרת אני רוצה את הדבר הארוך הזה"},{"start":1251.79,"end":1252.79,"text":"זה מוכר"},{"start":1252.79,"end":1255.79,"text":"אם אתה לא רוצה מין תמיד אפשר לעשות סוויץ' לכיוון הארוטיקה"},{"start":1255.79,"end":1257.79,"text":"זה גם עובד, תאמין לי"},{"start":1257.79,"end":1259.05,"text":"כן"},{"start":1259.05,"end":1260.05,"text":"אתם אוכלתם משהו?"},{"start":1260.05,"end":1261.05,"text":"כן כן"},{"start":1261.05,"end":1262.05,"text":"אז בוא נראה"},{"start":1262.05,"end":1263.05,"text":"בוא נראה"},{"start":1263.05,"end":1264.05,"text":"שים לב, שים לב, אתה יושב"},{"start":1264.05,"end":1266.2,"text":"בחרנו איזה דמות חושנית"},{"start":1266.2,"end":1268.33,"text":"שהפכה לסמל ארוטיקה"},{"start":1268.33,"end":1270.21,"text":"שים לב, תראה אותה בפרסמה"},{"start":1270.21,"end":1272.51,"text":"אז היית אצלו"},{"start":1272.51,"end":1273.57,"text":"לא"},{"start":1273.57,"end":1275.57,"text":"הייתי איתו"},{"start":1275.57,"end":1278.57,"text":"מבין את ההבדל אדון חוקר"},{"start":1278.57,"end":1280.89,"text":"כדאי שתמחקי את החיוך הזה"},{"start":1280.89,"end":1283.07,"text":"זה, מצאנו במיטה שלו"},{"start":1283.07,"end":1285.07,"text":"ואותו מצאנו בתוך הפריזר"},{"start":1285.07,"end":1287.07,"text":"את מוכנה לחזור על שמך?"},{"start":1287.07,"end":1288.02,"text":"כן"},{"start":1288.02,"end":1289.1,"text":"כאן ג'ודי לא צערו"},{"start":1289.1,"end":1291.1,"text":"נובקרפים סמרו"},{"start":1291.1,"end":1293.1,"text":"ויצטום אינסטינק בסיסי"},{"start":1293.1,"end":1295.1,"text":"שרון רולינגסטון קים בסינג'ר"},{"start":1295.1,"end":1297.13,"text":"מה כך עוד על שענו?"},{"start":1297.13,"end":1298.13,"text":"תודה, תודה, זה מספר"},{"start":1298.13,"end":1301.22,"text":"אתה רוצה להגיד לי שרק השם שלי"},{"start":1301.22,"end":1303.47,"text":"מביא אותך לסיפוק?"},{"start":1303.47,"end":1304.82,"text":"שוקי"},{"start":1304.82,"end":1306.94,"text":"בואי נחזור לעובדות"},{"start":1306.94,"end":1308.93,"text":"בשעה שמונה חיברת אותו לחשמל"},{"start":1308.93,"end":1311.93,"text":"כזאת אני מחשמלת"},{"start":1311.93,"end":1315.34,"text":"ראית איך פתיתי אותך?"},{"start":1315.34,"end":1318.34,"text":"איזה חושנית אני"},{"start":1318.34,"end":1320.88,"text":"בואי נחזור לחקירה"},{"start":1320.88,"end":1322.65,"text":"איפה היית אחר כך?"},{"start":1322.65,"end":1324.65,"text":"הייתי עם הנרצח"},{"start":1324.65,"end":1326.8,"text":"ביחד במיטה"},{"start":1326.8,"end":1329.8,"text":"אה איזה שובב"},{"start":1329.8,"end":1331.8,"text":"אך לב לא לב זהב"},{"start":1331.8,"end":1334.79,"text":"ואז לקחתי את המיקרופון"},{"start":1334.79,"end":1336.79,"text":"וחיוולתי לפה"},{"start":1336.79,"end":1339.08,"text":"אסור לראיין פה"},{"start":1339.08,"end":1341.08,"text":"מה תעשה לי?"},{"start":1341.08,"end":1343.08,"text":"תיקח אותי למשטרה"},{"start":1343.08,"end":1349.65,"text":"הייתי טוב במיטה עם זה?"},{"start":1349.65,"end":1355.92,"text":"מה יש לך בדיוק בראש אדון חוקר?"},{"start":1355.92,"end":1363.21,"text":"אני חושבת שראיתם יותר מדי"},{"start":1363.21,"end":1365.37,"text":"סרטים"},{"start":1365.37,"end":1367.68,"text":"אז מה עשיתם שם שלושתיכם?"},{"start":1367.68,"end":1369.89,"text":"את הוא המיקרופון"},{"start":1369.89,"end":1373.08,"text":"מכיוון שהמיקרופון הוא סמל פלי"},{"start":1373.08,"end":1375.08,"text":"אני שאלתי"},{"start":1375.08,"end":1377.08,"text":"והוא ענה לי"},{"start":1377.08,"end":1379.02,"text":"אהה חרוז"},{"start":1379.02,"end":1381.04,"text":"רגע רגע רגע רגע רגע אני לא מבין"},{"start":1381.04,"end":1383.29,"text":"את התכוון שהוא ענה לי"},{"start":1383.29,"end":1385.29,"text":"או שהוא ענה לי?"},{"start":1385.29,"end":1387.77,"text":"זה שני דברים שונים לגמרי"},{"start":1387.77,"end":1390.77,"text":"אההה זה קטע שלי עכשיו"},{"start":1390.77,"end":1392.77,"text":"לא שלך אל תפריע"},{"start":1392.77,"end":1394.77,"text":"את מוכנה לענות בבקשה"},{"start":1394.77,"end":1396.93,"text":"אני מתעניין במיקרופון שלי"},{"start":1396.93,"end":1399.09,"text":"אההה ואני בשלך"},{"start":1399.09,"end":1401.12,"text":"את מיקרופונים יש למי ושתת"},{"start":1401.12,"end":1403.85,"text":"רוצה ביס?"},{"start":1403.85,"end":1406.27,"text":"שוקי"},{"start":1406.27,"end":1412.99,"text":"מיקרופון הסמל הפעלי היחידי שעדיין לא השתמשו בו בפרסומות"},{"start":1412.99,"end":1416.04,"text":"מה עשית לי מה עשית?"},{"start":1416.04,"end":1428.08,"text":"שוז מבוץ ליה"},{"start":1428.08,"end":1430.08,"text":"זה תל שעמרה לבמבר"},{"start":1430.08,"end":1432.3,"text":"זה נקסטרעורדינייר"},{"start":1432.3,"end":1434.43,"text":"נקסטרעורדינייר"},{"start":1434.43,"end":1435.43,"text":"מנברה כהודיעה"},{"start":1435.43,"end":1436.38,"text":"כתאה זה ענור"},{"start":1436.38,"end":1437.62,"text":"מה כהיבר?"},{"start":1437.62,"end":1439.62,"text":"רגע רגע זה מעשית לי מעשית"},{"start":1439.62,"end":1441.62,"text":"או מעשית לי מעשית"},{"start":1441.62,"end":1442.62,"text":"זה לא עוד את הפער"},{"start":1442.62,"end":1444.62,"text":"ששני דברים שעונים לקמרה"},{"start":1444.62,"end":1451.58,"text":"נקסטרעורדינייר"}]