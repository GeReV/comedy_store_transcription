[{"start":33.76,"end":83.81,"text":"אורי הקב, לא פרמי פה, אורי הקב"},{"start":83.81,"end":97.1,"text":"אולי, לך, ניסי איתך בחזות"},{"start":97.1,"end":99.69,"text":"עוד פעם"},{"start":99.69,"end":100.25,"text":"אופה"},{"start":100.25,"end":102.07,"text":"אופה"},{"start":102.07,"end":110.89,"text":"אחי, יש לי מזל בול בלי טוטו"},{"start":110.89,"end":111.67,"text":"יאללה, בואו"},{"start":111.67,"end":123.19,"text":"ערב צח, ערב זח, שוב אנחנו בחלסטר של ז'וז'ו"},{"start":123.19,"end":124.77,"text":"והפעם ז'וז'ו מודאג"},{"start":124.77,"end":132.14,"text":"בימא שלי, רציתי לדבר איתכם על כל הילדים החדשים, הדור החדש שצומח לנו של ילדים לפלפים עם עיגולדים"},{"start":132.14,"end":133.26,"text":"ולמה אני מתכוון?"},{"start":133.26,"end":137.83,"text":"שבוע שעבר הלכתי לבקר אצל אחותי ג'ורג'ת ואצל ג'סי קלמן"},{"start":137.83,"end":140.54,"text":"כן, קלמן, בימא שלי עם פרצוף של זלמן"},{"start":140.54,"end":142.82,"text":"לא יומן איך אחותי נפלה כל כך חזק, לא יומן"},{"start":142.82,"end":147.68,"text":"יש להם ילד קטן, בלונדיני, עם שיניים עקומות שקוראים אותו יהודה"},{"start":147.68,"end":150.53,"text":"אבל כל החבר'ה קוראים לו אודי"},{"start":150.53,"end":151.45,"text":"קוקו"},{"start":151.45,"end":156.11,"text":"באמא שלי פחד אלוהים, זה ילד עם עגולד עם באמא שלי מיקרוסקופ נייד"},{"start":156.11,"end":158.37,"text":"עכשיו הילד הזה בא אליי ועושה לי"},{"start":158.37,"end":161.55,"text":"דאנג'אז'ה, בוא נשחק ביחד במחשב"},{"start":161.55,"end":165.55,"text":"אמרתי לו, סבבי, אחי, אני והמחשב זה קלה קלות, איך אומרים?"},{"start":165.55,"end":167.23,"text":"פיס אוף כיף באמא שלי"},{"start":167.23,"end":170.37,"text":"או פינאץ, פינאץ, אני בוטניה, בוטניה"},{"start":170.37,"end":174.81,"text":"it is not my cup of tea, אתה לא בקפה שלי, סבבי"},{"start":174.81,"end":178.85,"text":"התיישבנו על המחשב, פתחנו משחק באמא שלי"},{"start":178.85,"end":181.49,"text":"אני ישר מסתכל על המחשב, לא הבנתי מה קורה"},{"start":181.49,"end":184.07,"text":"חשבתי כמו בסנוקר, דופקים, מרביצים, משהו"},{"start":184.07,"end":186.95,"text":"לא, יש שם מקשים כאלה קטנים"},{"start":186.95,"end":189.51,"text":"וכתוב עליהם באותיות של אנגלית, באמא שלי"},{"start":189.51,"end":193.93,"text":"ובצד מונח לו, אכבר, אכברוש באמא שלי"},{"start":193.93,"end":195.67,"text":"הורדתי על אבנה, לא ידעתי מה לעשות"},{"start":195.67,"end":197.93,"text":"אמר לי לדעזוב עם זם שחקים, אהלה"},{"start":197.93,"end":199.29,"text":"איזה ילדים מוזרים"},{"start":199.29,"end":201.81,"text":"התחלנו לשחק טטריס באמא שלי"},{"start":201.81,"end":202.57,"text":"מה זה טטריס?"},{"start":202.57,"end":206.97,"text":"זה משחק שמפילים עליך לבנים בלוקים באמא שלי"},{"start":206.97,"end":209.03,"text":"ואתה משדר אותם ערימות, ערימות"},{"start":209.03,"end":213.01,"text":"עדיף איטונג, באמא שלי, לא הבנתי מה רוצה, ילד שיחקנו"},{"start":213.01,"end":216.92,"text":"אלה, התחלה באמא שלי, איך ששיחקנו, עוד לא עברה דקה"},{"start":216.92,"end":219.6,"text":"ניהיה לי, גם עובר, באמא שלי, גם עובר"},{"start":219.6,"end":221.68,"text":"עברתי, סבבי, העיקר עברתי ולא נכשלתי"},{"start":221.68,"end":223.9,"text":"האמא שלי לקח ממני את האחבר"},{"start":223.9,"end":226.76,"text":"בלי לחשוב פעמיים באמא שלי במשך שבע שעות"},{"start":226.76,"end":230.18,"text":"הוא רק מזחק ורק מזחק ואני רואה באמא שלי, המסכים עוברים"},{"start":230.18,"end":232.94,"text":"פתאום טטריס, פתאום מחשפות, הוא הרג שלוש עדים"},{"start":232.94,"end":237.76,"text":"הוא צונח עם עזית הקלבה הצדחנית, הפקמנו חלו את הדובדבן, מה עושה הילד הזה?"},{"start":237.76,"end":243.9,"text":"נבהלתי באמא שלי, בשוב הופיעה לו על המסך, 208,907 ניצחת"},{"start":243.9,"end":250.84,"text":"פה דוד ג'וזו איבד את הבלמיר, באמא שלי ילד קטני נצח אותי במחשב"},{"start":250.84,"end":255.13,"text":"ישר התעצבנתי, אמרתי ילד עמוד, גמרנו על המחשב"},{"start":255.13,"end":259.32,"text":"דבר ראשון, לקחתי את האחבר, שמתי לי אדום על קודת האחברים עם גבינה ציובית"},{"start":259.32,"end":262.16,"text":"באמא שלי, תוך שניה, תפסנו את האחבר"},{"start":262.16,"end":265.82,"text":"דבר שני, לקחתי כ-300 באמא שלי, פתחתי את המחשב"},{"start":265.82,"end":269.0,"text":"ועל כל הג'ונקים של המחשב, השפרצתי, הרגתי אותה ואחד אחד"},{"start":269.0,"end":270.56,"text":"המחשב מי חוסל"},{"start":270.56,"end":273.52,"text":"לקחתי את הילד באמא שלי, הורדתי אותו למטה לשכונה"},{"start":273.52,"end":279.2,"text":"שיביאו לו תקת שפחות, שיראה אור שמש, שישתזף, שיהיה ילד גבר באמא אמא שלי"},{"start":279.2,"end":281.41,"text":"מוסר אסכל, הורים יקרים"},{"start":281.41,"end":285.36,"text":"אם אתם רוצים שיהיה לכם ילד גבר, שרירי וחזק הרבה יותר"},{"start":285.36,"end":288.37,"text":"תעיפו אותו מיד מהמסך של הקומפיוטר"},{"start":288.37,"end":290.13,"text":"ותחשבו על זה"},{"start":290.13,"end":291.99,"text":"שמתם ליבי, יצא לי חרוז"},{"start":291.99,"end":324.45,"text":"מכה חדשה פוקדת"},{"start":324.45,"end":327.26,"text":"המזלמה המשוטטת של ג'ודי"},{"start":327.26,"end":329.78,"text":"ערב טוב"},{"start":329.78,"end":336.37,"text":"כאן ג'ודי לא צהרונוב, דבורה עומר סממה, יהודה שמן אלי מלך זורקין השופט בן זונה"},{"start":336.37,"end":339.28,"text":"מכה חדשה נוחתת על המדינה"},{"start":339.28,"end":344.31,"text":"לאחר עשרים שנה בהם נהדר מן הנוף הספרותי והציבורי"},{"start":344.31,"end":347.97,"text":"שב אלינו דני דין, הרועה ואינו נראה"},{"start":347.97,"end":352.03,"text":"והפעם לא בתפקיד המושיע בעצרה"},{"start":352.03,"end":354.03,"text":"כי אם בתפקיד הצרה עצמה"},{"start":354.03,"end":357.18,"text":"לקחנו את המצלמה המשוטטת"},{"start":357.18,"end":360.18,"text":"ויצאנו לבדוק הקצע הקטע"},{"start":360.18,"end":368.84,"text":"כאן ירון זהבי, המערה החשמלית, פניקה רגוע"},{"start":368.84,"end":377.18,"text":"נשמה אני כבר, אני כבר מגיע לשיר צמטר בסדר?"},{"start":377.18,"end":378.18,"text":"כן"},{"start":378.18,"end":384.2,"text":"אני חוזר ומדגיש לציבור אין מה לדאוג"},{"start":384.2,"end":386.2,"text":"אין מה לדאוג, העינה של המשטרה פקוחה"},{"start":386.2,"end":388.2,"text":"דני דין לא התחמק מאיתנו"},{"start":388.2,"end":390.2,"text":"ועל ראש הגנב בוהר הקובע"},{"start":390.2,"end":392.61,"text":"יום טוב לך דוני, להתראות"},{"start":392.61,"end":394.61,"text":"פרופסור קטרוס, אתה הממציא הידוע של דני דין"},{"start":394.61,"end":396.61,"text":"אולי אתה מבין מה קרה לו"},{"start":396.61,"end":399.61,"text":"בוודאי שאני מבין, תראה אני המצאתי בזמנו את המים הסגולים"},{"start":399.61,"end":402.61,"text":"המים הסגולים יש להם תופעת לוואי מאוד מאוד חשובה"},{"start":402.61,"end":404.61,"text":"שדני דין לא יודע"},{"start":404.61,"end":408.77,"text":"פעם ב-20 שנה הבן אדם הופך להיות רלף, מפרצת"},{"start":408.77,"end":410.77,"text":"הוא הופך להיות מרשעת ניידת"},{"start":410.77,"end":412.77,"text":"הוא הולך ברחום מקפקף אנשים"},{"start":412.77,"end":414.77,"text":"מצחוין אותם מביא להם פלסקים באוזניים"},{"start":414.77,"end":416.77,"text":"לכן יש לנו מצוקה קשה ואנחנו עובדים"},{"start":416.77,"end":418.77,"text":"על פתרון היסטרי במעבדה"},{"start":418.77,"end":420.77,"text":"24 שעות ביממה, אני מקווה שנמצא פתרון"},{"start":420.77,"end":422.77,"text":"היי! תביטת שקרה במעבדה"},{"start":422.77,"end":424.77,"text":"צריך לעבוד, פארק טאגזון"},{"start":424.77,"end":426.77,"text":"אנחנו כבר עובדים על הנושא ואני מקווה"},{"start":426.77,"end":428.77,"text":"שתוך כמה ימים יהיה לנו פתרון, תודה לכם"},{"start":428.77,"end":434.51,"text":"צוות הצילום הנאמן שלי"},{"start":434.51,"end":436.57,"text":"פיתח מצלמה מיוחדת"},{"start":436.57,"end":438.57,"text":"בה ניתן לראות את דני דין"},{"start":438.57,"end":440.83,"text":"כעת אנו נראה"},{"start":440.83,"end":452.6,"text":"נראה את אותו אירוע בשינוי הדרת"},{"start":452.6,"end":452.7,"text":"אוהבת אותי?"},{"start":452.6,"end":454.53,"text":"כן"},{"start":454.53,"end":456.93,"text":"גם אני"},{"start":456.93,"end":457.93,"text":"אז מה נתחתן?"},{"start":457.93,"end":464.69,"text":"מי יתחתן איתך ים חוערת?"},{"start":464.69,"end":465.69,"text":"זה כול בסדר חביבי"},{"start":465.69,"end":466.69,"text":"יקח את הרישיונות"},{"start":466.69,"end":467.69,"text":"שע לשלום"},{"start":467.69,"end":468.69,"text":"תודה רבה הכל טוב"},{"start":468.69,"end":470.84,"text":"כל השוטרים מניאקים"},{"start":470.84,"end":472.13,"text":"מה אמרת?"},{"start":472.13,"end":473.13,"text":"לא אני"},{"start":473.13,"end":473.23,"text":"מה אמרת?"},{"start":473.13,"end":474.13,"text":"צא מיד מהאוטו"},{"start":474.13,"end":475.22,"text":"לא אני לא אני"},{"start":475.22,"end":476.22,"text":"את זה תגיד בוא נעדת"},{"start":476.22,"end":477.22,"text":"קדימה"},{"start":477.22,"end":478.22,"text":"בנעדת אימא שלך"},{"start":478.22,"end":479.22,"text":"מניאק"},{"start":479.22,"end":480.22,"text":"בוא נצא מיד מהאוטו"},{"start":480.22,"end":485.98,"text":"אמרתי לך"},{"start":485.98,"end":487.94,"text":"שמעון"},{"start":487.94,"end":488.86,"text":"תזהר ממני"},{"start":488.86,"end":490.26,"text":"מה קרה לי אימא שלך?"},{"start":490.26,"end":492.26,"text":"תזהר לנקנקתי באוזן בצקלחווין"},{"start":492.26,"end":493.26,"text":"תזהר"},{"start":493.26,"end":508.37,"text":"מה זה היה?"},{"start":508.37,"end":509.53,"text":"מה קרה לי אימא שלך?"},{"start":509.53,"end":510.69,"text":"לא יודע למה?"},{"start":510.69,"end":512.69,"text":"מה זה היה אסקלטן לראש?"},{"start":512.69,"end":513.94,"text":"אתה קיבל אסקלטן לראש?"},{"start":513.94,"end":514.94,"text":"כן"},{"start":514.94,"end":515.94,"text":"אני קיבלתי אסקלווין באוזן"},{"start":515.94,"end":516.94,"text":"תגידי אתה בפגר?"},{"start":516.94,"end":519.0,"text":"שמעון אצטלבט"},{"start":519.0,"end":520.0,"text":"תזהר מני אתה"},{"start":520.0,"end":521.0,"text":"שמעון אצטלבט עליי"},{"start":521.0,"end":522.0,"text":"נשפה לך"},{"start":522.0,"end":523.0,"text":"תזהר שמעון"},{"start":523.0,"end":527.0,"text":"תזהר שמעון"},{"start":527.0,"end":528.0,"text":"באיזה שמעון אני אבדך"},{"start":528.0,"end":529.0,"text":"אני מארבב אותך"},{"start":529.0,"end":530.0,"text":"מה אתה בפגר?"},{"start":530.0,"end":533.93,"text":"תשובו של דני דין כדני שובבני"},{"start":533.93,"end":535.89,"text":"הפך לחדור שלג"},{"start":535.89,"end":537.85,"text":"ונתן הזדמנות ולגיטימציה"},{"start":537.85,"end":539.85,"text":"לכל מיני סוטים אחרים"},{"start":539.85,"end":541.85,"text":"לבוא לידי ביטוי"},{"start":541.85,"end":542.95,"text":"כמו למשל"},{"start":542.95,"end":544.95,"text":"השומע ואינו נשמע"},{"start":544.95,"end":545.95,"text":"סלח לי מה שעה?"},{"start":545.95,"end":547.95,"text":"אחת עשרה וחצי"},{"start":547.95,"end":548.95,"text":"סלח לי מה שעה?"},{"start":548.95,"end":549.95,"text":"אחת עשרה וחצי"},{"start":549.95,"end":550.95,"text":"סלח לי מה שעה?"},{"start":550.95,"end":551.95,"text":"אחת עשרה וחצי"},{"start":551.95,"end":552.95,"text":"סלח לי מה שעה?"},{"start":552.95,"end":553.95,"text":"אחת עשרה וחצי"},{"start":553.95,"end":554.95,"text":"סוטי אחר"},{"start":554.95,"end":557.95,"text":"הוא הממשה שאינו משיש"},{"start":557.95,"end":564.43,"text":"טוב לך מה שאני עושה?"},{"start":564.43,"end":565.43,"text":"מה אתה עושה?"},{"start":565.43,"end":569.47,"text":"דובי"},{"start":569.47,"end":571.53,"text":"השישי שאינו שושש"},{"start":571.53,"end":573.85,"text":"דובי מרגיש בחושו השישי"},{"start":573.85,"end":576.94,"text":"דברים שאינם קורים"},{"start":576.94,"end":589.77,"text":"אני מבין שהדוניוה מבין ואינו מובן"},{"start":589.77,"end":591.77,"text":"חרשטנטי פנאה אסתקלה"},{"start":591.77,"end":594.77,"text":"חרשטנטי פנאה אסתקלה"},{"start":594.77,"end":595.86,"text":"מה?"},{"start":595.86,"end":596.98,"text":"שיש תירפנטה"},{"start":596.98,"end":601.98,"text":"וחרשטנטי פנאה אסתקלה"},{"start":601.98,"end":603.74,"text":"תודה"},{"start":603.74,"end":605.12,"text":"שלונט"},{"start":605.12,"end":609.46,"text":"וכמובן הסוטה הגדול מכולם"},{"start":609.46,"end":611.65,"text":"הצוחק שאינו מצחיק"},{"start":611.65,"end":614.65,"text":"יש לי, יש לי, יש לי, יש לי, יש לי"},{"start":614.65,"end":615.87,"text":"דני דין"},{"start":615.87,"end":617.18,"text":"לא!"},{"start":617.18,"end":618.18,"text":"דני רות!"},{"start":618.18,"end":622.14,"text":"והרי הודעה שהגיע זה אתה"},{"start":622.14,"end":625.3,"text":"פרופסור קאטרוס מצא פתרון"},{"start":625.3,"end":627.29,"text":"לבעייתו של דני דין"},{"start":627.29,"end":630.51,"text":"ודני דין ההולכים בשולי הדרכים"},{"start":630.51,"end":632.54,"text":"ודובי דובי דוברמן"},{"start":632.54,"end":635.79,"text":"אין כמוך רב רמן"},{"start":635.79,"end":637.82,"text":"שלום לכולם ובכן פרופסור קאטרוס"},{"start":637.82,"end":639.82,"text":"כן המציא פתרון לבעיה"},{"start":639.82,"end":640.82,"text":"יש לי כאן גלולית"},{"start":640.82,"end":643.01,"text":"גלולית לבנה קטנה וחמודה"},{"start":643.01,"end":645.01,"text":"מה שהיא פועלת זה בצורה כזאת"},{"start":645.01,"end":647.14,"text":"אתה בולע את הגלולית"},{"start":647.14,"end":649.14,"text":"ואז מבן אדם שאתה למעשה"},{"start":649.14,"end":650.14,"text":"היית רגיל בן אדם רגיל"},{"start":650.14,"end":653.14,"text":"אתה הופך להיות רואה ואינו נראה"},{"start":653.14,"end":654.14,"text":"ודני דין הופך להיות"},{"start":654.14,"end":656.14,"text":"מתשופר שאיננו מתשפח"},{"start":656.14,"end":658.14,"text":"זאת אומרת אתה יכול לנקום בו"},{"start":658.14,"end":660.14,"text":"לתשפח אותו והוא לא יראה מאיפה"},{"start":660.14,"end":662.31,"text":"תבוא לו עקיף כידה"},{"start":662.31,"end":665.15,"text":"בואי נשימון עוד פעם כפכף"},{"start":665.15,"end":667.53,"text":"נשבע לך שימון הנה כך"},{"start":667.53,"end":669.45,"text":"בואי נהיה"},{"start":669.45,"end":676.41,"text":"יאללה"},{"start":676.41,"end":678.41,"text":"בואי נהיה"},{"start":678.41,"end":680.47,"text":"בואי נהיה"},{"start":680.47,"end":690.21,"text":"בואי נהיה"},{"start":690.21,"end":692.21,"text":"חפה לקיצה פרשייה נוספת"},{"start":692.21,"end":694.21,"text":"וגם דני דין"},{"start":694.21,"end":696.21,"text":"גיבור ילדותינו הפך מדמות"},{"start":696.21,"end":700.21,"text":"וחסרת גוף למטרת חסר נשמה"},{"start":700.21,"end":702.21,"text":"כאן ז'ודי לא צהרון או גורי אל אופק"},{"start":702.21,"end":704.21,"text":"שטרייט וורצל בורשטיין לדר שטקל"},{"start":704.21,"end":706.32,"text":"אסקיפניס אייניל אלון שריץ"},{"start":706.32,"end":708.8,"text":"גליל ארון פדר אל עצמי"},{"start":708.8,"end":710.91,"text":"בית שען"},{"start":710.91,"end":724.03,"text":"למה אני אוהב לשתות בירה"},{"start":724.03,"end":726.03,"text":"למה? כי אני אוהב"},{"start":726.03,"end":728.03,"text":"לטפוס ראש"},{"start":728.03,"end":735.24,"text":"למה אני אוהב לשתות בירה?"},{"start":735.24,"end":737.24,"text":"למה? לסיני"},{"start":737.24,"end":739.24,"text":"למה? אני אוהב לנקות את הראש"},{"start":739.24,"end":741.24,"text":"למה?"},{"start":741.24,"end":743.24,"text":"לנקות אני מנקה ראש"},{"start":743.24,"end":745.24,"text":"רגע יש לי יש לי יש לי"},{"start":745.24,"end":747.84,"text":"למה אני אוהב לפתור את השבצי היגיון"},{"start":747.84,"end":749.84,"text":"למה? כי אני אוהב לשבור את הראש אני"},{"start":749.84,"end":751.84,"text":"אני אוהב לשבור את הראש"},{"start":751.84,"end":755.98,"text":"יש לי יש לי יש לי"},{"start":755.98,"end":758.27,"text":"למה יש לו כאב ראש?"},{"start":758.27,"end":760.41,"text":"כי אני צועק לו באוזן"},{"start":760.41,"end":762.45,"text":"אלו"},{"start":762.45,"end":765.45,"text":"הלו! איי! מישהו בבית!"},{"start":765.45,"end":769.0,"text":"פאנט!"},{"start":769.0,"end":771.03,"text":"יו, אני צויק לו באותן!"},{"start":771.03,"end":774.03,"text":"אווו! אווו! אווו!"},{"start":774.03,"end":785.48,"text":"טוב, והרי תקציר החדשות כאן במפזק של ז'ק בערוץ הקהילתי שלכם."},{"start":785.48,"end":789.48,"text":"פרס נובל לציור, מוענק השנה לצייר הישראלי יואל פנדה."},{"start":789.48,"end":791.57,"text":"צוות הצילום יצא אליו."},{"start":791.57,"end":793.92,"text":"אוקיי, שקט אולפן רץ!"},{"start":793.92,"end":795.01,"text":"מורי!"},{"start":795.01,"end":795.93,"text":"אוקיי!"},{"start":795.93,"end":797.52,"text":"שלוש! אקשו!"},{"start":797.52,"end":801.52,"text":"ערב טוב, אני יואל פנדה, צייר אומן וחתן פרס נובל בישראל."},{"start":801.52,"end":805.52,"text":"את היצירה הזאת, יצירת המופת, הקדשתי לה שנה שלמה עד שהגעתי אליה."},{"start":805.52,"end":807.52,"text":"קאט! קאט! קאט! יופי!"},{"start":807.52,"end":809.52,"text":"עבדת היפה מצלבה, אבל יש לי בהם הציור."},{"start":809.52,"end":813.52,"text":"פשוט הצבע, הוא נבלה לי ביחד עם הקומפלקס הכללי."},{"start":813.52,"end":815.52,"text":"לכן תן לי רק לסדר את הטיפה."},{"start":815.52,"end":817.52,"text":"לא לעתידה, ממש!"},{"start":817.52,"end":820.74,"text":"זה הכל, עכשיו הצהוב ייתן לנו חיים אחרים, בסדר?"},{"start":820.74,"end":822.8,"text":"מצוין, בבקשה!"},{"start":822.8,"end":823.8,"text":"אוקיי?"},{"start":823.8,"end":827.17,"text":"שלוש, שתיים, אחת, אקשוי!"},{"start":827.17,"end":832.17,"text":"היצירה הזאת שזיקתה אותי בפרס, היא חלק ממני, היא חלק מנשמתי, את כל כולי כת..."},{"start":832.17,"end":840.17,"text":"לא טוב, לא טוב, לא טוב, תראה כל הכחול הזה מסביב, נורא נורא נבלה לי, אתה בסך הכל נהדרים, תראה זה נותן לו חיים אחרים, אוקיי?"},{"start":840.17,"end":846.59,"text":"זהו זה, עכשיו זה מצוין, אוקיי, מוכן? זהו, עכשיו זה יופי, קדימה, לה מצלבה!"},{"start":846.59,"end":848.64,"text":"תלוש, שתיים, אחת, אקשוי!"},{"start":848.64,"end":853.12,"text":"ביצירה הזאת, שי שלי וכל כולה בערך שלי..."},{"start":853.12,"end":858.09,"text":"קד, קד, אוקיי, אין ספק, היצירה לא מתאימה, היא פשוט לא מצטלמת טוב."},{"start":858.09,"end":861.05,"text":"היא לא אכפת לך, אני פשוט נשים את זה במקום, בסדר?"},{"start":861.05,"end":862.09,"text":"זהו זה, עכשיו זה יעבור..."},{"start":862.09,"end":864.09,"text":"מה זה אבל, אני לא מגיע את הציור הזה, מה מה זה?"},{"start":864.09,"end":867.09,"text":"בוודאי, זה הציור שלי, לך לשם, תסתכל מה קורה."},{"start":867.09,"end":868.09,"text":"אוקיי, קדימה, לך."},{"start":868.09,"end":870.09,"text":"אוקיי, תה לי מצלבה, המצלבה הזאת."},{"start":870.09,"end":874.37,"text":"אוקיי, שלום לכם. ובכן, זהו הציור שהזכה בשנה הבאה בפרס הנובל."},{"start":874.37,"end":876.37,"text":"זהו הציור שלי."},{"start":876.37,"end":882.37,"text":"כמו ועוד ציורים יפים אחרים אפשר לקנות אצלי בגלריה ורחוב סמטת האקרב 13 יפו. אלה חזק."},{"start":882.37,"end":888.75,"text":"הזמר האמריקני מייקל ג'קסון עבר ניתוח פלסטי נוסף וחרגע הוא נראה כך."},{"start":888.75,"end":897.18,"text":"גם אחותו של מייקל ג'קסון, לטויה ג'קסון, עברה ניתוח פלסטי בכדי להידמות לאחיה."},{"start":897.18,"end":904.76,"text":"הניתוח הצליח למרות תקלה קטנה וחרגע היא נראית כך."},{"start":904.76,"end":905.69,"text":"לאבולאפיה שלום."},{"start":905.69,"end":918.42,"text":"פרס נובל בתחום אמנות המחירה מוענק השנה לכהנת המחירות הגדולה ממכוערת, הרי תגובתה, ולנושא אחר לגמרי."},{"start":918.42,"end":928.85,"text":"נמצאתי כאן באולפן הקולנוען הישראלי נורי ברבק שזכה בפרס נובל לאומנות הקולנוע על מחקרו בנושא הקונטיניויטי. ערב טוב."},{"start":939.0,"end":969.38,"text":"כן נורי ספר לנו קודם כל מהי קונטיניויטי. עובכן קונטיניויטי כל אחד מכיר זה מושג מתחום הקולנוע שמשמעותו המשך יוטה. כלומר? כלומר נניח ניקח סצנה לדוגמה אדם שבאותה סצנה לבוש בצבע ירוק לא נראה אותו בשום צבע אחר במהלך הסצנה. אולי אתה יכול לתת לנו עוד דוגמה. למשל בסרטים שאינם איכותיים כל כך ניתן לראות בחורה יוצאת"},{"start":969.38,"end":999.94,"text":"מבית בסמלה בצבע אפור. לפתע פתאום בהמשך הסצנה אתה רואה אותה בחורה. לבשת מיני אדמדם. יש לך עוד דוגמאות לחוסר המשכיות? בטח. תראי לפעמים יש בסרטים הערביים. כן? אתה יכול לראות את הכוכב ובא לתת מכת קרטה לאיזה בלוקים. ופתאום בסוף הסצנה כל הבלוקים הופכים לבלאצות. מעניין. כמה שנים עבדת למחקר הזה?"},{"start":999.94,"end":1003.9,"text":"ארח כשבע שנים. אלבר! וזה טלפן את רטר!"},{"start":1003.9,"end":1007.95,"text":"אם כן, הרשה לי לברך אותך על זכייתך בפרס נובל."},{"start":1007.95,"end":1013.95,"text":"באמת תודה רבה בשמי ובשם כל הקבוצה ואיך אומרים? הכדור הוא עגול ולדרבי חוקי משלו."},{"start":1013.95,"end":1018.67,"text":"תודה רבה לך. זה הכל בינתיים כאן במבזק של ז'ק."},{"start":1018.67,"end":1021.67,"text":"רק האם אני יכול אם יותר לי למסור דש לאורי גרוס?"},{"start":1021.67,"end":1022.67,"text":"לא."},{"start":1022.67,"end":1026.65,"text":"אז אין מנוס אורי גרוס. שכח מזה, תן לה רוס."},{"start":1026.65,"end":1034.96,"text":"זה הכל בינתיים כאן במבזק של ז'ק. לילה טוב והמשך צפייה נעימה."},{"start":1034.96,"end":1045.45,"text":"קמה ועזבה אותי. אני לא יודע למה. היא כל הזמן אמרה לי:"},{"start":1045.45,"end":1050.64,"text":"אתה תמיד לוקחת דברים בצורה המסובכת ביותר. בחיים לא הבנתי אותה."},{"start":1050.64,"end":1058.2,"text":"יוסי, חכה לי רגע! אני בא! יוסי! שנייה! יוסי!"},{"start":1058.2,"end":1069.8,"text":"אם תמנתי אותה, סימן שהיא תמונה. תמונה!"},{"start":1069.8,"end":1080.84,"text":"יש לי, יש לי, יש לי! אם גיליתי אותה, סימן שהיא גלויה!"},{"start":1080.84,"end":1086.96,"text":"גלויה! יש לי, יש לי, יש לי!"},{"start":1086.96,"end":1093.01,"text":"אם תרפתי אותה, סימן שהיא תרופה!"},{"start":1093.01,"end":1100.01,"text":"יש לי, יש לי, יש לי, יש לי, יש לי, יש לי, יש לי!"},{"start":1100.01,"end":1105.75,"text":"אמא, הפכתי אותה! סימן שהכל נשפך עליי!"},{"start":1105.75,"end":1123.19,"text":"ערב צח, ערב זח, שוב אנחנו בחלסטרה של זוז'ו, והפעם רציתי לדבר איתכם על פרשומות לשנפונים לשיער."},{"start":1123.19,"end":1127.32,"text":"באמא שלי, זה ממש מדאיג אותי, אני בתור אחד שיש לי פריזורה חושקשוקה."},{"start":1127.32,"end":1131.32,"text":"אני מאוד מתעניין בנושא ולכן הדאגה היא רבה."},{"start":1131.32,"end":1135.51,"text":"פרשומת אחת זה הפרשומת של לאוריאל דה פריס."},{"start":1135.51,"end":1138.83,"text":"מה זה החרטאווית הזה באמא שלי? לא יומן."},{"start":1138.83,"end":1142.83,"text":"רואים בחורה, דווקא חיננית, עם הרבה חזון."},{"start":1142.83,"end":1145.83,"text":"רואים אותה באמא שלי, זה דרך היא עושה לעבודה, אני מרחם עליה."},{"start":1145.83,"end":1149.83,"text":"בשביל להגיע לעבודה, היא טסה במסוק, היא נוסעת בענויות,"},{"start":1149.83,"end":1152.83,"text":"היא שאתה בעגמים, היא עולה על רכבות באמא שלי, זה לא בחורה."},{"start":1152.83,"end":1154.83,"text":"זה רוג'ר מור, זה איך קוראים לזה?"},{"start":1154.83,"end":1157.31,"text":"דאבל או סמנט, באימא שלי, פחד אלוהים."},{"start":1157.31,"end":1160.11,"text":"אחר כך היא עושה את כל הדרך, מגיעה לעבודה,"},{"start":1160.11,"end":1162.91,"text":"עם השיער ונגמר להיום עבודה."},{"start":1162.91,"end":1164.43,"text":"מה זה החרטה הזה, באימא שלי?"},{"start":1164.43,"end":1165.39,"text":"זה לא יומן."},{"start":1165.39,"end":1168.75,"text":"ואז מראים מקרוב מה קורה שהיא שמה את השלפון."},{"start":1168.75,"end":1170.35,"text":"באימא שלי זה פחד."},{"start":1170.35,"end":1173.55,"text":"מראים טבלאות, הסבון הכנסה לוח לוח יוצא."},{"start":1173.55,"end":1176.59,"text":"זה לא שיער, באימא שלי, זה מעלית של אלקטרה, לא יומן."},{"start":1176.59,"end":1179.23,"text":"זה לא יומן, זה פחד, זה רכבת הרים, באימא שלי."},{"start":1179.23,"end":1181.99,"text":"זה לא קשקסים, זה שופת שלגים, לא יומן."},{"start":1181.99,"end":1184.23,"text":"אמרתי, הלאה, זאת היא שם ממש מפחידה."},{"start":1184.23,"end":1186.07,"text":"אמרתי, נעבור לפרסומת השנייה."},{"start":1186.07,"end":1189.75,"text":"הפרסומת השנייה היא פרסומת של חברת השיער."},{"start":1189.75,"end":1194.05,"text":"ולה, טוב על השיער, באימא שלי, שם של החברת דווקא נכבד."},{"start":1194.05,"end":1196.87,"text":"ולה, אבל הפרסומת זה לא יומן."},{"start":1196.87,"end":1199.54,"text":"קרם קולור רד."},{"start":1199.54,"end":1202.06,"text":"רד מהעץ, ימי חוער, באימא שלי."},{"start":1202.06,"end":1204.34,"text":"רואים שם איזה טרזן גדי מכולו כזה."},{"start":1204.34,"end":1206.18,"text":"יושעב עם כל מיני טלטלים."},{"start":1206.18,"end":1209.18,"text":"רד מהעץ, אימא שלי, והשלכת רצה עליו."},{"start":1209.18,"end":1211.86,"text":"והוא הרום, והיא מסתירה את התציאות שלה."},{"start":1211.86,"end":1214.94,"text":"איזה יופי, והם אוכלים ענבים מלקלקים."},{"start":1214.94,"end":1216.46,"text":"ופברוקי הזמיר בה."},{"start":1216.46,"end":1217.94,"text":"לשן דמעצי דלמוצו."},{"start":1217.94,"end":1220.58,"text":"לאמא שלי לא מבין מילה, זה בשפה אחרת בכלל."},{"start":1220.58,"end":1221.7,"text":"לא מבין מה הם רוצים."},{"start":1221.7,"end":1224.86,"text":"פחד אלוהים ושלכת ובכלל קיץ בחוץ."},{"start":1224.86,"end":1226.3,"text":"לא הבנתי כלום."},{"start":1226.3,"end":1229.92,"text":"לכן, צוות ההסרטה של זוזו ובנבל אש."},{"start":1229.92,"end":1231.19,"text":"לקח את הצוות."},{"start":1231.19,"end":1233.88,"text":"עשה פרשומת למוצר האמיתי."},{"start":1233.88,"end":1238.36,"text":"ששבש, שחוזק שוקי, סיבו לב."},{"start":1238.36,"end":1243.12,"text":"ששבש, קולור, בייג."},{"start":1243.12,"end":1253.02,"text":"לא נפוקה לחוזק זוקה."},{"start":1253.02,"end":1257.51,"text":"תקוונדולה, תרלה, ששבש."},{"start":1257.51,"end":1294.88,"text":"בואו שולגנטר על הפיקולוווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":1294.88,"end":1301.55,"text":"שיש ביש, קולור, מנומה"},{"start":1301.55,"end":1313.41,"text":"כן יש לי שיש ביש"},{"start":1313.41,"end":1333.68,"text":"שיש ביש וולה, פרפקטל יו"},{"start":1333.68,"end":1335.15,"text":"מושר אסקל"},{"start":1335.15,"end":1338.34,"text":"עזבוד חם שנפונים, קרימים ומוס"},{"start":1338.34,"end":1340.34,"text":"בוא נשאפ על צלחת חומוס"},{"start":1340.34,"end":1343.34,"text":"וכמו שאומר את הסמית שלנו"},{"start":1343.34,"end":1345.72,"text":"שיש ביש וולה"},{"start":1345.72,"end":1349.02,"text":"פרפנקטלי"},{"start":1349.02,"end":1350.34,"text":"פרפנקטלי"},{"start":1350.34,"end":1351.69,"text":"פרפנקטלי"},{"start":1351.69,"end":1352.67,"text":"يعني"},{"start":1352.67,"end":1353.69,"text":"בול עליך"},{"start":1353.69,"end":1354.69,"text":"מתחשבו עדי"},{"start":1354.69,"end":1356.95,"text":"פרפנקטלי"},{"start":1356.95,"end":1358.42,"text":"מי כתבי"},{"start":1358.42,"end":1359.42,"text":"תודה רבה."}]