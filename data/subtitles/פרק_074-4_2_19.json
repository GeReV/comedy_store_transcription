.89,"text":"אז למה שהם לא יבואו מההתחלה עם העוצמות?"},{"start":630.89,"end":632.89,"text":"יבואו דרגון זורד, מגה זורד ולא יקבלו מכות"},{"start":632.89,"end":634.89,"text":"למה הם צריכים לקבל מכות בשביל אחרי זה לסבול?"},{"start":634.89,"end":637.89,"text":"מה אשבי? שיקראו לעוצמות שלהם לפני שהם מקבלים את המכות?"},{"start":637.89,"end":638.89,"text":"בדיוק, זה היה ברור"},{"start":638.89,"end":639.89,"text":"אבל אסור להם"},{"start":639.89,"end":642.27,"text":"את אומרת אסור להם"},{"start":642.27,"end":644.19,"text":"זורדון אסר עליהם"},{"start":644.19,"end":646.02,"text":"זורדון אסר עליהם?"},{"start":646.02,"end":647.02,"text":"כן"},{"start":647.02,"end":648.14,"text":"אתה הוא אסר עליהם, לא שמעתי"},{"start":648.14,"end":651.2,"text":"מה זה אומרת שהוא גייס אותם?"},{"start":651.2,"end":653.1,"text":"מי אבל"},{"start":653.1,"end":654.1,"text":"מה בכלל זורדון הזה יכול להחליט?"},{"start":654.1,"end":656.1,"text":"הוא הרי יושב לו שם בתוך בקבוק, שקוע באופוריה"},{"start":656.1,"end":658.1,"text":"הוא יכול להגיד להם, אתה להפוך לדרגון זורד"},{"start":658.1,"end":659.1,"text":"למגה זורד"},{"start":659.1,"end":660.1,"text":"מה זאת אומרת?"},{"start":660.1,"end":661.1,"text":"בלי זורדון הם לא היו קיימים בכלל"},{"start":661.1,"end":663.1,"text":"זורדון מודיע להם, את הנחתה המפלצת בכלל"},{"start":663.1,"end":664.1,"text":"זורדון"},{"start":664.1,"end":665.1,"text":"זורדון"},{"start":665.1,"end":667.1,"text":"אם לא יהיו זורדון הם הם יודעים שאריאז שלטם איזה גם אביר"},{"start":667.1,"end":668.1,"text":"זה כבר דמגוגיה"},{"start":668.1,"end":669.1,"text":"זה כבר דמגוגיה"},{"start":669.1,"end":671.1,"text":"הרי זורדון בעצמו לא מסגל מול אריאז"},{"start":671.1,"end":672.1,"text":"זורדמה יש לו דרגון זורד"},{"start":672.1,"end":673.1,"text":"אבל"},{"start":673.1,"end":674.1,"text":"הכל בסדר?"},{"start":674.1,"end":678.1,"text":"בלי זורדון הם לא היו קיימים"},{"start":678.1,"end":682.1,"text":"בלי זורדון הם לא היו קיימים"},{"start":682.1,"end":683.1,"text":"הוא יושב בגוקה"},{"start":683.1,"end":685.1,"text":"אבל אם הם הופכים לבק זורד לדרגון זורד"},{"start":685.1,"end":687.1,"text":"סליחה אני מצטער שאני מתערב לכם בדיבור"},{"start":687.1,"end":689.1,"text":"כשבמקרה שמעתי"},{"start":689.1,"end":691.1,"text":"אני חייב להגיד לך שאני מסכים האדון כאן"},{"start":691.1,"end":692.1,"text":"זורדון"},{"start":692.1,"end":693.1,"text":"בבקשה"},{"start":693.1,"end":694.1,"text":"מי מן העורת איתם?"},{"start":694.1,"end":695.1,"text":"זורדון הוא לא קייג שנייה"},{"start":695.1,"end":697.1,"text":"שנייה שנייה אחת"},{"start":697.1,"end":698.1,"text":"אין סיגל"},{"start":698.1,"end":699.1,"text":"סיגל"},{"start":699.1,"end":700.1,"text":"סיגל"},{"start":700.1,"end":702.1,"text":"ב-2.72"},{"start":702.1,"end":705.1,"text":"לא להעביר לי שיחות, אני באמצע, באמצע שיחה חשובה."},{"start":705.1,"end":710.1,"text":"תשמעו טוב, בלי זורדון, אריה אז, היה כבר מזמן, משליט את האנושות."},{"start":710.1,"end":710.2,"text":"לא, לא, לא, שיחה, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע, רגע,"},{"start":710.1,"end":720.1,"text":"אני אשב פה פשוט ושומע את השיחה שלכם ואני לא יכול להתעלם מפרט אחד מאוד חשוב."},{"start":720.1,"end":724.1,"text":"אתם לאורך כל השיחה לא מזכים ולו לגע את מה שהיה בין ריטה וזונדר."},{"start":724.1,"end":727.1,"text":"כי זה לא רלוונטי לשיחה."},{"start":727.1,"end":731.1,"text":"שקט, סליחה! שקט, אין לך דבר יותר טוב לעשות, קש לו עבודה שלך."},{"start":731.1,"end":736.1,"text":"סליחה, אני מנהל עם מסעדה עם כל הכבוד לכם, אתם נשים פה רעש, אני מבקש תלונות מכל השונחנות בסביב."},{"start":736.1,"end":740.1,"text":"אני מבקש, בלי השטויות שלכם, אתה ואתה מתרגיב כמו ילדים קטנים."},{"start":740.1,"end":747.06,"text":"סליחה, אדוני, אדוני, אתה יודע מה? אני חושב שאתה וזורדון אפסים, וגם כל מי שפה מסביב, הוצאים רע."},{"start":747.06,"end":757.88,"text":"סליחה, אדוני, למי אתה אומר אפס? למי אדוני אתה אומר אפס? זורדון אפס?"},{"start":757.88,"end":761.45,"text":"זורדון אפס, את יודעת איך הוא חודש?"},{"start":761.45,"end":787.6,"text":"אסף, בוא בוא עושה קטעים שלך נוטניק, בוא!"},{"start":787.6,"end":789.6,"text":"מה זה לא ניגד?"},{"start":789.6,"end":792.6,"text":"ככה איטא, יא חברים, יופי יופי."},{"start":792.6,"end":798.11,"text":"ערב טוב, מכה חדשה, נפלה לקם אדיסטור."},{"start":798.11,"end":800.11,"text":"נמחה, טוב לך."},{"start":800.11,"end":802.11,"text":"איטא, סגבומניה!"},{"start":802.11,"end":806.11,"text":"זהו, למה עשית את זה מקודם? תודה חבר שלי, עכשיו נזכרתי מה אני עושה."},{"start":806.11,"end":808.36,"text":"ככה, נכון? הוא תמיד בעצה."},{"start":808.36,"end":811.36,"text":"אל דאגה, משטרת ישראל מתחת."},{"start":811.36,"end":814.36,"text":"שתמיד הוא אומר ובסוף הוא טועה."},{"start":814.36,"end":819.53,"text":"למה? סע, סע!"},{"start":819.53,"end":820.53,"text":"לך! לך לערוץ!"},{"start":820.53,"end":832.78,"text":"ערב טוב, שוב אנחנו במבזק של ז'ק והפעם נמצא איתי באולפן, חוקר השבק הידוע,"},{"start":832.78,"end":836.74,"text":"ומעריץ נלהב של להקת אבא, מר עדיס אבבה."},{"start":836.74,"end":837.77,"text":"ערב טוב לך מר עדיס."},{"start":837.77,"end":839.77,"text":"עדיס אודה, סתה שם רע לגרמה, שם לא סתה פרתמור."},{"start":839.77,"end":842.77,"text":"עוזר ספ, עוזר ספ, קוקי ספ, וואטרלו!"},{"start":842.77,"end":872.93,"text":"לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה לה"},{"start":872.93,"end":877.96,"text":"שיטת 'הטלטולים', זוהי שיטה שסופגת עדויות מתינוקות קטנים."},{"start":877.96,"end":879.64,"text":"זו שיטה שכל תינוק מכיר."},{"start":879.64,"end":880.96,"text":"-טלטולים. -טלטולים, אוללה."},{"start":880.96,"end":883.89,"text":"כן, אבל לא לשם כך הזמנו אותך לאולפן."},{"start":883.89,"end":888.72,"text":"הזמנו אותך מאחר ואתה, אפשר לומר, אבא לשיטה חדשה."},{"start":888.72,"end":890.97,"text":"-אכן מגיע לי מזל טוב. -מזל טוב."},{"start":890.97,"end":892.07,"text":"תודה, הנה זה מגיע."},{"start":892.07,"end":894.47,"text":"וכן, שים לב, השיטה היא כזאת."},{"start":894.47,"end":900.07,"text":"מה שקורה, להקת אבא ידועה בגרסאות, אלפי הגרסאות שלהם, לשירים הגדולים שלהם, כן?"},{"start":900.07,"end":901.97,"text":"ורסיות חדשות יצאו למחבר."},{"start":901.97,"end":908.07,"text":"ומה שקורה, השיטה הזאת, בעזרת השמעת שיר של אבא, היא שואבת מידע מסתר, מאדם מסוים."},{"start":908.07,"end":910.31,"text":"אתה יכול להדגים? -בבקשה."},{"start":910.31,"end":913.17,"text":"ובכן, לדוגמה, איך קוראים לך?"},{"start":913.17,"end":914.94,"text":"אני לא מעוניין להגיד."},{"start":914.94,"end":918.32,"text":"ווטרלו! לא, לא, לא, לא, לא, ווטרלו! -שאק, שאק!"},{"start":918.32,"end":921.25,"text":"בבקשה, בן כמה אתה?"},{"start":921.25,"end":923.39,"text":"אני לא, לא, לא רוצה להגיד."},{"start":926.09,"end":929.09,"text":"לא, לא, לא, לא, וכן מה השם של אמא שלך?"},{"start":929.09,"end":930.09,"text":"לא נעים, אני לא..."},{"start":930.09,"end":931.09,"text":"מני, מני, מני!"},{"start":931.09,"end":932.09,"text":"אולי, ברכה!"},{"start":932.09,"end":933.34,"text":"איך אתה יודע?"},{"start":933.34,"end":934.34,"text":"אני מכיר את המשפחה."},{"start":934.34,"end":935.66,"text":"אהה."},{"start":935.66,"end":938.72,"text":"אני הבנתי שהיא מנחה גם סרט הקלטה בו אתה מדגים את השיטה הזו."},{"start":938.72,"end":941.72,"text":"כמובן, יש לי פה את האמצע הבומבסית הזו, גרנדיוזית,"},{"start":941.72,"end":946.72,"text":"של אותו סרט הקלטה שפשוט מדגים את הקליפ הגרנדיוזי הזה של להקת אבא."},{"start":946.72,"end":949.72,"text":"קליפ ענק שבעזרתו אפשר לשאוב כמובן עדויות."},{"start":949.72,"end":952.72,"text":"כן, אם כן בואו נעבור לסרט ההקלטה."},{"start":952.72,"end":956.72,"text":"רק שניחה אם יותר לי למשור דש לאגטה ופרידה מלהקת אבא."},{"start":956.72,"end":957.72,"text":"לא בשום פנים ואופן לא."},{"start":957.72,"end":959.72,"text":"אז תשכח מזה דורן מזר."},{"start":959.72,"end":961.63,"text":"אללה בואו בסביב לפרנק, יו!"},{"start":961.63,"end":965.21,"text":"כן, אנחנו נעבור לסרט ההקלטה."},{"start":965.21,"end":969.31,"text":"רק שנייה, תגיד לי איזה סלע בזלת או שזה מסלול אספלט?"},{"start":969.31,"end":1090.35,"text":"if you change your mind, I'm the first in line, honey, I'm still free, take a chance on me, if you need me, let me know, gonna be around, if you got no place to go, when you're feeling down, if you're all alone."},{"start":1090.35,"end":1138.28,"text":"מה לחשוש? כל מה שתגידי, שאיר כאן במשרד הזה, בן ארבעת הקירות הללו, כאן שומרים על סודיות רפואית?"},{"start":1138.28,"end":1143.92,"text":"אני מקווה שאתה צודק אדוני פסיכולוג, אני פשוט עומד לספר לך משהו מאוד לא נעים."},{"start":1143.92,"end":1147.92,"text":"ואתה יודע, אני מאוד פעיל בשכונה שלנו, אני אישיות מאוד ציבורית."},{"start":1147.92,"end":1150.17,"text":"אני גם יש משפחה למופת."},{"start":1150.17,"end":1153.35,"text":"אם היא ודה דבר וחצי דבר מה שאני עומד לספר לך,"},{"start":1153.35,"end":1157.35,"text":"אני מאבד את כל החברים שלי, אני מאבד את הקריירה שלי בשכונה,"},{"start":1157.35,"end":1161.35,"text":"כל המשפחה שלי תעזוב אותי, אז שישאר בינינו הדוקטור."},{"start":1161.35,"end":1162.35,"text":"כן."},{"start":1162.35,"end":1164.35,"text":"תשמע, יש לי בעיה מאוד רצינית."},{"start":1164.35,"end":1168.38,"text":"בזמן לאחרון אני מרגיש שיש לי משיכה לסוסים."},{"start":1168.38,"end":1173.74,"text":"כן, לא, אני לא מתכוון משיכה כזאת של אחד שחובב סוסים."},{"start":1173.74,"end":1176.93,"text":"אני פשוט ממשך משיכה מינית לסוסים."},{"start":1176.93,"end":1178.93,"text":"זה יכול להיות סוס מקבה."},{"start":1178.93,"end":1180.93,"text":"וזה יכול להיות גם סוס זכר."},{"start":1180.93,"end":1183.93,"text":"וזה יכול להיות שיח קטן."},{"start":1183.93,"end":1187.89,"text":"לפני שבוע אפילו, אם כל המשפחה במצפה התיומי באילת,"},{"start":1187.89,"end":1190.89,"text":"אני ראיתי שם בעקוורים את הסוסים."},{"start":1190.89,"end":1192.89,"text":"התחלתי להזיע מרוב תשוקה."},{"start":1192.89,"end":1196.3,"text":"אתמול, אתמול עבר האגלונים עם האבטיחים."},{"start":1196.3,"end":1199.3,"text":"אעשהו על החצית הלשקולת האבטיח, לא יכולתי להתאפק."},{"start":1199.3,"end":1201.3,"text":"התבקתי נשיקה צרפתית לסוס שלו."},{"start":1201.3,"end":1203.3,"text":"פחתי שמישהו יראה, אתה חף?"},{"start":1203.3,"end":1204.3,"text":"ראה, ראה."},{"start":1204.3,"end":1207.36,"text":"אתה התקדמת היום מאוד, אתה התקדמת מאוד."},{"start":1207.36,"end":1210.36,"text":"אנחנו נמשיך הלאה בסדרה של טיפולים לפתור את הבעיה הזאת."},{"start":1210.36,"end":1212.36,"text":"בינתיים, 1,500 דולר עכשיו."},{"start":1212.36,"end":1214.36,"text":"הכי, הכי חשוב שזה יישאר בינינו, אה?"},{"start":1214.36,"end":1217.36,"text":"כמובן, כמובן שזה יישאר בינינו, אין לך מה להקשיב."},{"start":1217.36,"end":1219.36,"text":"דוקטור, בסדר, סידרנו לך הכל, תראה."},{"start":1219.36,"end":1224.36,"text":"יש לך פה את כל המכשיר מחובר כמו שצריך והקופסה טיפלנו בהכל בסדר."},{"start":1224.36,"end":1225.36,"text":"יראה, מי פה?"},{"start":1225.36,"end":1226.36,"text":"הכל בסדר?"},{"start":1226.36,"end":1227.36,"text":"צדוק."},{"start":1227.36,"end":1228.36,"text":"אמרתי לך זה."},{"start":1228.36,"end":1229.36,"text":"צדוק משלם לך, אלן."},{"start":1229.36,"end":1230.36,"text":"אללה וחייל."},{"start":1230.36,"end":1231.36,"text":"דה מוקא לי הכל."},{"start":1231.36,"end":1232.36,"text":"אללה צדוק, מה ענייני?"},{"start":1232.36,"end":1234.36,"text":"מה סיפורי של רגע דולה, תדא."},{"start":1234.36,"end":1236.36,"text":"בסדר, אנחנו חוזרים לעבודה בסדר?"},{"start":1236.36,"end":1238.36,"text":"בלי סוס."},{"start":1238.36,"end":1242.77,"text":"אנחנו שעושה עבודה, אנחנו שעושה עבודה."},{"start":1252.36,"end":1263.36,"text":"תודה רבה."},{"start":1263.36,"end":1291.22,"text":"תודה רבה."},{"start":1291.22,"end":1292.32,"text":"תודה רבה."}]