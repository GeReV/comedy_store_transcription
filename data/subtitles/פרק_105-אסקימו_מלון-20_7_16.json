[{"start":0.13,"end":2.23,"text":"אם שהארגזי החול מסוכנים לבריאות,"},{"start":2.23,"end":6.53,"text":"הריאה אי האחראית על בריאות הציבור ואי הכתובת לכל הפניות הללו."},{"start":6.53,"end":8.39,"text":"סימן שלא ראיתם שיעור חודשי."},{"start":8.39,"end":12.07,"text":"רביעי 6.30 ערוץ 3, מעדורת יום אחד."},{"start":12.07,"end":17.55,"text":"ספור 5.7 בערך."},{"start":17.55,"end":21.77,"text":"השידורים החוזרים 5.9, 6.7.30 בערוץ המקומי."},{"start":21.77,"end":22.37,"text":"רואים?"},{"start":22.37,"end":73.89,"text":"לכם לצופים ולצופים."},{"start":73.89,"end":78.44,"text":"אני ג'ורש פול זונה, המכונה גם בן זונה, המומחה שלכם לכל נוער."},{"start":78.44,"end":84.09,"text":"אבטח בחידה, ציין או צייני שבע שחפים היוצרים יחד סדרה מגנימה."},{"start":84.09,"end":86.29,"text":"אני בבקשה, כן? כן בבקשה?"},{"start":86.29,"end":90.98,"text":"יפה, הציוט בחוב אלם זה יפה, בואו ניתן לכם עוד הזדמנות, כן?"},{"start":90.98,"end":92.8,"text":"אסכימולימון, יפה מאוד."},{"start":92.8,"end":98.35,"text":"הצדרה המצוינת אסכימולימון, וכן לצדרה הציוט בחוב אלם דומות להפיל."},{"start":98.35,"end":100.49,"text":"ומה הן דומות? בגיבור הראשי."},{"start":100.49,"end":106.3,"text":"למשל, בסיוט בחוב אלם, הגיבור הראשי נותן לאצבעותיו משמעות קטלנית."},{"start":106.3,"end":111.75,"text":"כאילו בסדרה \"אסתימולימון\" צחי נוי נותן לישבנו משמעות פילוסופית."},{"start":111.75,"end":114.78,"text":"עוד על צחי נוי, צחי נוי מוגעון, יספיר."},{"start":114.78,"end":120.64,"text":"אפשר לומר שצחי נוי יכול לגלן כל מה שישראלי היה רוצה לעשות לחברו."},{"start":120.64,"end":129.92,"text":"אפשר להפליק לו, אפשר לצבות את לחיו, אפשר לסתור לישבנו, אפשר לרוץ איתו, לקפוץ איתו, לרקוד איתו,"},{"start":129.92,"end":132.61,"text":"ותמיד תרגיש איתו יבשה ונשי."},{"start":132.61,"end":137.44,"text":"כדי להדגיש את כוונתי, הרי קטע מתוך הסרט יוצאים קבוע."},{"start":137.49,"end":141.78,"text":"סרט שבו השתצוע, כוכבים הגדולים שלו, את כימולימון, סרט מספר שתיים."},{"start":141.78,"end":148.25,"text":"בקטע מתוך הסרט אנחנו רואים את יודה לאה, בנצי, ומומון עושים באותו."},{"start":148.25,"end":151.86,"text":"ולידם עושר בחור על אופנוע."},{"start":151.86,"end":155.46,"text":"הבחור מכונה על ידם פושטק ומרכים אלמה צעירה."},{"start":155.46,"end":160.93,"text":"להלן הדיאלוג, מומו פונה לה ואומר לו, תראו איזה פחון."},{"start":160.93,"end":164.8,"text":"כוונה כמובן לחלק הכווני של האלמה אותה הוא מרכים."},{"start":164.8,"end":168.89,"text":"ועד הפושטק אומר, תום לספה של חיה בטאטה."},{"start":169.38,"end":171.41,"text":"אני נכנס לפעולת צח עינוי."},{"start":171.41,"end":173.51,"text":"צח עינוי יאמר לו:"},{"start":173.51,"end":177.08,"text":"\"בסאטה הוציא אותך אידיוט\"."},{"start":177.08,"end":185.41,"text":"פושטק יענה לו אידיוט עשה אותך וצח עינוי יענה לו במשהו מוגדר כסמינה קולנואית:"},{"start":185.41,"end":187.62,"text":"\"בו תקפוץ לי דגנרל\"."},{"start":187.62,"end":190.69,"text":"משעשע ללא ספק, אפילו אני רוצה לצפוק."},{"start":190.69,"end":193.78,"text":"אכן, דיאלוג כזה שרק מוח גאוני החולם."},{"start":193.78,"end":196.29,"text":"לכן נעבור לסרט."},{"start":196.29,"end":200.85,"text":"סרט נוסף בסדרה, סרט שלא ראיתם מעולם, הראו לפניכם."},{"start":200.85,"end":243.04,"text":"תודה רבה."},{"start":243.06,"end":251.47,"text":"אלן מומו."},{"start":251.47,"end":252.82,"text":"אלן בנצי."},{"start":252.82,"end":253.82,"text":"אלן יודאלה."},{"start":253.82,"end":254.82,"text":"היי בנצי."},{"start":254.82,"end":255.82,"text":"אלן בנצי."},{"start":255.82,"end":256.82,"text":"היי מומו."},{"start":256.82,"end":257.82,"text":"אלן יודאלה."},{"start":257.82,"end":258.82,"text":"אלן מומו."},{"start":258.82,"end":259.82,"text":"אלן דמבו."},{"start":259.82,"end":262.82,"text":"היי חרדל, אתם רואים את שתי הקומות שם שישות לבד?"},{"start":262.82,"end":266.16,"text":"מהם פערות האלה שנראות מוכליליות."},{"start":266.16,"end":268.16,"text":"מה קרה לך, אני מתערף שאין מותמות על בטמואל."},{"start":268.16,"end":271.15,"text":"תקייק עליהם סתקים עלינו, תראו לנו חווצלות."},{"start":271.15,"end":272.75,"text":"וואו."},{"start":272.75,"end":274.9,"text":"יודאלה, איך תביא כמה גלידות?"},{"start":274.9,"end":277.06,"text":"מה קרה לך? למה דרך קרה לי?"},{"start":277.06,"end":277.98,"text":"תרשום, נחזיר לך."},{"start":277.98,"end":281.18,"text":"היי, אתם חייבים לי כבר שתי לירות 25 אגורות."},{"start":281.18,"end":284.21,"text":"תרשום, תרשום."},{"start":284.21,"end":286.98,"text":"בנסי, נעולך אליהם."},{"start":286.98,"end":309.29,"text":"נענות?"},{"start":309.29,"end":310.29,"text":"נעים מאוד, רכפת."},{"start":310.29,"end":312.29,"text":"אז מה, ואני נעים מאוד שלנו?"},{"start":312.29,"end":313.29,"text":"אז מה, אז מה?"},{"start":313.29,"end":317.15,"text":"אז מה, אולי תקפסו אליי ככה לשמוע קצת פלטר?"},{"start":317.15,"end":318.15,"text":"מה את אומרות?"},{"start":318.15,"end":320.29,"text":"לא מכירות."},{"start":320.29,"end":322.75,"text":"אולי קליפ ריצ'ארד, אה?"},{"start":322.75,"end":323.75,"text":"לא מכירות."},{"start":323.75,"end":325.97,"text":"אולי יש לך אביביטה?"},{"start":325.97,"end":328.19,"text":"יש מה שאתה אש בובה, יש הכל."},{"start":328.19,"end":329.19,"text":"די, את שובטה לא משקר."},{"start":329.19,"end":331.49,"text":"למה שאני אשקר?"},{"start":331.49,"end":335.03,"text":"בוא אליי, גם אולי נוכל קצת להתמזמז, אה?"},{"start":335.03,"end":336.01,"text":"וואו."},{"start":336.01,"end":337.02,"text":"וואו."},{"start":337.02,"end":338.02,"text":"אלך, וואו."},{"start":338.02,"end":339.02,"text":"את אפילו לא יודעת מה זה מזמוז."},{"start":339.02,"end":341.75,"text":"אלך אני לא יודעת מה זה."},{"start":341.75,"end":342.97,"text":"אלך אני לא יודעת."},{"start":342.97,"end":344.06,"text":"נו?"},{"start":344.06,"end":345.44,"text":"נו, מה זה?"},{"start":345.44,"end":348.19,"text":"אז פגד, זה מה זה בסיסי?"},{"start":348.19,"end":349.46,"text":"מזמוז."},{"start":349.46,"end":354.24,"text":"ונגיד עכשיו הוא לוקח את שלנו נלתחת לעת,"},{"start":354.24,"end":356.43,"text":"הוא מתחיל לשלוח ידיים,"},{"start":356.43,"end":359.55,"text":"ופתאום באה דבורה וממזמזת לנו באוזן."},{"start":362.7,"end":364.95,"text":"וואו מה כולה?"},{"start":364.95,"end":366.95,"text":"והדבורה מאיה וגם זיק ויויו גם."},{"start":366.95,"end":370.52,"text":"נו אז בנות הלכנו?"},{"start":370.52,"end":372.92,"text":"אה? יאללה בוא מנפות בואו."},{"start":372.92,"end":375.43,"text":"גזוז בבקשה."},{"start":375.43,"end":382.4,"text":"שלום."},{"start":382.4,"end":384.56,"text":"היי."},{"start":384.56,"end":387.0,"text":"מה הבחורה יפה כמוך עושה כאן?"},{"start":387.0,"end":389.5,"text":"מה גזוז?"},{"start":389.5,"end":390.75,"text":"אני בנצי."},{"start":390.75,"end":391.75,"text":"נעים מאוד נילי."},{"start":391.75,"end":394.79,"text":"מדברת איפי?"},{"start":394.79,"end":398.04,"text":"מה? אתה לא שמע טוב? יש לך בעיה באוזניים?"},{"start":398.04,"end":400.95,"text":"לי!"},{"start":400.95,"end":404.13,"text":"אולי את רוצה שאני לבה אותך הביתה?"},{"start":404.13,"end":406.08,"text":"החברות שלי מחכות לי בחורס."},{"start":406.08,"end":408.32,"text":"אולי את רוצה שאני לבה אותך עד החברות שלך?"},{"start":408.32,"end":409.26,"text":"למה לא?"},{"start":410.64,"end":412.64,"text":"למה לא?"},{"start":412.64,"end":415.75,"text":"למה לא?"},{"start":415.75,"end":420.18,"text":"למה לא?"},{"start":420.18,"end":431.46,"text":"למה לא?"},{"start":431.46,"end":433.45,"text":"למה לא?"},{"start":433.45,"end":437.27,"text":"למה לא?"},{"start":437.27,"end":439.26,"text":"למה לא?"},{"start":439.26,"end":448.6,"text":"למה לא?"},{"start":448.6,"end":452.9,"text":"זה שחזרתם אליי ולמקרתי ידידתי, גולדה."},{"start":452.9,"end":459.04,"text":"אין ספג שז'אנר, סרטי אסקימולימון, שייך לזרמה היפר-סוריאליסטי,"},{"start":459.04,"end":463.23,"text":"סיפר-וונטילציה, שבר סורי-אפריקני, שפריט."},{"start":463.23,"end":467.7,"text":"אם מדברים על שפריט, אי אפשר להתעלם מדמותה של האישה וכימולימון."},{"start":467.7,"end":469.15,"text":"בידו אישי."},{"start":469.15,"end":475.68,"text":"הזמן הוא קיץ, השנה היא 1978, אני נער לבוך, הייתי אומר תמים,"},{"start":475.68,"end":478.68,"text":"נער חסר ביטחון, בן 39."},{"start":478.68,"end":485.69,"text":"אני מתיישב ורואה על המסך, על האקרן הגדול, אני רואה את אופל ישפרה,"},{"start":485.69,"end":495.81,"text":"נכונה סטלה ועליה גואר ישבנו או ישבנו הדו פרצופי של צה חינוי, המילים הם מילים כדור בנות,"},{"start":495.81,"end":505.77,"text":"היא פונה אליו בצמד המילים הבלתי נשכח ואני אמר, אני מגמר, אני מגמר."},{"start":505.77,"end":506.72,"text":"זוכרת גולדה?"},{"start":506.72,"end":514.97,"text":"חבן נחזור אל שלושת גיבורנו במסעם לקראת התבגרותם וחיפוש אחר זהותם המים."},{"start":514.97,"end":525.32,"text":"חבר'ה, חבר'ה, ניגענו זה פה. מספרים שהבת של הרוקח שעובד כאן חמה כמו אש."},{"start":525.32,"end":527.32,"text":"אז מה לך עושה פה? בוא ניכנס אליה."},{"start":527.32,"end":529.32,"text":"רגע, רגע, אבל מה יקרה עם אבא שלהם? ויתמוסו את הדבר?"},{"start":529.32,"end":533.82,"text":"זה בסדר, חבר'ה. אתם תיכנסו ואני אשאר פה לשמור, להשגיח."},{"start":533.82,"end":536.08,"text":"תתפלו בה."},{"start":536.08,"end":537.08,"text":"חבר'ה, חבר'ה."},{"start":537.08,"end":553.65,"text":"שלום, בונבוני. שלום מומה."},{"start":553.65,"end":561.27,"text":"אנחנו צריכים, את יודעת, משהו כזה מגון קצת טרוך, אין אפשר."},{"start":561.27,"end":565.44,"text":"אינגה לי יודעת מוטט בדיוק מה אתם צריכים."},{"start":565.44,"end":569.58,"text":"אבל קודם אינגה צריך מודדת בלברוטורי."},{"start":569.58,"end":576.51,"text":"כדי לדעתי מתאים אתה מנשת אינגה הזק, אינגה מזמרת."},{"start":576.51,"end":583.65,"text":"דלה, אני ניחס עכשיו איתה. אתה תתכונן, אוקיי? אתה אחראי."},{"start":583.65,"end":585.65,"text":"בוא לאימא מוטט."},{"start":585.65,"end":589.42,"text":"בוא לעשות אינגה שערה יודל."},{"start":589.42,"end":592.57,"text":"אתה המוד, אתה יודע."},{"start":592.57,"end":598.97,"text":"יהודה לי, יהודה לי, יהודה."},{"start":598.97,"end":603.43,"text":"אה, אתה לעשות אינגה מבנרת."},{"start":603.43,"end":607.97,"text":"בינצי, מה אתה עושה?"},{"start":607.97,"end":609.93,"text":"אה, כושר נילי."},{"start":609.93,"end":612.05,"text":"כושר מחזק."},{"start":612.05,"end":614.05,"text":"מה זה הקולות האלה?"},{"start":614.05,"end":616.08,"text":"זה הרוקחת."},{"start":616.08,"end":618.01,"text":"היא עושה פיתוח קול."},{"start":618.01,"end":619.43,"text":"מה את עושה פה נילי?"},{"start":619.43,"end":620.72,"text":"חזרתי מקניות."},{"start":620.72,"end":623.3,"text":"צריכה אולי עזרה."},{"start":623.3,"end":624.3,"text":"תודה רבה."},{"start":624.3,"end":626.86,"text":"רוצה ללכת ככה?"},{"start":626.86,"end":630.05,"text":"כן, שי."},{"start":630.05,"end":631.92,"text":"יש לך גוף יפה."},{"start":631.92,"end":633.16,"text":"תודה."},{"start":633.16,"end":635.65,"text":"תודה רבה."},{"start":635.65,"end":637.88,"text":"תלה, לך תהנה."},{"start":637.88,"end":639.0,"text":"זאת לא רוכחה, דודי."},{"start":639.0,"end":641.22,"text":"היא עוצה ראיפוי בפיצוג, דודי."},{"start":641.22,"end":646.96,"text":"לקבלת הרוכחה, נעשיב."},{"start":646.96,"end":648.96,"text":"את מרקחת יעבור לטוב."},{"start":648.96,"end":651.12,"text":"אני מסתאר אדוני חיקה."},{"start":651.12,"end":652.12,"text":"אני הייתי במילואים."},{"start":652.12,"end":657.04,"text":"אתה רוכח, האבא של השרליט, של הבת שלך?"},{"start":657.04,"end":659.04,"text":"אני אבא שלו, איסוקריה של..."},{"start":659.04,"end":661.04,"text":"מישהו מטפל באדוני?"},{"start":661.04,"end":663.04,"text":"נפלו ביקום בסרטים."},{"start":663.04,"end":664.96,"text":"תודה רבה, תודה רבה."},{"start":664.96,"end":667.32,"text":"מה זה?"},{"start":667.32,"end":669.83,"text":"אני שומע קולות מלחמה."},{"start":669.83,"end":671.83,"text":"מה? מה שני בום בום בום בום."},{"start":671.83,"end":673.83,"text":"הלב שלי אני לא מאמין."},{"start":673.83,"end":674.79,"text":"מה שני?"},{"start":674.79,"end":676.79,"text":"הלב שלי מתייפה."},{"start":676.79,"end":678.79,"text":"מה שני כתרנו?"},{"start":678.79,"end":683.68,"text":"מה שני לא מאמין?"},{"start":683.68,"end":686.7,"text":"אני לא מאמין כתרנו."},{"start":686.7,"end":690.27,"text":"אתה עושה לחופה זה כתובי."},{"start":690.27,"end":693.07,"text":"כתובי, כתובי, כתובי."},{"start":693.07,"end":695.07,"text":"אני לא מאמין."},{"start":695.07,"end":697.07,"text":"רגע, רגע, רגע, רגע, רגע."},{"start":697.07,"end":698.0,"text":"רגע, רגע."},{"start":698.0,"end":700.19,"text":"מה זה המצטה הזה?"},{"start":700.19,"end":702.7,"text":"מה אתה עושה סכימו לימון בלי מצטה פלסיס?"},{"start":702.7,"end":712.79,"text":"אני לא מאמית, אני לא מאמית, אני לא מאמית, אני לא מאמית, אני לא מאמית, אני לא מאמית, אני לא מאמית לך תן אתגרה, מה?"},{"start":712.79,"end":717.77,"text":"כן, פה, תודה שעזרת לי עם הסלים, סטויות."},{"start":717.77,"end":736.59,"text":"אז, ביי, ביי, ונילי, הרבה זמן שאני רציתי להגילה, קורא אצלי משהו, ואני חושב שאני..."},{"start":736.59,"end":764.93,"text":"שם, הלו! אלו בנסי. אלו מומו. אלו ידלה. אלו בנסי. אלו בנסי. אלו מומו. אלו בנסי. אלו מימי. אלו מונסי. אלו ידיל. בנסי. בנסי. בנסי. שבאי, אני מנסי. שבאי, אני מנסי. שבאי, אני מנסי בערב. נדעי לך לבוא. שמעתי שני לי תהיה שם. זאת ששמת עליה עין."},{"start":764.93,"end":803.18,"text":"היי חלס כבר עם השיר הזה. אין לך משהו אחר. לא כזה, משהו אחר, שיר אחר. שאה. היי חבר'ה תראו את הקוזינה הזאת שם. זה לא נורמלי. תגיד לי בנסי. בחורות שהמצאות מהמיים. לאן הן הולכות? למקלחות. יאללה חבר'ה אני ראשון. בואו תעזרו לי להלות. יאללה כבר שמל אחד. יאללה חבר'ה. ים של קוזינות משבטיה. יא חביבי יהיה זה גוף. אין שם."},{"start":803.2,"end":805.2,"text":"תודה רבה."},{"start":838.05,"end":840.26,"text":"תודה רבה."},{"start":875.79,"end":877.79,"text":"תודה רבה."},{"start":877.79,"end":879.79,"text":"תראה לך נראה."},{"start":879.79,"end":881.79,"text":"תראה לך נראה, תראה לך אני נראה."},{"start":881.79,"end":883.79,"text":"הלאה, המשיבה תשומה אני ארגמון את זה."},{"start":883.79,"end":885.79,"text":"כן, כן, אידיוט."},{"start":885.79,"end":887.79,"text":"אבל אם אני אעשה דיאטה אני אשתנה."},{"start":887.79,"end":890.01,"text":"אתה, בחיים שלך לא תוכל להשתנה."},{"start":890.01,"end":897.25,"text":"מה אתה אומר על זה?"},{"start":897.25,"end":911.84,"text":"מה חיה, עשית על זה?"},{"start":911.84,"end":913.84,"text":"כל העבוצרות, קופית, ככה."},{"start":913.84,"end":915.84,"text":"על זה לא יודע, על זה לא!"},{"start":915.84,"end":917.97,"text":"אני טובה, אדוני שמור!"},{"start":917.97,"end":919.97,"text":"על זה לא!"},{"start":919.97,"end":921.97,"text":"אם אני דק חזמל, עושה לי זוב זוב זוב!"},{"start":921.97,"end":926.03,"text":"אני דבקתי ברבז בבית געגעגע!"},{"start":926.03,"end":928.03,"text":"חייב!"},{"start":928.03,"end":930.03,"text":"הלו, שם בש!"},{"start":930.03,"end":932.03,"text":"מה את תורף? אתה בין תעמיים הבני דודים?"},{"start":932.03,"end":934.03,"text":"זה נמוך, לא יכול לדבר!"},{"start":934.03,"end":936.03,"text":"אבל אני לא יודע לסקות אדוני!"},{"start":936.03,"end":938.03,"text":"אני דבקתי בבית ברבז לזה געגעגע!"},{"start":938.03,"end":940.03,"text":"יאללה דני, מה זה כבר מי העד דבר הזה?"},{"start":940.03,"end":942.03,"text":"כל פעם, עושים להגולה, עשי לו!"},{"start":942.03,"end":944.03,"text":"עשי להדונאי שמור!"},{"start":944.03,"end":946.03,"text":"זק בתים, זק אסקסים, זק שם פה!"},{"start":946.03,"end":950.03,"text":"הילה, הילה, תחליף, תחליף הזה, הילה, מבטא קורנימש, יאללה, משהו אחר!"},{"start":950.03,"end":952.03,"text":"אני יכול לעשות כל מיני מבטאי!"},{"start":952.03,"end":954.13,"text":"אני יכול לעשות מבטא איראני!"},{"start":954.13,"end":957.09,"text":"אני גם יכול לעשות חוביני רפתן ג'אני!"},{"start":957.09,"end":959.09,"text":"אני גם יכול להיות עמירה כך שברוש!"},{"start":959.09,"end":962.09,"text":"משהו אחר, עשי משהו ישראלי, ישראלי, אחול ישראלי!"},{"start":962.09,"end":963.09,"text":"ישראלי?"},{"start":963.09,"end":964.09,"text":"ישראלי!"},{"start":964.09,"end":966.12,"text":"אה, אני יכול לעשות לסף שלוש!"},{"start":966.12,"end":968.31,"text":"אמא לי, תעזרי לי, אדונאי!"},{"start":968.31,"end":970.31,"text":"תתבוא, אתה יש מיותר במילה!"},{"start":970.31,"end":1028.85,"text":"לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא"},{"start":1028.85,"end":1031.19,"text":"ומשמש את המשמוש הקטנצ'יק שלנו, אה?"},{"start":1031.19,"end":1034.24,"text":"למה לא?"},{"start":1034.24,"end":1037.02,"text":"נראה כמו חייזה"},{"start":1037.02,"end":1039.23,"text":"מייבאת"},{"start":1039.23,"end":1063.01,"text":"כמה מהמלון נראה"},{"start":1063.01,"end":1071.23,"text":"אלן יודלף"},{"start":1071.23,"end":1072.68,"text":"אה, אלן בנצי"},{"start":1072.68,"end":1073.28,"text":"אלן מומו"},{"start":1073.28,"end":1074.06,"text":"אלן בנצי"},{"start":1074.06,"end":1074.66,"text":"אלן יודלף"},{"start":1074.66,"end":1075.36,"text":"אלן בנצי"},{"start":1075.36,"end":1075.86,"text":"אלן מומו"},{"start":1075.86,"end":1076.48,"text":"אלן ממו"},{"start":1076.48,"end":1077.08,"text":"אלן בנצי"},{"start":1077.08,"end":1077.66,"text":"אלן בנצי"},{"start":1077.66,"end":1078.16,"text":"אלן מומו"},{"start":1078.16,"end":1078.94,"text":"אלן בנצי"},{"start":1078.94,"end":1080.64,"text":"יודלף"},{"start":1080.64,"end":1082.07,"text":"היית אצלילי?"},{"start":1082.07,"end":1084.11,"text":"אני חושב שהיא שם"},{"start":1084.11,"end":1101.15,"text":"איך הזה מומו, אה?"},{"start":1101.15,"end":1102.81,"text":"מה את רוצה ממני?"},{"start":1102.81,"end":1105.73,"text":"זו פי שהתנפלה עליי כמו איזה חתולה מיוחמת"},{"start":1105.73,"end":1107.55,"text":"אני מצטערת, בנצי"},{"start":1107.55,"end":1111.81,"text":"רומו יחתיכת נבלה, מה עשית לה?"},{"start":1111.81,"end":1113.95,"text":"אותו שזה אני, זה יכול להיות כל אחד"},{"start":1113.95,"end":1115.76,"text":"נשתוג מניאק"},{"start":1115.76,"end":1116.74,"text":"לא, בנצי"},{"start":1116.74,"end":1118.07,"text":"כמו מוצדק"},{"start":1118.07,"end":1119.72,"text":"זה לא הוא, האבא"},{"start":1119.72,"end":1121.32,"text":"מי זה?"},{"start":1121.32,"end":1121.42,"text":"אההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":1121.32,"end":1187.2,"text":"אהההההההההההההההההההההה"},{"start":1191.38,"end":1194.6,"text