[{"start":41.35,"end":42.61,"text":"אוהב ובריאות טובה."},{"start":42.61,"end":46.61,"text":"כאן הפרופסור יהוקמץ בן פסיק בפינת העברית שלכם."},{"start":46.61,"end":50.47,"text":"גם בימי קורונה יש לדבר בעברית תקינה."},{"start":50.47,"end":55.21,"text":"אל תאמרו אל קוגל, אמרו תקריש חיטוי."},{"start":55.21,"end":59.87,"text":"אל תתעטשו אל המרפק, תתעטשו אל הגומץ."},{"start":59.87,"end":62.31,"text":"היזהרו לו להידבק."},{"start":62.31,"end":65.85,"text":"כך יש לומר כי המחלה מדבקת."},{"start":65.85,"end":69.66,"text":"איך אומרים בעברית יפה, אני אדביק לך קאפה?"},{"start":69.66,"end":73.32,"text":"אומרים ככה, בכך כהלכה."},{"start":73.32,"end":74.68,"text":"בדיוק, אז יאללה."},{"start":74.68,"end":78.16,"text":"ערב זך ערב זך."},{"start":78.16,"end":79.44,"text":"נקסט פליז."},{"start":79.44,"end":81.6,"text":"אתה מטריב אותי."},{"start":81.6,"end":90.98,"text":"שלום."},{"start":90.98,"end":95.61,"text":"רק רציתי להגיד שהיום היה לי יום הולדת והיה לי קורונה."},{"start":95.61,"end":106.33,"text":"והדבקתי את הצלם."},{"start":106.33,"end":117.68,"text":"אני לא אשכור מסכור בנושים."},{"start":117.68,"end":118.44,"text":"טינג."},{"start":118.44,"end":119.52,"text":"שלום."},{"start":119.52,"end":121.82,"text":"כאן זה מלון דן קורונה תל אביב."},{"start":121.82,"end":122.24,"text":"כן."},{"start":122.24,"end":123.4,"text":"חדרי הבידוד זה פה?"},{"start":123.4,"end":124.86,"text":"פה זה חדרי הבידוד, אדוני."},{"start":124.96,"end":126.58,"text":"יש מיכם חופשי והבריכה סגורה."},{"start":126.58,"end":128.3,"text":"אז בוא בני, בוא, תפוס את מקומך."},{"start":128.3,"end":132.45,"text":"סליחה, סליחה, רגע, רגע, מה זה תפוס את מקומך? אי אפשר ככה להיכנס לכאן."},{"start":132.45,"end":141.3,"text":"כאן זה בית, כאן זה לב, ואותך אני אוהב, שמתחים במסיכות."},{"start":141.3,"end":144.06,"text":"איזה יופי. אבל אתם לא נכנסים לפה."},{"start":144.06,"end":145.94,"text":"למה, מה, אנחנו לא אנשים מהשורה?"},{"start":145.94,"end":152.88,"text":"אפילו כשעשינו משורה, הוא מוכן מסולח, מוכן מסולח."},{"start":152.88,"end":155.71,"text":"מספיק, מספיק. אסור להיכנס לפה בזהו."},{"start":155.71,"end":159.9,"text":"למה, הוא לא מרגיש טוב. יש לו אפילו שיעולים לך."},{"start":159.9,"end":172.07,"text":"לך, דודי, לקרדקלה, לקרדקלה, פני, שבק נקבלה, נקבלה, שבק פתאום, שבק. שלום."},{"start":172.07,"end":176.76,"text":"איזה שבק ואיזה שלום? תנו, חברים. נכנסים פה רק אנשים שיש להם קורונה."},{"start":176.76,"end":179.0,"text":"זה עולה למדינה מלא כסף, זה לא זון."},{"start":179.0,"end":194.58,"text":"חבר'ה, חבר'ה, לא ידע בפה האנגלית שלך. ספר לי. לא, אל ספר."},{"start":194.58,"end":201.62,"text":"אולי בכל זאת, דוקטור. אני לא יכול. זה בניגוד לאמנת משרד הבריאות, בניגוד לאמנת הרופאים, בניגוד לאמנת ג'נבא."},{"start":201.62,"end":206.94,"text":"אמנת תיאור טוי, נות תיאור טוי, סופר פוי."},{"start":206.94,"end":212.74,"text":"חבר'ה, אפשר להיכנס פה רק באישור של משרד הבריאות, או צו מאלוף."},{"start":212.74,"end":219.22,"text":"אני אלוף העולם, מי בול, ולקום כמו גדול."},{"start":219.22,"end":222.22,"text":"אה, תראו, אז אם יש לך תלונות, אתם זמנים לתלונן לבוס הגדול."},{"start":222.22,"end":224.38,"text":"אנחנו מחר בבית הכנסת לעשית."},{"start":224.38,"end":228.58,"text":"בסדר, אז בינתיים יש פה טבע תאונות, אתם יכולים שלוח איזה פוסט."},{"start":228.58,"end":233.21,"text":"פוסטו דוואן, נת אולב, פוסטו דוואן, דוואן, דוואן, דוואן, דוואן, דוואן, דוואן, דוואן."},{"start":233.21,"end":234.97,"text":"יש לך שזן? לא מכיר את השיר."},{"start":234.97,"end":238.29,"text":"ומנילו. זה מרום פייב, מרום פייב."},{"start":238.29,"end":241.35,"text":"יאללה, אז ביי ביי."},{"start":241.35,"end":242.46,"text":"אמור, שלום?"},{"start":242.46,"end":251.56,"text":"שלום לב על שבת, שלום לב על שבת, שלום לב על שבת, שלום לב על שבת, שלום לב על שבת."},{"start":251.56,"end":254.09,"text":"אבא, אנחנו נעבור את זה?"},{"start":254.09,"end":255.58,"text":"עם ישראל חי."},{"start":255.58,"end":257.24,"text":"לא יודע, נערף, היו פה איזה שני משוגעים."},{"start":257.24,"end":258.65,"text":"שמענו אותך."},{"start":258.65,"end":262.46,"text":"כמו איזה שני משוגעים בחוף."},{"start":262.46,"end":265.64,"text":"שמרנו נגיה ביד שתינו שמירנו"},{"start":265.64,"end":268.1,"text":"זה יהודאה ביטחון"},{"start":268.1,"end":269.8,"text":"נה לא לגע"},{"start":269.8,"end":276.5,"text":"שלום רק רציתי להגיד שיום היה לי אום הולדת ויהיה לי קורונה"},{"start":276.5,"end":292.15,"text":"וכשהדבקתי איתה אישה בסאוד"},{"start":292.15,"end":293.81,"text":"כמו אותו התפקתי בקורונה"},{"start":293.81,"end":295.73,"text":"ויש לו גם תסמינים"},{"start":295.73,"end":306.86,"text":"סחר הפזח והפעם רציתי לדבר איתכם"},{"start":306.86,"end":309.14,"text":"על מסכן משה בר סימנטוב"},{"start":309.14,"end":310.98,"text":"של המנכ״ל של המשרל של הבריאות"},{"start":310.98,"end":311.54,"text":"באמא שלי"},{"start":311.54,"end":313.06,"text":"שאם לא תעשו מה שהוא אומר"},{"start":313.06,"end":314.6,"text":"אתם תהיו בר מינן בסימנטוב"},{"start":314.6,"end":316.06,"text":"ולכן הוא מדבר"},{"start":316.06,"end":317.96,"text":"הוא מנסה לדבר לעם"},{"start":317.96,"end":319.6,"text":"אבל לא לעם שלנו"},{"start":319.6,"end":321.02,"text":"באמא שלי הוא לפלפו"},{"start":321.02,"end":322.66,"text":"מה זה הלפלפייה הזאת"},{"start":322.66,"end":323.98,"text":"אפילו אין לו עגולדים"},{"start":323.98,"end":325.06,"text":"יש לו שכפקופדים"},{"start":325.06,"end":326.22,"text":"מה זה שכפקופים האלה"},{"start":326.22,"end":327.6,"text":"כי אילו הם אפילו מסגרת אליהם"},{"start":327.6,"end":328.7,"text":"הם משווים עם עצמם"},{"start":328.7,"end":330.34,"text":"כמו שני צלחות פטרי"},{"start":330.34,"end":331.86,"text":"והוא מדבר בנימוס"},{"start":331.86,"end":333.62,"text":"ובשקט ובנועם"},{"start":333.62,"end":334.24,"text":"והוא מסביר"},{"start":334.24,"end":335.78,"text":"איפה תחשב שאתה בשווייץ?"},{"start":335.78,"end":336.9,"text":"תתעורר אחורה"},{"start":336.9,"end":338.16,"text":"באמא שלי והעוזרת שלו"},{"start":338.16,"end":338.76,"text":"הדוקטור הזאת"},{"start":338.76,"end":339.38,"text":"הפרופסור"},{"start":339.38,"end":340.62,"text":"שודו קוצוציצקי"},{"start":340.62,"end":341.2,"text":"באמא שלי"},{"start":341.2,"end":342.94,"text":"זה שם של ת'"},{"start":342.94,"end":343.96,"text":"זה לא שם של בן אדם"},{"start":343.96,"end":344.86,"text":"מה זה ה..."},{"start":344.86,"end":347.02,"text":"צריך לדבר לעם"},{"start":347.02,"end":349.05,"text":"באמא שלי תתעוררו"},{"start":349.05,"end":351.05,"text":"לעם שלנו צריך לדבר"},{"start":351.05,"end":352.93,"text":"עם החיות רחמניות"},{"start":352.93,"end":353.67,"text":"באמא שלי"},{"start":353.67,"end":355.51,"text":"עם החיות רחמניות"},{"start":355.51,"end":357.15,"text":"כולם שהמכונת הנשמה"},{"start":357.15,"end":358.85,"text":"מוברגת עליהן"},{"start":358.85,"end":360.63,"text":"עם הציוד המיוחד של דוקטור קליים"},{"start":360.63,"end":362.65,"text":"שהוא כבר מרחיב לנו את הנשימה"},{"start":362.65,"end":364.09,"text":"באמא שלי עם קריות אוויר"},{"start":364.09,"end":366.17,"text":"ועם הדים לאומיים מנומרים"},{"start":366.17,"end":367.85,"text":"הולכות בכיף ככה"},{"start":367.85,"end":369.17,"text":"עם שרצרים"},{"start":369.17,"end":372.15,"text":"באמא שלי לרופאים במקום סטטוסקופסים"},{"start":372.15,"end":373.45,"text":"שאיל להם חי ככה"},{"start":373.45,"end":375.19,"text":"באמא שלי מקשיבים לנשימה שלך"},{"start":375.19,"end":376.81,"text":"ישר אתה יש לדופק מהעיר"},{"start":376.81,"end":379.11,"text":"גם מהחיות, גם מהסטטוסקופ"},{"start":379.11,"end":381.11,"text":"ולגרגל שלוש פעמים ביום עמבה"},{"start":381.11,"end":383.49,"text":"זה כל מערכת רפואה בסיסית יודעת"},{"start":383.49,"end":384.23,"text":"באמא שלי"},{"start":384.23,"end":386.65,"text":"זה צריך לשדר לעם שמחת חיים"},{"start":386.65,"end":388.07,"text":"אנחנו לא וחדים באף אחד"},{"start":388.07,"end":389.45,"text":"ואז גם האנשים"},{"start":389.45,"end":391.99,"text":"הם לא יעמדו במרפסת ואם חיו כפיים"},{"start":391.99,"end":393.59,"text":"אלא יש שימו טיפים"},{"start":393.59,"end":394.89,"text":"באמא שלי, האחות הנחמניה"},{"start":394.89,"end":397.09,"text":"באמא שלי, בא הרופאים או שסול"},{"start":397.09,"end":398.15,"text":"מהפחת שמים לו טיפ"},{"start":398.15,"end":399.77,"text":"הם רוצים כסף הרופאים"},{"start":399.77,"end":401.47,"text":"הם לא רוצים לחיות כפיים סקינים"},{"start":401.47,"end":402.71,"text":"הם כבר לא יודעים איפה הם חיים"},{"start":402.71,"end":403.57,"text":"באמא שלי"},{"start":403.57,"end":405.71,"text":"לכם חברים יקרים"},{"start":405.71,"end":408.23,"text":"העם יקר, אני רוצה לפנות אליכם"},{"start":408.23,"end":409.85,"text":"אתם התבלבלתם לגמרי"},{"start":409.85,"end":411.96,"text":"כולם לטובתכם"},{"start":411.96,"end":415.14,"text":"שנים העם שלנו למד להתחמק ממילואים"},{"start":415.14,"end":416.66,"text":"לחמוק מהבוס בעבודה"},{"start":416.66,"end":418.78,"text":"לעבוד בשחור, להיות בבית"},{"start":418.78,"end":421.14,"text":"להיות עצלן, להשתלבט, להשתות משהו"},{"start":421.14,"end":422.82,"text":"אנחנו שיעי לגרסים בבית"},{"start":422.82,"end":424.4,"text":"לא פיקשו מיכם להילחם"},{"start":424.4,"end":426.68,"text":"לא פיקשו מיטלם, מבצעים"},{"start":426.68,"end":428.56,"text":"אפילו לא תרום אדם, כלום"},{"start":428.56,"end":430.44,"text":"תשכו בבית שלכם"},{"start":430.44,"end":432.1,"text":"ואל תחשו כלום, כלום"},{"start":432.1,"end":433.58,"text":"חלום, אמא שלי"},{"start":433.58,"end":435.8,"text":"אם אתה חייב את הדירה של סבתא"},{"start":435.8,"end":436.78,"text":"תשלח עליה נחל"},{"start":436.78,"end":439.18,"text":"כי אתה, אני מבין, אתה רוצה לגמור את סבתא מהר"},{"start":439.18,"end":442.0,"text":"כדי שתתפנה הדירה בירות שלנו, אמא שלי"},{"start":442.0,"end":444.46,"text":"אבל אם לא, תשבו בבית"},{"start":444.46,"end":446.5,"text":"תתאבקו, תגרבצו"},{"start":446.5,"end":447.84,"text":"תאכלו, תתפנינו"},{"start":447.84,"end":450.62,"text":"כל מה שחלמתם כל החיים"},{"start":450.62,"end":453.04,"text":"הבנתם, כולם חולמים על זה"},{"start":453.04,"end":455.4,"text":"מהארשים ועד הפלפונים"},{"start":455.4,"end":457.04,"text":"גם אמות ואמות"},{"start":457.04,"end":458.44,"text":"וגם אבות ואבות"},{"start":458.44,"end":460.62,"text":"וגם בגולחים וגם באמא"},{"start":460.62,"end":462.8,"text":"כולם תשבו בבית"},{"start":462.8,"end":466.86,"text":"פשוט תשבו בבית"},{"start":466.86,"end":468.77,"text":"הבנתם אותי?"},{"start":468.77,"end":471.31,"text":"ככה אני צריך לדבר, דובר המסטרד של הבריאות"},{"start":471.31,"end":472.79,"text":"להסביר לכם שתבינו"},{"start":472.79,"end":474.14,"text":"צטל ביטו"},{"start":474.14,"end":477.62,"text":"ודבר חשוב אחרון, מה שהורג את הווירוס הזה"},{"start":477.62,"end":479.38,"text":"זה החום, החום"},{"start":479.38,"end":481.48,"text":"אז תפעילו מנגל בכל בית"},{"start":481.48,"end":483.9,"text":"שנים אני אומר את זה, מנגל בכל בית"},{"start":483.9,"end":486.1,"text":"פי חמים עובדים ורק צנאות כבס"},{"start":486.1,"end":487.82,"text":"לא כל הבשרים האלה, הלוקשרים"},{"start":487.82,"end":489.42,"text":"של העטלף, של הסינים"},{"start":489.42,"end":491.4,"text":"שיחנקו עם העטלף, עם הדוב נמלים"},{"start":491.4,"end":493.92,"text":"עם הפנגולים, לאמא שלי זה כיפוד מגולח"},{"start":493.92,"end":495.7,"text":"מי מגלח כיפוד? הם לא נורמלים"},{"start":495.7,"end":500.58,"text":"מנגל בפיצחום והקורונה לגנום"},{"start":500.58,"end":503.84,"text":"אז תחשבו על זה, כשאתם יושבים בבית"},{"start":503.84,"end":505.82,"text":"הבנתם? בבית, סטלפי"},{"start":505.82,"end":507.56,"text":"לא עושים כלום, זהו"},{"start":507.56,"end":512.06,"text":"בברכת סטלס בך, הילולה וטרללה"},{"start":512.06,"end":514.23,"text":"ותחשבו על זה"},{"start":514.23,"end":518.7,"text":"שלום, רק רציתי להגיד שהיום היה לי יום הולדת"},{"start":518.7,"end":523.14,"text":"והיה לי קורונה והשבק לקח אותי לבידוד"},{"start":523.14,"end":527.46,"text":"כאן זה בית, כאן זה לב"},{"start":527.46,"end":539.42,"text":"קורים לי, אוקיי?"},{"start":539.42,"end":543.45,"text":"קורים לי בשכונה, מלכת השושלים"},{"start":543.45,"end":547.41,"text":"כל מה שיש לי בנכיר אני הופך לזיפים"}]