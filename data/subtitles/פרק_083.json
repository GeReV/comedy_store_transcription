[{"start":14.66,"end":16.66,"text":"אוקיי, בוא נתחיל. אתה מסתכל על המצלמה."},{"start":16.66,"end":18.66,"text":"זאת אומרת, הקומדיסטור מיד אחרי הפרסמות."},{"start":18.66,"end":20.63,"text":"אוקיי, אני יכול להכניס, נגיד, צחוק? קטן, משהו."},{"start":20.63,"end":21.63,"text":"כן, בוא נעשה חזרה קטנה."},{"start":21.63,"end":23.78,"text":"הקומדיסטור מיד אחרי הפרסמות."},{"start":23.78,"end":24.78,"text":"סויאל, יופי."},{"start":24.78,"end":27.71,"text":"אוקיי, שלוש, שתיים, שתיים, אחד, אקשן."},{"start":27.71,"end":31.03,"text":"אם אתה אומר את הכל נמצאו, יש כל מיניים שרצים בתוך פוספת גדול,"},{"start":31.03,"end":32.03,"text":"ואף אחד לא יודע מה קורה,"},{"start":32.03,"end":36.37,"text":"והכרי גדולה של האוויר עם שש בוטנים והרבה מטירות שם, מה?"},{"start":46.37,"end":48.37,"text":"הקומדיסטור מיד אחרי הפרסמות, אם את צחוק אבל לא..."},{"start":48.37,"end":50.37,"text":"הקומדיסטור מיד אחרי הפרסמות!"},{"start":50.37,"end":52.37,"text":"מצוין, קח את הזה, זה לא זה."},{"start":52.37,"end":54.69,"text":"אוקיי, שלוש, ארבע, אקשן!"},{"start":54.69,"end":56.69,"text":"אם את הקומדיסטור יש לך הרבה אנשים שרצוקים פוספטים ואף אחד לא יודע מה קורה,"},{"start":56.69,"end":58.69,"text":"ויש שש בוטנים, אם טיר הזה גדול לומד לך עם גויבה, מה?"},{"start":58.69,"end":61.13,"text":"מה? זה לא, לא, זה לא טוב."},{"start":61.13,"end":63.06,"text":"מה? זה לא טוב, אני לא מבין מה שאתה אומר."},{"start":63.06,"end":66.19,"text":"מה זה הדיבור הזה? תגיד פשוט, חמש מילים, פשוטות."},{"start":66.19,"end":67.19,"text":"סדר, עושה שנייה..."},{"start":67.19,"end":69.19,"text":"קומדיסטור מיד אחרי הפרסמות. מה?"},{"start":69.19,"end":70.19,"text":"אתה עושה את חזרה."},{"start":70.19,"end":72.19,"text":"הקומדיסטור מיד אחרי הפרסמות."},{"start":72.19,"end":74.19,"text":"אוקיי, יאללה, 3,4, אקשה."},{"start":74.19,"end":75.19,"text":"ככה זה טוב."},{"start":75.19,"end":76.19,"text":"סדר, סדר, סדר."},{"start":76.19,"end":77.19,"text":"אקשה."},{"start":77.19,"end":78.35,"text":"אם אתה בא לכל אומדיסטור, יש ככה מי,"},{"start":78.35,"end":79.35,"text":"שש, שש, שחתו לי שרוצות, ויש לך ג'מוז גדול,"},{"start":79.35,"end":81.35,"text":"ואף אחד לא יודע מה קורה, ושש, שטירה של טוש, מה?"},{"start":81.35,"end":83.35,"text":"מה זה? לא, זה לא, אתה לא עושה את זה טוב."},{"start":83.35,"end":84.35,"text":"מה יש?"},{"start":84.35,"end":85.35,"text":"אז אסף, בוא, תעשה דאטה."},{"start":85.35,"end":86.35,"text":"אסף, בוא."},{"start":86.35,"end":87.34,"text":"מה בעיה?"},{"start":87.34,"end":89.34,"text":"מה לא, הוא לא עושה את מסעיר."},{"start":89.34,"end":90.34,"text":"למה? מה את רוצה שהוא יגיד?"},{"start":90.34,"end":93.34,"text":"הקומדיסטור מידי חמש מילים שוטו, הקומדיסטור מיד אחרי הפרסמות."},{"start":93.34,"end":95.34,"text":"תמוך עליי, גיל, סתכל לה מצלמה ותגיד,"},{"start":95.34,"end":97.34,"text":"אם אתה רוצה לשבל את הביצות, אתה לא צריך עליו את זה,"},{"start":97.34,"end":98.34,"text":"אתה צריך עליו את זה, אתה צריך עליו כמה דמוסים,"},{"start":98.34,"end":99.53,"text":"שזה לא קורה עם מה?"},{"start":99.53,"end":101.53,"text":"תגיד את זה, הוא כסמוך עליי, תן לו אסף."},{"start":101.53,"end":102.62,"text":"תודה אסף."},{"start":102.62,"end":104.45,"text":"אסף."},{"start":104.45,"end":104.55,"text":"הקשן."},{"start":104.45,"end":106.45,"text":"הקומדיסטור מיד אחרי הפרסמות."},{"start":106.45,"end":107.45,"text":"אחלה תוכנית."},{"start":125.75,"end":157.19,"text":"ומאתה הם ניקאים."},{"start":157.19,"end":163.7,"text":"טוב טוב, אני ביקשתי מהבמהי לצאת רגע מהקטש לצחוקים ולעשות משהו קצת לא שגרתי בתוכנית."},{"start":163.7,"end":169.97,"text":"יש לי וידוי, אתם לא יודעים את זה, אבל יש לי אח תאום, כן?"},{"start":169.97,"end":170.97,"text":"כי אני יודע שאתם מופתעים."},{"start":170.97,"end":173.94,"text":"יש לי אח תאום, לא סתם תאום, תאום זהה."},{"start":173.94,"end":180.09,"text":"עד עכשיו היה נוח לנו לא לחשוף את העניין כי היינו ככה יכולים לשגע את כולם שגענו את כל העולם,"},{"start":180.09,"end":184.04,"text":"אבל עכשיו התבגרנו וזה הזמן להציג אותו בפניכם."},{"start":184.04,"end":186.04,"text":"פעם ראשונה, ליאור, אחי התאום."},{"start":186.04,"end":188.45,"text":"אהלן, ליאור, מעניין, חמוד."},{"start":188.45,"end":190.45,"text":"קודם כל זה מאמא, זה אחד."},{"start":190.45,"end":193.45,"text":"תודה, וואה, וואה, תודה."},{"start":193.45,"end":194.95,"text":"תודה."},{"start":194.95,"end":195.95,"text":"תודה, זה צילום נדיר."},{"start":195.95,"end":198.95,"text":"פעם ראשונה אנחנו ביחד מצטלמים לתלווי."},{"start":198.95,"end":199.95,"text":"יאללה, אסף, בואו, בואו, בואו."},{"start":199.95,"end":201.95,"text":"תצטלם לי, יש לי, יש לי חווי מצלם מהר, אוקיי, בוא."},{"start":201.95,"end":202.95,"text":"אסף."},{"start":202.95,"end":203.95,"text":"אני לא אסף, אני ליאור."},{"start":203.95,"end":205.58,"text":"די, בואו."},{"start":205.58,"end":208.58,"text":"אתם שגעו אותי אתם, תהיה את הטבע."},{"start":208.58,"end":210.58,"text":"אתה דרך מצטלם עכשיו."},{"start":210.58,"end":212.58,"text":"זה אנחנו, אני..."},{"start":212.58,"end":214.58,"text":"כמו שאמרתי שאני עשה וידוי, אני עשיתי אותו."},{"start":214.58,"end":215.58,"text":"אתה עכשיו כאילו מגלה לכולם את הכל מה?"},{"start":215.58,"end":216.58,"text":"גיליתי, זה מצולם, כן."},{"start":216.58,"end":217.58,"text":"בואו נה, תראה, מה..."},{"start":217.58,"end":219.84,"text":"בואו על התאומים, לך תדע."},{"start":219.84,"end":220.84,"text":"תראה מה זה."},{"start":220.84,"end":221.84,"text":"הנה, באמת, זה הזמן..."},{"start":221.84,"end":223.84,"text":"הבאתי את התמונות מאמא."},{"start":223.84,"end":224.84,"text":"הגיע הזמן, כן,"},{"start":224.84,"end":227.84,"text":"להראות לכם כמה תמונות ביחד שלנו מהילדות."},{"start":227.84,"end":228.84,"text":"הנה שנינו בגן."},{"start":228.84,"end":230.84,"text":"היינו חברים מאוד טובים."},{"start":230.84,"end":231.84,"text":"מאוד, מאוד."},{"start":231.84,"end":233.84,"text":"אתה זוכר שתמיד יתמושך הבשרות."},{"start":233.84,"end":235.84,"text":"כן, הנה זה..."},{"start":235.84,"end":236.84,"text":"זה פה בבר מצווה."},{"start":236.84,"end":238.84,"text":"מונה, זה אחלה כיף, תמי."},{"start":238.84,"end":239.84,"text":"אבל ללי אנחנו נחתם, תראה."},{"start":239.84,"end":240.84,"text":"הנה, ופה אנחנו בצבא."},{"start":240.84,"end":242.84,"text":"היינו לפעמים עושים שבוע שבוע."},{"start":242.84,"end":243.84,"text":"שבוע, אני הולך שבוע,"},{"start":243.84,"end":244.84,"text":"הוא באותו בסיס,"},{"start":244.84,"end":245.84,"text":"והמפקדים לא יסומים לב."},{"start":245.84,"end":246.84,"text":"איזה חיים היינו, זה טיון."},{"start":246.84,"end":247.84,"text":"פאב."},{"start":247.84,"end":250.45,"text":"אפשר להם על הפרסומות,"},{"start":250.45,"end":251.45,"text":"העניין הזה שלא רוצים."},{"start":251.45,"end":252.45,"text":"לא, לא, לא."},{"start":252.45,"end":253.45,"text":"עזוב אותך ספר,"},{"start":253.45,"end":254.45,"text":"אין פה אתם מדברים כבר."},{"start":254.45,"end":256.45,"text":"אני אספר את זה, אני אספר את זה."},{"start":256.45,"end":257.45,"text":"בקיצור,"},{"start":257.45,"end":260.45,"text":"בקיצור, לליאור רצה להשתתף בכמה פרסומות, כמו שאתם יודעים."},{"start":260.45,"end":262.45,"text":"בכמה? שתיים? שלא."},{"start":262.45,"end":265.45,"text":"ובכל הפרסומות האלף זה, אף אחד לא יודע, גם אני השתתפתי."},{"start":265.45,"end":271.44,"text":"אבל איפשהו הבמיים של הפרסומות לא אהבו את זה ששני פרצופים שמראים ממש אותו דבר פרסומת,"},{"start":271.44,"end":273.44,"text":"אז חתכו אותי, לא יודע למה דווקא חתכו אותי."},{"start":273.44,"end":278.44,"text":"אז בואו נראה כמה קטעים שלא שודרו אף פעם, שרואים את הגרסה המילה של הפרסומות."},{"start":278.44,"end":280.44,"text":"הנה."},{"start":280.44,"end":287.44,"text":"פה אתם רואים את הפרסומת של השמפו, שיושב ובוכה, ועכשיו הנה בא קטע האחרון שלא שודר מעולם."},{"start":287.44,"end":293.84,"text":"לא נורא, יש הרבה דגים היום."},{"start":293.84,"end":298.84,"text":"מה זה, שמפו בריח בצל?"},{"start":298.84,"end":303.84,"text":"אז בגלל זה הדמעות, השמתי בגלל הבכורה."},{"start":303.84,"end":305.84,"text":"תסביר, אתה בא אליי."},{"start":305.84,"end":309.84,"text":"כן, עכשיו הנה, זה הקטע הפרסומת מאוד מפורסמת."},{"start":309.84,"end":313.84,"text":"בסוף אפשר לדעת מה באמת היה מתחת למעיל שלו,"},{"start":313.84,"end":314.84,"text":"ומה באמת הפחיד את יעל."},{"start":314.84,"end":316.84,"text":"זה גדול, זה גדול."},{"start":316.84,"end":319.84,"text":"משום מה בחרו לא לשדר את זה, אבל זאת באמת הזדמנות להם."},{"start":319.84,"end":337.57,"text":"בואו יונה אחי, שיחקת אותה?"},{"start":337.57,"end":340.57,"text":"תודה רבה, באמת אחלה."},{"start":340.57,"end":341.57,"text":"אליי, אליי, בוא, בוא."},{"start":341.57,"end":342.57,"text":"עשה, בוא."},{"start":342.57,"end":345.57,"text":"כיף לראות, באמת כיף לראות שאתם חברים טובים מעבר לזה,"},{"start":345.57,"end":346.57,"text":"זה טענוג."},{"start":346.57,"end":351.38,"text":"אה, בואי נהביר את הביתה בו, בואי תח, יאללה."},{"start":384.27,"end":386.27,"text":"תודה רבה."},{"start":414.27,"end":416.27,"text":"תודה רבה."},{"start":416.27,"end":423.03,"text":"יש לי פרסומת שמעצבנת אנשים."},{"start":423.03,"end":426.25,"text":"יש לי שיר שמעצבנת אנשים."},{"start":426.25,"end":430.53,"text":"על ראש הברושה וחסר, שמחה ועמולה."},{"start":430.53,"end":434.53,"text":"שם כל הציפורים בעיר הקימו מקלה."},{"start":434.53,"end":443.42,"text":"תבין לביס."},{"start":443.42,"end":454.83,"text":"ביטון!"},{"start":454.83,"end":456.16,"text":"ביטון!"},{"start":456.16,"end":460.45,"text":"וואלה, החיים הפכו להיות משעממים בלי ביטון."},{"start":460.45,"end":461.37,"text":"ביטון!"},{"start":461.37,"end":463.44,"text":"ביטון!"},{"start":463.44,"end":464.75,"text":"ביטון!"},{"start":464.75,"end":466.72,"text":"איטון!"},{"start":466.72,"end":469.02,"text":"שלום!"},{"start":469.02,"end":470.08,"text":"מי אתה?"},{"start":470.08,"end":472.22,"text":"אתה אין סמצקילה."},{"start":472.22,"end":473.46,"text":"מה אתה רוצה?"},{"start":473.46,"end":475.71,"text":"אתה רוצה אליהם חברים."},{"start":475.71,"end":476.71,"text":"אתה רוצה להיות חבר שלי?"},{"start":476.71,"end":477.63,"text":"אה!"},{"start":477.63,"end":478.83,"text":"יש לך מחשבות אתה?"},{"start":478.83,"end":479.89,"text":"מחשבות איתה?"},{"start":479.89,"end":480.98,"text":"מחשבות, מחשבות"},{"start":480.98,"end":482.01,"text":"מחשבות, מחשבות"},{"start":482.01,"end":483.36,"text":"מחשבות, מחשבות"},{"start":483.36,"end":484.36,"text":"יש לך איזה מחשבה"},{"start":484.36,"end":485.36,"text":"משהו במישור הפילוסופי"},{"start":485.36,"end":486.36,"text":"לטרופי"},{"start":486.36,"end":488.36,"text":"איזה החיים זה כמו"},{"start":488.36,"end":490.36,"text":"החיים זה ככה"},{"start":490.36,"end":491.36,"text":"תגיד מה קרה לאמא שלך"},{"start":491.36,"end":492.32,"text":"תגיד מה קרה לאמא שלך"},{"start":492.32,"end":493.8,"text":"הלו?"},{"start":493.8,"end":494.8,"text":"ביטול!"},{"start":494.8,"end":495.76,"text":"מה זה?"},{"start":495.76,"end":497.76,"text":"מה תקעת אותי, הרב בל?"},{"start":497.76,"end":502.38,"text":"אלוהים, אלוהים חברים"},{"start":502.38,"end":503.6,"text":"אה?"},{"start":503.6,"end":504.69,"text":"תבין?"},{"start":504.69,"end":505.69,"text":"תבין"},{"start":505.69,"end":506.69,"text":"אתה לא יכול להיות חבר שלי"},{"start":506.69,"end":508.69,"text":"אלא מחסר לך מישור שלם"},{"start":508.69,"end":509.69,"text":"מישור שללם"},{"start":509.69,"end":510.69,"text":"מישור שלם"},{"start":510.69,"end":512.84,"text":"מישור שלם"},{"start":512.84,"end":513.91,"text":"לא"},{"start":513.91,"end":514.91,"text":"המישור הפילוסופי אין לך"},{"start":514.91,"end":515.91,"text":"פילוסופי לך"},{"start":515.91,"end":516.91,"text":"אין לך פילוסופיה"},{"start":516.91,"end":517.91,"text":"פילוסופיה"},{"start":517.91,"end":518.91,"text":"אושפי"},{"start":518.91,"end":520.0,"text":"יש לך פילוסופיה"},{"start":520.0,"end":521.0,"text":"אושפי"},{"start":521.0,"end":522.0,"text":"אושפי"},{"start":522.0,"end":523.0,"text":"מה יש לך?"},{"start":523.0,"end":524.0,"text":"אלא ניטשה"},{"start":524.0,"end":525.48,"text":"ראה"},{"start":525.48,"end":527.61,"text":"ניטשה היה אומר"},{"start":527.61,"end":528.93,"text":"רגע"},{"start":528.93,"end":529.92,"text":"מי זה ניטשה?"},{"start":529.92,"end":535.66,"text":"שבוצקיל על הידות שלי הוא פלסלוף"},{"start":535.66,"end":539.1,"text":"פלסלוף?"},{"start":539.1,"end":540.1,"text":"המוות"},{"start":540.1,"end":542.38,"text":"הוא חלק אינטגרלי מן החיים"},{"start":542.38,"end":544.38,"text":"הן יולדות אותנו מעל לקברים פתוחים"},{"start":544.38,"end":547.26,"text":"לרגע יש נצנוץ של אוריום"},{"start":547.49,"end":548.53,"text":"ואחר כך..."},{"start":548.53,"end":549.5,"text":"כאוס"},{"start":549.5,"end":551.1,"text":"אה חיה"},{"start":551.1,"end":552.14,"text":"תגיד"},{"start":552.14,"end":554.05,"text":"איזה מה גגדה יפה לעלימה שכה?"},{"start":554.05,"end":556.42,"text":"הלימה שכה עלה עיגי עייף"},{"start":556.42,"end":557.55,"text":"לא יודע"},{"start":557.55,"end":558.65,"text":"לוב חברים"},{"start":558.65,"end":559.65,"text":"אה?"},{"start":559.65,"end":560.57,"text":"ילבי"},{"start":560.57,"end":561.78,"text":"הלבי"},{"start":561.78,"end":564.09,"text":"הלבי"},{"start":564.09,"end":565.09,"text":"אין עבודה"},{"start":565.09,"end":566.09,"text":"אין חברים"},{"start":566.09,"end":567.15,"text":"ומה לעשות?"},{"start":567.15,"end":569.23,"text":"איטון"},{"start":569.23,"end":572.03,"text":"תודה רבה."},{"start":603.32,"end":605.32,"text":"תודה רבה."},{"start":605.32,"end":605.42,"text":"תודה רבה."},{"start":605.32,"end":608.66,"text":"תודה רבה."},{"start":649.87,"end":669.59,"text":"רעידת אדמה היא אסון טבע."},{"start":669.59,"end":672.59,"text":"אל תנצל את המפגע לטובתך האישית."},{"start":672.59,"end":676.77,"text":"זה בסדר, אמר גוטמן, אני רק צריך להתייעץ עם השותף שלי."},{"start":676.77,"end":679.77,"text":"זה מניב לנו רווח שלי יותר מי מאלף, תסגור את זה."},{"start":679.77,"end":681.77,"text":"7.2 אחוז זה בסדר המזומן אצלנו."},{"start":681.77,"end":702.28,"text":"רעידת אדמה היא לא הזמן ליצירת קשרים חברתיים."},{"start":702.28,"end":703.23,"text":"תורכה."},{"start":703.23,"end":722.79,"text":"אדוני, מה תעשה, אדוני!"},{"start":722.79,"end":728.94,"text":"תרגע!"},{"start":728.94,"end":736.0,"text":"בזמן רעידת אדמה, לעולם, אבל לעולם, אל תעסוק בפעילות שעלולה להזיק לאחרים."},{"start":736.0,"end":740.49,"text":"נו, לפתוח פאה."},{"start":740.49,"end":742.83,"text":"כן."},{"start":742.83,"end":754.12,"text":"עשיתי לך כבר טיפול שורש חינם."},{"start":754.12,"end":761.43,"text":"למרבה הפלא, יש מקרים שבהם רעידת האדמה עשויה לגרום לתוצאות חיוביות."},{"start":781.38,"end":800.03,"text":"לסיכום, בפעם הבאה שתתקל ברעידת אדמה אולי עדיף שתתקל בה ולא באיזה רמי כמו שאול שעובד עליך בעיניים הנה, קחת הכסף שלך."},{"start":800.03,"end":806.72,"text":"קל ההפקות גאים להציג את הפרק החמישי בסדרה הקומית הישראלית הגרועה ביותר."},{"start":806.72,"end":808.71,"text":"משפחת ישראלי."},{"start":808.71,"end":843.24,"text":"מה לך בדיוק?"},{"start":843.24,"end":847.24,"text":"אני, אני מודק את השפעת הקפה על השלט רחוק."},{"start":847.24,"end":852.18,"text":"אקזמה, תביא את השלט עוד מעט מתחיל בטלוויזיה אזור הדמדומים."},{"start":852.18,"end":854.34,"text":"למה, מה זה בכלל אזור הדמדומים?"},{"start":854.34,"end":858.34,"text":"את לא יודעת, תשאלי איתי מה שלך היא באה משם."},{"start":858.34,"end":863.75,"text":"או ייציק, לפעמים אתה כל כך אידיון."},{"start":863.75,"end":866.17,"text":"ערב טוב!"},{"start":866.17,"end":870.74,"text":"לארפלד פנית, קיבלת..."},{"start":870.74,"end":871.74,"text":"אולקוס!"},{"start":871.74,"end":873.74,"text":"איזה גלבע, לקיפ-קיפי."},{"start":873.74,"end":875.74,"text":"וזה מזכיר לי בדיכה גדולה, שימו לב."},{"start":875.74,"end":878.7,"text":"אחד בא לחבר שלו ואומר לו:"},{"start":878.7,"end":883.7,"text":"תן לי קוס קפה עם עשר קפיות סוכר, אבל אל תערבב."},{"start":883.7,"end":884.7,"text":"למה?"},{"start":884.7,"end":887.34,"text":"כי הוא לא אוהב מתוק."},{"start":887.34,"end":890.93,"text":"איזה גניבן."},{"start":890.93,"end":891.93,"text":"וסוכתיק."},{"start":891.93,"end":894.63,"text":"עכשיו, מה מתחיק פה?"},{"start":894.63,"end":895.69,"text":"מה מתחיק?"},{"start":895.69,"end":898.69,"text":"איך אני כבר 40 דקות מתחת לספה הענתיק כזאת,"},{"start":898.69,"end":900.67,"text":"ולא הצעתם לי קפה?"},{"start":900.67,"end":907.22,"text":"אם זה מה שיגרום לך לסתום את הפה על,"},{"start":907.22,"end":909.22,"text":"היא מציע לך את כל ברזיל."},{"start":909.22,"end":911.6,"text":"סמבא אלקטרוליטי."},{"start":911.6,"end":913.6,"text":"בוסנובה רקטלית."},{"start":913.6,"end":914.6,"text":"רוק אלטרנטיבי."},{"start":914.6,"end":915.6,"text":"רומבה אנלית."},{"start":915.6,"end":917.56,"text":"הקרנבל של מיכל."},{"start":917.56,"end":920.56,"text":"תשתקוש לכם איזה צמד מטומטמים."},{"start":920.56,"end":924.65,"text":"הנה אלפרד, כך בבקשה קפה שאודי הכין ותרגע."},{"start":924.65,"end":930.49,"text":"מה זה?"},{"start":930.49,"end":937.47,"text":"יש לזה טעם של גפילטפיש מעורבב עם ריביים שופי וכריס?"},{"start":937.47,"end":943.47,"text":"אני מצטער אמא, אני ניסיתי להמציא קפה שבמקום להורר הוא מרדים."},{"start":943.47,"end":944.75,"text":"מפגר!"},{"start":944.75,"end":948.78,"text":"אם היינו רוצים להירדם יכולנו ללכת לראות הופעה של אלפרד."},{"start":948.78,"end":951.78,"text":"או, הנה מתחיל אזור הדמדומים."},{"start":951.78,"end":955.8,"text":"או, מה זה המכוער הקריח הזה?"},{"start":955.8,"end":957.12,"text":"אוי."},{"start":957.12,"end":959.12,"text":"רודי, מה שומת בקפה?"},{"start":959.12,"end":960.12,"text":"אוי."},{"start":960.12,"end":965.64,"text":"גדול, גדול."},{"start":965.64,"end":970.7,"text":"דרך אגב, רודי, אופי חבר שלך איזה סנוב ראותי אתמול בחור, הוא לא אמר לי שום."},{"start":970.7,"end":972.7,"text":"טוב, בטח הוא לא זיהה אותך עם הבגדים."},{"start":972.7,"end":975.7,"text":"לא, רודי!"},{"start":975.7,"end":980.16,"text":"מה אתה מתפלא?"},{"start":980.16,"end":982.16,"text":"אתה באמת לא מצחיק, אתה יודע מי מצחיק?"},{"start":982.16,"end":983.34,"text":"אלפרד?"},{"start":983.34,"end":986.37,"text":"אלפרד, הוא מצחיק רק חבל שאין לו תוכנית בטלוויזיה."},{"start":986.37,"end":988.37,"text":"כל פעם שהיינו רואים אותו היינו מחליפים ערוץ."},{"start":988.37,"end":996.21,"text":"יאי חברת די שם, מספיק חברת די."},{"start":996.21,"end":998.21,"text":"יאי חברת די!"},{"start":998.21,"end":1003.79,"text":"עוד פעם הבאז לכאן את כל ההודים של ביתה."},{"start":1003.79,"end":1006.79,"text":"כמה פעמים אמרתי לך להפסיק לצאת איתם, הם לא בשבילך."},{"start":1006.79,"end":1008.79,"text":"הגיע הזמן שתגידי להם שלום."},{"start":1008.79,"end":1014.21,"text":"מדי!"},{"start":1014.21,"end":1020.05,"text":"מהבואי אני חושב שמטפקנו."},{"start":1020.05,"end":1023.1,"text":"יושבים שם למעלה, חם ויפת,"},{"start":1023.1,"end":1026.58,"text":"והם מארגלים את כל הכנונייה הזאתי."},{"start":1026.58,"end":1028.55,"text":"זה מתפלא על האינטליגנציה שלך."},{"start":1028.55,"end":1030.58,"text":"איך חם ויפת יכולים להיות שם?"},{"start":1030.58,"end":1032.58,"text":"כשאתה ואני כאן."},{"start":1032.58,"end":1035.25,"text":"אפרסמון פתולוגי."},{"start":1035.25,"end":1038.25,"text":"אפרסמון פתולוגי אתם עצמך!"},{"start":1038.25,"end":1040.17,"text":"כליו במשבר."},{"start":1040.17,"end":1042.27,"text":"כליו במשבר עם משבר."},{"start":1042.27,"end":1045.65,"text":"לולטרנגולים אינטראקטיבי."},{"start":1045.65,"end":1050.47,"text":"לא כבר תשתקו שלכם צמד מצ'וריסטי בגיל?"},{"start":1050.47,"end":1052.5,"text":"אתם לא רואים שהמשפחה במשבר?"},{"start":1052.5,"end":1055.5,"text":"זה לא הזמן להיב, עכשיו צריך להתאחד."},{"start":1055.5,"end":1058.5,"text":"כולנו יחד ננצח אותם."},{"start":1058.5,"end":1061.01,"text":"ישראלי המאוחדת!"},{"start":1061.01,"end":1064.0,"text":"אלי, אלי, ישראלי!"},{"start":1064.0,"end":1066.89,"text":"אלי, אלו!"},{"start":1066.89,"end":1083.55,"text":"אלו נושא שונה לגמרי."},{"start":1083.55,"end":1085.55,"text":"הפעם נמצא איתי באולפן הממציא הצרפתי"},{"start":1085.55,"end":1087.55,"text":"והמדען הישראלי מר \"איב-גי-משה\"."},{"start":1087.55,"end":1089.55,"text":"אה, סליחה, סליחה, סליחה."},{"start":1089.55,"end":1091.73,"text":"זה \"איב-גי-משה\"."},{"start":1091.73,"end":1093.73,"text":"ולא \"כפי שציינת\"."},{"start":1093.73,"end":1095.73,"text":"אה, אם כן, ערב טוב לך מר \"גי-משה\"."},{"start":1095.73,"end":1097.73,"text":"אתה יכול לקרוא לי \"איב\", זה בסדר."},{"start":1097.73,"end":1099.73,"text":"אז \"גוד-איב-נינג\"."},{"start":1099.73,"end":1101.73,"text":"אה, שאתה שם, ברדה גרם, השם נושא טופתנו!"},{"start":1101.73,"end":1108.73,"text":"אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, אה, סלמון מוניר."},{"start":1108.73,"end":1109.7,"text":"סליחה?"},{"start":1109.7,"end":1114.04,"text":"\"געדת הודה\" זה, אה, אה, אה, אה, לא כבר כלום."},{"start":1114.04,"end":1116.1,"text":"כן, אם כן, מה הבאת לנו הפעם?"},{"start":1116.1,"end":1121.1,"text":"וכן, הפעם, הכי נוטי, מכונה בומבסט, אקטראורדינר, פשוט להתפעל."},{"start":1121.1,"end":1123.01,"text":"אפשר לראות?"},{"start":1123.01,"end":1126.29,"text":"בבקשה."},{"start":1126.29,"end":1127.29,"text":"אווו..."},{"start":1127.29,"end":1130.08,"text":"בומבסט, גרנדיאזיק, מונארט."},{"start":1130.08,"end":1132.23,"text":"מה היא עושה?"},{"start":1132.23,"end":1135.71,"text":"זוהי המכונה שעושה ז'עדת עודה."},{"start":1135.71,"end":1137.28,"text":"ז'עדת עודה?"},{"start":1137.28,"end":1138.28,"text":"אכן."},{"start":1138.28,"end":1139.37,"text":"מה אתה יכול להדגין?"},{"start":1139.37,"end":1140.37,"text":"בבקשה."},{"start":1140.37,"end":1144.39,"text":"ז'עדת עודה."},{"start":1144.39,"end":1148.35,"text":"ז'עדת עודה."},{"start":1148.35,"end":1151.35,"text":"בבסבר, בבקשה. גרנדיאזיק, אקטראורדינר."},{"start":1151.35,"end":1154.3,"text":"זה יפה. איך אתה קורא למכונה הזו?"},{"start":1154.3,"end":1158.2,"text":"וזה אני קורא לה אסף."},{"start":1158.2,"end":1159.36,"text":"אסף."},{"start":1159.36,"end":1163.36,"text":"כן, אם כן, אתה יכול שוב להדגים את ז'עדת עודה?"},{"start":1163.36,"end":1165.36,"text":"במיוחד בשבילך, בבקשה, שים לב."},{"start":1165.36,"end":1168.61,"text":"ז' ז' ז' גרטה גרטה. ומאו!"},{"start":1168.61,"end":1171.61,"text":"בוז, בוז. ז' ז' ויק ויק."},{"start":1171.61,"end":1174.28,"text":"ז'עדת עודה."},{"start":1174.28,"end":1176.28,"text":"אקטראורדינר, ביב לפרנס. גדול, גרנדיאזיק."},{"start":1176.28,"end":1178.21,"text":"אני יכול גם לנסת?"},{"start":1178.21,"end":1181.41,"text":"בבקשה, בבקשה, בשבילך, למה לא?"},{"start":1181.41,"end":1191.28,"text":"גר, גר, גר, גר, גר, גר, גר, גר, גר, גר, גר, גר, גר, גר."},{"start":1191.28,"end":1199.86,"text":"המכונה היא לא עשתה, גרדת עודה."},{"start":1199.86,"end":1205.86,"text":"כמובן, כמובן, מה שחזית כרגע, מה שראית זה כמובן, מנגנון הגנה יוצא מגדר הרגיל."},{"start":1205.86,"end":1207.86,"text":"זה מנגנון הגנה מניףיקה של המכונה הזאת."},{"start":1207.86,"end":1213.86,"text":"לא כל בן אדם יכול פשוט לבוא לעשות למכונה זאת זאת גרתה גרתה וזווז."},{"start":1213.86,"end":1216.11,"text":"ואי תענה לו ב..."},{"start":1216.11,"end":1218.11,"text":"ג'אדת עודה."},{"start":1218.11,"end":1221.11,"text":"אם כן תודה רבה לך, זה הכל להפעם כאן במבזק של ז'אק."},{"start":1221.11,"end":1225.11,"text":"אה, רוקס ניכיים יותר לבסורדש לעברום הזרזר."},{"start":1225.11,"end":1227.11,"text":"לא בשום פנים ואופן..."},{"start":1227.11,"end":1229.11,"text":"מזל כי אני שונא אותו, הוא טיפוס חר הגדול."},{"start":1229.11,"end":1231.11,"text":"חייב לי המון כסף, מתאב אותו."},{"start":1231.11,"end":1232.11,"text":"מה..."},{"start":1232.11,"end":1233.11,"text":"איכס פשוט."},{"start":1233.11,"end":1236.11,"text":"כן. אם כן זה הכל להפעם כאן במבזק של ז'אק."},{"start":1236.11,"end":1238.11,"text":"לילה טוב והמשך צפייה מהנה"},{"start":1238.11,"end":1239.63,"text":"ג'עדת עודה"}]