[{"start":37.22,"end":41.5,"text":"רבותיי, לא יאמן, אנחנו כאן בשידור ישיר, בתחרות, הליפות, הליפות."},{"start":41.5,"end":42.26,"text":"אוקיי, מיד."},{"start":42.26,"end":66.21,"text":"הגיעו לכאן שניים, ואנחנו נמצאים ממש בגמר, המתמר, ובכן, אנחנו מאחלים, מאחלים."},{"start":66.21,"end":71.58,"text":"יום שחור לספורט הישראלי, ימנייק, יזבל, ימנייק, תודה."},{"start":71.58,"end":79.07,"text":"עד כאן, יום שחור גם לי בעצמי, תודה."},{"start":79.07,"end":82.5,"text":"בואי יזבל, בואי נתפל לך את הצורה, בואי יזבל, בואי, מה קרה?"},{"start":82.5,"end":90.96,"text":"אנו מעדיפים את הביצוע היהודי העברי הקדום לשיר, ותרשי לי לתרום לך את הקרפה לך בקונדום."},{"start":90.96,"end":99.72,"text":"ובכן, הלייטים שהגיעו אל המקומות הראשונים, זוהי העורכת המוזיקלית שלנו."},{"start":99.72,"end":105.23,"text":"שיר שהושמע כבר, אך יושמע במיוחד שוב ליום העצמאות."},{"start":105.23,"end":106.93,"text":"איזה ניסוח מטומטם."},{"start":106.93,"end":111.03,"text":"איך מפה זבוב תורדני?"},{"start":111.03,"end":113.6,"text":"יתושי הצצא תוקפים אותי."},{"start":113.6,"end":116.07,"text":"איזה ניסוח מטומטם."},{"start":116.07,"end":118.07,"text":"רבותיי, תופר לפלף בשטח."},{"start":118.07,"end":120.26,"text":"מה מצחיק אותך?"},{"start":120.26,"end":122.32,"text":"נהקירו אותך."},{"start":122.32,"end":124.32,"text":"נהקירו אותך."},{"start":124.32,"end":126.44,"text":"חובה! שקץ יהיה פה."},{"start":126.44,"end":130.44,"text":"תופר לפלף בשטח לא שאת הלפלפים בכל השראהם יהיו."},{"start":130.44,"end":132.46,"text":"מה אני אומר אין לי מוסר."},{"start":132.46,"end":134.46,"text":"לא, לא, לא, לא, לא, לא."},{"start":134.46,"end":138.32,"text":"טוב, רבית זבל, אתה לא נפל."},{"start":138.32,"end":140.32,"text":"את מחזיק, מה אתה רוצה? אתה לא נפל איתך."},{"start":140.32,"end":145.6,"text":"בהמתחתי כוחות על שוברענו לכם לברוח מפה לעזזל."},{"start":145.6,"end":150.69,"text":"אתם תברחו בכל, פוצו לכם פוצו!"},{"start":150.69,"end":152.84,"text":"ערב זק!"},{"start":152.84,"end":156.9,"text":"זה חיה, זה לא כלב, זה סוסיעות, זה..."},{"start":156.9,"end":161.02,"text":"זה דוחיפת הרים, זה לא יומן מה זה."},{"start":161.02,"end":163.82,"text":"ערב זק! איפה אנחנו?"},{"start":163.82,"end":165.82,"text":"בחלאסטרה של גוזו."},{"start":165.82,"end":167.82,"text":"ועכשיו..."},{"start":167.82,"end":169.85,"text":"איפה אנחנו?"},{"start":169.85,"end":171.85,"text":"האם בפנטה של גודי? לא."},{"start":171.85,"end":173.91,"text":"האם בלולו? לא."},{"start":173.91,"end":178.73,"text":"וכל מה שיש לו רגל זה..."},{"start":178.73,"end":181.3,"text":"מה דבילי שלי?"},{"start":181.3,"end":183.3,"text":"מה אני מדבר? מה עושה?"},{"start":183.3,"end":186.3,"text":"אנחנו לא היו נפרדים ממני, אני נפרד מעצמי."},{"start":186.3,"end":189.94,"text":"למעשה זאת פרידה שלי עם עצמי, כי הצעתי דביל."},{"start":189.94,"end":192.94,"text":"אבל מה שאני רוצה לומר זה... בוא נתחיל מהתחלה."},{"start":192.94,"end":198.13,"text":"קיצן התקבלה ההחלטה לתת לצביקה את תוכנית הבידור של יום שישי."},{"start":198.13,"end":210.3,"text":"את הולכם שחקו נא איתי. אליי צד..."},{"start":210.3,"end":215.41,"text":"מספיק, מספיק. מאיר, למה אתה בוחר?"},{"start":215.41,"end":218.41,"text":"דודו שבר לי את המשקפיים."},{"start":218.41,"end":221.5,"text":"דודו, למה שברת למהיר את המשקפיים?"},{"start":221.5,"end":224.5,"text":"הוא קורא לי כל הדמן בשמות, הוא מלגלי גלי."},{"start":224.5,"end":226.46,"text":"הוא אומר לי דמרי."},{"start":226.46,"end":228.46,"text":"זה לא יפה."},{"start":228.46,"end":229.46,"text":"מאיר, זה לא יפה."},{"start":229.46,"end":231.46,"text":"זה לא יפה."},{"start":231.46,"end":234.46,"text":"דודו, דודו, צא החוצה."},{"start":234.46,"end":236.46,"text":"דודו, צא החוצה."},{"start":236.46,"end":238.46,"text":"צא החוצה, דודו."},{"start":238.46,"end":241.51,"text":"צביקה, בוא תחליף אותו."},{"start":241.51,"end":246.63,"text":"ערב טוב, מייקל."},{"start":246.63,"end":249.63,"text":"ערב טוב, ז'וק, נעים מאוד להיות איתך באולפן."},{"start":249.63,"end":250.85,"text":"ערב טוב."},{"start":250.85,"end":253.97,"text":"מתי? אני לא רגיל שהוא לא מדבר אליי שטויות."},{"start":253.97,"end":254.97,"text":"ערב טוב."},{"start":254.97,"end":255.97,"text":"שלום, שלום."},{"start":255.97,"end":256.97,"text":"שלום, שלום."},{"start":256.97,"end":258.03,"text":"ערב טוב."},{"start":258.03,"end":259.25,"text":"ערב צח."},{"start":259.25,"end":262.99,"text":"אין לי מושג מה, אני צריך להגיד לך."},{"start":262.99,"end":264.99,"text":"אני רוצה להתאבד."},{"start":264.99,"end":266.99,"text":"יפה, הגעת למקום הנכון."},{"start":266.99,"end":268.69,"text":"אה."},{"start":268.69,"end":269.69,"text":"סיבת ההתאבדות."},{"start":269.69,"end":270.69,"text":"דיכאון ממושך."},{"start":270.69,"end":272.69,"text":"דיכאון זה ברור, אבל בגלל מה?"},{"start":272.69,"end":275.36,"text":"צביקה, לפחות אל תצחק לי."},{"start":275.36,"end":277.36,"text":"תמשיך, תמשיך, אני תמשיך."},{"start":277.36,"end":278.42,"text":"דיכאון בגלל מה?"},{"start":278.42,"end":279.33,"text":"הכול בג..."},{"start":279.33,"end":281.79,"text":"תמשיך!"},{"start":281.79,"end":282.79,"text":"תמשיך, ימייק."},{"start":282.79,"end":284.79,"text":"איזה רכבת אתה רוצה לדרס?"},{"start":284.79,"end":287.04,"text":"רכבת ישראל."},{"start":287.04,"end":291.42,"text":"די, נו."},{"start":291.42,"end":292.38,"text":"תמשיך, רגע, אוקיי."},{"start":292.38,"end":293.38,"text":"ממשיכים."},{"start":293.38,"end":294.38,"text":"אבל..."},{"start":296.63,"end":300.88,"text":"אתה מעוניין להידרס קלאבו?"},{"start":300.88,"end":301.88,"text":"שיגן."},{"start":301.88,"end":303.88,"text":"אין לי פרטנר."},{"start":303.88,"end":305.88,"text":"אתה מעוניין להידרס קלאבו?"},{"start":305.88,"end":307.1,"text":"מאוד."},{"start":307.1,"end":309.13,"text":"גיא!"},{"start":309.13,"end":310.13,"text":"אני אוהבת."},{"start":310.13,"end":313.13,"text":"חלעות את זרקים כאלה, זה משגע אותי."},{"start":313.13,"end":316.22,"text":"לא יכולים, אתה מצחיק אותם."},{"start":316.22,"end":318.8,"text":"אתה מצחיק אותם."},{"start":318.8,"end":323.91,"text":"אני לא מצחיק אותם."},{"start":323.91,"end":327.77,"text":"אני לא מצחיק אותם."},{"start":327.77,"end":328.98,"text":"בבקשה, כל טוב."},{"start":328.98,"end":334.82,"text":"מה קורה? שם יש עיקוב?"},{"start":334.82,"end":379.32,"text":"רבה, תודה רבה. ערב טוב לכולם."},{"start":379.32,"end":381.38,"text":"זהו רובי, הוא מנגן בגיטרה."},{"start":381.38,"end":383.5,"text":"אני אסף, אני מנגן בציקוצית."},{"start":383.5,"end":386.69,"text":"ואנחנו נשמיע לכם מיטב לחנים"},{"start":386.69,"end":390.69,"text":"של שירים עבריים יפים, מוכרים ואהובים על כולנו."},{"start":390.69,"end":394.73,"text":"אני מאחל לכולנו ערב מהנה ותרבותי."},{"start":394.73,"end":399.23,"text":"בקצה השמיים ובסוף המדבר"},{"start":399.23,"end":402.26,"text":"יש מקום רחוק מלא ברכי בר."},{"start":402.26,"end":408.9,"text":"אז בואו כולנו ניכנס למקום קטן לדאגה."},{"start":408.9,"end":418.32,"text":"סמבה היא קצב יפה."},{"start":418.32,"end":421.32,"text":"נותנת השראה לנגן הרבה."},{"start":421.32,"end":425.32,"text":"אז בואו גם אנחנו ננגן את שבחי הסמבה."},{"start":425.32,"end":437.76,"text":"שהמלאכים בוכים בעולם אחר."},{"start":437.76,"end":440.25,"text":"אז בעולם הזה עצוב לנו יותר."},{"start":440.25,"end":442.31,"text":"אתם קוראים לזה גשם."},{"start":442.31,"end":446.84,"text":"אנחנו קוראים לזה דמעות של מלאכים."},{"start":446.84,"end":459.43,"text":"הרי ידיעה שהגיעה זאתה."},{"start":459.43,"end":463.43,"text":"אז המער האמריקני מייקל ג'קסון עבר ניתוח פלסטי נוסף"},{"start":463.43,"end":465.43,"text":"ונתפס משחק רולטה בקזינו."},{"start":465.43,"end":467.43,"text":"כרגע הוא נראה כך."},{"start":467.43,"end":471.15,"text":"קאט!"},{"start":471.15,"end":472.15,"text":"קאט!"},{"start":472.15,"end":473.15,"text":"נו באמת חילה מה זה אומר הזה?"},{"start":473.15,"end":474.11,"text":"זה לא מצחיק."},{"start":474.11,"end":476.17,"text":"זה אומר נמוך, הוא ביצע, צייף מקשה."},{"start":476.17,"end":479.62,"text":"קטע הבא."},{"start":479.62,"end":480.62,"text":"תוכלית מתומטמת."},{"start":480.62,"end":511.64,"text":"תוכלי לשנות את סוף המחזה."},{"start":511.64,"end":512.64,"text":"אך שמעממה."},{"start":512.64,"end":515.67,"text":"גם את תוכלי לשנות את סוף המחזה."},{"start":515.67,"end":516.57,"text":"וזהו זה."},{"start":516.57,"end":526.29,"text":"חפצה אני בנסיך לא מן העולם הזה הבא."},{"start":526.29,"end":530.19,"text":"מה זה הבול שהיא תעשה?"},{"start":530.19,"end":533.19,"text":"גם את תוכלי לשנות את סוף המחזה וזהו זה."},{"start":533.19,"end":534.19,"text":"פליציה."},{"start":534.19,"end":539.18,"text":"גם את אם תרצי תוכלי לשנות את סוף המחזה וזהו זה."},{"start":539.18,"end":542.18,"text":"ראש המכון מר יצחק שוסטק שיספר לנו קצת"},{"start":542.18,"end":546.1,"text":"על אחותות צולעת ועל כל מיני אנשים."},{"start":546.1,"end":547.1,"text":"גם אחותי צולעת."},{"start":547.1,"end":548.28,"text":"ערב טוב."},{"start":548.28,"end":550.46,"text":"שוב אנו בתוכניתנו רגעי גבורה"},{"start":550.46,"end":553.46,"text":"והפעם אנו גאים לארח את שרון אראל"},{"start":553.46,"end":557.49,"text":"מי שהיה סגן אלוף ב... לא, סגן אלוף במיל."},{"start":557.49,"end":559.74,"text":"אנו מערכים את סגן אלוף במיל שרון אראל"},{"start":559.74,"end":561.7,"text":"מי שהיה..."},{"start":561.7,"end":563.08,"text":"עצבו."},{"start":563.08,"end":567.71,"text":"מי שהיה קצין ביטחון של אחותי הצולעת"},{"start":567.71,"end":571.22,"text":"והפעם עלו נערך את... סליחה, סליחה."},{"start":571.22,"end":574.82,"text":"מי שהיה קצין ותיק."},{"start":574.82,"end":577.07,"text":"נו נו גיל זו."},{"start":577.07,"end":578.04,"text":"נו נו גיל זו."},{"start":578.04,"end":579.06,"text":"נו נו אש."},{"start":579.06,"end":580.06,"text":"התחלה במה."},{"start":580.06,"end":582.18,"text":"יואב גיל מרביץ לי יואב."},{"start":582.18,"end":584.31,"text":"אוקיי צביקה תהיה ז'וז'ו."},{"start":584.31,"end":587.31,"text":"עסאב תתלבש לי יש לי יש לי גיל ורובי חם ויפת."},{"start":587.31,"end":588.5,"text":"קדימה יאללה יאללה."},{"start":588.5,"end":589.77,"text":"מה הייתי?"},{"start":589.77,"end":591.5,"text":"אמרתך."},{"start":591.5,"end":592.45,"text":"גם אני רוצה משהו."},{"start":592.45,"end":594.84,"text":"לא עכשיו אין זמן אין לך תפקידים עכשיו."},{"start":594.84,"end":595.84,"text":"אבל אתה הבטחת?"},{"start":595.84,"end":596.84,"text":"לא אין לך תפקידים עכשיו."},{"start":596.84,"end":597.84,"text":"יאללה איתה יחדת בצד."},{"start":597.84,"end":598.84,"text":"רגע שנייה."},{"start":598.84,"end":598.94,"text":"קדימה."},{"start":598.84,"end":599.84,"text":"רגע שנייה."},{"start":599.84,"end":601.84,"text":"אתה אמרת שאירו אותי יותר בתוכנית הבאה."},{"start":601.84,"end":604.84,"text":"וחוז מזה שאני התקשרתי למלא מפיקים שאירו אותי ואתה לא יכול..."},{"start":604.84,"end":606.84,"text":"איתה אין לך תפקיד עכשיו שבצד."},{"start":606.84,"end":607.84,"text":"אני רוצה שיגלו אותי."},{"start":607.84,"end":610.22,"text":"בבקשה יואב אתה הבטחת."},{"start":610.22,"end":613.03,"text":"טוב בסדר."},{"start":613.03,"end":615.05,"text":"נכנס לך לקטע הבא קדימה."},{"start":615.05,"end":616.05,"text":"באמת."},{"start":616.05,"end":622.84,"text":"תודה יואב."},{"start":622.84,"end":626.92,"text":"ערם צח ערב זר שוב אותם איתי."},{"start":626.92,"end":629.07,"text":"והפעם רציתי לדבר איתכם על..."},{"start":629.07,"end":630.07,"text":"מה זה החרטה זה?"},{"start":630.07,"end":632.77,"text":"שחיתות מקום בדיסטור."},{"start":632.77,"end":634.93,"text":"ובכם איתי שגה והבמה הן אכבד."},{"start":634.93,"end":636.93,"text":"ג'וזו בדרך עיניכם."},{"start":636.93,"end":638.93,"text":"וכדאי שתחשבו על זה."},{"start":638.93,"end":640.93,"text":"מה זה החרטה זה בימא ש..."},{"start":640.93,"end":644.16,"text":"חושב."},{"start":644.16,"end":646.82,"text":"בבקשה."},{"start":646.82,"end":647.82,"text":"תטוש לי מהעיניים."},{"start":647.82,"end":651.26,"text":"ערם צח."},{"start":651.26,"end":653.26,"text":"אני כבר הולך לטפל שהם יחשבו על זה."},{"start":653.26,"end":655.26,"text":"אנחנו כבר חוזרים."},{"start":655.26,"end":657.45,"text":"בוא נבוא!"},{"start":657.45,"end":659.45,"text":"דודו מגיע ב-MPD."},{"start":659.45,"end":662.45,"text":"אנחנו רואים את ה-MPD."},{"start":662.45,"end":664.45,"text":"דודו מרים."},{"start":664.45,"end":666.7,"text":"כל זעקה."},{"start":666.7,"end":667.7,"text":"פה קורה."},{"start":667.7,"end":669.66,"text":"מה ההפסקה?"},{"start":669.66,"end":673.3,"text":"הוא יודע שאין יותר כסטה אחרת."},{"start":673.3,"end":675.3,"text":"רוצים כבר הביתה ללכת?"},{"start":675.3,"end":678.3,"text":"בנות מהריצות קורות על הפתח."},{"start":678.3,"end":681.3,"text":"כולנו יודעים הרייטים בפתח."},{"start":681.3,"end":700.51,"text":"כולם על הסט."},{"start":700.51,"end":708.97,"text":"תודה רבה."},{"start":708.97,"end":712.47,"text":"מספריים מתקרב לראש."},{"start":712.47,"end":714.44,"text":"את האוזניים הוא רוצה לחתוך."},{"start":714.44,"end":716.7,"text":"ולפני שנשאל את עצמנו"},{"start":716.7,"end":718.7,"text":"אם הוא מגיע או לא מגיע"},{"start":718.7,"end":719.7,"text":"בואו נתאחד כולנו"},{"start":719.7,"end":721.7,"text":"ונהיה לרגע קט"},{"start":721.7,"end":734.89,"text":"אלף קבעים."},{"start":734.89,"end":736.89,"text":"תאר לך וצאר לי"},{"start":736.89,"end":738.86,"text":"על כך מעידות העיניים."},{"start":738.86,"end":741.08,"text":"בואי אישה ובואו גם אתם"},{"start":741.08,"end":743.23,"text":"ויום זהבי לי"},{"start":743.23,"end":746.16,"text":"לערוכת צהריים."},{"start":746.16,"end":759.08,"text":"כאן במקום שעות דרכנו"},{"start":759.08,"end":761.08,"text":"אך בא הזמן להתרחק."},{"start":761.08,"end":763.08,"text":"כאן נפרדים ממך אנחנו"},{"start":763.08,"end":765.08,"text":"מלחייך הפרסק."},{"start":765.08,"end":767.08,"text":"אז בואו גם אתם ויפרדו מאיתנו"},{"start":767.08,"end":769.08,"text":"ועם כל החיילים הולכים"},{"start":769.08,"end":780.68,"text":"הולכים בדרך."},{"start":780.68,"end":850.13,"text":"בוטי בוטי בוטי"},{"start":850.13,"end":852.13,"text":"אתה בחור כזה יפנותי"},{"start":852.13,"end":854.13,"text":"אצלנו בשכונה וצלצי"},{"start":854.13,"end":856.13,"text":"על השני פני."},{"start":856.13,"end":869.49,"text":"ערב טוב מרמדרוב"},{"start":869.49,"end":871.49,"text":"ערב טוב מרמדרוב"},{"start":871.49,"end":873.49,"text":"ערב טוב מרמדרוב"},{"start":873.49,"end":875.49,"text":"ערב טוב מרמדרוב"},{"start":875.49,"end":877.64,"text":"ערב טוב מרמדרוב"},{"start":877.64,"end":8