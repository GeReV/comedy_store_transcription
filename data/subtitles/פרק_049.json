[{"start":18.05,"end":53.72,"text":"מה קרה? כלום לא עשיתי, מה קרה?"},{"start":53.72,"end":56.03,"text":"עכשיו, הוא אמור לסיים..."},{"start":56.03,"end":56.61,"text":"עוד..."},{"start":56.61,"end":59.09,"text":"רגע, שליה, אחי, שליה, אני עובר אותו."},{"start":59.09,"end":60.19,"text":"שליה, הופה!"},{"start":60.19,"end":63.51,"text":"הוא אמור לסיים עוד דקה את המשחק, לא כל הזמן ציות."},{"start":63.51,"end":65.03,"text":"כן, כן."},{"start":65.03,"end":67.93,"text":"שליה, שליה, יש לך טלפון."},{"start":67.93,"end":73.75,"text":"שמעון."},{"start":73.75,"end":74.05,"text":"מה?"},{"start":74.05,"end":77.23,"text":"עברה לי מחשבה בראש."},{"start":77.23,"end":78.36,"text":"לא נכון."},{"start":78.36,"end":79.13,"text":"כן."},{"start":79.13,"end":83.09,"text":"אבל באה לי מחשבה במישור האומנותי."},{"start":83.09,"end":85.86,"text":"זה חדש."},{"start":85.86,"end":86.3,"text":"כן."},{"start":86.3,"end":88.23,"text":"בוא נקים שלישיית זמר."},{"start":88.23,"end":89.32,"text":"מי?"},{"start":89.32,"end":91.52,"text":"אני ואת, שלישיית זמר."},{"start":91.58,"end":95.17,"text":"איזה שרה לשרון נפעילה את אימא שלך בציבור?"},{"start":95.17,"end":96.77,"text":"לא, אני מדבר, תחשוב."},{"start":96.77,"end":100.21,"text":"להקים שלישיית כמו שוקולד מן תמאסטי, כמו מנגו,"},{"start":100.21,"end":103.21,"text":"נהיה שלישיית המישור הפילוסופי."},{"start":103.21,"end":104.28,"text":"זה באמת יפה."},{"start":104.28,"end":104.78,"text":"בטח."},{"start":104.78,"end":105.92,"text":"כן, אבל מה עם החומר?"},{"start":105.92,"end":108.12,"text":"איך אתה מדבר בטלוויזיה? מה חומר?"},{"start":108.12,"end":109.8,"text":"לא, לא, לא, אני אפרשן את עצמי."},{"start":109.8,"end":111.12,"text":"לא, לא, אני אפרשן את עצמי."},{"start":111.12,"end":112.04,"text":"אפרשן, אפרשן."},{"start":112.04,"end":114.24,"text":"בשביל להקים שלישייה, לא משנה באיזה מישור,"},{"start":114.24,"end":116.86,"text":"צריך איזה משורר שיכתוב את המנגינות."},{"start":116.86,"end":118.24,"text":"אה, אל תדאג."},{"start":118.24,"end":121.68,"text":"אני כותב, אני שער, אני מבצע, אני מתראהן אצל דן שילון,"},{"start":121.68,"end":123.84,"text":"אני חותם למעריצות, הכל עליי, אל תדאג."},{"start":123.84,"end":127.36,"text":"בסדר, מה איתי?"},{"start":127.36,"end":128.86,"text":"מה איתך?"},{"start":128.86,"end":131.97,"text":"למה, מה התפקיד שלי בכל השלישייה הזו?"},{"start":131.97,"end":135.09,"text":"אה, אתה נערת ליווי עם השמלה הנוצצת."},{"start":135.09,"end":137.09,"text":"אה, יפה, יפה."},{"start":137.09,"end":137.73,"text":"בטח."},{"start":137.73,"end":140.45,"text":"תגיד, ביטון, אה?"},{"start":140.45,"end":145.05,"text":"אולי נחליף מחשבה למה השמלה לא כל כך מוצצת חן בעיניי."},{"start":145.05,"end":149.45,"text":"אין בה, אתה לא אוהב את השמלה, אני אעשה אותך זה שמרחיק את המאריצות."},{"start":149.45,"end":153.29,"text":"בוא על המאריצות, אתה תרחיק אותם, אתה תהיה השומר ראש שלי."},{"start":153.29,"end":155.47,"text":"מה אתה אומר?"},{"start":155.47,"end":161.15,"text":"אני לא יודע, לא מתאים לי כל כך חיי הזוהר, התעילה לא בשבילי."},{"start":161.15,"end":163.19,"text":"אני מעדיף לפרוש בשיא."},{"start":163.19,"end":166.71,"text":"אין בה, אני תמיד יכול להקים צמד, צמד ביטון."},{"start":166.71,"end":170.25,"text":"תגיד, אני גם יכול להעביר מחשבה?"},{"start":170.25,"end":172.12,"text":"תעביר?"},{"start":172.12,"end":174.87,"text":"עוד בן אדם יכול להיכנס לצמד."},{"start":174.87,"end":178.67,"text":"מה זאת אומרת? אני אמרתי שניים."},{"start":178.67,"end":181.64,"text":"לא, לא, אני מתכוון נעשה צמד."},{"start":181.64,"end":185.28,"text":"שימון וביטון, בקליפ הפילוסופי."},{"start":185.28,"end":189.47,"text":"תגיד, איזה גבי לקח את החותך לברלין?"},{"start":189.47,"end":191.57,"text":"למה?"},{"start":191.57,"end":194.41,"text":"תדע מה שאני חושב על זה, זה יכול להיות לא רע."},{"start":194.41,"end":196.23,"text":"במישור האדמיניסטרטיבי."},{"start":196.23,"end":196.63,"text":"כן."},{"start":196.63,"end":197.92,"text":"רק יש בעיה מאוד קשה."},{"start":197.92,"end":199.12,"text":"והיא?"},{"start":199.12,"end":200.55,"text":"הכאור שלך."},{"start":200.55,"end":204.67,"text":"הכאור שלך הוא לא פוטוגני במישור הפוטוגרפי."},{"start":204.67,"end":207.44,"text":"מה וזה מהווה מכשלה?"},{"start":207.44,"end":210.68,"text":"זה עלול לעבוד בעיה, למרות שאצלך היתרון"},{"start":210.68,"end":214.14,"text":"זה שהכרחת היא מביאה את התשומת לב מהפנים למעלה."},{"start":214.14,"end":216.23,"text":"אז יכול להסתדר אחלה."},{"start":216.23,"end":218.23,"text":"אוי, זה יפה, זה פותר את העניין."},{"start":218.23,"end":219.23,"text":"אז יאללה, בוא לריד."},{"start":219.23,"end":220.32,"text":"לא, לא, לא, בלום."},{"start":220.32,"end":221.32,"text":"מה?"},{"start":221.32,"end":222.32,"text":"יש בעיה נוספת."},{"start":222.32,"end":223.99,"text":"מה בעיה?"},{"start":223.99,"end":224.99,"text":"בינינו."},{"start":224.99,"end":225.99,"text":"אבל ממש כזה ככה."},{"start":225.99,"end":227.37,"text":"כן."},{"start":227.37,"end":229.37,"text":"אנחנו לא יודעים לשיר, אנחנו."},{"start":229.37,"end":232.37,"text":"אבל אני מדבר איתך במישור הפילוסופי."},{"start":232.37,"end":234.37,"text":"במישור הפילוסופי כולם יודעים לשיר."},{"start":234.37,"end":235.37,"text":"מה קלם לך?"},{"start":235.37,"end":236.37,"text":"לא, לא."},{"start":236.37,"end":241.37,"text":"הוואן, הוואן, הוואן, הוואן, הוואן, הוואן, הוואן, הוואן."},{"start":241.37,"end":246.32,"text":"יומיים בשבוע, וואלה איזה יופי."},{"start":246.8,"end":248.8,"text":"שבה במישור הפילוסופי."},{"start":248.8,"end":249.8,"text":"החיים זה כמו חרוז."},{"start":249.8,"end":250.8,"text":"לא מבין, פרשן."},{"start":250.8,"end":252.8,"text":"עזום אותך עכשיו, כואבת לי השק."},{"start":252.8,"end":256.8,"text":"ככה זה כליל, החיים זה כמו פתיחה."},{"start":256.8,"end":261.8,"text":"למה איזה סוס יאור בלעת אמשך?"},{"start":261.8,"end":266.8,"text":"כל יומיים בשבוע אני מול המסך, שמעתי שאת אמשך בלעת מולטים סך."},{"start":266.8,"end":268.8,"text":"החיים זה כמו תלעג והשיר הזה טיפשי."},{"start":268.8,"end":271.8,"text":"וצריך לסבול אותו כל שני וחבישי."},{"start":271.8,"end":275.8,"text":"ככה זה כליל, החיים זה כמו פתיחה."},{"start":275.8,"end":280.18,"text":"איזה סוג מטוס התרסק על אימשך."},{"start":280.18,"end":283.63,"text":"פילוסופים כמו ניצ'ה, דקארט והפלטון."},{"start":283.63,"end":285.63,"text":"חושבים היום בדיוק כמו שמעון וביטון."},{"start":285.63,"end":287.63,"text":"אמנם הם פילוסופים חושבים באור אקלוגי."},{"start":287.63,"end":290.63,"text":"אך לנו יתרון במישור הביולוגי."},{"start":290.63,"end":294.63,"text":"ככה זה כליל כמו שמעון וביטון."},{"start":294.63,"end":298.88,"text":"כי אם לא נתפנן כנס בקיר בטון."},{"start":353.76,"end":358.76,"text":"תיסה אותך ישירות מלוס אנג'לס לתל אביב ללא חניות ביניים במטוס ה-747-400."},{"start":358.76,"end":360.76,"text":"פני עוד היום לסוכן הנציאות שלך."},{"start":360.76,"end":362.76,"text":"אל-אל, מספר אחת לאמריקה."},{"start":362.76,"end":366.23,"text":"זה לא בעיה, זה רק עוד כמה מודרגות."},{"start":366.23,"end":367.23,"text":"כמה מודרגות."},{"start":367.23,"end":370.86,"text":"אין כמו מוצרי חלב."},{"start":370.86,"end":375.11,"text":"יש בהם פרוטאין לחיזוק השעירים."},{"start":375.11,"end":377.58,"text":"סידן לחיזוק העצמות."},{"start":377.58,"end":380.99,"text":"מגנזיום לשמירה על שיווי משקל."},{"start":380.99,"end":384.53,"text":"פחממות לתוספת אנרגיה."},{"start":388.39,"end":391.39,"text":"וגם תיאמין לשיפור מצב הרוח."},{"start":391.39,"end":400.27,"text":"אתם בבית? אנחנו קובצים אליכם לקפה נמסלית."},{"start":400.27,"end":402.65,"text":"יום שרב."},{"start":402.65,"end":405.57,"text":"שעה."},{"start":405.57,"end":407.57,"text":"תודה לבא לכם."},{"start":407.57,"end":409.57,"text":"אל ילדי חולון, נפתח מי שנצלם אותם."},{"start":409.57,"end":411.57,"text":"וממצא המשיץ!"},{"start":411.57,"end":444.5,"text":"חדש מתאמה, קריות דגנים עם לואי קרם נוגעת."},{"start":444.5,"end":447.1,"text":"עוד קומים אנשים?"},{"start":447.1,"end":450.35,"text":"הפעם זאת ערוכה שאי אפשר לסרב לה."},{"start":450.35,"end":452.35,"text":"לא נזמין אותה להגברנו!"},{"start":452.35,"end":456.35,"text":"שף הים, מוצרי דגים, עכשיו בנבצע."},{"start":456.35,"end":458.92,"text":"אמא, מה יש לכינוח?"},{"start":458.92,"end":466.13,"text":"טיול מאורגן עם רימון טיולים לאירופה, תמונה אחרת של העולם."},{"start":466.13,"end":469.13,"text":"קבלו חוברת רימון טיולים חינם אצל סוכן הנסיעות."},{"start":469.13,"end":496.0,"text":"יחד, טלוויזיה סוני טריניטרון וווידאו טאפ סוני."},{"start":496.0,"end":497.1,"text":"השילוב המושלם."},{"start":497.1,"end":500.35,"text":"סוני, זה קול השוני."},{"start":500.35,"end":504.41,"text":"טיול מאורגן עם רימון טיולים בארצות הברית מחוף אל חוף."},{"start":504.41,"end":506.41,"text":"טיול לאפשרויות הבלתי מוגבלות."},{"start":506.41,"end":509.41,"text":"קבלו חוברת רימון טיולים חינם אצל סוכן לסיון."},{"start":509.41,"end":517.07,"text":"ילדים, בואו מחר בשש לחגיגת גלידוש בקניון הצהב בראשון לסיון."},{"start":517.07,"end":522.07,"text":"הביאו מחסים של גלידוש, קבלו פרסים ומתנות ותיהנו מההופעות להתראות."},{"start":522.07,"end":525.83,"text":"גלידוש בשניים."},{"start":525.83,"end":531.1,"text":"חדש מפיץ בוויל, הגנה משולשת ושיזוף."},{"start":531.1,"end":534.55,"text":"גם מסנני קרינה UVA ו-UVB."},{"start":534.55,"end":539.92,"text":"גם ויטמין E המונע את הזדקנות האור."},{"start":539.92,"end":543.89,"text":"וגם מיקרופיגמנטים המחזירים את קרני השמש."},{"start":543.89,"end":546.85,"text":"פיצבווין, היחיד עם שלוש הגנות בתכשיר אחד."},{"start":546.85,"end":550.29,"text":"צינון, הגנה ומניעת כמתים."},{"start":550.29,"end":552.29,"text":"פיצבווין עם ההגנה המשולשת ושיזוף"},{"start":552.29,"end":557.44,"text":"מפנק מוקר מלאכות לטיפוח, בריא ובטוח."},{"start":557.44,"end":575.32,"text":"בינינו, לא הייתם רוצים גם אתם להתעורר בבית כזה?"},{"start":575.32,"end":579.28,"text":"אז תתעוררו, תתקשרו עכשיו לפועלים ישיר לברר איפה אתם עומדים."},{"start":579.28,"end":582.28,"text":"על הכסף שחסר לכם, נשב אצלי מחר בסניב."},{"start":582.28,"end":584.82,"text":"הקפה, עליי."},{"start":584.82,"end":587.82,"text":"בנק הפועלים, גם אישי, גם ישיר."},{"start":587.82,"end":591.96,"text":"בנק הפועלים"},{"start":591.96,"end":651.91,"text":"לצו, תודה חבר, תודה חבר."},{"start":651.91,"end":661.37,"text":"טוב, שוב אנחנו במדריך כיצד נתנהג הנכון,"},{"start":661.37,"end":663.37,"text":"והפעם, עצות למציל המתחיל."},{"start":663.37,"end":667.37,"text":"ראשית, בהגיחה לבריכה, הקפד להתלבש בהתאם."},{"start":667.37,"end":670.59,"text":"בוקר טוב לכל המתרחתים!"},{"start":670.59,"end":677.05,"text":"בזג האוויר, הייתי ממנו היום."},{"start":677.05,"end":681.15,"text":"יש 40 מעלות בצל."},{"start":681.15,"end":686.58,"text":"העבודה כמציל קורחה במגע עם קהל."},{"start":686.58,"end":690.64,"text":"הקפד להיות מנומס ועדיב עם ציבור המתרחצים."},{"start":690.64,"end":694.09,"text":"גברת, את נו השימפנזה, ים חוערת."},{"start":694.09,"end":697.09,"text":"חיטה בין המכוער הגיבן שלך, תאיפי אותה החוצה, נו."},{"start":697.09,"end":700.18,"text":"את עם שני הסמטרים, כן, את השמנה."},{"start":700.18,"end":702.18,"text":"את, את השמנה, את."},{"start":702.18,"end":705.24,"text":"שמנמנה, חיטה בין זרקיות החוצה למערדודים."},{"start":705.24,"end":708.27,"text":"אדון פה ששוחק גב, אדון, אדון ששוחק גב."},{"start":708.27,"end":710.39,"text":"זה אב שלך או שזה קריש?"},{"start":710.39,"end":711.39,"text":"אתה מביא את האנשים פה, מה זה?"},{"start":711.39,"end":714.45,"text":"מה זה זה? צלול, צלול הרבה אבל, הרבה."},{"start":714.45,"end":717.17,"text":"יקב רוע."},{"start":717.17,"end":719.17,"text":"מערכת הקריזה נועדה לסייע בעדך,"},{"start":719.17,"end":721.17,"text":"לשמור על הסדר בבריכה."},{"start":721.17,"end":724.16,"text":"השתמש בה אך ורק למטרה הזו."},{"start":724.16,"end":726.42,"text":"חבר'ה, שנייה תשומת לב, חבר'ה,"},{"start":726.42,"end":728.42,"text":"להפסיק לסחוט לפרפר במים, להפסיק לסחוט, שימו לב."},{"start":728.42,"end":730.42,"text":"ביום אלף הקרוב, בשמונה וחצי,"},{"start":730.42,"end":734.42,"text":"אתם יודעים, יש בחירות ליושב ראש המועצה, אני רוצה לבקש מכולכם,"},{"start":734.42,"end":738.42,"text":"את שכחו את חיימי ג'אפר אחי, חיימי נתן לכם,"},{"start":738.42,"end":743.42,"text":"נלחם בשבילכם ונאבק עם אלי דעבול, אלי שלא נתן כלום השנה, כלום,"},{"start":743.42,"end":749.42,"text":"אלי יושב ראש המועצה, הכזב את כולנו, גנב כספים, רימה את כולם, זבל של בן אדם."},{"start":749.42,"end":753.42,"text":"עבודת המציל דורשת כישורים מיוחדים, אם אין לך אותם,"},{"start":753.42,"end":755.42,"text":"אל תתעקש להמשיך במקצוע הזה."},{"start":755.42,"end":764.92,"text":"שימו לב, כל המתרחצים, אני מבקש לעבור אל בן שני הדגלים שם."},{"start":764.92,"end":766.92,"text":"אל בן שני הדגלים, כל המתרחצים."},{"start":766.92,"end":768.3,"text":"אצילו!"},{"start":768.3,"end":771.33,"text":"אדוני, אני לא שומע. מה אמרת אדוני? מה?"},{"start":771.33,"end":773.62,"text":"אני פה! אי, אי, אני פה!"},{"start":773.62,"end":775.62,"text":"שנייה אדוני, אני מביא לך את הגלגל!"},{"start":775.62,"end":776.62,"text":"שנייה איפה שמתי אותו?"},{"start":776.62,"end":777.61,"text":"שנייה אחת אדוני!"},{"start":777.61,"end":780.61,"text":"או, או, אדוני, הנה הגלגל!"},{"start":780.61,"end":781.86,"text":"קפוס!"},{"start":781.86,"end":784.26,"text":"אדוני בסדר?"},{"start":784.26,"end":786.22,"text":"אדוני!"},{"start":786.22,"end":794.01,"text":"זכור, מטרתך היא להציל חיי אדם."},{"start":794.01,"end":798.99,"text":"איזה אדם יהיה מרוכז, ואירני כלפי אסובב אותך."},{"start":798.99,"end":800.05,"text":"אהלן!"},{"start":800.05,"end":803.53,"text":"בואו נה, פרוטטן לי את האוזן, ימניאק, לך!"},{"start":803.53,"end":805.53,"text":"מה יש לך? למה אתה אגרסיבי?"},{"start":805.53,"end":806.53,"text":"שנייה הרי גם תדר איתם."},{"start":806.53,"end":807.53,"text":"מה אתה מסתכל?"},{"start":807.53,"end":809.53,"text":"אתה פה שאתה עושה מפה, מדברים עליך יפה."},{"start":809.53,"end":810.53,"text":"אולי אתה עושה את זה זרם, מה יש לך?"},{"start":810.53,"end":811.53,"text":"אולי זה..."},{"start":811.53,"end":812.53,"text":"אולי זה זרם..."},{"start":812.53,"end":813.53,"text":"פחור צ'יק, שנייה אחת!"},{"start":813.53,"end":814.53,"text":"שנייה!"},{"start":814.53,"end":815.53,"text":"אתה לא רב, מתרקם פה משהו!"},{"start":815.53,"end":816.53,"text":"שנייה אחת!"},{"start":816.53,"end":817.53,"text":"תמשיך לפרפר!"},{"start":817.53,"end":819.53,"text":"זה לא מספר מניגה שלך, רגע! רגע!"},{"start":819.53,"end":822.49,"text":"חיי אדם תלויים במיומנותך."},{"start":822.49,"end":824.66,"text":"אכפת להיות זריז ומהיר."},{"start":824.66,"end":826.62,"text":"אל תלחץ בחוץ'יק!"},{"start":826.62,"end":827.65,"text":"את זילות!"},{"start":827.65,"end":829.65,"text":"הנה אני בא, תחזיק, כן, להמשיך!"},{"start":829.65,"end":830.65,"text":"להמשיך נשימה!"},{"start":830.65,"end":832.65,"text":"להחזיק מעמד, אני מגיע!"},{"start":832.65,"end":834.68,"text":"כבר אני מגיע!"},{"start":834.68,"end":836.68,"text":"אתה עוני, אני איש מקצוע, אני יודע, תנשום!"},{"start":836.68,"end":837.68,"text":"תנשום!"},{"start":837.68,"end":838.68,"text":"הופה, הנה אני!"},{"start":838.68,"end":840.67,"text":"הנה אני בא אליך, שנייה אחת!"},{"start":840.67,"end":842.53,"text":"שנייה!"},{"start":842.53,"end":843.53,"text":"תנחת, חכה, הנה אני מגיע!"},{"start":843.53,"end":844.53,"text":"חכה!"},{"start":844.53,"end":847.93,"text":"הופה, אני בא אליך!"},{"start":847.93,"end":849.93,"text":"בא אליך, תבשיך, תבשיך, לא להפסיק!"},{"start":849.93,"end":855.02,"text":"זכור, הזכות להעניק חיים היא שכרו האמיתי של המציל."},{"start":855.02,"end":859.68,"text":"הופה, בחורצי, בוא לכאן, בוא לכאן, תן לי הדור!"},{"start":859.68,"end":861.7,"text":"וואו, אני איתך!"},{"start":861.7,"end":865.7,"text":"בוא לכאן, תן לי הזולתרה, לא לרגע, לרגע, לרגע, לא להתרגש!"},{"start":865.7,"end":868.64,"text":"אביר, אביר, הופה, הופה!"},{"start":868.64,"end":872.65,"text":"איך סוי, המכוער, מי אציל את חיים?"},{"start":872.65,"end":876.45,"text":"חבל על הזמן, איך כתבא, איך..."},{"start":876.45,"end":881.19,"text":"לסיום היום, ייפרד לשלום מציבור הרוחצים."},{"start":881.19,"end":888.33,"text":"אני מבקש מכולם לצאת מהבריכה, הרחצה מסתיימת כעת, תודה רבה לכם וערב טוב לכולם."},{"start":920.08,"end":924.32,"text":"שלום לך. -אוקיי, עושים חזרה ומתחילים. -איזה חזרה? אנחנו עולים לשידור עכשיו, מתחילים."},{"start":924.32,"end":925.32,"text":"מה? -מתחילים, מתחילים."},{"start":925.32,"end":930.84,"text":"סיפורי לילה, תסקית רדיו בלשיים, את פיי קרוגר."},{"start":930.84,"end":932.95,"text":"היה זה לילה, חורפי וקר."},{"start":932.95,"end":937.95,"text":"הנמים כבדים כיסו את השמיים, ועלתה כבדה שררה סביב."},{"start":937.95,"end":941.96,"text":"לפתע עבריק ברק, ואחריו הראים הרעם."},{"start":941.96,"end":950.44,"text":"רעם חזק, רעם אדיר, ישם אז אל הרדק."},{"start":950.44,"end":958.16,"text":"העורך דין גולדשמיד שחב ער בביתו, כשלפתע נשמעת פיקה עמומה בדלת."},{"start":958.16,"end":963.33,"text":"גולדשמיד לא ענה, ומיד אחר כך נשמע צלצול פעמון הכניסה."},{"start":963.33,"end":972.17,"text":"העורך דין התכווץ בפחד במיטה, נשמתו כמעט פרחה כששמע צעדים במעלה המדרגות."},{"start":972.17,"end":976.14,"text":"צעדים במעלה המדרגות המובילות לחדרו."},{"start":976.14,"end":980.67,"text":"צעדים מפחידים."},{"start":980.67,"end":985.54,"text":"גולדשמיד ניסה לפתות את הרוצח בכסף."},{"start":985.54,"end":991.89,"text":"הוא שלף שטר והחל לרשרש בו מול פני הרוצח, לרשרש בו"},{"start":991.89,"end":1002.99,"text":"אך הרוצח קרא את השטר בבוז, קרא אותו, לגזרים הוא קרא אותו, לחתיכות קטנות"},{"start":1002.99,"end":1011.74,"text":"בסוליית הנעל של ישי העלומים, אמר גולדשטיין, והרוצח החל לנסר את נעליו של מר גולדשטיין"},{"start":1011.74,"end":1021.1,"text":"לנסר אותם, לנסר, לנסר, הוא ניסר וניסר, ניסר וניסר, אבל לא מצאה כלום"},{"start":1021.1,"end":1026.45,"text":"ברוב זעמו, הוא תפס את האורך דין וקרא בכוח את חולצתו"},{"start":1026.45,"end":1032.43,"text":"הוא קרא אותה לגזרים, קרא אותה, וקרא אותה, וקרא אותה"},{"start":1032.43,"end":1036.83,"text":"אחר כך תפס את משקפיו וניפץ להן את ההדשות"},{"start":1036.83,"end":1045.05,"text":"אחר כך הוא ראה כוס על השולחן וניפץ גם אותה"},{"start":1045.05,"end":1054.16,"text":"גולדשמיט ניסה להימלט וניסה לנפץ את חלון ביתו על מנת להזיק עזרה"},{"start":1054.16,"end":1057.88,"text":"הוא רץ אל החלון, אך עטף ביתה מהרוצח"},{"start":1057.88,"end":1062.22,"text":"אבל אותו זאת הצליח לשבור את החלון"},{"start":1062.22,"end":1074.35,"text":"אחר כך תפס הרוצח את גולדשמיט והתחיל להכניס לו סתירות וגרופים"},{"start":1074.35,"end":1077.25,"text":"סתירות וגרופים, מכות איומות"},{"start":1077.25,"end":1081.82,"text":"אחר כך לקח את ראשו של מר גולדשמיט ודפק אותו בשולחן"},{"start":1081.82,"end":1084.86,"text":"שוב ושוב, שוב ושוב"},{"start":1084.93,"end":1090.14,"text":"חזק, חזק, חזק, חזק יותר, חזק יותר"},{"start":1090.14,"end":1094.06,"text":"אחר כך לקח את המקדחה וקדח בידו של מר גולדשמיט"},{"start":1094.06,"end":1105.1,"text":"מר גולדשמיט לבסוף שלף הרוצח אקדח ויראה במר גולדשמיט"},{"start":1105.1,"end":1108.04,"text":"הוא יראה בו, הוא יראה בו בבטנוע"},{"start":1108.04,"end":1119.6,"text":"אך למזלו של מר גולדשמיט היה מעצור באקדח והאקדח לא יראה"},{"start":1119.6,"end":1124.21,"text":"מר גולדשמיט ניצל והרוצח נמלט"},{"start":1124.21,"end":1128.81,"text":"עד כאן סיפורי לילה להפעם ולפני שניפרד מאזינים יקרים"},{"start":1128.81,"end":1135.85,"text":"הלילה הודיע לכם שכמו בכל שבוע גם השבוע נתפנתה משרת איש האפקטים הקוליים שלנו"},{"start":1135.85,"end":1141.31,"text":"אז כל מי שמעוניין שייצור עםנו קשר באקדם לילה טוב ומשכה הזנה נעימה"},{"start":1141.31,"end":1183.03,"text":"וכן גבירותיי ורבותיי אנחנו נמצאים כאן בגמר עליפות העולם"},{"start":1183.03,"end":1185.61,"text":"לאלבונות והעלבות על ידי טלפתיה"},{"start":1185.61,"end":1188.53,"text":"המתמודד הברזילאי צ'אן קנסתה נמצא כאן מימיני"},{"start":1188.53,"end":1192.07,"text":"והמתמודד הישראלי א' הקטן מתרכז כאן משמאלי"},{"start":1192.07,"end":1194.69,"text":"אנו מקווים שישראלי יצליח סוף סוף לעשות משהו"},{"start":1194.69,"end":1196.95,"text":"במפת ההיאבקות הקשה הזאת"},{"start":1196.95,"end":1198.61,"text":"העלבות על ידי טלפתיה"},{"start":1198.61,"end":1207.99,"text":"בואו צפו איתנו"},{"start":1207.99,"end":1212.53,"text":"דרמה גבירות העברותי"},{"start":1212.53,"end":1213.37,"text":"שימו למה קורה כאן"},{"start":1213.37,"end":1214.97,"text":"הברזילאי על ידי..."},{"start":1214.97,"end":1215.91,"text":"ובכן לא יאומן"},{"start":1215.91,"end":1216.85,"text":"לא יאומן"},{"start":1216.85,"end":1217.35,"text":"מה קרה?"},{"start":1217.35,"end":1217.91,"text":"ראית"},{"start":1217.91,"end":1219.0,"text":"מה קרה?"},{"start":1219.0,"end":1220.96,"text":"למה הוא מער..."},{"start":1220.96,"end":1222.8,"text":"האם מירב תאורים?"},{"start":1222.8,"end":1226.24,"text":"הוא כמובן לא יודע הברזילאי"},{"start":1226.24,"end":1227.12,"text":"ובכן לא יאומן"},{"start":1227.12,"end":1227.82,"text":"זה רמאות"},{"start":1227.82,"end":1228.96,"text":"זה רמאות מנריאלי שונה"},{"start":1228.96,"end":1232.42,"text":"ובכן שוב יום שחור לספורט הישראלי"},{"start":1232.42,"end":1235.5,"text":"א' הקטן יצא מושפל מוקה קטן וחבוט"},{"start":1235.5,"end":1237.0,"text":"ובכן יום שחור"},{"start":1237.0,"end":1266.44,"text":"איפה שקדם שקדם"},{"start":1266.44,"end":1268.35,"text":"מי יזה את זה מי אדם"},{"start":1268.35,"end":1270.18,"text":"אין שקדם תמרו"},{"start":1270.18,"end":1270.62,"text":"אבא!"},{"start":1270.62,"end":1274.54,"text":"איזה כיף שאנחנו"},{"start":1274.54,"end":1278.54,"text":"אבא בוא נשחק"},{"start":1278.54,"end":1280.5,"text":"כן טוב אני אבל רוצה לקרוא אותי איתון"},{"start":1280.5,"end":1283.68,"text":"לא לא לא לא לא לא"},{"start":1283.68,"end":1284.96,"text":"בוא נשחק"},{"start":1284.96,"end":1286.96,"text":"תשמע אני אתראה את זה"},{"start":1286.96,"end":1288.96,"text":"אני אתה תהיה שודד ואני"},{"start":1288.96,"end":1290.96,"text":"לא אני אהיה שודד ואתה זה שאתה בעל"},{"start":1290.96,"end":1292.96,"text":"בסדר בסדר"},{"start":1292.96,"end":1295.92,"text":"שטב מדה פאקי אך תקמדיק"},{"start":1295.92,"end":1298.18,"text":"מי לימד אותך כאלה מילים תגיד לי"},{"start":1298.18,"end":1300.21,"text":"ספרות זולה ראיתי"},{"start":1300.21,"end":1302.21,"text":"אבא בוא נשחק"},{"start":1302.21,"end":1304.21,"text":"לא אמרנו משחק אחד אבל לא"},{"start":1304.21,"end":1306.21,"text":"אמרנו רק משחק אחד חמוד"},{"start":1306.21,"end":1307.21,"text":"חמוד לא די"},{"start":1307.21,"end":1308.21,"text":"תהיה חתול ואני אענה אותך"},{"start":1308.21,"end":1310.78,"text":"אבל אתה יודע שאבא לא אוהב שמענים חתולים"},{"start":1310.78,"end":1312.78,"text":"אסור לענות חתולים אתה לא יודע את זה"},{"start":1312.78,"end":1314.78,"text":"יאו מיאו מיאו"},{"start":1314.78,"end":1316.78,"text":"טוב אך יופי יופי די די"},{"start":1316.78,"end":1318.75,"text":"די חמוד די די"},{"start":1318.75,"end":1320.75,"text":"אני מענה אותך כי אתה שקט"},{"start":1320.75,"end":1322.75,"text":"ואני רוצה לעשות לך פיפי על האף"},{"start":1322.75,"end":1324.75,"text":"לא נודע את המספיק אני אמרתי בלי"},{"start":1324.75,"end":1326.75,"text":"פיפי אתה קצת עמיים פיפי על האף"},{"start":1326.75,"end":1327.75,"text":"אבל רק פיפי אחד?"},{"start":1327.75,"end":1329.75,"text":"פיפי פיפי"},{"start":1329.75,"end":1331.75,"text":"אבא תשכב רגע תשכב"},{"start":1331.75,"end":1334.75,"text":"אתה כדורגל ואני בוא אצבך"},{"start":1334.75,"end":1337.75,"text":"איי גול איפה בוא לי גימסבורג"},{"start":1337.75,"end":1340.75,"text":"איי אבא אני רוצה לקשור אותך עכשיו"},{"start":1340.75,"end":1343.75,"text":"ולהרביס לך עם שעות כמו שאתה אוהב"},{"start":1343.75,"end":1345.75,"text":"זה לא אני אוהב זה אמא אוהב"},{"start":1345.75,"end":1346.75,"text":"אתה מתבלבל גאולה"},{"start":1346.75,"end":1348.75,"text":"הילד רוצה שעדו תקחי אותו מבני"},{"start":1348.75,"end":1350.94,"text":"לך אבו דלי אמא אני אוהבת אותך"},{"start":1350.94,"end":1352.13,"text":"לך"},{"start":1352.13,"end":1355.13,"text":"וואנטי זכין"},{"start":1355.13,"end":1357.16,"text":"אגמומיות סיפורים עצובים"},{"start":1357.16,"end":1360.16,"text":"גורל אכזר יוסי סייאז"},{"start":1360.16,"end":1362.25,"text":"וואנטי זכין אדוני"},{"start":1362.25,"end":1364.25,"text":"רגע רגע אחי רגע"},{"start":1364.25,"end":1365.25,"text":"יש"},{"start":1365.25,"end":1366.35,"text":"כן מה יש"},{"start":1366.35,"end":1367.35,"text":"בדידות איומה"},{"start":1367.35,"end":1368.51,"text":"זהו"},{"start":1368.51,"end":1370.51,"text":"לא יש לי גם חרדת נטישה"},{"start":1370.51,"end":1372.64,"text":"לך תחפש את החברים שלך"},{"start":1372.64,"end":1374.64,"text":"זהו זה העניין אין לי חברים"},{"start":1374.64,"end":1376.64,"text":"אין חברים יאללה זה טוב עלי אחי"},{"start":1376.64,"end":1377.64,"text":"תודה"},{"s