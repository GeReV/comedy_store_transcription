[{"start":30.21,"end":32.33,"text":"ברוכים הבאים"},{"start":32.33,"end":34.27,"text":"ל\"קומדי סטור!\""},{"start":34.27,"end":76.93,"text":"דוני, אתה רוצה אולי מג'יק סטיק?"},{"start":76.93,"end":78.05,"text":"מה זה?"},{"start":78.05,"end":80.05,"text":"אתה יכול להגיע איתו לכל מיני מקומות בעולם"},{"start":80.05,"end":81.05,"text":"תודה"},{"start":112.44,"end":115.44,"text":"ורוח נושבת קרירה"},{"start":115.44,"end":119.36,"text":"נוסיף עוד כסם למדו"},{"start":119.36,"end":123.36,"text":"כסרוח, הם טובים"},{"start":123.36,"end":125.36,"text":"יש לי, יש לי, יש לי, יש לי"},{"start":125.36,"end":127.58,"text":"אני הולך לצוד"},{"start":127.58,"end":128.64,"text":"אדידס?"},{"start":128.64,"end":130.76,"text":"לא, אני הולך לצוד"},{"start":130.76,"end":131.79,"text":"פומה"},{"start":131.79,"end":135.79,"text":"יש לי, יש לי, יש לי"},{"start":135.79,"end":137.76,"text":"אני הולך לצוד"},{"start":137.76,"end":138.76,"text":"מעיל רוח?"},{"start":138.76,"end":140.95,"text":"לא, אני הולך לצוד"},{"start":140.95,"end":141.95,"text":"דובון"},{"start":141.95,"end":143.95,"text":"דובון"},{"start":143.95,"end":148.65,"text":"אני הולך לצוד את צמאוני"},{"start":148.65,"end":151.65,"text":"לא, אני הולך לצוד פילון"},{"start":151.65,"end":153.65,"text":"פילון"},{"start":153.65,"end":157.74,"text":"יש לי, יש לי, יש לי"},{"start":157.74,"end":159.93,"text":"אני הולך לצוד"},{"start":159.93,"end":160.96,"text":"זברה"},{"start":160.96,"end":163.3,"text":"לא, אני הולך לצוד"},{"start":163.3,"end":164.43,"text":"קוליגייט"},{"start":164.43,"end":165.49,"text":"יאי!"},{"start":205.2,"end":207.2,"text":"מה הטבעית והאלטרנטיבית!"},{"start":207.2,"end":208.19,"text":"איי!"},{"start":208.19,"end":210.23,"text":"מה זכרת זה? איזה לחזור ואיזה נעליים?"},{"start":210.23,"end":212.23,"text":"מה זה לעשי שובי הביתה, באמא שלי השתגעתי?"},{"start":212.23,"end":215.23,"text":"נכנסתי, אמרתי, ננסה, ניתן לזה צ'אנס!"},{"start":215.23,"end":218.29,"text":"איך שאני הולך, נכנסתי לקליניקה הראשונה,"},{"start":218.29,"end":221.29,"text":"הקליניקה של הרפלקסולוגיה!"},{"start":221.29,"end":223.25,"text":"באמא שלי, אנשים לא נורמליים."},{"start":223.25,"end":227.35,"text":"בא אליך בן אדם, ואומר לך שהוא ילחץ לך על הרגליים,"},{"start":227.35,"end":229.35,"text":"ויעברו לך כאבי ראש!"},{"start":229.35,"end":231.41,"text":"מה זכרת זה? הייתי לוחץ לו על האוזן,"},{"start":231.41,"end":233.41,"text":"על האף, על הרסיה, אולי העובר לו."},{"start":233.41,"end":235.5,"text":"לא, לא, לא, נתנתי לו צ'אנס."},{"start":235.5,"end":236.5,"text":"נשכפתי על המיטה שלו,"},{"start":236.5,"end":238.5,"text":"אבל לי תוריד בבקשה את הנעל."},{"start":238.5,"end":240.5,"text":"חשבתי אני סנדרלה."},{"start":240.5,"end":242.5,"text":"הורדתי את הנעל עם אמא שלי."},{"start":242.5,"end":244.47,"text":"איך שנשארתי מגרביים עליי,"},{"start":244.47,"end":248.47,"text":"התפשטה איזה מין נחוחית בעביר."},{"start":248.47,"end":251.47,"text":"הבן אדם מסתחרר, חטף את כיף אסתמה,"},{"start":251.47,"end":254.47,"text":"נחול על הרצפה, פתח את הראש עם אמא שלי,"},{"start":254.47,"end":256.47,"text":"אשתרע אמבולנסים הגיעו,"},{"start":256.47,"end":258.47,"text":"לקחו אותו בתחולים דווקא,"},{"start":258.47,"end":261.47,"text":"תביאו אותי כעד אף קולופה רצפתבול,"},{"start":261.47,"end":263.47,"text":"אמרתי אם זה ככה לא שווה, נלך הלאה,"},{"start":263.47,"end":267.45,"text":"הקליניקה הבאה היה המרפא באבנים טובות,"},{"start":267.45,"end":270.04,"text":"מה זה חרטזי?"},{"start":270.04,"end":272.07,"text":"מה זה אבנים טובות, אני בא יש לו כל מיני אבנים,"},{"start":272.07,"end":275.07,"text":"בצבע כחול ובצבע ירוק,"},{"start":275.07,"end":277.07,"text":"חשבתי משחקים חמש אבנים, לא ידעתי מה זה החרטזי,"},{"start":277.07,"end":279.07,"text":"מאמא שלי, אומר לי שים לב ג'וזו,"},{"start":279.07,"end":281.07,"text":"בשביל שיעבור לך כאב ראש,"},{"start":281.07,"end":284.07,"text":"אתה צריך לשים עליך שרשרת עם אבן כחולה,"},{"start":284.07,"end":287.26,"text":"אמרתי לו אחי, אני עלי שם שרשרת,"},{"start":287.26,"end":289.26,"text":"בתנאי שהשרשרת שלי עליך."},{"start":289.26,"end":291.26,"text":"איך שאורדתי את השרשר,"},{"start":291.26,"end":292.26,"text":"שמתי עליו מהכובד."},{"start":292.26,"end":294.26,"text":"דפק את הראש בא להצפה,"},{"start":294.26,"end":297.26,"text":"נפתח לו הראש אבי ובולנצים,"},{"start":297.26,"end":298.26,"text":"דווקא לא נטביוטיקה,"},{"start":298.26,"end":300.26,"text":"דווקא לא פרצפת המול."},{"start":300.26,"end":302.26,"text":"אמרתי גם זה לא שווה."},{"start":302.26,"end":304.26,"text":"המשכתי עלה לגדול מכולם."},{"start":304.26,"end":306.53,"text":"דיכור סיני."},{"start":306.53,"end":308.99,"text":"בא אליי בן אדם, בכלל הוא סיני,"},{"start":308.99,"end":310.99,"text":"עושה לי, אדוני,"},{"start":310.99,"end":313.99,"text":"אני אתקה לך 703 מחתים באוזן השמאלית."},{"start":313.99,"end":316.4,"text":"מה זה אהרת הזה, באימא שלי?"},{"start":316.4,"end":318.4,"text":"איך שהוא התקרב לי לאוזן?"},{"start":318.4,"end":319.4,"text":"מה להחץ?"},{"start":319.4,"end":322.4,"text":"שכח, שכח, שתי רציות להרגעת העבירה."},{"start":322.4,"end":324.4,"text":"מה רציות? דפק את הראש ברית פה,"},{"start":324.4,"end":326.4,"text":"פתח את הראש, אבולנסים,"},{"start":326.4,"end":329.4,"text":"דווקא לא פרצפת בו, לאי."},{"start":329.4,"end":333.69,"text":"מוסר הסכל, ג'וזו יפתח קליניקה בעצמו."},{"start":333.69,"end":337.88,"text":"הרפואה האלטרנטיבית היא כפקאפולוגיה, באימא שלי."},{"start":337.88,"end":339.88,"text":"נכנס אליי בן אדם לקליניקה."},{"start":339.88,"end":341.88,"text":"אני אומר, לא חי, מה כואב לך?"},{"start":341.88,"end":343.88,"text":"הוא אומר לי כואב לי הראש."},{"start":343.88,"end":344.88,"text":"איפה?"},{"start":344.88,"end":348.85,"text":"ומרימים את הקפה מהפחד או מרכבים."},{"start":348.85,"end":357.2,"text":"מוסר אסכל, אין רפואה לאלטרנטיבה ואין אלטרנטיבה לקפה."},{"start":357.2,"end":361.2,"text":"תהיו מרים ותחשבו על זה."},{"start":361.2,"end":393.22,"text":"מכה חדשה פוקדת את תל אביב."},{"start":393.22,"end":396.22,"text":"המצלמה המשוטטת של ג'ודי."},{"start":396.22,"end":397.76,"text":"ערב טוב."},{"start":397.76,"end":402.92,"text":"כאן ג'ודי לא צהרונוב קרפין או משמר סממא סוכניק סנטה קלאוס."},{"start":402.92,"end":407.17,"text":"מכה חדשה נוחתת על תל אביב, הפרגונומניה."},{"start":407.17,"end":413.2,"text":"פרגונומניה דחף חולני לפרגן, להלה, לשבח ולברך איש את ראהו."},{"start":413.2,"end":417.33,"text":"אכן, אנשים טובים באמצע הדרך."},{"start":417.33,"end":420.36,"text":"אנשים טובים מאוד."},{"start":420.36,"end":426.58,"text":"פרץ בלתי נשלט של עדיבות ורוחב לב ללוסיאג השתלטו על תושבי העיר הגדולה."},{"start":426.58,"end":432.82,"text":"לקחנו את המצלמה המשוטטת ויצאנו לבדוק הקצה הקטע."},{"start":432.82,"end":437.18,"text":"קאנבי נתן, פרום סאמוור אינדה מידה טרניאן."},{"start":437.18,"end":440.15,"text":"נשמע אני רוצה להגיד לך פשוט אתה מדהים."},{"start":440.15,"end":443.15,"text":"אתה עשית דברים שגרמו לי לרטט, רטט."},{"start":443.15,"end":446.15,"text":"תודה רבה אבל אני לעומת הכישרון שלך זה כלום."},{"start":446.15,"end":448.15,"text":"אתה פשוט צנוע שאתה יודע."},{"start":448.15,"end":450.15,"text":"אנשים מדברים על זה."},{"start":450.15,"end":452.4,"text":"לא נורא."},{"start":452.4,"end":453.4,"text":"סליחה אלוהים לא נורא."},{"start":453.4,"end":454.4,"text":"לא נורא."},{"start":454.4,"end":455.4,"text":"זה יכול להתראות."},{"start":455.4,"end":456.4,"text":"תראה הנה זה קורה."},{"start":456.4,"end":457.37,"text":"לא נורא גם זה..."},{"start":457.37,"end":458.66,"text":"גם זה קורה."},{"start":458.66,"end":459.66,"text":"זה יכול להראות את כל אותך."},{"start":459.66,"end":460.66,"text":"אני מאוד מצטר."},{"start":460.66,"end":462.63,"text":"לא קרה שום דבר."},{"start":462.63,"end":463.63,"text":"יש לך יופי של וסט."},{"start":463.63,"end":465.95,"text":"אז אני באמת מאוד אהבתי מה שעשית."},{"start":465.95,"end":466.95,"text":"זה היה פשוט לי."},{"start":466.95,"end":469.81,"text":"קח, קח, ואת."},{"start":469.81,"end":471.81,"text":"לא, לא, לא, אתה הגעת הראשון."},{"start":471.81,"end":472.81,"text":"לא, לא נעים לי."},{"start":472.81,"end":473.81,"text":"קח, אתה אבטיק את זה."},{"start":473.81,"end":474.81,"text":"אבל אני מת על הקבוצה שלך."},{"start":474.81,"end":475.81,"text":"בואי נעה."},{"start":475.81,"end":477.81,"text":"וואלה, תדעך, גם אתה היית גדול משחק השבת."},{"start":477.81,"end":478.81,"text":"היית לך."},{"start":478.81,"end":479.81,"text":"חרזי אבטה לה."},{"start":479.81,"end":480.81,"text":"מה קורה?"},{"start":480.81,"end":481.81,"text":"אתם לא רוצים להתקיע גדול?"},{"start":481.81,"end":483.81,"text":"לא יודע, לא רצינו להליב אותך."},{"start":483.81,"end":484.81,"text":"לא נעים, אתה יודע."},{"start":484.81,"end":485.81,"text":"לא נעים כל כך."},{"start":485.81,"end":501.7,"text":"השופט בן אדם, השופט בן אדם, ארסה למגב, ארסה למגב, ולמואל לבחור."},{"start":501.7,"end":504.98,"text":"אז מה דני, הפסקת לרוץ, אה?"},{"start":504.98,"end":507.98,"text":"כן, אין יותר התחרות, אין מתח, זהו, נגמר הכל."},{"start":507.98,"end":509.07,"text":"מדוע?"},{"start":509.07,"end":512.07,"text":"תראה, אני רץ, ואומר לי, אני רץ, ולידי רץ מי."},{"start":512.07,"end":516.07,"text":"הוא אומר לי, בוא תעקוף אותי, בוא, אתה יותר טוב ממני, בוא, תאי אפשר לרוץ."},{"start":516.07,"end":518.07,"text":"דרך אגב, סך על הפאלה שלך."},{"start":518.07,"end":519.07,"text":"אתה עלך יופיסת שאלה."},{"start":519.07,"end":520.07,"text":"תודה."},{"start":520.07,"end":524.07,"text":"אופה, סך על המיקרופון, איזה צבע, זה הצבע האהוב עליי, באמת, סך."},{"start":524.07,"end":525.07,"text":"תודה."},{"start":525.07,"end":528.07,"text":"וואו, סחטן על המצלמה, איזה יופיסת דבר הזה."},{"start":528.07,"end":533.07,"text":"בוא נהיינה, צופים בבית, סך עליכם, בוא נה, אתם עם סגולה, תאמינו לי, אני אוהב אתכם."},{"start":533.07,"end":534.19,"text":"סבבה עליכם."},{"start":534.19,"end":537.63,"text":"בואו, שיגי אותה, זה מישהו יודע!"},{"start":537.63,"end":540.63,"text":"אה, אבולי, איפה היית?"},{"start":540.63,"end":541.63,"text":"באותו שלי אני מזצל."},{"start":541.63,"end":542.63,"text":"אני חצי שעה באתי לך."},{"start":542.63,"end":543.63,"text":"שעבאתי לך."},{"start":543.63,"end":545.63,"text":"כשתלחתי לגנות קצת חומרים, אני רוצה לשטוף פה אותו אותו."},{"start":545.63,"end":547.63,"text":"אתה יודע, עניין של חצי שעה שעה, לא משהו."},{"start":547.63,"end":548.63,"text":"אה, מאחוז, אתה צריך עזרה בשטיפה?"},{"start":548.63,"end":549.63,"text":"לא, לא, תודה רבה לך."},{"start":549.63,"end":551.63,"text":"מאחוז, אם אתה צריך משהו, אני באוטו."},{"start":551.63,"end":552.63,"text":"אין בעיה, תודה."},{"start":552.63,"end":553.57,"text":"תראה, מה שטוב לך?"},{"start":553.57,"end":554.59,"text":"מאחוז."},{"start":554.59,"end":555.59,"text":"זה חצי שעה שעה, אני גומר."},{"start":555.59,"end":556.59,"text":"מה שטוב לך?"},{"start":556.59,"end":558.59,"text":"אני בסך הכל ממהר לך דרמיון, אל תהיה בלחץ."},{"start":558.59,"end":559.59,"text":"בסדר?"},{"start":559.59,"end":560.59,"text":"אין בעיה."},{"start":560.59,"end":562.59,"text":"תודה תודה אדוני, תענו."},{"start":562.59,"end":563.59,"text":"יופי של אטו יש לך."},{"start":563.59,"end":565.59,"text":"גם לך, על הכיפת."},{"start":565.59,"end":566.53,"text":"זכור טוב."},{"start":566.53,"end":577.35,"text":"גם ברמי דר גיסה תרתיים אשממה,"},{"start":577.35,"end":579.35,"text":"מה שהחל כפר פרה המשעשעת,"},{"start":579.35,"end":583.35,"text":"הפך במהרה למטרד שאין גדול ממנו."},{"start":583.35,"end":585.38,"text":"מה לא צ'ודי? ראב טוב היום."},{"start":585.38,"end":589.92,"text":"או, גם אתה גבר חסון שרירי ומוצק,"},{"start":589.92,"end":591.92,"text":"אכן מלח הארץ."},{"start":591.92,"end":592.92,"text":"תודה."},{"start":592.92,"end":593.89,"text":"המתן כמעה."},{"start":593.89,"end":597.19,"text":"כאן אינגה השוודית,"},{"start":597.19,"end":599.19,"text":"רחוב החלונות האדומים, אמסטרדם."},{"start":599.19,"end":602.69,"text":"אז איך אמרת שקוראים לך?"},{"start":602.69,"end":604.69,"text":"יואל, בוא איתי לאואל."},{"start":604.69,"end":608.42,"text":"לשפץ למועדון, לשפץ למועדון."},{"start":608.42,"end":611.38,"text":"הקבוצה שלנו הוא תמיד הכי טובה."},{"start":611.38,"end":613.38,"text":"הקבוצה שלנו הוא תמיד הכי טובה."},{"start":613.38,"end":616.38,"text":"למרות שהפסדנו מתחילת השנה."},{"start":616.38,"end":619.38,"text":"למרות שהפסדנו מתחילת השנה."},{"start":619.38,"end":621.38,"text":"מלצר, אפשר לקבל חשבון, בבקשה?"},{"start":621.38,"end":622.38,"text":"כן, בבקשה."},{"start":622.38,"end":623.38,"text":"בבקשה, חבר'ה."},{"start":623.38,"end":624.38,"text":"אני משלם."},{"start":624.38,"end":625.38,"text":"חבר'ה, יוצאתי את הרמטה."},{"start":625.38,"end":626.38,"text":"אתם העליבים, אחי?"},{"start":626.38,"end":628.38,"text":"אני את זה לא מתפשר."},{"start":628.38,"end":629.38,"text":"חבר'ה, חבר'ה."},{"start":629.38,"end":632.38,"text":"חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה, חבר'ה."},{"start":632.38,"end":634.54,"text":"היום עליי."},{"start":634.54,"end":636.72,"text":"עליי חבר'ה."},{"start":636.72,"end":637.72,"text":"חבר'ה."},{"start":637.72,"end":638.72,"text":"כל הכבוד."},{"start":638.72,"end":642.72,"text":"חבר'ה, מגיע לכם גם דין."},{"start":642.72,"end":643.72,"text":"תודה."},{"start":643.72,"end":644.72,"text":"תודה רבה."},{"start":644.72,"end":645.72,"text":"תודה רבה."},{"start":645.72,"end":646.72,"text":"חבר'ה, חבר'ה."},{"start":646.72,"end":647.72,"text":"תודה רבה."},{"start":647.72,"end":648.72,"text":"תודה רבה."},{"start":648.72,"end":649.72,"text":"תודה רבה."},{"start":649.72,"end":652.72,"text":"אני רוצה להרגיע את כל הציבור,"},{"start":652.72,"end":656.72,"text":"מה לא לדאוג, המשטרה לשם שינוי לא נדבקה במחלה הזאת,"},{"start":656.72,"end":660.63,"text":"ואנחנו עושים הכל על מנת לשיבל את הסדר על כנו."},{"start":660.63,"end":662.78,"text":"או, שלום לך אדוני, מה שלומך?"},{"start":662.78,"end":663.78,"text":"שלום."},{"start":663.78,"end":664.78,"text":"על הכפק יופי של גרב."},{"start":664.78,"end":665.78,"text":"אני עכשיו שדעתי כאן את הבנק."},{"start":665.78,"end":666.78,"text":"על הכפק, סבבה."},{"start":666.78,"end":667.78,"text":"אתה יכול לעצור אותי?"},{"start":667.78,"end":669.78,"text":"אה, לא, לא, לא, אתה עוד צעיר."},{"start":669.78,"end":670.78,"text":"אתה עוד צעיר, זה בסדר."},{"start":670.78,"end":671.78,"text":"לך לדכת אדוני."},{"start":671.78,"end":672.78,"text":"לא, תעצור אותי, בבקשה."},{"start":672.78,"end":673.78,"text":"רק אם זה יעשה לך טוב."},{"start":673.78,"end":677.78,"text":"הוא חי, הוא חי, הוא חי, הוא חי."},{"start":677.78,"end":680.75,"text":"הוא חי, הוא חי."},{"start":680.75,"end":683.01,"text":"אני מבין שיש לך בעיות מקצועיות."},{"start":683.01,"end":686.16,"text":"כן, תראה מה נגיד, חניתי סטנדאפיסט, כן?"},{"start":686.16,"end":687.16,"text":"הייתי בא לקהל, קוראה אותם."},{"start":687.16,"end":689.16,"text":"הייתי בא לבחורה, אומר לה:"},{"start":689.16,"end":691.16,"text":"\"בונה, את נראית כמו דמבו, תראי זה אוזניים יש לך.\""},{"start":691.16,"end":693.16,"text":"הייתי בא לאחרת, אומר לה:"},{"start":693.16,"end":695.16,"text":"\"בונה, זה השפם שלך או שזה סנאי עבר פה במקרה?\""},{"start":695.16,"end":697.16,"text":"הייתי שופך אותם, תבין?"},{"start":697.16,"end":699.16,"text":"היית שואל מי זה היה לי, כולם יהודים."},{"start":699.16,"end":701.6,"text":"היום אין, תבין, אני בא לבן אדם, אומר לו:"},{"start":701.6,"end":704.24,"text":"\"תגיד, אני רב סדר.\""},{"start":704.24,"end":708.13,"text":"עובד, תבין, אני אומר לו: \"בונה, אתה יפה.\""},{"start":708.13,"end":709.55,"text":"אוכל."},{"start":717.11,"end":721.49,"text":"נוסע מגיע על מקום שצריך לרדת, אומר לו: \"נעג כמה?\" הוא אומר לו: \"74.\""},{"start":721.49,"end":724.54,"text":"אמר לו: \"תודה.\""},{"start":724.54,"end":725.44,"text":"לא עובד, לא יודע."},{"start":725.44,"end":729.56,"text":"אך גם לבעי את הפרגונומניה בהקץ."},{"start":729.56,"end":734.72,"text":"מדענים רבים במכון ויצמן מצאו מזור לדליה ולמחלה."},{"start":734.72,"end":742.13,"text":"כאן ניתן לראות את החיידק שהוא הנוגדן למגפה בהגדלה של 1 למיליון."},{"start":742.13,"end":745.23,"text":"זהו חיידק הז'וז'ו-קוקיס."},{"start":745.23,"end":747.23,"text":"עט-עזי, מה זה עט-עזי?"},{"start":747.23,"end":751.32,"text":"עט-עט, חוסתה המדינה כולה בז'וז'ו-קוקיס."},{"start":751.32,"end":756.41,"text":"והארץ להיתה שקתה וחזרה להיות שוב מדינתנו האהובה."},{"start":756.41,"end":761.25,"text":"וואו, תדעתו את זה!"},{"start":761.25,"end":763.57,"text":"חנה, חתישה, אני מחכה פה!"},{"start":763.57,"end":765.57,"text":"חתישה, חתישה, חתישה!"},{"start":765.57,"end":768.49,"text":"מה זאת הזה?"},{"start":768.49,"end":770.84,"text":"לא, חתישה, לא!"},{"start":770.84,"end":773.0,"text":"לא, תשארנו!"},{"start":773.0,"end":776.78,"text":"לא, תשארנו!"},{"start":776.78,"end":780.78,"text":"שופן, תשאר כל העים שלך בשחות!"},{"start":780.78,"end":782.78,"text":"יא, שופן!"},{"start":782.78,"end":786.89,"text":"חתישה, חתישה!"},{"start":786.89,"end":788.89,"text":"הנה חזרו החיים אל מסלולם"},{"start":788.89,"end":790.89,"text":"ועולם כמן הגו נוהג"},{"start":790.89,"end":793.14,"text":"וכל הנחלים זורמים לים"},{"start":793.14,"end":796.14,"text":"ויש לי אהוב וסיירת חרוב"},{"start":796.14,"end":798.55,"text":"כאן ג'ודי לא צהרונוב"},{"start":798.55,"end":799.55,"text":"גרפי לותר קינג"},{"start":799.55,"end":801.55,"text":"סוקניק נווק לא פפר אחות"},{"start":801.55,"end":803.54,"text":"טרזדה נלסון מנדלה"},{"start":803.54,"end":806.61,"text":"טוב טוב הגמת, וושינגטון"},{"start":806.61,"end":815.67,"text":"ערב טוב, והרי תקציר החדשות"},{"start":815.67,"end":817.67,"text":"כאן במבזק של ז'אק"},{"start":817.67,"end":819.63,"text":"בערוץ הקהילתי שלכם"},{"start":819.63,"end":822.07,"text":"האופה והקונדיטור הבת ימי"},{"start":822.07,"end":823.07,"text":"דוד כימל"},{"start":823.07,"end":825.07,"text":"זכה אמש בתחרות בינלאומית"},{"start":825.07,"end":827.07,"text":"לאחר שיצר בפעם הראשונה בעולם"},{"start":827.07,"end":829.61,"text":"לחם חי"},{"start":829.61,"end":831.61,"text":"לחם חי בכלל לא מת"},{"start":831.61,"end":833.61,"text":"יש גם לחמניות גורמת"},{"start":833.61,"end":835.61,"text":"ולא אותו המצאה"},{"start":835.61,"end":837.57,"text":"פית הדיסק על המראה"},{"start":837.57,"end":839.57,"text":"הזמר האמריקני"},{"start":839.57,"end":841.57,"text":"מייקל ג'קסון משיקונה המלך הפופ"},{"start":841.57,"end":843.56,"text":"עבר ניתוח פלסטי נוסף"},{"start":843.56,"end":845.58,"text":"וכרגע הוא נראה כך"},{"start":845.58,"end":849.91,"text":"והרי כותרת"},{"start":849.91,"end":851.81,"text":"מתוך עיתוני הצהריים"},{"start":851.81,"end":854.18,"text":"הרמטכל עשר להעניש"},{"start":854.18,"end":856.18,"text":"חיילים בריתוק"},{"start":856.18,"end":858.27,"text":"לכספומט"},{"start":858.27,"end":862.51,"text":"כתבנו יצא אל השטח"},{"start":862.51,"end":864.51,"text":"אני מבין שאדוני מאוד מרוצה מהתקנה החדשה של הרמטכל"},{"start":864.51,"end":866.51,"text":"בוודאי שאני מרוצה"},{"start":866.51,"end":868.51,"text":"עוד שבוע מהיום התקנה תיכנס לתוקף"},{"start":868.51,"end":870.51,"text":"יקחו את כל אלה מפה"},{"start":870.51,"end":872.51,"text":"ואנחנו סוף נוכל להוציא כסף"},{"start":872.51,"end":874.6,"text":"כמו שצריך"},{"start":874.6,"end":876.6,"text":"בצהל המציאו מיד שיטות ריתוק חדשות"},{"start":876.6,"end":878.89,"text":"ריתוק למונית היא אחת"},{"start":878.89,"end":881.02,"text":"השיטות החביבות הלמפקדים"},{"start":881.02,"end":883.02,"text":"החייל מרותק למונית"},{"start":883.02,"end":885.02,"text":"עד שמונה המונית מגיע לתשעים ותשעה שקלים"},{"start":885.02,"end":887.21,"text":"שיטה נוספת ואכזרית מזו"},{"start":887.21,"end":889.21,"text":"היא שיטת ריתוק השחמט"},{"start":889.21,"end":891.24,"text":"החייל מרותק"},{"start":891.24,"end":893.24,"text":"למשחק שחמט"},{"start":893.24,"end":895.17,"text":"המתנהל בין שני אלופי עולם"},{"start":895.17,"end":897.42,"text":"וכיידו עליכם"},{"start":897.42,"end":899.74,"text":"המשחק עלול להימשך כמה שעות"},{"start":899.74,"end":905.34,"text":"השיטה האכזרית מכולן"},{"start":905.34,"end":907.3,"text":"ויש העומרים"},{"start":907.3,"end":909.72,"text":"אף סדיסטית"},{"start":909.72,"end":912.3,"text":"היא ריתוק היש לי יש לי"},{"start":912.3,"end":914.3,"text":"חיילים מרותקים לאזרח יש לי"},{"start":914.3,"end":916.52,"text":"עד שיספר בדיחה מוצלחת"},{"start":916.52,"end":918.52,"text":"יש לי יש לי יש לי"},{"start":918.52,"end":920.51,"text":"אול נושא אחר לגמרי"},{"start":920.51,"end":937.12,"text":"נמצא איתי כאן באולפן"},{"start":937.12,"end":939.12,"text":"הממציא הישראלי יהושפת טיימר"},{"start":939.12,"end":941.12,"text":"ערב טוב יהושפת"},{"start":949.11,"end":951.17,"text":"ספר לנו על המצעתך החדשה"},{"start":951.17,"end":953.77,"text":"ובכן זוי מכונת זמן"},{"start":953.77,"end":955.77,"text":"מה יוסע"},{"start":955.77,"end":958.11,"text":"ובכן הבט"},{"start":958.11,"end":960.11,"text":"ברגע שהלחץ על הכפתור הזה כאן"},{"start":960.11,"end":962.11,"text":"הזמן יזרום לו לאחורנית"},{"start":962.11,"end":965.58,"text":"בחמש שניות"},{"start":965.58,"end":967.61,"text":"ובכן הבט"},{"start":967.61,"end":969.61,"text":"ברגע שהלחץ על הכפתור הזה כאן"},{"start":969.61,"end":972.53,"text":"הזמן יזרום לו לאחורנית"},{"start":972.53,"end":974.53,"text":"בחמש שניות"},{"start":974.53,"end":976.53,"text":"ברגע שהלחץ על הכפתור הזה כאן"},{"start":976.53,"end":978.53,"text":"הזמן יזרום לו לאחורנית"},{"start":978.53,"end":981.3,"text":"בחמש שניות"},{"start":981.3,"end":983.3,"text":"ובכן הבט"},{"start":983.3,"end":985.3,"text":"ברגע שהלחץ על הכפתור הזה כאן"},{"start":985.3,"end":988.35,"text":"הזמן יזרום לו לאחורנית"},{"start":988.35,"end":990.31,"text":"בחמש שניות"},{"start":990.31,"end":992.31,"text":"ובכן הבט"},{"start":992.31,"end":994.31,"text":"ברגע שהלחץ על הכפתור הזה כאן"},{"start":994.31,"end":998.02,"text":"הזמן יזרום לו לאחורנית"},{"start":998.02,"end":1000.02,"text":"בחמש שניות"},{"start":1000.02,"end":1002.08,"text":"תודה רבה"},{"start":1002.08,"end":1004.08,"text":"זה הכל להפעם"},{"start":1004.08,"end":1006.08,"text":"כאן במבזק של ז'ק"},{"start":1006.08,"end":1008.62,"text":"זה הכל להפעם"},{"start":1008.62,"end":1011.26,"text":"כאן במבזק של ז'ק"},{"start":1011.26,"end":1013.26,"text":"לילה טוב"},{"start":1013.26,"end":1015.26,"text":"והמשך צפייה נעימה"},{"start":1015.26,"end":1018.15,"text":"בר מצווה"},{"start":1018.15,"end":1032.08,"text":"מה זה?"},{"start":1032.08,"end":1035.57,"text":"טקס התבגרות?"},{"start":1035.57,"end":1038.31,"text":"פולחן דתי?"},{"start":1038.31,"end":1041.83,"text":"בן 13 שנים"},{"start":1041.83,"end":1044.78,"text":"מספר מזל"},{"start":1044.78,"end":1047.35,"text":"האומנם"},{"start":1047.35,"end":1049.63,"text":"ואולי בפעם הבאה"},{"start":1049.63,"end":1051.61,"text":"כשתחגוג בר מצווה"},{"start":1051.61,"end":1054.36,"text":"תגלה שעשית אותה"},{"start":1054.36,"end":1056.77,"text":"ואולי בפעם הבאה"},{"start":1056.77,"end":1061.17,"text":"ואולי בפעם הבאה"},{"start":1061.17,"end":1063.17,"text":"ואולי בפעם הבאה"},{"start":1063.17,"end":1065.65,"text":"ואולי בפעם הבאה"},{"start":1065.65,"end":1072.38,"text":"ואולי בפעם הבאה"},{"start":1072.38,"end":1075.51,"text":"תקריבו את קורבנכם"},{"start":1075.51,"end":1077.51,"text":"אדם כי יקריב קורבן"},{"start":1077.51,"end":1079.51,"text":"דד הפרומה, סתקסתביך"},{"start":1079.51,"end":1081.82,"text":"שאל עליך מעל רגליך"},{"start":1081.82,"end":1083.82,"text":"וגם"},{"start":1083.82,"end":1085.82,"text":"כל בסבוע"},{"start":1085.82,"end":1090.5,"text":"ערב זך ושוב אנחנו"},{"start":1090.5,"end":1133.32,"text":"בחלסטר של זוזו"},{"start":1133.32,"end":1135.32,"text":"והפעם בעיה שמדאיגה אותי במיוחד"},{"start":1135.32,"end":1137.32,"text":"בעיית הבירות במדינה"},{"start":1137.32,"end":1139.54,"text":"רבותיי, הבירות יורדים"},{"start":1139.54,"end":1141.54,"text":"ממצב של מדחי לדחקה"},{"start":1141.54,"end":1143.54,"text":"באמא שלי"},{"start":1143.54,"end":1145.54,"text":"זה לא יאמן מה שקורה"},{"start":1145.54,"end":1147.54,"text":"פעם בירה היה בירה"},{"start":1147.54,"end":1149.54,"text":"היום איזה שמות שלפלפים יש לי בירות"},{"start":1149.54,"end":1151.57,"text":"בירה טובורג, בירה קארלסברג"},{"start":1151.57,"end":1153.57,"text":"בירה מילר"},{"start":1153.57,"end":1155.57,"text":"מה זה מילר, זה לפלפים עגולדים"},{"start":1155.57,"end":1157.57,"text":"אמא שלי עם קוקיה כזאת, מה זה?"},{"start":1157.57,"end":1159.57,"text":"אז גם בירה אינקנק"},{"start":1159.57,"end":1161.66,"text":"אמא שלי זה בירה עם סלמי"},{"start":1161.66,"end":1163.85,"text":"אבל פעם היה לנו בירות"},{"start":1163.85,"end":1165.85,"text":"הם כבוד, הם נשרים"},{"start":1165.85,"end":1167.85,"text":"עם עריות, הם נמרים"},{"start":1167.85,"end":1169.85,"text":"באימא שלי זה בירה עם הנחיות"},{"start":1169.85,"end":1171.85,"text":"היום הבעיה שמדאיגה אותי ביותר"},{"start":1171.85,"end":1175.81,"text":"היא הירידה של בירה גולדסטר"},{"start":1175.81,"end":1178.15,"text":"פעם בירה גולדסטר היה להם"},{"start":1178.15,"end":1180.25,"text":"אחלה קמפיין"},{"start":1180.25,"end":1182.25,"text":"הם קראו לזה תנולה גבר גולדסטר"},{"start":1182.25,"end":1184.44,"text":"היום זה תנולה לאף לאף גולדסטר"},{"start":1184.44,"end":1186.44,"text":"מה זה אחרת הזה?"},{"start":1186.44,"end":1188.47,"text":"רואים בפרשומת בחורה"},{"start":1188.47,"end":1190.69,"text":"נכנסת לפאב"},{"start":1190.69,"end":1192.69,"text":"חפשת, חפשת, מה המחפשת מנענע אותה?"},{"start":1192.69,"end":1194.69,"text":"נכנסת הפאב"},{"start":1194.69,"end":1196.69,"text":"ואז היא צריכה לזהות אותו"},{"start":1196.69,"end":1198.69,"text":"לפי הגולדסטר"},{"start":1198.69,"end":1201.23,"text":"מה זה החרטב הוואט הזה?"},{"start":1201.23,"end":1203.54,"text":"צוות הפרסום של זו זו ונבל אש"},{"start":1203.54,"end":1205.56,"text":"יצא החוצה"},{"start":1205.56,"end":1207.56,"text":"והביא קונטרה לגולדסטר"},{"start":1207.56,"end":1210.09,"text":"תחשבו על זה"},{"start":1210.09,"end":1214.1,"text":"איך אני אצאה אותך?"},{"start":1214.1,"end":1216.1,"text":"על פי הגורמט, מאמי, הגורמט"},{"start":1216.1,"end":1247.38,"text":"הזהב של הפאב"},{"start":1247.38,"end":1251.11,"text":"מוסר רסקל, שימו לב"},{"start":1251.11,"end":1253.11,"text":"כופרייטרים יקרים"},{"start":1253.11,"end":1255.11,"text":"לפני שאתם עושים פרסומת לבירה"},{"start":1255.11,"end":1257.17,"text":"תשתו משו"},{"start":1257.17,"end":1259.17,"text":"תיבזקו ותשתו"},{"start":1259.17,"end":1261.17,"text":"יחללכם רעיונות"},{"start":1261.17,"end":1263.17,"text":"ותחשבו הזה"},{"start":1263.17,"end":1264.67,"text":"לחיים"}]