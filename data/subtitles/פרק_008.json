[{"start":31.07,"end":37.37,"text":"ברוכים הבאים, אלה קור ומסתור!"},{"start":37.37,"end":41.93,"text":"ומה לא בבקשה?"},{"start":41.93,"end":44.51,"text":"תגיד לי, אתה מטורף? מה זה צריך להיות הנהיגה הזאת?"},{"start":44.51,"end":46.23,"text":"אתה נסעת פה מאה כמה שבתוך העיר?"},{"start":46.23,"end":48.35,"text":"לכן אני יודע, אני פשוט מאוד ממהר."},{"start":48.35,"end":49.03,"text":"אה, סליחה."},{"start":49.03,"end":77.32,"text":"שירות מודיעין שלום."},{"start":77.32,"end":79.84,"text":"אנו מטפלים בפניות קודמות."},{"start":79.84,"end":81.23,"text":"נעלה המתין."},{"start":81.23,"end":82.14,"text":"תודה."},{"start":82.14,"end":84.57,"text":"בזק, תשומת לבכן."},{"start":84.57,"end":87.55,"text":"אם ברצונכם לבקש יותר ממספר 1,"},{"start":87.55,"end":90.05,"text":"אנא, ציינו זאת בתחילת השיחה."},{"start":90.05,"end":92.18,"text":"בזק, לרשות חם."},{"start":92.18,"end":95.6,"text":"שירות מודיעין שלום."},{"start":95.6,"end":97.63,"text":"אנו מטפלים בפניות קודמות."},{"start":97.63,"end":100.83,"text":"נהלי המתין, תודה, בזק."},{"start":100.83,"end":103.8,"text":"בתשומת לבכם, אם ברצונכם בבקש..."},{"start":103.8,"end":106.08,"text":"מודיעין, שלום, מדברת ורד."},{"start":106.08,"end":109.02,"text":"תקבל מענה קולי בבקשה."},{"start":109.02,"end":111.44,"text":"המספר המבוקש הוא:"},{"start":111.44,"end":117.29,"text":"0-3-4-7-6-4-7-5"},{"start":117.29,"end":126.48,"text":"אני חוזרת: 0-2-2-2-1-x2-x1"},{"start":126.48,"end":128.77,"text":"לימור שלום."},{"start":128.77,"end":131.15,"text":"אני רוצה להזמין אותך לסרט."},{"start":131.15,"end":135.22,"text":"לקסומת ליבר: אם יתומך לצפות ביותר מסרט 1,"},{"start":135.22,"end":138.47,"text":"אנה הצייני זאת בתחילה בשיחה. תודה."},{"start":138.47,"end":143.82,"text":"סרט המבוקש הוא: שיימס גבון 0-0-7"},{"start":143.82,"end":148.52,"text":"אני חוזרת: בסביבות השאל 7-7-5"},{"start":148.52,"end":152.53,"text":"אסוף אותי ב-8-0-6"},{"start":152.53,"end":154.29,"text":"תודה."},{"start":154.29,"end":156.26,"text":"תודה. מתחשב בזה."},{"start":156.26,"end":171.61,"text":"מה? מי אחראי פה על ה..."},{"start":171.61,"end":173.13,"text":"אני? אני אחראי אלן."},{"start":173.13,"end":174.05,"text":"אחראי שני אלה?"},{"start":174.05,"end":174.61,"text":"כן, מה לעשות?"},{"start":174.61,"end":176.21,"text":"מה זה צריך להיות העניין הזה?"},{"start":176.21,"end":177.6,"text":"הם..."},{"start":177.6,"end":180.02,"text":"תגים, כן."},{"start":180.02,"end":183.74,"text":"זה בסדר, אבל הם לא מזיקים. אני אחראי אליהם."},{"start":183.74,"end":186.62,"text":"לא, לא מקובל עליי. תוציא אותם מפה, בקשה."},{"start":186.62,"end":189.06,"text":"אבל למה? תוציא אותם מפה."},{"start":189.06,"end":192.53,"text":"טוב, חבר'ה, אין ברירה. שמעתם מהריש יותר."},{"start":192.53,"end":193.96,"text":"זזים!"},{"start":193.96,"end":198.43,"text":"וופה!"},{"start":198.43,"end":202.27,"text":"אהלן."},{"start":202.27,"end":205.22,"text":"אהלן, בן אדם, מה קרה? למה הכרת כל כך?"},{"start":205.22,"end":207.3,"text":"אני מצטער, היום המון פקקים. תראה כמה..."},{"start":207.3,"end":209.05,"text":"אה, פקקים האלה, בוא שב שב."},{"start":209.05,"end":211.96,"text":"מה קרה? מה העניין? אתה לא מרגיש טוב?"},{"start":211.96,"end":213.2,"text":"לא יש לי כאב ראש."},{"start":213.2,"end":214.12,"text":"אה, אתה רוצה איזה כדור אולי?"},{"start":214.12,"end":214.68,"text":"יש לך?"},{"start":214.68,"end":216.26,"text":"כן, בטח."},{"start":216.26,"end":217.43,"text":"תודה."},{"start":217.43,"end":218.95,"text":"מה, בא לך לאכול משהו?"},{"start":218.95,"end":220.67,"text":"מה אתה תפריט לי?"},{"start":220.67,"end":222.57,"text":"תח."},{"start":222.57,"end":225.23,"text":"אה, אני חושב שבא לי לנגב משהו."},{"start":225.23,"end":226.01,"text":"לנגב?"},{"start":226.01,"end":226.29,"text":"כן."},{"start":226.29,"end":230.24,"text":"בוא על הכיף פק, בקיף, ננגב."},{"start":230.24,"end":232.96,"text":"תגיד איך אתה אוהב את הקפה שלך עם כמה כפיות?"},{"start":232.96,"end":234.68,"text":"שלוש כפיות."},{"start":234.68,"end":235.69,"text":"בבקשה."},{"start":235.69,"end":236.48,"text":"תודה."},{"start":236.48,"end":239.35,"text":"יופי, על הכיף פק, תודה."},{"start":239.35,"end":240.86,"text":"תפע מיץ'ך."},{"start":240.86,"end":242.08,"text":"לא, אני רוצה קש."},{"start":242.08,"end":244.67,"text":"קש, אין בעיה."},{"start":244.67,"end":247.71,"text":"תגיד יש לך משהו לכינוח?"},{"start":247.71,"end":250.82,"text":"כן, בטח שיש."},{"start":250.82,"end":271.4,"text":"אוהבים הילדים?"},{"start":271.4,"end":273.01,"text":"איפה הילד?"},{"start":273.01,"end":273.11,"text":"אהההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":273.01,"end":320.23,"text":"א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א א"},{"start":320.23,"end":323.64,"text":"עכשיו יש להקה חדשה שקוראים לה זקני צפת"},{"start":323.64,"end":326.49,"text":"תאימא שלי חשבתי, נבוא לצפת"},{"start":326.49,"end":330.43,"text":"נראה את כל הזקנים את בר כוחבה ואת רבי מאיר בעל הנס"},{"start":330.43,"end":332.43,"text":"ורבי שימשון בעל הקופה"},{"start":332.43,"end":334.03,"text":"כולם יושבים בסבבה"},{"start":334.03,"end":336.97,"text":"עם שש בש ושערים שירים, הלילה הלילה"},{"start":336.97,"end":340.06,"text":"לא! ראינו חבורה של מכוערים"},{"start":340.06,"end":342.14,"text":"עם תשפורות כאלה"},{"start":342.14,"end":345.12,"text":"דימה עם שערים, גבירותיי ורבותיי שימו לב"},{"start":345.12,"end":348.19,"text":"לא תבואי שישי שבא"},{"start":348.19,"end":350.59,"text":"זהו יום הבוחר"},{"start":350.59,"end":353.04,"text":"לא תבואי שישי שבא"},{"start":353.04,"end":354.4,"text":"זהו יום הבוחר"},{"start":354.4,"end":355.9,"text":"זהו יום הבוחר"},{"start":355.9,"end":357.2,"text":"זהו יום הבוחר"},{"start":357.2,"end":358.2,"text":"זהו יום הבוחר"},{"start":358.2,"end":359.47,"text":"לא תבואי שישי"},{"start":359.47,"end":361.69,"text":"באמא שלי אחותי כתגמל תמציאו יותר מילים"},{"start":361.69,"end":362.89,"text":"מה זה ערת זה?"},{"start":362.89,"end":364.89,"text":"שתי מילים שעה שיר התחרפנתי"},{"start":364.89,"end":365.69,"text":"מה זה זה?"},{"start":365.69,"end":367.77,"text":"חוץ מזה אני הייתי בטוח זה שיר להסתדרות"},{"start":367.77,"end":368.77,"text":"יום הבוחר יום הבוחר"},{"start":368.77,"end":369.63,"text":"מוצאתי פגאס אדום"},{"start":369.63,"end":370.97,"text":"לא ידעתי מה קורה"},{"start":370.97,"end":372.93,"text":"ממש הביא לי את החלסטרה"},{"start":372.93,"end":373.89,"text":"לא מספיק זה"},{"start":373.89,"end":374.96,"text":"יש להם עוד שיר"},{"start":374.96,"end":377.29,"text":"הזכין שלו ישין שלו ישין"},{"start":377.29,"end":378.97,"text":"באמא שלי איך ישן הזכין?"},{"start":378.97,"end":381.45,"text":"לעקה של מכוערים שערים לא מתחת למרפסת"},{"start":381.45,"end":382.81,"text":"בואי שישי בואי שבת"},{"start":382.81,"end":384.81,"text":"הזכין נקרא לו המוח"},{"start":384.81,"end":387.55,"text":"תחשבו עליו הוא ממש מסכן"},{"start":387.55,"end":407.94,"text":"הרמצא"},{"start":407.94,"end":418.21,"text":"משטרה מצאתי אקטח ברחוב"},{"start":418.21,"end":423.03,"text":"שר..."},{"start":423.03,"end":430.89,"text":"רחוב..."},{"start":430.89,"end":449.74,"text":"ש..."},{"start":449.74,"end":453.47,"text":"משטרה מצאתי אקטח ברחוב"},{"start":453.47,"end":459.18,"text":"אס..."},{"start":459.18,"end":467.64,"text":"אנו ככתובים ונחת מילדים ושמחה גדולה"},{"start":467.64,"end":469.24,"text":"תגידי"},{"start":469.24,"end":470.28,"text":"תגידי"},{"start":470.28,"end":472.44,"text":"בעלך כל הזמן אוכל?"},{"start":472.44,"end":475.4,"text":"לא, לא כל הזמן, רק אשך הוא ישן!"},{"start":475.4,"end":479.02,"text":"דרך!"},{"start":479.02,"end":481.74,"text":"אי, איך הוא שומר ממש! יש לי, יש לי!"},{"start":481.74,"end":484.87,"text":"תקשיבי, בחלך הוא כל הזמן זולל?"},{"start":484.87,"end":486.77,"text":"לא, לא כל הזמן, רק שהוא אוכל!"},{"start":486.77,"end":487.89,"text":"לא!"},{"start":487.89,"end":491.41,"text":"את מצקיק כלי, יאמר!"},{"start":491.41,"end":495.41,"text":"אי, רגע, רגע, רגע, יש לי גן, יש לי גן, תגידי!"},{"start":495.41,"end":498.08,"text":"בעלך כל הזמן משקר!"},{"start":498.08,"end":500.4,"text":"לא, רק שהוא מדבר!"},{"start":500.4,"end":502.4,"text":"אי, רגע, רגע!"},{"start":502.4,"end":504.4,"text":"הוא מדבר!"},{"start":504.4,"end":506.91,"text":"הוא יצא להתפוצד!"},{"start":506.91,"end":508.91,"text":"יש לי, יש לי, יש לי, יש לי, יש לי!"},{"start":508.91,"end":510.88,"text":"בקזה, חשב, נבנות!"},{"start":510.88,"end":513.1,"text":"בעלי, כל הזמן מטומטם!"},{"start":513.1,"end":516.57,"text":"פה, להיטים הוא אהבל!"},{"start":516.57,"end":534.8,"text":"פעם עם הפולניה יקרה,"},{"start":534.8,"end":536.8,"text":"נלמד כיצד להתמודד עם העובדה"},{"start":536.8,"end":538.8,"text":"שהבן הביא הבית השברצה."},{"start":538.8,"end":541.85,"text":"עוד עם כל, תפני מי."},{"start":541.85,"end":543.85,"text":"זה לא קל, אני יודעת. תפני מי."},{"start":543.85,"end":546.07,"text":"תפני מי ואל תראי לילד."},{"start":546.07,"end":548.67,"text":"הילד תאמיני לי, ילמד עם זה"},{"start":548.67,"end":551.92,"text":"אם זה במוקדם, אם זה במאוחר, שהוא שגע."},{"start":551.92,"end":554.92,"text":"את צריכה גם להסביר לו, מגיל צעיר,"},{"start":554.92,"end":557.92,"text":"שלא כל בני האדם נולדו שווים, אין מה לעשות."},{"start":557.92,"end":561.92,"text":"נכון, לא כולם צריכים להיות פולנים וחבל."},{"start":561.92,"end":565.92,"text":"אבל זה לא אומר שאני אצטרך להכינקו בכל הזמן."},{"start":565.92,"end":568.95,"text":"תראי, זה לא..."},{"start":568.95,"end":571.01,"text":"את צריכה להעמיד אותו במקום."},{"start":571.01,"end":573.01,"text":"את צריכה להעמיד אותו במקום."},{"start":573.01,"end":575.2,"text":"לא להתבייש להעניש."},{"start":575.2,"end":577.2,"text":"לאישית יש שלושה ילדים."},{"start":577.2,"end":584.92,"text":"רופא בן שמונה, עורך דין בן שש, ונגן כינור בן שנתיים, פוץ פוץ פוץ, הם עדיין לא הביאו שברצה הביתה."},{"start":584.92,"end":594.2,"text":"ואם הבן שלך יביא שברצה הביתה, תפני מי. תפני מי שנה, תפני משנתיים, ואם גם זה לא יעזור, תפני מי."},{"start":594.2,"end":597.98,"text":"ואת יודעת מה? אני לא יודעת. אני לא יודעת."},{"start":608.76,"end":613.74,"text":"קפס מנענע אותך, קפס."},{"start":642.35,"end":644.76,"text":"בבקשנה שהברה היה שבועות."},{"start":644.76,"end":648.79,"text":"זה מה שאני אומר, אתה רואה? אני אומר, אם נותנים יחס לעובד, אז הוא עובד."},{"start":648.79,"end":650.79,"text":"אבל כשלא מתייחסים אליו, אז הוא לא אכפת לו."},{"start":650.79,"end":652.79,"text":"והם אכפת להם מאיתנו, לא אכפת להם."},{"start":652.79,"end":655.79,"text":"אז אם להם לא אכפת להם מאיתנו, זמה שלי אכפת להם מאיתנו."},{"start":655.79,"end":656.79,"text":"ולי אכפת להם?"},{"start":656.79,"end":660.79,"text":"לא אכפת להם גם ממך, אתה לא אכפת לך מהם, אז הם לא אכפת להם מאיתנו."},{"start":660.79,"end":661.79,"text":"אבל לך אכפת להם."},{"start":661.79,"end":662.79,"text":"אני אכפת להם."},{"start":662.79,"end":667.79,"text":"לי לא אכפת להם מאיתנו גם, אני אומר אם להם לא אכפת להם מאיתנו, זמה שלך היא אכפת להם ממני, אני עם איתנו."},{"start":667.79,"end":668.79,"text":"אז לך לא אכפת להם ממני?"},{"start":668.79,"end":674.69,"text":"אני אמרתי שאלך לא אכפת להם ממני, אני אומר שאם להם לא אכפת להם מאיתנו, זמה שלך ולי אכפת להם מאיתנו."},{"start":674.69,"end":676.07,"text":"וממני יותר טוב."},{"start":676.07,"end":678.26,"text":"הנה שתי הם סכנה על דה."},{"start":678.26,"end":679.26,"text":"אתה תהיל איתי אותם."},{"start":679.26,"end":683.11,"text":"נמחא!"},{"start":683.11,"end":687.1,"text":"אלן, נחש מה יש לי ביד?"},{"start":687.1,"end":689.26,"text":"סנתר כנף."},{"start":689.26,"end":690.89,"text":"אחי סצת."},{"start":690.89,"end":692.66,"text":"לא נכון."},{"start":692.66,"end":701.47,"text":"לנשום עמוק."},{"start":701.47,"end":715.15,"text":"אי, אי, אחת, אחת, שתיים, אי."},{"start":715.15,"end":719.09,"text":"וואן, טו, וואן, טו, אה, אי."},{"start":719.09,"end":722.33,"text":"אקו קצת, אקו כן, אה, אי, אי."},{"start":722.33,"end":723.33,"text":"תן לי נמוכים, אי."},{"start":723.33,"end":727.16,"text":"וואן, טו, אה, וואן, טו, אי."},{"start":727.16,"end":733.12,"text":"שש עשרה מלעו לנער וליבו אמר."},{"start":733.12,"end":738.12,"text":"היא הייתה יפה כלבנה במילואה."},{"start":738.12,"end":749.15,"text":"והוא אהב אותה, והוא חלב דמותה, והוא אה, וואו, וואו, וואו, וואו, וואו, וואו, וכך התחילה קטן."},{"start":749.15,"end":753.55,"text":"תקו, תקו. אוקיי, זה בסדר. תן לי? אוקיי."},{"start":753.55,"end":759.33,"text":"מאה אחוז, אני לא רואה שום בעיה. תודה רבה, דוקטור. להתראות. תודה רבה."},{"start":759.33,"end":792.21,"text":"תודה רבה, לבקשה, תשתה את הכל. תגיד, תגיד, תגיד, תגיד. אבא שלך, אה, שוקו? לא. אבא שלי, אה, מי, אה, תה. תגיד, תגיד, תגיד. אבא שלך, הוא יודע, קר הקפה? לא, אבא שלי יודע, קר התה. תה. תגיד רגע."},{"start":792.21,"end":818.39,"text":"תגיד רגע, אבא שלך גבוה עד השעה, סודה? לא, אבא שלי גבוה עד השעה מים. מים, מים לדמיד המלך. לך לי, לך לי, לך לי, לך לי, לך לי, לך לי, לך לי, לך לי, לך לי. תגידו, האבא שלי תוצא כל הדייט. תח לי פה, תח."},{"start":826.34,"end":847.38,"text":"חפס מנה אותך, חפס מנה אותך, חפס מנה אותך, חפס..."},{"start":847.38,"end":858.96,"text":"תוריד את הכובעת עם שיזה, בשינה. תגיד לי, אתה יודע, קו המאירות..."},{"start":858.96,"end":859.96,"text":"ברוך! - יואל!"},{"start":859.96,"end":861.96,"text":"מה אני נמרוך! - מה נשמע, בואי..."},{"start":861.96,"end":863.96,"text":"מה עצר? - איזה מסע שזה עצר!"},{"start":863.96,"end":866.96,"text":"מה, אני צריך לראות אותך בקרישי, תגיד לי, מה הקטע הזה?"},{"start":866.96,"end":868.96,"text":"מה אתה מסע בקוות מהירות?"},{"start":868.96,"end":870.96,"text":"טוב, אתה הראש שלך לא במקום, אה?"},{"start":870.96,"end":872.96,"text":"כל הזמן הראש שלך בזיונים, רק זיונים, אה?"},{"start":872.96,"end":874.96,"text":"רק על הבחורות שלך אתה חושב, אחי,"},{"start":874.96,"end":878.14,"text":"אתה פטיש רציני, תגיד לי, מה, זה לא מסויע על אשתך?"},{"start":878.14,"end":880.17,"text":"כל הזיונים האלה שלך מעצת"},{"start":880.17,"end":882.16,"text":"טוב, היא בטח גם מי מזדרת מעצת, לא?"},{"start":882.16,"end":885.16,"text":"יש לך את ההוא, הבלונדיני הזה שראה איתה, לא, אה?"},{"start":885.16,"end":888.19,"text":"רק על קטע, תגיד לי, תשמע, אתה לא מבין שזה פוגע בילדים"},{"start":888.19,"end":890.16,"text":"רק בילדים שלך זה פוגע"},{"start":890.16,"end":892.19,"text":"תגיד לי, מה, מה עם הילדה שלך?"},{"start":892.19,"end":894.41,"text":"סידעת את הקטע הזה עם הכינים של אולה?"},{"start":894.41,"end":896.4,"text":"סידעת את זה?"},{"start":896.4,"end":898.47,"text":"תקשר לי אשתי, יש לה אחלה תכשיר, היא תיתן לך את זה"},{"start":898.47,"end":902.62,"text":"תיתן לך את זה, בסדר? ותהיה בקשר, הרחיבה תעשה כזה עם האיוב, בסדר?"},{"start":902.62,"end":904.74,"text":"פעם זה היה אני, למען פעם הבאה זה יכול להיות מישהו אחר"},{"start":904.74,"end":906.74,"text":"יאללה, סלמת אחי, להתראות"},{"start":906.74,"end":908.9,"text":"להתראות"},{"start":908.9,"end":911.75,"text":"בוא, בוא, תקנה קובה חדש"},{"start":911.75,"end":914.8,"text":"בוא שתעשה השתלה לסייר, זה יותר יפה"},{"start":914.8,"end":918.73,"text":"תן לי שני ספרדי, אחד ראנץ', פייטו פוחים וקולה"},{"start":918.73,"end":919.99,"text":"בסדר? תודה"},{"start":919.99,"end":926.72,"text":"אבי"},{"start":926.72,"end":930.08,"text":"חטאת, בני?"},{"start":930.08,"end":932.65,"text":"לא אני אבי, סבדה שלי חטאה"},{"start":932.65,"end":934.99,"text":"דבר, בני"},{"start":934.99,"end":939.65,"text":"היא, היא בשלה דעיסה"},{"start":939.65,"end":942.39,"text":"ונתנה לכולם"},{"start":942.39,"end":945.18,"text":"לאבא"},{"start":947.84,"end":952.78,"text":"לאחי, לאחותי, ורק לי לא נשאר."},{"start":952.78,"end":958.59,"text":"דיגי, דיגי, דיגי."},{"start":958.59,"end":962.36,"text":"ואחר כך באתי לסבתא שלי, ואמרתי לה,"},{"start":962.36,"end":964.06,"text":"את מחשושה לרעה."},{"start":964.06,"end":969.69,"text":"תחתונים וגופייה."},{"start":969.69,"end":974.78,"text":"אבי, ברח אותי."},{"start":974.78,"end":983.76,"text":"כולכם מאזינים למצד הפזמונים,"},{"start":983.76,"end":987.7,"text":"עליו יסופר במשך השנים."},{"start":987.7,"end":990.91,"text":"גלי, גלי צהל."},{"start":990.91,"end":992.96,"text":"EVERYBODY KNOW!"},{"start":992.96,"end":995.09,"text":"גלי, גלי צהל."},{"start":996.09,"end":1004.09,"text":"הסטנדאפ ממשיך להתפשט בעולם,"},{"start":1004.09,"end":1005.75,"text":"והפעם בסגנון הפוך."},{"start":1005.75,"end":1017.47,"text":"כולם בשביל לך!"},{"start":1017.47,"end":1022.68,"text":"אנחנו מקווים שקנית כרטיס,"},{"start":1022.68,"end":1025.06,"text":"כי אנחנו מתחתים בהכנסות."},{"start":1025.06,"end":1030.77,"text":"תאמין לנו, אתם קהל אחד אחד!"},{"start":1030.77,"end":1037.13,"text":"אי, זאת! כן, כן, אתה!"},{"start":1037.13,"end":1039.23,"text":"נכון שאתה רבק?"},{"start":1039.23,"end":1043.35,"text":"למה מי תתחתן איתך ים וכואר?"},{"start":1043.35,"end":1048.62,"text":"אי, יש פה מישהו מבת ים?"},{"start":1048.62,"end":1053.28,"text":"די תשקי, פשוט לא הבנת את השאלה!"},{"start":1053.28,"end":1058.56,"text":"אה, גדל, גדל!"},{"start":1058.56,"end":1062.3,"text":"אנחנו סבימנו, קייט הנאבה וואן,"},{"start":1062.3,"end":1067.23,"text":"אנחנו העינו עשר, וכוי שלהנית לילה טוב!"},{"start":1067.23,"end":1083.45,"text":"היו שני סינים, אלה כמה יש היום!"},{"start":1083.45,"end":1100.95,"text":"שלום ושוב להקות, והפעם המצב הרבה יותר חמור!"},{"start":1100.95,"end":1104.8,"text":"אני מדבר על להקה בשם \"להקת הג'ינג'יות\"."},{"start":1104.8,"end":1109.29,"text":"מה זה הג'ינג'יות האלה? אין שם ג'ינג'ית אחת באמא שלי."},{"start":1109.29,"end":1111.57,"text":"חיפשתי בכליף שילהם, חיפשתי."},{"start":1111.57,"end":1113.37,"text":"בעיתונים בפרסומיות, חיפשתי."},{"start":1113.37,"end":1117.17,"text":"כלום! אין שם ג'ינג', לא ג'ינג', לא אדום, לא חלודה, לא נעליים, כלום."},{"start":1117.17,"end":1118.53,"text":"יש להם שתי פרצופים,"},{"start":1118.53,"end":1121.41,"text":"מאוד מאוד לא מחמיאים הייתי בכנית, זה ככה,"},{"start":1121.41,"end":1123.73,"text":"ועם שערים שירים מאוד מאוד מוזרים,"},{"start":1123.73,"end":1126.65,"text":"חצי בעברית, חצי באנגלית. מה זה? למה?"},{"start":1126.65,"end":1129.17,"text":"\"היט מי ה-הנדרט טיימס, אל בי את די טיימס\"."},{"start":1129.17,"end":1131.81,"text":"שיגד בעברית, תביא לי כף עוד מאה פעמים,"},{"start":1131.81,"end":1136.75,"text":"אם לא אני אקח את הסיגריותיים, אני אקחה בפנים, שתרגעי, זה שיר נחמד."},{"start":1136.75,"end":1139.33,"text":"\"גיב מי ה-הנדרט טיימס\" זה אני בסבבה."},{"start":1139.33,"end":1142.29,"text":"למה באנגלית? למה? אם יש לך שיר עם קצב, לך איתו."},{"start":1142.29,"end":1144.69,"text":"תביא כפה, תביא סטיפה, תשחק אותה."},{"start":1144.69,"end":1146.33,"text":"ואללה, מה אני אקלח עם כהל אכבד?"},{"start":1146.33,"end":1148.79,"text":"אני מתגעגע לשירי ארץ ישראל הישנה,"},{"start":1148.79,"end":1150.91,"text":"שהבן אדם אומר לה: \"שעון מרעי שלוש,"},{"start":1150.91,"end":1153.01,"text":"מתי, מתי כבר שמוני, ואם היא לא ידעת,"},{"start":1153.01,"end":1156.13,"text":"הוא בי בי לה הטרד טיימ׶ של כפות לסאבה, ביניףים,"},{"start":1156.13,"end":1158.37,"text":"בי שמיח, בי כולם על השולחנות,"},{"start":1158.37,"end":1160.76,"text":"כי תחשבו הזה.\""}]