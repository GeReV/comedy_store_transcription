75,"end":744.13,"text":"יום טוב לך דוני להתראות"},{"start":744.13,"end":746.13,"text":"פרופסור קטרוס אתה הממציא הידוע של דני דין"},{"start":746.13,"end":748.13,"text":"אולי אתה מבין מה קרה לו"},{"start":748.13,"end":750.13,"text":"בוודאי שאני מבין תראה"},{"start":750.13,"end":752.13,"text":"אני המצאתי בזמנו את המים הזכולים"},{"start":752.13,"end":754.13,"text":"זה מאוד מאוד חשובה שדני דין לא יודע"},{"start":754.13,"end":756.35,"text":"פעם ב-20 שנה"},{"start":756.35,"end":758.35,"text":"הבן אדם הופך להיות רלף"},{"start":758.35,"end":760.35,"text":"מפרצת"},{"start":760.35,"end":762.35,"text":"הוא הופך להיות מרשעת ניידת"},{"start":762.35,"end":764.35,"text":"הוא הולך ברחום מקפקף אנשים"},{"start":764.35,"end":766.35,"text":"מצחוין אותם מביא להם פלסקים באוזניים"},{"start":766.35,"end":768.35,"text":"לכן יש לנו מצוקה קשה ואנחנו עובדים על פתרון"},{"start":768.35,"end":770.35,"text":"היסטרי במעבדה 24 שעות ביממה"},{"start":770.35,"end":772.35,"text":"אני מקווה שנמצא פתרון"},{"start":772.35,"end":774.35,"text":"היי תביאי תצויק לה מעבדה תתחיל לעבוד"},{"start":774.35,"end":776.32,"text":"פרק תגזות"},{"start":776.32,"end":778.32,"text":"אנחנו כבר עובדים על הנושא ואני מקווה שתוך כמה ימים יהיה לנו פתרון"},{"start":778.32,"end":783.03,"text":"תודה לכם"},{"start":783.03,"end":785.03,"text":"דבת הצילום הנאמן שלי"},{"start":785.03,"end":789.09,"text":"פיתח מצלמה מיוחדת בה ניתן לראות את דני דין"},{"start":789.09,"end":793.34,"text":"כעת אנו נראה את אותו אירוע בשינוי הדרת"},{"start":793.34,"end":802.36,"text":"אוהבת אותי?"},{"start":802.36,"end":803.8,"text":"כן"},{"start":803.8,"end":805.87,"text":"אתם עני"},{"start":805.87,"end":807.61,"text":"אז מה נתחתן?"},{"start":807.61,"end":809.61,"text":"מי יתחתן איתך ים חוערת?"},{"start":809.61,"end":816.83,"text":"זה כל בסדר חביבי, אקח את הראשיונות, שעה לשלום"},{"start":816.83,"end":817.83,"text":"תודה רבה, הכל טוב"},{"start":817.83,"end":819.83,"text":"כל השוטרים מניאקים"},{"start":819.83,"end":820.99,"text":"מה אמרת?"},{"start":820.99,"end":822.46,"text":"לא עני"},{"start":822.46,"end":823.46,"text":"מה עמדת, תשא מיד מהאוטו"},{"start":823.46,"end":826.46,"text":"לא עני, לא עני, את זה תגיד בו נעדת, קדימה"},{"start":826.46,"end":828.46,"text":"בניידתי אמא שלך, מניק"},{"start":828.46,"end":830.46,"text":"בואי נצא מיד מהאוטו, אמרתי לך"},{"start":830.46,"end":838.14,"text":"שמעון, תזער ממני"},{"start":838.14,"end":840.42,"text":"מה קרה לי אמא שלך?"},{"start":840.42,"end":843.42,"text":"תזער לנקנקתי באוזן בצקלחווין, תזער"},{"start":843.42,"end":859.88,"text":"מה זה היה? מה קרה לי אמא שלך?"},{"start":859.88,"end":861.16,"text":"לא יודע למה?"},{"start":861.16,"end":863.16,"text":"מה זה היה, סקלטן לראש?"},{"start":863.16,"end":864.38,"text":"אתה קיבלת סקלטן לראש?"},{"start":864.38,"end":865.38,"text":"כן"},{"start":865.38,"end":867.38,"text":"אני קיבלתי צקלעוין באוזן, תגיד אתה בפגר?"},{"start":867.38,"end":870.48,"text":"שמעון, אל צטלבט עליי, נשבר לך"},{"start":870.48,"end":871.48,"text":"תגיד אתה עליי, נשבר לך"},{"start":871.48,"end":872.48,"text":"תלך המסמרים אתה"},{"start":872.48,"end":873.44,"text":"תיזהר שמעון"},{"start":873.44,"end":878.29,"text":"בואי נשאיר עליי ואתך אני מערבב אותך"},{"start":878.29,"end":879.29,"text":"תגיד"},{"start":879.29,"end":880.19,"text":"מה אתה מאפגר?"},{"start":880.19,"end":884.13,"text":"תשובו של דני דין כדני שובבני"},{"start":884.13,"end":886.01,"text":"הפך לחדור שלג"},{"start":886.01,"end":890.08,"text":"ונתן הזדמנות ולגיטימציה לכל מיני סופים אחרים"},{"start":890.08,"end":892.14,"text":"לבוא לידי ביטוי"},{"start":892.14,"end":895.14,"text":"כמו למשל, השומע ואינו נשמע"},{"start":895.14,"end":897.14,"text":"סלח לי מה שעה?"},{"start":897.14,"end":898.14,"text":"אחת עשרה וחצי"},{"start":898.14,"end":899.14,"text":"סלח לי מה שעה?"},{"start":899.14,"end":900.14,"text":"אחת עשרה וחצי"},{"start":900.14,"end":901.14,"text":"סלח לי מה שעה?"},{"start":901.14,"end":902.14,"text":"אחת עשרה וחצי"},{"start":902.14,"end":903.14,"text":"סלח לי מה שעה?"},{"start":903.14,"end":904.14,"text":"אחת עשרה וחצי"},{"start":904.14,"end":905.14,"text":"סלוטה אחר"},{"start":905.14,"end":908.11,"text":"הוא הממשה שאינו משיש"},{"start":908.11,"end":914.55,"text":"טוב לך מה שאני עושה?"},{"start":914.55,"end":918.49,"text":"מה אתה עושה?"},{"start":918.49,"end":919.49,"text":"זהו דובי"},{"start":919.49,"end":921.52,"text":"השישי שאינו שושש"},{"start":921.52,"end":924.83,"text":"דובי מרגיש בחושו השישי"},{"start":924.83,"end":926.83,"text":"דברים שאינם קורים"},{"start":926.83,"end":939.88,"text":"אני מבין שהדוני הוא המבין ואינו מובן"},{"start":944.88,"end":958.42,"text":"וכמובן הסוטה הגדול מכולם"},{"start":958.42,"end":961.61,"text":"הצוחק שאינו מצחיק"},{"start":961.61,"end":964.61,"text":"יש לי יש לי יש לי יש לי"},{"start":964.61,"end":965.74,"text":"דני דין"},{"start":965.74,"end":967.09,"text":"לא"},{"start":967.09,"end":968.99,"text":"דני רות"},{"start":968.99,"end":972.0,"text":"והרי הודעה שהגיע זה אתה"},{"start":972.0,"end":977.15,"text":"פרופסור קאטרוס מצא פתרון לבעייתו של דני דין"},{"start":977.15,"end":979.28,"text":"ודני דין הולכים"},{"start":979.28,"end":981.4,"text":"בשולי הדרכים"},{"start":981.4,"end":983.36,"text":"ודובי דובי דוברמן"},{"start":983.36,"end":985.58,"text":"אין כמוך חברמן"},{"start":985.58,"end":987.64,"text":"שלום לכולם ובכן פרופסור קאטרוס"},{"start":987.64,"end":989.64,"text":"כן המציא פתרון לבעיה"},{"start":989.64,"end":991.8,"text":"יש לי כאן גלולית"},{"start":991.8,"end":993.77,"text":"גלולית לבנה קטנה וחמודה"},{"start":993.77,"end":995.77,"text":"מה שהיא פועלת זה בצורה כזאת"},{"start":995.77,"end":997.89,"text":"אתה בולע את הגלולית"},{"start":997.89,"end":999.89,"text":"ואז מבן אדם שאתה למעשה"},{"start":999.89,"end":1001.89,"text":"היית רגיל בן אדם רגיל"},{"start":1001.89,"end":1003.89,"text":"אתה הופך להיות רועה ואינו נראה"},{"start":1003.89,"end":1005.89,"text":"ודני דין הופך להיות מצופר שאיננו מתשטפח"},{"start":1005.89,"end":1007.89,"text":"זאת אומרת אתה יכול לנקום בו"},{"start":1007.89,"end":1009.89,"text":"לתשפח אותו והוא לא יראה מאיפה"},{"start":1009.89,"end":1011.91,"text":"תבוא לו עקיבקי ידה"},{"start":1011.91,"end":1014.8,"text":"בועדה שיבון עוד פעם כפקפת"},{"start":1014.8,"end":1017.15,"text":"נשמע לך שיבון הנה כך"},{"start":1017.15,"end":1019.15,"text":"אה בועדה"},{"start":1019.15,"end":1024.15,"text":"יאללה"},{"start":1024.15,"end":1042.71,"text":"וכך בא לקיצה פרשייה נוספת"},{"start":1042.71,"end":1044.71,"text":"וגם דני דין גיבור ילדותינו"},{"start":1044.71,"end":1046.71,"text":"הפך מדמות חסרת גוף"},{"start":1046.71,"end":1048.71,"text":"למטרת חסר נשמה"},{"start":1048.71,"end":1050.68,"text":"כאן ז'ודי לא צהר"},{"start":1050.68,"end":1052.68,"text":"אוגוריאל אופק שטרייט"},{"start":1052.68,"end":1053.68,"text":"וורשטיין לדר שטקל"},{"start":1053.68,"end":1055.68,"text":"איסקי פניס אי ניללון שריץ"},{"start":1055.68,"end":1057.77,"text":"דליל ארון פדר"},{"start":1057.77,"end":1059.9,"text":"אל עצמי"},{"start":1059.9,"end":1060.86,"text":"בצ'אן"},{"start":1060.86,"end":1066.03,"text":"צוות ההסרטה של ז'וזו ונבליה"},{"start":1066.03,"end":1067.03,"text":"שכנית לתת פרשומת אמיתית"},{"start":1067.03,"end":1069.03,"text":"למוצר האמיתי"},{"start":1069.03,"end":1070.22,"text":"המיקרולף"},{"start":1070.22,"end":1072.22,"text":"המיקרולף הוא כפה שקוראים אותו באנגליזית"},{"start":1072.22,"end":1074.22,"text":"הלף-לף פיינדר"},{"start":1074.22,"end":1078.4,"text":"זהו מכשיר שבעזרת קרן מור אופטית"},{"start":1078.4,"end":1081.43,"text":"הוא מקרין על הבן אדם שפותח את הדלת"},{"start":1081.43,"end":1084.56,"text":"ואז אתה יכול לראות אם הבן אדם הוא לפ-לף"},{"start":1084.56,"end":1086.56,"text":"או אם הוא לא לפ-לף"},{"start":1086.56,"end":1087.56,"text":"כמו שאומרים"},{"start":1087.56,"end":1090.56,"text":"למה להרבות במילים אם אפשר להרבי הבחורות"},{"start":1090.56,"end":1092.56,"text":"צוות הצילום יצא לשטח"},{"start":1092.56,"end":1093.75,"text":"שימו לב"},{"start":1093.75,"end":1095.72,"text":"אמצאה חדשה"},{"start":1095.72,"end":1097.87,"text":"חידושים ואמצאיות"},{"start":1097.87,"end":1100.86,"text":"לפ-לפ-פיינדר אלפיים"},{"start":1100.86,"end":1103.4,"text":"גליי הלפ-לפים"},{"start":1103.4,"end":1105.4,"text":"לפ-לפ-פיינדר יקר שעל הקיר"},{"start":1105.4,"end":1106.43,"text":"גליי"},{"start":1106.43,"end":1108.62,"text":"מי הכי לפ-לף בעיר?"},{"start":1108.62,"end":1111.85,"text":"לא"},{"start":1111.85,"end":1113.37,"text":"זה לפ-לף"},{"start":1113.37,"end":1115.33,"text":"זה לא"},{"start":1115.33,"end":1118.06,"text":"זה לפ-לף"},{"start":1118.06,"end":1120.53,"text":"זה לא"},{"start":1120.53,"end":1123.22,"text":"זה לפ-לף"},{"start":1123.22,"end":1125.66,"text":"זה לא"},{"start":1125.66,"end":1128.29,"text":"זה לפ-לף"},{"start":1128.29,"end":1130.69,"text":"זה לא"},{"start":1130.69,"end":1133.09,"text":"זה לפ-לף"},{"start":1133.09,"end":1135.04,"text":"זה לא"},{"start":1135.04,"end":1138.18,"text":"זה לפ-לף"},{"start":1138.18,"end":1140.15,"text":"זה לא"},{"start":1140.15,"end":1141.61,"text":"זה לפ-לף"},{"start":1141.61,"end":1146.7,"text":"זה לפ-לף"},{"start":1146.7,"end":1148.14,"text":"מה זה?"},{"start":1148.14,"end":1149.14,"text":"זה לפ-לף"},{"start":1149.14,"end":1151.46,"text":"מה זה ג'מי אמר את ג'ה?"},{"start":1151.46,"end":1152.46,"text":"זהה"},{"start":1152.46,"end":1153.81,"text":"אה"},{"start":1153.81,"end":1158.91,"text":"שברת שרי התקיעה להציג את המיקרולף הכי אמין שיש"},{"start":1158.91,"end":1160.91,"text":"אף-לף-לף לא יתחמק ממך"},{"start":1160.91,"end":1183.8,"text":"עשרים שנה"},{"start":1183.8,"end":1185.14,"text":"עשרים שנה"},{"start":1185.14,"end":1187.14,"text":"אני משיט סירות בים"},{"start":1187.14,"end":1191.85,"text":"אף אחד פעם לא קרה לי"},{"start":1191.85,"end":1194.85,"text":"אלפרדו משיט את הסירות"},{"start":1194.85,"end":1201.2,"text":"עשרים שנה אני בונה ערובות"},{"start":1201.2,"end":1204.8,"text":"אף אחד אף פעם לא קרה לי"},{"start":1204.8,"end":1206.8,"text":"אלפרדו בונה ערובות"},{"start":1206.8,"end":1215.01,"text":"עשרים שנה אני מקים קשרים"},{"start":1215.01,"end":1218.0,"text":"אף אחד אף פעם לא קרה לי"},{"start":1218.0,"end":1220.35,"text":"אלפרדו מקים מגשרים"},{"start":1220.35,"end":1228.6,"text":"פעם אחת דפקתי קרצה"},{"start":1228.6,"end":1283.92,"text":"אני שיש לי שלא הוא השיר לבח"},{"start":1283.92,"end":1290.33,"text":"הצלחתי לשיר טוטנטה"},{"start":1290.33,"end":1303.33,"text":"ועצרתי גם בפיפר"},{"start":1303.33,"end":1305.33,"text":"טוטואלי קלודיה סיפר"},{"start":1305.33,"end":1313.09,"text":"אחת רופה!"}]