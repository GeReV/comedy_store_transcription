[{"start":4.0,"end":31.28,"text":"רבותיי, ברוכים הבאים לקומדיסטור!"},{"start":31.28,"end":40.41,"text":"של חברים שעמלו קשה והזיעו למענה"},{"start":40.41,"end":44.26,"text":"החלטנו לקרוא לתוכנית הקומדיסטור"},{"start":44.26,"end":47.26,"text":"או בעברית בסמליה צחוקים"},{"start":47.26,"end":52.46,"text":"חזרנו יחדיו כדי להשתעשע בצוותא"},{"start":52.46,"end":57.18,"text":"ונשוב, נשוב אליכם מיד בתום הפרסמות"},{"start":57.18,"end":63.9,"text":"מפגרים אבל אוטים!"},{"start":63.9,"end":66.25,"text":"יאללה בוא נראה את הפרסמות"},{"start":66.25,"end":69.66,"text":"נלך לשם"},{"start":69.66,"end":124.49,"text":"אדוני, איך אני מגיע מפה לכל בו שלום?"},{"start":124.49,"end":126.61,"text":"כל בו שלום?"},{"start":126.61,"end":128.96,"text":"אתה עם רכב?"},{"start":128.96,"end":131.08,"text":"לא אני ברגל, למה זה רחוק?"},{"start":131.08,"end":135.08,"text":"תשמע אתה צריך בפוסטו שנייה"},{"start":135.08,"end":137.08,"text":"שתהוק"},{"start":137.08,"end":143.42,"text":"מה שקורה, אתה הולך לחוב שלישי, פונה אמינה, שני צמתים למטה, פונה שמאלה זה המקום"},{"start":143.42,"end":145.42,"text":"אוקיי, תודה רבה"},{"start":145.42,"end":146.42,"text":"תודה לך"},{"start":146.42,"end":147.42,"text":"תודה"},{"start":147.42,"end":158.65,"text":"שירות מודיעין שלום"},{"start":158.65,"end":161.03,"text":"אנו מטפלים בפניות קודמות"},{"start":161.03,"end":162.5,"text":"נעלה המתין"},{"start":162.5,"end":163.53,"text":"תודה"},{"start":163.53,"end":164.53,"text":"בזק"},{"start":164.53,"end":166.13,"text":"תשומת לבכם"},{"start":166.13,"end":169.25,"text":"אם ברצונכם לבקש יותר ממספר 1"},{"start":169.25,"end":171.44,"text":"אנא, ציינו זאת בתחילת השיחה"},{"start":171.44,"end":172.76,"text":"בזק"},{"start":172.76,"end":173.73,"text":"לרשותכם"},{"start":173.73,"end":176.98,"text":"שירות מודיעין שלום"},{"start":176.98,"end":178.36,"text":"שלום"},{"start":178.36,"end":180.61,"text":"אנו מטפלים בפניות קודמות"},{"start":180.61,"end":181.61,"text":"נהלי המפין"},{"start":181.61,"end":182.57,"text":"תודה"},{"start":182.57,"end":