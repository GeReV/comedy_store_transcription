[{"start":72.51,"end":81.48,"text":"טוב לכולם. כאן אנחנו כבידי בוקר בשעת כושר. זה אני אחיאל פסק כאן על המסך הקטן, והנה החברים שלי כאן מאחורה."},{"start":81.48,"end":92.14,"text":"יפה חברים. ובכן, אנחנו נתחיל כמובן כבידי בוקר בשחרור קל. לאחר ששתינו כוסית ולאה ויטמית C, הריאות התנפקו."},{"start":92.14,"end":95.14,"text":"בואו ונתחיל בחימום שלנו."},{"start":96.14,"end":110.41,"text":"כמובן פיסוק ושחרור קטן של השרירים. שחרור קטן וכיפופים קלים. ימין, שמאל. ימין, שמאל. מוסיפים. יד, יד, יד, יד."},{"start":110.41,"end":120.76,"text":"וכמובן שחרורים, שחרורים. ואנחנו נעשה כיפופים קצנים ברגליים לכיוום האגן וכל תושבת האשך. קדימה. לאט לאט. יפה."},{"start":120.76,"end":128.29,"text":"אוקיי, אנחנו מותחלים, בואו נתחיל לעבור למכול אירובי, אני מבצע, ואתם חוזרים אחריי."},{"start":128.29,"end":130.37,"text":"ברור? ברור!"},{"start":130.37,"end":132.41,"text":"יופי! יופי!"},{"start":132.41,"end":134.37,"text":"אוקיי! אוקיי!"},{"start":134.37,"end":142.02,"text":"אחת, שתיים! אחת, שתיים! אחת, שתיים! אחת, שתיים!"},{"start":142.02,"end":144.18,"text":"הפוזי, פוזי, פוזי, פוזי!"},{"start":144.18,"end":145.9,"text":"הפוזי, פוזי, פוזי, פוזי!"},{"start":145.9,"end":147.74,"text":"הפוזי, פוזי, טוסי, טוסי!"},{"start":147.74,"end":149.3,"text":"פוזי, פוזי, טוסי, טוסי!"},{"start":149.3,"end":150.9,"text":"שטוזה, שטוזה, הרטה, הר!"},{"start":151.06,"end":152.58,"text":"שטוזה, שטוזה, הרטה!"},{"start":152.58,"end":154.38,"text":"ציבור, ביברות!"},{"start":154.38,"end":155.98,"text":"ציבור, ביברות!"},{"start":155.98,"end":159.46,"text":"הבר, הבר, הבר, הבר!"},{"start":159.46,"end":161.42,"text":"אה, אה, אה, אשריר!"},{"start":161.42,"end":163.3,"text":"אה, אה, אשריר!"},{"start":163.3,"end":165.1,"text":"נתפס לי, אשריר!"},{"start":165.1,"end":167.14,"text":"נתפס לי, אשריר!"},{"start":167.14,"end":169.1,"text":"חבר'ה, נרצילי!"},{"start":169.1,"end":170.78,"text":"חבר'ה, נרצילי!"},{"start":170.78,"end":172.42,"text":"וואי, אני כרוע!"},{"start":172.42,"end":173.82,"text":"וואי, אני כרוע!"},{"start":173.82,"end":175.78,"text":"יא, בין אותו רגע נרצילי!"},{"start":175.78,"end":177.18,"text":"אתה רגע נרצילי!"},{"start":177.18,"end":179.1,"text":"אה, היא חובש!"},{"start":179.1,"end":180.98,"text":"אה, היא חובש!"},{"start":181.02,"end":185.48,"text":"אה, אה, אה!"},{"start":185.48,"end":187.48,"text":"אה, אה!"},{"start":187.48,"end":188.54,"text":"אה, אה!"},{"start":188.54,"end":190.3,"text":"אה, אה!"},{"start":190.3,"end":197.07,"text":"אה, אה, אה!"},{"start":197.07,"end":201.39,"text":"אה, אה, אה!"},{"start":201.39,"end":205.39,"text":"ערב צח ערב זח ושוב אנחנו חזרנו לחלסטרה של זוזו."},{"start":205.39,"end":207.38,"text":"והפעם חזרנו בגדול."},{"start":207.38,"end":211.73,"text":"עם אמא שלי, פרסומת שכבר הספקנו לראות שבעת אלפים פעם,"},{"start":211.73,"end":213.76,"text":"והביאה לתחלסטרה בהפוכה."},{"start":213.76,"end":216.34,"text":"הפרסומת שלה פאפסי."},{"start":216.34,"end":218.43,"text":"מה זה השטיפת מוח המפגרת הזאת עם אמא שלי?"},{"start":218.43,"end":220.41,"text":"זה לא יומן."},{"start":220.41,"end":222.57,"text":"רואים בן אדם על חוף הים?"},{"start":222.57,"end":224.57,"text":"במקרה הוא גם לפלפ עם קוקיה"},{"start":224.57,"end":226.57,"text":"וזה לא מפתיע אותנו."},{"start":226.57,"end":228.57,"text":"והוא יושב לא על כסדוח"},{"start":228.57,"end":230.57,"text":"אלא על קורסה"},{"start":230.57,"end":232.64,"text":"באמצע הים."},{"start":232.64,"end":234.66,"text":"מאיפה הגיע קורסה? מה קרה קסטל?"},{"start":234.66,"end":236.66,"text":"בא לטיול? מאיפה אחרת זה?"},{"start":236.66,"end":238.66,"text":"יושב על הקורסה?"},{"start":238.66,"end":240.66,"text":"ולא עם בגד ים, יעני שיראו לו את הפריזורה, את הסוודר, את..."},{"start":240.66,"end":242.66,"text":"לא!"},{"start":242.66,"end":244.66,"text":"הוא יושב עם חליפה!"},{"start":244.66,"end":246.66,"text":"הוא ברח מהבר מצווה, באמא שלי, מה זה אחרת זה?"},{"start":246.66,"end":248.66,"text":"לא מספיק שהוא יושב"},{"start":248.66,"end":250.66,"text":"הוא מתחיל לעשות לנו חישובים מפגרים"},{"start":250.66,"end":253.88,"text":"ורבותיי, זו זו חישה ומצא"},{"start":253.88,"end":255.88,"text":"שהחישובים שלא מוטעים"},{"start":255.88,"end":257.91,"text":"אומר לנו הלף-לף"},{"start":257.91,"end":261.87,"text":"אני מבלה שתיים נקודה שלוש שנים בהרצאות"},{"start":261.87,"end":265.47,"text":"מי מבלה שתיים נקודה שלוש שנים בהרצאות?"},{"start":265.47,"end":266.47,"text":"מה זה אחרת זה?"},{"start":266.47,"end":268.47,"text":"אני הייתי שלוש תקות בהרצאה וזה השפיק לי"},{"start":268.47,"end":271.47,"text":"הייתי אפרופו, הייתי בהרצאה של חבר שלי, זיגמון"},{"start":271.47,"end":273.47,"text":"פרויד, קרב אותו"},{"start":273.47,"end":277.47,"text":"זה, אני הייתי הולך אליו כדי לדעת מה פשר החלומות"},{"start":277.47,"end":280.46,"text":"באתי אליו אמרתי לו אחי, מה פשר החלום שעלמתי בלילה?"},{"start":280.46,"end":282.46,"text":"אמר לי זיגמון, תראה"},{"start":282.46,"end":284.46,"text":"זה מוכיח את התיאוריה שלי"},{"start":284.46,"end":286.56,"text":"של תזביך אדיפוס"},{"start":286.56,"end":289.8,"text":"שהילד הוא רוצה לשכב עם אמא שלו"},{"start":289.8,"end":291.77,"text":"ולרצוח את אבא שלו"},{"start":291.77,"end":293.83,"text":"במקום הבאתי לו תזביך כפה"},{"start":293.83,"end":295.83,"text":"ועם אמא שלי שתי רעשיות וכפה"},{"start":295.83,"end":298.83,"text":"מאז אמא שלו רודב תחרה ולא עוזבת אותו"},{"start":298.83,"end":300.83,"text":"אחר כך הוא מביא עוד יותר גרוע"},{"start":300.83,"end":306.29,"text":"הוא עושה אני מבזבז 4.2 שנים באכילה"},{"start":306.29,"end":310.53,"text":"ארבע נקודה שתיים אני 19.9 שנים באכילה אני מבזבז"},{"start":310.53,"end":312.53,"text":"ולא בקוטג"},{"start":312.53,"end":314.67,"text":"אלא בבשר"},{"start":314.67,"end":316.71,"text":"שיפודים על האש בבמן גל"},{"start":316.71,"end":318.71,"text":"בו שיש בית שמחה גדולה זה אוכל"},{"start":318.71,"end":320.71,"text":"והוא מסיים על הפלפון"},{"start":320.71,"end":324.71,"text":"בזה שהוא מבזבז 3.2 שנים בשינה"},{"start":324.71,"end":327.31,"text":"ומה קורה לפני השינה על הפלף קטן"},{"start":327.31,"end":329.79,"text":"מה אם איזה חווק שווק בעסים טובים?"},{"start":329.79,"end":331.97,"text":"על זה אתה לא מבזבז את הזמן?"},{"start":331.97,"end":333.97,"text":"בטח שלא"},{"start":333.97,"end":335.97,"text":"למה אתה לפלפון קטון"},{"start":335.97,"end":337.89,"text":"מושר עסקל"},{"start":337.89,"end":340.31,"text":"הדביל אומר בסוף"},{"start":340.31,"end":344.46,"text":"שנשאר לו עשרה חודשים להתפנפן עם פפסי"},{"start":344.46,"end":346.46,"text":"אבל אם תקחו בחשבון רבוטל"},{"start":346.46,"end":348.46,"text":"שמתו העשרה חודשים האלה"},{"start":348.46,"end":352.46,"text":"700 פעם בזמזנו זמן לראות הפרצובת המפגרת הזאת"},{"start":352.46,"end":354.46,"text":"ישאר לנו שתיים אחת שדכות לחיות"},{"start":354.46,"end":356.46,"text":"אז תתחילו לקחת זמן, נגמר לנו"},{"start":356.46,"end":358.46,"text":"מושר עסקל"},{"start":358.46,"end":360.46,"text":"קחו את הזמן, תאכלו מעשים טובים"},{"start":360.46,"end":362.46,"text":"ותעזבו את זה"},{"start":362.46,"end":364.46,"text":"תחשבו את זה"},{"start":364.46,"end":396.9,"text":"מכה חדשה פוקדת את תל אביב"},{"start":396.9,"end":398.9,"text":"המזלמה המשוטטת של ג'ודי"},{"start":398.9,"end":401.8,"text":"ארץ טוב"},{"start":401.8,"end":404.02,"text":"כאן ג'ודי לא צהרו נובכר פינסם"},{"start":404.02,"end":407.02,"text":"המבויץ תומל יעזר בן יהודה סוכנית"},{"start":407.02,"end":409.2,"text":"תוקר אף שלום קור"},{"start":409.2,"end":411.4,"text":"מכה חדשה נוחתת על תל אביב"},{"start":411.4,"end":413.36,"text":"חיידק המילימפוס"},{"start":413.36,"end":415.58,"text":"חיידק המילימפוס"},{"start":415.58,"end":417.58,"text":"חיידק שעושה למילימפוס"},{"start":417.58,"end":420.87,"text":"הסימפום הברור ביותר של המחלה"},{"start":420.87,"end":423.87,"text":"הוא שלעיתים מילה אמורה להיאמר"},{"start":423.87,"end":425.87,"text":"מתחלפת במילה אחרת"},{"start":425.87,"end":428.16,"text":"לקחנו את המצלמה המשוטטת"},{"start":428.16,"end":432.16,"text":"ויצאנו לבדוק החצה הקטה"},{"start":432.16,"end":434.64,"text":"כנתיב הבן יהודה"},{"start":434.64,"end":436.77,"text":"נתיבי הילון נתיבות"},{"start":436.77,"end":442.26,"text":"תגידי אתה משוגע אתה לא נורמלי"},{"start":442.26,"end":444.57,"text":"איך אתה נוהג?"},{"start":444.57,"end":451.94,"text":"מי המטומטם שנתן לך פינצטה?"},{"start":451.94,"end":454.57,"text":"להרים ידיים! זה שובח!"},{"start":454.57,"end":458.57,"text":"בואלה חבר'ה זה שובח עמיתי לא צחוק"},{"start":458.57,"end":462.57,"text":"חבר'ה יש לי ביד כולם אתם לא רואים"},{"start":462.57,"end":464.57,"text":"חבר'ה לא רואים"},{"start":464.57,"end":467.3,"text":"בואלה, נו!"},{"start":467.3,"end":469.3,"text":"עסיקו לצחוק אני אדגדג אתכם"},{"start":469.3,"end":476.29,"text":"רבותה, יש פה רמזור"},{"start":476.29,"end":478.29,"text":"רבותה, יש פה רמזור"},{"start":478.29,"end":480.29,"text":"מה צורך? אני בצירה"},{"start":480.29,"end":482.29,"text":"אוקיי, אני חושב שהוא חטף עפונת לב"},{"start":482.29,"end":485.46,"text":"בואי בואי"},{"start":485.46,"end":488.27,"text":"אני אשר לו את ההשפעה"},{"start":488.27,"end":490.63,"text":"איך היה לך מוטה?"},{"start":490.63,"end":494.87,"text":"נהדר, הייתה לי אינפלציה נהדרת"},{"start":494.87,"end":496.87,"text":"אך מה שהחל כפרפרה משעשעת"},{"start":496.87,"end":498.87,"text":"הפך במהרה למטרת"},{"start":498.87,"end":500.87,"text":"שאין גדול ממנו"},{"start":500.87,"end":503.36,"text":"ספר לנו מה קרה"},{"start":503.36,"end":505.57,"text":"אני התקשרתי למחבי האש"},{"start":505.57,"end":507.57,"text":"אמרתי להם"},{"start":507.57,"end":509.57,"text":"ארתיק ארתיק ארתיק"},{"start":509.57,"end":511.63,"text":"אצילו ארתיק"},{"start":511.63,"end":514.14,"text":"ולא הגיע אף אחד"},{"start":514.14,"end":516.14,"text":"עכשיו אתה יכול לראות בעצמך"},{"start":516.14,"end":518.13,"text":"כל הבית שלי חמוץ לגמרי"},{"start":518.13,"end":521.89,"text":"אני לא יודע מה לעשות"},{"start":521.89,"end":524.36,"text":"אני קרפיון לחלוטין"},{"start":524.36,"end":526.39,"text":"אני צעקתי להם ארתיק ארתיק"},{"start":526.39,"end":528.93,"text":"צעקתי להם"},{"start":528.93,"end":531.37,"text":"קרפיון לגמרי"},{"start":531.37,"end":533.88,"text":"אני מצטער"},{"start":533.88,"end":536.39,"text":"אני לא יודע למה לא שולחן לי"},{"start":536.39,"end":541.26,"text":"לא נורא"},{"start":541.26,"end":543.26,"text":"ערב מת ותחלמו על זה"},{"start":543.26,"end":546.19,"text":"מה זה החיידק המילימפוס הזה?"},{"start":546.19,"end":548.15,"text":"באמא שלי מבין לי את החלם פראם"},{"start":548.15,"end":549.66,"text":"מה?"},{"start":549.66,"end":550.66,"text":"אצילו לא מבין מה קורה"},{"start":550.66,"end":551.66,"text":"הולך לי המיליבט"},{"start":551.66,"end":553.0,"text":"המיה"},{"start":553.0,"end":555.34,"text":"טוב ניקח שחלה"},{"start":555.34,"end":557.85,"text":"חיידק המילימפוס"},{"start":557.85,"end":559.85,"text":"לא פסח אף על שירותי החירום"},{"start":559.85,"end":561.9,"text":"וחוחות הביטחון"},{"start":561.9,"end":565.01,"text":"והפך גם אותם לחוכבי תלולה"},{"start":565.01,"end":569.96,"text":"אוקיי מחלקה שתיים למצב קריאה הרד"},{"start":569.96,"end":571.96,"text":"אל המטרות שלפניכם שלושה כדורים למקבץ"},{"start":571.96,"end":573.96,"text":"בזמנכם החופשי"},{"start":573.96,"end":574.95,"text":"צלמנדרה"},{"start":574.95,"end":577.42,"text":"בזמנכם החופשי"},{"start":577.42,"end":578.54,"text":"טוסטר"},{"start":578.54,"end":582.78,"text":"בזמנכם החופשי"},{"start":582.78,"end":584.99,"text":"ברוש"},{"start":584.99,"end":588.04,"text":"אוקיי"},{"start":588.04,"end":589.06,"text":"תחרו מזה"},{"start":589.06,"end":590.06,"text":"תצפו בו את כל היגוזים"},{"start":590.06,"end":591.06,"text":"ניפגש בו עוד שעה בלונה פארק"},{"start":591.06,"end":592.06,"text":"קדימה"},{"start":592.06,"end":593.66,"text":"הלו?"},{"start":593.66,"end":594.66,"text":"משטרה שלוש"},{"start":594.66,"end":595.66,"text":"שלום משטרה"},{"start":595.66,"end":596.66,"text":"גנבו לי את הקומזיץ"},{"start":596.66,"end":597.66,"text":"תן לנו את הביוב שלו"},{"start":597.66,"end":599.85,"text":"אה זה קומזיץ 1600 חדשה"},{"start":599.85,"end":600.85,"text":"מה אני אעשה?"},{"start":600.85,"end":601.85,"text":"איפה אתה רוקד עכשיו?"},{"start":601.85,"end":603.94,"text":"אה אני בערך"},{"start":603.94,"end":604.94,"text":"בקיץ"},{"start":604.94,"end":606.94,"text":"טוב אז קודם כל אל תיגע בטוטים"},{"start":606.94,"end":610.0,"text":"תשמור על חום הברזיה תשאף חסידות"},{"start":610.0,"end":612.48,"text":"אנחנו מנצנצים אליך הרכבת"},{"start":612.48,"end":613.45,"text":"טוב תודה"},{"start":613.45,"end":616.72,"text":"דבורה"},{"start":616.72,"end":618.72,"text":"יודה קלטת, המרגנו של שלמה ארצי"},{"start":618.72,"end":619.72,"text":"אני מבין ששלמה מרוצה"},{"start":619.72,"end":621.72,"text":"שלמה מאושר רבותיי שלמה מאוד מאוד מרוצה"},{"start":621.72,"end":622.72,"text":"סוף סוף מבינים אותו"},{"start":622.72,"end":626.68,"text":"אחרי שנים שטענו שלא מבינים את המילים של שלמה"},{"start":626.68,"end":628.68,"text":"סוף סוף התגלתה המחלה רבותיי"},{"start":628.68,"end":629.68,"text":"שלמה לא התכוון לכתוב"},{"start":629.68,"end":631.68,"text":"\"גבר הולך לאיבוד דרך מרפסת\""},{"start":631.68,"end":632.65,"text":"שלמה התכוון לכתוב"},{"start":632.65,"end":635.65,"text":"\"גבר הולך לאיבוד ביער אבות ללא מצפן וללא פנס\""},{"start":635.65,"end":639.65,"text":"אבל המילים קפצו, זאת הייתה מחלה רבותיי"},{"start":639.65,"end":641.65,"text":"הוא לא התכוון לומר חתולים מחשבים קיצם לאחור"},{"start":641.65,"end":643.65,"text":"זה הרי השעון המעורר מפגר בחמש דקות"},{"start":643.65,"end":645.65,"text":"אבל המילים קפצו החוצה"},{"start":645.65,"end":646.65,"text":"לפתע זה הפך שיר על חתולים"},{"start":646.65,"end":648.65,"text":"אתה מבין המצב והמאוד קשה"},{"start":648.65,"end":650.65,"text":"שנים הוא נאבק במחלה וסוף סוף יצא החוצה"},{"start":650.65,"end":652.65,"text":"ולאור זאת אני שמח להכריז"},{"start":652.65,"end":653.65,"text":"כל הציבור בישראל"},{"start":653.65,"end":655.65,"text":"אנחנו יוצאים באוסף החדש של שלמה"},{"start":655.65,"end":656.65,"text":"האוסף המשושה"},{"start":656.65,"end":659.65,"text":"האוסף הזה מכיל שירים שאף אחד לא הבין עד היום"},{"start":659.65,"end":661.65,"text":"וכנראה שגם לא יבין להבא"},{"start":661.65,"end":663.65,"text":"אם כן יצא המילון החדש המתורגם של שלמה ארציני"},{"start":663.65,"end":665.65,"text":"לכן, קנו את האוסף המשושה"},{"start":665.65,"end":667.65,"text":"יופי, תודה לכם, אני מאוד שמח"},{"start":667.65,"end":669.65,"text":"כיצד תסתיים פרשי האומלה"},{"start":669.65,"end":671.65,"text":"זאת פתרונות לרמזורים"},{"start":671.65,"end":674.0,"text":"ואולי חתולים מתים בסתר"},{"start":674.0,"end":676.0,"text":"והפרחים בעליית הזז"},{"start":676.0,"end":678.38,"text":"כאן ג'ודי לא מאמון"},{"start":678.38,"end":680.38,"text":"עובשם עמקה סוטו גורדון רשיה"},{"start":680.38,"end":682.38,"text":"בגדה וזחתיקה"},{"start":682.38,"end":684.38,"text":"למען שפת קרשת ברי ברת"},{"start":684.38,"end":686.82,"text":"וטברת הברינה טברה"},{"start":686.82,"end":688.88,"text":"אבן שושן, אקדמיה העברית"},{"start":688.88,"end":694.91,"text":"וושינגטון"},{"start":694.91,"end":699.9,"text":"היי טובים! היי טובים! רופא!"},{"start":699.9,"end":703.33,"text":"יש לי, יש לי, יש לי, יש לי, יש לי!"},{"start":703.33,"end":706.55,"text":"תוכניות באנגלית: look and listen."},{"start":706.55,"end":708.63,"text":"רופא!"},{"start":708.63,"end":711.33,"text":"רגע, רגע, רגע, רגע, זה עוד לא זה."},{"start":711.33,"end":714.03,"text":"\"Do you know where are we?\""},{"start":714.03,"end":715.99,"text":"\"Here we are!\""},{"start":715.99,"end":717.72,"text":"\"Here we are!\""},{"start":717.72,"end":721.18,"text":"\"Here we are in the center of town, look!\""},{"start":721.18,"end":724.25,"text":"היי, היי, היי, היי, היי!"},{"start":724.25,"end":724.75,"text":"רופא."},{"start":724.75,"end":726.65,"text":"\"What are we?\""},{"start":726.65,"end":728.93,"text":"\"We are neighbors!\""},{"start":728.93,"end":730.43,"text":"רופא!"},{"start":730.43,"end":731.43,"text":"רופא!"},{"start":731.43,"end":736.2,"text":"רופא!"},{"start":736.2,"end":746.53,"text":"\"קאב!\""},{"start":746.53,"end":748.68,"text":"\"Who am I?\""},{"start":748.68,"end":750.68,"text":"\"I'm Suzy Surprise!\""},{"start":750.68,"end":751.68,"text":"רופא!"},{"start":751.68,"end":752.68,"text":"רופא!"},{"start":752.68,"end":758.8,"text":"רופא!"},{"start":758.8,"end":759.83,"text":"\"Surprise!\""},{"start":759.83,"end":761.83,"text":"\"It's Suzy Surprise!\""},{"start":761.83,"end":762.83,"text":"רופא!"},{"start":762.83,"end":770.07,"text":"יש לי, יש לי, יש לי, יש לי, יש לי, יש לי!"},{"start":770.07,"end":773.2,"text":"\"Do you know where is Gabby and Debbie?\""},{"start":773.2,"end":774.39,"text":"\"לא!"},{"start":774.39,"end":775.39,"text":"\"אי אפשר לדעת!"},{"start":775.39,"end":777.39,"text":"\"הם כל הזמן במקום אחר!\""},{"start":777.39,"end":778.39,"text":"\"פא!"},{"start":778.39,"end":781.9,"text":"\"יוא!"},{"start":781.9,"end":782.9,"text":"\"זה בגלל המגיק סטיק!"},{"start":782.9,"end":786.08,"text":"\"כך!"},{"start":786.08,"end":787.64,"text":"\"נעלמים!"},{"start":787.64,"end":790.21,"text":"תודה רבה."},{"start":830.71,"end":833.22,"text":"תודה רבה."},{"start":864.09,"end":867.09,"text":"עשרים שנה אסרו לה, לא לא, אסרו לי להסתפר עשרים שנה בגלל התפקיד הזה."},{"start":867.09,"end":869.09,"text":"הקטע הוא שאני דיברתי עם מינטר קשטן. תבין את הקטע?"},{"start":869.09,"end":870.09,"text":"משלמים להם כפול."},{"start":870.09,"end":871.09,"text":"וואלה?"},{"start":871.09,"end":872.28,"text":"כן."},{"start":872.28,"end":875.28,"text":"רמאס לי מכל העניין פה. אנחנו חייבים למצוא איזה מישהו שיחליף אותנו עם המקל הזה."},{"start":875.28,"end":877.48,"text":"מישהו שייכנס לתפקיד במקומנו."},{"start":877.48,"end":879.68,"text":"יו?"},{"start":879.68,"end":880.68,"text":"יש לי, יש לי, יש לי."},{"start":880.68,"end":882.94,"text":"Excuse me, sir!"},{"start":882.94,"end":883.94,"text":"אדוני?"},{"start":883.94,"end":884.94,"text":"אתה רוצה אולי magic stick?"},{"start":884.94,"end":886.03,"text":"מה זה?"},{"start":886.03,"end":888.03,"text":"אתה יכול להגיע איתו לכל מיני מקומות בעולם."},{"start":888.03,"end":893.0,"text":"זה מין סטקה כזאת שאתה מגיע איתו למקומות שונים לגמרי, אתה יכול להגיע לאן אתה רוצה."},{"start":893.0,"end":894.0,"text":"מה, אני באמת יכול?"},{"start":894.0,"end":895.0,"text":"כן, רק..."},{"start":895.0,"end":897.22,"text":"BE CAREFUL!"},{"start":897.22,"end":898.22,"text":"יש לי, יש לי, יש לי."},{"start":898.22,"end":900.25,"text":"BE CARE-SHO-EAT!"},{"start":900.25,"end":901.41,"text":"לא!"},{"start":901.41,"end":902.4,"text":"BE CAREFUL!"},{"start":902.4,"end":906.19,"text":"כך, כך, נראה לי זה הבן אדם המצאים."},{"start":906.19,"end":907.67,"text":"כך."},{"start":907.67,"end":908.82,"text":"תודה!"},{"start":908.82,"end":939.77,"text":"יש לי!"},{"start":939.77,"end":945.38,"text":"אנגוך!"},{"start":945.38,"end":948.49,"text":"פרוניגן."},{"start":948.49,"end":949.9,"text":"יש לי, יש לי, יש לי."},{"start":949.9,"end":952.06,"text":"אתה מצייר קרניות!"},{"start":952.06,"end":955.09,"text":"לא, אתה מצייר חמניות!"},{"start":955.09,"end":956.5,"text":"פרוניגן."},{"start":956.5,"end":958.92,"text":"יש לי, יש לי, יש לי."},{"start":958.92,"end":961.1,"text":"אתה ציירת איפה הילד?"},{"start":961.1,"end":962.26,"text":"לא!"},{"start":962.26,"end":964.26,"text":"אתה צייר את הפורטרט!"},{"start":964.26,"end":965.26,"text":"חרוניגן."},{"start":965.26,"end":967.58,"text":"יש לי, אתה, אתה צייר..."},{"start":967.58,"end":968.83,"text":"מאספיוניסט?"},{"start":968.83,"end":971.98,"text":"לא, אתה צייר אקספרסיוניסט!"},{"start":971.98,"end":973.39,"text":"חרוניגן!"},{"start":973.39,"end":974.39,"text":"חרווניגן!"},{"start":974.39,"end":975.39,"text":"חרווניגן!"},{"start":975.39,"end":976.39,"text":"יש לי, יש לי!"},{"start":976.39,"end":977.39,"text":"אה!"},{"start":977.39,"end":978.39,"text":"אה!"},{"start":978.39,"end":979.38,"text":"אה!"},{"start":979.38,"end":980.53,"text":"אה!"},{"start":980.53,"end":983.04,"text":"אה!"},{"start":983.04,"end":984.22,"text":"אה!"},{"start":984.22,"end":997.1,"text":"ערב טוב, והרי תקציר החדשות,"},{"start":997.1,"end":999.47,"text":"כאן במבזק של ז'ק."},{"start":999.47,"end":1006.59,"text":"הספינה הטורקית טורקו בוטו זל, זל, שהייתה עמוסה מתען יויו, טבעה מול חופי יוון ארבעים פעם."},{"start":1006.59,"end":1011.64,"text":"והרי ידיעה משמחת, בין הנספים לא היו יהודים."},{"start":1011.64,"end":1017.64,"text":"שר החוץ האמריקני, קריסטופר וורן, יצא למסע דילוגים סודי במזרח התיכון."},{"start":1017.64,"end":1024.02,"text":"לשר שלום, והרי לחדשות מעולם הפופ."},{"start":1024.02,"end":1030.36,"text":"אז המער האמריקני, מייקל ג'קסון, עבר ניתוח פלסטי נוסף, וכרגע הוא נראה כך:"},{"start":1030.36,"end":1043.86,"text":"לביתו של אלוויס פרסלי: שלום. ואתה לנושא אחר לגמרי, נמצאתי כאן באולפן האומן הישראלי יעקב אדם, ערב טוב יעקב."},{"start":1043.86,"end":1051.08,"text":"כן יעקב, ספר לנו על היצירה החדשה שלך."},{"start":1051.08,"end":1057.53,"text":"ובכן אפשר להגיד שזה מין שילוב אקסטראורדינר, של מספר דברים יש לנו פה קודם כל אמנות קינטית, לדבר ראשון."},{"start":1057.53,"end":1071.71,"text":"דבר שני יש לנו את אפקט האש וכל זה ביחד יוצר לנו מן פוטומונטאז', משהו גדול מאוד של תנועה, אש ובשר."},{"start":1071.71,"end":1078.72,"text":"כן, כרגע הצופים יכולים לראות את היצירה שלך, זה קצת מזכיר שווארמה."},{"start":1078.72,"end":1081.29,"text":"זה שווארמה."},{"start":1081.29,"end":1089.92,"text":"ערב טוב, זה הכל הפעם במצזק של זה."},{"start":1089.92,"end":1104.42,"text":"זה הכל הפעם במצזק של ז'ק, המשך צפייה הנעימה."},{"start":1104.42,"end":1115.29,"text":"חוריים טובים לכולם, חורים הבאים לתוכנית שעת נפש, אני משה הגות, ואלה החברים שלי, תכירו אותם."},{"start":1115.29,"end":1116.29,"text":"היי!"},{"start":1116.29,"end":1124.79,"text":"ונתחיל להישאר בחימום, אחרון ודי."},{"start":1124.79,"end":1129.32,"text":"נעבור אל החלק הקשה, אני אומר, אתם חוזרים אחריי."},{"start":1129.32,"end":1130.92,"text":"אני חושב."},{"start":1130.92,"end":1132.01,"text":"אני חושב."},{"start":1132.01,"end":1134.1,"text":"אני קיים."},{"start":1134.1,"end":1135.1,"text":"אני קיים."},{"start":1135.1,"end":1137.38,"text":"ועכשיו כולם ביחד לחשוב עמוק."},{"start":1137.38,"end":1145.65,"text":"אחרון ודי."},{"start":1145.65,"end":1147.93,"text":"זה הכל להפעם."},{"start":1147.93,"end":1149.93,"text":"תשתדלו יותר היום לא לחשוב."},{"start":1149.93,"end":1151.11,"text":"נוחו."},{"start":1151.11,"end":1155.36,"text":"ולהתראות בשבוע הבא בשעת נפש."},{"start":1155.36,"end":1157.51,"text":"ביי."},{"start":1157.51,"end":1166.9,"text":"ארץ החירושה."},{"start":1166.9,"end":1168.96,"text":"ושוב אנחנו בחלסטר של ג'וזו."},{"start":1168.96,"end":1172.96,"text":"והפעם רציתי לספר לכם על אוכל של תינוקים."},{"start":1172.96,"end":1175.63,"text":"עם אימא שלי."},{"start":1175.63,"end":1176.63,"text":"ולשתינוקים יוצאים היום לפלפים."},{"start":1176.63,"end":1178.69,"text":"איזה דברים נותנים להם לאכול?"},{"start":1178.69,"end":1179.69,"text":"תשתכלו בפרסומות."},{"start":1179.69,"end":1180.69,"text":"זה לא יעומן."},{"start":1180.69,"end":1183.69,"text":"יש פרסומות למטרנה ולרמדיה"},{"start":1183.69,"end":1185.69,"text":"ולכל החרטה הזה ולגראבר."},{"start":1185.69,"end":1187.69,"text":"כל האוכלים האלה מה זה?"},{"start":1187.69,"end":1188.69,"text":"זה אוכל של לפלפים."},{"start":1188.69,"end":1189.69,"text":"באימא שלי."},{"start":1189.69,"end":1191.69,"text":"גראבר זה רסק של בננה."},{"start":1191.69,"end":1194.69,"text":"שיביאו לו רסק של כבס, החושק שוקה."},{"start":1194.69,"end":1196.69,"text":"זה אוכל של ילד."},{"start":1196.69,"end":1198.69,"text":"לא סתמה בפגפן שר, אנחנו דור מזוין."},{"start":1198.69,"end":1201.66,"text":"למה ילדים גדלים לפלפים?"},{"start":1201.66,"end":1205.66,"text":"ושהם גדלים עוד יותר, בכלל איזה דברים מפגרים מביאים לילדים?"},{"start":1205.66,"end":1211.82,"text":"מביאים להם במבה ושוגי וקוקי ולוקו ופוף פוף וחרטה."},{"start":1211.82,"end":1216.16,"text":"הילדים יוצאים לפלפים נקודה, צריך לעשות משהו בעניין."},{"start":1216.16,"end":1219.22,"text":"לכן רבותיי, זו זו נכנס למערכה."},{"start":1219.22,"end":1222.32,"text":"שימו לב, פרסומת למאכל ילדים אהוב."},{"start":1222.32,"end":1228.35,"text":"הילדים גדלים, מפותחים, כל גבר ניהלו סבדר על החזה, ואימא שלי עם כבוד."},{"start":1228.35,"end":1234.41,"text":"אמא, אין כמו אמא."},{"start":1234.41,"end":1236.63,"text":"אימא, אבא."},{"start":1236.63,"end":1276.55,"text":"לא היה כמו, לא יהיה כמו, ואין כמו אמא."},{"start":1276.55,"end":1281.55,"text":"אמא של בוסם, ותחשבו על זה."}]