[{"start":3.84,"end":10.34,"text":"רואים ספור, חמישי בשבע בערך, השידורים החזרים חמישי בתשע, ושישי בשבע וחץ בערוץ המקומי."},{"start":78.77,"end":102.83,"text":"רואים שהם קשים, אני יודע, אני מקווה שיהיה בסדר."},{"start":102.83,"end":119.95,"text":"נתראות, מה? כן, סגיל. שעמור, מה אחת? הלת חבר'ה. הלו דוויד. מה בצב? חבר'ה, אולי נתפוק לדויד מכות?"},{"start":119.95,"end":129.03,"text":"נפגת לי בבוקר. מהו דגרוק? עכשיו אין אתם לדגרוק. רציות, הורדנו? כן, זה משעמל כבר. אולי זה נוק הלעי."},{"start":129.03,"end":135.1,"text":"אני התרגלתי. אז יאללה, בוא נהפוך אותו. טוב. יאללה, נהפוך."},{"start":135.1,"end":237.88,"text":"חפוך. אין יותר אלוהים עבודה. פעם לא עשימו שעבודה. מה קרה לך? זה תמיד כחיה. כל המשפחה כח. זה תורשתי. תבדוק בעיית יוחתין. יוחתין, יוחתין. יש לי בוסקילה דודים בתין. מה קרה בון בון? עקורים דפתום לא רוצים את בוסקילה יותר. אמרו עליך את הביתה, עליך את הביתה. נגמרה עונה. אני עונה. מה עונה? אני עונה. אתה ענית? לא עונה. אולי בוסקילה עליך לחפש עבודה בפברלייס 34 וחצי."},{"start":238.12,"end":239.42,"text":"אה, דבר על איזה?"},{"start":239.42,"end":240.45,"text":"אימא גלון ברנדון"},{"start":240.45,"end":242.56,"text":"אה, לא פי אוטוברם ברנדון"},{"start":242.56,"end":243.83,"text":"אוטם מועד"},{"start":243.83,"end":246.56,"text":"מה, תרעין"},{"start":246.56,"end":246.66,"text":"אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא אימא א"},{"start":246.56,"end":250.83,"text":"אין מה לעשות עם הבוצקילה, אין מה לעשות"},{"start":250.83,"end":257.37,"text":"נתראות עם הבוצקילה, נתראות רבלה"},{"start":257.37,"end":260.68,"text":"נתראות עם הבוצקילה"},{"start":260.68,"end":261.68,"text":"נתראות עם הבוצקילה"},{"start":261.68,"end":262.68,"text":"נתראות עם הבוצקילה"},{"start":262.68,"end":266.49,"text":"אההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":266.49,"end":268.6,"text":"איך אולי מה?"},{"start":268.6,"end":270.9,"text":"מי? מי? מי אתה?"},{"start":270.9,"end":271.9,"text":"אני ליאור"},{"start":271.9,"end":272.92,"text":"מי? מי זה ליאור?"},{"start":272.92,"end":274.92,"text":"ליאור, ליאור, אני השחקן שמשחק את הבוצקילה"},{"start":274.92,"end":276.92,"text":"רגע רגע, איזה פה ניסים הוא שלי"},{"start":276.92,"end":278.92,"text":"טוב, אני רוצה לחופשה בהוואי"},{"start":278.92,"end":279.92,"text":"רוצה לבוא?"},{"start":279.92,"end":280.86,"text":"הוואי אג'?"},{"start":280.86,"end":281.89,"text":"אבל לא זאת על התצערות ברגליים"},{"start":281.89,"end":282.85,"text":"תצערות ברגליים"},{"start":282.85,"end":284.23,"text":"בואי בואי בואי"},{"start":284.23,"end":286.23,"text":"בואי אמא בואי"},{"start":286.23,"end":287.36,"text":"בואי בואי בואי"},{"start":287.36,"end":288.36,"text":"בואי בואי בואי"},{"start":288.36,"end":333.12,"text":"אתם באים אליי בערב לשכות וירה"},{"start":333.12,"end":334.12,"text":"מאו"},{"start":334.12,"end":339.66,"text":"קלה מציגים"},{"start":339.66,"end":341.72,"text":"למציגים דרמה קוראה אטלט."},{"start":341.72,"end":344.75,"text":"שני חברים הלכו לים."},{"start":344.75,"end":345.75,"text":"סבוט אותי וקוט אותי."},{"start":345.75,"end":347.75,"text":"דבר למה עם סבוט אותי?"},{"start":347.75,"end":350.73,"text":"לא! אני מרגיש שמשהו נורא עומד לקרוא."},{"start":350.73,"end":352.94,"text":"קוט אותי!"},{"start":352.94,"end":357.89,"text":"ואכן משהו קרה."},{"start":357.89,"end":359.92,"text":"קוט אותי!"},{"start":359.92,"end":361.3,"text":"משהו נורא."},{"start":361.3,"end":363.36,"text":"קוט אותי!"},{"start":363.36,"end":365.69,"text":"משהו מכריד."},{"start":365.69,"end":367.74,"text":"קוט אותי!"},{"start":367.74,"end":370.15,"text":"קוט אותי, טבע."},{"start":370.15,"end":374.09,"text":"קוט אותי!"},{"start":380.98,"end":388.13,"text":"קוט אותי!"},{"start":388.13,"end":389.22,"text":"קוט אותי!"},{"start":389.22,"end":391.11,"text":"קוט אותי!"},{"start":391.11,"end":392.11,"text":"קוט אותי!"},{"start":392.11,"end":393.2,"text":"מי נשאר?"},{"start":393.2,"end":395.48,"text":"קוט אותי!"},{"start":395.48,"end":398.53,"text":"קוט אותי!"},{"start":398.53,"end":401.24,"text":"רגע!"},{"start":401.24,"end":402.49,"text":"מי אתם?"},{"start":402.49,"end":404.49,"text":"חשמל אותי ושרט אותי!"},{"start":404.49,"end":415.02,"text":"עכשיו, בקולנוע של ציר."},{"start":415.02,"end":417.33,"text":"קוט אותי!"},{"start":417.33,"end":423.45,"text":"קוט אותי!"},{"start":423.45,"end":424.45,"text":"קוט אותי!"},{"start":424.45,"end":429.28,"text":"קוט אותי!"},{"start":429.28,"end":430.28,"text":"קוט אותי!"},{"start":430.28,"end":431.28,"text":"קוט אותי!"},{"start":431.28,"end":432.28,"text":"קוט אותי!"},{"start":432.28,"end":433.28,"text":"קוט אותי!"},{"start":433.28,"end":434.28,"text":"קוט אותי!"},{"start":434.28,"end":435.44,"text":"קוט אותי!"},{"start":435.44,"end":438.14,"text":"עכשיו, בקולנוע של ציר."},{"start":438.14,"end":439.14,"text":"קוט אותי!"},{"start":439.14,"end":440.15,"text":"קוט אותי!"},{"start":440.15,"end":449.99,"text":"אה..."},{"start":449.99,"end":451.21,"text":"כן, הוא מחובר!"},{"start":451.21,"end":452.21,"text":"למוכן, דוד!"},{"start":452.21,"end":453.21,"text":"חייך!"},{"start":453.21,"end":455.71,"text":"בחבות!"},{"start":455.71,"end":458.63,"text":"חרוב!"},{"start":458.63,"end":468.07,"text":"ערב טוב לכולכם באשר הם שם."},{"start":468.07,"end":472.07,"text":"לכבוד התוכנית החגיגית החלטתי לפנות בפנייה נרגשת לכל הצופים והצופות."},{"start":472.07,"end":475.87,"text":"אני אקמור, את לא יודעת מה זה צופים וצופות, שרליקה, שרליקה?"},{"start":475.87,"end":476.87,"text":"אז מה?"},{"start":476.87,"end":478.15,"text":"אז מה?"},{"start":478.15,"end":481.15,"text":"הבמה של התוכנית החליט להעניק לנו תעודות הוקרה."},{"start":481.15,"end":483.15,"text":"אז מה, גם לי הוא החליט להעניק תעודות הוקרה?"},{"start":483.15,"end":484.15,"text":"אז מה?"},{"start":484.15,"end":485.27,"text":"כן?"},{"start":485.27,"end":486.27,"text":"כמה שלך בסדר וניקיון?"},{"start":486.27,"end":488.27,"text":"ראוי לשבח, כמה לך יש?"},{"start":488.27,"end":490.52,"text":"וי, בילתי ניתן לריצוי."},{"start":490.52,"end":491.9,"text":"כמה יש לך בשניניות?"},{"start":491.9,"end":493.87,"text":"מעולה פלוס, כמה לך יש?"},{"start":493.87,"end":495.84,"text":"וי, בילתי מספיק מינוס."},{"start":495.84,"end":497.18,"text":"כמה יש לך במוחשי?"},{"start":497.18,"end":499.24,"text":"מצוין בריבוע, כמה לך יש?"},{"start":499.24,"end":502.75,"text":"וי, בילתי מצחיק בכלל."},{"start":502.75,"end":504.71,"text":"כמה יש לך במאז'פסי?"},{"start":504.71,"end":507.09,"text":"מאה, כמה לך יש?"},{"start":507.09,"end":508.5,"text":"אני יש לי אחד!"},{"start":508.5,"end":510.88,"text":"זה לא הגיונית, קלנית!"},{"start":510.88,"end":513.42,"text":"אלק זה במאז'פסי!"},{"start":513.42,"end":515.42,"text":"את עושים לדעת מה זה בסיסי!"},{"start":515.42,"end":516.73,"text":"אלק אני לא יודעת מה זה בסיסי!"},{"start":516.73,"end":518.76,"text":"אלק אני לא יודעת מה זה בסיסי!"},{"start":518.76,"end":519.76,"text":"אלק אני לא יודעת מה זה בסיסי!"},{"start":519.76,"end":520.95,"text":"לא!"},{"start":520.95,"end":522.53,"text":"נו, מה זה בסיסי?"},{"start":522.53,"end":524.69,"text":"את מספקרת, זה מה זה בסיסי!"},{"start":524.69,"end":527.69,"text":"זה מה זה בסיסי, זה נגיד את השאת עם החברה שלך הכי טוב החמישים תוכניות?"},{"start":527.69,"end":531.1,"text":"ואין לכם על מה לדבר אז אתם מחרטטות עלה ועלדה?"},{"start":531.1,"end":533.41,"text":"ואומרת לך זה מה זה בסיסי?"},{"start":533.41,"end":537.54,"text":"אז זה!"},{"start":537.54,"end":540.45,"text":"קלנית, אז יש לך תעודה כזאת רואיה לשבח"},{"start":540.45,"end":542.69,"text":"שמרמה שאת יכולה לסתוך פרקויטה!"},{"start":542.69,"end":543.69,"text":"קלנית?"},{"start":543.69,"end":545.69,"text":"התעודה הזאת היא של מי סימבוסקילה!"},{"start":545.69,"end":551.2,"text":"זו התעודה שלך!"},{"start":551.2,"end":556.44,"text":"אלק וואו! אלק בידו שנונים מהראוי לשבח!"},{"start":556.44,"end":561.61,"text":"ובכן צופים וצופות יקרים כפי שיתחבר לכולכם קלנית הפעמי ממש מפגרת!"},{"start":561.61,"end":563.53,"text":"אלק אז מה?"},{"start":563.53,"end":567.53,"text":"עכשיו אחזור שוב ואפנה ואמשיך לסנות ואפנה כרגיל!"},{"start":567.53,"end":569.81,"text":"אלה צופים ואלה מצלמה!"},{"start":569.81,"end":572.83,"text":"אלק וואו! את לא יודעת מה זה מצלמה!"},{"start":572.83,"end":573.83,"text":"אלק לא יודעת מה!"},{"start":573.83,"end":574.78,"text":"נו!"},{"start":574.78,"end":575.86,"text":"נו מה זה!"},{"start":575.86,"end":576.86,"text":"בואי בואי סתקנה אני ארילה!"},{"start":576.86,"end":577.98,"text":"עברת על הדבר הזה שם!"},{"start":577.98,"end":580.04,"text":"בואי סתק לזה עם הריבוע!"},{"start":580.04,"end":581.04,"text":"זה המצלמה?"},{"start":581.04,"end":582.04,"text":"כן עם האור שם למעלה!"},{"start":582.04,"end":584.23,"text":"ושם זה עצותים בבית!"},{"start":584.23,"end":586.42,"text":"הלק מחייך תגידי מכוער!"},{"start":586.42,"end":589.15,"text":"ומאי סתק לי שם!"},{"start":589.15,"end":592.67,"text":"כן אני!"},{"start":592.67,"end":594.88,"text":"אני חושבת ששבר לי!"},{"start":594.88,"end":597.05,"text":"וואי בואי ספליק מהי!"},{"start":597.05,"end":599.54,"text":"וואי ספדיחה!"},{"start":599.54,"end":601.54,"text":"מה זה?"},{"start":601.54,"end":605.11,"text":"לא!"},{"start":605.11,"end":607.11,"text":"לא! לא! לא! לא!"},{"start":607.11,"end":618.01,"text":"לסמות אמן!"},{"start":618.01,"end":637.28,"text":"תחו לי סבור!"},{"start":637.28,"end":639.34,"text":"וואו! הוא שרוף! בוא נחבא אותו!"},{"start":639.34,"end":641.34,"text":"שלא דלק עוד פעם!"},{"start":641.34,"end":643.34,"text":"מה לגיטים! יאללה תחזרו לו!"},{"start":643.34,"end":645.34,"text":"מה אתם רוצים?"},{"start":645.34,"end":648.13,"text":"בטא!"},{"start":648.13,"end":650.44,"text":"שפו!"},{"start":650.44,"end":658.81,"text":"אה?"},{"start":658.81,"end":660.96,"text":"זה לא!"},{"start":660.96,"end":662.96,"text":"כי אני יודע לך אנחנו כאן במשרד מייצגים את מריו שוע שירת"},{"start":662.96,"end":664.96,"text":"למשות מועצת העיר"},{"start":664.96,"end":667.02,"text":"אנחנו מחפשים איזה קופירייטר טוב"},{"start":667.02,"end":669.02,"text":"איזה מישהו שנון שייתן לנו"},{"start":669.02,"end":671.02,"text":"איזה סיסמה טובה, סיסמה בריאה"},{"start":671.02,"end":673.02,"text":"שאת אחד עוד לא ראה, אתה יודע"},{"start":673.02,"end":675.02,"text":"סיסמה לסטיקר לרכב"},{"start":675.02,"end":677.02,"text":"כן, אני חשבתי על משהו"},{"start":677.02,"end":679.28,"text":"יש לך איזה משהו, זה לא די"},{"start":679.28,"end":681.37,"text":"שים לב, זה ככה"},{"start":681.37,"end":684.25,"text":"יושע, סיק, את הבא של בן אדם"},{"start":684.25,"end":686.56,"text":"נקודה"},{"start":686.56,"end":688.65,"text":"תחשבו רגע, סימן שאלה"},{"start":688.65,"end":690.65,"text":"מה, הוא לא יכול להיות טוב להיות ראש מעטה שלכם?"},{"start":690.65,"end":692.65,"text":"סימן קריאה"},{"start":692.65,"end":694.65,"text":"למה מי אתם חושבים שאתם?"},{"start":694.65,"end":696.65,"text":"עכשיו הוא גם איש משפחה למופת"},{"start":696.65,"end":698.67,"text":"יש לו ארבעה ילדים, יש לו אישה"},{"start":698.67,"end":700.67,"text":"ויש לו לב רחב"},{"start":700.67,"end":702.67,"text":"לכל השכונה ולכל העיר"},{"start":702.67,"end":704.67,"text":"ולכל המועצה של ראש נקודות"},{"start":704.67,"end":706.67,"text":"אישית, הייתי שם אותו נשיא ארצות הברית"},{"start":706.67,"end":708.67,"text":"אבל בגלל שאני אין לי סמכות"},{"start":708.67,"end":710.67,"text":"לשים אותו נשיא, הוא יהיה ראש מועצה"},{"start":710.67,"end":712.67,"text":"תאמינו לי, סבבה, לא תצטרו"},{"start":712.67,"end":718.02,"text":"לראש נקודות"},{"start":718.02,"end":722.51,"text":"סיכר, לרחב"},{"start":722.51,"end":724.63,"text":"אדוני, אולי לא הבנת, אנחנו מחפשים משהו ככה"},{"start":724.63,"end":726.72,"text":"יותר קצר, שלוש, ארבע מילים"},{"start":726.72,"end":728.97,"text":"תמצות"},{"start":728.97,"end":731.15,"text":"יש לי עוד משהו ככה"},{"start":731.15,"end":733.47,"text":"יושע"},{"start":733.47,"end":736.39,"text":"האם שלכם"},{"start":736.39,"end":738.74,"text":"נקודה"},{"start":738.74,"end":740.9,"text":"תראו בחייכם"},{"start":740.9,"end":742.93,"text":"חשבו שנייה, תחשבו, חשבתם"},{"start":742.93,"end":744.93,"text":"סימן שאלה, אתם רואים?"},{"start":744.93,"end":746.93,"text":"הגעתם למתקנה, אני תמיד אומר"},{"start":746.93,"end":748.89,"text":"צריך לחשוב"},{"start":748.89,"end":750.89,"text":"חבר'ה, בני אדם שלא חושבים"},{"start":750.89,"end":752.89,"text":"לא מדיע להם ראש מועצה"},{"start":752.89,"end":754.89,"text":"כמו משה רבינו בשעתו"},{"start":754.89,"end":756.89,"text":"שהוביל את בני אדם במדבר"},{"start":756.89,"end":758.89,"text":"כך גם יושע, מה זה בן אדם?"},{"start":758.89,"end":760.89,"text":"את כל הקטע שלי אצלון, רוב שהוא אמין"},{"start":760.89,"end":762.89,"text":"אני בטוח לא אגנוב משלוש נקודות"},{"start":762.89,"end":765.11,"text":"האיש, ת'בבי-בבי"},{"start":765.11,"end":770.14,"text":"ארבע נקודות, תודה"},{"start":770.14,"end":772.14,"text":"תשמע אדוני, אני לא חושב שאתה כל כך מתאים"},{"start":772.14,"end":774.14,"text":"למשרד הזה, אני מצטער בסדר"},{"start":774.14,"end":776.23,"text":"סלח לי, אבל אנחנו נסתפק בעובדים"},{"start":776.23,"end":778.23,"text":"שיש לנו כרגע, תודה לך"},{"start":778.23,"end":780.23,"text":"מצריך אתכם, אני תמד אמצל עודה"},{"start":780.23,"end":782.23,"text":"אני יכול ללכת לשלום, המתחרה שלכם"},{"start":782.23,"end":784.23,"text":"אני מריץ אותו עם אחלה סיסמה"},{"start":784.23,"end":786.23,"text":"מה קרה?"},{"start":786.23,"end":788.23,"text":"שלום, בטח גם שלום"},{"start":788.23,"end":790.23,"text":"יעסיק אותך"},{"start":790.23,"end":793.96,"text":"בטוח"},{"start":793.96,"end":799.57,"text":"מה זה? מה זה?"},{"start":799.57,"end":809.76,"text":"שלום"},{"start":809.76,"end":812.43,"text":"שלום בטוח"},{"start":812.43,"end":817.95,"text":"הים יפה הבוקר"},{"start":817.95,"end":819.98,"text":"ולהילי על הגליל"},{"start":819.98,"end":821.98,"text":"תראה לך את עדובת רבאיך"},{"start":821.98,"end":823.98,"text":"תגיד לי, מה אתה כזה מפסוק לי על הבוקר?"},{"start":823.98,"end":826.98,"text":"שאול, אני מאושר, חזרתי מהמכון גמילה"},{"start":826.98,"end":827.94,"text":"איזה מכון זה?"},{"start":827.94,"end":830.03,"text":"משוודים אנונימים"},{"start":830.03,"end":832.05,"text":"מה זה אומרת?"},{"start":832.05,"end":834.05,"text":"דה, אני עכשיו עברתי גמילה טיפול"},{"start":834.05,"end":836.05,"text":"גמילה משוודיות אלה"},{"start":836.05,"end":838.05,"text":"תחדובתך בערך, אתה יכול לגמיל"},{"start":838.05,"end":839.05,"text":"לא יעזור לך"},{"start":839.05,"end":841.05,"text":"אתה לעולם לא תגמיל משוודיות"},{"start":841.05,"end":842.05,"text":"אל תהיה אידיוט"},{"start":842.05,"end":844.05,"text":"אם תהיה שבדית, תתן לה תקריב"},{"start":844.05,"end":846.05,"text":"איני, לא עובד עליי, לא פושה"},{"start":846.05,"end":848.05,"text":"חף מפשע"},{"start":848.05,"end":849.05,"text":"אינגה"},{"start":849.05,"end":851.05,"text":"יונגרסון"},{"start":851.05,"end":852.05,"text":"הולגרסון"},{"start":852.05,"end":853.05,"text":"יורן בוק"},{"start":853.05,"end":854.05,"text":"מפחשבדית"},{"start":854.05,"end":855.05,"text":"וולבו"},{"start":855.05,"end":856.05,"text":"לעתלת האבא"},{"start":856.05,"end":857.05,"text":"ביקינגים"},{"start":857.05,"end":858.99,"text":"תחדובתך בערך, תחד"},{"start":858.99,"end":861.71,"text":"תלמי"},{"start":861.71,"end":865.71,"text":"אינגלסון, אינגלסון"},{"start":865.71,"end":873.86,"text":"I heard a lot about you. I heard your language, I'm from Sweden."},{"start":873.86,"end":875.86,"text":"לא, גוווי, גוווי!"},{"start":875.86,"end":878.86,"text":"עזוב לך מהרשך הזדמנות אליך עליה, גוווי!"},{"start":878.86,"end":880.86,"text":"לא, מי שנוגע בקסד לא יוכל לך רזילי גמם!"},{"start":880.86,"end":882.85,"text":"COME ON, TAKE ME, רכבים!"},{"start":882.85,"end":883.85,"text":"לא, לא, גו, גו!"},{"start":883.85,"end":886.03,"text":"זה פיטי, רן!"},{"start":886.03,"end":887.03,"text":"אהלן!"},{"start":887.03,"end":889.21,"text":"מהו, שאולן!"},{"start":889.21,"end":906.66,"text":"הייתי שם, לא כדאי לך, לא!"},{"start":906.66,"end":908.66,"text":"הייתה פה קודם שניים!"},{"start":908.66,"end":909.66,"text":"לא, לא! שאולן!"},{"start":909.66,"end":910.66,"text":"לא, לא אני עלך!"},{"start":910.66,"end":911.66,"text":"לא, שאולן!"},{"start":911.66,"end":912.64,"text":"לא, שאולן!"},{"start":912.64,"end":913.65,"text":"לא!"},{"start":913.65,"end":919.37,"text":"עזוב לך בחייך!"},{"start":919.37,"end":924.2,"text":"ולפעמים החגיגה נגמרת."},{"start":924.2,"end":929.34,"text":"הקיץ הגיע, ובעקבותם עונת החומשות."},{"start":929.34,"end":933.44,"text":"אנו, חברי הקומדיסטור, לא מוצאים עצמנו מן הכלל,"},{"start":933.44,"end":936.44,"text":"ולכן גם אנו יוצאים לפגרה יזומה."},{"start":936.44,"end":939.4,"text":"אך עלייה זה קוצמה."},{"start":939.4,"end":941.4,"text":"עם הפסקת עבודתנו בתוכנית,"},{"start":941.4,"end":946.4,"text":"מסתם מקור פרנסתנו ונשבר מתה לחמנו."},{"start":946.4,"end":949.58,"text":"מלכך התאגדו כל דמויות הקומדיסטור,"},{"start":949.58,"end":955.57,"text":"והקלידו שיר מיוחד שכל הפנסותיו קודש לרווחת חברי הקומדיסטור."},{"start":955.57,"end":957.57,"text":"אז למה להכביר מילים?"},{"start":957.57,"end":961.63,"text":"מפיגור לפגרה, כך יצאנו, הקומדיסטור."},{"start":961.63,"end":963.88,"text":"מטוב, מטוב."},{"start":963.88,"end":978.41,"text":"מטוב, מטוב."},{"start":978.41,"end":980.46,"text":"יאו, יאנה."},{"start":980.46,"end":985.01,"text":"זה כבר ללכר."},{"start":985.01,"end":986.01,"text":"כשחלפה ואלא."},{"start":986.01,"end":992.2,"text":"ושקם נמלה."},{"start":992.2,"end":997.45,"text":"מדיין בטול, בלי בושה."},{"start":997.45,"end":1000.95,"text":"אפילו הים והשמש."},{"start":1000.95,"end":1007.14,"text":"קים לי פעמים לברלו."},{"start":1007.14,"end":1046.99,"text":"ומטיסטור."},{"start":1046.99,"end":1065.15,"text":"שפת ודוליון."},{"start":1065.15,"end":1069.39,"text":"נעשה עכשיו."},{"start":1069.39,"end":1070.39,"text":"שום רעיון."},{"start":1070.39,"end":1072.02,"text":"לא עולה."},{"start":1072.02,"end":1136.23,"text":"דויון."},{"start":1136.23,"end":1182.69,"text":"כרגע לא הבנתי."},{"start":1182.69,"end":1212.74,"text":"הסיבור."},{"start":1212.74,"end":1214.73,"text":"רשום."},{"start":1214.73,"end":1256.09,"text":"תודה רבה."}]