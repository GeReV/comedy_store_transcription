[{"start":1.92,"end":4.48,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות."},{"start":4.48,"end":9.93,"text":"קשר בין המציאות לדמיון, הינו מקרי בהחלט."},{"start":9.93,"end":15.77,"text":"שמות האנשים והמקומות שונו, לצורך העלילה."},{"start":15.77,"end":17.63,"text":"ומאתה הם נקראים..."},{"start":17.63,"end":19.08,"text":"קומדיסטור."},{"start":19.08,"end":50.74,"text":"אדוני, אין לך מה לדאוג, אנחנו נמצא את הרכב שלך."},{"start":50.74,"end":52.02,"text":"אני מקווה כמה שיותר מהר."},{"start":52.02,"end":56.11,"text":"רק תיתן לי שוב את הפרטים שלך, השם וכו', נרשום את הטופס."},{"start":56.11,"end":57.34,"text":"איך קוראים לך?"},{"start":57.34,"end":63.5,"text":"אה, דוד. זה השם שלי, דוד."},{"start":63.5,"end":72.45,"text":"זה שם מאוד מוזר, מר."},{"start":73.55,"end":79.01,"text":"זאת אומרת, במהלך העבודה שלי נתקל בהמון שמות, אבל שם כמו..."},{"start":79.01,"end":84.45,"text":"לא שמעתי. איך אתה בדיוק מאיית?"},{"start":84.45,"end":88.41,"text":"כמו שזה נשמע, מה?"},{"start":88.41,"end":90.23,"text":"פשוט."},{"start":90.23,"end":95.63,"text":"כן?"},{"start":95.63,"end":98.04,"text":"ומה הכתובת שלך?"},{"start":98.04,"end":100.45,"text":"כתובת שלי. אני גר ב..."},{"start":100.45,"end":102.58,"text":"22."},{"start":102.58,"end":105.31,"text":"אתה מאוד חצוף, מר!"},{"start":105.31,"end":106.31,"text":"מר!"},{"start":106.31,"end":109.37,"text":"בחיים לא ראיתי מישהו שמכה שוטר במשרד שלו!"},{"start":109.37,"end":111.31,"text":"למה? בליקש את הכתובת, אז נתתי לך את הכתובת."},{"start":111.31,"end":112.69,"text":"אז תתן לי את הכתובת שלך!"},{"start":112.69,"end":114.69,"text":"אוקיי, זה הכתובת שלי, זה..."},{"start":114.69,"end":118.07,"text":"22."},{"start":118.07,"end":122.06,"text":"אה, למה אני הייתי בטוח שהכתובת שלך זה..."},{"start":122.06,"end":125.2,"text":"22."},{"start":125.2,"end":128.44,"text":"לא, אני התכוונתי שהכתובת שלי זה..."},{"start":128.44,"end":130.44,"text":"22."},{"start":130.44,"end":132.41,"text":"אתה בטוח שזה לא..."},{"start":132.41,"end":135.23,"text":"22?"},{"start":135.23,"end":140.69,"text":"לא, אני התכוונתי, עוד פעם אני אומר את זה, אני התכוונתי שהכתובת שלי זה..."},{"start":140.69,"end":143.33,"text":"22."},{"start":143.33,"end":147.39,"text":"אה, כן, אני יודע איפה זה."},{"start":147.39,"end":150.39,"text":"דודה שלי גר על יד, גר ברחוב..."},{"start":150.39,"end":156.12,"text":"34."},{"start":156.12,"end":164.06,"text":"עשוף זה, אנשים מוזרים."},{"start":164.06,"end":174.44,"text":"גברת, תתקשרי למר ותגידי לו שהפגישה אם מבוטלת ותשיגי לי את מיד!"},{"start":174.44,"end":308.57,"text":"אתם יודעים איפה זה לילים בלום שמונה?"},{"start":308.57,"end":326.65,"text":"הג'יפה משתך."},{"start":326.65,"end":327.65,"text":"בסדר, לכן."},{"start":327.65,"end":329.63,"text":"יופי, ערב זוב לכולם, אתם איתנו?"},{"start":329.63,"end":334.12,"text":"קאר שלנו, the one and lonely, מועדון הג'יפה."},{"start":334.12,"end":339.49,"text":"הלו שפיה, הלו קאקון."},{"start":339.49,"end":341.65,"text":"תודה, קאקון, מה עם משתך?"},{"start":341.65,"end":343.65,"text":"יופי, רק שנייה אחת יש הודעה, סליחה, אחד."},{"start":343.65,"end":349.57,"text":"חבר'ה, באמת, מי שגנב לאיסא שחר את השמשה הקטמית מהרכב,"},{"start":349.57,"end":353.57,"text":"הוא תקוע עם השפריצר, משפריסו על הפנים וגם המזוג בורח."},{"start":353.57,"end":354.57,"text":"תחזירו את השמשה."},{"start":354.57,"end":355.57,"text":"זה לא יפה, חבר'ה."},{"start":355.57,"end":358.43,"text":"לחיות כפיים לאיסא שחר, כן."},{"start":358.43,"end":360.43,"text":"הלו שפיה, הלו קאקון."},{"start":360.43,"end":363.43,"text":"הצמצן הוא כאן במועדון וכבר אני רוצה להזמין."},{"start":363.43,"end":364.43,"text":"ווייט!"},{"start":364.43,"end":369.4,"text":"הצמצ הנפלא שחזר מ-טור הופעות בצומת רישפון בחמוסיה."},{"start":369.4,"end":372.65,"text":"כפיים להם, כפיים."},{"start":372.65,"end":379.27,"text":"מוכשר שהביס את כל העולם בקוביה הונגרית."},{"start":379.27,"end":380.27,"text":"ווייט!"},{"start":380.27,"end":382.43,"text":"הצמצ הגדול!"},{"start":382.43,"end":384.77,"text":"כאן אצלנו מבלוק מספר 4."},{"start":384.77,"end":387.99,"text":"החבר'ה שיש להם את הדוד שמש החזק ביותר בשכונה,"},{"start":387.99,"end":388.99,"text":"קבלו אותם!"},{"start":388.99,"end":390.99,"text":"את צמצ הציקוצית!"},{"start":390.99,"end":394.15,"text":"האחים אראווייט!"},{"start":394.15,"end":403.32,"text":"זהו רובי, אני אסף."},{"start":403.32,"end":405.38,"text":"אנחנו האחים אראה."},{"start":405.38,"end":406.38,"text":"ואנחנו הבנו אליכם,"},{"start":406.38,"end":409.38,"text":"אוהבי השירה בכלל ואוהבי החיות בפרט."},{"start":409.38,"end":411.38,"text":"צרור שירי חיות,"},{"start":411.38,"end":413.38,"text":"מלווים בקולות אותנטיים מן הטבע."},{"start":413.38,"end":415.66,"text":"בואו ניכנס כולנו להתחלה"},{"start":415.66,"end":417.66,"text":"לג'ונגלים של אפריקה"},{"start":417.66,"end":419.66,"text":"אל עדר הפילים הגדול"},{"start":419.66,"end":421.66,"text":"ונתבונן בפילפילון הקטן"},{"start":421.66,"end":423.66,"text":"שלא ידע כיצד לדרוך."},{"start":423.66,"end":444.96,"text":"תודה רבה, תודה רבה."},{"start":444.96,"end":446.96,"text":"מאפריקה רחוקה נחזו אל ביתנו,"},{"start":446.96,"end":447.96,"text":"אל תל אביב,"},{"start":447.96,"end":449.96,"text":"אל שלושה חתולים קטנים"},{"start":449.96,"end":451.96,"text":"שישבו ושוחחו ביניהם."},{"start":451.96,"end":455.08,"text":"בואו ניכנס כולנו למילותיו של אברהם חלפי"},{"start":455.08,"end":457.08,"text":"ואל אווירת ה... בלוו."},{"start":457.08,"end":464.77,"text":"שלושה חתולים שוחחו ביניהם"},{"start":464.77,"end":468.63,"text":"ויאלי אנחנו גל הסתדר"},{"start":468.63,"end":486.18,"text":"עכשיו יש באמתחתנו הפתעה."},{"start":486.18,"end":489.27,"text":"אנחנו נאלתר שירי חיות לפי ברישות שלכם."},{"start":489.27,"end":491.27,"text":"אתם תגידו לנו מהקהל שם של חיה,"},{"start":491.27,"end":493.27,"text":"ואנחנו נשאיר עליה שיר, הצעות."},{"start":493.27,"end":494.4,"text":"לטעה."},{"start":494.4,"end":496.94,"text":"לטעה, גבוהותנו לחיה הטובה."},{"start":498.94,"end":503.06,"text":"ובכן, בואו נרחיק כולנו לערבות דרום אמריקה,"},{"start":503.06,"end":505.06,"text":"אל עץ הזית הקטן שעומד לו בפינה,"},{"start":505.06,"end":508.06,"text":"ואל הלטעה היא מן חיה כזו קטנה."},{"start":508.06,"end":510.06,"text":"לה, קוקה רצ'ה!"},{"start":510.06,"end":512.14,"text":"בבקשה."},{"start":512.14,"end":517.58,"text":"לטעה היא מן חיה כזו קטנה."},{"start":517.58,"end":523.87,"text":"ויש לבית עץ הזית שעומד לו בפינה."},{"start":523.87,"end":545.75,"text":"באמת, אסלח לי, אדוני, אני לא מבין בשביל מה."},{"start":545.75,"end":546.75,"text":"אני צריך ביטוח."},{"start":546.75,"end":551.87,"text":"מה זאת אומרת? חברת עדנה מציעה לך את הביטוח בתנאים הטובים ביותר."},{"start":551.87,"end":554.87,"text":"עם כל הכבוד לחברה שלך אני באמת מבטר על אותנו."},{"start":554.87,"end":555.87,"text":"זה מיותר."},{"start":555.87,"end":556.87,"text":"זה פשוט נראה לי מיותר."},{"start":556.87,"end":558.87,"text":"למה? כל בן אדם הזקוק לביטוח חיים?"},{"start":558.87,"end":559.87,"text":"אז אני לא."},{"start":559.87,"end":561.87,"text":"הנה בוא ניתן לך דוגמה."},{"start":561.87,"end":563.97,"text":"הציור שם של קאדישמן."},{"start":563.97,"end":566.0,"text":"אני רואה שזה אורגינל."},{"start":566.0,"end":567.0,"text":"כן, זה מאוד יקר."},{"start":567.0,"end":568.0,"text":"כן, זה מבוטח כמובן."},{"start":568.0,"end":570.0,"text":"לא, לא צריך."},{"start":570.0,"end":571.1,"text":"לא?"},{"start":571.1,"end":574.06,"text":"ברשותך תרשה לי להציג לך חבר שלי."},{"start":574.06,"end":575.12,"text":"ש..."},{"start":575.12,"end":576.12,"text":"שאול."},{"start":576.12,"end":578.43,"text":"שאול, מה, רופז?"},{"start":578.43,"end":579.39,"text":"רופז שאול."},{"start":579.39,"end":580.39,"text":"לאים מאוד."},{"start":580.39,"end":581.48,"text":"שאול, התמונה."},{"start":581.48,"end":588.19,"text":"אבל..."},{"start":588.19,"end":589.19,"text":"נו, איך אתה מרגיש עכשיו?"},{"start":589.19,"end":590.15,"text":"מה?"},{"start":590.15,"end":591.15,"text":"אתה רואה? אם אתה היית מבוטח,"},{"start":591.15,"end":594.15,"text":"אתה היית מקבל כל גרוש בחזרה."},{"start":594.15,"end":595.07,"text":"באמת?"},{"start":595.07,"end":596.24,"text":"לא רק שהיית מקבל כל גרוש בחזרה,"},{"start":596.24,"end":598.24,"text":"גם לא היית מרגיש עכשיו עדיות."},{"start":598.24,"end":600.1,"text":"והווזה שמה?"},{"start":600.1,"end":601.1,"text":"הווזה מבוטחת?"},{"start":601.1,"end":602.02,"text":"לא."},{"start":602.02,"end":603.1,"text":"זה מינג, נכון?"},{"start":603.1,"end":604.1,"text":"מאוד יקר, כן, עולה..."},{"start":604.1,"end":605.1,"text":"שאול."},{"start":605.1,"end":606.07,"text":"מה שאול?"},{"start":606.07,"end":607.07,"text":"מה שאול?"},{"start":607.07,"end":608.07,"text":"רגע, רגע, אדוני."},{"start":608.07,"end":612.68,"text":"אדוני, תן לשאול, לשאול, לעשות את העבודה בשבילך."},{"start":612.68,"end":617.21,"text":"הנה, הטלוויזיה, הטלוויזיה שלך היא מבוטחת."},{"start":617.21,"end":618.64,"text":"לא."},{"start":618.64,"end":619.73,"text":"שאול, הטלוויזיה."},{"start":619.73,"end":621.69,"text":"רגע, שמי, שמי."},{"start":621.69,"end":628.84,"text":"זה יפריע לך אם אני אעשן?"},{"start":628.84,"end":632.24,"text":"כן, העשן קצת מפריע."},{"start":632.24,"end":634.33,"text":"הנה, מה עפרה, בבקשה."},{"start":634.33,"end":636.16,"text":"תודה."},{"start":636.16,"end":638.53,"text":"האוטו האדום בחוץ הוא שלך?"},{"start":638.53,"end":643.3,"text":"מה, אה, לא, מה פתאום, לא."},{"start":643.3,"end":644.49,"text":"אין לי."},{"start":644.49,"end":646.41,"text":"מה שקר?"},{"start":646.41,"end":648.53,"text":"שאול, האוטו."},{"start":648.53,"end":652.66,"text":"רגע!"},{"start":652.66,"end":657.98,"text":"איך, איך קוראים לחברה שלכם?"},{"start":657.98,"end":659.78,"text":"אדנה."},{"start":659.78,"end":663.26,"text":"אה?"},{"start":663.26,"end":664.26,"text":"אני יכול לשאול אותך שאלה קצת אישית."},{"start":664.26,"end":665.66,"text":"כן."},{"start":665.66,"end":667.18,"text":"אתה נשוי."},{"start":667.18,"end":669.24,"text":"כן."},{"start":669.24,"end":670.24,"text":"יש לך ילדים?"},{"start":670.24,"end":671.24,"text":"מזלת."},{"start":671.24,"end":674.36,"text":"אתה כמובן מבוטח בביטוח חיים."},{"start":674.36,"end":677.34,"text":"למה לא?"},{"start":677.34,"end":682.53,"text":"למה, ממה יש לי לפח?"},{"start":682.53,"end":685.98,"text":"אה, אה, כמה זה עולה?"},{"start":685.98,"end":689.05,"text":"או, או, עכשיו אתה מדבר לעניין."},{"start":689.05,"end":690.67,"text":"תענוג לעשות איתך עסקים."},{"start":690.67,"end":696.11,"text":"אדנה, חברת הביטוח שתציע לך הצעה שפשוט אי אפשר לסרב לה."},{"start":696.11,"end":699.01,"text":"יאה!"},{"start":699.01,"end":703.07,"text":"חמוץ."},{"start":703.07,"end":704.07,"text":"נרקמות הגדודו."},{"start":704.07,"end":705.07,"text":"אלוף!"},{"start":705.07,"end":707.07,"text":"שטוק אלמניה, שטוק!"},{"start":707.07,"end":710.35,"text":"בונה, למי אמרת מניה?"},{"start":710.35,"end":711.51,"text":"איך?"},{"start":711.51,"end":716.03,"text":"בונה תזהר, חבל."},{"start":716.03,"end":718.19,"text":"יש לך פנים יפות."},{"start":718.19,"end":719.38,"text":"אה?"},{"start":719.38,"end":723.72,"text":"ועכשיו, קבלו אותו!"},{"start":723.72,"end":724.72,"text":"ווייט!"},{"start":724.72,"end":726.72,"text":"המצחיקן הגדול, אלוף הבדיחות!"},{"start":726.72,"end":728.72,"text":"ווייט!"},{"start":728.72,"end":731.17,"text":"אלף ווייט!"},{"start":731.17,"end":737.78,"text":"טוב, מה עניינים?"},{"start":737.78,"end":739.78,"text":"שוב כאן אני אלפרד, והתופפן שלי איז'וס."},{"start":739.78,"end":741.78,"text":"איזה גנב הייתנו, קוס אוכטי."},{"start":741.78,"end":743.9,"text":"שיבו לב נתחיל עם צרור בדיחות"},{"start":743.9,"end":745.9,"text":"שהבאנו במתחתנו מיוניטד סטוץ."},{"start":745.9,"end":747.9,"text":"פיל ואחבר נכנסים בחוף הים,"},{"start":747.9,"end":749.9,"text":"איך שהם מתיישבים?"},{"start":749.9,"end":751.9,"text":"פתאום אפיל קם, נכנס בתוך המים,"},{"start":751.9,"end":753.9,"text":"להתרחץ ולהתרחך בים."},{"start":753.9,"end":755.9,"text":"אז האחבר קורא לו: \"פיל! פיל! צא בחוצה! צא בחוצה!\""},{"start":755.9,"end":757.9,"text":"אפיל יוצא שואל אותו: \"למה? מה קרה?\""},{"start":757.9,"end":759.9,"text":"הוא אומר לו: \"רק רציתי לבדוק"},{"start":759.9,"end":761.9,"text":"שלא לקחת לי את הבגדים!\""},{"start":761.9,"end":764.02,"text":"עכשיו מה מצחיק פה?"},{"start":764.02,"end":766.02,"text":"איך פיל כזה גדול"},{"start":770.02,"end":772.28,"text":"קלתם!"},{"start":772.28,"end":774.28,"text":"איזה גנבה כוס אוכתי!"},{"start":774.28,"end":776.28,"text":"תודה רבה חבר'ה, ואני עובר לקטע הבא"},{"start":776.28,"end":778.28,"text":"תאמינו לי שוס אוכתי, שימו לב"},{"start":778.28,"end":780.28,"text":"קטעים מסרטים"},{"start":780.28,"end":782.21,"text":"קטע ראשון מתוך הסרט: לשחרר את ווילי"},{"start":782.21,"end":784.92,"text":"ווילי! חופשי!"},{"start":784.92,"end":786.92,"text":"וואלה! קלתם עוד הקטע"},{"start":786.92,"end":789.62,"text":"איזה גנבה הייתי, כוס אוכתי"},{"start":789.62,"end":791.62,"text":"תודה חבר'ה, שימו לב"},{"start":791.62,"end":794.16,"text":"קטע מתוך הסרט: לשחרר את ווילי? שתיים"},{"start":794.16,"end":796.16,"text":"ווילי! אמרתי לך חופשי, לא!"},{"start":796.16,"end":798.16,"text":"מה אתה אל מות? חופשי! וואלה!"},{"start":798.16,"end":800.18,"text":"הוא באלם מכלב!"},{"start":800.18,"end":803.18,"text":"חבר'ה, שימו לב, קטע מהסרט \"ארבע חתמונות ולוויה אחת\""},{"start":803.18,"end":805.24,"text":"מזל טוב! מזל טוב! מזל טוב!"},{"start":805.24,"end":807.24,"text":"מזל טוב! משתתף בצרכה!"},{"start":807.24,"end":809.24,"text":"איזה גנבה כוסוכתי!"},{"start":809.24,"end":810.24,"text":"הוא שרמותי!"},{"start":810.24,"end":812.24,"text":"שוס אמיתי, שוס אטרי, תודה!"},{"start":812.24,"end":815.6,"text":"חבר'ה, קטע מהסרט \"אצ אדומים תפוס\""},{"start":815.6,"end":818.85,"text":"הלו! הלו!"},{"start":818.85,"end":820.85,"text":"עוד פעם תפוס, יאללה, אי אפשר להשיג את \"אצ אדומים\""},{"start":820.85,"end":822.85,"text":"איזה גנבה כוסוכתי, וואלה!"},{"start":822.85,"end":825.42,"text":"קלטת פה את הקטע!"},{"start":825.42,"end":830.42,"text":"שימו לב, עכשיו אנחנו עוברים לשוס אמיתי, בדיחות וקטעים על חבר'ה והשכונה שלנו"},{"start":830.42,"end":835.89,"text":"יום אחד, קאקון, בכבודו ועצמו, נכנס בתוך גן חיות"},{"start":835.89,"end":837.89,"text":"איך שהוא נכנס בגן חיות, הוא מגיע לכלוב של הקוף"},{"start":837.89,"end":840.89,"text":"הקוף מסתכל עליו, קאקון מסתכל על הקוף"},{"start":840.89,"end":844.89,"text":"שניהם מביטים אחד על השני, פתאום הקוף תופס חבילה של בוטנים"},{"start":844.89,"end":847.89,"text":"וזורק על קאקון, זורק עליו את הבוטנים"},{"start":847.89,"end":852.0,"text":"למה? למה קאקון כל כך מכוער?"},{"start":852.0,"end":855.0,"text":"הקוף חשב זה... זה הוא קוף בכלל, לא קאקון!"},{"start":855.0,"end":884.76,"text":"חבר'ה, חבר'ה, חבר'ה, רגע, רגע, זה בדיקה, חבר'ה, לרגע, זה לא היה קאקון בכלל, זה היה דוד, מהשכונה ממול, זה גנבה, קוס אוקטי, הנה לבוקבוקי, תודה חבר'ה, תודה, תודה, קוס אימקי, חבר'ה, שקט, רגע, באמת תודה רבה לכם, אנחנו ממהרים לקלטורה בצפת, תהיו בריאים, כי לאלפרד ואיז'ו, ספניטה, קיבלת סטק בפיטה, נילון, תודה לבה חבר'ה, השיגעתי אותי כיף, תודה."},{"start":886.58,"end":892.03,"text":"ובכן, חיים, צהריים טובים לכם, אנחנו נמצאים כאן צוות חדשות החוץ של חברת החדשות מוטב."},{"start":892.03,"end":896.73,"text":"מה שהירה בצומת הזה הלאו צומת כדאיף לפני שניות ספורות, הוא כדילהלן."},{"start":896.73,"end":903.13,"text":"על פי הדיווחים, מכונית אפורה חצתה את הצומת במהירות מופרזת ונכנסה במעקי הבטיחות כאן בצדו הצפוני."},{"start":903.13,"end":904.81,"text":"לא ראיתי מאיפה הוא בא מהסיבוב פתאום, אני ראיתי..."},{"start":904.81,"end":910.11,"text":"סליחה אדוני אדוני נפנה לך מיד ואתה תספר בדיוק לקהל בבית מה קרה, מה הראה בתאונה הזאת, אוקיי?"},{"start":910.11,"end":912.21,"text":"בסדר תהיה בריא ביתן תרגיש טוב."},{"start":912.21,"end":917.91,"text":"ובכן חיים כמו שאמרתי מכונית חצתה במהירות מופרזת ונכנסה במעקי הבטיחות כאן בצד הצפוני."},{"start":917.91,"end":921.75,"text":"איך שאובר הוא פתאום בא מהסיבוב אני לא ראיתי, פתאום היה רוע שבחושר..."},{"start":921.75,"end":927.75,"text":"אדוני, בסדר, ברור לנו, ברור לנו כל העניין, אנחנו בעוד שניות נפנה אליך ואתה תספר בדיוק מה קרה, אוקיי? תתעזר בסבלנות?"},{"start":927.75,"end":928.75,"text":"אוקיי, בסדר, הכל טוב."},{"start":928.75,"end":933.94,"text":"ובכן חיים, המסעית שהגיחה ממול נכנסה אפי במעקי הבטיחות והפצועים כאן רבים."},{"start":933.94,"end":935.9,"text":"מה שקרה למעשה, על פי הידועות שגבינו קודם..."},{"start":935.9,"end":937.9,"text":"אני באתתי להפתאום היה מהסיבוב שהסתובב."},{"start":937.9,"end":942.9,"text":"אדוני, אדוני, שנייה אחת, אדוני, אני פונה אליך, תקשיב טוב, תקשיב טוב, סליחה, שנייה חיים."},{"start":942.9,"end":951.11,"text":"אני פונה אליך, ואתה מספר מה קרה, רק שאני פונה אליך, בסדר? אוקיי, שנייה תמתין, בסדר? אוקיי."},{"start":951.11,"end":961.68,"text":"ובכן, אותה ממשאית שלמרבה הפלא איש אינו יודע מדוע חדרה כאן לצומת הזה מצידו הצפוני של הצומת, כמו שאמרתי קודם לכן, פשוט פגעה בצורה מחרידה באותו רכב אפור."},{"start":961.68,"end":972.89,"text":"לא יודעת איפה הוא בא מהסיבוב פתאום. אדוני, אדוני, שנייה, אדוני, שנייה אחת, שנייה! שנייה! אני פונה אליך שיהיה כאן סדר בשידור! אני פונה אליך, אתה אומר מה שיש לך להגיד, אתה מספר!"},{"start":972.89,"end":991.63,"text":"בסדר, לא ככה סתם, לא פניתי עוד! רוצים לדעת מה יש לך להגיד? תמתין ותדבר! בסדר? שנייה אחת! ובכן חיים, אותו מעקה בטיחות כנראה לא בלם, קייעות, את אותה מכונית, מסעית גדולה שהגיחה מהצד הצפוני כמו שאמרתי, ובכן..."},{"start":991.63,"end":1019.94,"text":"ובכן, אדוני, אדוני, שנייה, שנייה אחד, שנייה, אני מדבר לך, נכון, מדבר אליך, שטוק רגע, שטוק, שנייה, אתה אומר רק מה שאני צריך אומר לך, ומה שאתה צריך להגיד, אל תבלבל איתמוך, אמרתי מה שקרה פה, מה הגיע משם, שנייה, תמתין, בסדר, שטוק תרגע, חיים, המשטרה פה מנסה לפזר את פקקי התנועה שנוצרו ברחבי האזור, פשוט למעשה, לא ידעתי אפילו איך היו, שטוק, חיים, אני יודע, אלי, תזיק את זה, אולי איך הוא הגיע בכלל, באתי, איך..."},{"start":1030.66,"end":1045.68,"text":"ובכן חיים, מה שיראה הוא למעשה, תאונה דרכים מחרידה, עד כה הדיווחים מספרים על חמישה פצועים, וארוג אחד, עד כאן מצומת כדאיף, אליך חיים."},{"start":1045.68,"end":1069.23,"text":"תודה חברים, תודה, ואתם שוב יצאנו כאן, במועדון שלנו, The One and Lonely, מועדון הג'יפוי, אתם יצאים כאן במועדון עם סרוליק פדיזה, כי עורכים של פדיזה, הם עורכים שלי."},{"start":1069.23,"end":1086.31,"text":"נראה אחד, יש לנו הודעה, חברים יקרים, מי שסתם לאיסה שכר את האגזוז עם סמבוסק, שיצא ויעזור לו כי איסה שכר נחנק בתוך האוטו, זה בושה. תודה."},{"start":1086.31,"end":1090.88,"text":"אתם איתנו ואנחנו עוברים אל הורי החבא שלנו, שימו לב, קבלו אותו."},{"start":1090.88,"end":1092.39,"text":"ווייט!"},{"start":1092.39,"end":1095.7,"text":"הידיד הוותיק של בוריס ילצין."},{"start":1095.7,"end":1096.95,"text":"ווייט!"},{"start":1096.95,"end":1102.82,"text":"הלכה במדליאת זהב באולימפיאדת עוזבק על התאמלות קרקע קרקע."},{"start":1102.82,"end":1104.22,"text":"ווייט!"},{"start":1104.72,"end":1116.29,"text":"חבר וידיד השכונה, הזמיר, שתמיד נותן לנו להשתמש במייחם שלו, הנה הוא כאן, חורכה בוריס ביסוץקי! קבלו אותו!"},{"start":1116.29,"end":1125.76,"text":"שלום, תל אביב!"},{"start":1125.76,"end":1133.21,"text":"1, 2, 3..."},{"start":1133.21,"end":1135.49,"text":"עזבו..."},{"start":1135.49,"end":1136.89,"text":"שנייה..."},{"start":1136.89,"end":1137.89,"text":"אוו, אוו..."},{"start":1137.89,"end":1145.21,"text":"יקצ'וזניה, יציביה, יציביה, זיבדו..."},{"start":1145.21,"end":1146.59,"text":"בוא תסמנוי!"},{"start":1146.59,"end":1152.12,"text":"תתקווי גליזיץ, מיה לנינגרד"},{"start":1152.12,"end":1153.94,"text":"קצימה!"},{"start":1153.94,"end":1155.23,"text":"חביס..."},{"start":1155.23,"end":1157.23,"text":"כפיים כולם להסתחף עם הסתרים!"},{"start":1157.23,"end":1158.23,"text":"ספסיבה, חרשו..."},{"start":1158.23,"end":1160.23,"text":"חרשו, נעיץ, נעיץ!"},{"start":1160.23,"end":1163.33,"text":"תתקווי גליזיץ, תתקווי גליזיץ!"},{"start":1163.33,"end":1166.15,"text":"מיה לנינגרד..."},{"start":1166.15,"end":1167.24,"text":"אלברץ!"},{"start":1167.24,"end":1168.16,"text":"אלברץ!"},{"start":1168.16,"end":1169.21,"text":"אלברץ!"},{"start":1169.21,"end":1171.27,"text":"אלברץ קום, אלברץ קום!"},{"start":1171.27,"end":1172.27,"text":"ספסיבה, חרשו..."},{"start":1172.27,"end":1174.27,"text":"אבן שלך על הבמה, אלברץ!"},{"start":1174.27,"end":1175.62,"text":"קדימה!"},{"start":1175.62,"end":1176.57,"text":"נתן בגליזיץ!"},{"start":1176.57,"end":1177.68,"text":"ספסיבה!"},{"start":1177.68,"end":1178.68,"text":"ספסיבה!"},{"start":1178.68,"end":1181.31,"text":"תודה, תל אביב!"},{"start":1181.31,"end":1188.02,"text":"חרשוות הידיעות שחשפו את החדרת הסיליקון לתוך החלב העמיד,"},{"start":1188.02,"end":1190.02,"text":"יצאנו אפענו לאורך כתבה משלנו."},{"start":1190.02,"end":1193.02,"text":"איתי נמצא כאן המנתח הפלסטי הנודע יחיאל תדמית."},{"start":1193.02,"end":1194.02,"text":"ערב טוב לך יחיאל!"},{"start":1194.02,"end":1195.02,"text":"ערב טוב."},{"start":1195.02,"end":1196.99,"text":"האם יש אמת בשמועה?"},{"start":1196.99,"end":1199.05,"text":"כן, כן, יש אמת, ואני לא מבין על מה המומה."},{"start":1199.05,"end":1200.05,"text":"אני מאוד מבסוט."},{"start":1200.05,"end":1206.21,"text":"אני צריך לראות את התורה האורך של אנשים שבאות הלילה לקליניקה ומחכות שאני אכדיר להם חלב עמיד לתוכח הזה."},{"start":1206.21,"end":1208.1,"text":"יש לזה תופעות לוואי?"},{"start":1208.1,"end":1209.84,"text":"בוודאי, קודם כל יש יתרונות."},{"start":1209.84,"end":1212.78,"text":"היתרון הוא שהן יכולות להעניק גם בלי להיכנס להיריון."},{"start":1212.78,"end":1215.14,"text":"רק לפעמים הם מתחיל לעשות מווו."},{"start":1215.14,"end":1216.1,"text":"זה קצת בעיה."},{"start":1216.1,"end":1218.31,"text":"זהו מר רמן."},{"start":1218.31,"end":1221.66,"text":"למר רמן יש סיפור אישי ונוגע ללב."},{"start":1221.66,"end":1222.8,"text":"שתף אותנו."},{"start":1222.8,"end":1228.25,"text":"תכן, מאז כל הסיפור הזה אני פשוט קניתי קופסאות של חלב עמיד."},{"start":1228.33,"end":1231.75,"text":"אני מסדר אותם על המדף בסלון, אני מתבונם בהם שעות."},{"start":1231.75,"end":1233.04,"text":"מדוע?"},{"start":1233.04,"end":1239.53,"text":"זה כל כך מוצק, זה כל כך מלא, זה כל כך זקוף, אתה מבין?"},{"start":1239.53,"end":1243.61,"text":"אני פשוט אם תסלח לי רק עוד מעצוגרים את הסופר."},{"start":1243.61,"end":1246.01,"text":"תודה רבה לך."},{"start":1246.01,"end":1250.78,"text":"כאן נמצאתי פה אדם ששתה שלושה ליטרים של חלב עמיד."},{"start":1250.78,"end":1252.57,"text":"שלום לך, מה שמחה?"},{"start":1252.57,"end":1256.82,"text":"אה?"},{"start":1256.82,"end":1267.61,"text":"זה הכל, תודה רבה."},{"start":1267.61,"end":1273.52,"text":"סופה לקטינו, סופה לקטיקטו."},{"start":1273.52,"end":1294.51,"text":"אם ככה אתה בוחרת את הבחורה שלך, חבר'ה תנולה רוצה לתת לך טיפ."},{"start":1294.51,"end":1296.83,"text":"תגיד, אתה אידיוט? מה אתה מתלבט?"},{"start":1296.83,"end":1301.6,"text":"קח את הבלונדינית, ותאמינו לנו, אין בה אף טיפה של סיליקון."},{"start":1301.6,"end":1359.48,"text":"תגיד, תגיד, תגיד, תגיד, תגיד, תגיד, תגיד."}]