[{"start":42.27,"end":43.17,"text":"מה בעיה שלך?"},{"start":43.17,"end":45.71,"text":"אני לא יודע מה יש לי, דוקטור בלושי."},{"start":45.71,"end":48.9,"text":"יש לי הרגשה שכולם מתעלמים ממני."},{"start":48.9,"end":49.9,"text":"הבא בתור, בבקשה?"},{"start":49.9,"end":72.91,"text":"בסדר, מה המצב?"},{"start":72.91,"end":73.91,"text":"מה איתך?"},{"start":73.91,"end":75.91,"text":"בוא נה, תגיד, אני כבר שבוע מסל להשיג אותך."},{"start":75.91,"end":76.91,"text":"אין תשובה בטלפון."},{"start":76.91,"end":77.91,"text":"יש לי טלפון חדש."},{"start":77.91,"end":78.91,"text":"אה, באמת, אז תן אותו."},{"start":78.91,"end":79.91,"text":"בבקשה."},{"start":79.91,"end":81.19,"text":"אה, לקפק."},{"start":81.19,"end":82.19,"text":"את הטלפון שלי יש לך?"},{"start":82.19,"end":83.19,"text":"כן, בטע."},{"start":83.19,"end":84.19,"text":"אני רוצה תחזיר אותו, בבקשה."},{"start":84.19,"end":85.35,"text":"מה?"},{"start":85.35,"end":86.41,"text":"אה, לקפק."},{"start":86.41,"end":87.61,"text":"מה, מה איתך?"},{"start":87.61,"end":88.64,"text":"אני יודע."},{"start":88.64,"end":89.64,"text":"אני אגיד לך."},{"start":89.64,"end":92.64,"text":"קודם אני עובר את הכביש, מישהו מאיזה משוגע, כי מה דורס אותי, אני..."},{"start":92.64,"end":94.64,"text":"מה אתה אומר? לקחת עליו במספר?"},{"start":94.64,"end":95.64,"text":"בטח שלקחתי מהנפרד."},{"start":95.64,"end":96.64,"text":"אה, יופי, על הכיפה."},{"start":96.64,"end":98.74,"text":"אופה, בוא נעין, האוטובוס שלי מגיע."},{"start":98.74,"end":100.74,"text":"טוב, שמור על קשר, אה?"},{"start":100.74,"end":101.74,"text":"כן, בטח על הכיפה."},{"start":101.74,"end":102.74,"text":"כי יאללה, אז תיקפוץ, אה?"},{"start":102.74,"end":102.84,"text":"בסדר."},{"start":102.74,"end":103.74,"text":"יאללה, אני זז."},{"start":103.74,"end":121.83,"text":"קאב פרש, אבל מאיר פעיל!"},{"start":121.83,"end":122.83,"text":"פעיל!"},{"start":122.83,"end":131.85,"text":"זה אבי חלש, אבל רפאל איתן!"},{"start":131.85,"end":133.85,"text":"וואה!"},{"start":133.85,"end":135.85,"text":"נגע, נגע!"},{"start":135.85,"end":136.85,"text":"יש לי!"},{"start":136.85,"end":141.04,"text":"יובל נאמן, אבל ערב מגד!"},{"start":141.04,"end":145.52,"text":"יש לי, יש לי, יש לי!"},{"start":145.52,"end":151.39,"text":"דוויד לוי, אבל שושה מהרבני על מוזלינות!"},{"start":151.39,"end":160.23,"text":"ספורט."},{"start":160.23,"end":165.26,"text":"במשחק הדרבי במביטר ירושלים למכבי נתניה, ניצחה הפועל חלפה."},{"start":165.26,"end":173.45,"text":"אהדי הפועל תל אביב זרקו בגבוקים על עובר הדשא, והשופט רשם בדוח שלו כי תפס את מהמנפון ברשבה רוכב על גמל."},{"start":173.45,"end":174.41,"text":"לגמל שלום."},{"start":174.41,"end":176.85,"text":"וכעת נעבור לידיות פנים."},{"start":176.85,"end":184.17,"text":"כנופיית שודדי התיקים, שנעולמה לפני כחודשיים, פשוטת שוב והפעם באזור המרכז."},{"start":184.17,"end":191.17,"text":"כתבתנו ג'ודי ארנובנס קרפינסה ממה, עקבה אחרי חברי הכנופייה והרי כתבתה."},{"start":191.17,"end":199.87,"text":"לקחנו את המצלמה המשוטטת והלכנו לראות את השודדים בפעולה. בואו ונראה אותם."},{"start":199.87,"end":207.65,"text":"עכשיו, כאן ג'ודי ליסה ארנוב, רוץ'ה חמורוב, קרפי נערונוב. בואו ונראה אותם. עכשיו."},{"start":207.65,"end":243.59,"text":"מה אם אני אומר לך לא נורמל אם הייתי בזדי תעופה? גנבו לי דעתיק, השאירו אותי עם הווידאו ביד."},{"start":243.59,"end":245.55,"text":"וביללם תפסו אותי במחז, קראו אותי."},{"start":245.55,"end":266.99,"text":"כשבמשלה יש כל כך הרבה תיקים, לא יזיק שיהיה לו קצת פחות תיקים."},{"start":266.99,"end":279.04,"text":"מה, מה זה התוכנית לזודן שלום? מה זה?"},{"start":279.04,"end":283.58,"text":"אני לא יודע מה רוצים מהם, אני דווקא די מבסוט, אתה יודעת, היה לי תיק."},{"start":283.58,"end":287.58,"text":"כזה מאוד הפריע לי, איך שנתקלתי בהם, הם לקחו לי אותו ממש על הקפק."},{"start":287.58,"end":289.58,"text":"חבר רק שישירו אותי עם התיקיית."},{"start":289.58,"end":294.6,"text":"כאן ג'ודי ליסא ארונוב קרפין ויצטום סממה."},{"start":294.6,"end":295.59,"text":"בון."},{"start":295.59,"end":303.54,"text":"תודה לך ג'ודי."},{"start":303.54,"end":307.69,"text":"ובאותו הקשר, לפני כשעה אנחנו נמסר לנו ממשטרת ישראל,"},{"start":307.69,"end":312.69,"text":"ניל כהדה, כנופיית שודדי התיקים, במהלך ביצוע שעוד שגרתי."},{"start":312.69,"end":315.69,"text":"הם יבואו מחר לפני שופט להערכת מעצרם,"},{"start":315.69,"end":321.68,"text":"ואילו אנחנו נוכל להירגע, שוב להגלבו תיקים מאזרחים תמינים."},{"start":321.68,"end":322.69,"text":"כלכלה."},{"start":322.69,"end":325.77,"text":"ספיחה."},{"start":325.77,"end":326.77,"text":"והראה הודעה."},{"start":326.77,"end":331.95,"text":"כנופייה חדשה פה נגד זורנו, כנופיית שודדי השולחנות."},{"start":331.95,"end":334.95,"text":"המשטרה מבקשת מהציבור לגלות ערנות."},{"start":334.95,"end":337.07,"text":"ובכן, עד כאן מהדורת החדשות."},{"start":337.07,"end":344.34,"text":"מחר, שרבי, כל טוב ולהתראות."},{"start":344.34,"end":350.41,"text":"בואו, בואו, בואו נתחיל מהמחילה. בואו תספר לי מה הבעיה שלך."},{"start":350.41,"end":352.41,"text":"הבעיה היא לא בי דוקטור בלושי, הבעיה היא באשתי."},{"start":352.41,"end":354.41,"text":"באשתך, מה הבעיה?"},{"start":354.41,"end":356.66,"text":"היא כל הזמן חושבת שהיא טלוויזיה."},{"start":356.66,"end":358.66,"text":"חושבת שהיא טלוויזיה? אז למה אתה לא מביא אותה לטיפול?"},{"start":358.66,"end":361.66,"text":"לא, לא, לא צריך, לא צריך. רק תגליח לחבר אותה לוידאו."},{"start":361.66,"end":366.12,"text":"בודה, איפה אתה? מה קרה לך?"},{"start":366.12,"end":369.12,"text":"אל תשאל, מסכנה, אשתי הילדה לא הרגישה טוב מהבוקר,"},{"start":369.12,"end":371.12,"text":"מהבוקר לקחת אותה להשפוז נמרץ."},{"start":371.12,"end":372.12,"text":"מה? השפוז נמרץ?"},{"start":372.12,"end":376.12,"text":"כן, מסכנה ילדה לא הרגישה טוב, אשתי הקיית הנשמה, מסכנה ילדה לא הרגישה טוב."},{"start":376.12,"end":379.12,"text":"4 שעות מחלקה נורבולוגת, מסכנה אשתי ילדה לא הרגישה טוב."},{"start":379.12,"end":380.09,"text":"מי, אשתך?"},{"start":380.09,"end":383.09,"text":"הילדה לא הרגישה טוב, מסכנה מהבוקר, השפוז נמרץ שמה."},{"start":383.09,"end":387.09,"text":"כמו משוגעים מחלקה נורבולוגת, מסכנה אשתי הקיית הנשמה, ילדה לא הרגישה טוב."},{"start":387.09,"end":388.09,"text":"אה, הילדה לא הרגישה טוב?"},{"start":388.09,"end":395.09,"text":"אשתי מסכנה לא הרגישה טוב, ארבע שעות, הילדה כמו מתרוצית ארבע שעות במחלקה נורבולוגית, ישפוס דמרץ, אשתי מסכנה."},{"start":395.09,"end":397.73,"text":"רגע, לא הבנתי מי מסכן, אשתך או ילדה?"},{"start":397.73,"end":409.17,"text":"אני מסכנה אשתי ילדה לא הרגישה טוב, כמו ארבע שעות מקיית הנשמה שם בישפוס דמרץ, ארבע שעות אשתי מסכנה ילדה לא הרגישה טוב שם, אשתי מסכנה ילדה לא הרגישה טוב שם במחלקה נורבולוגית."},{"start":409.17,"end":410.17,"text":"שכן."},{"start":410.17,"end":427.93,"text":"אה, אלו, יש לך בעיה בקרבורטור."},{"start":427.93,"end":432.43,"text":"אה, אלו, יש לך בעיה בקרבורטור, אתה לא שומע?"},{"start":432.43,"end":438.21,"text":"כן, אתה היה בקרבורטור, איזה אנשים."},{"start":438.21,"end":442.69,"text":"אה, מה קרה?"},{"start":442.69,"end":443.66,"text":"אה?"},{"start":443.66,"end":444.81,"text":"אתה חזרה משהו?"},{"start":444.81,"end":445.94,"text":"באה בעיות?"},{"start":445.94,"end":446.94,"text":"זה מנוע חשמלי אני רואה, אה?"},{"start":446.94,"end":447.97,"text":"אל תשאל מה קרה לי."},{"start":447.97,"end":448.97,"text":"מה קרה?"},{"start":448.97,"end":450.22,"text":"אני פה תקור עם האוטו."},{"start":450.22,"end":451.22,"text":"כן."},{"start":451.22,"end":452.22,"text":"פתאום בא כלב."},{"start":452.22,"end":453.4,"text":"כלב?"},{"start":453.4,"end":454.4,"text":"כן."},{"start":454.4,"end":456.4,"text":"אומר לי יש לך בעיה בקרבורטור."},{"start":456.4,"end":457.87,"text":"הכלב."},{"start":457.87,"end":459.57,"text":"מה כלב?"},{"start":459.57,"end":461.57,"text":"הכלב אמר לי יש לך בעיה בקרבורטור."},{"start":461.57,"end":462.75,"text":"תגיד אתה עושה צחוק?"},{"start":462.75,"end":465.1,"text":"כלב אמר לך יש לך בעיה בקרבורטור?"},{"start":465.1,"end":466.1,"text":"יש לך אני."},{"start":466.1,"end":467.1,"text":"איזה כלב?"},{"start":467.1,"end":469.51,"text":"כלב זה זאב כזה אני לא יודע."},{"start":469.51,"end":471.51,"text":"גובה בינוני."},{"start":471.51,"end":472.51,"text":"כלב."},{"start":472.51,"end":473.51,"text":"אה כזה עם פרווה שחורה?"},{"start":473.51,"end":474.51,"text":"כן כן כן כן."},{"start":474.51,"end":475.51,"text":"עזוב אותך ממנו זה."},{"start":475.51,"end":476.51,"text":"לא מבין במכונאות זה."},{"start":476.51,"end":477.51,"text":"מה קנה לך?"},{"start":477.51,"end":480.27,"text":"הנה הקפה שלכם."},{"start":480.27,"end":482.27,"text":"הנה יש פה טורקי, שחור וקצר."},{"start":482.27,"end":484.19,"text":"רק תקידו לי מה למיד."},{"start":484.19,"end":497.19,"text":"תגיד אתה מטוס כבד?"},{"start":497.19,"end":498.25,"text":"מה פתאום?"},{"start":498.25,"end":499.25,"text":"אני מטוס קל."},{"start":502.25,"end":504.25,"text":"יאללה, גם יש לי אחד."},{"start":504.25,"end":506.24,"text":"אתה ממורמטוק?"},{"start":506.24,"end":508.6,"text":"פתאום, אני ממורמר!"},{"start":508.6,"end":510.75,"text":"ממורמר!"},{"start":510.75,"end":513.75,"text":"יש לי, יש לי, יש לי."},{"start":513.75,"end":515.91,"text":"תגיד, אתה מטורבן?"},{"start":515.91,"end":517.91,"text":"לא, אני מטורבט!"},{"start":517.91,"end":524.45,"text":"תגיד, אתה מטומטם?"},{"start":524.45,"end":526.48,"text":"לא, אני אהבל!"},{"start":526.48,"end":534.58,"text":"תגיד לי, הוא בכוונה עושה את זה?"},{"start":534.58,"end":536.62,"text":"הוא לא יודע, הוא לא מבין, מסכן."},{"start":536.62,"end":538.56,"text":"אה, מסכן."},{"start":538.56,"end":542.29,"text":"תגיד, אתה ראית את התוכנית \"Discovery\" על החור באוזון?"},{"start":542.29,"end":544.15,"text":"לא, לא, לא ראיתי תוכנית."},{"start":544.15,"end":548.15,"text":"יופי, ראית שעשו שם הניסוי ועשו חור בבצע."},{"start":548.15,"end":551.1,"text":"עכשיו יצא שהצהוב יצא לפני הלבן, איך זה?"},{"start":551.1,"end":552.34,"text":"אה, אתה לא הבנת את הניסוי."},{"start":552.34,"end":555.34,"text":"הרי הם לקחו את הבצע, הבצע זה כמו כדור הארץ, נכון?"},{"start":555.34,"end":557.34,"text":"עכשיו מה יש מסביב לכדור הארץ?"},{"start":557.34,"end":560.87,"text":"ארצות הברית, אמסטרדה."},{"start":560.87,"end":561.87,"text":"לונדון וכל שם."},{"start":561.87,"end":564.87,"text":"יופי, עכשיו הם לקחו את הבצע ועשו בחור למעלה."},{"start":564.87,"end":568.86,"text":"עכשיו כשהם הפכו יצא שהצהוב יצא לפני הלבן."},{"start":568.86,"end":570.41,"text":"מאיפה? -מה בצעה."},{"start":570.41,"end":572.39,"text":"איזה בצעה?"},{"start":572.39,"end":574.39,"text":"שלחור באוזון, בדיסקברי."},{"start":574.39,"end":575.93,"text":"אה, מצאו אותה."},{"start":575.93,"end":576.93,"text":"את מי? את אשתך."},{"start":576.93,"end":578.25,"text":"מה יש לה?"},{"start":578.25,"end":580.37,"text":"ממסכנה, הרי הילדה לא הרגישה טוב, לקחת אותה לאשפוס."},{"start":580.37,"end":583.37,"text":"אני מסכנה, אשתי, הילדה לא הרגישה טוב."},{"start":583.37,"end":586.37,"text":"ארבע שעות באשפוס, זה מרץ כמו משוגע מחלקה נרבולוגית."},{"start":586.37,"end":588.37,"text":"מסכנה, אשתי, הילדה לא הרגישה טוב."},{"start":588.37,"end":590.29,"text":"מיזמין הפוך?"},{"start":590.29,"end":597.56,"text":"אמנו, מבקשה."},{"start":597.56,"end":600.93,"text":"אתה מודע לזה שנסעת במהירות מופרזת?"},{"start":600.93,"end":604.01,"text":"תרשום, נסע במהירות מופרזת."},{"start":604.01,"end":604.99,"text":"תרשום, נסע במהירות מופרזת."},{"start":604.99,"end":608.03,"text":"תרשום, נסע במהירות."},{"start":608.03,"end":609.12,"text":"תרשום, נסע במהירות."},{"start":609.12,"end":611.82,"text":"תרשום, נסע."},{"start":611.82,"end":614.4,"text":"תרשום, נסע, תרשום, לא, מה?"},{"start":614.4,"end":615.4,"text":"נסע זה עם סבמן או..."},{"start":615.4,"end":617.72,"text":"טוב, יאללה, בחור, יאללה."},{"start":617.72,"end":619.91,"text":"סעסע, תפס אותנו ביום טוב, סעסע."},{"start":619.91,"end":628.72,"text":"יום טוב לך, דומה מנוע, בבקשה?"},{"start":628.72,"end":630.52,"text":"מה קורה?"},{"start":630.52,"end":632.52,"text":"יום טוב, יש לך נהירות?"},{"start":632.52,"end":634.52,"text":"למה יש לך משהו לגלגל?"},{"start":634.52,"end":636.61,"text":"מתחכם, אה?"},{"start":636.61,"end":637.61,"text":"תעודות, תעודות."},{"start":637.61,"end":644.3,"text":"בלתי מספיק בתושבה?"},{"start":644.3,"end":646.36,"text":"לא, לא, אתה מסתכל לשלי שאלת."},{"start":646.36,"end":648.64,"text":"צריך להשתפר בבית."},{"start":648.64,"end":650.28,"text":"כך את זה."},{"start":650.28,"end":652.24,"text":"תבוא מחר לתחנה המשטרה עם ההורים."},{"start":652.24,"end":653.36,"text":"שלום חבילה."},{"start":653.36,"end":654.36,"text":"סע, סעלים פה."},{"start":654.36,"end":655.36,"text":"או, אתה!"},{"start":655.36,"end":657.36,"text":"סליחה שהתעקבתי."},{"start":657.36,"end":658.36,"text":"מי הזמין פילטר?"},{"start":658.36,"end":664.42,"text":"סליחה, מישהו יכול לעזור לנו כאן?"},{"start":664.42,"end":665.42,"text":"כן, בבקשה."},{"start":665.42,"end":667.48,"text":"רציתי לדעת, מה את זה בן זה לזה?"},{"start":667.48,"end":670.86,"text":"זה יפני וזה דרום אמריקאי."},{"start":670.86,"end":672.86,"text":"יפני יפני או יפני דרום קוריאה?"},{"start":672.86,"end":673.86,"text":"לא, לא, יפני יפני."},{"start":673.86,"end":675.98,"text":"יש לזה אבא ואימא והכל כמו שצריך."},{"start":675.98,"end":676.98,"text":"אחריות?"},{"start":676.98,"end":678.98,"text":"אחריות כמו שצריך, אחריות לשנה."},{"start":678.98,"end":681.2,"text":"המחיר שרשום זה מחיר מזומן?"},{"start":681.2,"end":684.2,"text":"זה מחיר מזומן ואפשר משישת השלומים בלי ריבית ובלי עצמנה."},{"start":684.2,"end":685.2,"text":"בלי עצמנה."},{"start":685.2,"end":686.2,"text":"אז זה אשראה וזה אין בעיה."},{"start":686.2,"end":687.2,"text":"אין בעיה."},{"start":687.2,"end":689.2,"text":"אני רציתי לדעת, מה הייתה ממליץ?"},{"start":689.2,"end":692.29,"text":"אני הייתי ממליץ על הדרום אמריקאי."},{"start":692.29,"end":696.29,"text":"בסך הכל אנחנו רוצים סוס, אבל אנחנו רוצים משהו שיחזיק מעמד."},{"start":696.29,"end":699.32,"text":"זה סוס עבודה, זה פשוט אחלה של מוצר."},{"start":699.32,"end":703.82,"text":"ויש לנו מבצע לזה, שלוש שנים אחריות, זה ממש מבצע לשבוע."},{"start":703.82,"end":706.82,"text":"ואנחנו רוצים אבל חדש, לא מתעצוגה, כן?"},{"start":706.82,"end":707.82,"text":"לא, לא חדילה."},{"start":707.82,"end":708.82,"text":"ויש צבעים אחרים?"},{"start":708.82,"end":711.82,"text":"יש, יש גם בבש ויש גם בירוק."},{"start":711.82,"end":712.82,"text":"אז פקה מיידית?"},{"start":712.82,"end":713.82,"text":"כן, תוך יום יומיים."},{"start":713.82,"end":717.36,"text":"מה אתם לראים?"},{"start":717.36,"end":719.36,"text":"אנחנו נחזור יותר מאוחר, אני רוצה לשאול כך."},{"start":719.36,"end":721.58,"text":"אני מביאים טוב בגברים האלה."},{"start":721.58,"end":722.71,"text":"אוקיי, מתי אתם סוגרים?"},{"start":722.71,"end":726.71,"text":"אוקיי, אנחנו יכול להיות שעוד נחזור, בסדר?"},{"start":726.71,"end":728.71,"text":"תודה בכל אופן."},{"start":728.71,"end":729.71,"text":"שלום, שלום."},{"start":729.71,"end":730.71,"text":"תודה."},{"start":730.71,"end":731.86,"text":"מה זה?"},{"start":731.86,"end":732.86,"text":"תגיד לי, זה מצחיק אותך?"},{"start":732.86,"end":733.86,"text":"אני לא מבין את זה אפילו."},{"start":733.86,"end":736.34,"text":"מה יש להבין? זה לא מצחיק כל כך."},{"start":736.34,"end":739.34,"text":"תגיד לי, אני נמאס לי להגור בסחירות, אני רוצה לעבור דרה."},{"start":739.34,"end":741.33,"text":"איך אני עושה עם המשקנתה?"},{"start":741.33,"end":744.33,"text":"זה נורא פשוט, אתה לוקח את המשקנתה שלך, אתה הולך לבנק יאהב,"},{"start":744.33,"end":747.33,"text":"ואתה אומר להם שאתה רוצה משקנתה, הם נותנים לך 40 אלף דולר ממשלתי,"},{"start":747.33,"end":752.33,"text":"אתה הולך את זה, אתה צריך משלימה, אתה לוקח שלושה ערבים, אתה חייב לבנק ירושלים,"},{"start":752.33,"end":756.33,"text":"אתה לוקח מבנק ירושלים שהשמת את השלושה ערבים, מפקיד אותם בבנק שלך,"},{"start":756.33,"end":763.33,"text":"עכשיו, אחרי שאפקדת אותם, אתה מקבל חוזה מבנק ירושלים, שעימא ערת זהרה שהקבלן מתחייב לתת לך את הכל הקרמיקה,"},{"start":763.33,"end":769.33,"text":"עימא ארבע דוגמאות מעל הברז, חרי שקיבלת את כל הזה, אתה לוקח ואתה צריך את הכסף, את המזומן של הדולר,"},{"start":769.33,"end":773.32,"text":"אולי אתה חייב לקח מהבנק שלך, הבנק שלך, איפה אתה גר בדיוק?"},{"start":773.32,"end":774.42,"text":"אני גר בזכירות."},{"start":774.42,"end":775.93,"text":"עם מי?"},{"start":775.93,"end":777.18,"text":"המשתך?"},{"start":777.18,"end":782.18,"text":"עם הילדה, הילדה המסכנה, אשתי לא הרגיש אותו בערבה שעות בהשפוץ, זה מרס כמו משוגה, מחלקה נורבולוגית,"},{"start":782.18,"end":787.56,"text":"מסכנה אשתי, כי אתה נשמה, הילדה מסכנה לא הרגיש אותו כמו משוגה, ארבע שעות, מסתובב."},{"start":787.56,"end":793.08,"text":"הוא חולה בראש."},{"start":793.08,"end":795.08,"text":"בוא, בוא, בוא, בוא, תספר לי מה הבעיה שלך."},{"start":795.08,"end":798.08,"text":"איזה בעיה, ד\"ר בלושי, אין שום בעיה."},{"start":798.08,"end":800.08,"text":"באתי להגיד לך תודה רבה."},{"start":800.08,"end":802.08,"text":"אחרי עשרים שנה של טיפול מסור,"},{"start":802.08,"end":803.08,"text":"אני סוף סוף נרפאתי."},{"start":803.08,"end":806.08,"text":"אני יודע שאני לא נפוליאון."},{"start":806.08,"end":808.08,"text":"תודה רבה לך להתראות."},{"start":808.08,"end":811.28,"text":"אלוהים."},{"start":811.28,"end":813.14,"text":"קראת לי?"},{"start":813.14,"end":824.68,"text":"ושוב על פרסומות מביא לי תחלסטרה."},{"start":824.68,"end":825.68,"text":"מה נעשי ככה זה?"},{"start":825.68,"end":828.74,"text":"הפרסומת שגמרה לי את החיים זה הפרסומת הזאת."},{"start":828.74,"end":829.74,"text":"כדלי קלמן, שימו לב."},{"start":829.74,"end":831.7,"text":"אתה רעב?"},{"start":831.7,"end":835.48,"text":"תחשוב קוטיץ'"},{"start":835.48,"end":837.31,"text":"מה הם התחרפינו?"},{"start":837.31,"end":839.31,"text":"מה הם לפלפים?"},{"start":839.31,"end":841.31,"text":"אני רעב, אני חושב פרה"},{"start":841.31,"end":843.31,"text":"על האש מנפנף אותה"},{"start":843.31,"end":845.31,"text":"ותוקח שיפודים בכל מקום"},{"start":845.31,"end":847.31,"text":"מה קרה להם?"},{"start":847.31,"end":849.31,"text":"אם רעב, אז להרביץ אותה"},{"start":849.31,"end":856.44,"text":"הפעם גבירותיי ורבותיי"},{"start":856.44,"end":858.44,"text":"שוב פרסומות גבינה"},{"start":858.44,"end":860.44,"text":"ושוב החלסטרה עולה לי בהדרגה"},{"start":860.44,"end":862.37,"text":"ושוב לא כדאי להיות לידי"},{"start":862.37,"end":864.73,"text":"פרסומת לגבינה מעודנית"},{"start":864.73,"end":866.88,"text":"רואים פועלי בניין"},{"start":866.88,"end":868.88,"text":"מסרחים"},{"start":868.88,"end":870.88,"text":"עם זקן, עם ג'יפה"},{"start":870.88,"end":872.88,"text":"ומה הוא אוהל"},{"start":872.88,"end":874.88,"text":"פרוסה עם גבינה לבנאי"},{"start":874.88,"end":876.88,"text":"ולא מספיק זה"},{"start":876.88,"end":878.88,"text":"הוא פותח ספר"},{"start":878.88,"end":880.91,"text":"של מה?"},{"start":880.91,"end":882.94,"text":"של פועימה"},{"start":882.94,"end":885.0,"text":"מה זה?"},{"start":885.0,"end":887.0,"text":"הוא קורא שובי רב שובי ציפור"},{"start":887.0,"end":889.0,"text":"מה זה אחרת הזה?"},{"start":889.0,"end":891.0,"text":"מה קורה פה?"},{"start":891.0,"end":893.0,"text":"שיפתחו לחמניה"},{"start":893.0,"end":895.31,"text":"ישימו עריסה עם שנוויץ"},{"start":895.31,"end":898.23,"text":"ושיקרא פטריקים"},{"start":898.23,"end":898.33,"text":"זה ברור? תחשבו על זה"},{"start":898.23,"end":898.33,"text":"הרצח"},{"start":898.23,"end":904.8,"text":"כן כן כן"},{"start":904.8,"end":905.8,"text":"בוא בוא בוא בוא נתחיל מההתחלה"},{"start":905.8,"end":906.8,"text":"מה הבעיה שלך?"},{"start":906.8,"end":908.86,"text":"אני לא יודע מה לעשות דוקטור בלושי"},{"start":908.86,"end":910.86,"text":"אני מרגיש שיש לי משיכה מינית לחתולים"},{"start":910.86,"end":914.2,"text":"משיכה מינית לחתולים?"},{"start":914.2,"end":916.2,"text":"חתולים סחרים או חתולים נקבות?"},{"start":916.2,"end":918.26,"text":"בטח נקבות מה אני אומו?"},{"start":918.26,"end":923.76,"text":"אבי"},{"start":923.76,"end":925.21,"text":"כן בני"},{"start":925.21,"end":927.61,"text":"חתתי"},{"start":927.61,"end":929.66,"text":"דבר"},{"start":929.66,"end":932.12,"text":"בני"},{"start":932.12,"end":933.12,"text":"אתמול הלכתי לים"},{"start":933.12,"end":934.98,"text":"כן"},{"start":934.98,"end":937.23,"text":"וראיתי סתירה"},{"start":937.23,"end":940.22,"text":"קבל סתירה"},{"start":940.22,"end":945.61,"text":"ואחרי זה הלכתי לנמל"},{"start":945.61,"end":947.95,"text":"כן"},{"start":947.95,"end":948.95,"text":"וראיתי מנוף"},{"start":948.95,"end":950.4,"text":"קבל אגרוף"},{"start":950.4,"end":955.62,"text":"קבל אגרוף"},{"start":955.62,"end":956.74,"text":"ואחרי זה"},{"start":956.74,"end":957.74,"text":"שני חברים שלי"},{"start":957.74,"end":959.12,"text":"צוות אותי וקוט אותי"},{"start":959.12,"end":960.5,"text":"הלכו לים"},{"start":960.5,"end":962.14,"text":"קוט אותי טבע"},{"start":962.14,"end":963.14,"text":"מי נשאר?"},{"start":963.14,"end":969.23,"text":"אבי ברך אותי"},{"start":969.23,"end":974.74,"text":"קוו קוו דלה אומה"},{"start":974.74,"end":976.74,"text":"קוו קוו קוו"},{"start":976.74,"end":979.92,"text":"טרסימן טריקו"},{"start":979.92,"end":980.92,"text":"טריקו"},{"start":980.92,"end":983.23,"text":"טריקו טריקו טרע"},{"start":983.23,"end":984.35,"text":"ולו"},{"start":984.35,"end":985.41,"text":"ולו"},{"start":985.41,"end":986.41,"text":"ולו"},{"start":986.41,"end":988.41,"text":"ולו ולו ולו ולו"},{"start":988.41,"end":989.41,"text":"ולו"},{"start":989.41,"end":990.41,"text":"חד שתיים שלות"},{"start":990.41,"end":991.41,"text":"חד שתיים"},{"start":991.41,"end":992.41,"text":"תצרו אותי אה?"},{"start":992.41,"end":993.41,"text":"אה?"},{"start":993.41,"end":994.41,"text":"אתה רצית להצבוע אותי?"},{"start":994.41,"end":995.41,"text":"מי נשאר?"},{"start":995.41,"end":996.41,"text":"מי נשאר?"},{"start":996.41,"end":997.41,"text":"מי נשאר?"},{"start":997.41,"end":998.41,"text":"מי נשאר?"},{"start":998.41,"end":1002.42,"text":"מה בשבילך אדוני?"},{"start":1002.42,"end":1003.45,"text":"פול בבקשה"},{"start":1003.45,"end":1004.45,"text":"פול מיד"},{"start":1004.45,"end":1007.11,"text":"בבקשה אדוני"},{"start":1007.11,"end":1009.2,"text":"חסר לי קצת שמן"},{"start":1009.2,"end":1010.2,"text":"נוסיף?"},{"start":1010.2,"end":1012.23,"text":"אין בעיה שוב היה אדוני"},{"start":1012.23,"end":1013.23,"text":"בבקשה"},{"start":1013.23,"end":1015.89,"text":"שלום אדוני"},{"start":1015.89,"end":1016.89,"text":"תודה רבה"},{"start":1016.89,"end":1018.01,"text":"ורותיי ורותיי"},{"start":1018.01,"end":1020.01,"text":"גם בשבוע שעבר הייתה ממחידה"},{"start":1020.01,"end":1023.01,"text":"היו לנו המון המון מכתבים ויש לנו גב זוכה"},{"start":1023.01,"end":1025.01,"text":"בואו נעבור לטקס הענקת הפרס"},{"start":1025.01,"end":1027.01,"text":"כרטיס תישרה לאירופה"},{"start":1027.01,"end":1030.73,"text":"בבקשה"},{"start":1030.73,"end":1037.74,"text":"היינו רוצים להעניק את הפרס לזוכה בשעשוון האחרון"},{"start":1037.74,"end":1039.92,"text":"והיא..."},{"start":1039.92,"end":1041.98,"text":"רונה"},{"start":1041.98,"end":1046.42,"text":"היינו רוצים לשאול את רונה, רונה מה התשובה?"},{"start":1046.42,"end":1050.42,"text":"בול בול בול בול בול בול בול בול בול בול בול בול"},{"start":1050.42,"end":1060.7,"text":"וואלה יש לי אחד"},{"start":1060.7,"end":1061.67,"text":"יוסי נגר?"},{"start":1061.67,"end":1062.88,"text":"לא!"},{"start":1062.88,"end":1063.88,"text":"יוסי בני!"},{"start":1063.88,"end":1064.88,"text":"לא!"},{"start":1064.88,"end":1065.88,"text":"בני!"},{"start":1065.88,"end":1066.88,"text":"אה!"},{"start":1066.88,"end":1068.88,"text":"תכנעלה יש לי יש לי יש לי"},{"start":1068.88,"end":1069.82,"text":"משה ירקן?"},{"start":1069.82,"end":1071.13,"text":"לא!"},{"start":1071.13,"end":1073.13,"text":"לא!"},{"start":1073.13,"end":1074.13,"text":"לא!"},{"start":1074.13,"end":1075.13,"text":"לא!"},{"start":1075.13,"end":1076.13,"text":"לא!"},{"start":1076.13,"end":1077.13,"text":"יש לי יש לי!"},{"start":1077.13,"end":1079.09,"text":"יעקב פקיד!"},{"start":1079.09,"end":1080.09,"text":"לא!"},{"start":1080.09,"end":1081.09,"text":"יעקב שמי!"},{"start":1081.09,"end":1083.09,"text":"לא!"},{"start":1083.09,"end":1085.09,"text":"יש לי יש לי יש לי!"},{"start":1085.09,"end":1086.09,"text":"יש לי יש לי!"},{"start":1086.09,"end":1087.09,"text":"חיים רמון!"},{"start":1087.09,"end":1088.21,"text":"לא!"},{"start":1088.21,"end":1090.21,"text":"חיים עברפן!"},{"start":1090.21,"end":1134.89,"text":"לא!"},{"start":1134.89,"end":1135.89,"text":"שוין!"},{"start":1135.89,"end":1136.92,"text":"לא שווה בכלל!"},{"start":1136.92,"end":1138.1,"text":"תגיד מה יש עכשיו?"},{"start":1138.1,"end":1140.1,"text":"עכשיו יש את האו עם האקטואליה"},{"start":1140.1,"end":1141.1,"text":"עם השולחן!"},{"start":1141.1,"end":1142.11,"text":"מי?"},{"start":1142.11,"end":1144.11,"text":"זה שאשתו עם..."},{"start":1144.11,"end":1145.11,"text":"עכשיו?"},{"start":1145.11,"end":1146.11,"text":"לא! קודם יש את הפרסומות"},{"start":1146.11,"end":1148.11,"text":"עם הקוטג שהיא אוכלת את הגבינה"},{"start":1148.11,"end":1150.11,"text":"ועפה להם הילדים עם השלוק"},{"start":1150.11,"end":1152.11,"text":"שהוא לוקח אותו עם התפוח"},{"start":1152.11,"end":1153.11,"text":"רצה..."},{"start":1153.11,"end":1155.11,"text":"השם שלו מתחיל בג'"},{"start":1155.11,"end":1157.07,"text":"אה! זה שעה בלקה של הדבורים!"},{"start":1157.07,"end":1158.07,"text":"כן! זהו! אבל לא!"},{"start":1158.07,"end":1160.07,"text":"אבל הוא בתוכנית אחרי!"},{"start":1160.07,"end":1161.07,"text":"יש לפניו את האו!"},{"start":1161.07,"end":1163.0,"text":"שחליבו לו את השולחן!"},{"start":1163.0,"end":1164.1,"text":"עם המשקפיים!"},{"start":1164.1,"end":1168.8,"text":"שישתו נוע עם הזה, נוע, השם שתו מתחיל בחוטנר."},{"start":1168.8,"end":1177.18,"text":"-טוטנר? -טוטנר, לא, לא טוטנר, יוד, יודנר, יוטנר, יוטנר."}]