[{"start":21.09,"end":37.28,"text":"אלה קורא נסדור!"},{"start":37.28,"end":52.77,"text":"נסע לביתנו."},{"start":52.77,"end":55.24,"text":"מה אני נעשה במועד מאוחר יותר? תודה."},{"start":55.24,"end":56.84,"text":"אתה שומע, אני ממש תקוע,"},{"start":56.84,"end":59.87,"text":"כי אני לא יכול מחר בשש וחצי לבוא לחזרה, לא יכול."},{"start":59.87,"end":61.16,"text":"חבל, חבל, חבל."},{"start":61.16,"end":61.66,"text":"למה?"},{"start":61.66,"end":64.4,"text":"כי אנחנו סיכמנו כמה אנשים שנעשה את כל העניין הזה"},{"start":64.4,"end":65.74,"text":"בראש ובראשונה, כן?"},{"start":65.74,"end":68.24,"text":"ואתה, אם אתה מגיע, אתה דופק את העסק, אתה דופק את העסק."},{"start":68.24,"end":71.12,"text":"אני לא יודע מה לעשות, גיל, אני חכה שנייה, אני בממתינה, בסדר?"},{"start":71.12,"end":72.36,"text":"ידר, אני אמתין לך, נו."},{"start":72.36,"end":72.92,"text":"מי זה?"},{"start":72.92,"end":77.48,"text":"סגר, מה אני... -אה, סגר, מה אתה? מה אתה? איפה אתה? אני מדהים לעשות את טלפונים. מה?"},{"start":77.48,"end":82.36,"text":"אינו, אז מה אני יכול? אני מגיע, בשני, אני מגיע. -אהו, בשני, אני גם חפזתי אותו עם סולו דש."},{"start":82.36,"end":86.56,"text":"בסדר, סתפתי, בסדר? אני אחזור עליך, בסדר? -אבל מה ירקה, סך חדחו. -אבל מה ירקה, סך חדחו. -רגע, אוקיי, תגיל לי."},{"start":86.56,"end":91.89,"text":"גילי. -מה לא? -כן. -מה קורה, בסדר? -שמע, אני רוצה להגיד לך משהו, אני לא יודע מה לעשות."},{"start":91.89,"end":95.25,"text":"אני הייתי מבקש אם אתה יכול לדוג להזיז את זה יותר מאוחר."},{"start":95.25,"end":99.77,"text":"סדר, סדר, תעשה כמה טלפונים ואני תגמור. -אוקיי, תגמור את זה ואני..."},{"start":99.77,"end":104.12,"text":"סגב, סגב, סגב, סגב, סגב!"},{"start":104.12,"end":109.63,"text":"ואללה, לא שומעי, יאללה, ססובר, ססוב, ססוב, ססוב!"},{"start":109.63,"end":116.08,"text":"ידע, בוא נה, אי אפשר לדבר עם... רובי, קייני לי, רובי!"},{"start":116.08,"end":123.16,"text":"מה את... בוא נה, זה סגב, זה לא קולה את הג'יפה הזה, אני לא מאמין, אי אפשר לדבר עם אנשים פה, יאללה, נו."},{"start":123.16,"end":144.73,"text":"אם אתה אהבתי, הייתה יפה כל כך, היה לבושה, העיניים, תחלואה, לקודם כל תלמד, תשאיר את התלתן כך."},{"start":144.73,"end":189.01,"text":"שבתי לי מה יש לי, אני שאת בה יש לי, שלא הוא עשי קול בחורה."},{"start":189.01,"end":277.04,"text":"רותי והימי פרדס חן, שאורתי גם בפיפר, טוטליק לא די אסיכר."},{"start":277.04,"end":332.09,"text":"אתראות, אני אתקשר אחר כך."},{"start":332.09,"end":333.21,"text":"אה, לצביקה?"},{"start":333.21,"end":336.17,"text":"אה, מה אני נמסיך? -בחיאת, אני חייב טלפון דחוף, תן לי את הפלפון. - בקשה."},{"start":336.17,"end":337.09,"text":"תודה."},{"start":337.09,"end":339.55,"text":"פשוט, אני שעה, מנסה."},{"start":339.55,"end":344.69,"text":"לא מאמין תפוס, יש לנודניק פה? -יש לנודניק, איתי! איתי נודניק!"},{"start":344.69,"end":356.67,"text":"איי, מה אני, בוא נשחק, בוא, אמרת לך, בוא נלך, בוא נלך, בוא נלך הרע שלי, בוא נלך שחק, בוא נלך שחק, נו, אל תהיה כזה, נו, איזה מגיל אתה. -לא, בוא כבר, נו, בוא, יש!"},{"start":356.67,"end":360.63,"text":"ערב טוב וברוכים הבאים לתוכניתנו, עץ בעל הדופק."},{"start":360.63,"end":364.39,"text":"כמידי שבוע, אנו מערכים תופעות חריגות בחברה הישראלית."},{"start":364.39,"end":367.59,"text":"אנשים שבחרו בדרך חיים שונה מהמקובל."},{"start":367.59,"end":371.1,"text":"כאלה שאומרים, לא, אנחנו לא כמו כולם, אנחנו שונים."},{"start":371.1,"end":375.34,"text":"והפעם בתוכניתנו, זוג הטרוסקסואלי."},{"start":375.34,"end":379.43,"text":"הוא גבר, היא אישה, והם חיים באותה דירה,"},{"start":379.43,"end":383.01,"text":"חולקים חדר משותף ואף ישנים באותה מיטה."},{"start":383.01,"end":385.73,"text":"הם כמובן בחרו לא לחשף יתר על המידה,"},{"start":385.73,"end":389.57,"text":"לכן אנחנו הסוונו את פניהם ואף נפנה אליהם בשמות בדוגים."},{"start":389.57,"end":392.07,"text":"אמנון ותמר, ערב טוב לכם."},{"start":392.07,"end":392.87,"text":"ערב טוב."},{"start":392.87,"end":394.99,"text":"ערב טוב, אני רק רוצה לומר בהסוונות הזאת"},{"start":394.99,"end":401.53,"text":"שאם כבר אנחנו מופיעים בטלוויזיה אז אנחנו פשוט החלטנו להיחסי."},{"start":401.53,"end":404.18,"text":"כל הכבוד, אנחנו איתכם."},{"start":404.18,"end":406.56,"text":"לטובת כלל החברה האטרוסקסואלית."},{"start":406.56,"end":410.43,"text":"אמנון ותמר, אתם מקיימים יחסי מין?"},{"start":410.43,"end":412.68,"text":"כן."},{"start":412.68,"end":415.9,"text":"תמר, האם אורייך יודעים שאת בעצם..."},{"start":415.9,"end":418.81,"text":"זאת אומרת, אם להשתמש בשפה הנהוגה בקהיליה שלכם,"},{"start":418.81,"end":420.8,"text":"הם יודעים שאת סטרייטית?"},{"start":420.8,"end":424.21,"text":"אמא שלי ובת זוגתה לא יודעות,"},{"start":424.21,"end":428.85,"text":"אבל אבא שלי ואשתו, יעקב, הם יודעים ותומכים בי."},{"start":428.85,"end":433.08,"text":"אמנון, אתה בעצם נולדת גבר ונשארת כך עד היום."},{"start":433.08,"end":435.14,"text":"מתי הרגשת שאתה שונה?"},{"start":435.14,"end":439.06,"text":"תראה, אצלי זה התחיל עוד כשהייתי ילד."},{"start":439.06,"end":442.4,"text":"התחלתי להימשך למשחקים מוזרים,"},{"start":442.4,"end":447.18,"text":"אהבתי טרקטורים, כדורגל, מכוניות."},{"start":447.18,"end":452.57,"text":"ובגיל ההתבגרות הייתי בורח לגנים ציבוריים,"},{"start":452.57,"end":454.73,"text":"והייתי מתעסק עם בחורות."},{"start":454.73,"end":456.19,"text":"בחורות."},{"start":456.19,"end":462.49,"text":"אני רק רוצה בהזדמנות הזאת לומר שזה פשוט נורא לכל מקום שאנחנו הולכים,"},{"start":462.49,"end":466.65,"text":"נורמים סטרייטים, סטרייטים, אחורה גב, אחורה גב, לא אומרים את זה בפנים."},{"start":466.65,"end":469.69,"text":"זה לא שאנשים באים ואומרים, אחורה גב, סטרייטים, הנורמלים האלה."},{"start":469.69,"end":471.21,"text":"אנחנו כמו כולם."},{"start":471.21,"end":473.98,"text":"כמו כולם, אצל הערכן, במקולת, אין הבדל."},{"start":473.98,"end":477.49,"text":"אנחנו לא שונים, אנחנו לא שונים, אומרים אמנון ותמר."},{"start":477.49,"end":480.37,"text":"ענה, חברה, קבלי אותנו עזרותייך הפתוחות."},{"start":480.37,"end":482.77,"text":"אנחנו נשמע, מה אתם שם בבית אומרים?"},{"start":482.77,"end":485.57,"text":"אנחנו מחכים לטלפונים של המאזינים."},{"start":485.57,"end":487.13,"text":"הנה, אני חושב שיש לי מישהו על הקו."},{"start":487.13,"end":488.01,"text":"הלואו?"},{"start":488.01,"end":489.05,"text":"הלואו, שלום."},{"start":489.05,"end":489.89,"text":"הלואו, שלום."},{"start":489.89,"end":491.21,"text":"מי אתה ומינין אתה?"},{"start":491.21,"end":492.77,"text":"רענן ביזר."},{"start":492.77,"end":494.59,"text":"שלום לך רענן, מינין אתה?"},{"start":494.59,"end":495.83,"text":"מעלך וביזר."},{"start":495.83,"end":497.43,"text":"ערב טוב לך רענן."},{"start":497.43,"end":498.23,"text":"ערב טוב לך."},{"start":498.23,"end":503.8,"text":"דבר ראשון, אני הייתי מעוניין לחזק את עידיהם של הצמד הנחמד הזה שהחליט לחשוף את עצמו."},{"start":503.8,"end":504.48,"text":"תודה רענן."},{"start":504.48,"end":505.24,"text":"תודה רבה."},{"start":505.24,"end":506.28,"text":"כל הכבוד לכם."},{"start":506.28,"end":506.8,"text":"תודה."},{"start":506.8,"end":512.13,"text":"ואני, גם אני, אני מוכרח להודות, אני כבר כמה שנים מקיים,"},{"start":512.13,"end":520.48,"text":"אמנם זה מוזר סקס, אני מקיים יחסים עם עצמים, עצמים בבית שלי, כן?"},{"start":520.48,"end":523.86,"text":"רק בזמן האחרון אני התחלתי לעשות את זה עם נעלי הבית שלי."},{"start":523.86,"end":528.82,"text":"אה, עירענן, סליחה שאני קוטע אותך, התוכנית על משיכה לנעלי בית ושער חפצים,"},{"start":528.82,"end":532.34,"text":"הייתה בשבוע שעבר, התוכנית הזו דנה בהטרוסקסואלית."},{"start":532.34,"end":536.42,"text":"לא, ברור לי, ברור לי, רק הנעלי בית האלה, הם ממין נקבה."},{"start":536.42,"end":540.02,"text":"זה לא משנה שום עובדה, אני בקשת לתק, חבל על הזמן."},{"start":540.02,"end":547.49,"text":"לא, לא, זה עם ריצ'ראץ', אלו, זה עם נעליים עם ריצ'ראץ', אני לא מדבר איתך על הסקוצ'ים, זה עם ריצ'ראץ', זה בלי עקב, אלו, אלו, להתראות."},{"start":547.49,"end":552.43,"text":"אני חושב שהוא צריך להיות תמיד וללכת עם הדברים שהוא מאמין בהם."},{"start":552.43,"end":556.2,"text":"תעקב אחרי לבך, ככה אנחנו אומרים לכולם."},{"start":556.2,"end":561.6,"text":"תודה רבה לך, רענן, תודה רבה לכם הצופים שהייתם ממנו, תודה לכם, אמנון ותמר."},{"start":561.6,"end":567.84,"text":"היו איתנו גם בשבוע הבא, במערך ישראלים שאוהבים חומוס."},{"start":567.84,"end":570.48,"text":"ביי ביי, היו איתנו בשבוע הבא להתראות."},{"start":570.48,"end":574.22,"text":"ואנחנו חשבנו שאנחנו נפלא נורא."},{"start":574.22,"end":582.68,"text":"שלום לך אדוני, הרשי לי להציג לך את השירותים החדשים של חברת \"בזק\"."},{"start":582.68,"end":586.24,"text":"אה, לא, סליחה."},{"start":586.24,"end":594.98,"text":"אה, ילד!"},{"start":594.98,"end":595.75,"text":"מה?"},{"start":595.75,"end":599.87,"text":"בטוח אתה שאתה רוצה לדעת מה צופן לך עתידך."},{"start":599.87,"end":605.2,"text":"תמיד חלמתי להיות אצל מגדת עתידות וחוץ מזה מוצחן זכותית, יש לי זה פשוטית."},{"start":605.2,"end":610.38,"text":"אני רואה, נבחן!"},{"start":610.38,"end":612.3,"text":"נכון, מחר יש לי מיטה."},{"start":612.3,"end":616.83,"text":"אתה תקבל טוב מאוד."},{"start":616.83,"end":619.25,"text":"זה יכול להיות."},{"start":619.25,"end":624.1,"text":"ילד, אני רואה את אמא שלך."},{"start":624.1,"end":629.13,"text":"אמא שלך תזכה במבצע, נושא פרסים ילד."},{"start":629.13,"end":633.46,"text":"או זה! או לא!"},{"start":633.46,"end":635.7,"text":"אני רואה את אביכה!"},{"start":635.7,"end":640.17,"text":"אתה אוהב את אביכה, ילד!"},{"start":640.17,"end":643.21,"text":"אביכה ישבור רגל!"},{"start":643.21,"end":648.21,"text":"נושא פרסים ילד."},{"start":648.21,"end":652.42,"text":"נושא פרסים ילד."},{"start":652.42,"end":654.42,"text":"מה, אתה קיבלת טוב מאוד במולדת?"},{"start":654.42,"end":655.42,"text":"כן!"},{"start":655.42,"end":656.42,"text":"מזל טוב."},{"start":656.42,"end":658.42,"text":"אבל זה לא בגלל המגטת עתידות, זה בגלל חד."},{"start":658.42,"end":659.42,"text":"כן, לכן."},{"start":659.42,"end":660.42,"text":"כן, לכן."},{"start":660.42,"end":662.42,"text":"אז עכשיו קיבלתי בלתי מספיק עובדה."},{"start":662.42,"end":663.42,"text":"זה צירוף מקרים."},{"start":663.42,"end":664.42,"text":"רק צירוף."},{"start":664.42,"end":665.42,"text":"את אמין לי בשטויות."},{"start":665.42,"end":667.42,"text":"שלום גברת לוי."},{"start":667.42,"end":668.42,"text":"כן."},{"start":668.42,"end":670.42,"text":"את השתתפת במבצע של חברת ביוטי וומן."},{"start":670.42,"end":671.42,"text":"כן."},{"start":671.42,"end":675.42,"text":"לבשר לה שזכית בטלושים עסך אלפיים שקלים לקניית מוצרי קוסמטיקה."},{"start":675.42,"end":676.42,"text":"לא נכון."},{"start":676.42,"end":677.58,"text":"כן, כן."},{"start":677.58,"end":678.58,"text":"תודה."},{"start":678.58,"end":679.58,"text":"בבקשה."},{"start":679.58,"end":680.58,"text":"תודה, תודה רבה, תודה רבה."},{"start":680.58,"end":682.58,"text":"זכיתי בטלושים ב..."},{"start":682.58,"end":683.67,"text":"מי זה?"},{"start":683.67,"end":685.21,"text":"זכיתי בפרס."},{"start":685.21,"end":686.17,"text":"מה סלטו?"},{"start":686.17,"end":688.34,"text":"לא, לא, לא, אבל זה בדיוק מה שהמגד..."},{"start":688.34,"end":689.34,"text":"זה, זה..."},{"start":689.34,"end":691.34,"text":"שאולה, שאולה, שאולה, אתה לא קמה כיסה."},{"start":691.34,"end":693.34,"text":"שאולה, אתה לא קמה כיסה, שאולה."},{"start":693.34,"end":695.34,"text":"היא גם אמרה שהאבא שלי..."},{"start":695.34,"end":696.34,"text":"אבא, נשבור את הרגל."},{"start":696.34,"end":701.34,"text":"אבא, נשב, לא!"},{"start":701.34,"end":704.34,"text":"הוא יכול לזמור את הרגל כה המקיד את עתידות הבאית."},{"start":704.34,"end":706.34,"text":"אנחנו נטפל בכל הדברים בבית."},{"start":706.34,"end":708.34,"text":"אני אלך לבחור."},{"start":708.34,"end":712.34,"text":"לא! היא אמרה שהיא יקפל זאת מאוד."},{"start":712.34,"end":713.34,"text":"לא!"},{"start":713.34,"end":714.46,"text":"או, שלום לך."},{"start":714.46,"end":715.49,"text":"אלן."},{"start":715.49,"end":717.49,"text":"זה בסדר, זה רק חיים השחרן."},{"start":717.49,"end":718.56,"text":"חיים, אלן."},{"start":718.56,"end":719.68,"text":"אלברט, אתה יכול לבקשה לעזור לי?"},{"start":719.68,"end":721.68,"text":"יש לי שתי כיסאות פה למטה,"},{"start":721.68,"end":722.68,"text":"אם לא חפתך רק שנייה לרדת ולעזר."},{"start":722.68,"end":723.68,"text":"אין בעיה, מייד."},{"start":723.68,"end":724.68,"text":"אה!"},{"start":724.68,"end":726.68,"text":"מה קרה? מה קרה?"},{"start":726.68,"end":727.68,"text":"הו!"},{"sta