[{"start":5.41,"end":7.71,"text":"באמת, בחיית רעפקום, איפה הקריין שפותח את התוכנית?"},{"start":7.71,"end":9.71,"text":"זה תוכנית מיוחדת לפורים, מה קורה כאן?"},{"start":9.71,"end":11.21,"text":"- מה קורה כאן? - שלום."},{"start":11.21,"end":13.81,"text":"- אין לך? מה זה? - אתה הקריין."},{"start":13.81,"end":16.89,"text":"- הקריין? - תגיד לי, איך אתה לבוש?"},{"start":16.89,"end":18.97,"text":"- איך אתה לבוש? - מה זאת אומרת?"},{"start":18.97,"end":21.22,"text":"זה תוכנית מיוחדת חגיגית לפורים."},{"start":21.22,"end":23.01,"text":"- דגבורי? - הלו?"},{"start":23.01,"end":24.41,"text":"- הלו? - תראה, איך אתה לבוש?"},{"start":24.41,"end":26.01,"text":"אתה צריך להיות לבוש לך, קורי."},{"start":26.01,"end":27.42,"text":"- איך אתה לבוש? היא לא דגבורי."},{"start":27.42,"end":29.83,"text":"- לא משנה, תביאו לי קריין אחר."},{"start":29.83,"end":33.02,"text":"- הוא משנה, רגע, דגבורי, אכולו, אבוסקילה יכול לעשות רגע."},{"start":33.02,"end":34.2,"text":"אכול, לא עם עמודה?"},{"start":34.2,"end":35.41,"text":"- סדר."},{"start":35.41,"end":36.57,"text":"- הלטם בזה."},{"start":36.57,"end":41.75,"text":"- פלוכים הבאים למציבת פורים של הקרומד היסטורי, יס!"},{"start":41.75,"end":44.95,"text":"הפתעות, פספוסים, ומה לא בעצם, אה?"},{"start":44.95,"end":45.85,"text":"איך היה?"},{"start":45.85,"end":47.84,"text":"סדר זה, הלו, דגבורי."},{"start":47.84,"end":52.09,"text":"כל ה... אה, אה, אה, אה, כל זה, סדר זה, אה?"},{"start":52.09,"end":56.09,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במציאות."},{"start":56.09,"end":61.43,"text":"קשר בין המציאות לדמיון, הינו מקרי בהחלט."},{"start":61.43,"end":66.77,"text":"תמות האנשים והמקומות שונו לצורך העלילה."},{"start":66.77,"end":105.74,"text":"ומאתה הם נקראים הקומה."},{"start":105.74,"end":108.74,"text":"אני גאה לפתוח את חגיגות המשתה של פרס ומדי."},{"start":108.74,"end":112.03,"text":"החלנה, מה בתוכנית האומנותית?"},{"start":112.03,"end":115.11,"text":"אני מזמין לך ענת ליצן החצר, נחמן המופלה,"},{"start":115.11,"end":118.11,"text":"שישעשע אותנו בשיר הלל לשושן הבירה."},{"start":118.11,"end":120.29,"text":"הכניסו!"},{"start":120.29,"end":131.93,"text":"שושן הבירה, מיפה של נעסייה, מה נרשע."},{"start":131.93,"end":136.93,"text":"ונה חשברסי, בקינייש יונה, מיפה רכה תמדינה."},{"start":136.93,"end":139.93,"text":"בקינייש יונה, מיפה רכה תמדינה."},{"start":139.93,"end":145.04,"text":"תפתעו, תפתע, שביחו תקר."},{"start":145.04,"end":148.04,"text":"استدمל תהנית רשת."},{"start":148.04,"end":152.04,"text":"בקبرסה, יסوسה, מיפה רכה תبורסה."},{"start":152.04,"end":156.71,"text":"בואו, בואו, בואו, שושן הבירה."},{"start":156.71,"end":160.45,"text":"בואו, בואו, שושן הבירה."},{"start":160.45,"end":174.84,"text":"אה!"},{"start":174.84,"end":176.84,"text":"יש מה שאלה שהופיעה במבחן הפסיכומטרי?"},{"start":176.84,"end":179.84,"text":"שני פרסים נוסעים ברכבת, אחד מצ..."},{"start":179.84,"end":181.35,"text":"מה קרה?"},{"start":181.35,"end":183.13,"text":"את ראית זה?"},{"start":183.13,"end":184.43,"text":"מה?"},{"start":184.43,"end":185.43,"text":"זה, זה, זה, פה, השתיים הזה."},{"start":185.43,"end":186.43,"text":"איזה שתיים?"},{"start":186.43,"end":188.43,"text":"זה השתיים הקטנצ'ק הזה פה, בפינה, בפינה."},{"start":188.43,"end":189.78,"text":"אה! מה זה?"},{"start":189.78,"end":191.26,"text":"ממתי הוא כאן?"},{"start":191.26,"end":193.22,"text":"כל התוכלית ראית אבל הוא לא חושב שיזוז, כלום."},{"start":193.22,"end":194.22,"text":"לא זה אז, זה קטע."},{"start":194.22,"end":198.14,"text":"נעבוד עליו, נעבוד עליו."},{"start":198.14,"end":199.33,"text":"קום בבת אחר."},{"start":199.33,"end":201.22,"text":"וואו!"},{"start":201.22,"end":203.59,"text":"מה זה?"},{"start":203.59,"end":205.05,"text":"לא עוזר."},{"start":205.05,"end":206.91,"text":"מי?"},{"start":206.91,"end":207.97,"text":"מי?"},{"start":207.97,"end":209.22,"text":"לא יורד כלום."},{"start":209.22,"end":210.22,"text":"עזוב, עזוב."},{"start":210.22,"end":212.08,"text":"מה נעשה?"},{"start":212.08,"end":214.08,"text":"יש פה חברים יעזרו לנו, בוא בוא איתי פה."},{"start":214.08,"end":215.23,"text":"תקט, זה עוקב אחרינו."},{"start":215.23,"end":217.23,"text":"תקטע, יאללה, זה גדול."},{"start":217.23,"end":218.23,"text":"הלן חבר'ס."},{"start":218.23,"end":219.23,"text":"הלן, הלן."},{"start":219.23,"end":220.23,"text":"אתה בסדר?"},{"start":220.23,"end":221.23,"text":"כן, בסדר, בסדר."},{"start":221.23,"end":222.23,"text":"מה זה?"},{"start":222.23,"end":225.25,"text":"הם אלה שמעבירים את הפרסומות מהפרצוף הזה ל\"שתיים\" הגדול."},{"start":225.25,"end":227.25,"text":"או, מגניף, אתה יכול להדגים?"},{"start":227.25,"end":228.25,"text":"בטח."},{"start":228.25,"end":229.44,"text":"מוכנים?"},{"start":229.44,"end":231.44,"text":"טו טו טו טו טו טו טו טו טו טו."},{"start":231.44,"end":236.35,"text":"מה זה? עוד פעם, אוקיי?"},{"start":236.35,"end":239.38,"text":"טו טו טו טו טו טו טו טו טו טו."},{"start":239.38,"end":242.89,"text":"מה? חיים!"},{"start":242.89,"end":247.53,"text":"שימי את הקסטה של ההדרכה שיבינו איך לעשות את זה נכון."},{"start":247.53,"end":248.53,"text":"מה?"},{"start":248.53,"end":257.65,"text":"אורגע, סליחה, לא מניחה."},{"start":257.65,"end":262.7,"text":"צריך בוסקילה להיכנס, תסים ספר 17, 17, 17."},{"start":262.7,"end":265.31,"text":"שעצור עושות רע עשרה בקנוע."},{"start":265.31,"end":267.5,"text":"מתי מתחיל לצייר את כל נוער?"},{"start":267.5,"end":269.5,"text":"תחיל עוד מעט, נו?"},{"start":269.5,"end":271.46,"text":"מעט, נו, סליח."},{"start":271.46,"end":273.72,"text":"תודה רבה."},{"start":323.62,"end":325.62,"text":"תודה רבה."},{"start":325.62,"end":327.62,"text":"תודה רבה."},{"start":356.74,"end":361.49,"text":"תודה רבה."},{"start":416.58,"end":417.58,"text":"תודה רבה."},{"start":489.46,"end":492.46,"text":"אדוני, אתה עם הקופקורן, לא לגעת, זה בוסקי לך בקופקורן."},{"start":492.46,"end":496.7,"text":"הלו, הוא בוסקי לך עבור אחר כך על הכול הקופקורן, הלו."},{"start":496.7,"end":497.83,"text":"לא לגעת, נו, נו, נו."},{"start":497.83,"end":502.94,"text":"אלא, אתם בזה, אלף כיבובה, אלף כיבובה,"},{"start":502.94,"end":503.94,"text":"אחר כך הוא תכסיבוב אחר כך."},{"start":503.94,"end":516.15,"text":"תודה רבה על התו המלך החשבראש."},{"start":516.15,"end":519.07,"text":"אני גאה להמשיך בחגיגות המשתה."},{"start":519.07,"end":520.47,"text":"ובכן, מה בתוכנה?"},{"start":520.47,"end":523.47,"text":"אם כן, הבאנו לכאן את המופע המדהים"},{"start":523.47,"end":527.47,"text":"מערבות טקסס הרחוקה, שהכיל לנו כאן ליצן החצר."},{"start":527.47,"end":530.24,"text":"תגידו!"},{"start":563.82,"end":568.13,"text":"שושנה בירה, הבואו בו, שושנה בירה"},{"start":568.13,"end":590.67,"text":"לאחר גירוש ושתי התאספו בנות מחמד מכל רחבי הממלכה כדי לזכות בליבו של החשברוש."},{"start":590.67,"end":591.67,"text":"קלנית!"},{"start":591.67,"end":592.67,"text":"מה, רכפת?"},{"start":592.67,"end":595.15,"text":"איזה שושני המלך החשברוש!"},{"start":595.15,"end":596.15,"text":"וואו, איזה מהודו!"},{"start":596.15,"end":597.15,"text":"איזה ועדכוש!"},{"start":597.15,"end":598.15,"text":"איזה חפץ בעיקרו!"},{"start":598.15,"end":600.15,"text":"איזה חפץ חשוד!"},{"start":600.15,"end":603.01,"text":"תגידי, רכפת!"},{"start":603.01,"end":605.48,"text":"למה החשוירוש הסתכסך עם ושתי?"},{"start":605.48,"end":608.83,"text":"הוא לא הסתכסך איתה, סתם העבר בנמחת ולשחרור"},{"start":608.83,"end":612.13,"text":"וואו, לאן הוא עבר?"},{"start":612.13,"end":615.58,"text":"לשום מקום מיוחד, הוא עבר, זה דושנוני, זה אי אפשר להמחיש"},{"start":615.58,"end":618.28,"text":"קלנית"},{"start":618.28,"end":619.82,"text":"מה רכי?"},{"start":619.82,"end":621.82,"text":"החשוירוש הבחר אותי כי התחפשתי למלכת הלילה"},{"start":621.82,"end":624.91,"text":"אז מה הוא הבחר אותי כי התחפשתי למלכת הכוכבים?"},{"start":624.91,"end":626.91,"text":"אלה קוטח, אפילו לא נבחרת למספרס"},{"start":626.91,"end":628.91,"text":"אז מה, ואת לא למסמדי"},{"start":628.91,"end":629.91,"text":"אז מה?"},{"start":629.91,"end":631.16,"text":"אז מה?"},{"start":631.16,"end":633.16,"text":"ועברה זכיתי מקום ראשון בתחפושת המקורי"},{"start":633.16,"end":635.16,"text":"אז מה, ואני זכיתי בתחרות התחפושת היפה"},{"start":635.16,"end":637.16,"text":"אלה כיפה, התחפש לקובוי"},{"start":637.16,"end":639.16,"text":"אז מה, ואת לצב נינג'ה"},{"start":639.16,"end":640.09,"text":"אז מה?"},{"start":640.09,"end":642.35,"text":"אני לא יכולה שוחח איתך על פורים ועיצובים"},{"start":642.35,"end":644.44,"text":"את אפילו לא יודעת מי זה זרש"},{"start":644.44,"end":647.84,"text":"אלה כאני לא יודעת מי זה"},{"start":647.84,"end":648.77,"text":"נו"},{"start":648.77,"end":649.93,"text":"אלה כאני לא יודעת"},{"start":649.93,"end":650.91,"text":"נו"},{"start":650.91,"end":652.19,"text":"נו, מה זה?"},{"start":652.19,"end":655.17,"text":"את מפגרת, זה מה זה בסיסי?"},{"start":655.17,"end":658.49,"text":"זרש, זה נגיד את עולה במעלית בשושן הבירה"},{"start":658.49,"end":661.22,"text":"ואת באה ללחוץ על כפתור"},{"start":661.22,"end":662.18,"text":"נו"},{"start":662.18,"end":663.21,"text":"והמעלית מחושמלת?"},{"start":663.21,"end":664.2,"text":"נו"},{"start":664.2,"end":665.2,"text":"אז את מקבלת זרש?"},{"start":665.2,"end":667.03,"text":"נו"},{"start":667.03,"end":668.86,"text":"אז זה זה"},{"start":668.86,"end":670.05,"text":"וואו, מאיפה הולך?"},{"start":670.05,"end":672.18,"text":"מחגי ישראל ומועדיו קרח פי"},{"start":699.39,"end":744.57,"text":"תודה רבה."},{"start":744.63,"end":752.95,"text":"עבר בינינו קרפיון ולא נתת לי שום שמפון נגד קסקסים."},{"start":752.95,"end":762.03,"text":"להתחילה שניגב וכורא של אפוליאון שוברה למכונית שלי."},{"start":762.03,"end":772.13,"text":"כל המושך כמו חציל ומסביבי החורף מתורה."},{"start":778.85,"end":868.88,"text":"עכשיו יכולתי לומר שאת כמו פרח, כמו בלידה ביום קיץ מחושף, אבל זה תקוע לי במוח כמו הדורות בשביל להיות אבוקדו מקולה."},{"start":868.88,"end":888.24,"text":"מעלתו המלך החשבראש אני גאה להזמין את מופע הרוק המשובח."},{"start":888.24,"end":893.61,"text":"ליצן הרצח! אין מישהו אחר בארבון הזה!"},{"start":893.61,"end":900.86,"text":"אדוני המלך, אדוני המלך, נחמן שלנו הוא איש מופלא, בעל אלף סגנונות, וכאן הוא יראה לנו סגנון שונה לחלוטין."},{"start":900.86,"end":904.32,"text":"אך ניסו!"},{"start":904.32,"end":914.89,"text":"אך ניסו!"},{"start":914.89,"end":922.36,"text":"אך ניסו!"},{"start":922.36,"end":972.13,"text":"ערב טוב לך שלטרה!"},{"start":972.13,"end":974.22,"text":"שלטרה!"},{"start":974.22,"end":975.22,"text":"זה אשורי!"},{"start":975.22,"end":976.22,"text":"שלטרה!"},{"start":976.22,"end":977.22,"text":"מה בעניין?"},{"start":977.22,"end":979.22,"text":"שלטרה!"},{"start":979.22,"end":982.34,"text":"ערב טוב לך רשמקה!"},{"start":982.34,"end":986.4,"text":"מי זה רשמקה?"},{"start":986.4,"end":987.4,"text":"איזה רוסיה הוא פגד היום?"},{"start":987.4,"end":988.4,"text":"ערב טוב לך רשמקה!"},{"start":988.4,"end":994.6,"text":"מי זה?"},{"start":994.6,"end":995.6,"text":"מי זאת רשמקה?"},{"start":995.6,"end":996.6,"text":"תעשה כוכבית הרבה משתיים!"},{"start":996.6,"end":1001.26,"text":"תצא לי רשמקה!"},{"start":1002.26,"end":1004.26,"text":"תצא קשה!"},{"start":1004.26,"end":1006.26,"text":"תעשה כוכבית הרבה משתיים!"},{"start":1006.26,"end":1008.26,"text":"תעשה כוכבית הרבה משתיים!"},{"start":1008.26,"end":1010.26,"text":"תעשה כוכבית הרבה!"},{"start":1010.26,"end":1012.26,"text":"תעשה כוכבית הרבה!"},{"start":1012.26,"end":1015.76,"text":"תעשה כוכבית!"},{"start":1015.76,"end":1017.76,"text":"תעשה כוכבית!"},{"start":1017.76,"end":1019.78,"text":"תעשה כוכבית!"},{"start":1019.78,"end":1021.89,"text":"תעשה כוכבית!"},{"start":1021.89,"end":1024.1,"text":"תעשה כוכבית!"},{"start":1024.1,"end":1026.32,"text":"תעשה כוכבית!"},{"start":1026.32,"end":1029.89,"text":"תעשה כוכבית!"},{"start":1029.89,"end":1032.36,"text":"מה אתה רוצה?"},{"start":1032.36,"end":1034.67,"text":"תעשה חברי מנהי!"},{"start":1034.67,"end":1036.67,"text":"תרצה להיות חבר שלי?"},{"start":1036.67,"end":1040.89,"text":"מה אתה רוצה ממני?"},{"start":1040.89,"end":1043.27,"text":"אלה הם חברים!"},{"start":1043.27,"end":1045.49,"text":"תרצה להיות חבר שלי?"},{"start":1045.49,"end":1049.49,"text":"מה אתה רוצה?"},{"start":1049.49,"end":1051.62,"text":"לא, מה אתה רוצה?"},{"start":1051.62,"end":1055.25,"text":"מה אתה רוצה?"},{"start":1055.25,"end":1059.79,"text":"אלכס!"},{"start":1059.79,"end":1062.21,"text":"מה אתה אומר על חליטת הפוק?"},{"start":1070.26,"end":1073.98,"text":"לא מוט ש..."},{"start":1073.98,"end":1075.94,"text":"לא חושב, תקעתי מנות, שנייה"},{"start":1075.94,"end":1129.81,"text":"רגע, מניסים ואין לפלה"},{"start":1129.81,"end":1132.1,"text":"שאול, למה נתחפש בפורים?"},{"start":1132.1,"end":1134.19,"text":"לא הולך להתחפש, תעזוב אותך בעלכה"},{"start":1134.19,"end":1136.19,"text":"לא, לא, למה נתחפש?"},{"start":1136.19,"end":1138.19,"text":"איזה תחפושת, תעזוב אותך בעלכה"},{"start":1138.19,"end":1140.35,"text":"בוא, בוא נתחפש אלה"},{"start":1140.35,"end":1142.35,"text":"אלה לא רוצה להתחפש, נו תעזוב אותי בעלכה"},{"start":1142.35,"end":1144.35,"text":"יש לי רעיון, נו"},{"start":1144.35,"end":1146.31,"text":"אלה זכוק את רעיון"},{"start":1146.31,"end":1148.31,"text":"אתה תתחפש לי, אני אתחפש לך"},{"start":1148.31,"end":1150.31,"text":"אני אתחפש לך"},{"start":1150.31,"end":1152.33,"text":"איזה רעיון מטומטם זה, תעזוב אותך בעלכה"},{"start":1152.33,"end":1154.33,"text":"לא למה, אתה תתחפש לי"},{"start":1154.33,"end":1156.33,"text":"תהיה אני"},{"start":1156.33,"end":1158.33,"text":"אני אתחפש אני אתנו"},{"start":1158.33,"end":1160.33,"text":"בבקשה"},{"start":1160.33,"end":1162.33,"text":"לא רוצה, תעזוב אותי בעלכה"},{"start":1162.33,"end":1170.94,"text":"בבקשה מתוק שלי"},{"start":1170.94,"end":1176.0,"text":"ישע ועזוב אותך בחייך"},{"start":1176.0,"end":1178.83,"text":"אבי לי שי"},{"start":1178.83,"end":1180.83,"text":"עזוב אותך בחייך"},{"start":1180.83,"end":1182.83,"text":"נו אבי לי שי"},{"start":1182.83,"end":1184.83,"text":"עזוב, עזוב, עזוב אותך"},{"start":1184.83,"end":1186.83,"text":"נו תעשה טובה, אבי לי שי"},{"start":1186.83,"end":1188.83,"text":"שי"},{"start":1188.83,"end":1190.83,"text":"יאללה, זרוק נושא"},{"start":1190.83,"end":1193.31,"text":"שווידיות"},{"start":1193.31,"end":1195.72,"text":"נושא טוב"},{"start":1195.72,"end":1197.87,"text":"איזה כיף לי"},{"start":1197.87,"end":1197.97,"text":"השווידיות"},{"start":1197.87,"end":1199.87,"text":"לי"},{"start":1199.87,"end":1202.51,"text":"לי לי לי לי"},{"start":1202.51,"end":1204.85,"text":"לי לי לי"},{"start":1204.85,"end":1207.04,"text":"לי לי לי"},{"start":1207.04,"end":1212.44,"text":"תחת"},{"start":1212.44,"end":1214.88,"text":"את הגאות"},{"start":1214.88,"end":1217.03,"text":"לקח נושא תמי"},{"start":1217.03,"end":1219.03,"text":"מה עשה אותו"},{"start":1219.03,"end":1221.03,"text":"עזוב אותך בחייך"},{"start":1221.03,"end":1223.66,"text":"עזוב אותך בחייך"},{"start":1223.66,"end":1226.04,"text":"אדוני המלך החשברוש"},{"start":1226.04,"end":1228.55,"text":"אני גאה להזמין מופע נחמד"},{"start":1228.55,"end":1231.89,"text":"שיחתום את המשתה מופע בסגנון הברוק"},{"start":1231.89,"end":1237.57,"text":"עם מי?"},{"start":1237.57,"end":1239.7,"text":"נחמן?"},{"start":1239.7,"end":1242.27,"text":"לא! לא נחמן!"},{"start":1242.27,"end":1244.83,"text":"נכניסו!"},{"start":1244.83,"end":1252.84,"text":"שענה בירה"},{"start":1252.84,"end":1255.03,"text":"סולסי"},{"start":1255.03,"end":1257.03,"text":"העמן הרשע"},{"start":1257.03,"end":1259.03,"text":"הוא נחש פרסי"},{"start":1259.03,"end":1261.03,"text":"על הגז יש אבז"},{"start":1261.03,"end":1263.03,"text":"מברך את הברווז"},{"start":1263.03,"end":1274.81,"text":"נכניסו"},{"start":1274.81,"end":1290.78,"text":"נכניסו"},{"start":1290.78,"end":1294.24,"text":"נכניסו"}]