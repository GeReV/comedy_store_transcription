[{"start":29.31,"end":34.43,"text":"רבותיי, ברוכים הבאים, אלה קומדיסטור!"},{"start":34.43,"end":41.11,"text":"אגע, את מי לחשוב? רק אגע."},{"start":41.11,"end":48.1,"text":"משחק עם כלבה שש-מש?"},{"start":48.1,"end":49.36,"text":"כן."},{"start":49.36,"end":50.36,"text":"מה נעשה כלבה גאונית?"},{"start":50.36,"end":52.36,"text":"איזה גאונית? אני כבר מוביל אליה חמש טיים."},{"start":52.36,"end":55.36,"text":"קודם דפקתי לה שני מעשים רצופים, מה גאונית?"},{"start":55.36,"end":57.73,"text":"יאללה, תורך."},{"start":57.73,"end":80.32,"text":"חבר'ה! איפה אתם?"},{"start":80.32,"end":84.43,"text":"יש... יש לי..."},{"start":84.43,"end":86.29,"text":"סלמטק?"},{"start":86.29,"end":88.41,"text":"לא! סלמית!"},{"start":89.41,"end":94.21,"text":"אי... אני עייף..."},{"start":94.21,"end":97.62,"text":"עבר'ה! אני... אני הולך לי קונרי!"},{"start":97.62,"end":99.98,"text":"לא! אני הולך לי שון!"},{"start":99.98,"end":105.5,"text":"יש לי, יש לי!"},{"start":105.5,"end":160.19,"text":"הם שלוש!"},{"start":160.19,"end":164.83,"text":"שלו רבין!"},{"start":164.83,"end":166.41,"text":"ישנו אחד סולגיר!"},{"start":166.41,"end":167.46,"text":"שלך!"},{"start":167.46,"end":168.78,"text":"כן!"},{"start":168.78,"end":170.22,"text":"רוצים?"},{"start":170.22,"end":172.08,"text":"מליון דולר!"},{"start":172.08,"end":174.74,"text":"שום!"},{"start":174.74,"end":176.05,"text":"מליון דולר!"},{"start":176.05,"end":211.97,"text":"תודה רבה."},{"start":211.99,"end":247.96,"text":"תודה רבה."},{"start":247.98,"end":252.8,"text":"סמי וסוסו? לא! סמי בורקס!"},{"start":252.8,"end":257.08,"text":"בושקות! בושקות!"},{"start":257.08,"end":259.45,"text":"היום המזנון כבירי."},{"start":259.45,"end":269.62,"text":"ערב צח."},{"start":269.62,"end":272.07,"text":"והפעם משהו שונה לגמרי."},{"start":272.07,"end":273.55,"text":"החלסטרה של זוזו."},{"start":273.55,"end":276.96,"text":"פעם שמות של מחלות ושל חיידקים."},{"start":276.96,"end":279.07,"text":"מי זה הלפלף?"},{"start":279.07,"end":281.07,"text":"שהיא מביא את השמות של החיידקים?"},{"start":281.47,"end":286.03,"text":"בימא שלי מייל ברונحיטיס, קלואויטיס, קלזامיטיס, בסדר?"},{"start":286.03,"end":288.17,"text":"אבל עד שבא חיידק גבר."},{"start":288.17,"end":290.4,"text":"בימא שלי חיידק שאוחי البصار."},{"start":290.4,"end":293.04,"text":"ואוהב לי עול البصار על عيش? איך קרעולו?"},{"start":293.04,"end":294.82,"text":"סטריפטוקוקוס."},{"start":294.82,"end":296.24,"text":"מה זה ערת הזה?"},{"start":296.24,"end":298.16,"text":"זה חיידק לסלפלף, שקינזים, קוקיות."},{"start":298.16,"end":299.44,"text":"זה חיידק ערס."},{"start":299.44,"end":300.4,"text":"הם עגלים."},{"start":300.4,"end":303.66,"text":"הם נחמדים בעוזניים, הם כאלה זוהרים, הם מפנועים."},{"start":303.66,"end":305.12,"text":"חיידק עושך שוקה."},{"start":305.12,"end":306.6,"text":"זה קורים לסטריפטוקוקוס."},{"start":306.72,"end":311.26,"text":"זה צריך לקרוא לו בבר, ההיידק שאוהב בשר."},{"start":311.26,"end":312.83,"text":"תחשיבו על זה."},{"start":312.83,"end":316.96,"text":"תגיד, מה אתה אומר על סלט הבית?"},{"start":316.96,"end":319.16,"text":"אני חושב שזה יקר מדי."},{"start":319.16,"end":321.68,"text":"זה לא, זה לא יקר כמו שזה עולה הרבה כסף."},{"start":321.68,"end":324.0,"text":"במחשבה שנייה אני חושב שפשוט המחיר גבוה."},{"start":324.0,"end":325.2,"text":"זאת לא הבעיה."},{"start":325.2,"end":327.29,"text":"הבעיה מתחילה מזה שזה פשוט לא זול."},{"start":327.29,"end":328.78,"text":"אבל זה משמין, לא?"},{"start":328.78,"end":330.98,"text":"זה לא משמין כמו שזה מעלה במשקל."},{"start":330.98,"end":333.78,"text":"במחשבה שנייה אני חושב שזה פשוט מלא קלוריות."},{"start":333.78,"end":335.66,"text":"אבל לא זאת הבעיה."},{"start":335.78,"end":339.58,"text":"הבעיה מתחילה עם זה שזה רחוק מלהיות יתתי, פשוט רחוק מלהיות יתתי."},{"start":339.58,"end":340.66,"text":"אבל תשווה, תשווה."},{"start":340.66,"end":343.62,"text":"זה רחוק מלהיות יתתי, זה הכל."},{"start":343.62,"end":346.64,"text":"סליחה, אני פשוט חייב, סליחה שאני מתפרץ ככה,"},{"start":346.64,"end":349.98,"text":"אבל אנחנו פשוט ישבנו פה ולא יכולנו שלא להקשיב לכם."},{"start":349.98,"end":353.13,"text":"ואני חייב לשאול אתכם שאלה, אני יכול להבין למה אתם חוזרים על עצמכם?"},{"start":353.13,"end":356.29,"text":"זה לא שאתם חוזרים על עצמכם, כמו שאתם אומרים את אותו דבר כל הזמן."},{"start":356.37,"end":359.89,"text":"כן, במחשבה שנייה אני פשוט חושב שאתם מבטאים את אותו רעיון מספר פעמים."},{"start":359.89,"end":364.53,"text":"זאת לא הבעיה. הבעיה מתחילה בזה שאין שום הבדל בין המשמעויות של המשפטים שלכם."},{"start":364.53,"end":366.71,"text":"כן, לא בכלי חבר'ה, מה קורה פה?"},{"start":366.71,"end":369.28,"text":"תגידו, אתם מה שומעים לב של הקטע הזה אין פואנטה?"},{"start":369.28,"end":372.74,"text":"זה לא שאין לו פואנטה, כמו שאין איזה פאנצ' להן בסוף."},{"start":372.74,"end":376.26,"text":"במחשבה שנייה מה שחסר לי זה איזשהו עוקץ, אבל זאת לא הבעיה."},{"start":376.34,"end":381.44,"text":"בעיה חבר'ה מתחילה בזה שאין לו כעת' זה סוף מצחיק."},{"start":381.44,"end":385.17,"text":"יופי חבר'ה, נורא מצחיק."},{"start":385.17,"end":387.73,"text":"כן, לא שזה מצחיק כמו שזה מלא הומור."},{"start":387.73,"end":390.13,"text":"זה לא שזה מלא הומור כמו שזה משעשע."},{"start":390.13,"end":392.33,"text":"זה לא משעשע כמו שזה מעלה גיחור."},{"start":392.33,"end":393.25,"text":"מעלה גיחור שזה משחד מודי."},{"start":393.25,"end":395.77,"text":"זה לא שאתם מגילים אותי כמו שאתם מעורים בשעת מפש."},{"start":395.77,"end":397.89,"text":"זה לא שאתם מעורים בשעת."},{"start":397.89,"end":407.72,"text":"מה זה אמר נגנן נר?"},{"start":407.72,"end":408.6,"text":"לא, לא."},{"start":408.6,"end":410.04,"text":"מה נאמר וחלב-לב?"},{"start":410.04,"end":410.84,"text":"לא, לא."},{"start":410.84,"end":411.96,"text":"ובלין נגזיר."},{"start":412.04,"end":445.99,"text":"לא, לא, לא, איזה בלעטفל, לא, לא, לא, איזה יעטفל, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא, לא,"},{"start":445.99,"end":447.99,"text":"לא לא לא לא לא! -אזبע! אזبע!"},{"start":447.99,"end":452.21,"text":"בגטושיק? -לא! בגדד!"},{"start":452.21,"end":454.21,"text":"בגדד!"},{"start":454.21,"end":461.15,"text":"יש לי! יש לי! יש לי! יש לי!"},{"start":461.15,"end":466.39,"text":"בקלואה! לא תודה! זה מתוק! מתוק!"},{"start":466.39,"end":478.39,"text":"מוסקוט! הלו! אתריابין! תגיד לו בסדר!"},{"start":478.39,"end":482.54,"text":"חצים מיליון גמוליך! בסדר!"},{"start":482.54,"end":486.04,"text":"בסדר! אז תשלח לי את זה בפאקס ואני כבר אכזיר לך תשובה!"},{"start":486.04,"end":488.07,"text":"אוקיי! אוקיי! אין בעיה!"},{"start":488.07,"end":490.04,"text":"ביי! ביי! ליטרון! ביי! ביי!"},{"start":490.04,"end":491.41,"text":"אלן!"},{"start":491.41,"end":492.41,"text":"אלן!"},{"start":492.41,"end":493.41,"text":"מה העניינים? מה עניינים? מה עניינים?"},{"start":493.41,"end":494.41,"text":"מה עניינים? מה עניינים? בוא שבשב!"},{"start":494.41,"end":494.51,"text":"על הכיפה!"},{"start":494.41,"end":496.41,"text":"לא יודע! התקשרת עליי! אמרת לי את רוצה לכתוב?"},{"start":496.41,"end":498.41,"text":"תשמע! קודם כל מגיע לי מזל טוב! לא תאמין!"},{"start":498.41,"end":500.41,"text":"העבודה סיפתך ביתון? קיבלתי אותה!"},{"start":500.41,"end":502.41,"text":"אה! קיבלתי אותה מזל טוב על הכיפה!"},{"start":502.41,"end":508.41,"text":"קיבלתי משימה ראשונה, לכתוב כתבה על אנשים מעניינים ועל החיים שלהם."},{"start":508.41,"end":509.41,"text":"נו, שגאון, יפה."},{"start":509.41,"end":511.95,"text":"אכפת לך שאני אכתוב עליך?"},{"start":511.95,"end":515.26,"text":"לא, למה שהיא אכפת לי? בואו תכתוב חופשי, באמת."},{"start":515.26,"end":518.33,"text":"אמרת לי את זה גם בטלפון, אז אני הכנתי את עצמי לקראת זה."},{"start":518.33,"end":519.38,"text":"נדע."},{"start":519.38,"end":522.2,"text":"אוקיי, זהו."},{"start":522.2,"end":524.2,"text":"כן, יש לי אבל עוד כמה שאלות."},{"start":524.2,"end":526.2,"text":"ככה שרתי, שרתי, שרתי. בשביל זה אני פה."},{"start":526.2,"end":530.2,"text":"כבן אדם שרואה דברים בדרכו שלו, איך אתה רואה את עצמך?"},{"start":530.2,"end":536.91,"text":"איך אני רואה את עצמי, אני ככה, כן."},{"start":536.91,"end":539.91,"text":"ומה השקפות שלך לגבי כל מה שקורה סביבך?"},{"start":539.91,"end":544.91,"text":"אז זהו, השקפות שלי למה שקורה סביבי, אין בערך ככה, אתה יודע, כאלה."},{"start":544.91,"end":548.09,"text":"יש לך איזה שאיפות, משהו?"},{"start":548.09,"end":551.09,"text":"יש לי, יש לי שאיפות. שאיפות זה אחד הדברים שאני..."},{"start":551.09,"end":557.73,"text":"אוקיי, תודה רבה, מאוד נחמד."},{"start":557.73,"end":560.85,"text":"מה זאת אומרת, תודה רבה, מה זהו? זהו, יש לך מספיק חומר?"},{"start":560.85,"end":562.85,"text":"כן, בטח שיש לי מספיק חומר."},{"start":562.85,"end":566.91,"text":"אה, אוקיי. זאת אומרת, אז אני מבין שאין לך הרבה ציפיות מהכתבה הזאת."},{"start":568.91,"end":572.91,"text":"אה, זהו, רק שתי ציפיות? תגיד לי, אני יכול לקרוא את מה שכתבת?"},{"start":572.91,"end":574.91,"text":"כן, חופשי, אין לי שום דבר להסתירנו לך."},{"start":574.91,"end":579.1,"text":"לא, אני פשוט רוצה לדעת מה אתה כותב, איך זה יתפרסם."},{"start":579.1,"end":581.1,"text":"אוקיי, זאת אומרת, אלה השאלות שיהיו?"},{"start":581.1,"end":584.1,"text":"רק אלה, כל אלה, אני יכול לבנות על זה?"},{"start":584.1,"end":586.19,"text":"אתה יכול לבנות על זה, חופשי."},{"start":586.19,"end":589.19,"text":"אוקיי, כן, אני פשוט... לא, אתה מבין, אני חייב לדעת אם אני יכול לבנות על זה."},{"start":589.19,"end":590.19,"text":"בוא בוא תעזור לי, רגע."},{"start":590.19,"end":591.19,"text":"אתה מבין, אני פשוט..."},{"start":591.19,"end":592.19,"text":"מה אתה במה?"},{"start":592.19,"end":610.85,"text":"אני מבין אולי איזה בית, משהו... משהו נורא..."},{"start":610.85,"end":667.32,"text":"שידור, אוקיי, ובכן, שלום לכולם, ערב טוב, ובכן, כדורגל כבר אין, אבל שידורנו לא תמו."},{"start":667.32,"end":672.32,"text":"אנחנו כאן, גבירותיי ורבותיי, בהלסינקי, בשידור שלב הגמר."},{"start":672.32,"end":676.32,"text":"כאן, אליפות העולם, הגמר, אני רוצה לעבור להצגת המשתתפים."},{"start":676.32,"end":679.32,"text":"באדום, הפולני, בוריס בודגוב."},{"start":679.32,"end":684.32,"text":"בוריס בודגוב בא לניסיון הרב, ומולו בכחול, מר סטפן זלמק."},{"start":684.32,"end":687.32,"text":"סטפן זלמק הנציג היוגוסלאבי."},{"start":687.32,"end":689.32,"text":"ובכן, אני רוצה לעבור כבר לשידור התחרות."},{"start":689.32,"end":692.32,"text":"אנחנו איתכם כל הזמן אל התחרות."},{"start":692.32,"end":697.45,"text":"ובכן, רבותיי, הם יצאו לדרך."},{"start":697.45,"end":699.45,"text":"אין ספק הדרמה החלה."},{"start":699.45,"end":700.45,"text":"שימו לב, הצופים מראים,"},{"start":700.45,"end":702.45,"text":"אפשר להגיד שכבר יש לנו בטח מהתחלה."},{"start":702.45,"end":703.45,"text":"הם צמודים אחד לשני."},{"start":703.45,"end":705.45,"text":"אין ספק שאפשר לראות בבירור"},{"start":705.45,"end":707.45,"text":"שהפולני הוא הרבה יותר מנוסה לעומת היוגוסלאבי,"},{"start":707.45,"end":708.45,"text":"שהוא הרבה יותר פיזי."},{"start":708.45,"end":709.45,"text":"אך תחיד בתמועותיו."},{"start":709.45,"end":710.45,"text":"אך תחיד בתמועותיו."},{"start":710.45,"end":711.45,"text":"שימו לב את החרות בעיצומה."},{"start":711.45,"end":712.45,"text":"הם צמודים אחד לשני,"},{"start":712.45,"end":713.45,"text":"הקהל מריאלם כל רב."},{"start":713.45,"end":714.45,"text":"הם מתכווים לקרות הרע."},{"start":714.45,"end":715.45,"text":"מה יכול להיות?"},{"start":715.45,"end":716.45,"text":"הם מזוים כמו שדים."},{"start":716.45,"end":717.45,"text":"שימו לב, יש יתרון קטן לפעולני."},{"start":717.45,"end":718.45,"text":"לא!"},{"start":718.45,"end":719.45,"text":"הם רוצים להזין אותו."},{"start":719.45,"end":720.45,"text":"כן!"},{"start":720.45,"end":720.55,"text":"וירותיי ורבותיי!"},{"start":720.45,"end":721.45,"text":"האם יש לנו כתה?"},{"start":721.45,"end":723.45,"text":"יוסף, תלי את זה בשינו,"},{"start":723.45,"end":724.45,"text":"חוזר הפעם בינוך איתי."},{"start":724.45,"end":726.45,"text":"הקהל עומד לא יודע מה תוצר."},{"start":726.45,"end":728.45,"text":"הנה אני מקבל את זה כבר על המוניטור."},{"start":728.45,"end":731.45,"text":"ברור לכולם שיש לנו כאן שוב טייקו."},{"start":731.45,"end":733.45,"text":"וירותיי ורבותיי,"},{"start":733.45,"end":735.45,"text":"שנה שמינית ברציפות,"},{"start":735.45,"end":737.48,"text":"טייקו ולמתמודדים,"},{"start":737.48,"end":738.48,"text":"עטירי הניסיון,"},{"start":738.48,"end":739.48,"text":"עטירי הטכניקה,"},{"start":739.48,"end":741.48,"text":"ועטירי הסטרואידים."},{"start":741.48,"end":742.48,"text":"וירותיי ורבותיי,"},{"start":742.48,"end":743.48,"text":"תודה רבה לכם."},{"start":743.48,"end":745.48,"text":"כאן סנפירי יהודה."},{"start":745.48,"end":747.24,"text":"בון."},{"start":747.24,"end":751.24,"text":"זה אנחנו הצופים שבנו."},{"start":751.24,"end":755.68,"text":"לכבודכי בנו שרים היום."},{"start":755.68,"end":759.95,"text":"תודה רבה."},{"start":789.29,"end":799.92,"text":"תודה רבה, תודה רבה, תודה רבה."},{"start":823.6,"end":825.6,"text":"תודה רבה, תודה רבה."},{"start":825.6,"end":830.3,"text":"לאן אתם הולכים, רגע! אלו! אל תשאר אותי פה!"},{"start":830.3,"end":836.87,"text":"תן, בני."},{"start":836.87,"end":838.35,"text":"חטאתי."},{"start":838.35,"end":839.26,"text":"דבר, בני."},{"start":839.26,"end":848.93,"text":"אתמול הלכתי אל המלך ואמרתי לו: שלום אדוני המלך, איפה הייתי ומה עשיתי?"},{"start":848.93,"end":853.01,"text":"מילה ראשונה: אני."},{"start":853.01,"end":858.46,"text":"מילה שנייה: אוהב."},{"start":858.46,"end":864.85,"text":"מילה שלישית: אותך."},{"start":864.85,"end":867.06,"text":"אני."},{"start":867.06,"end":868.47,"text":"אוהב."},{"start":868.47,"end":869.6,"text":"אותך."},{"start":869.6,"end":873.63,"text":"אביב, ערך אותי."},{"start":873.63,"end":875.85,"text":"ואיך ים מגעים?"},{"start":876.85,"end":883.9,"text":"נפגש בעוד שעה?"},{"start":883.9,"end":885.39,"text":"כן, עוד שעה."},{"start":885.39,"end":886.68,"text":"איפה?"},{"start":886.68,"end":888.54,"text":"מול הסנטר."},{"start":888.54,"end":889.54,"text":"מול הסנטר או מול הסנטר?"},{"start":889.54,"end":890.51,"text":"כן, מול הסנטר."},{"start":890.51,"end":893.89,"text":"לא, יש מול הסנטר ויש מול הסנטר."},{"start":893.89,"end":894.89,"text":"איפה, איפה תפגוש אותי?"},{"start":894.89,"end":896.8,"text":"מול הסנטר, מה בעיה?"},{"start":896.8,"end":898.88,"text":"לא, תראה, יש מול הסנטר."},{"start":898.88,"end":899.88,"text":"מי?"},{"start":899.88,"end":902.84,"text":"ויש מול הסנטר, זה שני דברים שונים."},{"start":902.84,"end":904.84,"text":"נו כן, מול הסנטר, מה בעיה?"},{"start":904.84,"end":905.84,"text":"אז איפה בדיוק?"},{"start":905.84,"end":906.84,"text":"מול הסנטר."},{"start":906.84,"end":907.9,"text":"לא, יש מול הסנטר."},{"start":907.9,"end":908.9,"text":"כן."},{"start":908.9,"end":911.02,"text":"זה מול הסנטר, אוקיי?"},{"start":911.02,"end":914.02,"text":"סגרנו, ויש מול הסנטר."},{"start":914.02,"end":916.02,"text":"מול הסנטר?"},{"start":916.02,"end":918.99,"text":"מול הסנטר או מול הסנטר?"},{"start":918.99,"end":919.99,"text":"מול הסנטר!"},{"start":919.99,"end":922.11,"text":"רגע, רגע, בוא, בוא, בוא."},{"start":922.11,"end":923.36,"text":"יש מול הסנטר?"},{"start":923.36,"end":924.36,"text":"כן."},{"start":924.36,"end":925.36,"text":"מה, תגיד מה, מול הסנטר?"},{"start":925.36,"end":926.36,"text":"מול הסנטר."},{"start":926.36,"end":928.36,"text":"יפה, ויש מול הסנטר."},{"start":928.36,"end":930.36,"text":"מול הסנטר."},{"start":930.36,"end":932.36,"text":"מול הסנטר, זה מול הסנטר."},{"start":932.36,"end":934.36,"text":"יש מול הסנטר ומול הסנטר."},{"start":934.36,"end":937.68,"text":"שלום, אתם יכולים אולי לעזור לי, אני פשוט מחפש איפה זה מול הסנטר."},{"start":937.68,"end":938.68,"text":"מה?"},{"start":938.68,"end":943.31,"text":"בוא נה, המשטרה היום לא יודע מה קרה להם."},{"start":943.31,"end":944.29,"text":"מה קרה?"},{"start":944.29,"end":956.64,"text":"שום לכים הפולניה יקרה."},{"start":956.64,"end":962.64,"text":"והיום נלמד כיצד להתמודד עם העובדה שהילד שומע אביו גפן."},{"start":962.64,"end":966.17,"text":"קודם כל תפני מי, תפני מי."},{"start":966.17,"end":970.17,"text":"דבר שאני כבר מגיל צעירה צריכה להשמיע לו מוזיקה טובה."},{"start":970.17,"end":973.17,"text":"מה ראה? תשמיע לו פרנק סינטרה."},{"start":973.17,"end":975.17,"text":"אף אחד עוד לא התאבד בגלל זה."},{"start":975.17,"end":979.42,"text":"תראי, אני יודעת, זה שיגונות של כל החבר'ס האלה."},{"start":979.42,"end":981.42,"text":"תראי, גם אני הייתי פעם צעירה."},{"start":981.42,"end":984.42,"text":"גם אני תתפליק, תתפליק."},{"start":984.42,"end":986.42,"text":"גם אני הייתי פעם צעירה."},{"start":986.42,"end":988.42,"text":"ואני שמעתי את כל המוזיקה הזאת."},{"start":988.42,"end":991.42,"text":"איך החבר'ה אומרים: מגניב, מגניב."},{"start":991.42,"end":992.42,"text":"פריק, פריק."},{"start":992.42,"end":993.42,"text":"נו, אז אני שמעתי."},{"start":993.42,"end":998.42,"text":"אני לא קראתי את הסמלה בהופעה של מייק בורשטיין בבית העם."},{"start":998.42,"end":999.42,"text":"קראתי."},{"start":999.42,"end":1002.42,"text":"אז אני אומרת אם הוא רוצה שישמע, שישמע."},{"start":1002.42,"end":1005.42,"text":"אבל אם הבן שלי התאבד בגלל זה אני ארוג אותו."},{"start":1005.42,"end":1008.42,"text":"אני ארוג אותו, כנס לביתה, כנס לביתה."},{"start":1008.42,"end":1014.72,"text":"תראי, אני לא יודעת, אני לא יודעת, את יודעת מה? אנחנו דור מזוין."},{"start":1014.72,"end":1017.83,"text":"ובכן, שלום לכם ערב טוב, פריצה שנייה שלנו כאן מהלסינקי,"},{"start":1017.83,"end":1020.83,"text":"בתחרות אליפות העולם למדרגות טעות."},{"start":1020.83,"end":1024.83,"text":"ובכן, גבירותיי ורבותיי, הפעם מקצה נשים, ויש איתנו שתי משתתפות."},{"start":1024.83,"end":1027.83,"text":"האמריקאית ג'וליאנה מסצ'וסיץ,"},{"start":1027.83,"end":1031.83,"text":"והמזרח גרמניה גרטה אבוג'יל דה אבואלי טוטי פרוטי."},{"start":1031.83,"end":1037.83,"text":"ובכן גבירותיי ורבותיי, המזרח גרמניה זכתה לא מכבר בקרב רב במקצה חזה של 100 מטרים,"},{"start":1037.83,"end":1042.83,"text":"ונעבור מיד לשידור התחרות, רק ניתן כמה מילים לסלמון מוניר מהמחקה בערבית."},{"start":1042.83,"end":1045.79,"text":"אלן הוא הסלמון, מלמזרח גרמניה ולאמריקניה."},{"start":1045.79,"end":1048.79,"text":"תודה רבה לך סלמון, בוא נעבור מיד לשידור ישיר של התחרות."},{"start":1048.79,"end":1051.79,"text":"גבירותיי ורבותיי, בוא נזניק את התחרות הזאת."},{"start":1051.79,"end":1054.95,"text":"ובכן, כן, התחרות יצאה לדרך!"},{"start":1054.95,"end":1073.95,"text":"סיול המזרר גרמניה רבותיי, עשתה זאת שוב."},{"start":1073.95,"end":1076.95,"text":"גרתה גרמניה רבותיי, עשתה זאת שוב."},{"start":1076.95,"end":1077.95,"text":"גרתה, בוא הנה, אני רוצה להפתח כמה מילים."},{"start":1077.95,"end":1080.95,"text":"הנה גרתה, בנצרת גוד מורי גרתה."},{"start":1080.95,"end":1083.87,"text":"ובכן גרתה, רציתי לדעת, כל הישראלים שתופיעים לך בבית,"},{"start":1083.87,"end":1085.91,"text":"איך את עושה זאת שנה שמינית ברציפות?"},{"start":1085.91,"end":1087.91,"text":"את מנצחת, האם זאת טכניקה?"},{"start":1087.91,"end":1090.13,"text":"משתי שיבת בלטט, אני זכיתי."},{"start":1090.13,"end":1092.63,"text":"כן, בהחלט."},{"start":1092.63,"end":1094.63,"text":"ובכן, תודה רבה לגרתה."},{"start":1094.63,"end":1097.63,"text":"אנחנו בטלוויזיה הישראלית נהיה איתכם כאן בשנה הבאה."},{"start":1097.63,"end":1100.63,"text":"בתחרות אליפות העולם בי-קלאס, רבותיי."},{"start":1100.63,"end":1102.63,"text":"יש תמורה בהנהגרה."},{"start":1102.63,"end":1103.63,"text":"תודה ולהתראות."},{"start":1103.63,"end":1113.46,"text":"מי?"},{"start":1113.46,"end":1115.14,"text":"מה?"},{"start":1115.14,"end":1116.38,"text":"מה קורה איתך?"},{"start":1116.38,"end":1117.38,"text":"מה עניינים?"},{"start":1117.38,"end":1118.38,"text":"איפה אתה?"},{"start":1118.38,"end":1119.38,"text":"לכיפה."},{"start":1119.38,"end":1120.38,"text":"ידע, מה נשמע?"},{"start":1125.59,"end":1128.64,"text":"ערב צה."},{"start":1128.64,"end":1131.86,"text":"החלסטרה של ז'וז'ו גאה לעריח הפעם"},{"start":1131.86,"end":1135.12,"text":"את התפריטים של כל מיני המשעדות והפאבים"},{"start":1135.12,"end":1137.12,"text":"שיצצים כפטריות די אשתקד."},{"start":1137.12,"end":1139.73,"text":"לא הבנתי מילה, אבל לא משנה."},{"start":1139.73,"end":1140.73,"text":"עכשיו תראו מה קורה."},{"start":1140.73,"end":1142.69,"text":"אתה נכנס בסבבה לאיזה מסעדה,"},{"start":1142.69,"end":1145.69,"text":"ואתה חושב שיהיה לך אחלה בילוי,"},{"start":1145.69,"end":1147.69,"text":"תזמין לאכול משהו איזה חומוס לנגב,"},{"start":1147.69,"end":1150.69,"text":"איזה קוס קפה, איזה צ'יפס."},{"start":1150.69,"end":1152.84,"text":"אמא שלי, מה שקטור פה זה יידיש."},{"start":1152.84,"end":1154.84,"text":"שופו, יידיש מדוברת."},{"start":1154.84,"end":1157.15,"text":"ואני אראה לכם, אני אתן לכם דוגמיות, שימו לב."},{"start":1157.15,"end":1159.23,"text":"מה תרצה לאכול?"},{"start":1159.23,"end":1161.92,"text":"שטרונגול מוקרם?"},{"start":1161.92,"end":1163.61,"text":"באמא שלי כתוב."},{"start":1163.61,"end":1167.06,"text":"שטרונגול, לא משפיל שהוא שטרונגול, הוא גם מוקרם."},{"start":1167.06,"end":1168.54,"text":"ורגע, חכו!"},{"start":1168.54,"end":1170.69,"text":"פטיטי חסה גמדית,"},{"start":1170.69,"end":1173.31,"text":"רצועות גבינה ולבבות דקל."},{"start":1173.31,"end":1175.27,"text":"באמא שלי, מה זה? ניתוח פתוח? מה זה?"},{"start":1175.27,"end":1177.47,"text":"זה תרומות איברים, זה לא אוכל הדבר הזה."},{"start":1177.47,"end":1178.89,"text":"אני משתגע, לא יאומן."},{"start":1178.89,"end":1179.73,"text":"מה תרצה?"},{"start":1179.73,"end":1185.37,"text":"פנכת פירות? מה זה פנכת? פנחת פנחת? מה זה? מה אני פחח? מה זה הדברים האלה?"},{"start":1185.37,"end":1190.09,"text":"אני רוצה להכנס, תביאו לי וטיח, תביאו לי קוסקוס, תביאו לי אוכל!"},{"start":1190.09,"end":1197.15,"text":"ומספיק עם החלסטרה הזה, הבנתם אותי? מוסר רסכים, פעם הבאה, שזה מלצר יבוא אלי בטעות,"},{"start":1197.15,"end":1204.32,"text":"ויגיד לי: \"אתה רוצה זרבובית מוקרמת?\" אני אביא לו קפה מוקפצת, וזה אמרו לכם, קפה מוקפצת."},{"start":1204.32,"end":1207.15,"text":"ותיזהרו ממני, ותחשבו על החלסטרה."},{"start":1209.53,"end":1241.07,"text":"אני פה! הלו, אני פה! אין לי לוזון! לא! אין לי קופטר! הלו, אני פה! משיק מסקנה! לא! מסוק מסוכן! יש לי, יש לי! הלו, אני פה! אני פה! הלו! עד ראש איצי, ואני היו אוקח!"},{"start":1241.07,"end":1243.74,"text":"תודה רבה."},{"start":1272.29,"end":1277.12,"text":"אתה משמרת. -איך רואים, באמת אתה לא, אתה ערבי."}]