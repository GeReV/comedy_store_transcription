[{"start":18.24,"end":41.19,"text":"שלום לכם כהל אני מציג את עצמי מיד, קוראים לי ג'וני בולצ'ית עם הבנג'ו הנייד."},{"start":41.19,"end":45.19,"text":"באתי לספר לכם סיפור מאוד עתיק, אותו יש לך מיד כמו הקדח מהנרטיק."},{"start":45.19,"end":50.19,"text":"לאיירה מוקד פושים יצא המערב, הגיעו צמד של פושים ילדון, קטם ואב."},{"start":50.19,"end":54.19,"text":"החליטו ברעים להילחם בכל נחיר, אבא טוב וילד עם שיער בכל נחיר."},{"start":54.19,"end":55.19,"text":"אוו יאה!"},{"start":55.19,"end":58.1,"text":"הוויה!"},{"start":58.1,"end":61.89,"text":"ליי, ליי, ליי..."},{"start":61.89,"end":76.37,"text":"אוי, אוי, אוי, אוי, אוי, אוי..."},{"start":76.37,"end":76.47,"text":"אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! אה! א"},{"start":76.37,"end":110.7,"text":"אהההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההההה"},{"start":110.7,"end":111.7,"text":"את הכובע!"},{"start":111.7,"end":114.78,"text":"כובע, של קש, בגינה ממש"},{"start":114.78,"end":120.93,"text":"עוד אחד נפל חלל"},{"start":120.93,"end":122.55,"text":"אין לדוואן בית דאס!"},{"start":122.55,"end":123.23,"text":"הוא! הוא!"},{"start":123.23,"end":124.43,"text":"אין לדוואן בית דאס!"},{"start":124.43,"end":124.97,"text":"הוא! הוא!"},{"start":124.97,"end":126.89,"text":"אין לדוואן גו! אין לדוואן גו!"},{"start":126.89,"end":128.19,"text":"אין לדוואן גו! אין לדוואן בית דאס!"},{"start":128.19,"end":129.57,"text":"יפת, שטח יומד!"},{"start":129.57,"end":131.23,"text":"מה זה הרעש הזה, תשתוק, אה?"},{"start":131.23,"end":133.12,"text":"הנה ג'ינו פני צלקי."},{"start":133.12,"end":137.5,"text":"יפת, קשי לדוק רב, בוא נציל את העיר הזה."},{"start":137.5,"end":139.26,"text":"איך?"},{"start":139.26,"end":143.84,"text":"אה, בא לדוק רב, אה?"},{"start":143.84,"end":148.67,"text":"באתי להציל את העיר, וחוץ מזה, אפש לי ברשותי, מנה."},{"start":148.67,"end":151.62,"text":"לא משפיע עליי כל השטויות שלך, יאללה עוף מפה."},{"start":151.62,"end":156.0,"text":"בוא בארץ, חם דלתמות, נתגשים לדור עצבות, בוא נכי."},{"start":156.0,"end":159.1,"text":"לא משפיע עליי, עכשיו לך."},{"start":159.1,"end":162.38,"text":"לך, לך למדבר, אני ברגים יובים."},{"start":162.38,"end":167.61,"text":"לא מפריע לי, ואם אתה מעלץ אותי, אני יכול לפגוע בך בול בלב."},{"start":167.61,"end":174.02,"text":"כמו הלב, כמו לב היה, לבו של מרקו, בוא בוא."},{"start":174.02,"end":175.1,"text":"אה!"},{"start":175.1,"end":176.48,"text":"אין ברירה!"},{"start":176.48,"end":179.23,"text":"prepare to die!"},{"start":179.23,"end":180.59,"text":"יפת!"},{"start":180.59,"end":188.14,"text":"הנשק הסודי!"},{"start":188.14,"end":199.16,"text":"יש פגעי נור!"},{"start":199.16,"end":202.08,"text":"יאהה!"},{"start":202.08,"end":207.2,"text":"אה, בראבו יפת, אה, בראבו, איזה יופי, יצאת לתעיירה, בוא נעבור לעיירה הבאה."},{"start":207.2,"end":208.21,"text":"אבא!"},{"start":208.21,"end":208.89,"text":"אה?"},{"start":208.89,"end":210.38,"text":"לא שילמת לזונה."},{"start":210.38,"end":211.79,"text":"אז היה אונדאוס."},{"start":211.79,"end":216.67,"text":"כן, ככה חם ויפת נדדו מכפר לעיר, את כל המבלים לדוקו חוש על זה מרשיר."},{"start":216.67,"end":219.93,"text":"מוסר אזכה לקשיבו לי, כי זה פשוט נורא."},{"start":219.93,"end":222.65,"text":"במקום לקנות אקדח אז יצטרפו לחוג זמרא."},{"start":222.65,"end":234.75,"text":"זה יקדח המיטי תרים ידיים ותן את כל הכסף שיש בפה!"},{"start":234.75,"end":239.69,"text":"קביאו את הכסף יש עוד פעם שעוד, את כל הכסף מהכספת."},{"start":239.69,"end":240.81,"text":"דנית."},{"start":240.81,"end":241.86,"text":"סינית."},{"start":241.86,"end":242.66,"text":"בינדר."},{"start":242.66,"end":244.02,"text":"already did it."},{"start":244.02,"end":245.46,"text":"do it tomorrow."},{"start":245.46,"end":248.57,"text":"שעוד דפק אורביץ זה שעוד!"},{"start":248.57,"end":251.71,"text":"קביאו את הכסף יש עוד שעוד."},{"start":251.71,"end":253.25,"text":"דנית."},{"start":253.25,"end":254.38,"text":"סינית."},{"start":254.38,"end":255.1,"text":"פרסית."},{"start":255.1,"end":255.9,"text":"גורדית."},{"start":255.9,"end":257.66,"text":"doing it tomorrow."},{"start":257.66,"end":259.77,"text":"פרסית."},{"start":259.77,"end":262.14,"text":"פרסית."},{"start":262.14,"end":263.24,"text":"דנית."},{"start":263.24,"end":264.24,"text":"סיגי."},{"start":264.24,"end":265.24,"text":"סמדית."},{"start":265.24,"end":266.24,"text":"סימא."},{"start":266.24,"end":268.27,"text":"doing it tomorrow."},{"start":268.27,"end":269.27,"text":"לא לזוס! זה שעוד!"},{"start":269.27,"end":270.27,"text":"זה פצטת אדום!"},{"start":270.27,"end":271.27,"text":"תחבוד שאת המחביץ!"},{"start":271.27,"end":272.27,"text":"תמיד את הגסף מיד!"},{"start":272.27,"end":273.33,"text":"עשינו!"},{"start":273.33,"end":274.33,"text":"ראינו!"},{"start":274.33,"end":275.33,"text":"העינו!"},{"start":275.33,"end":276.33,"text":"שמינו!"},{"start":276.33,"end":278.33,"text":"doing it tomorrow!"},{"start":278.33,"end":280.42,"text":"אה, זה שעוד וזה יויו האמיתי!"},{"start":280.42,"end":281.51,"text":"וואה!"},{"start":281.51,"end":282.51,"text":"וואה!"},{"start":282.51,"end":284.51,"text":"את זה עוד לא עשינו!"},{"start":284.51,"end":285.51,"text":"וואה!"},{"start":285.51,"end":286.46,"text":"יויו!"},{"start":286.46,"end":287.67,"text":"יויו!"},{"start":287.67,"end":289.67,"text":"כלי הנשק המושלם לשוד הבנק שלך!"},{"start":289.67,"end":334.93,"text":"שעמות 47 יצא חוקר נפורסם למצוא את האוצר העבוד במערות מדבר יהודה."},{"start":334.93,"end":336.86,"text":"שמו היה אינדיאנה ג'ונס."},{"start":336.86,"end":338.5,"text":"ג'ונס."},{"start":338.5,"end":339.5,"text":"אינדיאנה ג'ונס."},{"start":339.5,"end":340.85,"text":"אינדי?"},{"start":340.85,"end":342.07,"text":"זה לא מסוכן?"},{"start":342.07,"end":343.48,"text":"רואיתי למערה."},{"start":343.48,"end":344.48,"text":"אל תדאגי."},{"start":344.48,"end":346.48,"text":"כל עוד עתיתי יהיה בסדר."},{"start":346.48,"end":348.93,"text":"הוא כל כך גברי."},{"start":348.93,"end":349.93,"text":"אה?"},{"start":349.93,"end":373.65,"text":"אה?"},{"start":373.65,"end":385.03,"text":"לך שאין לך מה לדאור, כל עוד עתיתי."},{"start":385.03,"end":386.03,"text":"שעתיתי, נכון?"},{"start":386.03,"end":433.15,"text":"כשאני מתקרב לאוצר,"},{"start":433.15,"end":441.48,"text":"בארון הקבורה המצרי,"},{"start":441.48,"end":443.71,"text":"של יד המומיה."},{"start":443.71,"end":444.98,"text":"אישה, אישה, סליחה."},{"start":444.98,"end":455.61,"text":"זה פה שלוש פעמים?"},{"start":455.61,"end":469.57,"text":"סופראנה שיהיה פה צער."},{"start":469.57,"end":473.08,"text":"הנה המצלמה של חי בלו."},{"start":473.08,"end":477.6,"text":"סלמי היה איגר שלנו."},{"start":477.6,"end":480.37,"text":"למה אנחנו ראית דנוצה?"},{"start":480.37,"end":482.37,"text":"לא ראית למי הצוצקלך?"},{"start":482.37,"end":483.62,"text":"ואני עוד אומר,"},{"start":483.62,"end":485.62,"text":"היא חיה עומדה."},{"start":485.62,"end":486.73,"text":"מה?"},{"start":486.73,"end":487.87,"text":"הוא עומד."},{"start":487.87,"end":488.9,"text":"היא חיה."},{"start":488.9,"end":490.9,"text":"והמומיה שלנו,"},{"start":490.9,"end":491.9,"text":"היא השאלה."},{"start":491.9,"end":492.9,"text":"המומיה!"},{"start":492.9,"end":493.9,"text":"שעבר אותם בדרך."},{"start":493.9,"end":494.9,"text":"מי המומיה?"},{"start":494.9,"end":495.9,"text":"שים לך."},{"start":495.9,"end":498.15,"text":"הוא שער אותי כבר."},{"start":498.15,"end":501.15,"text":"אני המומיה."},{"start":501.15,"end":502.15,"text":"אני אומר,"},{"start":502.15,"end":503.15,"text":"זה המומיה או לא?"},{"start":503.15,"end":504.15,"text":"זה לא,"},{"start":504.15,"end":505.15,"text":"כמיש אמיתי."},{"start":505.15,"end":506.15,"text":"זה הכמיש."},{"start":506.15,"end":508.14,"text":"אני יושב לבד,"},{"start":508.14,"end":509.14,"text":"מי?"},{"start":509.14,"end":510.14,"text":"הוא חשוב."},{"start":510.14,"end":512.23,"text":"אני עוד אומר."},{"start":512.23,"end":513.41,"text":"עד כאן,"},{"start":513.41,"end":515.4,"text":"חיים לו."},{"start":515.4,"end":517.52,"text":"בואו נחזור לטרד פי."},{"start":517.52,"end":521.03,"text":"הוא חשוב."},{"start":521.03,"end":522.03,"text":"הוא חשוב."},{"start":522.03,"end":525.13,"text":"חיים!"},{"start":525.13,"end":527.22,"text":"חיים!"},{"start":527.22,"end":529.82,"text":"חיים דהי בלי צחוק אם זה לא מצחיק."},{"start":529.82,"end":531.29,"text":"חיים!"},{"start":531.29,"end":532.29,"text":"חיים תוציא אותי!"},{"start":532.29,"end":534.08,"text":"חיים!"},{"start":534.08,"end":536.26,"text":"תוציא אותי!"},{"start":536.26,"end":537.29,"text":"חיים!"},{"start":537.29,"end":547.93,"text":"שלום כמה מן ברמיזו סאודיה."},{"start":547.93,"end":549.93,"text":"פי תשעונוס דקקה."},{"start":549.93,"end":550.93,"text":"פאק רוגרס."},{"start":550.93,"end":552.93,"text":"נורי מסכין וליד עיין."},{"start":552.93,"end":554.93,"text":"פי תתרשעקו."},{"start":554.93,"end":556.82,"text":"עד..."},{"start":556.82,"end":558.82,"text":"נורי נורי נורי."},{"start":558.82,"end":563.3,"text":"מין ברמיס ההודיה."},{"start":563.3,"end":565.3,"text":"פי תשעונוס."},{"start":565.3,"end":571.33,"text":"מין תלפייסיון לאיס ראיילי, מין אורشالים אלקות."},{"start":571.33,"end":578.1,"text":"מיקייבר על אחלה עבודה, פילتاتרה, שקיה נורי."},{"start":578.1,"end":580.1,"text":"לא, לא, אני אצל במהבים בפתוח."},{"start":580.1,"end":584.06,"text":"זה כבר, זה זרירי, פתאסע, עונוס, די נסטו."},{"start":584.06,"end":587.6,"text":"תרשעקו, תרשעקו."},{"start":587.6,"end":596.43,"text":"קהווי, קהווי, אושלם כה, מן ברامי סעודיה, פתאסע, עונוס, דקיקה, מגייבת."},{"start":596.43,"end":601.43,"text":"לא, לא, פתאסע, עונוס, תחדירו ותזريו ולדعיין, אלבה מפתוח."},{"start":601.43,"end":602.43,"text":"מרחב, מרחב."},{"start":602.43,"end":611.46,"text":"אושלם כה, מן ברامי סעודיה, פתאסע, עונוס, דקיקה, מגייבת."},{"start":611.46,"end":614.46,"text":"לא, לא, פתאסע, עונוס, בלו סיבاستيان."},{"start":614.46,"end":638.91,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":638.91,"end":646.08,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":646.08,"end":651.96,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":651.96,"end":656.87,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":656.87,"end":658.84,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":658.84,"end":662.84,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":662.84,"end":669.37,"text":"לא, פתאסע, עונוס, דקיקה, מגייבת."},{"start":669.37,"end":672.37,"text":"ולמגי, פתאסע, עונוס, דקיקה, מגייבת."},{"start":672.37,"end":682.0,"text":"ולמגי, פתאסע, עונוס, דקיקה, מגייבת."},{"start":682.0,"end":688.77,"text":"פתאסע, עונוס, דקיקה, מגייבת."},{"start":688.77,"end":691.77,"text":"ולמגי, פתאסע, עונוס, דקיקה, מגייבת."},{"start":691.77,"end":697.42,"text":"ולמגי, פתאסע, עונוס, דקיקה, מגייבת."},{"start":697.42,"end":704.62,"text":"פתאסע, עונוס, דקיקה, מגייבת."},{"start":704.62,"end":710.22,"text":"נורי, סלם ותעלם."},{"start":710.22,"end":712.22,"text":"נורי, סלם ותעלם."},{"start":712.22,"end":714.73,"text":"ילבב, מפתוח?"},{"start":714.73,"end":715.82,"text":"דרבנק!"},{"start":715.82,"end":717.82,"text":"אבו-Jamil, هذه, טלפיסיון."},{"start":717.82,"end":719.82,"text":"הלו, לולו!"},{"start":719.82,"end":720.82,"text":"מגייבי!"},{"start":720.82,"end":722.82,"text":"במה, במה, במה."},{"start":722.82,"end":724.82,"text":"נורי, לוק, from Kufsatsi Murim."},{"start":724.82,"end":727.82,"text":"I made you a doobie."},{"start":727.82,"end":730.07,"text":"מידי, מידי, מידי?"},{"start":730.07,"end":730.6,"text":"הילה?"},{"start":730.6,"end":732.28,"text":"הילה?"},{"start":732.28,"end":736.05,"text":"הילה?"},{"start":736.05,"end":736.85,"text":"סורי, סורי."},{"start":736.85,"end":738.42,"text":"הילה?"},{"start":738.42,"end":739.42,"text":"הילה?"},{"start":739.42,"end":740.42,"text":"הילה?"},{"start":740.42,"end":741.42,"text":"הילה?"},{"start":741.42,"end":742.42,"text":"הילה?"},{"start":742.42,"end":743.42,"text":"הילה?"},{"start":743.42,"end":744.42,"text":"הילה?"},{"start":744.42,"end":745.42,"text":"הילה?"},{"start":745.42,"end":746.42,"text":"הילה?"},{"start":746.42,"end":747.42,"text":"הילה?"},{"start":747.42,"end":748.42,"text":"הילה?"},{"start":748.42,"end":749.39,"text":"הילה?"},{"start":749.39,"end":750.39,"text":"הילה?"},{"start":750.39,"end":751.39,"text":"הילה?"},{"start":751.39,"end":752.58,"text":"הילה?"},{"start":752.58,"end":753.58,"text":"הילה?"},{"start":753.58,"end":754.58,"text":"הילה?"},{"start":754.58,"end":756.53,"text":"הילה?"},{"start":756.53,"end":757.5,"text":"הילה?"},{"start":757.5,"end":758.5,"text":"הילה?"},{"start":758.5,"end":759.5,"text":"הילה?"},{"start":759.5,"end":760.48,"text":"הילה?"},{"start":760.48,"end":763.93,"text":"הילה?"},{"start":763.93,"end":769.93,"text":"הילה נמצא כאן בנבי אספלט, ואיתי נמצא בן אדם ששבר כרגע את השיא העולמי בעמידה על רגל אחת."},{"start":769.93,"end":772.19,"text":"שלום לך מר אברהם קאץ."},{"start":772.19,"end":773.18,"text":"שלום רב."},{"start":773.18,"end":777.21,"text":"שלום שלום, אני מבין שאתה שברת את השיא העולמי בעמידה על רגל אחת."},{"start":777.21,"end":783.2,"text":"כן, כן, מי שיחס בשיא הקודם זה היה יום הורגון מפנסילבניה, הוא עמד על רגל אחת ברציפות שבוע וחצי."},{"start":783.2,"end":784.2,"text":"וכמה זמן אתה עומד?"},{"start":784.2,"end":785.2,"text":"שלוש וחצי שנים."},{"start":785.2,"end":786.2,"text":"שלוש וחצי שנים."},{"start":786.2,"end":788.2,"text":"שלוש וחצי שנים ואותה ברבותיי."},{"start":788.2,"end":793.2,"text":"כן, שלוש וחצי שנים, שבעה ימים, ארבע שעות ו... 16 דקות בקירוב."},{"start":793.2,"end":796.2,"text":"סופנו בוודאי רוצים לדעת מה הוביל אותך לעמוד על רגל אחת."},{"start":796.2,"end":799.2,"text":"ובכן זה התחיל יום אחד שישבנו לאכול ארוחת ערב אני והבת שלי."},{"start":799.2,"end":800.2,"text":"היא לא רצה ללמוד את החביטה."},{"start":800.2,"end":801.2,"text":"אמרתי לה, תגמרי את החביטה."},{"start":801.2,"end":802.2,"text":"אמרתי לה, תגמרי את החביטה."},{"start":802.2,"end":809.2,"text":"אמרתי לה, אם את לא גמרי את החביטה, אני עומד לך רגל אחת עד שאת לא תגמרי את החביטה."},{"start":809.2,"end":812.2,"text":"צופנו בוודאי רוצים לדעת האם היא גמרה לאכולת החביטה כן או לא?"},{"start":812.2,"end":820.2,"text":"לא איפה זאת עקשנית כמו פרד. היא אמרה לי שאם אני לא מוריד את הרגל שלי, היא עולה על השולחן ונשארת שם על השולחן עד שאני לא הוריד את הרגל."},{"start":820.2,"end":824.2,"text":"וזה מה שמוביל אותנו לשיא עולמי חדש שנשבר גם כן היום."},{"start":824.2,"end":828.2,"text":"כן גבירותיי ורבותיי, אני נמצא כאן עם רותי קץ. ערב טוב לך רותי."},{"start":828.2,"end":830.2,"text":"מה? ערב טוב, ערב טוב."},{"start":830.2,"end":833.2,"text":"את עומדת על השולחן כבר כמה שנים, כמה בדיוק?"},{"start":833.2,"end":838.52,"text":"שלוש וחצי שנים, שני עשר יום ו-ארבעה חודשים בהם."},{"start":838.52,"end":841.52,"text":"צופנו בוודאי רוצים לדעת מתי תרדים מהשולחן."},{"start":841.52,"end":845.52,"text":"אני לא ארד מהשולחן, אני לא ארד עד שהאבא שלי לא יוריד את הרגל שלו לרצפה."},{"start":845.52,"end":847.52,"text":"אני לא יוריד את הרגל שלו לרצפה שלו תגמרית החביטה."},{"start":847.52,"end":849.52,"text":"אז לא יוריד ולא יוריד."},{"start":849.52,"end":851.52,"text":"אז אני גם לא יוריד, אני לא יוריד את הרגל, אני אשגל הרגל אחר."},{"start":851.52,"end":852.52,"text":"ראו, ראו, ראו."},{"start":852.52,"end":853.52,"text":"תגמרית החביטה."},{"start":853.52,"end":854.52,"text":"לא יוריד."},{"start":854.52,"end":855.52,"text":"תגמרית החביטה."},{"start":855.52,"end":856.52,"text":"תגמרית החביטה."},{"start":856.52,"end":858.52,"text":"משפחת קאץ, ראו, שברתם כל סי אפשרי."},{"start":858.52,"end":860.52,"text":"אולי הגיע הזמן לשלום בית."},{"start":860.52,"end":862.52,"text":"עד שלא פוחת החביטה, אין מה לדבר."},{"start":862.52,"end":863.52,"text":"גם אני לא לא נשאר כאן."},{"start":863.52,"end":864.52,"text":"רק שני היורם."},{"start":864.52,"end":866.52,"text":"תביא את הגיגית, אני רוצה להתקלח."},{"start":866.52,"end":869.53,"text":"כן, לי לא נותר אלא לאיים עליהם."},{"start":869.53,"end":871.53,"text":"אם אתה לא תרד מהרגל,"},{"start":871.53,"end":872.53,"text":"ואת לא תרדים מהשולחן,"},{"start":872.53,"end":874.53,"text":"אני עומד לחלל דבקה ולדלג."},{"start":874.53,"end":875.83,"text":"חלל דבקה."},{"start":875.83,"end":878.18,"text":"בבקשה."},{"start":878.18,"end":881.77,"text":"אני עומד לקפצה."},{"start":881.77,"end":884.21,"text":"אני נשאר את השולחן פה למעלה."},{"start":906.17,"end":909.17,"text":"איזה יופי שימון וביטון הפכו להגדה עוד בחייהם."},{"start":909.17,"end":913.17,"text":"אבל אני מדבר איתך בתור גרטל עכשיו."},{"start":913.17,"end":914.17,"text":"אה, שדת."},{"start":914.17,"end":917.96,"text":"שמה, מה עם כיפה אדומה? שווה או לא שווה?"},{"start":917.96,"end":919.96,"text":"מה זאת אומרת שווה או לא שווה? התחתנה, לא שמעת?"},{"start":919.96,"end":920.96,"text":"התחתנה מתי?"},{"start":920.96,"end":922.02,"text":"מה מתי? לפני שבועיים."},{"start":922.02,"end":923.02,"text":"ממי?"},{"start":923.02,"end":924.05,"text":"עם הזאב."},{"start":924.05,"end":925.02,"text":"הזאב מכיפה אדומה?"},{"start":925.02,"end":927.02,"text":"כן, זאב נחמה."},{"start":927.02,"end":928.21,"text":"מאת ניקס."},{"start":928.21,"end":929.21,"text":"מטרתה."},{"start":929.21,"end":930.21,"text":"מה אתה אומר? למה התחתנה איתו?"},{"start":930.21,"end":932.21,"text":"להשתחרר מהצבא."},{"start":932.21,"end":933.21,"text":"אה, בטח."},{"start":933.21,"end":937.34,"text":"לא, אז, בטל, בטל את המחשבה, בטל אותה דחור."},{"start":937.34,"end":938.34,"text":"בטל אותה מיידי."},{"start":938.34,"end":939.34,"text":"בטח, בטלתה?"},{"start":939.34,"end":940.34,"text":"בטלנו."},{"start":940.34,"end":941.34,"text":"יפה."},{"start":941.34,"end":942.34,"text":"הנה, באה למחשבה חדשה."},{"start":942.34,"end":943.3,"text":"יפה."},{"start":943.3,"end":944.78,"text":"שים לב."},{"start":944.78,"end":945.78,"text":"כן."},{"start":945.78,"end":954.31,"text":"החיים של הבן אדם זה בדיוק כמו בית שעשוי מממתקים עם המחשפה בפנים של הבית."},{"start":954.31,"end":957.11,"text":"באיזה סיר בשלו את אימא שלך?"},{"start":957.11,"end":958.45,"text":"נרוסת, למה?"},{"start":958.45,"end":960.45,"text":"למה זה לא פרקטימה שאתה מדבר עלי."},{"start":960.45,"end":961.45,"text":"למה?"},{"start":961.45,"end":962.45,"text":"מה זאת אומרת בית משוקולד?"},{"start":962.45,"end":963.45,"text":"זה בית מממתקים."},{"start":963.45,"end":965.45,"text":"בסדר אבל בחום הזה?"},{"start":965.45,"end":967.45,"text":"הבית תימס טיפול עליך התקרה."},{"start":967.45,"end":968.45,"text":"ממה עשויה התקרה?"},{"start":968.45,"end":969.45,"text":"מבאפלות."},{"start":969.45,"end":970.73,"text":"מבאפלות?"},{"start":970.73,"end":972.73,"text":"לאיזה דלת הפכה אמא שלך בחצות?"},{"start":972.73,"end":974.73,"text":"לא יודע, היה לנעל מסכוכית, למה?"},{"start":974.73,"end":976.73,"text":"בסדר, לא ידעתי, אני מצטער."},{"start":976.73,"end":979.73,"text":"אבל אל תשאל, נשבר לנעל שבועיים בבית חולים היינו."},{"start":979.73,"end":980.73,"text":"אה, כן?"},{"start":980.73,"end":981.73,"text":"יופי."},{"start":981.73,"end":983.73,"text":"אבל לא, למה אתה נכנס איתי למישור ש..."},{"start":983.73,"end":985.73,"text":"אני מדבר איתך במישור של הפילוסופיה."},{"start":985.73,"end":987.02,"text":"אה, לא הבאתי."},{"start":987.02,"end":990.02,"text":"לא במישור של ההגדות, נדבר במישור של הפילוסופיה."},{"start":990.02,"end":991.02,"text":"תשמע, תשמע, תשמע."},{"start":991.02,"end":993.62,"text":"מה קורה? נגיד את הילד, בסדר?"},{"start":993.62,"end":994.62,"text":"כן."},{"start":994.62,"end":995.59,"text":"את הילד קטן וחמוד."},{"start":995.59,"end":996.59,"text":"כן."},{"start":996.59,"end":997.59,"text":"לא באמת, במישור של הפילוסופיה."},{"start":997.59,"end":999.59,"text":"אה, בסדר, אבל חמוד, אני הבנתי שאתה לא רוצה להגיד לי."},{"start":999.59,"end":1000.59,"text":"בטח, יש גאיה."},{"start":1000.59,"end":1001.59,"text":"בדיוק, עכשיו תראה."},{"start":1001.59,"end":1003.59,"text":"אתה חמוד, ואתה גדל במקום יפה."},{"start":1003.59,"end":1004.59,"text":"כן."},{"start":1004.59,"end":1006.59,"text":"וכיף לך, והחיים ורודים, והכל טוב, נכון?"},{"start":1006.59,"end":1007.59,"text":"כן, כן."},{"start":1007.59,"end":1012.19,"text":"עכשיו, תבחוק את החיוך שלא יפחי את הילדים בבית."},{"start":1012.19,"end":1015.22,"text":"עכשיו, נגיד אתה באמצע של החלום שלך, נכון?"},{"start":1015.22,"end":1016.22,"text":"כן."},{"start":1016.22,"end":1017.22,"text":"עכשיו פתאום בא לך משהו מתוק."},{"start":1017.22,"end":1018.44,"text":"מה אתה עושה?"},{"start":1018.44,"end":1020.56,"text":"אני מביא ליקה לקיר."},{"start":1020.56,"end":1024.06,"text":"לא במישור של ההגדה, אני מדברת לך במישור הפילוסופי."},{"start":1024.06,"end":1025.06,"text":"בא לך משהו מתוק."},{"start":1025.06,"end":1027.06,"text":"אה, אה, אני בא לאימה, אני בא לאימה."},{"start":1027.06,"end":1029.06,"text":"אני אומר לאימה, תביא לי משהו מתוק."},{"start":1029.06,"end":1031.06,"text":"בדיוק, ומה אימה עושה?"},{"start":1031.06,"end":1033.06,"text":"אימה מביאה לי קפה."},{"start":1033.06,"end":1034.06,"text":"בדיוק, זה המחשבה?"},{"start":1034.06,"end":1035.88,"text":"איזה מחשבה?"},{"start":1035.88,"end":1043.9,"text":"של המישור הפילוסופי שהחיים הם חיים מתוקים והם לאים ממתקים והכל כיף עד שבא לך הקפה בפנים."},{"start":1043.9,"end":1046.01,"text":"הבנתי."},{"start":1046.01,"end":1048.69,"text":"אז תגיד אני גם כן יכול להעביר מחשבה."},{"start":1048.69,"end":1049.94,"text":"שדר."},{"start":1049.94,"end":1053.34,"text":"למה אני יצאתי גרטל עם עצמה המטומטמת?"},{"start":1053.34,"end":1056.29,"text":"א', התשובה תמונה בגוף השאלה."},{"start":1056.29,"end":1065.56,"text":"ב', תראה, אם היינו משאירים אותך המקרחת, הילדים היו פוחדים, היו חושבים התערה מהחיה והיפה, המכוער, המפחידה שהיפה והחיה."},{"start":1065.56,"end":1070.56,"text":"אה, המפלץ, המפלץ, זהו, המפלץ, זהו, הבנתי."},{"start":1070.56,"end":1071.68,"text":"באמת, מה?"},{"start":1071.68,"end":1075.34,"text":"באה לי מחשפה."},{"start":1075.34,"end":1076.37,"text":"באיזה מישור?"},{"start":1076.37,"end":1078.95,"text":"במישור של הפחד, באה לי מחשפה."},{"start":1078.95,"end":1087.69,"text":"ילדים, איפה אתם הולכים באמצע הגדה?"},{"start":1087.69,"end":1094.3,"text":"הנידון למוות, רובן סוולדרמה."},{"start":1094.3,"end":1098.12,"text":"מילים אחרונות, בבקשה."},{"start":1098.12,"end":1101.77,"text":"איזה יופי של דבר זה!"},{"start":1101.77,"end":1102.77,"text":"תודה רבה."},{"start":1102.77,"end":1104.77,"text":"מה זה מיוחד? זה מעץ, מה זה, אה?"},{"start":1104.77,"end":1106.73,"text":"זה חזק הדבר הזה, אה?"},{"start":1106.73,"end":1107.73,"text":"חזק, חזק מאוד."},{"start":1107.73,"end":1109.73,"text":"על איזה פרינסיפ זה עובד, אה?"},{"start":1109.73,"end":1112.73,"text":"אני שם לך את הלולאה מהדי כטיפה,"},{"start":1112.73,"end":1114.73,"text":"אתה עומד על הדלת,"},{"start":1114.73,"end":1116.73,"text":"אני פותח את הדלת עם הידית ואתה מת!"},{"start":1116.73,"end":1117.73,"text":"וואלה, הבנתי, הבנתי."},{"start":1117.73,"end":1119.73,"text":"החבל הזה החזיק אותי, מה זה?"},{"start":1119.73,"end":1121.73,"text":"כן, כן, זה חבל חזק מאוד."},{"start":1121.73,"end":1123.73,"text":"זה דבר חדש זה? אתה המצאתה את זה?"},{"start":1123.73,"end":1125.73,"text":"לא, זה מאוד פשוט, הכי בנאלי."},{"start":1125.73,"end":1126.82,"text":"אוקיי."},{"start":1126.82,"end":1129.29,"text":"יש לך איזו בקשה האחרונה?"},{"start":1129.29,"end":1130.35,"text":"לא."},{"start":1130.35,"end":1131.34,"text":"לא."},{"start":1131.34,"end":1132.34,"text":"אז נתחיל."},{"start":1132.34,"end":1133.34,"text":"בקשה."},{"start":1133.34,"end":1136.07,"text":"מה על ההורג?"},{"start":1136.07,"end":1139.89,"text":"רגע, רגע, שמיעה, רגע."},{"start":1139.89,"end":1140.88,"text":"לא הבנתי."},{"start":1140.88,"end":1141.88,"text":"כן, מה אתה אמרת לי?"},{"start":1141.88,"end":1144.03,"text":"אתה אמרת לי שזה הכי בנאלי"},{"start":1144.03,"end":1146.67,"text":"או שזה הכי בנאלי?"},{"start":1146.67,"end":1148.7,"text":"אני אמרת לך שזה הכי בנאלי."},{"start":1148.7,"end":1150.7,"text":"לא, לא, אתה לא הבנת, שנייה."},{"start":1150.7,"end":1152.7,"text":"אני עדיין לא הבנתי."},{"start":1152.7,"end":1154.7,"text":"האם זה הכי בנאלי"},{"start":1154.7,"end":1158.06,"text":"או שזה הכי בנאלי?"},{"start":1158.06,"end":1159.06,"text":"מה יש כאלו לביא?"},{"start":1159.06,"end":1160.06,"text":"זה הכי בנאלי."},{"start":1160.06,"end":1162.06,"text":"מה זה לא, זה שני דברים שונים לגמרי."},{"start":1162.06,"end":1163.06,"text":"רגע, שנייה."},{"start":1163.06,"end":1165.21,"text":"יש הכי בנאלי."},{"start":1165.21,"end":1167.21,"text":"זה אחד, תשים בצד."},{"start":1167.21,"end":1168.21,"text":"כן."},{"start":1168.21,"end":1169.4,"text":"ויש הכי בנאלי."},{"start":1169.4,"end":1171.42,"text":"אני אומר לך הכי בנאלי."},{"start":1171.42,"end":1172.42,"text":"מה יש כאלו לביא?"},{"start":1172.42,"end":1174.42,"text":"נו, עכשיו אני לא נקור את זה."},{"start":1174.42,"end":1175.42,"text":"מה זאת אומרת?"},{"start":1175.42,"end":1177.42,"text":"יש הכי בנאלי ויש הכי בנאלי."},{"start":1177.42,"end":1178.42,"text":"מה יש בנאלי?"},{"start":1178.42,"end":1179.42,"text":"שאווי זה הכי בנאלי."},{"start":1179.42,"end":1180.42,"text":"מה זה הכי בנאלי?"},{"start":1180.42,"end":1182.42,"text":"רומץ, רומץ."},{"start":1182.42,"end":1183.42,"text":"רומץ, רומץ."},{"start":1183.42,"end":1185.45,"text":"מה זה המתקן המטופש הזה?"},{"start":1185.45,"end":1186.39,"text":"מי בנאל את זה?"},{"start":1186.39,"end":1190.09,"text":"עבר'ה, רגע, רגע."},{"start":1190.09,"end":1195.16,"text":"דפוק זה הדבר הזה."},{"start":1195.16,"end":1196.67,"text":"דה!"},{"start":1196.67,"end":1199.75,"text":"בממלכה רחוקה אי שם,"},{"start":1199.75,"end":1201.75,"text":"חיו להם בשלווא ואושך."},{"start":1201.75,"end":1205.75,"text":"מלך, ביתו הנסיכה ובנו הנסיכ."},{"start":1205.75,"end":1212.83,"text":"שלום אדוני המלך."},{"start":1212.83,"end":1214.83,"text":"שלום בנאי יקרים."},{"start":1214.83,"end":1215.83,"text":"איפה הייתם ומה עשיתם?"},{"start":1215.83,"end":1217.83,"text":"היינו ב..."},{"start":1217.83,"end":1222.16,"text":"במגרש כדורגל."},{"start":1222.16,"end":1223.22,"text":"מה פתאום?"},{"start":1223.22,"end":1224.22,"text":"פליסיה!"},{"start":1224.22,"end":1225.35,"text":"פליסיה!"},{"start":1225.35,"end":1226.31,"text":"באים כאן."},{"start":1226.31,"end":1230.25,"text":"ועשינו שמה."},{"start":1230.25,"end":1231.47,"text":"בניתם שידה?"},{"start":1231.47,"end":1233.88,"text":"כן, בנינו שידה."},{"start":1233.88,"end":1234.88,"text":"מנה רוסקה."},{"start":1234.88,"end":1236.88,"text":"ארונית, ארונית קטנה עם גרזש."},{"start":1236.88,"end":1240.88,"text":"פליסיה, היום עלו לך 35 שנים."},{"start":1240.88,"end":1241.88,"text":"35 שנים?"},{"start":1241.88,"end":1243.82,"text":"פליסיה, פליסיה!"},{"start":1243.82,"end":1246.0,"text":"ותרם מצאת חתן."},{"start":1246.0,"end":1251.03,"text":"פליסיה, עברו כאן כל כך הרבה נסיכים ועדיין לא מצאת את בכיר ליבך."},{"start":1251.03,"end":1256.03,"text":"פליסיה, גם את אם תרצי תוכלי לשנות את סוף המחזה וזהו זה."},{"start":1256.03,"end":1258.22,"text":"פליסיה, למה עינך מוצאת חתן?"},{"start":1258.22,"end":1263.94,"text":"אבא, אני מחפשת את אביר חלומותה."},{"start":1263.94,"end":1268.72,"text":"פליסיה, בואי נאכל משהו."},{"start":1268.72,"end":1270.78,"text":"מה את רוצה לאכול ליום הולדתך?"},{"start":1270.78,"end":1275.16,"text":"אני הייתי רוצה ארוחה צרפתית אבא."},{"start":1275.16,"end":1277.38,"text":"נהן בעיות, מוריס!"},{"start":1277.38,"end":1282.99,"text":"בבקשה, ארוחה צרפתית מלכותית."},{"start":1282.99,"end":1285.99,"text":"הספציאליטה שלנו רגלי צפרדיה."},{"start":1285.99,"end":1289.84,"text":"רגלי צפרדיה?"},{"start":1289.84,"end":1292.09,"text":"מעדן מלאכי."},{"start":1292.09,"end":1301.2,"text":"סוף סוף מצאתי את נסיך על עמותיי."},{"start":1301.2,"end":1306.2,"text":"וכך הם חיים באושר ובאושר עד עצם היום הזה."},{"start":1306.2,"end":1307.29,"text":"איזה פיקה."},{"start":1307.29,"end":1309.23,"text":"מושרים נחף רגל."},{"start":1309.23,"end":1310.11,"text":"ועדון."}]