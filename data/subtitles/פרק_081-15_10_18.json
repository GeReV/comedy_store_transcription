[{"start":0.83,"end":18.08,"text":"יזמין"},{"start":18.08,"end":20.08,"text":"לא יכול להיות מה זה?"},{"start":20.08,"end":22.08,"text":"אמרתי המנוי אליו אתה עומד לחייג"},{"start":22.08,"end":24.08,"text":"לא יהיה זמין"},{"start":24.08,"end":26.08,"text":"רגע מאיפה זה יודע לאן אני הולך לחייג?"},{"start":26.08,"end":28.59,"text":"אני לא זה אני הודעה מוקלטת"},{"start":28.59,"end":30.54,"text":"מה מה מה מה מה מה מה מה מה מה מה אז רגע איך את יודעת ששהוא לא"},{"start":30.54,"end":32.55,"text":"אם את כל כך חכמה כן אז למי אני עומד"},{"start":32.55,"end":34.55,"text":"להתקשר?"},{"start":34.55,"end":36.55,"text":"אתה עומד לחייג אל המנוי יהודה אברהמי"},{"start":36.55,"end":38.55,"text":"ידידך מתקופת הטירונות"},{"start":38.55,"end":40.55,"text":"איתו עשית מילואים לפני כחודש"},{"start":40.55,"end":42.53,"text":"בביר אלו סוף סופו"},{"start":42.53,"end":44.8,"text":"נכון עשיתי את זה"},{"start":44.8,"end":46.8,"text":"אז למה? למה הוא לא בבית? איפה? איפה הוא?"},{"start":46.8,"end":48.8,"text":"המנוי יהודה אברהמי לא יהיה זמין"},{"start":48.8,"end":50.8,"text":"בפני שהוא צופה עכשיו בתוכנית"},{"start":50.8,"end":52.8,"text":"הקומדיסטור שתחל מיד בתום"},{"start":52.8,"end":54.89,"text":"הפרסומות"},{"start":54.89,"end":56.88,"text":"טוב תודה אני תקשר לאשתי"},{"start":56.88,"end":58.88,"text":"נגיד לה שיש קומדיסטור"},{"start":58.88,"end":60.88,"text":"המנוי אליו אתה עומד לחייג לא יהיה זמין"},{"start":60.88,"end":62.88,"text":"רגע רגע רגע למה לא יהיה זמין"},{"start":62.88,"end":64.88,"text":"גם אשתי צריכה להיות בבית עכשיו"},{"start":64.88,"end":66.88,"text":"אשתך המנויה ריקה מתושלח"},{"start":66.88,"end":68.88,"text":"נמצאת כרגע במיטתו של אותו ידידך"},{"start":68.88,"end":70.88,"text":"המנוי יהודה אברהמי"},{"start":70.88,"end":74.88,"text":"מייחד בתוכנית הקומדיסטור שתחל מיד בתום הפרסומות"},{"start":74.88,"end":76.29,"text":"תודה רבה לך"},{"start":76.29,"end":77.8,"text":"ריבקה"},{"start":77.8,"end":81.02,"text":"הקומדיסטור מיד בתום הפרסומות"},{"start":81.02,"end":88.73,"text":"תוכנית זו מבוססת על מקרים שהתרחשו במזיאות"},{"start":88.73,"end":93.87,"text":"כל קשר בין המציאות לדמיון הינו מקרי בהחלט"},{"start":93.87,"end":99.62,"text":"כמות האנשים והמקומות שונו לצורך העלילה"},{"start":99.62,"end":101.62,"text":"ומאתה הם ניקאים"},{"start":101.62,"end":131.25,"text":"הקומד"},{"start":131.25,"end":132.25,"text":"כן, החלקה שבע"},{"start":132.25,"end":134.57,"text":"האמון שלכם עומד להתחיל"},{"start":134.57,"end":137.57,"text":"חסר לכם שאתם לא מתקתקים אותו פיקס"},{"start":137.57,"end":140.89,"text":"יש איזה בעיות צעד מין כלכלה"},{"start":140.89,"end":142.49,"text":"רפא"},{"start":142.49,"end":143.93,"text":"מי אנחנו?"},{"start":143.93,"end":144.93,"text":"חל רגלים"},{"start":144.93,"end":145.93,"text":"אין כמונו"},{"start":145.93,"end":146.93,"text":"חל רגלים"},{"start":146.93,"end":147.93,"text":"כי אנחנו"},{"start":147.93,"end":148.93,"text":"חל רגלים"},{"start":148.93,"end":149.93,"text":"חל רגלים"},{"start":149.93,"end":150.93,"text":"אל אל אלים"},{"start":150.93,"end":151.93,"text":"אל אל אלים"},{"start":151.93,"end":152.93,"text":"אל אל אלים"},{"start":152.93,"end":153.93,"text":"מה לא"},{"start":153.93,"end":155.79,"text":"תגיע לכאן"},{"start":155.79,"end":156.79,"text":"תגיע לכאן"},{"start":156.79,"end":160.03,"text":"הלום"},{"start":160.03,"end":161.44,"text":"איך קוראים לך חייל?"},{"start":161.44,"end":162.44,"text":"קוראים לך חייל"},{"start":162.44,"end":163.44,"text":"ניסים"},{"start":163.44,"end":165.6,"text":"ניסים מה?"},{"start":165.6,"end":166.59,"text":"ניסים בוסקילה"},{"start":166.59,"end":168.97,"text":"בוסקילה מה?"},{"start":168.97,"end":170.0,"text":"מה מה?"},{"start":170.0,"end":172.58,"text":"בוסקילה זהו נחרדיה"},{"start":172.58,"end":174.58,"text":"זהו נחרדיה יותר נגמר"},{"start":174.58,"end":176.73,"text":"נגמר מה?"},{"start":176.73,"end":178.69,"text":"גמר השם נחרדיה"},{"start":178.69,"end":180.69,"text":"ניסים בוסקילה וזהו"},{"start":180.69,"end":183.69,"text":"ניסים בוסקילה וזהו המפקד"},{"start":183.69,"end":185.12,"text":"לא"},{"start":185.12,"end":186.65,"text":"ניסים בוסקילה"},{"start":186.65,"end":188.22,"text":"זהו"},{"start":188.22,"end":190.22,"text":"ניסים בוסקילה המפקד"},{"start":190.22,"end":191.22,"text":"המפקד"},{"start":191.22,"end":192.22,"text":"המפקד"},{"start":192.22,"end":193.22,"text":"המפקד"},{"start":193.22,"end":194.64,"text":"אני אמרתי"},{"start":194.64,"end":195.64,"text":"לא חשוב"},{"start":195.64,"end":197.28,"text":"לא חשוב"},{"start":197.28,"end":198.28,"text":"תגיד לחייל"},{"start":198.28,"end":199.24,"text":"מה אתה עושה פה?"},{"start":199.24,"end":201.78,"text":"מילואים עבודה ביטוח לאומי"},{"start":201.78,"end":205.57,"text":"אתה יודע שאנחנו עומדים לערוך אימון"},{"start":205.57,"end":208.51,"text":"שכולל שימוש בנשק חם"},{"start":208.51,"end":210.17,"text":"רובים"},{"start":210.17,"end":211.23,"text":"כאלה שיורים"},{"start":211.23,"end":213.22,"text":"אתה פעם החזקת ביד שלך רובה"},{"start":213.22,"end":215.22,"text":"השתמשת פעם במטווח"},{"start":215.22,"end":217.22,"text":"אתה יודע להחזיק נשק"},{"start":217.22,"end":219.22,"text":"אתה יודע בכלל להשתמש ברובה"},{"start":219.22,"end":221.22,"text":"אתה פעם בחיים שלך היית במילואים"},{"start":221.22,"end":222.22,"text":"זאת צורה של חייל"},{"start":222.22,"end":224.22,"text":"אתה בכלל יכול לתות משהו"},{"start":224.22,"end":227.93,"text":"מילואים עבודה"},{"start":227.93,"end":228.93,"text":"אוקיי"},{"start":228.93,"end":230.93,"text":"נראה מה אתה יודע"},{"start":230.93,"end":232.47,"text":"תוך עשר שניות"},{"start":232.47,"end":234.6,"text":"היית במטווח"},{"start":234.6,"end":235.56,"text":"התחלת לראות"},{"start":235.56,"end":236.56,"text":"קדימה"},{"start":236.56,"end":237.56,"text":"זוז עוד"},{"start":274.17,"end":276.17,"text":"בסדר ניסים בסדר"},{"start":276.17,"end":277.17,"text":"איך אתה ברימונים"},{"start":277.17,"end":278.17,"text":"רימונים"},{"start":278.17,"end":279.29,"text":"רימונים"},{"start":279.29,"end":280.29,"text":"רימונים"},{"start":280.29,"end":281.29,"text":"לימונים"},{"start":281.29,"end":282.29,"text":"לימונים"},{"start":282.29,"end":283.29,"text":"בואו תגיע אהנה"},{"start":283.29,"end":284.29,"text":"אנחנו עושים תרגול את רימון"},{"start":284.29,"end":286.29,"text":"המון לימון לגן לניסים"},{"start":286.29,"end":287.55,"text":"אוקיי"},{"start":287.55,"end":288.55,"text":"מחלקה שבע"},{"start":288.55,"end":290.53,"text":"הגענו לשלב הקשה של האימון"},{"start":290.53,"end":293.18,"text":"תרגול את רימון חי"},{"start":293.18,"end":294.17,"text":"מה אתם עושים"},{"start":294.17,"end":296.17,"text":"כשנופן לכם מתחת הרגליים"},{"start":296.17,"end":297.17,"text":"דבר כזה"},{"start":297.17,"end":374.36,"text":"סאטוווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":374.36,"end":404.62,"text":"תודה רבה."},{"start":404.64,"end":445.05,"text":"תודה רבה."},{"start":445.05,"end":448.03,"text":"תודה רבה."},{"start":448.03,"end":450.57,"text":"תודה רבה."},{"start":450.57,"end":454.36,"text":"תודה רבה."},{"start":454.36,"end":456.55,"text":"תודה רבה."},{"start":456.55,"end":460.55,"text":"תודה רבה."},{"start":460.55,"end":462.55,"text":"תודה רבה."},{"start":462.55,"end":464.55,"text":"תודה רבה."},{"start":464.55,"end":466.55,"text":"תודה רבה."},{"start":466.55,"end":497.43,"text":"תודה רבה."},{"start":497.43,"end":508.37,"text":"מה?"},{"start":508.37,"end":510.75,"text":"מה?"},{"start":510.75,"end":512.75,"text":"מה קרה?"},{"start":512.75,"end":528.86,"text":"זה מיסטר לופר. זה אקטראורדינר."},{"start":528.86,"end":560.21,"text":"זה תשאמרה, נבום בר."},{"start":560.21,"end":562.84,"text":"תודה רבה."},{"start":562.84,"end":565.18,"text":"מה?"},{"start":565.18,"end":570.59,"text":"זה מיסטר לופר. זה אקטראורדינר."},{"start":570.59,"end":572.59,"text":"תשאמרה לבום בר."},{"start":572.59,"end":576.76,"text":"עצר לופר."},{"start":576.76,"end":578.76,"text":"תגילי איזה מכונה אתה יוצר."},{"start":578.76,"end":583.86,"text":"זמן לא מבנון אשר עשה."},{"start":583.86,"end":588.02,"text":"שבש."},{"start":588.02,"end":601.78,"text":"אם יסיה בומבסטיק."},{"start":601.78,"end":607.84,"text":"אם יסיה בומבסטיק."},{"start":607.84,"end":624.14,"text":"יקבליק בומבסטיק."},{"start":624.14,"end":629.92,"text":"קהל ההפקות גאים להציג את הפרק השלישי"},{"start":629.92,"end":632.92,"text":"בסדרה הקומית הישראלית הגרועה ביותר."},{"start":632.92,"end":634.92,"text":"משפחת ישראלית."},{"start":634.92,"end":666.43,"text":"מה דוד? מתגרשים אה?"},{"start":666.43,"end":672.23,"text":"אז מה? מתגרשים אה?"},{"start":672.23,"end":674.68,"text":"אתה שיהיה במזל בקרובת חי."},{"start":674.68,"end":679.54,"text":"נו, רק שאלה אחת דוד."},{"start":679.54,"end":681.54,"text":"זה שאתה מתגרש כבר בפעם השלושים וכמה."},{"start":681.54,"end":685.54,"text":"זה לא פוגע בתדמית המקצועית שלך כי יועץ לי ענייני ניסוין?"},{"start":685.54,"end":687.65,"text":"ככה זה."},{"start":687.65,"end":689.92,"text":"הסנדלר הולך יחף."},{"start":689.92,"end":691.92,"text":"הנה, תראה אותי. מכונאי רכב?"},{"start":691.92,"end":694.92,"text":"אצלי באוטו ארברקס בקולקל כבר שבועיים."},{"start":694.92,"end":699.92,"text":"אני כדי לחנות צריך לדחוף משהו מתארת לגלגלים של המכונית שלא יתרדר לי בחנייה."},{"start":699.92,"end":703.26,"text":"דרך אגב, אתה יודע."},{"start":703.26,"end":707.26,"text":"היום יש יום הולדת לאשתי, למפלצת."},{"start":707.26,"end":712.38,"text":"אני יודע, יש לה 250, 263, משהו כזה."},{"start":712.38,"end":716.5,"text":"כל אופן, מארגלים לה פה בשימת הפתעה אני והילדים."},{"start":716.5,"end":717.5,"text":"משהו צנוע."},{"start":717.5,"end":720.5,"text":"רגע, עושים פה דברים משונים, אני חייב לנתק."},{"start":720.5,"end":721.5,"text":"ביי."},{"start":721.5,"end":722.65,"text":"תגיד לי, גולם."},{"start":722.65,"end":723.65,"text":"גולם."},{"start":723.65,"end":725.77,"text":"מה זה?"},{"start":725.77,"end":732.37,"text":"אני בודק את השפעת ריקוד הפלמנקו על המבנה המולקולרי של הקישוטים."},{"start":732.37,"end":738.37,"text":"אולי אתה רוצה שאני אבדוק מה תעשה ההוגה למבנה הטופוגרפי של הפרצוף שלך."},{"start":738.37,"end":742.37,"text":"מה אתה צוחק?"},{"start":742.37,"end":743.37,"text":"שב טמפית."},{"start":743.37,"end":746.94,"text":"מה, את צוחקת פרסיפלורה?"},{"start":746.94,"end":751.97,"text":"את יותר טוב, תתאגי מה לעשות שאמא מגיע."},{"start":751.97,"end":756.03,"text":"ברגע שהיא נכנסת, את מחבה את האור ונזהרת בחושך לא ליפול פה על ההוגה."},{"start":756.03,"end":760.02,"text":"אבא, את יודע שאני מבולה כל כך הרבה בחדרים חשוכים ואז פעם לא נופן?"},{"start":761.02,"end":765.02,"text":"מה החוכמה? איך אפשר ליפול כשהגב שלך צמוד למזרון?"},{"start":765.02,"end":770.02,"text":"אוי אבא, תגיד לו שישתוק ושילך לעשות ניתוח, תעשתי."},{"start":770.02,"end":773.02,"text":"אגזמות! שקט שיהיה כאן."},{"start":773.02,"end":776.24,"text":"מטבע לי שאני שומע את האוטו מגיע לחנייה."},{"start":776.24,"end":779.69,"text":"נו, הגוזילה הגיעה. שמי, שמי, תחבי תאור."},{"start":779.69,"end":782.69,"text":"אבא, בהזדמנות הזאת אני רוצה לבקש ממכם אלה שצוחקים כל הזמן"},{"start":782.69,"end":786.69,"text":"לשתף פעולה זו הפתעה ולא לצחוק, בסדר?"},{"start":786.69,"end":789.69,"text":"חיל רבקום, מיקשתי לא לצחוק, נכון?"},{"start":789.69,"end":792.2,"text":"די, אלה!"},{"start":792.2,"end":797.56,"text":"אלה!"},{"start":797.56,"end":803.36,"text":"אתם שלי, אתם התפלפלתם!"},{"start":803.36,"end":807.64,"text":"יום ההולדת שלי הוא רק מאוד חודר!"},{"start":807.64,"end":809.24,"text":"מה נדברת?"},{"start":809.24,"end":812.24,"text":"על מה נדברת שטויה, תביא סיבה, תביא רגע את הלוח שלה!"},{"start":812.24,"end":817.62,"text":"אמא לא נורא, בחודש הבא נעשה לך עוד מסיבת הפתעה!"},{"start":817.62,"end":818.62,"text":"תודה מותה!"},{"start":818.62,"end":821.84,"text":"אוי ואבוי, אני חושב שאת צדקת!"},{"start":821.84,"end":825.84,"text":"איזה אידיוט כאן הדביק את הדפים עם מסטיק!"},{"start":825.84,"end":828.84,"text":"מה אתה צוחק מוגלה?"},{"start":828.84,"end":834.84,"text":"אבא, אני רק... רק רציתי לבדוק את הירידה ברמת החומציות של חודש נובמבר!"},{"start":834.84,"end":839.94,"text":"אוי, מפגע! אני לא מאמינה! אני סימנתי שם עד כל הימים הבטוחים!"},{"start":839.94,"end":844.94,"text":"זה מה שחסר לי! עכשיו במקום שנה מעוברת אני אקבל בת מעוברת!"},{"start":844.94,"end":846.93,"text":"זה לא חשוב, מפלצת לי!"},{"start":846.93,"end":850.93,"text":"העיקר ששמת משהו מטרד הגלגלים של המכוני שלא תתארדה לי בחנייה!"},{"start":850.93,"end":857.02,"text":"אל תדאגי ציק לסמוך עליי, אתה זוכר את המיל הישן שלך מהחורף מפני שנתיים?"},{"start":857.02,"end":860.02,"text":"אז גלגלתי אותו ודחבתי אותו מתחת לאוטו!"},{"start":860.02,"end":863.02,"text":"אך איזה גאון, איזה גאון, זוסק זמה!"},{"start":863.02,"end":868.02,"text":"בואי אינה, גאול קטן שלי שמה לי מעיל מתחת לגלגלים של האוטו!"},{"start":868.02,"end":872.01,"text":"בואי אינה, אני אוהב אותך, דום קטן ועסיסי!"},{"start":872.01,"end":876.0,"text":"תנגר הוא גדול וסעיר שכמוך דום מן!"},{"start":876.0,"end":885.37,"text":"חבר'ה, מה העניינים? נו, לאלפרד פניטה, קיבלת הסטק ב..."},{"start":885.37,"end":886.45,"text":"פיטה!"},{"start":886.45,"end":889.45,"text":"ניילון! איזה גנב הייתי, איזה קטעים החושרמו אותי!"},{"start":889.45,"end":892.09,"text":"נו, חבר'ה?"},{"start":892.09,"end":895.09,"text":"תודה רבה, אני רואה שעשיתם לי מסיבה תפתאה!"},{"start":895.09,"end":900.09,"text":"איך ידעתם שהיו מולדת שלי בדיוק חודש לפני היו מולדת של תקווה!"},{"start":900.09,"end":902.09,"text":"יופי שזכרתם באמת, תודה טוב שהתמנתם את החבר'ה!"},{"start":902.09,"end":907.05,"text":"נו, ואפרופו ימולדת, יש לי בדיחה חזקה ביותר, שימו לב, אני נסה עליכם, בסדר?"},{"start":907.05,"end":911.08,"text":"יש אחד, קנה לי אשתו, לי מולדת, מצווה!"},{"start":911.08,"end":917.56,"text":"עכשיו, שנה אחרי זה מתאי, היה לי אשתו, עוד פעם ימולדת, הוא לא הביא לי אשתו, שום דבר!"},{"start":917.56,"end":919.75,"text":"בוא אשתו ושאלה אותו!"},{"start":919.75,"end":922.75,"text":"בוא לי היקר, למה הוא לא הבאת לי מתנה, אז הוא אמר לה!"},{"start":922.75,"end":926.75,"text":"למה לא אשתמשת במתנה משנה שעבר'ה, שבאתי לך!"},{"start":926.75,"end":931.02,"text":"איזה גניבה!"},{"start":931.02,"end":934.39,"text":"עכשיו, מה מתחיק בו?"},{"start":934.39,"end":935.39,"text":"מה מתחיק?"},{"start":935.39,"end":941.0,"text":"איך היא אכלה לי אשתמש במתנה משנה שעבר'ה, אם הוא לא הביא לו פתקה חלפה בכלל!"},{"start":941.0,"end":950.92,"text":"אה! אה! אה! אה! אה! אה! בגלל שאתה מצחיק!"},{"start":950.92,"end":951.92,"text":"תודה רבה!"},{"start":951.92,"end":956.92,"text":"אתה! אתה מצחיק! בנהיל הוא כרגח המולטיפייטון אה!"},{"start":956.92,"end":961.05,"text":"אבל אתה מצחיק! מצחיק מופה ג'ויה במשבר!"},{"start":961.05,"end":967.05,"text":"אבל אבא הוא באמת מצחיק, לפעמים יש לו בדיחות שמשכיבות אותי על הרצפה!"},{"start":967.05,"end":971.05,"text":"את צריכה משהו שיאמין אותך על הרגליים, לשקף, זה המצב הטבעי שלה!"},{"start":971.05,"end":974.05,"text":"אתה תשתוק, מכוער!"},{"start":974.05,"end":975.05,"text":"את מכוערת!"},{"start":975.05,"end":979.05,"text":"כברי, כברי, לא להריב! לא להריב בהולדת שלי! באמת לא להריב!"},{"start":979.05,"end":982.01,"text":"שניכם מכוערים ודומים לכנפה! וזהו!"},{"start":982.01,"end":988.15,"text":"טוב, אני לא יודע מה איתכם, אני יוצא החוצה, אני לא נשאר עוד שנייה אחת ביום הולדת של הדבורה מאיה!"},{"start":988.15,"end":990.15,"text":"צ'יקו ודיקו!"},{"start":990.15,"end":992.15,"text":"ימונגו בריגרסיה!"},{"start":992.15,"end":993.15,"text":"הפרסק אמפיבי!"},{"start":993.15,"end":994.15,"text":"מחיר סקטום!"},{"start":994.15,"end":996.15,"text":"פיצה במעצר!"},{"start":996.15,"end":998.15,"text":"קוספטן דלוק!"},{"start":998.15,"end":1000.15,"text":"פי ארסית!"},{"start":1000.15,"end":1002.15,"text":"כן!"},{"start":1002.15,"end":1004.15,"text":"ותקפוץ לשחק גוינג בכניסה למתנס ביום בית!"},{"start":1004.15,"end":1006.15,"text":"אני יוצא החוצה לנשום אוויר צח!"},{"start":1006.15,"end":1008.15,"text":"האם אתה כבר יוצא החוצה?"},{"start":1008.15,"end":1010.15,"text":"יותר טוב תיקח את המיעיל שלך שלא תצטנן!"},{"start":1010.15,"end":1013.15,"text":"מצאתי אותו זרוק מתחת למכונית שלך בחנייה!"},{"start":1013.15,"end":1015.15,"text":"תודה!"},{"start":1015.15,"end":1025.44,"text":"רגש?"},{"start":1025.44,"end":1035.29,"text":"כן, קצת נרגש!"},{"start":1035.29,"end":1037.29,"text":"פעם ראשונה בטלוויזיה!"},{"start":1037.29,"end":1038.29,"text":"כן, נכון!"},{"start":1038.29,"end":1039.29,"text":"הזמינו אותי, אבל פעם ראשונה..."},{"start":1039.29,"end":1040.29,"text":"בואו אני אלמד אותך איזו שיטה קטנה!"},{"start":1040.29,"end":1041.48,"text":"תרגע!"},{"start":1041.48,"end":1042.48,"text":"תזרום עם העניין!"},{"start":1042.48,"end":1043.47,"text":"תלך עם זה!"},{"start":1043.47,"end":1044.56,"text":"אתה יודע מה?"},{"start":1048.56,"end":1052.52,"text":"אגב, אגב, אגב, אגב, אקשה!"},{"start":1052.52,"end":1058.48,"text":"ערב טוב, שוב אתה בתוכניתנו בארבע עיניים, והפעם נמצא איתנו כאן, הסופר והמשורר חיים אברון. ערב טוב לך."},{"start":1058.48,"end":1064.93,"text":"הרבה מעצפים בבית רוצים לדעת איך ההרגשה להיות סופר בין 25 שיש לו 25 סופרים."},{"start":1064.93,"end":1071.15,"text":"מה אני אגיד לך זה לא כבוד גדול, אני ארבד, ואני זימנתי לו להיסציבו אולפנים וארבעה פנסים משובים עליה מתוך דולפים כדול שמסווה בתוך תנור גדול אובן, מה?"},{"start":1071.15,"end":1076.1,"text":"אה, רעיון ראשון שלך בטלוויזיה, אתה בוודאי מתרגש."},{"start":1076.1,"end":1085.95,"text":"בטח שאני מתרגש, זה לא קרה לי פעם אחת, אני יושבתי 60 בקבוקים עם תוך, אנשים גדולים מסתובבים מתוך גדולים פלייר וערונבות קט, קט, קט, קט."},{"start":1085.95,"end":1087.17,"text":"אני, אני..."},{"start":1087.17,"end":1089.17,"text":"מה, מה, מה קרה? מה יש? מה?"},{"start":1089.17,"end":1090.17,"text":"הנה, אתה בסדר."},{"start":1090.17,"end":1092.17,"text":"אני בסדר גמור. הכל טוב, מה?"},{"start":1092.17,"end":1093.17,"text":"לא, לא, נורא."},{"start":1093.17,"end":1095.17,"text":"סליחה, סליחה, זה יכול לקרות."},{"start":1095.17,"end":1096.17,"text":"אני לא מבין, אני לא..."},{"start":1096.17,"end":1104.3,"text":"ערב טוב, ונעבור אליך חיים עברון."},{"start":1104.3,"end":1105.26,"text":"חיים, ערב טוב."},{"start":1105.26,"end":1107.41,"text":"חיים, הרבה מעצופים מתעניינים לדעת,"},{"start":1107.41,"end":1111.47,"text":"האם אתה משתמש בחומרים אישיים מהבית בעבודות שלך?"},{"start":1111.47,"end":1113.43,"text":"אני דוגל אף פעם לא להשתמש בחומרים אישיים,"},{"start":1113.43,"end":1115.43,"text":"מקווה שאני מגדל שאני עם כלב סנדר מהגדול,"},{"start":1115.43,"end":1116.43,"text":"ואף אחד לא אמר לי, תיקח אותה, תזורג אותה,"},{"start":1116.43,"end":1117.43,"text":"תעשה מה שאתה עושה איתם, אני לא יודעת מה קוראים."},{"start":1117.43,"end":1118.43,"text":"מה?"},{"start":1118.43,"end":1119.43,"text":"מה?"},{"start":1119.43,"end":1121.43,"text":"קאט, קאט, קאט, עוד פעם, עוד פעם."},{"start":1121.43,"end":1122.43,"text":"מה קרה?"},{"start":1122.43,"end":1123.43,"text":"אתה מדבר משונה."},{"start":1123.43,"end":1125.43,"text":"מה, עשורם, לא דיברו איתי שזה ייקח כל כך הבזמן."},{"start":1125.43,"end":1126.43,"text":"למה יצר לזכת לי ולהלו?"},{"start":1126.43,"end":1127.43,"text":"מה זאת אומרת אבל יייצ לי?"},{"start":1127.43,"end":1129.43,"text":"אתה אין לך גישה, אתה לא יודע לשאול אנשים,"},{"start":1129.43,"end":1131.43,"text":"אתה אין לך גישה למורויינים שלך."},{"start":1131.43,"end":1132.43,"text":"מה זאת אומרת?"},{"start":1132.43,"end":1133.43,"text":"קום, תראה איך אני עושה את העבודה."},{"start":1133.43,"end":1134.43,"text":"בבקשה."},{"start":1134.43,"end":1135.43,"text":"קום, תרמד ממקסואן."},{"start":1135.43,"end":1136.43,"text":"בבקשה."},{"start":1136.43,"end":1137.62,"text":"אני מתכוון לפגוע בו, אבל..."},{"start":1137.62,"end":1138.62,"text":"קדימה, אקשן."},{"start":1138.62,"end":1140.62,"text":"ערב טוב, שוב לנו בתוכנית \"בר\" בעיניים,"},{"start":1140.62,"end":1142.62,"text":"נמצא איתנו כאן חיים מבון, סופר ומשורר."},{"start":1142.62,"end":1144.62,"text":"תגדעים, שאתה גודף את הסופר,"},{"start":1144.62,"end":1145.62,"text":"אתה גודף את הסופר את הסופר,"},{"start":1145.62,"end":1146.62,"text":"אתה גודף את הסופר,"},{"start":1146.62,"end":1146.72,"text":"איזה עבר?"},{"start":1146.62,"end":1146.72,"text":"מה?"},{"start":1146.62,"end":1147.62,"text":"לא, אני אשפתם,"},{"start":1147.62,"end":1148.62,"text":"אני אשפתם שחבוש את אורבן,"},{"start":1148.62,"end":1149.62,"text":"פירשתי את כל הדברים אליו בכתב ראשים,"},{"start":1149.62,"end":1150.62,"text":"לא יודעתי מה זה עשוד ועמו לי."},{"start":1150.62,"end":1151.62,"text":"לא, אבל אני מקווה שיש לדמיים,"},{"start":1151.62,"end":1153.62,"text":"זה לא מנתיף את הסופרים שהיא נגיעו,"},{"start":1153.62,"end":1154.62,"text":"זה לא, קוראים מה,"},{"start":1154.62,"end":1155.62,"text":"שבבית לא ידעים ביתו,"},{"start":1155.62,"end":1158.22,"text":"מה?"},{"start":1158.22,"end":1159.22,"text":"Ladies and gentlemen,"},{"start":1159.22,"end":1223.32,"text":"מה, יש לה מחצבה גדולה, מה קרה?"},{"start":1223.32,"end":1228.18,"text":"זה מיסטר אופר, זה אקסטראורדינר,"},{"start":1228.18,"end":1231.04,"text":"זה תשמרן הבומדה,"},{"start":1231.9,"end":1260.11,"text":"זה רלב, זה מחונה,"},{"start":1260.11,"end":1266.45,"text":"מיסטר בומב, מיסטר בומבסטי,"},{"start":1266.45,"end":1267.8,"text":"הכל הוא לא יוצא,"}]