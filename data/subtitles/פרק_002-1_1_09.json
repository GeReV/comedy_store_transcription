[{"start":1.73,"end":4.49,"text":"אושל המקפעד הכלל מן ברמז'ו סעודיה"},{"start":4.49,"end":7.49,"text":"פיל תמניה עונוס מן הטלפציון על האסרעילי"},{"start":7.49,"end":9.75,"text":"פיל מוסלסל קומידיסטור"},{"start":9.75,"end":78.86,"text":"אני נכנס"},{"start":78.86,"end":92.55,"text":"משתתפים, פילים בקרקס מהמם"},{"start":92.55,"end":94.45,"text":"הייתי רוצה להתנות את הראשון שלנו"},{"start":94.45,"end":96.03,"text":"הגבל מיותר שלנו"},{"start":96.03,"end":99.57,"text":"החמורבי, גדול חידוני הארץ ואורח"},{"start":99.57,"end":102.44,"text":"אין אף אף אף אף אף אף אף אף אף אף אף אף אף אף אף אף אף"},{"start":102.44,"end":105.02,"text":"גם תחתי כמה חידות להתמצות, תודה רבה"},{"start":105.02,"end":108.2,"text":"ונפתח ויחידות בנושא בניינים בתל אף"},{"start":111.75,"end":113.75,"text":"על שלום, מעיר כמובן!"},{"start":113.75,"end":124.21,"text":"בניין זה, בידי זוגתים, שלום, באנו לבקר, אךלן, באנו לבקר אותם, מה נשמע בית ביקורי אתים כמובן!"},{"start":124.21,"end":130.21,"text":"תודה הבא, אז רבי שביבו לב מה זה, איזה בניין זה, הלונדון מיניסטר!"},{"start":130.21,"end":135.21,"text":"איך עושים קטע כזה? זה היה טוב! -בטח, הייבים לעשות איזה קטע... -איזה קטע... איזה אפילו משהו מרתק."},{"start":135.21,"end":139.21,"text":"-איזה אברהם אבינו, איזה משהו... -בטח! -משהו אפילו מותח, כמו המרגלים."},{"start":139.21,"end":141.21,"text":"-מרגלים! -מרגלים!"},{"start":141.21,"end":144.24,"text":"איזה אברהם מרגלים, שם שלחו."},{"start":144.24,"end":146.36,"text":"הרי בני ישראל שלחו את המרגלים."},{"start":146.36,"end":148.36,"text":"-כן. -לראות מה קורה שם אצלהם, מה שמה מגויים."},{"start":148.36,"end":150.36,"text":"-כן. -יש מעלים."},{"start":150.36,"end":153.36,"text":"-יש מעלים. -הם הלחו בדקור ההוא, חזרו ואומרו להם ככה וככה וככה."},{"start":153.36,"end":156.36,"text":"זהו, זה, תמונת מצד נתנו להם, לא יותר מזה."},{"start":156.36,"end":160.36,"text":"-אה, מה אתה מדבר? לא הבאתי שהיו מרגלים. -היו מרגלים, בטעם מרגלים."},{"start":160.36,"end":162.36,"text":"הלחו עם הענבים, הביאו כל מיני דברים."},{"start":162.36,"end":164.36,"text":"הלכו לטור בארץ"},{"start":164.36,"end":166.36,"text":"לטור בארץ"},{"start":166.36,"end":168.36,"text":"וילחו המרגלם לטור בארץ"},{"start":168.36,"end":170.36,"text":"ויחזרו וימרו"},{"start":170.36,"end":172.36,"text":"אין אין אין אין"},{"start":172.36,"end":174.36,"text":"עשר עשר"},{"start":174.36,"end":176.36,"text":"אין אין אין"},{"start":176.36,"end":178.36,"text":"אין אין אין"},{"start":178.36,"end":181.41,"text":"אין אין אין אין"},{"start":181.41,"end":183.63,"text":"אין אין אין אין"},{"start":183.63,"end":185.63,"text":"עשר עשר עשר"},{"start":185.63,"end":187.63,"text":"עשר עשר עשר"},{"start":187.63,"end":190.14,"text":"עשר עשר"},{"start":190.14,"end":197.4,"text":"עשר"},{"start":197.4,"end":199.43,"text":"רבותיי ורבותיי"},{"start":199.43,"end":201.43,"text":"נדבר על דירות ופרסומים של דירות בארץ"},{"start":201.43,"end":203.43,"text":"שזה מביא לי תחה לסטרה"},{"start":203.43,"end":205.43,"text":"ולא כדאי שיהיה מישהו בסביבה שלי"},{"start":205.43,"end":207.62,"text":"ולמה אני מתכוון?"},{"start":207.62,"end":209.62,"text":"כל גבעה שבונים עליה היום"},{"start":209.62,"end":211.62,"text":"איפה קנית דירה?"},{"start":211.62,"end":213.62,"text":"בסוויוני סוויונים?"},{"start":213.62,"end":215.62,"text":"בכליוני כליונים? בסיבובי הפרחים?"},{"start":215.62,"end":217.62,"text":"מה זה אחרתה זה?"},{"start":217.62,"end":219.62,"text":"מה קורה לנו? השתגענו?"},{"start":219.62,"end":221.62,"text":"באמא שלי כל גבעה ניהרדוף היה כנטון"},{"start":221.62,"end":223.62,"text":"מה זה? עוד מעט"},{"start":223.62,"end":225.62,"text":"יבנו בחירייה"},{"start":225.62,"end":227.74,"text":"יקראו לזה מורדות חירייה הירוקה"},{"start":227.74,"end":229.77,"text":"תחשבו על זה"},{"start":229.77,"end":232.38,"text":"ג'ג'י"},{"start":232.38,"end":234.63,"text":"תזיז את האוטו מפה"},{"start":234.63,"end":236.91,"text":"מה? תזיז את האוטו מפה"},{"start":236.91,"end":238.91,"text":"בסדר, חבן אותי"},{"start":238.91,"end":241.54,"text":"בוא אני חבן לך בוא"},{"start":241.54,"end":244.22,"text":"סחורה"},{"start":244.22,"end":248.51,"text":"קדימה, קדימה"},{"start":248.51,"end":250.63,"text":"קדימה, נו"},{"start":250.63,"end":253.88,"text":"סחורה"},{"start":253.88,"end":256.86,"text":"סחורה"},{"start":256.86,"end":258.86,"text":"לך עולה?"},{"start":258.86,"end":260.86,"text":"סחורה"},{"start":260.86,"end":264.51,"text":"קדימה, קדימה"},{"start":264.51,"end":267.46,"text":"קדימה, קדימה, נו, קדימה"},{"start":267.46,"end":270.58,"text":"סחורה"},{"start":270.58,"end":273.03,"text":"סחורה, בן אדם"},{"start":273.03,"end":275.53,"text":"סחורה"},{"start":275.53,"end":277.53,"text":"מה קורא לך בן אדם?"},{"start":277.53,"end":279.53,"text":"אני לא יודע מה תחליט"},{"start":279.53,"end":281.53,"text":"אני אומר לך, סחורה"},{"start":281.53,"end":283.53,"text":"בסדר, אחורה"},{"start":283.53,"end":285.53,"text":"סחורה"},{"start":285.53,"end":287.74,"text":"סחורה"},{"start":287.74,"end":291.51,"text":"אופה"},{"start":291.51,"end":293.51,"text":"אמרתי שזרקו על אבא אבן"},{"start":293.51,"end":295.51,"text":"מסכים"},{"start":295.51,"end":297.51,"text":"מסכים"},{"start":297.51,"end":299.51,"text":"שמעתי"},{"start":299.51,"end":301.67,"text":"שהגשש"},{"start":301.67,"end":303.67,"text":"חיוויר"},{"start":303.67,"end":305.73,"text":"שמעתי"},{"start":305.73,"end":307.73,"text":"שמעתי שלא נשאר מיוסי שריד"},{"start":307.73,"end":309.73,"text":"מסכים"},{"start":309.73,"end":311.73,"text":"שמעתי"},{"start":311.73,"end":313.73,"text":"שבילי לרמן"},{"start":313.73,"end":317.46,"text":"מוסקונה"},{"start":317.46,"end":322.31,"text":"מוסקונה"},{"start":322.31,"end":324.31,"text":"בסדר, בא לכם כאן נכבד הצמיצה,נו כאן במועדון השכונתי"},{"start":324.31,"end":326.31,"text":"המועדון שלנו"},{"start":326.31,"end":328.5,"text":"מועדון הג'יפאה"},{"start":328.5,"end":334.53,"text":"כאן נכבד, אני רוצה עכשיו"},{"start":334.53,"end":336.67,"text":"שתקבלו במחיות כף בדרן ענק"},{"start":336.67,"end":338.89,"text":"אומן גדול, אומן גדול"},{"start":338.89,"end":341.03,"text":"בדחן ממדרגה ראשונה, הוא מצחיק את כולם"},{"start":341.03,"end":341.73,"text":"קבלו אותו"},{"start":341.73,"end":345.46,"text":"אוהד, אלפרד, הגדול"},{"start":345.46,"end":346.12,"text":"הנה הוא בא"},{"start":346.12,"end":361.41,"text":"שיר יבני, בבקשה"},{"start":361.41,"end":367.3,"text":"סלים, סלים, סלים, סלים"},{"start":367.3,"end":368.42,"text":"על כתפנו"},{"start":368.42,"end":371.06,"text":"פירות, פירות, פירות, פירות"},{"start":371.06,"end":372.18,"text":"בסלנו"},{"start":372.18,"end":374.88,"text":"סוקרטס פתק, סופר סל"},{"start":374.88,"end":377.08,"text":"הנה לבוקבוקי, איזה גנב עקושלוקי"},{"start":377.08,"end":379.32,"text":"תודה רבה, אני אתחיל עם כמה בדיחות ראשונות"},{"start":379.32,"end":380.2,"text":"באמת לא צריך"},{"start":380.2,"end":383.5,"text":"עקשב, אני אתחיל עם כמה בדיחות ראשונות"},{"start":383.5,"end":385.52,"text":"בדיחה ראשונה, יום אחד עלכתי לי ברחוב"},{"start":385.52,"end":387.26,"text":"פתאום אני רואה גברת עם התינוק על הכתפיים"},{"start":387.26,"end":389.34,"text":"התינוק בוכה, מיילל, צועק, אני אומר לגברת"},{"start":389.34,"end":391.54,"text":"גברת, תביאי, נטפל בתינוק, תראי לי את התינוק"},{"start":391.54,"end":392.64,"text":"אז יראי לאותו מת"},{"start":392.64,"end":394.44,"text":"הנה לבוקבוקי, איזה גנב עקושלוקי"},{"start":394.44,"end":397.12,"text":"שנייה הקרקק, שנייה קרקק, עלכתי לי ברחוב"},{"start":397.12,"end":399.6,"text":"פתאום אני רואה רבי, אני צועק לו"},{"start":399.6,"end":401.6,"text":"רבי רבי, אז היראי לאותו"},{"start":401.6,"end":402.54,"text":"איזה גנבה"},{"start":402.54,"end":406.1,"text":"לא משנה, עלכתי לי ברחוב, עלכתי לי ברחוב"},{"start":406.1,"end":407.84,"text":"פתאום אני רואה שני סרטנים"},{"start":407.84,"end":409.44,"text":"סרטן אחד אומר לחבר שלו, תגיד"},{"start":409.44,"end":411.46,"text":"תרוצה סיגריה? הוא אומר לו, יש תגעת, תתקבל בן אדם"},{"start":411.46,"end":412.2,"text":"איזה גנבה"},{"start":412.2,"end":416.88,"text":"אושלם כה, בעד הכליל, מן ברמי של סעודיה"},{"start":416.88,"end":418.58,"text":"מן הטלפייסיון הלאה, סרעילי"},{"start":418.58,"end":419.84,"text":"פיל מוסלסל אלף"},{"start":419.84,"end":422.74,"text":"קומדי סטור, וליד עיין, וליד עיין"},{"start":422.74,"end":434.68,"text":"ערב טוב לכולם, ערב משובח לכולם"},{"start":434.68,"end":436.72,"text":"אני הפרופסור יוקמאץ בן פסיק"},{"start":436.72,"end":438.64,"text":"בפינת העברית, והיום נדבר"},{"start":438.64,"end":440.38,"text":"על המילה הלועזית המחליאה, והוא עושה"},{"start":440.38,"end":442.98,"text":"טלפון, ובכן, בעברית שכה"},{"start":442.98,"end":445.0,"text":"אין לומר טלפון, יש לומר"},{"start":445.0,"end":446.9,"text":"סך רחוק, לדוגמה"},{"start":446.9,"end":448.92,"text":"שכרח רחקתי לך אתמול"},{"start":448.92,"end":450.92,"text":"אך ענת לי המזכירה האלקטרונית"},{"start":450.92,"end":453.2,"text":"אגב, מזכירה, ניתן לרשום"},{"start":453.2,"end":454.96,"text":"מזכירה בקוף, ואז"},{"start":454.96,"end":457.14,"text":"הכוונה היא למזכירה"},{"start":457.14,"end":458.76,"text":"גורמת לדבר שיהיה זקור"},{"start":458.76,"end":460.6,"text":"זקוף, עומד, לדוגמה"},{"start":460.6,"end":462.7,"text":"יש תרופה חדשה לאימפוטנטים"},{"start":462.7,"end":464.6,"text":"מזכירה אלקטרונית"},{"start":464.6,"end":466.82,"text":"בבריצך אין לומר מזכירה"},{"start":466.82,"end":468.98,"text":"יש לומר משיבון, והכוונה"},{"start":468.98,"end":471.06,"text":"היא למשיב עון, מחזיר"},{"start":471.06,"end":472.1,"text":"כוח גברה"},{"start":472.1,"end":481.64,"text":"בסדר, לורה"},{"start":481.64,"end":483.14,"text":"טוב, טוב דווקא"},{"start":483.14,"end":484.58,"text":"משתפרות"},{"start":484.58,"end":485.4,"text":"יפה, יש בזה"},{"start":485.4,"end":485.9,"text":"ממש"},{"start":485.9,"end":487.68,"text":"אני לא אוהב תקטעים"},{"start":487.68,"end":489.72,"text":"זה ממש, זה ירוד"},{"start":489.72,"end":490.66,"text":"ירוד יותר"},{"start":490.66,"end":492.66,"text":"ממש, נחמד מאוד"},{"start":492.66,"end":493.82,"text":"אבל זה לאט לאט עולה"},{"start":493.82,"end":495.66,"text":"זה עולה, משתפר, משתפר"},{"start":495.66,"end":497.42,"text":"זה יגיע לסיים"},{"start":497.42,"end":498.86,"text":"זה יהיה הכי טוב שיכול להיות"},{"start":498.86,"end":500.96,"text":"בטח, זה אני אומר לך, הקטע הזה"},{"start":500.96,"end":503.0,"text":"זה הכי גרוע שיכול להיות בתוכנית הזאת"},{"start":503.0,"end":504.46,"text":"להוריד אותו, יערחו את זה"},{"start":504.46,"end":505.66,"text":"יערחו, יערחו את זה"},{"start":505.66,"end":506.78,"text":"יעושים קאט"},{"start":506.78,"end":508.84,"text":"חיבל שזה כמו שמדבקים"},{"start":508.84,"end":510.66,"text":"חותכים אחרי זה, אין סיכון"},{"start":510.66,"end":511.62,"text":"חבל שזה לייב רק"},{"start":511.62,"end":512.76,"text":"זה, זה הדעייה"},{"start":512.76,"end":514.42,"text":"אם לא הייתי, לא לייב?"},{"start":514.42,"end":515.12,"text":"זה גם פלייבק"},{"start":515.12,"end":515.72,"text":"זה גם פלייבק"},{"start":515.72,"end":516.46,"text":"זה הכול פלייבק"},{"start":516.46,"end":519.88,"text":"זה גדולה שלנו"},{"start":519.88,"end":520.68,"text":"האטרקציה של לקה"},{"start":520.68,"end":522.52,"text":"לפני שנעבור לאטלנציה"},{"start":522.52,"end":523.76,"text":"הפשקת פרסום"},{"start":523.76,"end":525.76,"text":"שימו לב איזה פרסום את אני עושה"},{"start":525.76,"end":526.72,"text":"טאדאם טאדאם"},{"start":526.72,"end":528.03,"text":"לבזק, למה?"},{"start":528.03,"end":531.13,"text":"בזק כל הקשר!"},{"start":531.13,"end":540.22,"text":"כן, כן, זה כן לדלתור!"},{"start":540.22,"end":542.65,"text":"יפים עליי, יפים עליי, לא!"},{"start":542.65,"end":545.53,"text":"נכנע!"},{"start":545.53,"end":552.29,"text":"אה, איש לו איסא אצ'בו!"},{"start":552.29,"end":553.37,"text":"הוז!"},{"start":553.37,"end":555.81,"text":"אדם משיח בו יבוא!"},{"start":555.81,"end":556.84,"text":"הוז!"},{"start":556.84,"end":559.1,"text":"איש לו איסא אצ'בו!"},{"start":559.1,"end":560.02,"text":"הוז!"},{"start":560.02,"end":562.44,"text":"אדם משיח בו יבוא!"},{"start":562.44,"end":563.1,"text":"הוז!"},{"start":563.1,"end":565.32,"text":"יפים עליי, לא!"},{"start":565.32,"end":575.68,"text":"אלה הצרפתים מרוב של חרמנים הם נמצאו לחם עומד!"},{"start":575.68,"end":578.05,"text":"הפגד זה לחם עומד!"},{"start":578.05,"end":580.86,"text":"מה יש לנו בארץ חלה?"},{"start":580.86,"end":587.93,"text":"אלה הצרפתים קחו סרט כחול בצרפתית, אה?"},{"start":587.93,"end":590.43,"text":"לגבר'ה שם של פלייר!"},{"start":590.43,"end":593.54,"text":"פיאר!"},{"start":593.54,"end":596.13,"text":"לא יוסי!"},{"start":596.13,"end":598.66,"text":"ואילו עמיצק!"},{"start":598.66,"end":603.63,"text":"עמידק, עמיפלק! מה זה אחרת הזה?"},{"start":603.63,"end":607.87,"text":"קחו לי דוגמת האיטלקית, אה?"},{"start":607.87,"end":609.66,"text":"עזבו צרפתים, איטלקי!"},{"start":609.66,"end":613.24,"text":"הגבר'ה האיטלקי קם בבוקר, עושה לי אשתו..."},{"start":613.24,"end":650.91,"text":"בואווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווווו"},{"start":650.91,"end":682.55,"text":"שבור את ההגה, שבור, יופי, כן, שבור את כל ההגה, שבור, שבור חזק, חזק, שבור אותך, כן, כן, שבור תהגה, כן, שבור, שבור, יופי, כן, עוד, עוד, חזק, כן, יופי, שבור, כן, כן, יופי, יופי, כן, עוד, שבור, שבור תהגה, שבור, יופי, כן, שבור תהגה, כן, שבור תהגה, שבור, יופי, שבור, יופי, שבור, יופי, שבור, יופי, שבור, יופי, שבור, יופי, שבור, יופי, שבור, יופי, שב"},{"start":682.55,"end":687.49,"text":"*ערבית*"},{"start":716.39,"end":717.39,"text":"*ערבית*"},{"start":717.39,"end":718.39,"text":"אני... אני אוכל!"},{"start":718.39,"end":719.09,"text":"*ערבית*"},{"start":719.09,"end":720.39,"text":"מה אתה אוכל? סירית!"},{"start":720.39,"end":721.34,"text":"מה לוקחי יודעת?"},{"start":721.34,"end":724.98,"text":"תמיד תביא סגריה"},{"start":724.98,"end":725.98,"text":"קו שבטה"},{"start":725.98,"end":727.92,"text":"פרסומת מעצבנת זה הפרסומת של אגד"},{"start":727.92,"end":729.23,"text":"מכירים?"},{"start":729.23,"end":730.29,"text":"רואים אוטובוס נוסע"},{"start":730.29,"end":731.45,"text":"אווירה תרבותית כזאת"},{"start":731.45,"end":732.45,"text":"בית הובן ברקע"},{"start":732.45,"end":733.44,"text":"נהג חייכה נדיב"},{"start":733.44,"end":735.44,"text":"אנשים מבוגרים משנים ככה"},{"start":735.44,"end":736.44,"text":"עם נכסה על העיניים"},{"start":736.44,"end":738.75,"text":"אתה עולה על קו 605"},{"start":738.75,"end":739.75,"text":"נתן לי תל אביב"},{"start":739.75,"end":740.75,"text":"קשה לי"},{"start":740.75,"end":742.75,"text":"את רחוקה ממני"},{"start":742.75,"end":744.71,"text":"הרדיו פול ווליום"},{"start":744.71,"end":746.71,"text":"נהג שר איתו ילדים פצחים גרעינים"},{"start":746.71,"end":749.7,"text":"ריקים עליך איזה באס הזה"},{"start":749.7,"end":751.7,"text":"בפרסומת אנשים ישנים ככה"},{"start":751.7,"end":755.3,"text":"מתי פעם אחרונה ראיתם באוטובוס"},{"start":755.3,"end":758.29,"text":"בן אדם ישן ככה?"},{"start":758.29,"end":760.74,"text":"באוטובוסים אנשים ישנים ככה"},{"start":760.74,"end":762.74,"text":"עם עריר מזיל מפה"},{"start":762.74,"end":765.25,"text":"דן אביא להם קונטרה"},{"start":765.25,"end":767.25,"text":"זהו את האוטובוס מפה"},{"start":767.25,"end":769.41,"text":"תראים? אוטובוס אקרודיון"},{"start":769.41,"end":771.91,"text":"זה האוטובוס הכי מפגר בעולם"},{"start":771.91,"end":774.35,"text":"הכי מפגר בעולם"},{"start":774.35,"end":776.35,"text":"אתה יושב מאחורה, אתה מסתכל מצד שמאל"},{"start":776.35,"end":783.72,"text":"בחלון, אתה רואה את הנהג"},{"start":783.72,"end":785.72,"text":"זה מתחק"},{"start":785.72,"end":787.72,"text":"זה עובד"},{"start":787.72,"end":789.72,"text":"יש עובד מה שעובד עובד"},{"start":789.72,"end":791.72,"text":"עם הצלחה לא מתווכח"},{"start":791.72,"end":793.72,"text":"ישראל רכשה מטוס F-16"},{"start":793.72,"end":797.22,"text":"בלתי נראה"},{"start":797.22,"end":800.24,"text":"בגדי המלך החדשים"},{"start":800.24,"end":802.24,"text":"תדמיינו לעצמכם הקפצה של המטוס הבלתי נראה הזה"},{"start":802.24,"end":804.24,"text":"אחי איפה מטוס? איפה מטוס?"},{"start":804.24,"end":807.65,"text":"איפה מטוס? איפה מטוס?"},{"start":807.65,"end":809.71,"text":"רואים את הטייס בשמיים ככה?"},{"start":809.71,"end":815.39,"text":"אין מטוס"},{"start":815.39,"end":817.64,"text":"מטוס בלתי נראה"},{"start":817.64,"end":819.64,"text":"מי יהיה הטייס? דני דין?"},{"start":819.64,"end":821.64,"text":"עונוס דקיקה מן בר המגוס אותיה"},{"start":821.64,"end":823.64,"text":"מן הטלפסטיון על האסראילי"},{"start":823.64,"end":825.64,"text":"פל מוסלסל חרטה בפיטה"},{"start":825.64,"end":828.82,"text":"מן נגבים בשרבול"},{"start":828.82,"end":831.96,"text":"אה? אתה יודע אולי מה השעה?"},{"start":831.96,"end":834.82,"text":"כן!"},{"start":834.82,"end":841.9,"text":"סלח לי!"},{"start":841.9,"end":843.99,"text":"אתה יודע אולי איפה זה נכון על אמבי?"},{"start":843.99,"end":845.96,"text":"לא אני מצטער אני לא יודע"},{"start":845.96,"end":847.96,"text":"אתה לא צריך להסטער"},{"start":847.96,"end":849.96,"text":"משום אתה רואה כי השער בן פה אני פולה עם הינה"},{"start":849.96,"end":851.96,"text":"לא צריך להסטער, אידיוט"},{"start":851.96,"end":859.45,"text":"ידידים, העניינים"},{"start":859.45,"end":861.89,"text":"מה זה שנים לראית אותך"},{"start":861.89,"end":902.04,"text":"אני נועד אותה פתאום באקשה הרבה, פתאום באקשה הרבה, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אל"},{"start":902.04,"end":909.52,"text":"‫זה שם זה? ‫- זה שם זה? ‫- פעם היה להכת הדודאים, ‫היה גשר הירקון, ‫- שלושה ריקים. ‫- זה לא ככה."},{"start":909.52,"end":915.28,"text":"‫- זה סתם, שם, מנגבים בשרבות. ‫- מה מנגבים? ‫כל היום זה כבר אומר לך לא מחונכים."},{"start":915.28,"end":918.32,"text":"‫אין כבר... ‫- אבל השם אתה יכול לדעת את הלא מחינוכים."},{"start":918.32,"end":921.4,"text":"‫- כבר לא אנשים יפתחו טלוויזיה לתוכנות כזה. ‫- לא יפתחו זה, לא רנטינג."},{"start":921.4,"end":923.32,"text":"‫כל הרנטינג יורד אחרת. ‫- זה כל הרנטינג יורד."},{"start":923.32,"end":927.3,"text":"‫אני רציתי, איך עובד הרנטינג הזה? ‫- זה אני אסביר לך."},{"start":927.3,"end":930.58,"text":"‫עכשיו, נניח, אתה בבורסה, ‫נגיד אתה מושקע."},{"start":930.58,"end":932.42,"text":"‫לא, ברייטינג. ‫- ברייטינג אני אומר."},{"start":932.42,"end":935.82,"text":"‫- אה, אני בבורסה. ‫- נניח, אתה מושקע בבורסה. ‫- אני מושקע בבורסה, כן."},{"start":935.82,"end":938.62,"text":"‫עכשיו, ברגע שאתה מכרת, ‫- אני מכרתי."},{"start":938.62,"end":940.73,"text":"‫ישר יש קונים. ‫- יש קונים."},{"start":940.73,"end":945.06,"text":"‫הם באים, מסתכלים בטלוויזיה, ‫ישר עולה כל הרנטינג."},{"start":945.06,"end":947.3,"text":"‫אה, זה ככה עובד. ‫- ככה זה עובד, ישירות."},{"start":947.3,"end":950.94,"text":"‫איך שאתה מוכר אותו? ‫- איך שאתה מוכר? ‫- הם עולים ויורדים."},{"start":950.94,"end":953.14,"text":"‫- אבל לי אין לי מה למכור. ‫- אין לך מלמכור, אל תקנה."},{"start":953.14,"end":957.0,"text":"‫חידע, חידע! ‫- אויגוד, מה?"},{"start":957.0,"end":960.35,"text":"‫למה שהולכים פרה לחלל? ‫- לא."},{"start":960.35,"end":964.83,"text":"‫בשביל החלב! ‫- רגע, יש לי קונטרה."},{"start":964.83,"end":968.54,"text":"‫למה הולכים לטיול במצדה ‫עם חליל?"},{"start":968.54,"end":971.92,"text":"‫- למה? ‫- בשביל לנחש! ‫- וואי, בשביל לנחש!"},{"start":971.92,"end":974.96,"text":"‫- זוי, זוי. ‫- יש לי, יש לי, יש לי."},{"start":974.96,"end":977.84,"text":"‫- נו. ‫- למה הולכים לפרדס ‫עם שקית זבל?"},{"start":977.84,"end":980.53,"text":"‫- נו. ‫- בשביל קליפות התפוזים!"},{"start":980.53,"end":982.53,"text":"‫- דו! ‫- בשביל קליפות התפוזים!"},{"start":982.53,"end":986.93,"text":"‫- למה? ‫- למה הולכים כל בוקר לעבודה?"},{"start":986.93,"end":989.17,"text":"‫- נו. ‫- בשביל הפרנסה."},{"start":989.17,"end":1014.86,"text":"‫- אם מישהו פה רוצה להתחיל איתך."},{"start":1014.86,"end":1023.04,"text":"‫- חופפות ביחד. ‫- שוטות נס ביחד."},{"start":1023.04,"end":1026.98,"text":"‫- מוזיקה הכי חמה הכי לא יתת."},{"start":1026.98,"end":1030.62,"text":"‫- תודה שאת..."},{"start":1030.62,"end":1031.66,"text":"‫- חיים שלי."},{"start":1031.66,"end":1034.82,"text":"‫- חברות הכי טובות, ‫ראשון הדרבי ב-11."},{"start":1034.82,"end":1036.73,"text":"‫בערוץ 24 חדש."},{"start":1036.73,"end":1044.39,"text":"‫- השעה 11."},{"start":1044.39,"end":1046.62,"text":"‫תהיו חזקים אוהבי נוטלה."},{"start":1046.62,"end":1049.69,"text":"‫לא יכולים לחכות לטעם ‫שאתם הכי אוהבים?"},{"start":1049.69,"end":1051.44,"text":"‫נוטלה בי רדי."},{"start":1051.44,"end":1053.72,"text":"‫מעטפת ופל קריספי פריחה ‫ו טעימה,"},{"start":1053.72,"end":1057.32,"text":"‫ממולת בממרח נוטלה קרמי ‫ופצפוצי חיטה קרנצ'ים."},{"start":1057.32,"end":1058.84,"text":"‫נוטלה בי רדי."},{"start":1058.84,"end":1060.12,"text":"‫רדי טו אנג'וי."},{"start":1060.12,"end":1062.09,"text":"‫חפשו במחלקת ההוגיות."},{"start":1062.09,"end":1063.09,"text":"‫- אפשר בפיג'אמה."},{"start":1063.09,"end":1066.72,"text":"‫אפשר בפיג'אמה."},{"start":1066.72,"end":1068.04,"text":"‫אפשר בפיג'אמה."},{"start":1068.04,"end":1069.16,"text":"‫להחליף גלגל."},{"start":1069.16,"end":1070.08,"text":"‫אפשר בפיג'אמה."},{"start":1070.08,"end":1072.0,"text":"‫לבוא מחתונה של חברה מהגן."},{"start":1072.0,"end":1073.56,"text":"‫ממש לא, בפיג'אמה?"},{"start":1073.56,"end":1074.04,"text":"‫לא."},{"start":1074.04,"end":1077.86,"text":"‫לחקוד על הסיבה פיג'אמה ‫באה להגן."},{"start":1077.86,"end":1082.78,"text":"‫קולקציות פיג'אמה את החורף של דלתא."},{"start":1082.78,"end":1085.78,"text":"‫קונים ב-400 שקלים ומשלמים ‫200 שקלים בלבד."},{"start":1085.78,"end":1087.54,"text":"‫לחברי מועדון ולמצטרפים חדשים."},{"start":1087.54,"end":1089.05,"text":"‫דלתא, אפשר בפיג'אמה."},{"start":1099.11,"end":1106.74,"text":"‫דצ'יה דסטר, בדגמים חדשים ‫ועוצמתיים, מ-94,990 שקלים."},{"start":1106.74,"end":1110.43,"text":"‫משלמים רק על מה שצריך ‫ויכולים לחסוך בהוצאות ובדלת."},{"start":1110.43,"end":1113.18,"text":"‫דצ'יה, החשבון פשוט."},{"start":1113.18,"end":1119.73,"text":"‫השקעתם בעיצוב הבית, ‫אז למה להרטיב אותו בתרסיסים רגילים?"},{"start":1119.73,"end":1123.89,"text":"‫הכירו את Airwick Pure, ‫מבשם אוויר בהתזה היבשה"},{"start":1123.89,"end":1128.38,"text":"‫שממלא את הבית וניחוח נהדר, ‫ולא בסימני התזה."},{"start":1128.38,"end":1132.25,"text":"‫Airwick Pure, גם מבשם אוויר אוטומטי, ‫מכשיר ומילוי."},{"start":1132.25,"end":1136.17,"text":"‫שימרו על רעננות הבית ‫כל היום ללא סימני התזה."},{"start":1136.17,"end":1139.4,"text":"‫אירויק, במגוון מוצרים ‫לויסום הבית."},{"start":1139.4,"end":1141.8,"text":"‫כשאתם סובלים מכאב ‫ונפיחות בגרון,"},{"start":1141.8,"end":1143.77,"text":"‫אתם רוצים הקלה יעילה."},{"start":1143.77,"end":1146.01,"text":"‫בדיוק בשביל זה ‫פיתחנו את סטרפן."},{"start":1146.01,"end":1148.65,"text":"‫תראו, הוא משלב משקח ‫כאבים אנטי-דלקתי"},{"start":1148.65,"end":1150.57,"text":"‫עם בעולה מקומית של החסנית מתיצה."},{"start":1150.57,"end":1154.09,"text":"‫כך שסטרפן מתחיל להקל ‫לאחר שתי דקות ועד ארבע שעות."},{"start":1154.09,"end":1156.17,"text":"‫שלום ולא להתראות לכאב הגרון."},{"start":1156.17,"end":1159.81,"text":"‫סטרפן מתחיל להקל ‫אחר שתי דקות ועד ארבע שעות."},{"start":1208.64,"end":1212.09,"text":"‫שארבע."},{"start":1212.09,"end":1214.91,"text":"‫הוא ימות אם לא תחזיר אליו."},{"start":1214.91,"end":1218.35,"text":"‫אנחנו הולכים להתת להם שוב ‫שאם לא ישכחו בחיים שלהם."},{"start":1218.35,"end":1224.35,"text":"‫סוף שבוע ישראלי בערוץ 24. ‫כל סוף שבוע בערוץ 24 יחדש."},{"start":1224.35,"end":1238.88,"text":"‫היכרתי את יואל דרך חברה. ‫היה לנו בליינד אייט."},{"start":1238.88,"end":1245.3,"text":"‫הוא היה ממש נחמד. ‫הוא חור מאוד סימפטי."},{"start":1245.3,"end":1247.84,"text":"‫הכל היה נראה ממש בסדר."},{"start":1247.84,"end":1253.04,"text":"‫אחרי נפגשנו כמה פעמים, ‫פעם שנייה ושלישית,"},{"start":1253.04,"end":1257.72,"text":"‫וניברנו, שוחחנו. ‫הכל היה ממש נחמד."},{"start":1257.72,"end":1261.16,"text":"‫הכל היה נראה ממש בסדר."},{"start":1261.16,"end":1268.22,"text":"‫אחרי חודש בערך עברנו לגור ביחד,"},{"start":1268.22,"end":1275.31,"text":"‫והכל היה ממש בסדר, ‫אני לא יודעת."},{"start":1275.31,"end":1285.41,"text":"‫יום אחד הוא ביקש שאני ‫התחתן איתו,"},{"start":1285.41,"end":1292.05,"text":"‫ואני הסכמתי, ו... ‫אנחנו כבר שנתיים חיים ביחד,"},{"start":1292.05,"end":1296.45,"text":"‫יש לנו ילד מאוד חמות, ‫קטנג'י כזה,"},{"start":1296.45,"end":1298.81,"text":"‫ואנחנו מאוד מאושרים."},{"start":1298.81,"end":1309.07,"text":"‫אני צ'ינג'י עם אופי. ‫תסתכלו איזה יופי."},{"start":1309.07,"end":1313.07,"text":"‫טלטלים של זהב ולניים כוכב."},{"start":1313.07,"end":1318.78,"text":"‫בכיתה הם קוראים לי צ'ינג'י. ‫בבית הם קוראים לי צ'ינג'י."},{"start":1318.78,"end":1321.98,"text":"‫ובלילה בתוך חקרית, ‫\"צ'ינג'י, צ'ינג'י מחמדים\"."},{"start":1321.98,"end":1324.99,"text":"‫תאים זה! ‫מסביק!"},{"start":1324.99,"end":1330.68,"text":"‫אני לא רוצה שתקראו לי צ'ינג'י יותר, ‫כי מי שיקרא לי צ'ינג'י, ‫הואו, מה אני אעשה לו?"},{"start":1330.68,"end":1333.6,"text":"‫אתם לא מכירים אותי. ‫אני אין לי אלוהים."},{"start":1333.6,"end":1339.64,"text":"‫אני דוויק המלך. ‫אבל רק על יונתן אני מרושע ‫לקרוא לי צ'ינג'י."},{"start":1339.64,"end":1423.92,"text":"תודה, תודה, תודה, תודה, תודה, תודה, תודה, תודה."},{"start":1423.94,"end":1444.77,"text":"תודה, תודה, תודה, תודה, תודה, תודה, תודה, תודה."}]