 אה, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא, אלא,

